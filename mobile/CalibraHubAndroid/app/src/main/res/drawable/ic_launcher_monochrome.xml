<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon monochrome katmanı (Android 13+ themed icons / Material You). Aynı kalibrasyon
  kadranı geometrisi (ic_launcher_foreground.xml ile birebir aynı yerleşim — 3 iğne dahil) ama tek
  tonlu — sistem bu katmanı kullanıcının duvar kağıdı temasına göre kendi rengiyle yeniden boyar,
  bu yüzden burada cyan/beyaz/violet çok-tonlu ayrım yerine tek renk (beyaz) + opaklık hiyerarşisi
  kullanılır: ana çentik %100, ara çentik %70; iğneler n1=1.0 / n2=0.7 / n3=0.5 (uzunluk+kalınlık
  hiyerarşisiyle birlikte alpha hiyerarşisi de şekil ayrımını tint sonrası korur).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 0) Gösterge halkası -->
    <path
        android:pathData="M54,54 m-24,0 a24,24 0 1,0 48,0 a24,24 0 1,0 -48,0"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2.2"
        android:strokeAlpha="0.85"
        android:fillColor="#00000000" />

    <!-- 1) 12 çentik — 4 ana (12/3/6/9) + 8 ara -->
    <group android:name="tick_0" android:pivotX="54" android:pivotY="54" android:rotation="0">
        <path android:pathData="M54,22 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="5" android:strokeLineCap="round" />
    </group>
    <group android:name="tick_1" android:pivotX="54" android:pivotY="54" android:rotation="30">
        <path android:pathData="M54,26 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="2.6" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>
    <group android:name="tick_2" android:pivotX="54" android:pivotY="54" android:rotation="60">
        <path android:pathData="M54,26 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="2.6" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>
    <group android:name="tick_3" android:pivotX="54" android:pivotY="54" android:rotation="90">
        <path android:pathData="M54,22 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="5" android:strokeLineCap="round" />
    </group>
    <group android:name="tick_4" android:pivotX="54" android:pivotY="54" android:rotation="120">
        <path android:pathData="M54,26 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="2.6" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>
    <group android:name="tick_5" android:pivotX="54" android:pivotY="54" android:rotation="150">
        <path android:pathData="M54,26 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="2.6" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>
    <group android:name="tick_6" android:pivotX="54" android:pivotY="54" android:rotation="180">
        <path android:pathData="M54,22 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="5" android:strokeLineCap="round" />
    </group>
    <group android:name="tick_7" android:pivotX="54" android:pivotY="54" android:rotation="210">
        <path android:pathData="M54,26 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="2.6" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>
    <group android:name="tick_8" android:pivotX="54" android:pivotY="54" android:rotation="240">
        <path android:pathData="M54,26 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="2.6" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>
    <group android:name="tick_9" android:pivotX="54" android:pivotY="54" android:rotation="270">
        <path android:pathData="M54,22 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="5" android:strokeLineCap="round" />
    </group>
    <group android:name="tick_10" android:pivotX="54" android:pivotY="54" android:rotation="300">
        <path android:pathData="M54,26 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="2.6" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>
    <group android:name="tick_11" android:pivotX="54" android:pivotY="54" android:rotation="330">
        <path android:pathData="M54,26 L54,29" android:strokeColor="#FFFFFFFF" android:strokeWidth="2.6" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>

    <!-- 2) 3 iğne — n1 saat 10 (300°) alpha 1.0, n2 saat 2 (60°) alpha 0.7, n3 saat 6 (180°)
         alpha 0.5; uzunluk/kalınlık hiyerarşisi foreground ile birebir aynı. -->
    <group android:name="needle_n1" android:pivotX="54" android:pivotY="54" android:rotation="300">
        <path android:pathData="M54,35.5 L54,59.5" android:strokeColor="#FFFFFFFF" android:strokeWidth="6.2" android:strokeLineCap="round" android:strokeAlpha="1" />
    </group>
    <group android:name="needle_n2" android:pivotX="54" android:pivotY="54" android:rotation="60">
        <path android:pathData="M54,40 L54,54" android:strokeColor="#FFFFFFFF" android:strokeWidth="4.4" android:strokeLineCap="round" android:strokeAlpha="0.7" />
    </group>
    <group android:name="needle_n3" android:pivotX="54" android:pivotY="54" android:rotation="180">
        <path android:pathData="M54,43.5 L54,54" android:strokeColor="#FFFFFFFF" android:strokeWidth="3" android:strokeLineCap="round" android:strokeAlpha="0.5" />
    </group>

    <!-- 3) Merkez hub -->
    <path
        android:pathData="M54,54 m-6.5,0 a6.5,6.5 0 1,0 13,0 a6.5,6.5 0 1,0 -13,0"
        android:fillColor="#FFFFFFFF" />
</vector>
