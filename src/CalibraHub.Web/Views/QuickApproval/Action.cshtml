@{
    Layout = null;
    var error       = ViewBag.Error       as string;
    var success     = (bool)(ViewBag.Success  ?? false);
    var isApprove   = (bool)(ViewBag.IsApprove ?? false);
    var alreadyUsed = (bool)(ViewBag.AlreadyUsed ?? false);
    var usedAction  = ViewBag.UsedAction  as string;
    var approverName = ViewBag.ApproverName as string;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Onay İşlemi — CalibraHub</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            padding: 24px 16px;
        }
        .card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(0,0,0,.10);
            padding: 40px 36px;
            max-width: 460px;
            width: 100%;
            text-align: center;
        }
        .icon { font-size: 56px; margin-bottom: 18px; line-height: 1; }
        .title { font-size: 1.4rem; font-weight: 700; margin-bottom: 10px; color: #1e293b; }
        .sub   { font-size: 0.92rem; color: #64748b; line-height: 1.6; }
        .badge {
            display: inline-block;
            padding: 6px 18px;
            border-radius: 999px;
            font-size: 0.82rem;
            font-weight: 700;
            margin-bottom: 14px;
        }
        .badge-approve { background: #dcfce7; color: #16a34a; }
        .badge-reject  { background: #fee2e2; color: #dc2626; }
        .badge-warn    { background: #fef9c3; color: #a16207; }
        .badge-error   { background: #fee2e2; color: #991b1b; }
        .msg-box {
            margin-top: 18px;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 0.82rem;
            line-height: 1.5;
        }
        .msg-error  { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; }
        .msg-info   { background: #f0f9ff; border: 1px solid #bae6fd; color: #0369a1; }
        .logo {
            font-size: 0.72rem; font-weight: 600; color: #cbd5e1;
            margin-top: 28px; letter-spacing: .05em;
        }
    </style>
</head>
<body>
    <div class="card">
        @if (success)
        {
            <div class="icon">@(isApprove ? "✅" : "❌")</div>
            <div class="badge @(isApprove ? "badge-approve" : "badge-reject")">
                @(isApprove ? "Onaylandı" : "Reddedildi")
            </div>
            <div class="title">İşlem Tamamlandı</div>
            <div class="sub">
                @if (!string.IsNullOrWhiteSpace(approverName))
                {
                    <span><strong>@approverName</strong> tarafından </span>
                }
                bu onay talebi
                @(isApprove ? "onaylandı" : "reddedildi").
                İlgili kişiler otomatik olarak bilgilendirilecektir.
            </div>
        }
        else if (alreadyUsed)
        {
            <div class="icon">ℹ️</div>
            <div class="badge badge-warn">Zaten İşlendi</div>
            <div class="title">Bu Bağlantı Kullanıldı</div>
            <div class="sub">
                Bu onay bağlantısı daha önce kullanıldı
                @if (!string.IsNullOrWhiteSpace(usedAction))
                {
                    <span>(<strong>@(usedAction == "approve" ? "onaylandı" : "reddedildi")</strong>)</span>
                }.
                Her bağlantı yalnızca bir kez kullanılabilir.
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="icon">⚠️</div>
            <div class="badge badge-error">Hata</div>
            <div class="title">İşlem Yapılamadı</div>
            <div class="msg-box msg-error">@error</div>
        }
        else
        {
            <div class="icon">⏳</div>
            <div class="title">İşleniyor…</div>
        }

        <div class="logo">CalibraHub</div>
    </div>
</body>
</html>
