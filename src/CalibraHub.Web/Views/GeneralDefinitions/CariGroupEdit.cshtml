@model CalibraHub.Web.Models.CariGroupEditViewModel
@{
    var isNew = Model.Id == null;
    ViewData["Title"]    = isNew ? "Yeni Cari Grup" : $"Grup: {Model.Name}";
    ViewData["FormCode"] = "CARI_GROUPS";
    ViewData["BodyClass"] = "page-cge workspace-frame-body";
}

@section Styles {
<style>
.cge-root {
    --cge-bg:      #f1f5f9; --cge-surface: #ffffff; --cge-border: #e2e8f0;
    --cge-text:    #0f172a; --cge-muted:   #64748b; --cge-accent: #6366f1;
    display: flex; align-items: flex-start; justify-content: center;
    flex: 1 1 auto; overflow-y: auto; padding: 32px 16px; background: var(--cge-bg);
}
body.app-theme-dark .cge-root {
    --cge-bg: #080c17; --cge-surface: #0d1323;
    --cge-border: rgba(255,255,255,.09); --cge-text: #e2e8f0; --cge-muted: #94a3b8;
}
.cge-card {
    width: 100%; max-width: 560px; background: var(--cge-surface);
    border: 1px solid var(--cge-border); border-radius: 14px;
    box-shadow: 0 4px 24px rgba(0,0,0,.08); overflow: hidden;
}
.cge-body { padding: 24px; }
.cge-rows { display: flex; flex-direction: column; }
.cge-row {
    display: flex; align-items: center; gap: 16px;
    padding: 10px 0; border-bottom: 1px solid var(--cge-border);
}
.cge-row:last-child { border-bottom: none; }
.cge-row > label:first-child {
    width: 120px; min-width: 120px; flex-shrink: 0;
    font-size: 13px; font-weight: 600; color: var(--cge-muted);
}
.cge-required::after { content: ' *'; color: #ef4444; }
.cge-input {
    padding: 8px 12px; border-radius: 8px;
    background: var(--cge-bg); border: 1px solid var(--cge-border);
    color: var(--cge-text); font-size: 14px;
    transition: border-color .15s; outline: none;
}
.cge-input:focus {
    border-color: var(--cge-accent);
    box-shadow: 0 0 0 3px rgba(99,102,241,.12);
}
.cge-input.is-invalid {
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 3px rgba(239,68,68,.15) !important;
    animation: cgeShake 0.4s ease both;
}
@@keyframes cgeShake {
    10%, 90% { transform: translateX(-2px); }
    20%, 80% { transform: translateX(3px); }
    30%, 50%, 70% { transform: translateX(-3px); }
    40%, 60% { transform: translateX(3px); }
}
.cge-msg { margin-top: 14px; padding: 8px 14px; border-radius: 8px; font-size: 13px; }
.cge-msg.ok  { background: rgba(16,185,129,.1); color: #059669; border: 1px solid rgba(16,185,129,.25); }
.cge-msg.err { background: rgba(239,68,68,.1);  color: #dc2626; border: 1px solid rgba(239,68,68,.25); }
body.app-theme-dark .cge-msg.ok  { color: #34d399; }
body.app-theme-dark .cge-msg.err { color: #f87171; }
/* Confirm modal */
.cge-modal-backdrop {
    position: fixed; inset: 0; z-index: 9990;
    background: rgba(0,0,0,.55); backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
}
.cge-modal {
    background: var(--cge-surface); border: 1px solid var(--cge-border);
    border-radius: 14px; padding: 28px 32px; max-width: 420px; width: 90%;
    box-shadow: 0 20px 60px rgba(0,0,0,.3); text-align: center;
}
.cge-modal-icon { margin-bottom: 12px; display: flex; justify-content: center; }
.cge-modal h2 { font-size: 18px; font-weight: 700; color: var(--cge-text); margin: 0 0 8px; }
.cge-modal p { font-size: 14px; color: var(--cge-muted); margin: 0 0 20px; }
.cge-modal-btns { display: flex; gap: 10px; justify-content: center; }
</style>
}

<div class="ux-edit-shell">
  @await Html.PartialAsync("_CalibraActionBar", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
  {
      ["Title"]       = isNew ? "Yeni Cari Grup" : "Cari Grup Düzenle",
      ["ListUrl"]     = "/GeneralDefinitions/CariGroups",
      ["NewUrl"]      = "/GeneralDefinitions/CariGroupEdit",
      ["SaveBtnId"]   = "cge-save",
      ["DeleteBtnId"] = "cge-delete",
      ["ShowDelete"]  = !isNew,
  })

  <div class="cge-root">
    <div class="cge-card">
        <div class="cge-body">
            <input type="hidden" id="cgeId" value="@Model.Id" />
            <div class="cge-rows">
                <div class="cge-row">
                    <label for="cgeName" class="cge-required">Grup Adi</label>
                    <input id="cgeName" class="cge-input" value="@Model.Name" maxlength="150" style="flex:1 1 auto;min-width:0;" placeholder="orn. Toptan / Perakende / VIP" />
                </div>
                <div class="cge-row">
                    <label for="cgeCategory">Kategori</label>
                    <select id="cgeCategory" class="cge-input" style="width:120px;">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <option value="@i" selected="@(Model.GroupCategory == i)">@i</option>
                        }
                    </select>
                </div>
                <div class="cge-row">
                    <label for="cgeSort">Sira</label>
                    <input id="cgeSort" type="number" class="cge-input" value="@Model.SortOrder" min="0" style="width:120px;" />
                </div>
                <div class="cge-row">
                    <label>Durum</label>
                    <div class="form-check form-switch" style="margin:0;">
                        <input id="cgeIsActive" class="form-check-input" type="checkbox" role="switch" @(Model.IsActive ? "checked" : "") />
                    </div>
                </div>
            </div>
            <div id="cgeMsg"></div>
        </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function () {
    window.cgeSave = function() {
        var nameEl = document.getElementById('cgeName');
        var name = nameEl.value.trim();
        if (!name) { shakeInvalid(nameEl); return; }
        var idVal = document.getElementById('cgeId').value;
        var sortVal = parseInt(document.getElementById('cgeSort').value, 10);
        var catVal = parseInt(document.getElementById('cgeCategory').value, 10);
        var payload = {
            id: idVal ? parseInt(idVal) : null,
            name: name,
            sortOrder: isNaN(sortVal) ? 0 : sortVal,
            isActive: document.getElementById('cgeIsActive').checked,
            groupCategory: isNaN(catVal) ? 1 : catVal
        };
        fetch('/GeneralDefinitions/SaveCariGroupJson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) {
                window.location.href = '/GeneralDefinitions/CariGroups';
            } else {
                cgeMsg(d.message || 'Kaydetme basarisiz.', false);
            }
        })
        .catch(function() { cgeMsg('Sunucu hatasi.', false); });
    };

    window.cgeDelete = function() {
        var id = parseInt(document.getElementById('cgeId').value);
        if (!id) return;
        var name = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Name));
        showConfirm(name).then(function(ok) {
            if (!ok) return;
            fetch('/GeneralDefinitions/DeleteCariGroupJson?id=' + id, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.success) {
                    window.location.href = '/GeneralDefinitions/CariGroups';
                } else {
                    cgeMsg(d.message || 'Silinemedi.', false);
                }
            });
        });
    };

    // Rapor §2.1 — inline showConfirm kaldirildi, global helper kullaniliyor (wwwroot/js/confirm-modal.js)
    // window.showConfirm(name) → ayni davranis (otomatik silme mesaji + danger=true)

    function escHtml(s) {
        if (!s) return '';
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function shakeInvalid(el) {
        el.classList.remove('is-invalid');
        void el.offsetWidth;
        el.classList.add('is-invalid');
        setTimeout(function() { el.classList.remove('is-invalid'); }, 1200);
    }
    ['cgeName'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('input', function() { el.classList.remove('is-invalid'); });
    });

    var _saveBtn = document.getElementById('cge-save');
    if (_saveBtn) _saveBtn.addEventListener('click', window.cgeSave);
    var _deleteBtn = document.getElementById('cge-delete');
    if (_deleteBtn) _deleteBtn.addEventListener('click', window.cgeDelete);

    function cgeMsg(msg, ok) {
        var el = document.getElementById('cgeMsg');
        if (!msg) { el.innerHTML = ''; return; }
        el.innerHTML = '<div class="cge-msg ' + (ok ? 'ok' : 'err') + '">' + escHtml(msg) + '</div>';
        if (ok) setTimeout(function() { el.innerHTML = ''; }, 3000);
    }
})();
</script>
}
