@{
    ViewData["Title"] = "Satis Temsilcileri";
    ViewData["FormCode"] = "SALES_REPS";
    ViewData["BodyClass"] = "page-sales-reps-edit";
    ViewData["DbInfo"] = "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>sales_representatives</td><td style='padding:6px 8px;'>Satis temsilcisi tanimlari (kod, ad, durum)</td></tr>"
        + "</table>";
}

@section Styles {
<style>
    .page-sales-reps-edit .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-sales-reps-edit .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important;
        margin: 0 !important; overflow: hidden !important;
    }
    .workspace-frame-body.page-sales-reps-edit .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-sales-reps-edit .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    /* ── Action bar ─────────────────────── */
    .sr-action-bar {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px; flex-shrink: 0;
        background: rgba(15,15,26,0.85); border-bottom: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    }
    body.app-theme-light .sr-action-bar {
        background: rgba(248,250,252,0.92); border-bottom-color: #e2e8f0;
    }
    .sr-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 14px; border-radius: 8px; border: 1px solid;
        font-size: 0.78rem; font-weight: 600; cursor: pointer;
        transition: all 0.12s ease; background: transparent;
    }
    .sr-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .sr-btn--primary { background: #6366f1; border-color: #4f46e5; color: #fff; }
    .sr-btn--primary:hover:not(:disabled) { background: #4f46e5; }
    .sr-btn--secondary {
        background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.65);
    }
    body.app-theme-light .sr-btn--secondary {
        background: #fff; border-color: #e2e8f0; color: #475569;
    }
    .sr-btn--secondary:hover:not(:disabled) { background: rgba(255,255,255,0.1); color: #fff; }
    body.app-theme-light .sr-btn--secondary:hover:not(:disabled) { background: #f1f5f9; color: #1e293b; }
    .sr-btn--danger {
        background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.25); color: #f87171;
    }
    .sr-btn--danger:hover:not(:disabled) { background: rgba(239,68,68,0.18); }

    /* ── Content ───────────────────────── */
    .sr-content {
        flex: 1 1 auto; min-width: 0; overflow-y: auto;
        padding: 20px 24px; background: transparent;
    }
    body.app-theme-dark .sr-content,
    html.dark .sr-content { background: #0c0f1a; background-image: radial-gradient(at 20% 30%,rgba(99,102,241,0.12) 0px,transparent 50%),radial-gradient(at 80% 20%,rgba(14,165,233,0.08) 0px,transparent 50%),radial-gradient(at 50% 80%,rgba(168,85,247,0.08) 0px,transparent 50%); }
    body.app-theme-light .sr-content { background: #f8fafc; }

    /* ── Card ──────────────────────────── */
    .sr-card {
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 14px; padding: 22px;
        backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
        margin-bottom: 16px;
    }
    body.app-theme-light .sr-card {
        background: rgba(255,255,255,0.8); border-color: rgba(15,23,42,0.08);
        box-shadow: 0 2px 6px rgba(15,23,42,0.04);
    }
    .sr-card-title {
        font-size: 0.85rem; font-weight: 700;
        color: rgba(255,255,255,0.85);
        margin: 0 0 14px 0; display: flex; align-items: center; gap: 8px;
    }
    body.app-theme-light .sr-card-title { color: #64748b; }
    .sr-card-title::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #6366f1; }

    /* ── Form rows ─────────────────────── */
    .sr-rows { display: flex; flex-direction: column; gap: 0; }
    .sr-row {
        display: flex; align-items: center; gap: 16px;
        padding: 9px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .sr-row:last-child { border-bottom: none; }
    body.app-theme-light .sr-row { border-bottom-color: rgba(15,23,42,0.06); }
    .sr-row > label:first-child {
        width: 140px; min-width: 140px; flex-shrink: 0;
        font-size: 0.75rem; font-weight: 600; color: rgba(255,255,255,0.55);
        letter-spacing: 0.02em; text-align: right; padding-right: 4px;
    }
    body.app-theme-light .sr-row > label:first-child { color: #64748b; }
    .sr-input {
        padding: 9px 12px; border-radius: 9px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.85); font-size: 0.85rem;
        transition: border-color 0.15s, background 0.15s;
    }
    body.app-theme-light .sr-input { background: #fff; border-color: #e2e8f0; color: #1e293b; }
    .sr-input:focus {
        outline: none; border-color: #6366f1;
        background: rgba(255,255,255,0.06);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }
    body.app-theme-light .sr-input:focus { background: #fff; }
    .sr-required::after { content: ' *'; color: #f87171; }

    /* ── Search toolbar ────────────────── */
    .sr-search-wrap {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        padding: 10px 14px; border-radius: 10px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 14px;
    }
    body.app-theme-light .sr-search-wrap { background: #fff; border-color: #e2e8f0; }

    /* ── List ──────────────────────────── */
    .sr-list { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .sr-list thead th {
        text-align: left; padding: 8px 10px; font-weight: 600;
        color: rgba(165,180,252,0.85); font-size: 0.72rem;
        text-transform: uppercase; letter-spacing: .03em;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.03); white-space: nowrap;
    }
    body.app-theme-light .sr-list thead th {
        color: rgba(71,85,105,0.7); background: #f8fafc; border-bottom-color: #e2e8f0;
    }
    .sr-list tbody tr {
        border-bottom: 1px solid rgba(255,255,255,0.05);
        cursor: pointer; transition: background .12s;
    }
    body.app-theme-light .sr-list tbody tr { border-bottom-color: rgba(0,0,0,0.05); }
    .sr-list tbody tr:hover { background: rgba(99,102,241,0.08); }
    body.app-theme-light .sr-list tbody tr:hover { background: rgba(99,102,241,0.06); }
    .sr-list tbody tr.is-selected { background: rgba(16,185,129,0.12); }
    body.app-theme-light .sr-list tbody tr.is-selected { background: rgba(16,185,129,0.08); }
    .sr-list td { padding: 7px 10px; color: rgba(255,255,255,0.85); vertical-align: middle; }
    body.app-theme-light .sr-list td { color: #1e293b; }
    .sr-list .sr-list-code { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-weight: 600; color: #a5b4fc; }
    body.app-theme-light .sr-list .sr-list-code { color: #4f46e5; }
    .sr-list-status {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 2px 8px; border-radius: 999px; font-size: 0.68rem; font-weight: 600;
    }
    .sr-list-status.on { background: rgba(16,185,129,0.15); color: #34d399; }
    .sr-list-status.off { background: rgba(148,163,184,0.15); color: #94a3b8; }
    body.app-theme-light .sr-list-status.on { background: rgba(16,185,129,0.1); color: #059669; }
    body.app-theme-light .sr-list-status.off { background: rgba(148,163,184,0.15); color: #64748b; }
    .sr-list-empty { padding: 28px; text-align: center; color: rgba(255,255,255,0.35); font-style: italic; font-size: 0.82rem; }
    body.app-theme-light .sr-list-empty { color: #94a3b8; }

    .act-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; padding: 0;
        border-radius: 5px; border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.65);
        cursor: pointer; margin-right: 3px;
    }
    .act-btn:hover { background: rgba(255,255,255,0.1); }
    .act-btn.primary { color: #a5b4fc; border-color: rgba(129,140,248,.3); }
    .act-btn.danger  { color: #f87171; border-color: rgba(248,113,113,.3); }
    body.app-theme-light .act-btn { background: #fff; border-color: #e2e8f0; color: #475569; }
    body.app-theme-light .act-btn:hover { background: #f1f5f9; }
    body.app-theme-light .act-btn.primary { color: #4f46e5; border-color: #c7d2fe; }
    body.app-theme-light .act-btn.danger  { color: #dc2626; border-color: #fecaca; }

    .sr-msg { padding: 6px 12px; border-radius: 6px; font-size: 0.76rem; margin-top: 10px; }
    .sr-msg.ok  { background: rgba(16,185,129,.1); color: #34d399; border: 1px solid rgba(52,211,153,.25); }
    .sr-msg.err { background: rgba(239,68,68,.1); color: #f87171; border: 1px solid rgba(248,113,113,.25); }

    /* Zorunlu alan bos — kirmizi cerceve + titresim */
    .sr-input.is-invalid {
        border-color: #ef4444 !important;
        background: rgba(239, 68, 68, 0.06) !important;
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.20) !important;
        animation: srShake 0.45s cubic-bezier(.36,.07,.19,.97) both;
    }
    @@keyframes srShake {
        10%, 90% { transform: translateX(-2px); }
        20%, 80% { transform: translateX(3px); }
        30%, 50%, 70% { transform: translateX(-4px); }
        40%, 60% { transform: translateX(4px); }
    }

    /* K.I.T.T. yesil tarayici — action bar alti (save success) */
    .sr-action-bar { position: relative; overflow: hidden; }
    .sr-action-bar::before {
        content: ''; position: absolute;
        left: 0; right: 0; bottom: 0;
        height: 2px;
        pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,
            rgba(0, 60, 20, 0) 0%,
            rgba(10, 120, 40, .55) 50%,
            rgba(0, 60, 20, 0) 100%);
    }
    .sr-action-bar::after {
        content: ''; position: absolute;
        left: 0; bottom: -1px;
        width: 18%; height: 4px;
        pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,
            transparent 0%,
            rgba(34, 197, 94, .35) 18%,
            rgba(74, 255, 140, 1) 50%,
            rgba(34, 197, 94, .35) 82%,
            transparent 100%);
        box-shadow:
            0 0 10px 2px rgba(34, 197, 94, .95),
            0 0 22px 6px rgba(34, 197, 94, .55),
            0 0 40px 12px rgba(34, 197, 94, .22);
        border-radius: 50%;
    }
    .sr-action-bar.is-save-flash::before { animation: srKittBg   1800ms ease-out forwards; }
    .sr-action-bar.is-save-flash::after  { animation: srKittScan 1800ms cubic-bezier(.45,.05,.55,.95) forwards; }
    @@keyframes srKittBg {
        0%, 100% { opacity: 0; }
        10%, 90% { opacity: 1; }
    }
    @@keyframes srKittScan {
        0%   { opacity: 0; left: 0; }
        8%   { opacity: 1; }
        48%  { opacity: 1; left: 82%; }
        52%  { opacity: 1; left: 82%; }
        92%  { opacity: 1; left: 0; }
        100% { opacity: 0; left: 0; }
    }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">

    <!-- Aksiyon seridi -->
    <div class="sr-action-bar" data-no-proxy>
        <button type="button" class="sr-btn sr-btn--primary" onclick="srSave()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Kaydet
        </button>
        <button type="button" class="sr-btn sr-btn--secondary" onclick="srNew()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Yeni
        </button>
        <button type="button" class="sr-btn sr-btn--danger" id="srBtnDelete" disabled onclick="srDelete()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            Sil
        </button>
    </div>

    <div class="sr-content">

        <!-- Form karti -->
        <div class="sr-card">
            <p class="sr-card-title">Satis Temsilcisi Bilgileri</p>
            <div class="sr-rows">
                <div class="sr-row">
                    <label for="srCode" class="sr-required">Kod</label>
                    <input id="srCode" class="sr-input" style="max-width:180px;text-transform:uppercase;" />
                </div>
                <div class="sr-row">
                    <label for="srName" class="sr-required">Ad</label>
                    <input id="srName" class="sr-input" style="flex:1 1 auto;min-width:0;" />
                </div>
                <div class="sr-row">
                    <label for="srIsActive">Durum</label>
                    <div class="form-check form-switch" style="margin:0;">
                        <input id="srIsActive" class="form-check-input" type="checkbox" role="switch" checked />
                    </div>
                </div>
            </div>
            <input type="hidden" id="srId" value="" />
            <div id="srMsg"></div>
        </div>

        <!-- Liste karti -->
        <div class="sr-card">
            <p class="sr-card-title">Tanimli Temsilciler</p>
            <div class="sr-search-wrap">
                <label style="font-size:0.75rem;color:rgba(255,255,255,.55);">Ara</label>
                <input type="text" id="srSearch" class="sr-input" placeholder="Kod veya ada gore ara..." oninput="srLoad()" style="flex:1 1 auto;min-width:200px;" />
            </div>
            <div style="overflow-x:auto;">
                <table class="sr-list">
                    <thead>
                        <tr>
                            <th style="width:70px;"></th>
                            <th style="width:140px;">Kod</th>
                            <th>Ad</th>
                            <th style="width:100px;">Durum</th>
                        </tr>
                    </thead>
                    <tbody id="srBody"></tbody>
                </table>
            </div>
        </div>

    </div>
</section>

@section Scripts {
<script>
(function() {
    var API = function(a) { return '/GeneralDefinitions/' + a; };
    var selId = 0;

    window.srLoad = function() {
        var s = document.getElementById('srSearch').value;
        fetch(API('GetSalesReps') + '?search=' + encodeURIComponent(s))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var body = document.getElementById('srBody');
                if (!data || data.length === 0) {
                    body.innerHTML = '<tr><td colspan="4" class="sr-list-empty">Kayit bulunamadi.</td></tr>';
                    return;
                }
                body.innerHTML = data.map(function(d) {
                    var sel = (d.id === selId) ? ' is-selected' : '';
                    var stCls = d.isActive ? 'on' : 'off';
                    var stTxt = d.isActive ? 'Aktif' : 'Pasif';
                    return '<tr class="' + sel.trim() + '" onclick="srSelect(' + d.id + ')">' +
                        '<td onclick="event.stopPropagation()">' +
                            '<button type="button" class="act-btn primary" title="Duzelt" onclick="srSelect(' + d.id + ')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></button>' +
                            '<button type="button" class="act-btn danger" title="Sil" onclick="srDeleteRow(' + d.id + ')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>' +
                        '</td>' +
                        '<td class="sr-list-code">' + (d.repCode || '') + '</td>' +
                        '<td>' + (d.repName || '') + '</td>' +
                        '<td><span class="sr-list-status ' + stCls + '">' + stTxt + '</span></td>' +
                    '</tr>';
                }).join('');
            });
    };

    window.srSelect = function(id) {
        selId = id;
        fetch(API('GetSalesRep') + '?id=' + id)
            .then(function(r) { return r.json(); })
            .then(function(d) {
                document.getElementById('srId').value = d.id;
                document.getElementById('srCode').value = d.repCode;
                document.getElementById('srName').value = d.repName;
                document.getElementById('srIsActive').checked = d.isActive;
                document.getElementById('srBtnDelete').disabled = false;
                srLoad();
            });
    };

    window.srNew = function() {
        selId = 0;
        document.getElementById('srId').value = '';
        document.getElementById('srCode').value = '';
        document.getElementById('srName').value = '';
        document.getElementById('srIsActive').checked = true;
        document.getElementById('srBtnDelete').disabled = true;
        srMsg('');
        srLoad();
    };

    window.srSave = function() {
        var codeEl = document.getElementById('srCode');
        var nameEl = document.getElementById('srName');
        var code = codeEl.value.trim();
        var name = nameEl.value.trim();
        var invalid = false;
        if (!code) { shakeInvalid(codeEl); invalid = true; }
        if (!name) { shakeInvalid(nameEl); invalid = true; }
        if (invalid) return;

        var payload = {
            id: parseInt(document.getElementById('srId').value) || null,
            repCode: code,
            repName: name,
            isActive: document.getElementById('srIsActive').checked
        };
        fetch(API('SaveSalesRepJson'), { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(payload) })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.success) { flashKitt(); srNew(); }
                else srMsg(d.message || 'Hata', false);
            });
    };

    function shakeInvalid(el) {
        el.classList.remove('is-invalid');
        void el.offsetWidth; // animasyonu yeniden tetikle
        el.classList.add('is-invalid');
        setTimeout(function() { el.classList.remove('is-invalid'); }, 1400);
    }

    // Input'a yazinca invalid sinifini temizle
    ['srCode','srName'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('input', function() { el.classList.remove('is-invalid'); });
    });

    function flashKitt() {
        var bar = document.querySelector('.sr-action-bar');
        if (!bar) return;
        bar.classList.remove('is-save-flash');
        void bar.offsetWidth;
        bar.classList.add('is-save-flash');
        setTimeout(function() { bar.classList.remove('is-save-flash'); }, 1800);
    }

    // Kod alanina var olan bir kod yazilirsa (blur / Tab / Enter) otomatik Ad doldur
    (function initCodeLookup() {
        var codeEl = document.getElementById('srCode');
        if (!codeEl) return;
        function tryLookup() {
            var code = codeEl.value.trim();
            if (!code) return;
            // Zaten duzenleme modundaysak ve kod ayni ise gereksiz
            if ((document.getElementById('srId').value || '') !== '') return;
            fetch(API('GetSalesReps') + '?search=' + encodeURIComponent(code))
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data || data.length === 0) return;
                    var match = data.find(function(d) { return (d.repCode || '').toLowerCase() === code.toLowerCase(); });
                    if (!match) return;
                    selId = match.id;
                    document.getElementById('srId').value = match.id;
                    document.getElementById('srCode').value = match.repCode;
                    document.getElementById('srName').value = match.repName;
                    document.getElementById('srIsActive').checked = !!match.isActive;
                    document.getElementById('srBtnDelete').disabled = false;
                    srLoad();
                });
        }
        codeEl.addEventListener('blur', tryLookup);
        codeEl.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === 'Tab') tryLookup();
        });
    })();

    window.srDelete = function() {
        var id = parseInt(document.getElementById('srId').value);
        if (!id || document.getElementById('srBtnDelete').disabled) return;
        askConfirm('Bu temsilciyi silmek istediginize emin misiniz?', {
            title: 'Temsilci Silinsin Mi?', okText: 'Evet, Sil', danger: true
        }).then(function(ok) {
            if (!ok) return;
            fetch(API('DeleteSalesRepJson') + '?id=' + id, { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(d) {
                    if (d.success) { srMsg('Silindi.', true); srNew(); }
                    else srMsg(d.message || 'Silinemedi', false);
                });
        });
    };

    window.srDeleteRow = function(id) {
        askConfirm('Bu temsilciyi silmek istediginize emin misiniz?', {
            title: 'Temsilci Silinsin Mi?', okText: 'Evet, Sil', danger: true
        }).then(function(ok) {
            if (!ok) return;
            fetch(API('DeleteSalesRepJson') + '?id=' + id, { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.success) srLoad(); });
        });
    };

    function askConfirm(msg, opts) {
        if (window.CalibraAlert && typeof CalibraAlert.confirm === 'function') {
            return CalibraAlert.confirm(msg, opts || {});
        }
        return Promise.resolve(window.confirm(msg));
    }

    function srMsg(msg, ok) {
        var el = document.getElementById('srMsg');
        if (!msg) { el.innerHTML = ''; return; }
        el.innerHTML = '<div class="sr-msg ' + (ok ? 'ok' : 'err') + '">' + msg + '</div>';
        if (ok) setTimeout(function() { el.innerHTML = ''; }, 3000);
    }

    srLoad();
})();
</script>
}
