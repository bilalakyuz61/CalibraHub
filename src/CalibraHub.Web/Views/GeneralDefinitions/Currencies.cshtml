@{
    ViewData["Title"] = "Doviz Tanimlamalari";
    ViewData["FormCode"] = "CURRENCIES";
    ViewData["BodyClass"] = "page-currencies-edit";
    ViewData["DbInfo"] = "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr style='border-bottom:1px solid #e2e8f0;'><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>currencies</td><td style='padding:6px 8px;'>Doviz tanimlari (kod, ad, sembol, durum)</td></tr>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>Exchange</td><td style='padding:6px 8px;'>Kur bilgileri (doviz kodu, tarih, alis/satis, efektif alis/satis, kaynak)</td></tr>"
        + "</table>";
}

@section Styles {
<style>
    .page-currencies-edit .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-currencies-edit .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important;
        margin: 0 !important; overflow: hidden !important;
    }
    .workspace-frame-body.page-currencies-edit .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-currencies-edit .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    /* ── Action bar (MaterialCardEdit ile ayni) ─────────────────────── */
    .cur-action-bar {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px; flex-shrink: 0;
        background: rgba(15,15,26,0.85); border-bottom: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    }
    body.app-theme-light .cur-action-bar {
        background: rgba(248,250,252,0.92); border-bottom-color: #e2e8f0;
    }
    .cur-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 14px; border-radius: 8px; border: 1px solid;
        font-size: 0.78rem; font-weight: 600; cursor: pointer;
        transition: all 0.12s ease; background: transparent;
    }
    .cur-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .cur-btn--primary { background: #6366f1; border-color: #4f46e5; color: #fff; }
    .cur-btn--primary:hover:not(:disabled) { background: #4f46e5; }
    .cur-btn--secondary {
        background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.65);
    }
    body.app-theme-light .cur-btn--secondary {
        background: #fff; border-color: #e2e8f0; color: #475569;
    }
    .cur-btn--secondary:hover:not(:disabled) { background: rgba(255,255,255,0.1); color: #fff; }
    body.app-theme-light .cur-btn--secondary:hover:not(:disabled) { background: #f1f5f9; color: #1e293b; }
    .cur-btn--danger {
        background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.25); color: #f87171;
    }
    .cur-btn--danger:hover:not(:disabled) { background: rgba(239,68,68,0.18); }

    /* ── Body: sidebar + content ─────────────────────────────────── */
    .cur-body { display: flex; flex: 1 1 auto; min-height: 0; overflow: hidden; }

    .cur-sidenav {
        width: 220px; flex-shrink: 0;
        border-right: 1px solid rgba(255,255,255,0.07);
        background: rgba(255,255,255,0.02);
        display: flex; flex-direction: column;
        padding: 10px 8px; gap: 4px; overflow-y: auto;
    }
    body.app-theme-light .cur-sidenav { background: #f8fafc; border-right-color: #e2e8f0; }
    .cur-sidenav-label {
        font-size: 0.7rem; font-weight: 700;
        color: rgba(255,255,255,0.55);
        padding: 6px 8px 2px; margin-top: 6px;
    }
    .cur-sidenav-label:first-child { margin-top: 0; }
    body.app-theme-light .cur-sidenav-label { color: #94a3b8; }
    .cur-nav-btn {
        display: flex; align-items: center; gap: 8px;
        width: 100%; padding: 8px 12px;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 8px;
        color: rgba(255,255,255,0.6);
        font-size: 0.76rem; font-weight: 500; text-align: left;
        cursor: pointer; transition: all 0.15s; line-height: 1.35;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    body.app-theme-light .cur-nav-btn {
        color: #64748b; background: #f1f5f9; border-color: #e2e8f0;
    }
    .cur-nav-btn:hover {
        background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85);
        border-color: rgba(255,255,255,0.15);
    }
    body.app-theme-light .cur-nav-btn:hover { background: #e2e8f0; color: #1e293b; border-color: #cbd5e1; }
    .cur-nav-btn.is-active {
        background: rgba(16,185,129,0.12);
        border-color: rgba(16,185,129,0.35);
        color: #34d399; font-weight: 600;
    }
    body.app-theme-light .cur-nav-btn.is-active {
        background: rgba(16,185,129,0.1);
        border-color: rgba(16,185,129,0.3);
        color: #059669;
    }
    /* Malzeme Kartı sol-menü paritesi (2026-07-11): ring→dolu+glow. Boyut 8x8, aktif buton renk/border değişmez. */
    .cur-nav-dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
        background: transparent; border: 1.5px solid #cbd5e1; transition: all .18s;
    }
    .cur-nav-btn:hover .cur-nav-dot { border-color: #94a3b8; }
    .cur-nav-btn.is-active .cur-nav-dot { background: #6366f1; border-color: #6366f1; box-shadow: 0 0 7px rgba(99,102,241,.5); }
    body.app-theme-dark .cur-nav-dot { border-color: rgba(255,255,255,.24); }
    body.app-theme-dark .cur-nav-btn:hover .cur-nav-dot { border-color: rgba(255,255,255,.48); }
    body.app-theme-dark .cur-nav-btn.is-active .cur-nav-dot { background: #6366f1; border-color: #6366f1; box-shadow: 0 0 7px rgba(99,102,241,.55); }

    .cur-content {
        flex: 1 1 auto; min-width: 0; overflow-y: auto;
        padding: 20px 24px;
        background: transparent;
        position: relative;
    }
    body.app-theme-dark .cur-content { background: #0c0f1a; background-image: radial-gradient(at 20% 30%,rgba(99,102,241,0.12) 0px,transparent 50%),radial-gradient(at 80% 20%,rgba(14,165,233,0.08) 0px,transparent 50%),radial-gradient(at 50% 80%,rgba(168,85,247,0.08) 0px,transparent 50%); }
    body.app-theme-light .cur-content { background: #f8fafc; }

    /* ── Card (MaterialCardEdit mce-card ile uyumlu) ─────────────── */
    .cur-card {
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 14px; padding: 22px;
        backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
        margin-bottom: 16px;
    }
    body.app-theme-light .cur-card {
        background: rgba(255,255,255,0.8); border-color: rgba(15,23,42,0.08);
        box-shadow: 0 2px 6px rgba(15,23,42,0.04);
    }
    .cur-card-title {
        font-size: 0.85rem; font-weight: 700;
        color: rgba(255,255,255,0.85);
        margin: 0 0 14px 0; display: flex; align-items: center; gap: 8px;
    }
    body.app-theme-light .cur-card-title { color: #64748b; }
    .cur-card-title::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #6366f1; }
    /* Serbest (inline-style) filtre etiketleri icin tema-uyumlu degisken. */
    body.app-theme-light { --cur-t55: #64748b; }

    /* ── Form rows ─────────────────────────────────────────────── */
    .cur-rows { display: flex; flex-direction: column; gap: 0; }
    .cur-row {
        display: flex; align-items: center; gap: 16px;
        padding: 9px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .cur-row:last-child { border-bottom: none; }
    body.app-theme-light .cur-row { border-bottom-color: rgba(15,23,42,0.06); }
    .cur-row > label:first-child {
        width: 140px; min-width: 140px; flex-shrink: 0;
        font-size: 0.75rem; font-weight: 600; color: rgba(255,255,255,0.55);
        letter-spacing: 0.02em; text-align: right; padding-right: 4px;
    }
    body.app-theme-light .cur-row > label:first-child { color: #64748b; }
    .cur-input, .cur-select {
        padding: 9px 12px; border-radius: 9px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.85); font-size: 0.85rem;
        transition: border-color 0.15s, background 0.15s;
    }
    body.app-theme-light .cur-input,
    body.app-theme-light .cur-select { background: #fff; border-color: #e2e8f0; color: #1e293b; }
    .cur-input:focus, .cur-select:focus {
        outline: none; border-color: #6366f1;
        background: rgba(255,255,255,0.06);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }
    body.app-theme-light .cur-input:focus, body.app-theme-light .cur-select:focus { background: #fff; }
    .cur-select option { background: #0d1117; color: rgba(255,255,255,0.85); }
    body.app-theme-light .cur-select option { background: #ffffff; color: #1e293b; }
    .cur-required::after { content: ' *'; color: #f87171; }

    /* ── Currency list (Sekme 1) ─────────────────────────────────── */
    .cur-list-wrap {
        margin-top: 18px; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 14px;
    }
    body.app-theme-light .cur-list-wrap { border-top-color: rgba(15,23,42,0.08); }
    .cur-list-title {
        font-size: 0.72rem; font-weight: 700; letter-spacing: .04em;
        color: rgba(255,255,255,0.55); margin: 0 0 10px 0;
    }
    body.app-theme-light .cur-list-title { color: #64748b; }
    .cur-list { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .cur-list thead th {
        text-align: left; padding: 8px 10px; font-weight: 600;
        color: rgba(165,180,252,0.85); font-size: 0.72rem;
        letter-spacing: .03em;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.03); white-space: nowrap;
    }
    body.app-theme-light .cur-list thead th {
        color: rgba(71,85,105,0.7); background: #f8fafc; border-bottom-color: #e2e8f0;
    }
    .cur-list tbody tr {
        border-bottom: 1px solid rgba(255,255,255,0.05); cursor: pointer;
        transition: background .12s;
    }
    body.app-theme-light .cur-list tbody tr { border-bottom-color: rgba(0,0,0,0.05); }
    .cur-list tbody tr:hover { background: rgba(99,102,241,0.08); }
    body.app-theme-light .cur-list tbody tr:hover { background: rgba(99,102,241,0.06); }
    .cur-list tbody tr.is-selected { background: rgba(16,185,129,0.12); }
    body.app-theme-light .cur-list tbody tr.is-selected { background: rgba(16,185,129,0.08); }
    .cur-list td { padding: 7px 10px; color: rgba(255,255,255,0.85); vertical-align: middle; }
    body.app-theme-light .cur-list td { color: #1e293b; }
    .cur-list .cur-list-code { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-weight: 600; color: #a5b4fc; }
    body.app-theme-light .cur-list .cur-list-code { color: #4f46e5; }
    .cur-list .cur-list-status {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 2px 8px; border-radius: 999px; font-size: 0.68rem; font-weight: 600;
    }
    .cur-list .cur-list-status.on { background: rgba(16,185,129,0.15); color: #34d399; }
    .cur-list .cur-list-status.off { background: rgba(148,163,184,0.15); color: #94a3b8; }
    body.app-theme-light .cur-list .cur-list-status.on { background: rgba(16,185,129,0.1); color: #059669; }
    body.app-theme-light .cur-list .cur-list-status.off { background: rgba(148,163,184,0.15); color: #64748b; }
    .cur-list-empty { padding: 24px; text-align: center; color: rgba(255,255,255,0.35); font-style: italic; font-size: 0.82rem; }
    body.app-theme-light .cur-list-empty { color: #94a3b8; }

    /* ── Toplu TCMB butonu ─────────────────────────────────────── */
    .btn-tcmb {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 9px 16px; font-size: 0.8rem; font-weight: 600;
        border-radius: 8px; border: 1px solid rgba(99,102,241,.35);
        background: rgba(99,102,241,.08); color: #a5b4fc;
        cursor: pointer; transition: all .15s;
    }
    .btn-tcmb:hover { background: rgba(99,102,241,.18); border-color: rgba(99,102,241,.55); }
    body.app-theme-light .btn-tcmb { color: #4f46e5; background: rgba(99,102,241,.06); border-color: rgba(99,102,241,.3); }
    body.app-theme-light .btn-tcmb:hover { background: rgba(99,102,241,.12); }

    /* ── Rate filter toolbar ──────────────────────────────────── */
    .cur-rate-toolbar {
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        padding: 10px 14px; border-radius: 10px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        margin-bottom: 14px;
    }
    body.app-theme-light .cur-rate-toolbar { background: #fff; border-color: #e2e8f0; }
    .cur-rate-toolbar .cur-input, .cur-rate-toolbar .cur-select { padding: 7px 10px; font-size: 0.78rem; }

    /* ── Rate grid ────────────────────────────────────────────── */
    .cur-grid { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
    .cur-grid thead th {
        text-align: left; padding: 8px 10px; font-weight: 600;
        color: rgba(165,180,252,0.85); font-size: 0.72rem;
        letter-spacing: .03em;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.03); white-space: nowrap;
    }
    body.app-theme-light .cur-grid thead th {
        color: rgba(71,85,105,0.7); background: #f8fafc;
        border-bottom-color: #e2e8f0;
    }
    .cur-grid tbody tr { border-bottom: 1px solid rgba(255,255,255,0.05); }
    body.app-theme-light .cur-grid tbody tr { border-bottom-color: rgba(0,0,0,0.05); }
    .cur-grid tbody tr:hover { background: rgba(255,255,255,0.03); }
    body.app-theme-light .cur-grid tbody tr:hover { background: #f8fafc; }
    .cur-grid td { padding: 6px 10px; color: rgba(255,255,255,0.85); vertical-align: middle; }
    body.app-theme-light .cur-grid td { color: #1e293b; }
    .cur-rate { font-variant-numeric: tabular-nums; text-align: right; }
    /* ── Onceki kur + degisim gostergesi (kur degerinin solunda) ─ */
    .cur-trend-prev {
        font-size: 0.68rem; font-variant-numeric: tabular-nums;
        color: rgba(255,255,255,0.32); margin-right: 6px;
    }
    body.app-theme-light .cur-trend-prev { color: #94a3b8; }
    .cur-trend-delta {
        font-size: 0.68rem; font-weight: 600; margin-right: 8px;
        font-variant-numeric: tabular-nums;
    }
    .cur-trend-delta.up   { color: #10b981; }
    .cur-trend-delta.down { color: #ef4444; }
    .cur-trend-delta.eq   { color: rgba(255,255,255,0.3); }
    body.app-theme-light .cur-trend-delta.eq { color: #94a3b8; }
    .cur-doviz-name { font-size: 0.74rem; color: rgba(255,255,255,0.55); }
    body.app-theme-light .cur-doviz-name { color: #64748b; }
    .cur-rate-date { font-size: 0.74rem; color: rgba(255,255,255,0.55); }
    body.app-theme-light .cur-rate-date { color: #64748b; }
    .cur-empty { text-align: center; padding: 32px; color: rgba(255,255,255,0.35); font-style: italic; }
    body.app-theme-light .cur-empty { color: #94a3b8; }

    /* ── Action buttons on rate rows ──────────────────────────── */
    .act-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; padding: 0;
        border-radius: 5px; border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.65);
        cursor: pointer; margin-right: 3px;
    }
    .act-btn:hover { background: rgba(255,255,255,0.1); }
    .act-btn.primary { color: #a5b4fc; border-color: rgba(129,140,248,.3); }
    .act-btn.danger  { color: #f87171; border-color: rgba(248,113,113,.3); }
    body.app-theme-light .act-btn { background: #fff; border-color: #e2e8f0; color: #475569; }
    body.app-theme-light .act-btn:hover { background: #f1f5f9; }
    body.app-theme-light .act-btn.primary { color: #4f46e5; border-color: #c7d2fe; }
    body.app-theme-light .act-btn.danger  { color: #dc2626; border-color: #fecaca; }

    .cur-inline-input {
        width: 90px; padding: 3px 6px; font-size: 0.76rem;
        text-align: right; height: 26px; border-radius: 5px;
        font-variant-numeric: tabular-nums;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.15);
        color: rgba(255,255,255,0.9); color-scheme: dark;
    }
    body.app-theme-light .cur-inline-input {
        background: #fff; border-color: #e2e8f0; color: #1e293b; color-scheme: light;
    }

    /* ── Loading + msg ───────────────────────────────────────── */
    .cur-loading {
        display: none; position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 10;
        background: rgba(12,15,26,0.6); align-items: center; justify-content: center;
    }
    body.app-theme-light .cur-loading { background: rgba(248,250,252,0.7); }
    .cur-loading.is-active { display: flex; }
    .cur-spinner { width: 32px; height: 32px; border: 3px solid rgba(255,255,255,0.12); border-top-color: #818cf8; border-radius: 50%; animation: curSpin .7s linear infinite; }
    @@keyframes curSpin { to { transform: rotate(360deg); } }

    .cur-msg { padding: 6px 12px; border-radius: 6px; font-size: 0.76rem; margin-top: 10px; }
    .cur-msg.ok { background: rgba(16,185,129,.1);  color: #34d399; border: 1px solid rgba(52,211,153,.25); }
    .cur-msg.err { background: rgba(239,68,68,.1);  color: #f87171; border: 1px solid rgba(248,113,113,.25); }

    body.app-theme-dark input[type="date"].cur-input { color-scheme: dark; }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">

    <!-- Aksiyon Seridi -->
    <div class="cur-action-bar" data-no-proxy>
        <button type="button" class="cur-btn cur-btn--primary" onclick="crSave()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Kaydet
        </button>
        <button type="button" class="cur-btn cur-btn--secondary" onclick="crNew()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Yeni
        </button>
        <button type="button" class="cur-btn cur-btn--danger" id="crBtnDelete" disabled onclick="crDeleteCurrency()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            Sil
        </button>
    </div>

    <div class="cur-body">

        <!-- Sol navigasyon -->
        <nav class="cur-sidenav" aria-label="Bolumler">
            <span class="cur-sidenav-label">Genel</span>
            <button type="button" class="cur-nav-btn is-active" id="curNavDefinition" data-nav-target="curDefinitionCard">
                <span class="cur-nav-dot"></span>
                Doviz Tanimlamalari
            </button>
            <button type="button" class="cur-nav-btn" id="curNavRates" data-nav-target="curRatesCard">
                <span class="cur-nav-dot"></span>
                Kur Bilgileri
            </button>
        </nav>

        <!-- Sag icerik -->
        <div class="cur-content" id="curContent">

            <!-- Sekme 1: Doviz Tanimlamalari -->
            <div class="cur-card" id="curDefinitionCard">
                <p class="cur-card-title">Doviz Tanimlamalari</p>
                <div class="cur-rows">
                    <div class="cur-row">
                        <label for="crCode" class="cur-required">Kod</label>
                        <input id="crCode" class="cur-input" style="text-transform:uppercase;max-width:110px;" placeholder="TCMB kodu" />
                    </div>
                    <div class="cur-row">
                        <label for="crName" class="cur-required">Ad</label>
                        <input id="crName" class="cur-input" style="flex:1 1 auto;min-width:0;" />
                    </div>
                    <div class="cur-row">
                        <label for="crSymbol">Sembol</label>
                        <input id="crSymbol" class="cur-input" style="max-width:80px;" />
                    </div>
                    <div class="cur-row">
                        <label for="crIsActive">Durum</label>
                        <div class="form-check form-switch" style="margin:0;">
                            <input id="crIsActive" class="form-check-input" type="checkbox" role="switch" checked />
                        </div>
                    </div>
                </div>
                <input type="hidden" id="crId" value="" />
                <div id="crMsg"></div>

                <!-- Tanimli dovizler listesi -->
                <div class="cur-list-wrap">
                    <p class="cur-list-title">Tanimli Dovizler</p>
                    <div style="overflow-x:auto;">
                        <table class="cur-list">
                            <thead>
                                <tr>
                                    <th style="width:90px;">Kod</th>
                                    <th>Ad</th>
                                    <th style="width:70px;">Sembol</th>
                                    <th style="width:100px;">Durum</th>
                                </tr>
                            </thead>
                            <tbody id="crDefList"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Sekme 2: Kur Bilgileri -->
            <div class="cur-card" id="curRatesCard" style="display:none;position:relative;">
                <p class="cur-card-title">Kur Bilgileri</p>

                <!-- Toplu TCMB cekme -->
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;padding:12px 14px;border-radius:10px;background:rgba(99,102,241,.04);border:1px solid rgba(99,102,241,.18);margin-bottom:16px;">
                    <span style="font-size:0.72rem;font-weight:700;color:rgba(165,180,252,.85);letter-spacing:.04em;">Toplu TCMB Kur</span>
                    <label style="font-size:0.75rem;color:var(--cur-t55, rgba(255,255,255,.55));">Baslangic</label>
                    <input type="date" id="crBulkFrom" class="cur-input" style="max-width:150px;" />
                    <label style="font-size:0.75rem;color:var(--cur-t55, rgba(255,255,255,.55));">Bitis</label>
                    <input type="date" id="crBulkTo" class="cur-input" style="max-width:150px;" />
                    <button type="button" class="btn-tcmb" onclick="crFetchTcmb()">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 17 12 21 16 17"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.88 18.09A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.29"/></svg>
                        Toplu Kur Cek
                    </button>
                </div>

                <!-- Filtre -->
                <div class="cur-rate-toolbar">
                    <label style="font-size:0.75rem;color:var(--cur-t55, rgba(255,255,255,.55));">Doviz</label>
                    <select id="crFilterCode" class="cur-select" style="min-width:120px;" onchange="crLoadRates()"></select>
                    <label style="font-size:0.75rem;color:var(--cur-t55, rgba(255,255,255,.55));">Baslangic</label>
                    <input type="date" id="crFromDate" class="cur-input" style="max-width:150px;" onchange="crLoadRates()" />
                    <label style="font-size:0.75rem;color:var(--cur-t55, rgba(255,255,255,.55));">Bitis</label>
                    <input type="date" id="crToDate" class="cur-input" style="max-width:150px;" onchange="crLoadRates()" />
                </div>

                <!-- Kur listesi -->
                <div style="overflow-x:auto;">
                    <table class="cur-grid">
                        <thead>
                            <tr>
                                <th style="width:90px;"></th>
                                <th>Kod</th>
                                <th>Doviz</th>
                                <th>Tarih</th>
                                <th style="text-align:right;">Dvz Alis</th>
                                <th style="text-align:right;">Dvz Satis</th>
                                <th style="text-align:right;">Eff Alis</th>
                                <th style="text-align:right;">Eff Satis</th>
                            </tr>
                        </thead>
                        <tbody id="crRateBody"></tbody>
                    </table>
                </div>

                <div class="cur-loading" id="crLoading"><div class="cur-spinner"></div></div>
            </div>

        </div>
    </div>
</section>

@section Scripts {
<script>
(function() {
    var API = function(action) { return '/GeneralDefinitions/' + action; };
    var currencies = [];
    var today = new Date().toISOString().split('T')[0];

    document.getElementById('crFromDate').value = today;
    document.getElementById('crToDate').value = today;
    document.getElementById('crBulkFrom').value = today.substring(0,8) + '01';
    document.getElementById('crBulkTo').value = today;

    // ── Sekme navigasyon ────────────────────────────────────
    (function initNav() {
        var btns = document.querySelectorAll('.cur-nav-btn');
        btns.forEach(function(btn) {
            btn.addEventListener('click', function() {
                btns.forEach(function(b) { b.classList.remove('is-active'); });
                btn.classList.add('is-active');
                var target = btn.getAttribute('data-nav-target');
                document.querySelectorAll('.cur-card').forEach(function(c) {
                    c.style.display = (c.id === target) ? '' : 'none';
                });
                if (target === 'curRatesCard') crLoadRates();
            });
        });
    })();

    // Init
    loadCurrencies().then(function() { crLoadRates(); });

    function loadCurrencies() {
        return fetch(API('GetCurrencies')).then(function(r) { return r.json(); }).then(function(data) {
            currencies = data;
            var sel = document.getElementById('crFilterCode');
            sel.innerHTML = '<option value="">Tumu</option>' + data.map(function(c) {
                return '<option value="' + c.code + '">' + c.code + '</option>';
            }).join('');
            renderDefList();
        });
    }

    function renderDefList() {
        var body = document.getElementById('crDefList');
        if (!body) return;
        if (!currencies || currencies.length === 0) {
            body.innerHTML = '<tr><td colspan="4" class="cur-list-empty">Henuz tanimli doviz yok.</td></tr>';
            return;
        }
        var selId = parseInt(document.getElementById('crId').value) || 0;
        body.innerHTML = currencies.map(function(c) {
            var sel = (c.id === selId) ? ' is-selected' : '';
            var stCls = c.isActive ? 'on' : 'off';
            var stTxt = c.isActive ? 'Aktif' : 'Pasif';
            return '<tr class="cur-list-row' + sel + '" data-id="' + c.id + '" onclick="crSelectCurrency(' + c.id + ')">' +
                '<td class="cur-list-code">' + (c.code || '') + '</td>' +
                '<td>' + (c.name || '') + '</td>' +
                '<td>' + (c.symbol || '') + '</td>' +
                '<td><span class="cur-list-status ' + stCls + '">' + stTxt + '</span></td>' +
                '</tr>';
        }).join('');
    }

    window.crSelectCurrency = function(id) {
        var c = currencies.find(function(x) { return x.id === id; });
        if (!c) return;
        document.getElementById('crId').value = c.id;
        document.getElementById('crCode').value = c.code || '';
        document.getElementById('crName').value = c.name || '';
        document.getElementById('crSymbol').value = c.symbol || '';
        document.getElementById('crIsActive').checked = !!c.isActive;
        document.getElementById('crBtnDelete').disabled = false;
        document.querySelectorAll('#crDefList tr').forEach(function(tr) { tr.classList.remove('is-selected'); });
        var row = document.querySelector('#crDefList tr[data-id="' + id + '"]');
        if (row) row.classList.add('is-selected');
    };

    window.crLoadRates = function() {
        var code = document.getElementById('crFilterCode').value;
        var from = document.getElementById('crFromDate').value;
        var to = document.getElementById('crToDate').value;
        showLoading(true);
        fetch(API('GetRates') + '?filterCode=' + encodeURIComponent(code) + '&fromDate=' + from + '&toDate=' + to)
            .then(function(r) { return r.json(); })
            .then(function(data) { renderRates(data); showLoading(false); })
            .catch(function() { showLoading(false); });
    };

    var INP = 'type="number" step="0.0001" min="0" class="cur-inline-input"';

    function renderRates(rates) {
        var body = document.getElementById('crRateBody');
        if (rates.length === 0) {
            body.innerHTML = '<tr><td colspan="8" class="cur-empty">Kur bilgisi bulunamadi.</td></tr>';
            return;
        }
        body.innerHTML = rates.map(function(r) { return renderRateRow(r, false); }).join('');
    }

    function renderRateRow(r, editing) {
        var actBtns = editing
            ? '<button type="button" class="act-btn primary" title="Kaydet" onclick="crSaveInlineRate(this,\'' + r.currencyCode + '\',\'' + r.rateDate + '\')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></button>' +
              '<button type="button" class="act-btn" title="Iptal" onclick="crCancelInlineRate(this,\'' + r.currencyCode + '\',\'' + r.rateDate + '\')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>'
            : '<button type="button" class="act-btn primary" title="Duzelt" onclick="crEditRateInline(this,\'' + r.currencyCode + '\',\'' + r.rateDate + '\')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></button>' +
              '<button type="button" class="act-btn danger" title="Sil" onclick="crDeleteRate(\'' + r.currencyCode + '\',\'' + r.rateDate + '\')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>';

        var buyCell    = editing ? '<input ' + INP + ' value="' + (r.buyingRate || 0) + '" data-field="buying" />'    : fmtTrend(r.buyingRate, r.prevBuyingRate, r.prevRateDateDisplay) + '<span class="cur-rate">' + fmtRate(r.buyingRate) + '</span>';
        var sellCell   = editing ? '<input ' + INP + ' value="' + (r.sellingRate || 0) + '" data-field="selling" />'   : fmtTrend(r.sellingRate, r.prevSellingRate, r.prevRateDateDisplay) + '<span class="cur-rate">' + fmtRate(r.sellingRate) + '</span>';
        var effBuyCell = editing ? '<input ' + INP + ' value="' + (r.effectiveBuyingRate || 0) + '" data-field="effbuying" />'  : fmtTrend(r.effectiveBuyingRate, r.prevEffectiveBuyingRate, r.prevRateDateDisplay) + '<span class="cur-rate">' + (r.effectiveBuyingRate > 0 ? fmtRate(r.effectiveBuyingRate) : '-') + '</span>';
        var effSellCell= editing ? '<input ' + INP + ' value="' + (r.effectiveSellingRate || 0) + '" data-field="effselling" />' : fmtTrend(r.effectiveSellingRate, r.prevEffectiveSellingRate, r.prevRateDateDisplay) + '<span class="cur-rate">' + (r.effectiveSellingRate > 0 ? fmtRate(r.effectiveSellingRate) : '-') + '</span>';

        return '<tr data-code="' + r.currencyCode + '" data-date="' + r.rateDate + '">' +
            '<td style="white-space:nowrap;">' + actBtns + '</td>' +
            '<td style="font-weight:600;">' + r.currencyCode + '</td>' +
            '<td class="cur-doviz-name">' + (r.currencyName || '') + '</td>' +
            '<td class="cur-rate-date">' + r.rateDateDisplay + '</td>' +
            '<td class="cur-rate">' + buyCell + '</td>' +
            '<td class="cur-rate">' + sellCell + '</td>' +
            '<td class="cur-rate">' + effBuyCell + '</td>' +
            '<td class="cur-rate">' + effSellCell + '</td>' +
            '</tr>';
    }

    window.crEditRateInline = function(btn, code, rateDate) {
        var tr = btn.closest('tr');
        var cells = tr.querySelectorAll('td');
        var buyVal    = parseFloat(cells[4].textContent.replace(',','.')) || 0;
        var sellVal   = parseFloat(cells[5].textContent.replace(',','.')) || 0;
        var effBuyVal = cells[6].textContent.trim() === '-' ? 0 : (parseFloat(cells[6].textContent.replace(',','.')) || 0);
        var effSellVal= cells[7].textContent.trim() === '-' ? 0 : (parseFloat(cells[7].textContent.replace(',','.')) || 0);
        var nameText  = cells[2].textContent;
        var dateText  = cells[3].textContent;
        var r = { currencyCode: code, currencyName: nameText, rateDate: rateDate, rateDateDisplay: dateText,
            buyingRate: buyVal, sellingRate: sellVal, effectiveBuyingRate: effBuyVal, effectiveSellingRate: effSellVal };
        tr.outerHTML = renderRateRow(r, true);
        var newTr = document.querySelector('tr[data-code="' + code + '"][data-date="' + rateDate + '"]');
        if (newTr) { var inp = newTr.querySelector('input'); if (inp) inp.focus(); }
    };

    window.crSaveInlineRate = function(btn, code, rateDate) {
        var tr = btn.closest('tr');
        var get = function(f) { return parseFloat(tr.querySelector('[data-field="' + f + '"]').value) || 0; };
        var payload = { currencyCode: code, rateDate: rateDate,
            buyingRate: get('buying'), sellingRate: get('selling'),
            effectiveBuyingRate: get('effbuying'), effectiveSellingRate: get('effselling') };
        btn.disabled = true;
        fetch(API('SaveRateJson'), { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.success) { crLoadRates(); }
                else { showMsg(d.message || 'Hata', false); btn.disabled = false; }
            })
            .catch(function() { showMsg('Baglanti hatasi', false); btn.disabled = false; });
    };

    window.crCancelInlineRate = function() { crLoadRates(); };

    window.crNew = function() {
        document.getElementById('crId').value = '';
        document.getElementById('crCode').value = '';
        document.getElementById('crName').value = '';
        document.getElementById('crSymbol').value = '';
        document.getElementById('crIsActive').checked = true;
        document.getElementById('crBtnDelete').disabled = true;
        showMsg('');
    };

    // Standart kirmizi titresim — proje genelinde kullanilan cb-invalid-shake class'i
    function crShakeInvalid(ids) {
        ids.forEach(function (id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.classList.remove('cb-invalid-shake');
            void el.offsetWidth; // reflow — animasyonu yeniden tetikle
            el.classList.add('cb-invalid-shake');
            setTimeout(function () { el.classList.remove('cb-invalid-shake'); }, 550);
        });
        var first = document.getElementById(ids[0]);
        if (first) first.focus({ preventScroll: true });
    }

    window.crSave = function() {
        var codeEl = document.getElementById('crCode');
        var nameEl = document.getElementById('crName');
        var code = (codeEl.value || '').trim();
        var name = (nameEl.value || '').trim();

        // Zorunlu alanlar bos — text mesaj yerine kirmizi titresim
        var invalid = [];
        if (!code) invalid.push('crCode');
        if (!name) invalid.push('crName');
        if (invalid.length > 0) { crShakeInvalid(invalid); return; }

        var payload = {
            id: parseInt(document.getElementById('crId').value) || null,
            code: code,
            name: name,
            symbol: document.getElementById('crSymbol').value,
            isActive: document.getElementById('crIsActive').checked
        };
        fetch(API('SaveCurrencyJson'), { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(payload) })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.success) { crNew(); loadCurrencies().then(function() { crLoadRates(); }); }
                else showMsg(d.message || 'Hata', false);
            });
    };

    window.crDeleteCurrency = function() {
        var id = parseInt(document.getElementById('crId').value);
        if (!id || document.getElementById('crBtnDelete').disabled) return;
        askConfirm('Bu dovizi silmek istediginize emin misiniz? Tum kur bilgileri de silinecektir.', {
            title: 'Doviz Silinsin Mi?', okText: 'Evet, Sil', danger: true
        }).then(function(ok) {
            if (!ok) return;
            fetch(API('DeleteCurrencyJson') + '?id=' + id, { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(d) {
                    if (d.success) { showMsg('Silindi.', true); crNew(); loadCurrencies().then(function() { crLoadRates(); }); }
                    else showMsg(d.message || 'Silinemedi', false);
                });
        });
    };

    window.crDeleteRate = function(code, date) {
        askConfirm('Bu kuru silmek istediginize emin misiniz?', {
            title: 'Kur Silinsin Mi?', okText: 'Evet, Sil', danger: true
        }).then(function(ok) {
            if (!ok) return;
            fetch(API('DeleteRateJson') + '?currencyCode=' + code + '&rateDate=' + date, { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(d) { if (d.success) crLoadRates(); });
        });
    };

    function askConfirm(msg, opts) {
        if (window.CalibraAlert && typeof CalibraAlert.confirm === 'function') {
            return CalibraAlert.confirm(msg, opts || {});
        }
        return Promise.resolve(window.confirm(msg));
    }

    window.crFetchTcmb = function() {
        var from = document.getElementById('crBulkFrom').value;
        var to = document.getElementById('crBulkTo').value;
        showLoading(true);
        fetch(API('FetchTcmbRatesJson') + '?fromDate=' + from + '&toDate=' + to, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                showLoading(false);
                showMsg(d.message || (d.success ? 'Tamamlandi.' : 'Kur bilgisi alinamadi.'), d.success);
                // Başarı/başarısızlıktan bağımsız: filtre tarihlerini bulk aralığıyla
                // senkronize et ve listeyi yenile (veriler kısmen kaydedilmiş olabilir).
                document.getElementById('crFromDate').value = from;
                document.getElementById('crToDate').value = to;
                crLoadRates();
            })
            .catch(function() { showLoading(false); showMsg('TCMB ile baglanti kurulamadi. Internet baglantinizi kontrol edin.', false); });
    };

    function fmtRate(v) { return v ? v.toFixed(4) : '-'; }
    function fmtTrend(cur, prev, prevDate) {
        if (!cur || cur <= 0) return '';
        if (prev == null || prev <= 0) return '';
        var delta = cur - prev;
        var prevStr = prev.toFixed(4);
        var title = prevDate ? 'Onceki kur tarihi: ' + prevDate : '';
        var prevHtml = '<span class="cur-trend-prev"' + (title ? ' title="' + title + '"' : '') + '>' + prevStr + '</span>';
        var cls, label;
        if (Math.abs(delta) < 0.00005) {
            cls = 'eq';   label = '= 0.0000';
        } else if (delta > 0) {
            cls = 'up';   label = '&#x25B2; +' + delta.toFixed(4);
        } else {
            cls = 'down'; label = '&#x25BC; ' + delta.toFixed(4);
        }
        return prevHtml + '<span class="cur-trend-delta ' + cls + '">' + label + '</span>';
    }
    function showLoading(on) { document.getElementById('crLoading').classList.toggle('is-active', on); }
    function showMsg(msg, ok) {
        var el = document.getElementById('crMsg');
        if (!msg) { el.innerHTML = ''; return; }
        el.innerHTML = '<div class="cur-msg ' + (ok ? 'ok' : 'err') + '">' + msg + '</div>';
        if (ok) setTimeout(function() { el.innerHTML = ''; }, 3000);
    }
})();
</script>
}
