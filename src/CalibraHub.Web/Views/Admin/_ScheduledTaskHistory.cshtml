@model IReadOnlyCollection<CalibraHub.Domain.Entities.ScheduledTaskRun>
@{
    Layout = null;
}
<style>
.sth { font-family: inherit; }
.sth-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.sth-table th { padding: 8px 10px; text-align: left; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: #94a3b8; border-bottom: 1px solid rgba(255,255,255,.08); }
.sth-table td { padding: 8px 10px; border-bottom: 1px solid rgba(255,255,255,.05); vertical-align: top; }
.sth-table tr:last-child td { border-bottom: none; }
.sth-badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 5px; font-size: 11px; font-weight: 600; white-space: nowrap; }
.sth-ok   { background: rgba(34,197,94,.12);  color: #4ade80; }
.sth-err  { background: rgba(239,68,68,.12);   color: #f87171; }
.sth-run  { background: rgba(59,130,246,.12);  color: #60a5fa; }
.sth-dur  { color: #64748b; font-size: 12px; }
.sth-msg  { color: #94a3b8; font-size: 12px; max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sth-trig { color: #64748b; font-size: 11px; }
.sth-empty { padding: 32px; text-align: center; color: #64748b; font-size: 13px; }
</style>
<div class="sth">
@if (!Model.Any())
{
    <div class="sth-empty">Henüz çalıştırma kaydı yok.</div>
}
else
{
    <table class="sth-table">
        <thead>
            <tr>
                <th>Zaman</th>
                <th>Durum</th>
                <th>Süre</th>
                <th>Mesaj</th>
                <th>Tetikleyen</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model)
        {
            var badgeCls = r.Status == 0 ? "sth-ok" : r.Status == 2 ? "sth-run" : "sth-err";
            var badgeLbl = r.Status == 0 ? "Başarılı" : r.Status == 2 ? "Çalışıyor" : "Hata";
            var trigLbl  = r.Trigger == CalibraHub.Domain.Enums.RunTrigger.Manual   ? "Manuel"
                         : r.Trigger == CalibraHub.Domain.Enums.RunTrigger.System   ? "Sistem"
                         : "Zamanlama";
            var durText  = r.DurationMs.HasValue ? (r.DurationMs.Value < 1000
                               ? $"{r.DurationMs.Value} ms"
                               : $"{r.DurationMs.Value / 1000.0:F1} s") : "—";
            <tr>
                <td style="white-space:nowrap;">@r.StartedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                <td><span class="sth-badge @badgeCls">@badgeLbl</span></td>
                <td class="sth-dur">@durText</td>
                <td class="sth-msg" title="@(r.Message ?? "")">@(r.Message ?? "—")</td>
                <td class="sth-trig">@trigLbl</td>
            </tr>
        }
        </tbody>
    </table>
}
</div>
