@{
    ViewData["Title"] = "Proje Talimatlari";
    ViewData["FormCode"] = "ADMIN_PROJECT_INSTRUCTIONS";
}

@section Styles {
<style>
    .pi-layout { display: flex; flex-direction: column; height: 100%; overflow: hidden; gap: 0; }
    .pi-editor-wrap { flex: 3 1 0; display: flex; flex-direction: column; min-height: 0; overflow: hidden; border-bottom: 1px solid var(--app-border,#dde3ee); }
    .pi-editor-wrap textarea { flex: 1 1 auto; min-height: 0; resize: none; border-radius: 0; border-left: 0; border-right: 0; border-bottom: 0; font-family: Consolas, "Courier New", monospace; font-size: 0.82rem; line-height: 1.5; white-space: pre; overflow-wrap: normal; overflow-x: auto; overflow-y: auto; padding: 12px 16px; }
    .pi-editor-wrap textarea:focus { box-shadow: none; border-color: var(--app-border); }
    .pi-requests-wrap { flex: 1 1 0; min-height: 0; overflow: auto; }
    .pi-req-grid { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
    .pi-req-grid thead th { text-align: left; padding: 3px 8px; font-weight: 600; color: #64748b; font-size: 0.7rem; text-transform: uppercase; border-bottom: 2px solid #e2e8f0; background: #f8fafc; white-space: nowrap; }
    .pi-req-grid tbody tr { border-bottom: 1px solid #f1f5f9; }
    .pi-req-grid td { padding: 3px 8px; vertical-align: middle; }
    .pi-empty { text-align: center; padding: 20px; color: #94a3b8; font-style: italic; }
    .pi-msg { padding: 4px 8px; border-radius: 5px; font-size: 0.7rem; }
    .pi-msg.ok { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
    .pi-msg.err { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
</style>
}

<div class="entity-form-toolbar" data-no-proxy="1">
    <button type="button" class="btn btn-primary btn-sm" onclick="piSave()">Kaydet</button>
    <span id="piMsg" style="display:inline-block;margin-left:8px;"></span>
</div>

<div class="pi-layout">
    <div class="pi-editor-wrap">
        <textarea id="piContent" class="form-control" spellcheck="false" autocomplete="off"></textarea>
    </div>
    <div class="pi-requests-wrap">
        <table class="pi-req-grid"><thead><tr>
            <th>ID</th><th>Kategori</th><th>Talep</th><th>Aciklama</th>
        </tr></thead><tbody id="piReqBody"></tbody></table>
    </div>
</div>

@section Scripts {
<script>
(function() {
    var API = function(a) { return '/Admin/' + a; };

    function piLoad() {
        fetch(API('GetProjectInstructionsJson'))
            .then(function(r) { return r.json(); })
            .then(function(d) {
                document.getElementById('piContent').value = d.content || '';
                var body = document.getElementById('piReqBody');
                if (!d.completedItems || d.completedItems.length === 0) {
                    body.innerHTML = '<tr><td colspan="4" class="pi-empty">Tamamlanan istek bulunmuyor.</td></tr>';
                    return;
                }
                body.innerHTML = d.completedItems.map(function(x) {
                    return '<tr>' +
                        '<td>' + esc(x.requestId) + '</td>' +
                        '<td>' + esc(x.category) + '</td>' +
                        '<td>' + esc(x.title) + '</td>' +
                        '<td style="color:#64748b;font-size:0.74rem;">' + esc(x.userComment) + '</td>' +
                        '</tr>';
                }).join('');
            });
    }

    window.piSave = function() {
        var content = document.getElementById('piContent').value;
        fetch(API('SaveProjectInstructionsJson'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content: content })
        })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                piMsg(d.message || (d.success ? 'Kaydedildi.' : 'Hata'), d.success);
            });
    };

    function piMsg(msg, ok) {
        var el = document.getElementById('piMsg');
        el.innerHTML = '<span class="pi-msg ' + (ok ? 'ok' : 'err') + '">' + msg + '</span>';
        if (ok) setTimeout(function() { el.innerHTML = ''; }, 3000);
    }

    function esc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    piLoad();
})();
</script>
}
