@{
    ViewData["Title"] = "Entegrator Ayarlari";
    ViewData["FormCode"] = "INTEGRATOR_SETTINGS";
    ViewData["DbInfo"] = "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>integrator_settings</td><td style='padding:6px 8px;'>Entegrator baglanti ayarlari (sirket bazli)</td></tr>"
        + "</table>";
}

@section Styles {
<style>
    .page-integrator .integrator-dashboard { height: 100%; min-height: 0; }
    .page-integrator .integrator-dashboard__content {
        display: flex !important; flex-direction: column;
        width: 100% !important; max-width: none !important;
        min-height: 0; padding: 0; margin: 0 !important; overflow: hidden;
    }
    .isr-body { flex: 1 1 auto; min-height: 0; overflow-y: auto; padding: 16px 24px; }

    .isr-form { max-width: 720px; }

    /* Form satirlari */
    .isr-line {
        display: flex; align-items: center; gap: 12px;
        padding: 6px 0; border-bottom: 1px solid var(--app-border-light,#f1f5f9);
    }
    .isr-line:last-child { border-bottom: none; }
    .isr-line > label {
        width: 150px; flex-shrink: 0;
        font-size: 0.8rem; font-weight: 600; color: var(--app-text-muted,#64748b);
        text-align: right; padding-right: 4px;
    }
    .isr-line > .form-control, .isr-line > .form-select,
    .isr-line > .form-check { width: 280px; flex: 0 0 280px; }
    .isr-line-desc {
        font-size: 0.72rem; color: #94a3b8;
        line-height: 1.3; flex: 1 1 auto;
    }


</style>
}

<div class="entity-form-toolbar cb-sticky-toolbar cb-sticky-toolbar--top" data-no-proxy="1">
    <button type="button" class="btn btn-primary btn-sm" onclick="isrSave()">Kaydet</button>
    <button type="button" class="btn btn-outline-danger btn-sm" id="isrDelBtn" onclick="isrDelete()" disabled>Sil</button>
    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="isrTest()">Baglanti Test</button>
    <span id="isrTestMsg" style="margin-left:8px;"></span>
    <span id="isrToolbarMsg" style="margin-left:8px;"></span>
</div>

<div class="isr-body">
    <div class="isr-form">
        <input type="hidden" id="isrId" />
        <input type="hidden" id="isrCompanyId" />

        <div class="isr-line">
            <label>Aktif</label>
            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                <input type="checkbox" id="isrIsActive" class="form-check-input" role="switch" checked />
            </div>
            <span class="isr-line-desc">Pasife alindiginda veri cekilmez</span>
        </div>
        <div class="isr-line">
            <label>Saglayici</label>
            <select id="isrProvider" class="form-select form-select-sm"></select>
            <span class="isr-line-desc">e-Belge entegrasyon saglayicisi</span>
        </div>
        <div class="isr-line">
            <label>Servis URL</label>
            <input id="isrBaseUrl" class="form-control form-control-sm" maxlength="300" placeholder="https://..." />
            <span class="isr-line-desc">e-Belge web servis adresi</span>
        </div>
        <div class="isr-line">
            <label>Kullanici Adi</label>
            <input id="isrUsername" class="form-control form-control-sm" maxlength="120" />
            <span class="isr-line-desc">Servise giris kullanici adi</span>
        </div>
        <div class="isr-line">
            <label>Sifre</label>
            <input id="isrSecret" type="password" class="form-control form-control-sm" maxlength="200"
                   autocomplete="new-password" placeholder="Degistirmek icin girin" />
            <span class="isr-line-desc">Bos birakilirsa mevcut sifre korunur</span>
        </div>

        <!-- Belge Isleme -->
        <div class="isr-line">
            <label>Okunmus Belgeler</label>
            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                <input type="checkbox" id="isrInclReceived" class="form-check-input" role="switch" />
            </div>
            <span class="isr-line-desc">Daha once okunmus belgeler de cekilsin</span>
        </div>
        <div class="isr-line">
            <label>Portalde Okundu</label>
            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                <input type="checkbox" id="isrMarkReceived" class="form-check-input" role="switch" />
            </div>
            <span class="isr-line-desc">Acikken: belge indirilince saglayici portalinda <strong>okundu/alindi</strong> olarak isaretlenir. Kapali tutulursa portal durumu degismez</span>
        </div>
        <div class="isr-line">
            <label>Kesilen e-Fatura</label>
            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                <input type="checkbox" id="isrInvoices" class="form-check-input" role="switch" />
            </div>
            <span class="isr-line-desc">Sirketin kestigi e-Faturalar da indirilsin</span>
        </div>
        <div class="isr-line">
            <label>Kesilen e-Arsiv</label>
            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                <input type="checkbox" id="isrArchives" class="form-check-input" role="switch" />
            </div>
            <span class="isr-line-desc">Sirketin kestigi e-Arsivler de indirilsin</span>
        </div>
        <div class="isr-line">
            <label>Kesilen e-Irsaliye</label>
            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                <input type="checkbox" id="isrDispatches" class="form-check-input" role="switch" />
            </div>
            <span class="isr-line-desc">Sirketin kestigi e-Irsaliyeler de indirilsin</span>
        </div>

        <!-- Islem Parametreleri -->
        <div class="isr-line">
            <label>Zamanlanmis Gorev</label>
            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                <input type="checkbox" id="isrScheduleEnabled" class="form-check-input" role="switch" />
            </div>
            <span class="isr-line-desc">Belirtilen aralikta otomatik veri cekme</span>
        </div>
        <div class="isr-line">
            <label>Zaman Asimi (sn)</label>
            <input id="isrTimeout" type="number" class="form-control form-control-sm" value="30" />
            <span class="isr-line-desc">Servis istekleri icin maksimum bekleme suresi</span>
        </div>
        <div class="isr-line">
            <label>Geriye Bakis (gun)</label>
            <input id="isrLookback" type="number" class="form-control form-control-sm" value="30" />
            <span class="isr-line-desc">Veri cekerken kac gun geriye bakilsin</span>
        </div>
        <div class="isr-line">
            <label>Cekme Araligi (sn)</label>
            <input id="isrPolling" type="number" class="form-control form-control-sm" value="120" />
            <span class="isr-line-desc">Zamanlanmis gorev kac saniyede bir calissin</span>
        </div>
        <div class="isr-line">
            <label>Max Kayit Pull</label>
            <input id="isrMaxPull" type="number" class="form-control form-control-sm" value="200" />
            <span class="isr-line-desc">Tek seferinde cekilecek maksimum belge sayisi</span>
        </div>
        <div class="isr-line">
            <label>Log Saklama (Gun)</label>
            <input id="isrLogDays" type="number" class="form-control form-control-sm" value="30" />
            <span class="isr-line-desc">Entegrasyon calisma gecmisi kac gun saklansin</span>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function() {
    var API = function(a) { return '/Admin/' + a; };

    function init() {
        fetch(API('GetIntegratorFormDataJson'))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var pSel = document.getElementById('isrProvider');
                pSel.innerHTML = data.providers.map(function(p) {
                    return '<option value="' + p.value + '">' + esc(p.label) + '</option>';
                }).join('');

                var companyId = data.currentCompanyId || (data.companies && data.companies.length > 0 ? data.companies[0].id : null);
                if (companyId) {
                    document.getElementById('isrCompanyId').value = companyId;
                    fetch(API('GetIntegratorsListJson') + '?companyId=' + companyId)
                        .then(function(r) { return r.json(); })
                        .then(function(items) {
                            if (items && items.length > 0) loadIntegrator(items[0].id);
                        });
                }
            });
    }

    function loadIntegrator(id) {
        fetch(API('GetIntegratorJson') + '?id=' + id)
            .then(function(r) { return r.json(); })
            .then(function(x) {
                if (!x) return;
                document.getElementById('isrId').value = x.id || '';
                document.getElementById('isrCompanyId').value = x.companyId || '';
                setVal('isrProvider', x.provider);
                document.getElementById('isrBaseUrl').value = x.baseUrl || '';
                document.getElementById('isrUsername').value = x.username || '';
                document.getElementById('isrSecret').value = '';
                document.getElementById('isrTimeout').value = x.timeoutSeconds || 30;
                document.getElementById('isrLookback').value = x.lookbackDays || 30;
                document.getElementById('isrPolling').value = x.pollingIntervalSeconds || 120;
                document.getElementById('isrMaxPull').value = x.maxRecordsPerPull || 200;
                document.getElementById('isrLogDays').value = x.logRetentionDays || 30;
                document.getElementById('isrScheduleEnabled').checked = x.scheduleEnabled;
                document.getElementById('isrIsActive').checked = x.isActive;
                document.getElementById('isrInclReceived').checked = x.includeReceivedDocumentsInPull;
                document.getElementById('isrMarkReceived').checked = x.markDownloadedDocumentsAsReceived;
                document.getElementById('isrInvoices').checked = x.includeIssuedEInvoicesInPull;
                document.getElementById('isrArchives').checked = x.includeIssuedEArchivesInPull;
                document.getElementById('isrDispatches').checked = x.includeIssuedEDispatchesInPull;
                document.getElementById('isrDelBtn').disabled = false;
                document.getElementById('isrTestResult').style.display = 'none';
            });
    }

    function buildPayload() {
        return {
            id: document.getElementById('isrId').value || null,
            companyId: document.getElementById('isrCompanyId').value || null,
            provider: document.getElementById('isrProvider').value,
            name: '',
            baseUrl: document.getElementById('isrBaseUrl').value,
            companyTaxNumber: '',
            username: document.getElementById('isrUsername').value,
            secret: document.getElementById('isrSecret').value,
            timeoutSeconds: parseInt(document.getElementById('isrTimeout').value) || 30,
            lookbackDays: parseInt(document.getElementById('isrLookback').value) || 30,
            pollingIntervalSeconds: parseInt(document.getElementById('isrPolling').value) || 120,
            maxRecordsPerPull: parseInt(document.getElementById('isrMaxPull').value) || 200,
            logRetentionDays: parseInt(document.getElementById('isrLogDays').value) || 30,
            includeReceivedDocumentsInPull: document.getElementById('isrInclReceived').checked,
            markDownloadedDocumentsAsReceived: document.getElementById('isrMarkReceived').checked,
            includeIssuedEInvoicesInPull: document.getElementById('isrInvoices').checked,
            includeIssuedEArchivesInPull: document.getElementById('isrArchives').checked,
            includeIssuedEDispatchesInPull: document.getElementById('isrDispatches').checked,
            isActive: document.getElementById('isrIsActive').checked,
            scheduleEnabled: document.getElementById('isrScheduleEnabled').checked
        };
    }

    window.isrSave = function() {
        fetch(API('SaveIntegratorSettingsJson'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(buildPayload())
        }).then(function(r) { return r.json(); })
          .then(function(d) {
              toolbarMsg(d.message, d.success);
              if (d.success) {
                  var idEl = document.getElementById('isrId');
                  if (!idEl.value && d.id) idEl.value = d.id;
                  document.getElementById('isrDelBtn').disabled = false;
              }
          })
          .catch(function(e) { toolbarMsg('Hata: ' + e.message, false); });
    };

    window.isrDelete = async function() {
        var id = document.getElementById('isrId').value;
        if (!id) return;
        var ok = await CalibraAlert.confirm('Bu entegrator ayarini silmek istediginize emin misiniz?',
            { title: 'Entegrator Sil', okText: 'Evet, Sil', cancelText: 'Vazgec', danger: true });
        if (!ok) return;
        fetch(API('DeleteIntegratorSettingsJson') + '?id=' + id, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                toolbarMsg(d.message, d.success);
                if (d.success) {
                    document.getElementById('isrId').value = '';
                    document.getElementById('isrDelBtn').disabled = true;
                }
            });
    };

    window.isrTest = function() {
        testMsg('Test ediliyor...', null);
        fetch(API('TestIntegratorConnectionJson'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(buildPayload())
        }).then(function(r) { return r.json(); })
          .then(function(d) { testMsg(d.message, d.success); })
          .catch(function(e) { testMsg('Baglanti hatasi: ' + e.message, false); });
    };

    function testMsg(msg, ok) {
        var el = document.getElementById('isrTestMsg');
        if (!msg) { el.innerHTML = ''; return; }
        var cls = ok === null
            ? 'background:#f1f5f9;color:#475569;border:1px solid #cbd5e1;'
            : ok ? 'background:#dcfce7;color:#15803d;border:1px solid #bbf7d0;'
                 : 'background:#fef2f2;color:#dc2626;border:1px solid #fecaca;';
        el.innerHTML = '<span style="display:inline-block;padding:3px 10px;border-radius:5px;font-size:0.72rem;' + cls + '">' + esc(msg) + '</span>';
    }

    function toolbarMsg(msg, ok) {
        var el = document.getElementById('isrToolbarMsg');
        if (!msg) { el.innerHTML = ''; return; }
        var cls = ok ? 'background:#dcfce7;color:#15803d;border:1px solid #bbf7d0;' : 'background:#fef2f2;color:#dc2626;border:1px solid #fecaca;';
        el.innerHTML = '<span style="display:inline-block;padding:3px 10px;border-radius:5px;font-size:0.72rem;' + cls + '">' + esc(msg) + '</span>';
        if (ok) setTimeout(function() { el.innerHTML = ''; }, 3000);
    }

    function setVal(id, val) {
        var el = document.getElementById(id);
        if (el && val != null) el.value = val;
    }

    function esc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    init();
})();
</script>
}
