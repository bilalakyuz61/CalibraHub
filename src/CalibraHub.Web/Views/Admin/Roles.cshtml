@model CalibraHub.Web.Models.Admin.RoleManagementViewModel
@{
    ViewData["Title"] = "Rol Tanimlama";
    ViewData["BodyClass"] = "page-admin-roles";
    var rolesListState = Model.RolesListState;
    var usersListState = Model.UsersListState;
    var rolesPagerRouteValues = new Dictionary<string, string?>();
    var usersPagerRouteValues = new Dictionary<string, string?>();
    if (Model.CompanyId.HasValue)
    {
        rolesPagerRouteValues["companyId"] = Model.CompanyId.Value.ToString();
        usersPagerRouteValues["companyId"] = Model.CompanyId.Value.ToString();
    }

    rolesPagerRouteValues["usersPage"] = usersListState.Page.ToString();
    rolesPagerRouteValues["usersPageSize"] = usersListState.PageSize.ToString();
    usersPagerRouteValues["rolesPage"] = rolesListState.Page.ToString();
    usersPagerRouteValues["rolesPageSize"] = rolesListState.PageSize.ToString();
}

@section Styles {
<style>
    .page-admin-roles .integrator-dashboard__content {
        display: flex !important; flex-direction: column;
        width: 100% !important; max-width: none !important;
        min-height: 0; padding: 0; margin: 0 !important; overflow: hidden;
    }
    .page-admin-roles .integrator-dashboard__header { flex: 0 0 auto; }
    .page-admin-roles .integrator-dashboard__grid { flex: 1 1 auto !important; display: flex !important; flex-direction: column !important; gap: 4px; min-height: 0; }
    .page-admin-roles .integrator-dashboard__group { flex: 1 1 0 !important; min-height: 0; overflow: hidden; }
</style>
}

<section class="admin-content integrator-dashboard integrator-dashboard__content">
        <header class="integrator-dashboard__header">
            <div>
                <h1>Rol Tanimlama</h1>
                <p class="integrator-dashboard__subtitle">Sistemdeki roller ve bu rollere tanimli yetki matrisini yonetin.</p>
            </div>
        </header>

        <form method="get" asp-action="Roles" class="integrator-table-search mb-3">
            <input type="hidden" name="rolesPageSize" value="@rolesListState.PageSize" />
            <input type="hidden" name="usersPageSize" value="@usersListState.PageSize" />
            <div class="integrator-table-search__fields">
                <select name="companyId" asp-items="Model.CompanyOptions" class="form-select">
                    <option value="">Sirket seciniz</option>
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary integrator-btn-primary">Filtrele</button>
                <a class="btn btn-outline-secondary integrator-btn-tertiary" asp-action="Roles">Temizle</a>
            </div>
        </form>

        <div class="integrator-dashboard__grid">
            <section class="integrator-dashboard__group">
                <div class="integrator-section-label">Rol ve Yetki Matrisi</div>
                <article class="integrator-card integrator-card--table">
                    <div class="integrator-card__header">
                        <div class="integrator-card__title-wrap">
                            <span class="integrator-card__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24"><path d="M12 3 4 7v5c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V7z"></path><path d="m9 12 2 2 4-4"></path></svg>
                            </span>
                            <div>
                                <h2>Rol ve Yetki Matrisi</h2>
                                <p>Her rol icin tanimli yetkileri etiket formatinda inceleyin.</p>
                            </div>
                        </div>
                    </div>

                    <div class="integrator-table-wrap">
                        <table class="table integrator-table integrator-table--compact">
                            <thead>
                            <tr>
                                <th>Rol</th>
                                <th>Yetkiler</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Roles.Count == 0)
                            {
                                <tr>
                                    <td colspan="2" class="integrator-table__empty">Tanimli rol bulunmuyor.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var role in Model.Roles)
                                {
                                    <tr>
                                        <td>@role.Name</td>
                                        <td>
                                            <div class="integrator-permission-tags">
                                                @if (role.Permissions.Count == 0)
                                                {
                                                    <span class="integrator-permission-tag is-empty">Yetki yok</span>
                                                }
                                                else
                                                {
                                                    @foreach (var permission in role.Permissions)
                                                    {
                                                        <span class="integrator-permission-tag">@permission</span>
                                                    }
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                    @await Html.PartialAsync("_GridPager", new CalibraHub.Web.Models.Shared.GridPagerViewModel
                    {
                        State = rolesListState,
                        ActionName = "Roles",
                        RouteValues = rolesPagerRouteValues
                    })
                </article>
            </section>

            <section class="integrator-dashboard__group">
                <div class="integrator-section-label">Sirket Bazli Kullanicilar</div>
                <article class="integrator-card integrator-card--table">
                    <div class="integrator-card__header">
                        <div class="integrator-card__title-wrap">
                            <span class="integrator-card__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24"><path d="M5 19v-1a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4v1"></path><circle cx="12" cy="8" r="3"></circle></svg>
                            </span>
                            <div>
                                <h2>Kullanici Rol Listesi</h2>
                                <p>Secili sirketteki kullanicilarin rol dagilimini goruntuleyin.</p>
                            </div>
                        </div>
                    </div>

                    <div class="integrator-table-wrap">
                        <table class="table integrator-table integrator-table--compact">
                            <thead>
                            <tr>
                                <th>Kullanici</th>
                                <th>E-posta</th>
                                <th>Rol</th>
                            </tr>
                            </thead>
                            <tbody>
                            @if (Model.Users.Count == 0)
                            {
                                <tr>
                                    <td colspan="3" class="integrator-table__empty">Secili sirket icin kullanici bulunmuyor.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td>@user.FullName</td>
                                        <td>@user.Email</td>
                                        <td>@user.Role</td>
                                    </tr>
                                }
                            }
                            </tbody>
                        </table>
                    </div>
                    @await Html.PartialAsync("_GridPager", new CalibraHub.Web.Models.Shared.GridPagerViewModel
                    {
                        State = usersListState,
                        ActionName = "Roles",
                        RouteValues = usersPagerRouteValues
                    })
                </article>
            </section>
        </div>
    </section>
