                    </div>

                    </div><!-- /waBody -->

                    <div id="waMsg" style="margin: 8px 0; min-height:24px; font-size:.8rem;"></div>

                    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;">
                        <button type="button" class="btn btn-primary btn-sm" onclick="waSave()">Kaydet</button>
                        <button type="button" class="btn btn-secondary btn-sm" onclick="waTest()">Bağlantıyı Test Et</button>
                    </div>

                    @if (waCfg?.IsEnabled == true && (!string.IsNullOrEmpty(waCfg?.PhoneNumberId) || !string.IsNullOrEmpty(waCfg?.WebQrBridgeUrl)))
                    {
                        <div class="cs-section-title" style="margin-top:18px;">Test Mesajı</div>
                        <div class="cs-line">
                            <label>Hedef Numara</label>
                            <input type="text" class="form-control form-control-sm" id="waToPhone" placeholder="+905555555555" />
                        </div>
                        <div class="cs-line">
                            <label>Mesaj</label>
                            <input type="text" class="form-control form-control-sm" id="waText" value="CalibraHub test mesajı" />
                        </div>
                        <div class="cs-line">
                            <label></label>
                            <button type="button" class="btn btn-secondary btn-sm" onclick="waSendTest()">📤 Gönder</button>
                        </div>
                        <div class="wa-safety-note">
                            Safety Layer aktif: dakikada max 5, saatte 60, günde 300 mesaj. Aynı alıcıya günde 3.
                            İnsan-benzeri 3-15sn rastgele gecikme. Aynı içerik günde max 10.
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(waCfg?.LastError))
                    {
                        <div class="cs-instruction" style="margin-top:14px; background: rgba(239,68,68,.08); border-color: rgba(239,68,68,.25); color:#dc2626;">
                            <strong>Son hata:</strong> @waCfg.LastError
                        </div>
                    }
                </div>

                @* ───────────────────────────────────────────────────────────────
                   2026-05-23 — Yapay Zeka tab
                   React AiProvidersPanel mount edilir (window.CalibraHub.mountAiProvidersPanel).
                   Provider tanımları + admin CRUD + bağlantı test.
                   ─────────────────────────────────────────────────────────────── *@
                <div class="cs-tab-pane@(firstVisible == "ai" ? " is-active" : "")" id="cs-pane-ai" data-cs-pane-key="ai">
                    <div class="cs-instruction" style="margin-bottom:14px;">
                        <strong>Yapay Zeka Provider Yönetimi.</strong> Birden fazla provider
                        (OpenAI, Anthropic, Azure OpenAI, Google Gemini) aynı anda tanımlanabilir.
                        Kullanıcılar sohbet ederken provider seçer; seçmezse <em>Varsayılan</em>
                        işaretli olan kullanılır.
                    </div>
                    <div id="ai-providers-root" data-mount="ai-providers"
                         style="min-height: 240px;"></div>
                </div>


            </div>
        </div>
    </form>

    </div><!-- /integrator-dashboard__content -->
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    // Genel Kaydet butonu — aktif taba göre dispatch
    window.csSave = function() {
        var active = document.querySelector('.cs-tab-btn.is-active');
        var tab = active ? active.getAttribute('data-cs-tab') : 'general';
        if (tab === 'integrator') { isrSave(); return; }
        // 'apiprofile' tab'i kaldirildi (Hub'a tasindi). Eski deger gelirse
        // sessizce ana form submit'e dus.
        document.getElementById('company-form').submit();
    };

    (function () {
        // Auth method toggle
        var authSelect = document.getElementById('authMethodSelect');
        var oauthPanel = document.getElementById('oauthPanel');
        var pwdLabel = document.getElementById('smtpPasswordLabel');
        function updateAuth() {
            if (!authSelect) return;
            var m = authSelect.value;
            if (oauthPanel) oauthPanel.style.display = m === 'OAuth2' ? 'block' : 'none';
            if (pwdLabel) pwdLabel.textContent = m === 'AppPassword' ? 'Uygulama Sifresi' : m === 'OAuth2' ? 'Sifre (opsiyonel)' : 'Sifre';
            // Talimatlar
            document.querySelectorAll('.cs-instruction').forEach(function (el) { el.style.display = 'none'; });
            var inst = document.getElementById('instruction' + m);
            if (inst) inst.style.display = 'block';
        }
        if (authSelect) { authSelect.addEventListener('change', updateAuth); updateAuth(); }

        // SMTP test
        var testBtn = document.getElementById('btnTestSmtp');
        if (testBtn) {
            testBtn.addEventListener('click', async function () {
                testBtn.disabled = true; testBtn.textContent = 'Test ediliyor...';
                try {
                    var f = document.getElementById('company-form');
                    var fd = new FormData(f);
                    var token = fd.get('__RequestVerificationToken') || '';
                    var resp = await fetch('@Url.Action("TestSmtpConnectionJson", "Admin")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({
                            companyId: parseInt(fd.get('SmtpInput.CompanyId')) || 0,
                            name: fd.get('SmtpInput.Name') || 'Test',
                            fromEmail: fd.get('SmtpInput.FromEmail') || '',
                            fromDisplayName: fd.get('SmtpInput.FromDisplayName') || '',
                            host: fd.get('SmtpInput.Host') || '',
                            port: parseInt(fd.get('SmtpInput.Port')) || 587,
                            username: fd.get('SmtpInput.Username') || '',
                            password: fd.get('SmtpInput.Password') || '',
                            useSsl: fd.get('SmtpInput.UseSsl') === 'true',
                            testRecipientEmail: fd.get('SmtpInput.TestRecipientEmail') || null
                        })
                    });
                    var data = await resp.json();
                    // Rapor §6.6 — toast / CalibraAlert tercih
                    var msg = (data.isSuccess ? '✓ ' : '✗ ') + (data.message || '');
                    if (window.CalibraAlert && CalibraAlert[data.isSuccess ? 'success' : 'error']) CalibraAlert[data.isSuccess ? 'success' : 'error'](msg);
                    else if (window.CalibraHub && CalibraHub.toast) CalibraHub.toast(msg, data.isSuccess ? 'ok' : 'err');
                    else alert(msg);
                } catch (e) {
                    var em = 'Test hatasi: ' + e.message;
                    if (window.CalibraAlert && CalibraAlert.error) CalibraAlert.error(em);
                    else if (window.CalibraHub && CalibraHub.toast) CalibraHub.toast(em, 'err');
                    else alert(em);
                }
                finally { testBtn.disabled = false; testBtn.textContent = 'Baglanti Test Et'; }
            });
        }

        // Tab gecisi
        document.querySelectorAll('.cs-tab-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.cs-tab-btn').forEach(function (b) { b.classList.remove('is-active'); });
                document.querySelectorAll('.cs-tab-pane').forEach(function (p) { p.classList.remove('is-active'); });
                btn.classList.add('is-active');
                var tab = btn.getAttribute('data-cs-tab');
                var pane = document.getElementById('cs-pane-' + tab);
                if (pane) pane.classList.add('is-active');
                // 'apiprofile' tab'i kaldirildi (Hub'a tasindi).
                if (tab === 'integrator' && !window._isrInited) { window._isrInited = true; isrInit(); }
                // 2026-05-23 — Yapay Zeka tab: ilk açılışta React panel mount edilir.
                if (tab === 'ai' && !window._aiPanelMounted) { window._aiPanelMounted = true; mountAiPanel(); }
            });
        });
    })();

    // 2026-05-23 — Yapay Zeka panel mount yardımcısı.
    // Şirket Ayarları sayfası React bundle'ı default yüklemez (Razor-only sayfa);
    // tab ilk açılınca on-demand <script>+<link> ekleyip mount eder.
    function mountAiPanel() {
        console.log('[AI] mountAiPanel called');
        var el = document.getElementById('ai-providers-root');
        if (!el) { console.error('[AI] ai-providers-root element bulunamadı'); return; }
        el.innerHTML = '<div style="padding:20px;color:#94a3b8;">React panel yükleniyor…</div>';

        // Bundle script + css yüklü mü? Değilse şimdi ekle.
        var BUNDLE_JS  = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js")';
        var BUNDLE_CSS = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css")';

        if (!document.querySelector('link[data-ai-bundle]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet'; link.href = BUNDLE_CSS;
            link.setAttribute('data-ai-bundle', '1');
            document.head.appendChild(link);
        }

        function tryMount() {
            if (window.CalibraHub && window.CalibraHub.mountAiProvidersPanel) {
                try {
                    console.log('[AI] mountAiProvidersPanel çağrılıyor');
                    window.CalibraHub.mountAiProvidersPanel(el);
                    console.log('[AI] mount başarılı');
                    return true;
                } catch (err) {
                    console.error('[AI] mount sırasında hata:', err);
                    el.innerHTML = '<div style="padding:20px;color:#dc2626;">Mount hatası: ' + (err.message || err) + '</div>';
                    return true;  // tekrar deneme
                }
            }
            return false;
        }
        function doMount() {
            if (tryMount()) return;
            // Bundle henüz yüklenmemiş — script yükle + load event'inde mount et
            if (!document.querySelector('script[data-ai-bundle]')) {
                var script = document.createElement('script');
                script.src = BUNDLE_JS;
                script.setAttribute('data-ai-bundle', '1');
                script.onload = function () {
                    // window.CalibraHub.* hazır olana kadar 100ms aralıkla 4sn dene
                    var tries = 0;
                    var timer = setInterval(function () {
                        if (tryMount() || ++tries >= 40) clearInterval(timer);
                    }, 100);
                };
                script.onerror = function () {
                    el.innerHTML = '<div style="padding:20px;color:#dc2626;">React bundle yüklenemedi (' + BUNDLE_JS + ').</div>';
                };
                document.head.appendChild(script);
            } else {
                // Script tag zaten ekli ama henüz parse edilmemiş — bekle
                var tries = 0;
                var timer = setInterval(function () {
                    if (tryMount() || ++tries >= 40) clearInterval(timer);
                }, 100);
            }
        }
        doMount();
    }

    </script>
    <script>
(function() {
    var _apSelectedId = null;

    window.apLoad = function apLoad() {
        fetch('/Admin/GetApiProfilesJson')
            .then(function(r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function(profiles) {
                var tbody = document.getElementById('apTableBody');
                if (profiles.error) {
                    tbody.innerHTML = '<tr><td colspan="5" style="padding:16px;text-align:center;color:#991b1b;">' + apEsc(profiles.message) + '</td></tr>';
                    return;
                }
                if (!profiles.length) {
                    tbody.innerHTML = '<tr><td colspan="5" style="padding:16px;text-align:center;color:#94a3b8;">Profil bulunamadi. Formu doldurup Kaydet\'e basin.</td></tr>';
                    return;
                }
                tbody.innerHTML = profiles.map(function(p) {
                    var enc = JSON.stringify(p).replace(/"/g,'&quot;');
                    var selCls = p.id === _apSelectedId ? ' ap-tr-sel' : '';
                    return '<tr class="' + selCls + '">' +
                        '<td class="ap-td" style="white-space:nowrap;">' +
                            '<button type="button" class="ap-btn-edit" onclick="apSelect(' + enc + ')" title="Duzenle">&#9998;</button>' +
                            '<button type="button" class="ap-btn-del" onclick="apDeleteById(\'' + p.id + '\')" title="Sil">&#128465;</button>' +
                        '</td>' +
                        '<td class="ap-td">' + apEsc(p.name) + '</td>' +
                        '<td class="ap-td">' + apEsc(p.authType) + '</td>' +
                        '<td class="ap-td" style="font-size:0.78rem;opacity:.75;">' + apEsc(p.baseUrl) + '</td>' +
                        '<td class="ap-td" style="text-align:center;">' + (p.isActive ? '&#x2713;' : '') + '</td>' +
                        '</tr>';
                }).join('');
            })
            .catch(function(e) { apMsg('err', 'Liste yuklenemedi: ' + e.message); });
    }

    window.apSelect = function(p) {
        _apSelectedId = p.id;
        document.getElementById('apId').value = p.id;
        document.getElementById('apName').value = p.name;
        document.getElementById('apBaseUrl').value = p.baseUrl;
        apSetSelect('apAuthType', p.authType || 'None');
        document.getElementById('apIsActive').checked = p.isActive;
        apLoadAuthConfig(p.authType, p.authConfigJson);
        apMsg('', '');
    };

    function apClearForm() {
        _apSelectedId = null;
        document.getElementById('apId').value = '';
        document.getElementById('apName').value = '';
        document.getElementById('apBaseUrl').value = '';
        apSetSelect('apAuthType', 'None');
        document.getElementById('apIsActive').checked = true;
        apClearAuth();
        apMsg('', '');
    }

    window.apSave = function() {
        var name = document.getElementById('apName').value.trim();
        var baseUrl = document.getElementById('apBaseUrl').value.trim();
        if (!name) { apMsg('err', 'Profil adi zorunludur.'); return; }
        if (!baseUrl) { apMsg('err', 'Base URL zorunludur.'); return; }
        var authType = document.getElementById('apAuthType').value;
        var payload = {
            id: document.getElementById('apId').value || null,
            name: name,
            baseUrl: baseUrl,
            authType: authType,
            authConfigJson: apBuildAuthConfig(authType),
            isActive: document.getElementById('apIsActive').checked
        };
        fetch('/Admin/SaveApiProfileJson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        }).then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        }).then(function(d) {
            apMsg(d.success ? 'ok' : 'err', d.message);
            if (d.success) { apClearForm(); apLoad(); }
        }).catch(function(e) { apMsg('err', 'Kayit hatasi: ' + e.message); });
    };

    window.apDeleteById = async function(id) {
        var ok = await CalibraAlert.confirm('Bu profili silmek istediginizden emin misiniz?',
            { title: 'Profil Sil', okText: 'Evet, Sil', cancelText: 'Vazgec', danger: true });
        if (!ok) return;
        fetch('/Admin/DeleteApiProfileJson?id=' + id, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                apMsg(d.success ? 'ok' : 'err', d.message);
                if (d.success) { apClearForm(); apLoad(); }
            })
            .catch(function(e) { apMsg('err', 'Silme hatasi: ' + e.message); });
    };

    window.apAuthChange = function() {
        var at = document.getElementById('apAuthType').value;
        document.getElementById('apAuthOAuth2').style.display = at === 'OAuth2Password' ? '' : 'none';
        document.getElementById('apAuthBearer').style.display = at === 'BearerStatic' ? '' : 'none';
        document.getElementById('apAuthBasic').style.display = at === 'BasicAuth' ? '' : 'none';
        document.getElementById('apAuthApiKey').style.display = at === 'ApiKey' ? '' : 'none';
    };

    function apLoadAuthConfig(authType, json) {
        apClearAuth();
        apSetSelect('apAuthType', authType || 'None');
        apAuthChange();
        if (!json) return;
        try {
            var c = JSON.parse(json);
            if (authType === 'OAuth2Password') {
                document.getElementById('apOAuthTokenEndpoint').value = c.tokenEndpoint || '';
                document.getElementById('apOAuthUsername').value = c.username || '';
                document.getElementById('apOAuthPassword').value = c.password || '';
                var ef = c.extraFields || {};
                document.getElementById('apOAuthBranchCode').value = ef.branchcode || '0';
                document.getElementById('apOAuthDbName').value = ef.dbname || '';
                document.getElementById('apOAuthDbUser').value = ef.dbuser || 'sa';
                document.getElementById('apOAuthDbPassword').value = ef.dbpassword || '';
                document.getElementById('apOAuthDbType').value = ef.dbtype || '0';
            } else if (authType === 'BearerStatic') {
                document.getElementById('apBearerToken').value = c.token || '';
            } else if (authType === 'BasicAuth') {
                document.getElementById('apBasicUsername').value = c.username || '';
                document.getElementById('apBasicPassword').value = c.password || '';
            } else if (authType === 'ApiKey') {
                document.getElementById('apApiKeyHeader').value = c.apiKeyHeader || '';
                document.getElementById('apApiKeyValue').value = c.apiKeyValue || '';
            }
        } catch(e) {}
    }

    function apBuildAuthConfig(authType) {
        if (authType === 'None') return null;
        var c = {};
        if (authType === 'OAuth2Password') {
            c = {
                tokenEndpoint: document.getElementById('apOAuthTokenEndpoint').value,
                tokenField: 'access_token',
                grantType: 'password',
                username: document.getElementById('apOAuthUsername').value,
                password: document.getElementById('apOAuthPassword').value,
                extraFields: {
                    branchcode: document.getElementById('apOAuthBranchCode').value,
                    dbname: document.getElementById('apOAuthDbName').value,
                    dbuser: document.getElementById('apOAuthDbUser').value,
                    dbpassword: document.getElementById('apOAuthDbPassword').value,
                    dbtype: document.getElementById('apOAuthDbType').value
                }
            };
        } else if (authType === 'BearerStatic') {
            c = { token: document.getElementById('apBearerToken').value };
        } else if (authType === 'BasicAuth') {
            c = { username: document.getElementById('apBasicUsername').value, password: document.getElementById('apBasicPassword').value };
        } else if (authType === 'ApiKey') {
            c = { apiKeyHeader: document.getElementById('apApiKeyHeader').value, apiKeyValue: document.getElementById('apApiKeyValue').value };
        }
        return JSON.stringify(c);
    }

    function apClearAuth() {
        ['apOAuthTokenEndpoint','apOAuthUsername','apOAuthPassword','apOAuthDbName','apOAuthDbPassword',
         'apBearerToken','apBasicUsername','apBasicPassword','apApiKeyHeader','apApiKeyValue'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.value = '';
        });
        document.getElementById('apOAuthBranchCode').value = '0';
        document.getElementById('apOAuthDbUser').value = 'sa';
        document.getElementById('apOAuthDbType').value = '0';
        apAuthChange();
    }

    function apMsg(type, msg) {
        var el = document.getElementById('ap-msg');
        if (!el) return;
        if (!msg) { el.innerHTML = ''; return; }
        var cls = type === 'ok' ? 'ap-msg-ok' : 'ap-msg-err';
        el.innerHTML = '<div class="' + cls + '">' + apEsc(msg) + '</div>';
        if (type === 'ok') setTimeout(function() { el.innerHTML = ''; }, 3000);
    }

    function apSetSelect(id, val) {
        var sel = document.getElementById(id);
        if (!sel) return;
        for (var i = 0; i < sel.options.length; i++) {
            if (sel.options[i].value === val) { sel.selectedIndex = i; return; }
        }
    }

    function apEsc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

})();
    </script>
    <script>
(function() {
    var ISR_API = function(a) { return '/Admin/' + a; };

    window.isrInit = function() {
        fetch(ISR_API('GetIntegratorFormDataJson'))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var pSel = document.getElementById('isrProvider');
                if (pSel) pSel.innerHTML = data.providers.map(function(p) {
                    return '<option value="' + isrEsc(p.value) + '">' + isrEsc(p.label) + '</option>';
                }).join('');
                var companyId = data.currentCompanyId || (data.companies && data.companies.length > 0 ? data.companies[0].id : null);
                if (companyId) {
                    document.getElementById('isrCompanyId').value = companyId;
                    fetch(ISR_API('GetIntegratorsListJson') + '?companyId=' + companyId)
                        .then(function(r) { return r.json(); })
                        .then(function(items) { if (items && items.length > 0) isrLoad(items[0].id); });
                }
            });
    };

    function isrLoad(id) {
        fetch(ISR_API('GetIntegratorJson') + '?id=' + id)
            .then(function(r) { return r.json(); })
            .then(function(x) {
                if (!x) return;
                document.getElementById('isrId').value           = x.id || '';
                document.getElementById('isrCompanyId').value    = x.companyId || '';
                isrSetVal('isrProvider', x.provider);
                document.getElementById('isrBaseUrl').value      = x.baseUrl || '';
                document.getElementById('isrUsername').value     = x.username || '';
                document.getElementById('isrSecret').value       = '';
                document.getElementById('isrTimeout').value      = x.timeoutSeconds || 30;
                document.getElementById('isrLookback').value     = x.lookbackDays || 30;
                document.getElementById('isrPolling').value      = x.pollingIntervalSeconds || 120;
                document.getElementById('isrMaxPull').value      = x.maxRecordsPerPull || 200;
                document.getElementById('isrLogDays').value      = x.logRetentionDays || 30;
                document.getElementById('isrScheduleEnabled').checked       = x.scheduleEnabled;
                document.getElementById('isrIsActive').checked              = x.isActive;
                document.getElementById('isrInclReceived').checked          = x.includeReceivedDocumentsInPull;
                document.getElementById('isrMarkReceived').checked          = x.markDownloadedDocumentsAsReceived;
                document.getElementById('isrInvoices').checked              = x.includeIssuedEInvoicesInPull;
                document.getElementById('isrArchives').checked              = x.includeIssuedEArchivesInPull;
                document.getElementById('isrDispatches').checked            = x.includeIssuedEDispatchesInPull;
            });
    }

    function isrBuildPayload() {
        return {
            id: document.getElementById('isrId').value || null,
            companyId: document.getElementById('isrCompanyId').value || null,
            provider: document.getElementById('isrProvider').value,
            name: '',
            baseUrl: document.getElementById('isrBaseUrl').value,
            companyTaxNumber: '',
            username: document.getElementById('isrUsername').value,
            secret: document.getElementById('isrSecret').value,
            timeoutSeconds: parseInt(document.getElementById('isrTimeout').value) || 30,
            lookbackDays: parseInt(document.getElementById('isrLookback').value) || 30,
            pollingIntervalSeconds: parseInt(document.getElementById('isrPolling').value) || 120,
            maxRecordsPerPull: parseInt(document.getElementById('isrMaxPull').value) || 200,
            logRetentionDays: parseInt(document.getElementById('isrLogDays').value) || 30,
            includeReceivedDocumentsInPull: document.getElementById('isrInclReceived').checked,
            markDownloadedDocumentsAsReceived: document.getElementById('isrMarkReceived').checked,
            includeIssuedEInvoicesInPull: document.getElementById('isrInvoices').checked,
            includeIssuedEArchivesInPull: document.getElementById('isrArchives').checked,
            includeIssuedEDispatchesInPull: document.getElementById('isrDispatches').checked,
            isActive: document.getElementById('isrIsActive').checked,
            scheduleEnabled: document.getElementById('isrScheduleEnabled').checked
        };
    }

    window.isrSave = function() {
        fetch(ISR_API('SaveIntegratorSettingsJson'), {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(isrBuildPayload())
        }).then(function(r) { return r.json(); })
          .then(function(d) {
              isrToolbarMsg(d.message, d.success);
              if (d.success) {
                  var idEl = document.getElementById('isrId');
                  if (!idEl.value && d.id) idEl.value = d.id;
              }
          }).catch(function(e) { isrToolbarMsg('Hata: ' + e.message, false); });
    };

    window.isrDelete = async function() {
        var id = document.getElementById('isrId').value;
        if (!id) return;
        var ok = await CalibraAlert.confirm('Bu entegrator ayarini silmek istediginize emin misiniz?',
            { title: 'Entegrator Sil', okText: 'Evet, Sil', cancelText: 'Vazgec', danger: true });
        if (!ok) return;
        fetch(ISR_API('DeleteIntegratorSettingsJson') + '?id=' + id, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                isrToolbarMsg(d.message, d.success);
                if (d.success) { document.getElementById('isrId').value = ''; }
            });
    };

    window.isrTest = function() {
        isrTestMsg('Test ediliyor...', null);
        fetch(ISR_API('TestIntegratorConnectionJson'), {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(isrBuildPayload())
        }).then(function(r) { return r.json(); })
          .then(function(d) { isrTestMsg(d.message, d.success); })
          .catch(function(e) { isrTestMsg('Baglanti hatasi: ' + e.message, false); });
    };

    function isrTestMsg(msg, ok) {
        var el = document.getElementById('isrTestMsg');
        if (!el) return;
        if (!msg) { el.innerHTML = ''; return; }
        var cls = ok === null ? 'background:rgba(100,116,139,.12);color:#94a3b8;border:1px solid rgba(100,116,139,.2);'
            : ok ? 'background:rgba(16,185,129,.12);color:#34d399;border:1px solid rgba(52,211,153,.25);'
                 : 'background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(248,113,113,.25);';
        el.innerHTML = '<span style="display:inline-block;padding:3px 10px;border-radius:5px;font-size:0.72rem;' + cls + '">' + isrEsc(msg) + '</span>';
    }

    function isrToolbarMsg(msg, ok) {
        var el = document.getElementById('isrToolbarMsg');
        if (!el) return;
        if (!msg) { el.innerHTML = ''; return; }
        var cls = ok ? 'background:rgba(16,185,129,.12);color:#34d399;border:1px solid rgba(52,211,153,.25);'
                     : 'background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(248,113,113,.25);';
        el.innerHTML = '<span style="display:inline-block;padding:3px 10px;border-radius:5px;font-size:0.72rem;' + cls + '">' + isrEsc(msg) + '</span>';
        if (ok) setTimeout(function() { if (el) el.innerHTML = ''; }, 3000);
    }

    function isrSetVal(id, val) { var el = document.getElementById(id); if (el && val != null) el.value = val; }
    function isrEsc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
})();

// ── PTT Adres Kataloğu import ─────────────────────────────────
(function () {
    // 2026-07-06 — Adres Kataloğu pane'i kaldırıldı (şehir/ilçe ileride ayrı
    // tanımlama ekranına taşınacak). Pane DOM'da yoksa script hiç başlamaz.
    if (!document.getElementById('cs-pane-addresses')) return;
    function $id(id) { return document.getElementById(id); }

    async function refreshCount() {
        try {
            var r = await fetch('/Address/Status', { credentials: 'same-origin' });
            var d = await r.json();
            $id('addrCatalogCount').textContent = (d.count || 0).toLocaleString('tr-TR');
        } catch (e) { $id('addrCatalogCount').textContent = '?'; }
    }

    async function doImport() {
        var fileInput = $id('addrJsonFile');
        var msg = $id('addrImportMsg');
        var btn = $id('addrImportBtn');
        msg.textContent = '';
        if (!fileInput.files || fileInput.files.length === 0) {
            msg.textContent = 'Önce bir JSON dosyası seçiniz.';
            msg.style.color = '#f59e0b';
            return;
        }
        var file = fileInput.files[0];
        msg.textContent = 'Dosya okunuyor...';
        msg.style.color = '';
        try {
            var text = await file.text();
            var arr = JSON.parse(text);
            if (!Array.isArray(arr)) { throw new Error('JSON bir dizi olmalı (array).'); }
            // Farkli key isimlerini normalize et
            var rows = arr.map(function (x) {
                return {
                    countryCode:      x.countryCode || x.ulke || 'TR',
                    cityCode:         x.cityCode || x.ilKodu || x.plaka || null,
                    cityName:         x.cityName || x.il || x.city || '',
                    districtName:     x.districtName || x.ilce || x.district || '',
                    neighborhoodName: x.neighborhoodName || x.mahalle || x.neighborhood || x.koy || '',
                    postalCode:       x.postalCode || x.postaKodu || x.pk || null
                };
            }).filter(function (r) { return r.cityName && r.districtName && r.neighborhoodName; });

            if (rows.length === 0) { msg.textContent = 'Eşleşen satır yok. JSON yapısını kontrol ediniz.'; msg.style.color = '#f59e0b'; return; }

            msg.textContent = rows.length.toLocaleString('tr-TR') + ' satır yükleniyor...';
            btn.disabled = true;
            var clearExisting = $id('addrClearExisting').checked;
            var r = await fetch('/Address/ImportPtt', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ clearExisting: clearExisting, rows: rows })
            });
            var data = await r.json();
            if (!data.success) { msg.textContent = 'Hata: ' + (data.message || 'bilinmeyen'); msg.style.color = '#ef4444'; return; }
            msg.textContent = '✓ ' + (data.inserted || 0).toLocaleString('tr-TR') + ' satır başarıyla yüklendi.';
            msg.style.color = '#10b981';
            await refreshCount();
        } catch (e) {
            msg.textContent = 'Hata: ' + e.message;
            msg.style.color = '#ef4444';
        } finally {
            btn.disabled = false;
        }
    }

    async function doUrlImport() {
        var url = ($id('addrImportUrl').value || '').trim();
        var msg = $id('addrImportMsg');
        var btn = $id('addrUrlImportBtn');
        msg.textContent = '';
        if (!url) { msg.textContent = 'Önce bir URL giriniz.'; msg.style.color = '#f59e0b'; return; }
        msg.textContent = 'İndiriliyor ve yükleniyor (büyük dosyalarda 30-60 sn sürebilir)...';
        msg.style.color = '';
        btn.disabled = true;
        try {
            var clearExisting = $id('addrClearExisting').checked;
            var r = await fetch('/Address/ImportFromUrl', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ url: url, clearExisting: clearExisting })
            });
            var data = await r.json();
            if (!data.success) { msg.textContent = 'Hata: ' + (data.message || 'bilinmeyen'); msg.style.color = '#ef4444'; return; }
            msg.textContent = '✓ ' + (data.inserted || 0).toLocaleString('tr-TR') + ' satır indirildi & yüklendi.';
            msg.style.color = '#10b981';
            await refreshCount();
        } catch (e) {
            msg.textContent = 'Hata: ' + e.message;
            msg.style.color = '#ef4444';
        } finally {
            btn.disabled = false;
        }
    }

    async function doPreview() {
        var raw = ($id('addrImportUrl').value || '').trim();
        var msg = $id('addrImportMsg');
        var box = $id('addrPreviewBox');
        var content = $id('addrPreviewContent');
        msg.textContent = '';
        // Ilk URL'i al (cok URL girilmisse)
        var url = raw.split(/[\r\n]+/).map(function (s) { return s.trim(); }).filter(Boolean)[0];
        if (!url) { msg.textContent = 'URL giriniz.'; msg.style.color = '#f59e0b'; return; }
        msg.textContent = 'Önizleniyor...'; msg.style.color = '';
        try {
            var r = await fetch('/Address/PreviewUrl', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ url: url })
            });
            var data = await r.json();
            if (!data.success) {
                msg.textContent = 'Hata: ' + (data.message || 'bilinmeyen');
                msg.style.color = '#ef4444';
                box.style.display = 'none';
                return;
            }
            var sample = data.parsedSample || [];
            var summary = '✓ Kök dizide ' + (data.rootArrayLength || 0).toLocaleString('tr-TR')
                        + ' eleman, ilk ' + sample.length + ' satır parse edildi:\n\n';
            content.textContent = summary + JSON.stringify(sample, null, 2);
            box.style.display = '';
            if (sample.length === 0) {
                msg.textContent = '⚠ Hiç satır parse edilemedi — JSON yapısı tanınmıyor olabilir.';
                msg.style.color = '#f59e0b';
            } else {
                msg.textContent = 'Önizleme tamam. JSON yapısı uygun, "İndir & Yükle" ile devam edebilirsin.';
                msg.style.color = '#10b981';
            }
        } catch (e) {
            msg.textContent = 'Hata: ' + e.message;
            msg.style.color = '#ef4444';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        var btn = $id('addrImportBtn');
        if (btn) btn.addEventListener('click', doImport);
        var urlBtn = $id('addrUrlImportBtn');
        if (urlBtn) urlBtn.addEventListener('click', doUrlImport);
        var prevBtn = $id('addrPreviewBtn');
        if (prevBtn) prevBtn.addEventListener('click', doPreview);
        // Sayi ilk tab acilisinda gorunsun
        var tabBtn = document.querySelector('.cs-tab-btn[data-cs-tab="addresses"]');
        if (tabBtn) tabBtn.addEventListener('click', refreshCount);
        // Sayfayi acarken de fetch etsin (az trafik)
        refreshCount();
    });
})();

// ── WhatsApp tab handlers ───────────────────────────────────────────────
(function () {
    function getCsrf() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function waMsg(text, ok) {
        var el = document.getElementById('waMsg');
        if (!el) return;
        if (!text) { el.innerHTML = ''; return; }
        var bg = ok === null ? 'rgba(148,163,184,.12)' : (ok ? 'rgba(34,197,94,.12)' : 'rgba(239,68,68,.12)');
        var cl = ok === null ? 'var(--app-text-muted,#64748b)' : (ok ? '#16a34a' : '#dc2626');
        var br = ok === null ? 'rgba(148,163,184,.3)' : (ok ? 'rgba(34,197,94,.3)' : 'rgba(239,68,68,.3)');
        el.innerHTML = '<span style="display:inline-block;padding:5px 12px;border-radius:6px;background:'
            + bg + ';color:' + cl + ';border:1px solid ' + br + ';">' + text + '</span>';
    }

    window.waToggleEnabled = function (checked) {
        var body = document.getElementById('waBody');
        if (body) body.classList.toggle('wa-body--disabled', !checked);
        if (checked && _isWebQrSelected()) _startQrPoll();
        else if (!checked) _stopQrPoll();
    };

    window.waSelectProvider = function (p) {
        var hidden = document.getElementById('waProvider');
        if (!hidden) return;
        hidden.value = p;
        document.querySelectorAll('.wa-prov-card').forEach(function (t) {
            t.classList.toggle('is-active', parseInt(t.dataset.waProvider) === p);
        });
        var cap = document.getElementById('waPanelCloudApi');
        var qr  = document.getElementById('waPanelWebQr');
        if (cap) cap.style.display = (p === 0 ? '' : 'none');
        if (qr)  qr.style.display  = (p === 1 ? '' : 'none');
        if (p === 1 && _isWaEnabled()) _startQrPoll(); else _stopQrPoll();
    };

    window.waSave = function () {
        var providerEl = document.getElementById('waProvider');
        if (!providerEl) return;
        var fd = new FormData();
        fd.append('provider', providerEl.value);
        fd.append('accessToken', (document.getElementById('waToken') || {}).value || '');
        fd.append('appSecret', (document.getElementById('waAppSecret') || {}).value || '');
        fd.append('phoneNumberId', (document.getElementById('waPhoneId') || {}).value || '');
        fd.append('businessAccountId', (document.getElementById('waBizId') || {}).value || '');
        fd.append('webhookVerifyToken', (document.getElementById('waWebhookToken') || {}).value || '');
        fd.append('webQrBridgeUrl', (document.getElementById('waBridgeUrl') || {}).value || '');
        fd.append('isEnabled', document.getElementById('waEnabled').checked ? 'true' : 'false');
        fd.append('__RequestVerificationToken', getCsrf());
        waMsg('Kaydediliyor...', null);
        fetch('/Admin/WhatsApp/Save', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                waMsg(d.message || (d.success ? 'Kaydedildi' : 'Hata'), d.success);
                if (d.success) setTimeout(function () { location.reload(); }, 800);
            });
    };

    window.waTest = function () {
        waMsg('Test ediliyor...', null);
        var fd = new FormData(); fd.append('__RequestVerificationToken', getCsrf());
        fetch('/Admin/WhatsApp/Test', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                // kind: 'ok' (yesil) | 'info' (sari/notr — Bridge connecting/awaiting_qr) | 'error' (kirmizi)
                var ok;
                if (d.kind === 'info') ok = null;             // notr — gecici durum, hata degil
                else if (d.kind === 'error') ok = false;      // gercek hata
                else ok = d.success;                           // backwards-compat
                waMsg(d.message || (d.success ? 'OK' : 'Hata'), ok);
                if (d.success) setTimeout(function () { location.reload(); }, 1200);
            });
    };

    window.waSendTest = function () {
        var to  = (document.getElementById('waToPhone') || {}).value || '';
        var msg = (document.getElementById('waText')    || {}).value || '';
        if (!to.trim())  { waMsg('Hedef numara zorunlu.', false); return; }
        if (!msg.trim()) { waMsg('Mesaj zorunlu.', false); return; }
        waMsg('Mesaj gönderiliyor...', null);
        var fd = new FormData();
        fd.append('toPhone', to.trim());
        fd.append('message', msg.trim());
        fd.append('__RequestVerificationToken', getCsrf());
        fetch('/Admin/WhatsApp/SendTest', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) { waMsg(d.message || (d.success ? 'Gönderildi' : 'Hata'), d.success); });
    };

    // ── Pairing Code (Baileys) ────────────────────────────────────────────
    function waSetupPairingButton() {
        var btn = document.getElementById('waPairBtn');
        if (!btn) return;
        // Rapor §6.6 — native alert → CalibraAlert/toast (fallback alert)
        function _waNotify(msg, kind) {
            if (window.CalibraAlert && CalibraAlert[kind]) { CalibraAlert[kind](msg); return; }
            if (window.CalibraHub && CalibraHub.toast) { CalibraHub.toast(msg, kind === 'error' ? 'err' : (kind === 'warn' ? 'warn' : 'ok')); return; }
            alert(msg);
        }
        btn.addEventListener('click', function () {
            var phoneEl = document.getElementById('waPairPhone');
            var raw = (phoneEl?.value || '').replace(/[^\d]/g, '');
            if (raw.length < 10) { _waNotify('Telefon en az 10 basamak olmali (ulke kodu dahil)', 'warn'); return; }

            btn.disabled = true; btn.textContent = 'Kod aliniyor...';
            var fd = new FormData();
            fd.append('phone', raw);
            fd.append('__RequestVerificationToken', getCsrf());
            fetch('/Admin/WhatsApp/PairingCode', { method: 'POST', body: fd, credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    btn.disabled = false; btn.textContent = 'Kod Al';
                    if (d.success && d.code) {
                        document.getElementById('waPairResult').style.display = '';
                        document.getElementById('waPairCode').textContent = d.code;
                        // Otomatik kopyala
                        try {
                            var codeEl = document.getElementById('waPairCode');
                            codeEl.addEventListener('click', function () {
                                navigator.clipboard?.writeText(d.code);
                            });
                        } catch (e) { /* ignore */ }
                    } else {
                        _waNotify('Kod alinamadi: ' + (d.message || 'bilinmeyen hata'), 'error');
                    }
                })
                .catch(function (err) {
                    btn.disabled = false; btn.textContent = 'Kod Al';
                    _waNotify('Aglar hatasi: ' + err.message, 'error');
                });
        });
    }
    waSetupPairingButton();

    // ── Web QR polling (Bridge'in /status + /qr cevabini server uzerinden cek) ──
    var _qrTimer = null;
    var _lastQr = null;

    function _setQrMsg(text, color) {
        var el = document.getElementById('waQrMsg');
        if (!el) return;
        el.textContent = text;
        el.style.color = color || 'var(--app-text-muted,#64748b)';
    }
    function _setQrImg(dataUrl) {
        var img = document.getElementById('waQrImg');
        if (!img) return;
        if (dataUrl) {
            if (_lastQr !== dataUrl) { img.src = dataUrl; _lastQr = dataUrl; }
            img.style.display = '';
        } else {
            img.style.display = 'none';
            img.removeAttribute('src');
            _lastQr = null;
        }
    }
    function _applyQrState(d) {
        if (!d) return;
        if (!d.reachable) {
            _setQrImg(null);
            // 'disabled' / 'no_url' = ayarlar henuz DB'ye kaydedilmemis — bridge sorunu degil.
            if (d.state === 'disabled' || d.state === 'no_url') {
                _setQrMsg('Ayarlar henuz kaydedilmedi — Web QR secip alttaki Kaydet butonuna basin.', '#d97706');
            } else {
                _setQrMsg('Bridge\'e ulasilamiyor: ' + (d.error || 'bilinmeyen hata'), '#dc2626');
            }
            return;
        }
        switch (d.state) {
            case 'awaiting_qr':
                if (d.qr) {
                    _setQrImg(d.qr);
                    _setQrMsg('Telefondan tara: WhatsApp → Bagli Cihazlar → Cihaz Bagla', '#16a34a');
                } else {
                    _setQrImg(null);
                    _setQrMsg('QR bekleniyor...', null);
                }
                break;
            case 'connecting':
                _setQrImg(null);
                _setQrMsg('Bridge baglaniyor (~10sn)...', null);
                break;
            case 'ready':
                _setQrImg(null);
                _setQrMsg('Bagli: ' + (d.displayName || '') + (d.phone ? ' (+' + d.phone + ')' : ''), '#16a34a');
                _stopQrPoll();
                // Reload yok — uzerine biniyor. DOM'u in-place guncelle: WhatsApp YONETIMI altindaki
                // status div'i guncellenir.
                var oldStatus = document.querySelector('.wa-status--off, .wa-status--warn');
                if (oldStatus && d.phone) {
                    oldStatus.className = 'wa-status wa-status--ok';
                    oldStatus.innerHTML = '✓ Aktif — <b>+' + d.phone + '</b> (Web QR)';
                }
                break;
            default:
                _setQrImg(null);
                _setQrMsg('Bridge state: ' + d.state, null);
        }
    }
    function _pollQrOnce() {
        return fetch('/Admin/WhatsApp/Qr', { credentials: 'same-origin', cache: 'no-store' })
            .then(function (r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(_applyQrState)
            .catch(function (err) {
                console.error('[WA-QR] polling hatasi:', err);
                _setQrImg(null);
                _setQrMsg('QR cekilemedi: ' + (err && err.message ? err.message : err), '#dc2626');
            });
    }
    function _startQrPoll() {
        if (_qrTimer) return;
        console.log('[WA-QR] polling basliyor (her 4sn)');
        _setQrMsg('Bridge sorgulaniyor...', null);
        _pollQrOnce();
        _qrTimer = setInterval(_pollQrOnce, 4000); // 4sn — daha rahat, flicker'i azaltir
    }
    function _stopQrPoll() {
        if (_qrTimer) { clearInterval(_qrTimer); _qrTimer = null; console.log('[WA-QR] polling durdu'); }
    }
    function _isWebQrSelected() {
        var p = document.getElementById('waProvider');
        return p && parseInt(p.value, 10) === 1;
    }
    function _isWaEnabled() {
        var el = document.getElementById('waEnabled');
        return el ? el.checked : false;
    }

    // Web QR zaten seciliyse ve entegrasyon aktifse polling'i hemen baslatıyoruz
    if (_isWebQrSelected() && _isWaEnabled()) _startQrPoll();

    // Sayfa arka plana gecince polling durdur; geri gelince tekrar baslatiyoruz
    document.addEventListener('visibilitychange', function () {
        if (document.hidden) _stopQrPoll();
        else if (_isWebQrSelected()) _startQrPoll();
    });
})();
    </script>
}
