@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    // Genel Kaydet butonu — aktif taba göre dispatch
    window.csSave = function() {
        var active = document.querySelector('.cs-tab-btn.is-active');
        var tab = active ? active.getAttribute('data-cs-tab') : 'general';
        if (tab === 'integrator') { isrSave(); return; }
        if (tab === 'apiprofile') { apSave(); return; }
        document.getElementById('company-form').submit();
    };

    (function () {
        // Auth method toggle
        var authSelect = document.getElementById('authMethodSelect');
        var oauthPanel = document.getElementById('oauthPanel');
        var pwdLabel = document.getElementById('smtpPasswordLabel');
        function updateAuth() {
            if (!authSelect) return;
            var m = authSelect.value;
            if (oauthPanel) oauthPanel.style.display = m === 'OAuth2' ? 'block' : 'none';
            if (pwdLabel) pwdLabel.textContent = m === 'AppPassword' ? 'Uygulama Sifresi' : m === 'OAuth2' ? 'Sifre (opsiyonel)' : 'Sifre';
            // Talimatlar
            document.querySelectorAll('.cs-instruction').forEach(function (el) { el.style.display = 'none'; });
            var inst = document.getElementById('instruction' + m);
            if (inst) inst.style.display = 'block';
        }
        if (authSelect) { authSelect.addEventListener('change', updateAuth); updateAuth(); }

        // SMTP test
        var testBtn = document.getElementById('btnTestSmtp');
        if (testBtn) {
            testBtn.addEventListener('click', async function () {
                testBtn.disabled = true; testBtn.textContent = 'Test ediliyor...';
                try {
                    var f = document.getElementById('company-form');
                    var fd = new FormData(f);
                    var token = fd.get('__RequestVerificationToken') || '';
                    var resp = await fetch('@Url.Action("TestSmtpConnectionJson", "Admin")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({
                            companyId: parseInt(fd.get('SmtpInput.CompanyId')) || 0,
                            name: fd.get('SmtpInput.Name') || 'Test',
                            fromEmail: fd.get('SmtpInput.FromEmail') || '',
                            fromDisplayName: fd.get('SmtpInput.FromDisplayName') || '',
                            host: fd.get('SmtpInput.Host') || '',
                            port: parseInt(fd.get('SmtpInput.Port')) || 587,
                            username: fd.get('SmtpInput.Username') || '',
                            password: fd.get('SmtpInput.Password') || '',
                            useSsl: fd.get('SmtpInput.UseSsl') === 'true',
                            testRecipientEmail: fd.get('SmtpInput.TestRecipientEmail') || null
                        })
                    });
                    var data = await resp.json();
                    alert(data.isSuccess ? '✓ ' + data.message : '✗ ' + data.message);
                } catch (e) { alert('Test hatasi: ' + e.message); }
                finally { testBtn.disabled = false; testBtn.textContent = 'Baglanti Test Et'; }
            });
        }

        // Tab gecisi
        document.querySelectorAll('.cs-tab-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.cs-tab-btn').forEach(function (b) { b.classList.remove('is-active'); });
                document.querySelectorAll('.cs-tab-pane').forEach(function (p) { p.classList.remove('is-active'); });
                btn.classList.add('is-active');
                var tab = btn.getAttribute('data-cs-tab');
                var pane = document.getElementById('cs-pane-' + tab);
                if (pane) pane.classList.add('is-active');
                if (tab === 'apiprofile') apLoad();
                if (tab === 'integrator' && !window._isrInited) { window._isrInited = true; isrInit(); }
            });
        });
    })();
    </script>
    <script>
(function() {
    var _apSelectedId = null;

    window.apLoad = function apLoad() {
        fetch('/Admin/GetApiProfilesJson')
            .then(function(r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function(profiles) {
                var tbody = document.getElementById('apTableBody');
                if (profiles.error) {
                    tbody.innerHTML = '<tr><td colspan="5" style="padding:16px;text-align:center;color:#991b1b;">' + apEsc(profiles.message) + '</td></tr>';
                    return;
                }
                if (!profiles.length) {
                    tbody.innerHTML = '<tr><td colspan="5" style="padding:16px;text-align:center;color:#94a3b8;">Profil bulunamadi. Formu doldurup Kaydet\'e basin.</td></tr>';
                    return;
                }
                tbody.innerHTML = profiles.map(function(p) {
                    var enc = JSON.stringify(p).replace(/"/g,'&quot;');
                    var selCls = p.id === _apSelectedId ? ' ap-tr-sel' : '';
                    return '<tr class="' + selCls + '">' +
                        '<td class="ap-td" style="white-space:nowrap;">' +
                            '<button type="button" class="ap-btn-edit" onclick="apSelect(' + enc + ')" title="Duzenle">&#9998;</button>' +
                            '<button type="button" class="ap-btn-del" onclick="apDeleteById(\'' + p.id + '\')" title="Sil">&#128465;</button>' +
                        '</td>' +
                        '<td class="ap-td">' + apEsc(p.name) + '</td>' +
                        '<td class="ap-td">' + apEsc(p.authType) + '</td>' +
                        '<td class="ap-td" style="font-size:0.78rem;opacity:.75;">' + apEsc(p.baseUrl) + '</td>' +
                        '<td class="ap-td" style="text-align:center;">' + (p.isActive ? '&#x2713;' : '') + '</td>' +
                        '</tr>';
                }).join('');
            })
            .catch(function(e) { apMsg('err', 'Liste yuklenemedi: ' + e.message); });
    }

    window.apSelect = function(p) {
        _apSelectedId = p.id;
        document.getElementById('apId').value = p.id;
        document.getElementById('apName').value = p.name;
        document.getElementById('apBaseUrl').value = p.baseUrl;
        apSetSelect('apAuthType', p.authType || 'None');
        document.getElementById('apIsActive').checked = p.isActive;
        apLoadAuthConfig(p.authType, p.authConfigJson);
        apMsg('', '');
    };

    function apClearForm() {
        _apSelectedId = null;
        document.getElementById('apId').value = '';
        document.getElementById('apName').value = '';
        document.getElementById('apBaseUrl').value = '';
        apSetSelect('apAuthType', 'None');
        document.getElementById('apIsActive').checked = true;
        apClearAuth();
        apMsg('', '');
    }

    window.apSave = function() {
        var name = document.getElementById('apName').value.trim();
        var baseUrl = document.getElementById('apBaseUrl').value.trim();
        if (!name) { apMsg('err', 'Profil adi zorunludur.'); return; }
        if (!baseUrl) { apMsg('err', 'Base URL zorunludur.'); return; }
        var authType = document.getElementById('apAuthType').value;
        var payload = {
            id: document.getElementById('apId').value || null,
            name: name,
            baseUrl: baseUrl,
            authType: authType,
            authConfigJson: apBuildAuthConfig(authType),
            isActive: document.getElementById('apIsActive').checked
        };
        fetch('/Admin/SaveApiProfileJson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        }).then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        }).then(function(d) {
            apMsg(d.success ? 'ok' : 'err', d.message);
            if (d.success) { apClearForm(); apLoad(); }
        }).catch(function(e) { apMsg('err', 'Kayit hatasi: ' + e.message); });
    };

    window.apDeleteById = function(id) {
        if (!confirm('Bu profili silmek istediginizden emin misiniz?')) return;
        fetch('/Admin/DeleteApiProfileJson?id=' + id, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                apMsg(d.success ? 'ok' : 'err', d.message);
                if (d.success) { apClearForm(); apLoad(); }
            })
            .catch(function(e) { apMsg('err', 'Silme hatasi: ' + e.message); });
    };

    window.apAuthChange = function() {
        var at = document.getElementById('apAuthType').value;
        document.getElementById('apAuthOAuth2').style.display = at === 'OAuth2Password' ? '' : 'none';
        document.getElementById('apAuthBearer').style.display = at === 'BearerStatic' ? '' : 'none';
        document.getElementById('apAuthBasic').style.display = at === 'BasicAuth' ? '' : 'none';
        document.getElementById('apAuthApiKey').style.display = at === 'ApiKey' ? '' : 'none';
    };

    function apLoadAuthConfig(authType, json) {
        apClearAuth();
        apSetSelect('apAuthType', authType || 'None');
        apAuthChange();
        if (!json) return;
        try {
            var c = JSON.parse(json);
            if (authType === 'OAuth2Password') {
                document.getElementById('apOAuthTokenEndpoint').value = c.tokenEndpoint || '';
                document.getElementById('apOAuthUsername').value = c.username || '';
                document.getElementById('apOAuthPassword').value = c.password || '';
                var ef = c.extraFields || {};
                document.getElementById('apOAuthBranchCode').value = ef.branchcode || '0';
                document.getElementById('apOAuthDbName').value = ef.dbname || '';
                document.getElementById('apOAuthDbUser').value = ef.dbuser || 'sa';
                document.getElementById('apOAuthDbPassword').value = ef.dbpassword || '';
                document.getElementById('apOAuthDbType').value = ef.dbtype || '0';
            } else if (authType === 'BearerStatic') {
                document.getElementById('apBearerToken').value = c.token || '';
            } else if (authType === 'BasicAuth') {
                document.getElementById('apBasicUsername').value = c.username || '';
                document.getElementById('apBasicPassword').value = c.password || '';
            } else if (authType === 'ApiKey') {
                document.getElementById('apApiKeyHeader').value = c.apiKeyHeader || '';
                document.getElementById('apApiKeyValue').value = c.apiKeyValue || '';
            }
        } catch(e) {}
    }

    function apBuildAuthConfig(authType) {
        if (authType === 'None') return null;
        var c = {};
        if (authType === 'OAuth2Password') {
            c = {
                tokenEndpoint: document.getElementById('apOAuthTokenEndpoint').value,
                tokenField: 'access_token',
                grantType: 'password',
                username: document.getElementById('apOAuthUsername').value,
                password: document.getElementById('apOAuthPassword').value,
                extraFields: {
                    branchcode: document.getElementById('apOAuthBranchCode').value,
                    dbname: document.getElementById('apOAuthDbName').value,
                    dbuser: document.getElementById('apOAuthDbUser').value,
                    dbpassword: document.getElementById('apOAuthDbPassword').value,
                    dbtype: document.getElementById('apOAuthDbType').value
                }
            };
        } else if (authType === 'BearerStatic') {
            c = { token: document.getElementById('apBearerToken').value };
        } else if (authType === 'BasicAuth') {
            c = { username: document.getElementById('apBasicUsername').value, password: document.getElementById('apBasicPassword').value };
        } else if (authType === 'ApiKey') {
            c = { apiKeyHeader: document.getElementById('apApiKeyHeader').value, apiKeyValue: document.getElementById('apApiKeyValue').value };
        }
        return JSON.stringify(c);
    }

    function apClearAuth() {
        ['apOAuthTokenEndpoint','apOAuthUsername','apOAuthPassword','apOAuthDbName','apOAuthDbPassword',
         'apBearerToken','apBasicUsername','apBasicPassword','apApiKeyHeader','apApiKeyValue'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.value = '';
        });
        document.getElementById('apOAuthBranchCode').value = '0';
        document.getElementById('apOAuthDbUser').value = 'sa';
        document.getElementById('apOAuthDbType').value = '0';
        apAuthChange();
    }

    function apMsg(type, msg) {
        var el = document.getElementById('ap-msg');
        if (!el) return;
        if (!msg) { el.innerHTML = ''; return; }
        var cls = type === 'ok' ? 'ap-msg-ok' : 'ap-msg-err';
        el.innerHTML = '<div class="' + cls + '">' + apEsc(msg) + '</div>';
        if (type === 'ok') setTimeout(function() { el.innerHTML = ''; }, 3000);
    }

    function apSetSelect(id, val) {
        var sel = document.getElementById(id);
        if (!sel) return;
        for (var i = 0; i < sel.options.length; i++) {
            if (sel.options[i].value === val) { sel.selectedIndex = i; return; }
        }
    }

    function apEsc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

})();
    </script>
    <script>
(function() {
    var ISR_API = function(a) { return '/Admin/' + a; };

    window.isrInit = function() {
        fetch(ISR_API('GetIntegratorFormDataJson'))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var pSel = document.getElementById('isrProvider');
                if (pSel) pSel.innerHTML = data.providers.map(function(p) {
                    return '<option value="' + isrEsc(p.value) + '">' + isrEsc(p.label) + '</option>';
                }).join('');
                var companyId = data.currentCompanyId || (data.companies && data.companies.length > 0 ? data.companies[0].id : null);
                if (companyId) {
                    document.getElementById('isrCompanyId').value = companyId;
                    fetch(ISR_API('GetIntegratorsListJson') + '?companyId=' + companyId)
                        .then(function(r) { return r.json(); })
                        .then(function(items) { if (items && items.length > 0) isrLoad(items[0].id); });
                }
            });
    };

    function isrLoad(id) {
        fetch(ISR_API('GetIntegratorJson') + '?id=' + id)
            .then(function(r) { return r.json(); })
            .then(function(x) {
                if (!x) return;
                document.getElementById('isrId').value           = x.id || '';
                document.getElementById('isrCompanyId').value    = x.companyId || '';
                isrSetVal('isrProvider', x.provider);
                document.getElementById('isrBaseUrl').value      = x.baseUrl || '';
                document.getElementById('isrUsername').value     = x.username || '';
                document.getElementById('isrSecret').value       = '';
                document.getElementById('isrTimeout').value      = x.timeoutSeconds || 30;
                document.getElementById('isrLookback').value     = x.lookbackDays || 30;
                document.getElementById('isrPolling').value      = x.pollingIntervalSeconds || 120;
                document.getElementById('isrMaxPull').value      = x.maxRecordsPerPull || 200;
                document.getElementById('isrLogDays').value      = x.logRetentionDays || 30;
                document.getElementById('isrScheduleEnabled').checked       = x.scheduleEnabled;
                document.getElementById('isrIsActive').checked              = x.isActive;
                document.getElementById('isrInclReceived').checked          = x.includeReceivedDocumentsInPull;
                document.getElementById('isrMarkReceived').checked          = x.markDownloadedDocumentsAsReceived;
                document.getElementById('isrInvoices').checked              = x.includeIssuedEInvoicesInPull;
                document.getElementById('isrArchives').checked              = x.includeIssuedEArchivesInPull;
                document.getElementById('isrDispatches').checked            = x.includeIssuedEDispatchesInPull;
            });
    }

    function isrBuildPayload() {
        return {
            id: document.getElementById('isrId').value || null,
            companyId: document.getElementById('isrCompanyId').value || null,
            provider: document.getElementById('isrProvider').value,
            name: '',
            baseUrl: document.getElementById('isrBaseUrl').value,
            companyTaxNumber: '',
            username: document.getElementById('isrUsername').value,
            secret: document.getElementById('isrSecret').value,
            timeoutSeconds: parseInt(document.getElementById('isrTimeout').value) || 30,
            lookbackDays: parseInt(document.getElementById('isrLookback').value) || 30,
            pollingIntervalSeconds: parseInt(document.getElementById('isrPolling').value) || 120,
            maxRecordsPerPull: parseInt(document.getElementById('isrMaxPull').value) || 200,
            logRetentionDays: parseInt(document.getElementById('isrLogDays').value) || 30,
            includeReceivedDocumentsInPull: document.getElementById('isrInclReceived').checked,
            markDownloadedDocumentsAsReceived: document.getElementById('isrMarkReceived').checked,
            includeIssuedEInvoicesInPull: document.getElementById('isrInvoices').checked,
            includeIssuedEArchivesInPull: document.getElementById('isrArchives').checked,
            includeIssuedEDispatchesInPull: document.getElementById('isrDispatches').checked,
            isActive: document.getElementById('isrIsActive').checked,
            scheduleEnabled: document.getElementById('isrScheduleEnabled').checked
        };
    }

    window.isrSave = function() {
        fetch(ISR_API('SaveIntegratorSettingsJson'), {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(isrBuildPayload())
        }).then(function(r) { return r.json(); })
          .then(function(d) {
              isrToolbarMsg(d.message, d.success);
              if (d.success) {
                  var idEl = document.getElementById('isrId');
                  if (!idEl.value && d.id) idEl.value = d.id;
              }
          }).catch(function(e) { isrToolbarMsg('Hata: ' + e.message, false); });
    };

    window.isrDelete = function() {
        var id = document.getElementById('isrId').value;
        if (!id || !confirm('Bu entegrator ayarini silmek istediginize emin misiniz?')) return;
        fetch(ISR_API('DeleteIntegratorSettingsJson') + '?id=' + id, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                isrToolbarMsg(d.message, d.success);
                if (d.success) { document.getElementById('isrId').value = ''; }
            });
    };

    window.isrTest = function() {
        isrTestMsg('Test ediliyor...', null);
        fetch(ISR_API('TestIntegratorConnectionJson'), {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(isrBuildPayload())
        }).then(function(r) { return r.json(); })
          .then(function(d) { isrTestMsg(d.message, d.success); })
          .catch(function(e) { isrTestMsg('Baglanti hatasi: ' + e.message, false); });
    };

    function isrTestMsg(msg, ok) {
        var el = document.getElementById('isrTestMsg');
        if (!el) return;
        if (!msg) { el.innerHTML = ''; return; }
        var cls = ok === null ? 'background:rgba(100,116,139,.12);color:#94a3b8;border:1px solid rgba(100,116,139,.2);'
            : ok ? 'background:rgba(16,185,129,.12);color:#34d399;border:1px solid rgba(52,211,153,.25);'
                 : 'background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(248,113,113,.25);';
        el.innerHTML = '<span style="display:inline-block;padding:3px 10px;border-radius:5px;font-size:0.72rem;' + cls + '">' + isrEsc(msg) + '</span>';
    }

    function isrToolbarMsg(msg, ok) {
        var el = document.getElementById('isrToolbarMsg');
        if (!el) return;
        if (!msg) { el.innerHTML = ''; return; }
        var cls = ok ? 'background:rgba(16,185,129,.12);color:#34d399;border:1px solid rgba(52,211,153,.25);'
                     : 'background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(248,113,113,.25);';
        el.innerHTML = '<span style="display:inline-block;padding:3px 10px;border-radius:5px;font-size:0.72rem;' + cls + '">' + isrEsc(msg) + '</span>';
        if (ok) setTimeout(function() { if (el) el.innerHTML = ''; }, 3000);
    }

    function isrSetVal(id, val) { var el = document.getElementById(id); if (el && val != null) el.value = val; }
    function isrEsc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
})();
    </script>
}
