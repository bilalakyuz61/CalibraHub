                        </div>
                        <div class="isr-line">
                            <label>Geriye Bakis (gun)</label>
                            <input id="isrLookback" type="number" class="form-control form-control-sm" value="30" />
                            <span class="isr-line-desc">Veri cekerken kac gun geriye bakilsin</span>
                        </div>
                        <div class="isr-line">
                            <label>Cekme Araligi (sn)</label>
                            <input id="isrPolling" type="number" class="form-control form-control-sm" value="120" />
                            <span class="isr-line-desc">Zamanlanmis gorev kac saniyede bir calissin</span>
                        </div>
                        <div class="isr-line">
                            <label>Max Kayit Pull</label>
                            <input id="isrMaxPull" type="number" class="form-control form-control-sm" value="200" />
                            <span class="isr-line-desc">Tek seferinde cekilecek maksimum belge sayisi</span>
                        </div>
                        <div class="isr-line">
                            <label>Log Saklama (Gun)</label>
                            <input id="isrLogDays" type="number" class="form-control form-control-sm" value="30" />
                            <span class="isr-line-desc">Entegrasyon calisma gecmisi kac gun saklansin</span>
                        </div>
                        <div class="isr-line" style="margin-top:6px;">
                            <label></label>
                            <button type="button" class="isr-test-btn" onclick="isrTest()">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="flex-shrink:0;"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                Baglanti Test
                            </button>
                            <span id="isrTestMsg"></span>
                        </div>
                    </div>
                </div>

                @* 2026-07-06 — "Adres Kataloğu (PTT)" pane'i kaldırıldı; şehir/ilçe için
                   ileride ayrı tanımlama ekranı yapılacak. AddressController + DB duruyor. *@
                @if (false)
                {
                <!-- Adres Kataloğu (PTT) — devre dışı -->
                <div class="cs-tab-pane" id="cs-pane-addresses" data-cs-pane-key="addresses">
                    <div class="cs-section-title">PTT Posta Kodu Kataloğu</div>
                    <p style="margin:6px 0 14px;font-size:.82rem;color:rgba(100,116,139,.9);">
                        Cari kartlarındaki İl / İlçe / Mahalle dropdown'ları bu katalogdan beslenir. PTT verisini
                        (JSON formatında) yükleyerek katalogu güncelleyebilirsiniz. Önerilen kaynak:
                        <a href="https://postakodu.ptt.gov.tr/" target="_blank" rel="noopener">postakodu.ptt.gov.tr</a>
                        veya topluluk dataset'leri (örn. GitHub <code>basakalagon/turkiye-il-ilce-mahalle</code>).
                    </p>

                    <div class="cs-line" style="align-items:center;">
                        <label>Mevcut Satır</label>
                        <span id="addrCatalogCount" style="font-weight:700;font-size:.9rem;">–</span>
                        <span style="color:rgba(100,116,139,.7);font-size:.78rem;">satır DB'de mevcut</span>
                    </div>

                    <div style="border-top:1px dashed rgba(148,163,184,.3);margin:14px 0;"></div>

                    <div class="cs-section-title" style="font-size:.86rem;margin-top:0;">1) URL'den İndir</div>
                    <div class="cs-line" style="align-items:flex-start;">
                        <label>URL(ler)</label>
                        <div style="display:flex;flex-direction:column;gap:6px;flex:1;">
                            <textarea id="addrImportUrl" class="form-control form-control-sm" rows="5"
                                      placeholder="https://kurum-icin-host/adres-data.json (her satıra bir URL)"
                                      style="font-family:monospace;font-size:.78rem;"></textarea>
                            <div style="font-size:.72rem;color:rgba(100,116,139,.85);line-height:1.5;">
                                Her satıra bir URL — birden fazla olabilir, sunucu sırayla indirip tek transaction'da yükler.
                                Lisanslı PTT verisini, NVI/UAVT'den alınan dosyayı veya kurum içi sunucuda host edilen JSON'u buraya yapıştırın.
                                <br><br>
                                <strong>Desteklenen JSON formatları:</strong>
                                <ul style="margin:4px 0 0 18px;padding:0;">
                                    <li><strong>Flat:</strong> <code>[{"cityName":"İstanbul","districtName":"Kadıköy","neighborhoodName":"Caferağa","postalCode":"34710"}, ...]</code></li>
                                    <li><strong>Nested:</strong> <code>[{"il":"İstanbul","ilceler":[{"ilce":"Kadıköy","mahalleler":[{"mahalle":"Caferağa","postaKodu":"34710"}]}]}]</code></li>
                                    <li><strong>Wrapper:</strong> <code>{"data":[...]}</code> veya <code>{"results":[...]}</code> — iç dizi otomatik bulunur</li>
                                </ul>
                                <strong>Kabul edilen key isimleri (TR/EN):</strong> il/cityName, ilce/districtName, mahalle/neighborhoodName, postaKodu/postalCode/zip, plaka/cityCode, ulke/countryCode
                            </div>
                        </div>
                    </div>
                    <div class="cs-line">
                        <label></label>
                        <div style="display:flex;gap:8px;align-items:center;">
                            <button type="button" class="btn btn-secondary btn-sm" id="addrPreviewBtn">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                                Önizle (DB'ye yazmaz)
                            </button>
                            <button type="button" class="btn btn-primary btn-sm" id="addrUrlImportBtn">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                İndir & Yükle
                            </button>
                            <span id="addrImportMsg" style="font-size:.82rem;"></span>
                        </div>
                    </div>
                    <div class="cs-line" id="addrPreviewBox" style="display:none;align-items:flex-start;">
                        <label>Önizleme</label>
                        <div style="flex:1;font-family:monospace;font-size:.74rem;background:rgba(0,0,0,.04);border:1px solid rgba(148,163,184,.25);border-radius:6px;padding:10px;max-height:260px;overflow:auto;white-space:pre;" id="addrPreviewContent"></div>
                    </div>

                    <div style="border-top:1px dashed rgba(148,163,184,.3);margin:18px 0 14px;"></div>

                    <div class="cs-section-title" style="font-size:.86rem;margin-top:0;">2) Yerel JSON Dosyasından Yükle</div>
                    <div class="cs-line" style="align-items:flex-start;">
                        <label>JSON Dosyası</label>
                        <div style="display:flex;flex-direction:column;gap:8px;flex:1;">
                            <input type="file" id="addrJsonFile" accept=".json,application/json" class="form-control form-control-sm" style="max-width:420px;" />
                            <div style="font-size:.72rem;color:rgba(100,116,139,.8);">
                                Format: <code>[{ "cityName":"İstanbul","districtName":"Kadıköy","neighborhoodName":"Caferağa","postalCode":"34710" }, ...]</code>
                            </div>
                        </div>
                    </div>
                    <div class="cs-line">
                        <label></label>
                        <button type="button" class="btn btn-secondary btn-sm" id="addrImportBtn">
                            Dosyadan Yükle
                        </button>
                    </div>

                    <div class="cs-line" style="margin-top:14px;">
                        <label></label>
                        <label style="display:inline-flex;align-items:center;gap:8px;font-size:.82rem;">
                            <input type="checkbox" id="addrClearExisting" checked />
                            Yüklerken mevcut katalogu sıfırla (TRUNCATE)
                        </label>
                    </div>
                </div>
                }

                @{
                    var waCfg = ViewBag.WhatsAppConfig as CalibraHub.Domain.Entities.WhatsAppConfig;
                    var waProviderInt = waCfg is null ? 0 : (int)waCfg.Provider;
                }

                <!-- WhatsApp Tab Pane -->
                <div class="cs-tab-pane@(firstVisible == "whatsapp" ? " is-active" : "")" id="cs-pane-whatsapp" data-cs-pane-key="whatsapp">
                    <div class="cs-section-title">WhatsApp Yönetimi</div>

                    <!-- Entegrasyon switch — en üstte -->
                    <div class="wa-toggle-row">
                        <div class="wa-toggle-label">
                            WhatsApp Entegrasyonu
                            <small>Kapalıyken mesaj gönderme/alma devre dışı kalır</small>
                        </div>
                        <label class="wa-switch" title="WhatsApp entegrasyonunu etkinleştir/devre dışı bırak">
                            <input type="checkbox" id="waEnabled" @(waCfg?.IsEnabled == true ? "checked" : "") onchange="waToggleEnabled(this.checked)" />
