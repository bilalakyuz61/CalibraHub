                                <div id="waQrArea" class="wa-qr-area">
                                    <div id="waQrMsg" class="wa-qr-area__msg">Bridge URL kaydet ve bağlantıyı başlat…</div>
                                    <img id="waQrImg" class="wa-qr-area__img" alt="" style="display:none;" />
                                </div>
                            </div>

                            <!-- Pairing Code kolonu -->
                            <div class="wa-connect-col">
                                <div class="wa-connect-col__title">🔢 Telefon Kodu ile Bağlan</div>
                                <div class="wa-connect-col__hint">WhatsApp → Bağlı Cihazlar → Cihaz Bağla → Telefon numarasıyla bağla</div>
                                <div style="display:flex; gap:8px; align-items:center;">
                                    <input type="tel" class="form-control form-control-sm" id="waPairPhone"
                                           placeholder="905XXXXXXXXX (ülke kodu, +'sız)" maxlength="14" style="flex:1;" />
                                    <button type="button" class="btn btn-sm" id="waPairBtn"
                                            style="background:linear-gradient(135deg,#25d366,#128c7e); color:#fff; border:none; padding:6px 16px; border-radius:6px; font-weight:600; white-space:nowrap;">
