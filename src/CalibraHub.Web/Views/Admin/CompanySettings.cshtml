                                    <div style="font-size:.72rem; color:var(--app-text-muted,#64748b); margin-bottom:8px;">
                                        60 saniye içinde WhatsApp'a gir:
                                    </div>
                                    <div id="waPairCode"
                                         style="font-family:'Courier New',monospace; font-size:1.6rem; font-weight:700; letter-spacing:6px; padding:10px 16px; background:rgba(37,211,102,.12); color:#16a34a; border:2px solid rgba(37,211,102,.4); border-radius:8px; display:inline-block; user-select:all; cursor:pointer;"
                                         title="Tıkla → kopyala">—</div>
                                </div>
                            </div>
