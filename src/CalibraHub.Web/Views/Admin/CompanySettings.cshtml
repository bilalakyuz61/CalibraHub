@model CalibraHub.Web.Models.Admin.CompanyManagementViewModel
@inject CalibraHub.Application.Abstractions.Services.IPermissionService PermService
@using System.Security.Claims
@using CalibraHub.Application.Security
@using CalibraHub.Application.Services.Security
@using CalibraHub.Domain.Enums
@{
    ViewData["Title"] = "Şirket Ayarları";
    ViewData["FormCode"] = "COMPANY_SETTINGS";
    ViewData["BodyClass"] = "page-admin-company";
    ViewData["DbInfo"] = "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>company</td><td style='padding:6px 8px;'>Sirket bilgileri (unvan, vergi no, adres, logo, ayarlar). Sistem DB'de tutulur.</td></tr>"
        + "</table>";

    // 2026-06-08 — Tab bazlı yetki kontrolü. Şirket Ayarları TEK form (COMPANY_SETTINGS);
    // tab erişimleri form-içi BUTTON:TAB_* aksiyonlarıyla yetkilendirilir. Yetki Yönetimi
    // UI'da tek "Şirket Ayarları" satırı görünür; tab izinleri altta listelenir.
    //
    // - "general" tab: COMPANY_SETTINGS form-level VIEW yetkisine bağlı (ayrı buton yok)
    // - Diğer tab'lar: BUTTON:TAB_<KEY> yetkisi gerektirir
    var tabPermissionMap = new (string Key, string ButtonKey, string Label)[]
    {
        ("general",    "",                "Genel Bilgiler"),     // VIEW yetisi varsa görünür
        ("mail",       "TAB_MAIL",        "Mail Ayarlari"),
        ("integrator", "TAB_INTEGRATOR",  "Entegrator Ayarlari"),
        // 2026-07-06 — "Adres Kataloğu" (PTT) sekmesi kaldırıldı: şehir/ilçe için
        // ileride ayrı tanımlama ekranı yapılacak. Backend (AddressController) ve
        // DB tabloları duruyor; yalnızca UI girişi kapatıldı.
        ("whatsapp",   "TAB_WHATSAPP",    "WhatsApp"),
        ("ai",         "TAB_AI",          "Yapay Zeka"),
    };

    var visibleTabs = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var isSysAdmin = User.IsInRole("SystemAdmin")
                     || string.Equals(User.FindFirstValue(ClaimTypes.Role), "SystemAdmin", StringComparison.OrdinalIgnoreCase);

    if (isSysAdmin)
    {
        foreach (var (key, _, _) in tabPermissionMap) visibleTabs.Add(key);
    }
    else
    {
        var uidStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
        var rStr   = User.FindFirstValue(ClaimTypes.Role) ?? "Operator";
        var dStr   = User.FindFirstValue("department_id");
        int.TryParse(uidStr, out var uid);
        int? did = int.TryParse(dStr, out var d) && d > 0 ? d : null;
        UserAuthorizationCatalog.TryParseRole(rStr, out var rEnum);
        if (uid > 0)
        {
            // Önce COMPANY_SETTINGS:VIEW — formu açma yetkisi varsa Genel tab görünür
            var hasView = await PermService.CheckAsync(uid, rEnum, did, "COMPANY_SETTINGS", "VIEW", Context.RequestAborted);
            if (hasView) visibleTabs.Add("general");

            // Diğer tab'lar — BUTTON:TAB_* yetkisine bağlı
            foreach (var (key, btnKey, _) in tabPermissionMap)
            {
                if (string.IsNullOrEmpty(btnKey)) continue; // general zaten yukarıda
                if (await PermService.CanInvokeButtonAsync(uid, rEnum, did, "COMPANY_SETTINGS", btnKey, Context.RequestAborted))
                    visibleTabs.Add(key);
            }
        }
    }

    // Aktif olacak ilk görünür tab (varsa). Hiçbiri yoksa form boş gözükür (empty state).
    var firstVisible = tabPermissionMap.FirstOrDefault(t => visibleTabs.Contains(t.Key)).Key ?? string.Empty;
}

@section Styles {
<style>
    .page-admin-company .integrator-dashboard { height: 100%; min-height: 0; }
    .page-admin-company .integrator-dashboard__content {
        display: flex !important; flex-direction: column;
        width: 100% !important; max-width: none !important;
        min-height: 0; padding: 0; margin: 0 !important; overflow: hidden;
    }
    .cs-body { display: flex; flex: 1 1 auto; min-height: 0; overflow: hidden; }

    /* Sol: dikey tab nav */
    .cs-tab-nav {
        width: 180px; flex-shrink: 0;
        border-right: 1px solid var(--app-border,#dde3ee);
        background: var(--app-surface,#fff);
        display: flex; flex-direction: column;
        padding: 8px 0; overflow-y: auto;
    }
    .cs-tab-btn {
        display: flex; align-items: center; gap: 10px; width: 100%; text-align: left;
        padding: 8px 16px; font-size: 0.82rem; font-weight: 600;
        color: var(--app-text-muted,#64748b); background: none; border: none;
        border-left: 3px solid transparent; cursor: pointer;
        transition: color .12s, background .12s, border-color .12s;
    }
    .cs-tab-btn:hover { background: var(--app-muted-surface,#f3f5f7); color: var(--app-text,#333); }
    .cs-tab-btn.is-active {
        color: var(--theme-accent,#2563eb); border-left-color: var(--theme-accent,#2563eb);
        background: var(--theme-accent-soft,rgba(37,99,235,.06));
    }

    /* Malzeme Kartı sol-menü paritesi — bölüm başlığı + daire dot indikatör */
    .cs-nav-label {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.63rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase;
        color: var(--app-text-muted,#94a3b8);
        padding: 8px 16px 5px; margin-top: 2px;
    }
    .cs-nav-label:first-child { margin-top: 0; }
    .cs-nav-label::after { content: ''; flex: 1; height: 1px; background: var(--app-border-light,#e2e8f0); }
    .cs-nav-dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
        border: 1.5px solid var(--app-border,#cbd5e1); background: transparent;
        transition: all .18s;
    }
    .cs-tab-btn:hover .cs-nav-dot { border-color: var(--app-text-muted,#94a3b8); }
    .cs-tab-btn.is-active .cs-nav-dot {
        background: var(--theme-accent,#2563eb); border-color: var(--theme-accent,#2563eb);
        box-shadow: 0 0 7px var(--theme-accent-soft,rgba(37,99,235,.55));
    }
    @@media (max-width: 768px) { .cs-nav-label { display: none; } }

    /* Sag: tab icerigi */
    .cs-tab-content { flex: 1 1 auto; min-width: 0; overflow-y: auto; padding: 16px 20px; }
    .cs-tab-pane { display: none; }
    .cs-tab-pane.is-active { display: block; }

    /* Form stilleri */
    .cs-form-row { display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 10px; }
    .cs-form-field { display: flex; flex-direction: column; min-width: 0; }
    .cs-form-field--grow { flex: 1 1 auto; }
    .cs-form-field label { font-size: 0.78rem; font-weight: 600; color: var(--app-text-muted,#64748b); margin-bottom: 2px; }
    .cs-section-title {
        font-size: 0.76rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em;
        color: var(--app-text-muted,#94a3b8); margin: 4px 0 8px; padding-bottom: 4px;
        border-bottom: 1px solid var(--app-border-light,#f1f5f9);
    }
    .cs-switch-row { display: flex; gap: 20px; align-items: center; margin-top: 4px; }
    .cs-switch-row .form-check { margin: 0; }
    .cs-switch-row .form-check-label { font-size: 0.8rem; font-weight: 500; }
    .cs-line {
        display: flex; align-items: center; gap: 12px;
        padding: 6px 0; border-bottom: 1px solid var(--app-border-light,#f1f5f9);
    }
    .cs-line:last-child { border-bottom: none; }
    .cs-line > label:first-child {
        width: 130px; flex-shrink: 0;
        font-size: 0.8rem; font-weight: 600; color: var(--app-text-muted,#64748b);
        text-align: right; padding-right: 4px;
    }
    .cs-line > .form-control { flex: 1 1 auto; }
    @@media (max-width: 768px) {
        .cs-line { flex-direction: column; align-items: stretch; gap: 2px; }
        .cs-line > label:first-child { width: auto; text-align: left; }
        .cs-tab-nav { width: 100%; flex-direction: row; overflow-x: auto; border-right: none; border-bottom: 1px solid var(--app-border,#dde3ee); padding: 0; }
        .cs-tab-btn { border-left: none; border-bottom: 3px solid transparent; padding: 8px 12px; white-space: nowrap; }
        .cs-tab-btn.is-active { border-left-color: transparent; border-bottom-color: var(--theme-accent,#2563eb); }
        .cs-body { flex-direction: column; }
    }
    .cs-instruction {
        margin-top: 12px; padding: 10px 14px; border-radius: 6px;
        font-size: 0.78rem; line-height: 1.6; color: #1e293b;
        background: #f0f9ff; border: 1px solid #bae6fd;
    }
    .cs-instruction strong { color: #0369a1; }
    .cs-instruction ul { margin: 6px 0 4px 16px; padding: 0; }
    .cs-instruction li { margin-bottom: 4px; }
    .cs-instruction code { background: #e0f2fe; padding: 1px 5px; border-radius: 3px; font-size: 0.74rem; }
    .cs-instruction a { color: #0369a1; text-decoration: underline; }

    /* ── WhatsApp entegrasyon switch ─────────────────────────────────── */
    .wa-toggle-row {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 14px; border-radius: 10px;
        background: var(--app-muted-surface,#f8fafc);
        border: 1px solid var(--app-border,#e2e8f0);
        margin-bottom: 14px;
    }
    .wa-toggle-label {
        font-size: .85rem; font-weight: 600; color: var(--app-text,#1e293b); flex: 1;
    }
    .wa-toggle-label small {
        display: block; font-weight: 400; font-size: .72rem; color: var(--app-text-muted,#64748b); margin-top: 1px;
    }
    /* Bootstrap-style switch */
    .wa-switch { position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; }
    .wa-switch input { opacity: 0; width: 0; height: 0; }
    .wa-switch-track {
        position: absolute; inset: 0; border-radius: 24px; cursor: pointer;
        background: var(--app-border-strong,#94a3b8);
        transition: background .2s;
    }
    .wa-switch-track::before {
        content: ''; position: absolute; width: 18px; height: 18px; border-radius: 50%;
        left: 3px; top: 3px; background: #fff;
        transition: transform .2s; box-shadow: 0 1px 3px rgba(0,0,0,.2);
    }
    .wa-switch input:checked + .wa-switch-track { background: #25d366; }
    .wa-switch input:checked + .wa-switch-track::before { transform: translateX(20px); }
    /* Pasifken bağlantı paneli soluk */
    .wa-body--disabled { opacity: .45; pointer-events: none; user-select: none; }
    body.app-theme-dark.page-admin-company .wa-toggle-row {
        background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.12);
    }
    body.app-theme-dark.page-admin-company .wa-toggle-label { color: #e2e8f0; }

    /* ── WhatsApp tab ─────────────────────────────────────────────────── */
    .wa-prov-card {
        text-align: left; padding: 12px 14px; border-radius: 8px; cursor: pointer;
        background: var(--app-surface,#fff); border: 1.5px solid var(--app-border,#dde3ee);
        transition: border-color .12s, background .12s;
    }
    .wa-prov-card:hover { border-color: var(--app-border-strong,#94a3b8); }
    .wa-prov-card.is-active {
        border-color: var(--theme-accent,#2563eb);
        background: var(--theme-accent-soft, rgba(37,99,235,.06));
    }
    .wa-prov-card__title { font-weight: 700; font-size: 0.88rem; color: var(--app-text,#1e293b); margin-bottom: 4px; }
    .wa-prov-card__desc  { font-size: 0.74rem; color: var(--app-text-muted,#64748b); line-height: 1.4; }
    .wa-prov-card__badge { display: inline-block; padding: 1px 8px; border-radius: 999px; font-size: 0.62rem; font-weight: 700; margin-left: 6px; vertical-align: middle; }
    .wa-badge-ok   { background: rgba(34,197,94,.15);   color: #16a34a; }
    .wa-badge-warn { background: rgba(245,158,11,.15);  color: #b45309; }
    body.app-theme-dark .wa-badge-ok   { color: #86efac; }
    body.app-theme-dark .wa-badge-warn { color: #fbbf24; }
    .isr-line {
        display: flex; align-items: center; gap: 12px;
        padding: 5px 0;
    }
    .isr-line > label {
        width: 150px; flex-shrink: 0;
        font-size: 0.8rem; font-weight: 600; color: var(--app-text-muted,#64748b);
        text-align: right; padding-right: 4px;
    }
    .isr-line > .form-control, .isr-line > .form-select { width: 280px; flex: 0 0 280px; }
    .isr-line-desc { font-size: 0.72rem; color: #94a3b8; line-height: 1.3; flex: 1 1 auto; }
    .isr-test-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 14px; border-radius: 20px;
        border: 1px solid rgba(99,102,241,.4);
        background: rgba(99,102,241,.06);
        color: #6366f1; font-size: 0.78rem; font-weight: 600;
        cursor: pointer; transition: background .15s, border-color .15s;
        white-space: nowrap;
    }
    .isr-test-btn:hover {
        background: rgba(99,102,241,.13);
        border-color: rgba(99,102,241,.65);
    }
    body.app-theme-dark.page-admin-company .isr-test-btn {
        border-color: rgba(129,140,248,.35);
        background: rgba(129,140,248,.07);
        color: #818cf8;
    }
    body.app-theme-dark.page-admin-company .isr-test-btn:hover {
        background: rgba(129,140,248,.14);
        border-color: rgba(129,140,248,.6);
    }

    /* Dark tema overrideları */
    body.app-theme-dark.page-admin-company .cs-tab-nav {
        background: rgba(255,255,255,.02);
        border-right-color: rgba(255,255,255,.07);
    }
    body.app-theme-dark.page-admin-company .cs-tab-btn {
        color: #64748b;
    }
    body.app-theme-dark.page-admin-company .cs-tab-btn:hover {
        background: rgba(255,255,255,.04);
        color: #cbd5e1;
    }
    body.app-theme-dark.page-admin-company .cs-tab-btn.is-active {
        color: #818cf8;
        border-left-color: #818cf8;
        background: rgba(129,140,248,.07);
    }
    body.app-theme-dark.page-admin-company .cs-nav-label { color: rgba(255,255,255,.30); }
    body.app-theme-dark.page-admin-company .cs-nav-label::after { background: rgba(255,255,255,.07); }
    body.app-theme-dark.page-admin-company .cs-nav-dot { border-color: rgba(255,255,255,.24); }
    body.app-theme-dark.page-admin-company .cs-tab-btn:hover .cs-nav-dot { border-color: rgba(255,255,255,.48); }
    body.app-theme-dark.page-admin-company .cs-tab-btn.is-active .cs-nav-dot {
        background: #818cf8; border-color: #818cf8; box-shadow: 0 0 7px rgba(129,140,248,.55);
    }
    body.app-theme-dark.page-admin-company .cs-line {
        border-bottom-color: rgba(255,255,255,.05);
    }
    body.app-theme-dark.page-admin-company .cs-line > label:first-child {
        color: #64748b;
    }
    body.app-theme-dark.page-admin-company .cs-section-title {
        color: #475569;
        border-bottom-color: rgba(255,255,255,.05);
    }
    body.app-theme-dark.page-admin-company .cs-instruction {
        background: rgba(14,165,233,.08);
        border-color: rgba(14,165,233,.2);
        color: #cbd5e1;
    }
    body.app-theme-dark.page-admin-company .cs-instruction strong { color: #38bdf8; }
    body.app-theme-dark.page-admin-company .cs-instruction code {
        background: rgba(14,165,233,.12);
        color: #7dd3fc;
    }
    body.app-theme-dark.page-admin-company .cs-instruction a { color: #38bdf8; }
    body.app-theme-dark.page-admin-company .isr-line-desc { color: #475569; }
    body.app-theme-dark.page-admin-company .isr-line > label { color: #64748b; }

    /* WhatsApp tab — dark theme overrides */
    body.app-theme-dark.page-admin-company .wa-prov-card {
        background: rgba(255,255,255,.03);
        border-color: rgba(255,255,255,.10);
    }
    body.app-theme-dark.page-admin-company .wa-prov-card:hover {
        background: rgba(255,255,255,.06);
        border-color: rgba(255,255,255,.18);
    }
    body.app-theme-dark.page-admin-company .wa-prov-card.is-active {
        background: rgba(129,140,248,.10);
        border-color: #818cf8;
    }
    body.app-theme-dark.page-admin-company .wa-prov-card__title { color: #e2e8f0; }
    body.app-theme-dark.page-admin-company .wa-prov-card__desc  { color: #94a3b8; }
    body.app-theme-dark.page-admin-company .wa-badge-ok   { background: rgba(34,197,94,.18);  color: #86efac; }
    body.app-theme-dark.page-admin-company .wa-badge-warn { background: rgba(245,158,11,.18); color: #fbbf24; }

    /* WhatsApp ust durum rozeti */
    .wa-status {
        padding: 10px 14px; border-radius: 8px; margin-bottom: 12px;
        font-size: 0.84rem; line-height: 1.4;
        border: 1px solid transparent;
    }
    .wa-status--off  { background: var(--app-muted-surface, #f1f5f9); border-color: var(--app-border, #e2e8f0); color: var(--app-text, #475569); }
    .wa-status--ok   { background: rgba(34,197,94,.10);  border-color: rgba(34,197,94,.3);  color: #15803d; }
    .wa-status--warn { background: rgba(245,158,11,.10); border-color: rgba(245,158,11,.3); color: #b45309; }
    body.app-theme-dark.page-admin-company .wa-status--off  { background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.10); color: #cbd5e1; }
    body.app-theme-dark.page-admin-company .wa-status--ok   { background: rgba(34,197,94,.14);  border-color: rgba(34,197,94,.35);  color: #86efac; }
    body.app-theme-dark.page-admin-company .wa-status--warn { background: rgba(245,158,11,.14); border-color: rgba(245,158,11,.35); color: #fcd34d; }

    /* WhatsApp QR area + form metinleri — dark okunurluk */
    .wa-qr-area {
        flex:1; padding:18px; border:1px dashed var(--app-border,#cbd5e1); border-radius:8px;
        text-align:center; min-height:96px;
        display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px;
        background: var(--app-muted-surface, #f8fafc);
        color: var(--app-text, #334155); font-size:.82rem;
    }
    .wa-qr-area__msg { color: var(--app-text, #334155); line-height:1.4; }
    .wa-qr-area__img { max-width:240px; border-radius:8px; background:#fff; padding:8px; }
    .wa-enabled-toggle {
        display:inline-flex; align-items:center; gap:8px; font-size:.82rem; cursor:pointer;
        color: var(--app-text, #1e293b);
    }
    .wa-safety-note {
        margin-left:138px; font-size:.7rem; line-height:1.5;
        color: var(--app-text-muted, #64748b);
    }
    .wa-connect-methods {
        display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-top:14px;
    }
    .wa-connect-col {
        border:1px solid var(--app-border,#e2e8f0); border-radius:10px; padding:16px;
        background:var(--app-surface,#fff);
    }
    .wa-connect-col__title {
        font-weight:700; font-size:.85rem; margin-bottom:4px; color:var(--app-text,#1e293b);
    }
    .wa-connect-col__hint {
        font-size:.72rem; color:var(--app-text-muted,#64748b); line-height:1.4; margin-bottom:12px;
    }
    body.app-theme-dark.page-admin-company .wa-connect-col {
        border-color:rgba(255,255,255,.14); background:rgba(255,255,255,.03);
    }
    body.app-theme-dark.page-admin-company .wa-connect-col__title { color:#e2e8f0; }
    body.app-theme-dark.page-admin-company .wa-qr-area {
        background: rgba(129,140,248,.05);
        border-color: rgba(255,255,255,.18);
        color: #cbd5e1;
    }
    body.app-theme-dark.page-admin-company .wa-qr-area__msg { color: #cbd5e1; }
    body.app-theme-dark.page-admin-company .wa-qr-area__img { background:#0f172a; }
    body.app-theme-dark.page-admin-company .wa-enabled-toggle { color: #e2e8f0; }
    body.app-theme-dark.page-admin-company .wa-safety-note { color: #94a3b8; }
    /* Entegrasyon API tablo — light tema */
    #apTable { font-size: 0.85rem; }
    #apTable thead th {
        font-size: 0.75rem; font-weight: 600; color: #64748b;
        padding: 6px 10px; border-bottom: 2px solid #e2e8f0;
    }
    .ap-td { padding: 7px 10px; border-bottom: 1px solid #f1f5f9; color: #1e293b; font-size: 0.85rem; }
    .ap-tr-sel { background: #eff6ff !important; }
    .ap-tr-sel .ap-td { color: #1e40af; }
    #apTable tbody tr:hover { background: #f8fafc; }
    .ap-btn-edit  { background:none;border:none;cursor:pointer;color:#2563eb;padding:0 4px;font-size:1rem; }
    .ap-btn-del   { background:none;border:none;cursor:pointer;color:#ef4444;padding:0 4px;font-size:1rem; }
    /* Entegrasyon API tablo — dark tema */
    body.app-theme-dark.page-admin-company #apTable thead th {
        color: #475569; border-bottom-color: rgba(255,255,255,.08);
    }
    body.app-theme-dark.page-admin-company .ap-td {
        border-bottom-color: rgba(255,255,255,.05);
        color: #cbd5e1;
    }
    body.app-theme-dark.page-admin-company .ap-tr-sel { background: rgba(129,140,248,.1) !important; }
    body.app-theme-dark.page-admin-company .ap-tr-sel .ap-td { color: #a5b4fc; }
    body.app-theme-dark.page-admin-company #apTable tbody tr:hover { background: rgba(255,255,255,.03); }
    body.app-theme-dark.page-admin-company .ap-btn-edit  { color: #818cf8; }
    body.app-theme-dark.page-admin-company .ap-btn-del   { color: #f87171; }
    /* ap-msg bildirim kutulari */
    .ap-msg-ok  { padding:5px 12px;border-radius:6px;font-size:0.78rem;background:#dcfce7;color:#15803d;border:1px solid #bbf7d0; }
    .ap-msg-err { padding:5px 12px;border-radius:6px;font-size:0.78rem;background:#fef2f2;color:#dc2626;border:1px solid #fecaca; }
    body.app-theme-dark.page-admin-company .ap-msg-ok  { background:rgba(16,185,129,.1);color:#34d399;border-color:rgba(52,211,153,.25); }
    body.app-theme-dark.page-admin-company .ap-msg-err { background:rgba(239,68,68,.08);color:#f87171;border-color:rgba(248,113,113,.25); }
    body.app-theme-dark.page-admin-company input[readonly] {
        background: rgba(255,255,255,.03) !important;
        cursor: not-allowed;
    }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact">
    <div class="integrator-dashboard__content" style="display:flex;flex-direction:column;height:100%;min-height:0;overflow:hidden;">

    <div class="entity-form-toolbar" data-no-proxy style="flex:0 0 auto;">
        <button type="button" class="btn btn-primary integrator-btn-primary" onclick="csSave()">Kaydet</button>
    </div>

    <form id="company-form" method="post" asp-action="CompanySettings" autocomplete="off" novalidate style="display:contents;">
        @Html.AntiForgeryToken()
        <input asp-for="Input.Id" type="hidden" />

        <div class="cs-body">
            <div class="cs-tab-nav">
                @* 2026-06-08 — Tab visibility, kullanıcının ilgili FormCode'a VIEW yetkisi
                   olup olmadığına göre belirlenir. SystemAdmin'a hepsi açık. *@
                @if (visibleTabs.Count > 0)
                {
                    <span class="cs-nav-label">Genel</span>
                }
                @foreach (var (key, _, label) in tabPermissionMap)
                {
                    if (!visibleTabs.Contains(key)) { continue; }
                    var isActive = string.Equals(key, firstVisible, StringComparison.OrdinalIgnoreCase) ? " is-active" : "";
                    <button type="button" class="cs-tab-btn@(isActive)" data-cs-tab="@key"><span class="cs-nav-dot"></span>@label</button>
                }
            </div>

            <div class="cs-tab-content">

                @if (visibleTabs.Count == 0)
                {
                    <div style="padding: 60px 28px; text-align: center; color: #94a3b8;">
                        <div style="font-size: 40px; margin-bottom: 12px; opacity: .5;">🛡️</div>
                        <div style="font-size: 14px; font-weight: 600; color: #475569;">Şirket Ayarları için tanımlı yetkiniz yok.</div>
                        <div style="font-size: 12px; margin-top: 6px;">Yöneticinizle iletişime geçin.</div>
                    </div>
                }

                <!-- Genel Bilgiler -->
                <div class="cs-tab-pane@(firstVisible == "general" ? " is-active" : "")" id="cs-pane-general" data-cs-pane-key="general">
                    <div class="cs-line">
                        <label>Sirket Adi</label>
                        <input asp-for="Input.Name" class="form-control form-control-sm" readonly
                               style="background:var(--app-muted-surface,#f3f5f7);cursor:not-allowed;" />
                    </div>
                    <div class="cs-line">
                        <label>Unvan</label>
                        <input asp-for="Input.Title" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Vergi Dairesi</label>
                        <input asp-for="Input.TaxOffice" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Vergi Numarasi</label>
                        <input asp-for="Input.TaxNumber" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Adres</label>
                        <input asp-for="Input.Address" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Il</label>
                        <input asp-for="Input.City" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Ilce</label>
                        <input asp-for="Input.District" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Posta Kodu</label>
                        <input asp-for="Input.PostalCode" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Dış Erişim URL</label>
                        <input asp-for="Input.PublicBaseUrl" class="form-control form-control-sm"
                               placeholder="https://calibra.sirketim.com (boş → otomatik)" />
                    </div>
                    <div class="cs-line">
                        <label>Durum</label>
                        <div class="form-check form-switch" style="margin:0;padding-top:4px;">
                            <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="Input.IsActive" class="form-check-label" style="font-size:.82rem;font-weight:600;">Aktif</label>
                        </div>
                    </div>
                </div>

                <!-- Mail Ayarlari -->
                <div class="cs-tab-pane@(firstVisible == "mail" ? " is-active" : "")" id="cs-pane-mail" data-cs-pane-key="mail">
                    <div class="cs-line">
                        <label>SMTP Host</label>
                        <input asp-for="SmtpInput.Host" class="form-control form-control-sm" placeholder="smtp.gmail.com" />
                    </div>
                    <div class="cs-line">
                        <label>Port</label>
                        <input asp-for="SmtpInput.Port" class="form-control form-control-sm" type="number" style="max-width:100px;" />
                    </div>
                    <div class="cs-line">
                        <label>SSL/TLS</label>
                        <div class="form-check form-switch" style="margin:0;padding-top:4px;">
                            <input asp-for="SmtpInput.UseSsl" class="form-check-input" type="checkbox" role="switch" />
                        </div>
                    </div>
                    <div class="cs-line">
                        <label>E-posta Adresi</label>
                        <input asp-for="SmtpInput.FromEmail" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Gorunen Ad</label>
                        <input asp-for="SmtpInput.FromDisplayName" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label>Yontem</label>
                        <select asp-for="SmtpInput.AuthMethod" class="form-select form-select-sm" id="authMethodSelect" style="max-width:260px;">
                            <option value="Normal">Normal Sifre</option>
                            <option value="AppPassword">Uygulama Sifresi (2FA)</option>
                            <option value="OAuth2">OAuth2 (Gmail/Outlook)</option>
                        </select>
                    </div>
                    <div class="cs-line">
                        <label>Kullanici Adi</label>
                        <input asp-for="SmtpInput.Username" class="form-control form-control-sm" />
                    </div>
                    <div class="cs-line">
                        <label id="smtpPasswordLabel">Sifre</label>
                        <input asp-for="SmtpInput.Password" class="form-control form-control-sm" type="password"
                               autocomplete="new-password" value="@Model.SmtpInput.Password" />
                    </div>

                    <div id="oauthPanel" style="display:none;">
                        <div class="cs-line">
                            <label>Client ID</label>
                            <input asp-for="SmtpInput.OAuth2ClientId" class="form-control form-control-sm" />
                        </div>
                        <div class="cs-line">
                            <label>Client Secret</label>
                            <input asp-for="SmtpInput.OAuth2ClientSecret" class="form-control form-control-sm" type="password"
                                   value="@Model.SmtpInput.OAuth2ClientSecret" />
                        </div>
                        <div class="cs-line">
                            <label>Refresh Token</label>
                            <input asp-for="SmtpInput.OAuth2RefreshToken" class="form-control form-control-sm" type="password"
                                   value="@Model.SmtpInput.OAuth2RefreshToken" />
                        </div>
                    </div>

                    <div class="cs-line">
                        <label>Test Alici</label>
                        <input asp-for="SmtpInput.TestRecipientEmail" class="form-control form-control-sm" placeholder="bos = gonderen adrese gonder" />
                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnTestSmtp" style="white-space:nowrap;flex-shrink:0;">Test Et</button>
                    </div>

                    <!-- Talimatlar -->
                    <div id="instructionNormal" class="cs-instruction" style="display:none;">
                        <strong>Normal Sifre</strong> — SMTP sunucunuzun kullanici adi ve sifresini girin.
                        Cogu kurumsal mail sunucusu bu yontemi destekler.
                    </div>
                    <div id="instructionAppPassword" class="cs-instruction" style="display:none;">
                        <strong>Uygulama Sifresi (2FA)</strong> — Hesabinizda 2 adimli dogrulama aktifse normal sifre calismaz.
                        <ul>
                            <li><strong>Gmail:</strong> <a href="https://myaccount.google.com/apppasswords" target="_blank" rel="noopener">myaccount.google.com/apppasswords</a> adresinden uygulama sifresi olusturun. Host: <code>smtp.gmail.com</code>, Port: <code>587</code>, SSL: acik.</li>
                            <li><strong>Outlook/Microsoft 365:</strong> <a href="https://account.live.com/proofs/AppPassword" target="_blank" rel="noopener">account.live.com &gt; Guvenlik &gt; Uygulama Sifresi</a>. Host: <code>smtp.office365.com</code>, Port: <code>587</code>, SSL: acik.</li>
                            <li><strong>Yandex:</strong> Ayarlar &gt; Guvenlik &gt; Uygulama sifreleri. Host: <code>smtp.yandex.com</code>, Port: <code>465</code>, SSL: acik.</li>
                        </ul>
                        Olusturulan uygulama sifresini yukaridaki <em>Uygulama Sifresi</em> alanina yapistiriniz.
                    </div>
                    <div id="instructionOAuth2" class="cs-instruction" style="display:none;">
                        <strong>OAuth2</strong> — Gmail API veya Microsoft Graph ile token tabanli kimlik dogrulama.
                        <ul>
                            <li><strong>Gmail:</strong> Google Cloud Console &gt; APIs &gt; Gmail API etkinlestir &gt; OAuth 2.0 Client ID olustur &gt; Refresh Token al.</li>
                            <li><strong>Outlook:</strong> Azure AD &gt; App Registration &gt; Mail.Send izni &gt; Client Secret + Refresh Token al.</li>
                        </ul>
                        Bu yontem en guvenli secenektir ancak kurulumu daha karmasiktir.
                    </div>

                    <input asp-for="SmtpInput.Id" type="hidden" />
                    <input asp-for="SmtpInput.CompanyId" type="hidden" />
                    <input asp-for="SmtpInput.Name" type="hidden" value="@(Model.SmtpInput.Name ?? "Varsayilan")" />
                    <input asp-for="SmtpInput.IsActive" type="hidden" value="true" />
                </div>

                <!-- Ayarlar -->
                @* "Genel Parametreler" pane'i (cs-pane-settings) kaldirildi.
                   E-Belge Onay Sistemi: /Admin/Parameters > Genel sekmesine tasindi.
                   IsEDocumentApprovalEnabled mevcut degerini POST sirasinda korumak icin
                   gizli input olarak burada tutuluyor (CompanySettings save action onu yine bekliyor). *@
                <input asp-for="Input.IsEDocumentApprovalEnabled" type="hidden" />

                @* "Entegrasyon API" tab pane'i kaldirildi — tum profil yonetimi
                   /Integrations#profiles (Hub > Profiller tab) altinda yapiliyor.
                   Backend AdminController.SaveApiProfileJson/DeleteApiProfileJson
                   geriye uyum icin DURUYOR (eski JS ya da scripts cagiriyor olabilir),
                   sadece bu UI tab'i kaldirildi. *@

                <!-- Entegrator Ayarlari -->
                <div class="cs-tab-pane@(firstVisible == "integrator" ? " is-active" : "")" id="cs-pane-integrator" data-cs-pane-key="integrator">
                    <span id="isrToolbarMsg"></span>
                    <div class="isr-form" style="max-width:720px;">
                        <input type="hidden" id="isrId" />
                        <input type="hidden" id="isrCompanyId" />
                        <div class="isr-line">
                            <label>Aktif</label>
                            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                                <input type="checkbox" id="isrIsActive" class="form-check-input" role="switch" checked />
                            </div>
                            <span class="isr-line-desc">Pasife alindiginda veri cekilmez</span>
                        </div>
                        <div class="isr-line">
                            <label>Saglayici</label>
                            <select id="isrProvider" class="form-select form-select-sm"></select>
                            <span class="isr-line-desc">e-Belge entegrasyon saglayicisi</span>
                        </div>
                        <div class="isr-line">
                            <label>Servis URL</label>
                            <input id="isrBaseUrl" class="form-control form-control-sm" maxlength="300" placeholder="https://..." />
                            <span class="isr-line-desc">e-Belge web servis adresi</span>
                        </div>
                        <div class="isr-line">
                            <label>Kullanici Adi</label>
                            <input id="isrUsername" class="form-control form-control-sm" maxlength="120" />
                            <span class="isr-line-desc">Servise giris kullanici adi</span>
                        </div>
                        <div class="isr-line">
                            <label>Sifre</label>
                            <input id="isrSecret" type="password" class="form-control form-control-sm" maxlength="200"
                                   autocomplete="new-password" placeholder="Degistirmek icin girin" />
                            <span class="isr-line-desc">Bos birakilirsa mevcut sifre korunur</span>
                        </div>
                        <div class="isr-line">
                            <label>Okunmus Belgeler</label>
                            <div class="form-check form-switch" style="margin:0;padding-top:3px;">
                                <input type="checkbox" id="isrInclReceived" class="form-check-input" role="switch" />
                            </div>
                            <span class="isr-line-desc">Daha once okunmus belgeler de cekilsin</span>
                        </div>
                        <div class="isr-line">
