@inject CalibraHub.Web.Infrastructure.Ui.IUiTextService UiText
@{
    var activeMenu = (ViewData["AdminMenu"] as string ?? string.Empty).ToLowerInvariant();
    var managementOpen = activeMenu is "dashboard" or "form-management";
    var panelModuleOpen = activeMenu is "dashboard";
    var guideModuleOpen = activeMenu is "form-management";
    var systemSettingsOpen = activeMenu is "company-settings" or "integrator-settings" or "mail-settings" or "erp-settings" or "appearance" or "project-instructions";
    var logsOpen = activeMenu is "system-logs" or "db-schema" or "locks";
    var viewSettingsOpen = activeMenu is "view-settings-screens" or "view-settings-material-cards";
    var settingsOpen = systemSettingsOpen || logsOpen || viewSettingsOpen;
    var organizationModuleOpen = activeMenu is "users" or "departments" or "roles";
    var definitionsOpen = organizationModuleOpen;
    var ui = await UiText.GetFormAsync("shared.admin_menu");
    var collapseMenuText = ui.Text("collapse_menu");
    var searchPlaceholderText = ui.Text("search_placeholder");
    var favoritesTitleText = ui.Text("favorites_title");
    var managementText = ui.Text("management");
    var panelText = ui.Text("panel");
    var generalSettingsText = ui.Text("general_settings");
    var settingsText = ui.Text("settings");
    var systemSettingsText = ui.Text("system_settings");
    var companyDefinitionText = ui.Text("company_definition");
    var integratorSettingsText = ui.Text("integrator_settings");
    var mailSettingsText = ui.Text("mail_settings");
    var erpSettingsText = ui.Text("erp_settings");
    var appearanceText = ui.Text("appearance");
    var projectInstructionsText = "Proje Talimatlari";
    var viewsText = ui.Text("views");
    var screenDesignSettingsText = ui.Text("screen_design_settings");
    var logText = ui.Text("log");
    var systemLogReportText = ui.Text("system_log_report");
    var definitionsText = ui.Text("definitions");
    var organizationText = ui.Text("organization");
    var departmentsText = ui.Text("departments");
    var usersText = ui.Text("users");
    var rolesText = ui.Text("roles");
}

<nav class="admin-nav" data-menu-root data-menu-scope="admin">
    <button type="button"
            class="side-toggle"
            data-sidebar-toggle
            aria-expanded="true"
            aria-label="@collapseMenuText"
            title="@collapseMenuText">
        <span class="menu-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="m14.5 6-5 6 5 6"></path></svg>
        </span>
        <span class="menu-text">@collapseMenuText</span>
    </button>

    <div class="menu-search-wrap">
        <input type="search"
               class="menu-search-input"
               data-menu-search
               placeholder="@searchPlaceholderText"
               autocomplete="off" />
    </div>

    <section class="favorites-panel" data-favorites-panel hidden>
        <h3 class="favorites-title">@favoritesTitleText</h3>
        <div class="favorites-list" data-favorites-list></div>
    </section>

    <details class="admin-group" @(managementOpen ? "open" : null)>
        <summary>
            <span class="menu-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><rect x="4" y="4" width="7" height="7"></rect><rect x="13" y="4" width="7" height="5"></rect><rect x="13" y="11" width="7" height="9"></rect><rect x="4" y="13" width="7" height="7"></rect></svg>
            </span>
            <span class="menu-text">@managementText</span>
        </summary>

        <div class="menu-group-content">
            <div class="menu-group-content-inner">
                <details class="admin-group admin-group-nested" @(panelModuleOpen ? "open" : null)>
                    <summary>
                        <span class="menu-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M4 18h16"></path><path d="M7 15V9"></path><path d="M12 15V6"></path><path d="M17 15v-4"></path></svg>
                        </span>
                        <span class="menu-text">@panelText</span>
                    </summary>

                    <div class="menu-group-content">
                        <div class="menu-group-content-inner">
                            <div class="menu-entry" data-menu-entry data-favorite-key="admin-dashboard">
                                <a class="admin-nav-item @(activeMenu == "dashboard" ? "active" : string.Empty)"
                                   asp-controller="Admin" asp-action="Index" title="@generalSettingsText">
                                    <span class="menu-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24"><path d="M4 19V5h16v14z"></path><path d="M8 14l2-2 2 1 4-4"></path></svg>
                                    </span>
                                    <span class="menu-text">@generalSettingsText</span>
                                </a>
                                <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="@($"{generalSettingsText} favorilere ekle")">
                                    <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                                </button>
                            </div>

                        </div>
                    </div>
                </details>

                <details class="admin-group admin-group-nested" @(guideModuleOpen ? "open" : null)>
                    <summary>
                        <span class="menu-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M4 6h16"></path><path d="M4 12h10"></path><path d="M4 18h7"></path><circle cx="18" cy="16" r="3"></circle><path d="m21 19-1.5-1.5"></path></svg>
                        </span>
                        <span class="menu-text">Rehber Merkezi</span>
                    </summary>

                    <div class="menu-group-content">
                        <div class="menu-group-content-inner">
                            <div class="menu-entry" data-menu-entry data-favorite-key="admin-form-management">
                                <a class="admin-nav-item @(activeMenu == "form-management" ? "active" : string.Empty)"
                                   asp-controller="Admin" asp-action="FormManagement" title="Form Tasarım Ayarları">
                                    <span class="menu-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect></svg>
                                    </span>
                                    <span class="menu-text">Form Tasarım Ayarları</span>
                                </a>
                                <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="Form Tasarım Ayarları favorilere ekle">
                                    <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </details>
            </div>
        </div>
    </details>

    <details class="admin-group" @(settingsOpen ? "open" : null)>
