                            <svg viewBox="0 0 24 24"><path d="M4 6h16"></path><path d="M4 12h16"></path><path d="M4 18h16"></path><circle cx="8" cy="6" r="2"></circle><circle cx="14" cy="12" r="2"></circle><circle cx="10" cy="18" r="2"></circle></svg>
