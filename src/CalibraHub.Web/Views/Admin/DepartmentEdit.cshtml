@model CalibraHub.Application.Contracts.DepartmentDto
@{
    var isNew = Model is null;
    ViewData["Title"] = isNew ? "Yeni Departman" : $"Departman: {Model!.Name}";
    ViewData["BodyClass"] = "page-department-edit";
    var companies = (System.Collections.Generic.IReadOnlyCollection<CalibraHub.Application.Contracts.CompanyDto>)
        (ViewBag.Companies ?? System.Array.Empty<CalibraHub.Application.Contracts.CompanyDto>());
}

@section Styles {
<style>
    .de-root {
        --de-bg:      #f1f5f9;
        --de-surface: #ffffff;
        --de-border:  #e2e8f0;
        --de-text:    #0f172a;
        --de-muted:   #64748b;
        --de-accent:  #6366f1;
        display: flex; align-items: flex-start; justify-content: center;
        min-height: 100%; padding: 32px 16px;
        background: var(--de-bg);
    }
    body.app-theme-dark .de-root {
        --de-bg:      #080c17;
        --de-surface: #0d1323;
        --de-border:  rgba(255,255,255,.09);
        --de-text:    #e2e8f0;
        --de-muted:   #94a3b8;
    }
    .de-card {
        width: 100%; max-width: 520px;
        background: var(--de-surface); border: 1px solid var(--de-border);
        border-radius: 14px; padding: 28px 28px 24px;
        box-shadow: 0 4px 24px rgba(0,0,0,.08);
    }
    .de-header {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 24px; padding-bottom: 16px;
        border-bottom: 1px solid var(--de-border);
    }
    .de-header h1 { font-size: 17px; font-weight: 700; margin: 0; color: var(--de-text); }
    .de-back {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 12px; border-radius: 8px;
        border: 1px solid var(--de-border); background: none;
        color: var(--de-muted); font-size: 13px; cursor: pointer;
        text-decoration: none; transition: background .12s;
    }
    .de-back:hover { background: var(--de-bg); color: var(--de-text); }
    .de-spacer { flex: 1; }

    .de-field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
    .de-label { font-size: 12px; font-weight: 600; color: var(--de-muted); }
    .de-input, .de-select {
        padding: 9px 12px; border-radius: 8px;
        border: 1px solid var(--de-border);
        background: var(--de-bg); color: var(--de-text);
        font-size: 14px; outline: none;
        font-family: inherit;
        transition: border-color .15s, box-shadow .15s;
    }
    .de-input:focus, .de-select:focus {
        border-color: var(--de-accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,.12);
    }
    .de-input.is-invalid, .de-select.is-invalid {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 3px rgba(239,68,68,.12) !important;
    }
    body.app-theme-dark .de-select { color-scheme: dark; }
    .de-input:disabled, .de-select:disabled {
        opacity: .65; cursor: not-allowed;
        background: rgba(255,255,255,.02);
    }
    .de-hint { font-size: 11px; color: var(--de-muted); margin-top: 2px; }

    .de-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .de-switch-row { display: flex; align-items: center; gap: 10px; }
    .de-switch { position: relative; width: 42px; height: 24px; display: inline-block; flex-shrink: 0; }
    .de-switch input { opacity: 0; width: 0; height: 0; position: absolute; }
    .de-switch-track {
        position: absolute; inset: 0; border-radius: 24px; cursor: pointer;
        background: #e2e8f0; transition: background .2s;
    }
    .de-switch input:checked + .de-switch-track { background: #10b981; }
    body.app-theme-dark .de-switch-track { background: rgba(255,255,255,.12); }
    body.app-theme-dark .de-switch input:checked + .de-switch-track { background: #059669; }
    .de-switch-track::before {
        content: ''; position: absolute; height: 18px; width: 18px;
        left: 3px; top: 3px; border-radius: 50%;
        background: #fff; transition: transform .2s;
        box-shadow: 0 1px 3px rgba(0,0,0,.25);
    }
    .de-switch input:checked + .de-switch-track::before { transform: translateX(18px); }
    .de-switch-label { font-size: 13px; font-weight: 600; color: var(--de-muted); }

    .de-actions {
        display: flex; gap: 8px; margin-top: 24px;
        padding-top: 16px; border-top: 1px solid var(--de-border);
    }
    .de-btn {
        padding: 9px 20px; border-radius: 8px; font-size: 13px; font-weight: 600;
        border: 1px solid transparent; cursor: pointer; transition: all .12s;
        text-decoration: none; display: inline-flex; align-items: center; justify-content: center;
    }
    .de-btn--primary { background: var(--de-accent); color: #fff; border-color: #4f46e5; }
    .de-btn--primary:hover { filter: brightness(1.1); }
    .de-btn--primary:disabled { opacity: .55; cursor: not-allowed; }
    .de-btn--ghost { background: none; border-color: var(--de-border); color: var(--de-text); }
    .de-btn--ghost:hover { background: var(--de-bg); }
    .de-btn--danger { background: none; border-color: #fecaca; color: #dc2626; margin-left: auto; }
    body.app-theme-dark .de-btn--danger { border-color: rgba(239,68,68,.35); color: #f87171; }
    .de-btn--danger:hover { background: rgba(239,68,68,.08); }
    .de-btn--danger:disabled { opacity: .4; cursor: not-allowed; }

    .de-err {
        margin-top: 10px; padding: 8px 12px; border-radius: 8px; font-size: 13px;
        background: rgba(239,68,68,.08); color: #dc2626; border: 1px solid rgba(239,68,68,.2);
    }
    body.app-theme-dark .de-err { color: #f87171; }

    /* Delete modal */
    .de-modal-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,.48); backdrop-filter: blur(3px);
        display: flex; align-items: center; justify-content: center;
    }
    .de-modal {
        background: var(--de-surface); border: 1px solid var(--de-border);
        border-radius: 14px; padding: 24px; width: 360px; max-width: 90vw;
        display: flex; flex-direction: column; gap: 14px;
        box-shadow: 0 24px 64px rgba(0,0,0,.35);
    }
    .de-modal-icon { display: flex; justify-content: center; color: #ef4444; }
    .de-modal-title { font-size: 16px; font-weight: 600; text-align: center; color: var(--de-text); }
    .de-modal-msg { font-size: 13px; color: var(--de-muted); text-align: center; line-height: 1.55; }
    .de-modal-actions { display: flex; gap: 8px; justify-content: center; margin-top: 4px; }
    .de-modal-cancel {
        padding: 8px 22px; border-radius: 8px; font-size: 13px; font-weight: 500;
        border: 1px solid var(--de-border); background: var(--de-surface);
        color: var(--de-text); cursor: pointer; transition: background .12s;
    }
    .de-modal-cancel:hover { background: var(--de-bg); }
    .de-modal-del {
        padding: 8px 22px; border-radius: 8px; font-size: 13px; font-weight: 500;
        border: none; background: #ef4444; color: #fff; cursor: pointer; transition: filter .12s;
    }
    .de-modal-del:hover:not(:disabled) { filter: brightness(1.1); }
    .de-modal-del:disabled { opacity: .5; cursor: not-allowed; }
</style>
}

<div class="de-root">
  <div class="de-card">
    <div class="de-header">
      <a class="de-back" href="/Admin/Departments">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Listeye Dön
      </a>
      <span class="de-spacer"></span>
      <h1>@(isNew ? "Yeni Departman" : "Departmanı Düzenle")</h1>
    </div>

    <input type="hidden" id="de-id" value="@(Model?.Id.ToString() ?? "")" />

    <div class="de-field">
      <label class="de-label" for="de-name">Departman Adı *</label>
      <input id="de-name" class="de-input" maxlength="100"
             value="@(Model?.Name ?? "")" placeholder="Örn: Üretim" />
    </div>

    @if (!isNew)
    {
      <div class="de-field">
        <label class="de-label">Durum</label>
        <div class="de-switch-row">
          <label class="de-switch">
            <input type="checkbox" id="de-active" @(Model!.IsActive ? "checked" : "") />
            <span class="de-switch-track"></span>
          </label>
          <span class="de-switch-label" id="de-active-label">@(Model.IsActive ? "Aktif" : "Pasif")</span>
        </div>
      </div>
    }

    <div id="de-err" style="display:none;" class="de-err"></div>

    <div class="de-actions">
      <button class="de-btn de-btn--primary" id="de-save">Kaydet</button>
      <a class="de-btn de-btn--ghost" href="/Admin/Departments">İptal</a>
      @if (!isNew)
      {
        <button class="de-btn de-btn--danger" id="de-delete">Sil</button>
      }
    </div>
  </div>
</div>

@if (!isNew)
{
  <div id="de-modal" class="de-modal-backdrop" style="display:none;" onclick="deCloseModal()">
    <div class="de-modal" onclick="event.stopPropagation()">
      <div class="de-modal-icon">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <div class="de-modal-title">Departmanı Sil</div>
      <div class="de-modal-msg" id="de-modal-msg"></div>
      <div class="de-modal-actions">
        <button class="de-modal-cancel" onclick="deCloseModal()">Vazgeç</button>
        <button class="de-modal-del" id="de-modal-del">Sil</button>
      </div>
    </div>
  </div>
}

@Html.AntiForgeryToken()

@section Scripts {
<script>
(function () {
    var idVal = document.getElementById('de-id')?.value || '';
    var isNew = !idVal;

    function csrf() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function setErr(msg) {
        var el = document.getElementById('de-err');
        if (!el) return;
        if (msg) { el.textContent = msg; el.style.display = ''; }
        else el.style.display = 'none';
    }
    function shake(id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.classList.remove('is-invalid'); void el.offsetWidth;
        el.classList.add('is-invalid');
        setTimeout(function () { el.classList.remove('is-invalid'); }, 1200);
    }

    // ── Active toggle label sync ──────────────────────────────
    var activeEl = document.getElementById('de-active');
    var activeLabel = document.getElementById('de-active-label');
    if (activeEl && activeLabel) {
        activeEl.addEventListener('change', function () {
            activeLabel.textContent = activeEl.checked ? 'Aktif' : 'Pasif';
        });
    }

    // ── Save ──────────────────────────────────────────────────
    var saveBtn = document.getElementById('de-save');
    if (saveBtn) {
        saveBtn.addEventListener('click', function () {
            var name = (document.getElementById('de-name').value || '').trim();
            var invalid = false;
            if (!name) { shake('de-name'); invalid = true; }
            if (invalid) return;

            saveBtn.disabled = true;
            setErr('');

            if (isNew) {
                // companyId payload'a koyulmuyor — server aktif kullanicinin sirketini kullanir.
                var createPayload = {
                    code: '',
                    name: name
                };
                fetch('/Admin/SaveDepartmentJson', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrf() },
                    body: JSON.stringify(createPayload)
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d && (d.ok || d.success)) {
                        window.location.href = '/Admin/Departments';
                    } else {
                        setErr((d && (d.error || d.message)) || 'Kayıt başarısız.');
                        saveBtn.disabled = false;
                    }
                })
                .catch(function (e) { setErr('Bağlantı hatası: ' + (e.message || e)); saveBtn.disabled = false; });
            } else {
                var updatePayload = {
                    id: idVal,
                    name: name,
                    isActive: document.getElementById('de-active').checked
                };
                fetch('/Admin/UpdateDepartmentJson', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrf() },
                    body: JSON.stringify(updatePayload)
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d && (d.ok || d.success)) {
                        window.location.href = '/Admin/Departments';
                    } else {
                        setErr((d && (d.error || d.message)) || 'Kayıt başarısız.');
                        saveBtn.disabled = false;
                    }
                })
                .catch(function (e) { setErr('Bağlantı hatası: ' + (e.message || e)); saveBtn.disabled = false; });
            }
        });
    }

    // ── Delete modal ──────────────────────────────────────────
    var deleteBtn = document.getElementById('de-delete');
    if (deleteBtn) {
        deleteBtn.addEventListener('click', function () {
            var name = document.getElementById('de-name').value;
            var msgEl = document.getElementById('de-modal-msg');
            if (msgEl) msgEl.innerHTML = '<strong>' + name + '</strong> departmanını silmek istediğinize emin misiniz?';
            document.getElementById('de-modal').style.display = 'flex';
            document.getElementById('de-modal-del').focus();
        });

        var modalDel = document.getElementById('de-modal-del');
        if (modalDel) {
            modalDel.addEventListener('click', function () {
                modalDel.disabled = true;
                modalDel.textContent = 'Siliniyor…';
                fetch('/Admin/DeleteDepartmentJson?id=' + idVal, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrf() }
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d && (d.ok || d.success)) {
                        window.location.href = '/Admin/Departments';
                    } else {
                        deCloseModal();
                        setErr((d && (d.error || d.message)) || 'Silinemedi.');
                    }
                })
                .catch(function (e) { deCloseModal(); setErr('Bağlantı hatası: ' + (e.message || e)); });
            });
        }
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') deCloseModal();
    });
})();

function deCloseModal() {
    var m = document.getElementById('de-modal');
    if (m) m.style.display = 'none';
    var btn = document.getElementById('de-modal-del');
    if (btn) { btn.disabled = false; btn.textContent = 'Sil'; }
}
</script>
}
