                                <span class="st-switch"></span>
                                <span class="st-schedule-label">Her gün belirli saatte
                                    <span class="st-schedule-hint">(SS:DD)</span>
                                </span>
                            </span>
                            <span class="st-schedule-value" onclick="event.stopPropagation()">
                                <span style="font-size:.75rem;">Saat</span>
                                <input type="time" class="st-input" id="stfDailyTime" value="09:00" style="width:120px;" onfocus="stSelectSchedule(2)"/>
                            </span>
                        </label>

                        <!-- Once -->
                        <label class="st-schedule-row" data-sch="3" onclick="stSelectSchedule(3)">
                            <span class="st-schedule-key">
                                <input type="radio" name="stSchedType" value="3" class="st-switch-input"/>
                                <span class="st-switch"></span>
                                <span class="st-schedule-label">Sadece bir kere
                                    <span class="st-schedule-hint">(tarih/saat)</span>
                                </span>
                            </span>
                            <span class="st-schedule-value" onclick="event.stopPropagation()">
                                <input type="datetime-local" class="st-input" id="stfOnceDateTime" style="width:220px;" onfocus="stSelectSchedule(3)"/>
                            </span>
                        </label>

                        <!-- Cron -->
                        <label class="st-schedule-row" data-sch="1" onclick="stSelectSchedule(1)">
                            <span class="st-schedule-key">
                                <input type="radio" name="stSchedType" value="1" class="st-switch-input"/>
                                <span class="st-switch"></span>
                                <span class="st-schedule-label">Cron ifadesi
                                    <span class="st-schedule-hint">(dk sa g ay hf)</span>
                                </span>
                            </span>
                            <span class="st-schedule-value" onclick="event.stopPropagation()">
                                <input type="text" class="st-input" id="stfCronExpr" placeholder="0 9 * * *" style="width:160px; font-family:ui-monospace,Consolas,monospace;" onfocus="stSelectSchedule(1)"/>
                                <button type="button" class="st-info-btn" onclick="stToggleCronHelp(event)" aria-label="Cron yardimi">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10"/>
                                        <line x1="12" y1="16" x2="12" y2="12"/>
                                        <line x1="12" y1="8" x2="12.01" y2="8"/>
                                    </svg>
                                </button>
                                <div id="stCronHelp" class="st-info-pop" style="display:none;">
                                    <div class="st-info-pop-title">Cron ifadesi nasıl yazılır?</div>
                                    <div class="st-info-pop-row">
                                        <code>┌─── dakika (0-59)<br/>│ ┌─ saat (0-23)<br/>│ │ ┌─ ayın günü (1-31)<br/>│ │ │ ┌─ ay (1-12)<br/>│ │ │ │ ┌─ haftanın günü (0-6, 0=Pazar)<br/>│ │ │ │ │<br/>* * * * *</code>
                                    </div>
                                    <div class="st-info-pop-section">
                                        <div class="st-info-pop-subtitle">Örnekler</div>
                                        <table class="st-info-pop-table">
                                            <tr><td><code>0 9 * * *</code></td><td>Her gün 09:00</td></tr>
                                            <tr><td><code>*/15 * * * *</code></td><td>Her 15 dakikada bir</td></tr>
                                            <tr><td><code>0 8 * * 1-5</code></td><td>Hafta içi 08:00</td></tr>
                                            <tr><td><code>0 0 1 * *</code></td><td>Her ayın 1'i 00:00</td></tr>
                                            <tr><td><code>30 7 * * 0,6</code></td><td>Hafta sonu 07:30</td></tr>
                                        </table>
                                    </div>
                                    <div class="st-info-pop-section">
                                        <div class="st-info-pop-subtitle">Operatörler</div>
                                        <ul>
                                            <li><code>*</code> her değer</li>
                                            <li><code>1,3,5</code> liste</li>
                                            <li><code>1-5</code> aralık</li>
                                            <li><code>*/15</code> her 15 birim</li>
                                        </ul>
                                    </div>
                                </div>
                            </span>
                        </label>

                        <!-- Weekly on specific days -->
                        <label class="st-schedule-row" data-sch="5" onclick="stSelectSchedule(5)">
                            <span class="st-schedule-key">
                                <input type="radio" name="stSchedType" value="5" class="st-switch-input"/>
                                <span class="st-switch"></span>
                                <span class="st-schedule-label">Haftanın belirli günleri
                                    <span class="st-schedule-hint">(saat + günler)</span>
                                </span>
                            </span>
                            <span class="st-schedule-value" onclick="event.stopPropagation()">
                                <input type="time" class="st-input" id="stfWeeklyTime" value="09:00" style="width:100px;" onfocus="stSelectSchedule(5)"/>
                                <span id="stfWeeklyDays" class="st-dow-pills">
                                    <button type="button" data-d="1" class="st-dow-pill">Pzt</button>
                                    <button type="button" data-d="2" class="st-dow-pill">Sal</button>
                                    <button type="button" data-d="3" class="st-dow-pill">Çar</button>
                                    <button type="button" data-d="4" class="st-dow-pill">Per</button>
                                    <button type="button" data-d="5" class="st-dow-pill">Cum</button>
                                    <button type="button" data-d="6" class="st-dow-pill">Cts</button>
                                    <button type="button" data-d="0" class="st-dow-pill">Paz</button>
                                </span>
                            </span>
                        </label>

                        <!-- Monthly on specific days -->
                        <label class="st-schedule-row" data-sch="6" onclick="stSelectSchedule(6)">
                            <span class="st-schedule-key">
                                <input type="radio" name="stSchedType" value="6" class="st-switch-input"/>
                                <span class="st-switch"></span>
                                <span class="st-schedule-label">Ayın belirli günleri
                                    <span class="st-schedule-hint">(saat + 1..31)</span>
                                </span>
                            </span>
                            <span class="st-schedule-value" onclick="event.stopPropagation()">
                                <input type="time" class="st-input" id="stfMonthlyTime" value="09:00" style="width:100px;" onfocus="stSelectSchedule(6)"/>
                                <input type="text" class="st-input" id="stfMonthlyDays" placeholder="örn: 1,15,28" style="flex:1;min-width:130px;" onfocus="stSelectSchedule(6)"/>
                            </span>
                        </label>

                        <!-- Manual -->
                        <label class="st-schedule-row" data-sch="4" onclick="stSelectSchedule(4)">
                            <span class="st-schedule-key">
                                <input type="radio" name="stSchedType" value="4" class="st-switch-input"/>
                                <span class="st-switch"></span>
                                <span class="st-schedule-label">Sadece elle çalıştırılsın
                                    <span class="st-schedule-hint">(▶ butonu ile)</span>
                                </span>
                            </span>
                            <span class="st-schedule-value">
                                <span class="st-schedule-value-empty">— ayar yok —</span>
                            </span>
                        </label>
                    </div>
                </div>
            </div>
        <div class="st-modal-foot">
            <button type="button" class="st-foot-btn st-foot-btn--cancel" onclick="stCloseEdit()">İptal</button>
            <button type="button" class="st-foot-btn st-foot-btn--save" id="stSaveBtn" onclick="stSubmitEdit()">Kaydet</button>
        </div>
    </div>
</div>

<!-- History Modal -->
<div id="stHistoryModal" class="st-modal-bd" style="display:none;">
    <div class="st-modal-card" style="max-width:860px;display:flex;flex-direction:column;">
        <div class="st-modal-head">
            <div class="st-modal-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/><path d="M1 20v-6h6"/><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/></svg>
            </div>
            <h3 id="stHistoryTitle" class="st-modal-title">Çalıştırma Geçmişi</h3>
            <button type="button" class="st-action-btn st-action-btn--del" onclick="stCloseHistory()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="st-modal-body" id="stHistoryBody" style="min-height:200px;max-height:60vh;overflow:auto;">Yükleniyor...</div>
    </div>
</div>

<!-- Komut detay modal: history'de "Komutu goster" linkine tiklaninca acilir -->
<div id="stCmdModal" class="st-modal-bd" style="display:none;">
    <div class="st-modal-card" style="max-width:820px;display:flex;flex-direction:column;">
        <div class="st-modal-head">
            <div class="st-modal-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h3 class="st-modal-title">Çalıştırılan Komut</h3>
            <button type="button" class="st-action-btn st-action-btn--del" onclick="stCloseCmdModal()" aria-label="Kapat">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="st-modal-body" style="padding:14px 18px;">
            <pre class="st-cmd-pre" id="stCmdModalContent"></pre>
        </div>
        <div class="st-modal-foot">
            <button type="button" class="st-foot-btn st-foot-btn--cancel" onclick="stCloseCmdModal()">Kapat</button>
            <button type="button" class="st-foot-btn st-foot-btn--save" onclick="stCopyCmd()">Kopyala</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        function esc(s) { return (s === null || s === undefined) ? '' : String(s).replace(/[&<>"']/g, function (c) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
        function csrfToken() { return document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''; }

        // Ekran ortasi temali toast — alert() yerine kullanilir
        function stNotify(message, kind) {
            kind = kind || 'info';
            var icon = kind === 'success' ? '✓' : kind === 'error' ? '✕' : kind === 'warning' ? '!' : 'i';
            var bd = document.createElement('div');
            bd.className = 'st-toast-bd';
            bd.innerHTML =
                '<div class="st-toast st-toast--' + kind + '" role="alert">' +
                    '<div class="st-toast-icon">' + icon + '</div>' +
                    '<div class="st-toast-msg">' + esc(message) + '</div>' +
                    '<button class="st-toast-x" aria-label="Kapat">×</button>' +
                '</div>';
            document.body.appendChild(bd);
            var dismiss = function () { if (bd.parentNode) bd.parentNode.removeChild(bd); };
            bd.querySelector('.st-toast-x').addEventListener('click', dismiss);
            bd.addEventListener('click', function (e) { if (e.target === bd) dismiss(); });
            // Hata/uyari biraz daha uzun kalsin
            var timeout = (kind === 'error' || kind === 'warning') ? 5000 : 3000;
            setTimeout(dismiss, timeout);
        }
        window.stNotify = stNotify;

        // Ekran ortasi confirm modali — onayli silme/tehlikeli islem icin
        function stConfirm(title, message, onYes, opts) {
            opts = opts || {};
            var yesLabel = opts.yesLabel || 'Evet, sil';
            var cancelLabel = opts.cancelLabel || 'Vazgeç';

            var bd = document.createElement('div');
            bd.className = 'st-confirm-bd';
            bd.innerHTML =
                '<div class="st-confirm-card" role="alertdialog">' +
                    '<div class="st-confirm-head">' +
                        '<div class="st-confirm-icon">' +
                            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                                '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>' +
                                '<line x1="12" y1="9" x2="12" y2="13"/>' +
                                '<line x1="12" y1="17" x2="12.01" y2="17"/>' +
                            '</svg>' +
                        '</div>' +
                        '<span>' + esc(title) + '</span>' +
                    '</div>' +
                    '<div class="st-confirm-body">' + esc(message) + '</div>' +
                    '<div class="st-confirm-foot">' +
                        '<button class="st-confirm-btn st-confirm-btn--cancel" data-cancel>' + esc(cancelLabel) + '</button>' +
                        '<button class="st-confirm-btn st-confirm-btn--yes" data-yes>' + esc(yesLabel) + '</button>' +
                    '</div>' +
                '</div>';
            document.body.appendChild(bd);
            var dismiss = function () { if (bd.parentNode) bd.parentNode.removeChild(bd); };
            bd.querySelector('[data-cancel]').addEventListener('click', dismiss);
            bd.querySelector('[data-yes]').addEventListener('click', function () { dismiss(); onYes && onYes(); });
            bd.addEventListener('click', function (e) { if (e.target === bd) dismiss(); });
            // Escape = iptal, Enter = onayla
            function keyHandler(e) {
                if (e.key === 'Escape') { dismiss(); document.removeEventListener('keydown', keyHandler); }
                if (e.key === 'Enter')  { dismiss(); onYes && onYes(); document.removeEventListener('keydown', keyHandler); }
            }
            document.addEventListener('keydown', keyHandler);
        }
        window.stConfirm = stConfirm;

        // ── Sol tab gorev tipi secimi ─────────────────────────────
        // Sol panel tablari HTML'de hardcoded (data-type=1/2/4/5). Tip secilince
        // sag panel tip-spesifik form goruntulenir, taskType state'e yazilir.
        var TASK_TYPE_LABELS = {
            1: 'SQL Prosedür Ayarları',
            2: 'HTTP API Ayarları',
            4: 'Döviz Kuru Yenileme',
            5: 'View Raporu Ayarları'
        };
        function stDefaultStateForType(tt) {
            var s = {
                taskType: tt,
                scheduleType: 0,
                intervalValue: 60, intervalUnit: 'seconds',
                dailyTime: '09:00',
                httpMethod: 'GET', httpTimeout: 60, httpContentType: 'application/json', httpHeaders: [],
                sqlTimeout: 300, sqlParams: []
            };
            return s;
        }

        function applyStateToForm(s) {
            document.getElementById('stfName').value        = s.name || '';
            document.getElementById('stfDescription').value = s.description || '';
            // isEnabled UI'da gosterilmiyor — her zaman true (manuel/zamanlama disable
            // etmek icin "Sadece elle calistirilsin" zamanlama secenegi var).
            // Code kolonu kaldirildi — Id zaten unique key gorevi gorur.
            window._stEditingIsEnabled = s.isEnabled !== false;

            // Oncul gorev dropdown'unu doldur — _stCache (mevcut gorev listesi) kullan
            stPopulatePrerequisites(window._stEditingId || 0, s.prerequisiteTaskId || null);

            // Task type — sol tab'i secili yap + tip-spesifik formu goster
            var tt = s.taskType || 1;
            stSelectTaskType(tt);

            if (tt === 1) {
                document.getElementById('stfSqlProcName').value = s.sqlProcName || '';
                document.getElementById('stfSqlTimeout').value  = s.sqlTimeout || 300;
                resetKvList('stfSqlParams', s.sqlParams || [], 'stfSqlParamRow');
            } else if (tt === 2) {
                document.getElementById('stfHttpUrl').value         = s.httpUrl || '';
                document.getElementById('stfHttpMethod').value      = s.httpMethod || 'GET';
                document.getElementById('stfHttpTimeout').value     = s.httpTimeout || 60;
                document.getElementById('stfHttpContentType').value = s.httpContentType || 'application/json';
                document.getElementById('stfHttpBody').value        = s.httpBody || '';
                resetKvList('stfHttpHeaders', s.httpHeaders || [], 'stfHttpHeaderRow');
            } else if (tt === 5) {
                document.getElementById('stfVrFormat').value  = s.vrFormat || 'xlsx';
                document.getElementById('stfVrSubject').value = s.vrSubject || '';
                document.getElementById('stfVrBody').value    = s.vrBody || '';
                document.getElementById('stfVrMaxRows').value = s.vrMaxRows || 10000;
                window._stVrRecipients = (s.vrRecipients || []).map(function (e) { return { email: e, label: e }; });
                stVrRenderRecipients();
                // View dropdown lazy load — state'ten gelen view value'yu degisken'e sakla
                window._stVrPendingView = s.vrViewName || '';
                (async function () {
                    await stVrLoadMeta();
                    var sel = document.getElementById('stfVrViewName');
                    if (sel && window._stVrPendingView) sel.value = window._stVrPendingView;
                })();
            }

            // Schedule
            stSelectSchedule(s.scheduleType != null ? s.scheduleType : 0);
            document.getElementById('stfIntervalValue').value = s.intervalValue || 60;
            document.getElementById('stfIntervalUnit').value  = s.intervalUnit || 'seconds';
            document.getElementById('stfDailyTime').value     = s.dailyTime || '09:00';
            document.getElementById('stfCronExpr').value      = s.cronExpr || '';
            if (s.onceDateTime) document.getElementById('stfOnceDateTime').value = s.onceDateTime;
            document.getElementById('stfWeeklyTime').value    = s.weeklyTime || '09:00';
            document.getElementById('stfMonthlyTime').value   = s.monthlyTime || '09:00';
            document.getElementById('stfMonthlyDays').value   = s.monthlyDays || '';
            // DOW pill toggle state
            var weeklySet = new Set((s.weeklyDays || []).map(Number));
            document.querySelectorAll('#stfWeeklyDays .st-dow-pill').forEach(function (b) {
                b.classList.toggle('is-active', weeklySet.has(parseInt(b.dataset.d, 10)));
            });

        }

        // generateTaskCodeFromName kaldirildi — code kolonu artik DB'de yok, Id zaten unique.

        // Oncul gorev dropdown'unu doldur: _stCache'den (mevcut gorev listesi) gorevleri
        // listele, kendisini hariç tut (cycle onleme), seçili degeri set et.
        function stPopulatePrerequisites(currentEditingId, selectedId) {
            var sel = document.getElementById('stfPrerequisite');
            if (!sel) return;
            sel.innerHTML = '<option value="">— Yok —</option>';
            var cache = Array.isArray(window._stCache) ? window._stCache : [];
            cache.forEach(function (t) {
                if (t.id === currentEditingId) return; // kendisi olamaz
                if (t.taskTypeName === 'Builtin') return; // builtin'lar tetiklenmiyor
                var opt = document.createElement('option');
                opt.value = String(t.id);
                // Sadece gorev adi gosterilir; kod gosterimi kaldirildi (Id zaten unique).
                opt.textContent = t.name;
                if (selectedId && Number(selectedId) === t.id) opt.selected = true;
                sel.appendChild(opt);
            });
        }

        // Sol tab'da gorev tipi secildiginde cagirilir: tab class'larini, tip-spesifik
        // form bolumunu ve "Gorev Ayarlari" section basligini gunceller.
        function stSelectTaskType(tt) {
            tt = parseInt(tt, 10) || 1;
            document.querySelectorAll('#stStepForm .st-tabs .st-tab').forEach(function (b) {
                b.classList.toggle('is-active', parseInt(b.dataset.type, 10) === tt);
            });
            stShowTypeForm(tt);
        }
        window.stSelectTaskType = stSelectTaskType;

        function stShowTypeForm(tt) {
            document.getElementById('stFormSql').style.display        = (tt === 1 ? '' : 'none');
            document.getElementById('stFormHttp').style.display       = (tt === 2 ? '' : 'none');
            document.getElementById('stFormCurrency').style.display   = (tt === 4 ? '' : 'none');
            document.getElementById('stFormViewReport').style.display = (tt === 5 ? '' : 'none');
            window._stCurrentTaskType = tt;
            document.getElementById('stTypeSectionTitle').textContent = TASK_TYPE_LABELS[tt] || 'Görev Ayarları';
            // View Report secildiyse dropdown'lari lazy-load et
            if (tt === 5) stVrLoadMeta();
        }

        /* ── View Report: yardimci fonksiyonlar ─────────────────── */
        window._stVrRecipients = [];
        window._stVrViewLoaded = false;
        window._stVrUsersLoaded = false;

        async function stVrLoadMeta() {
            if (!window._stVrViewLoaded) {
                try {
                    var r = await fetch('/Admin/ScheduledTasks/DbViews', { credentials: 'same-origin' });
                    var views = await r.json() || [];
                    var sel = document.getElementById('stfVrViewName');
                    var current = sel.value;
                    sel.innerHTML = '<option value="">— seçiniz —</option>' +
                        views.map(function (v) { return '<option value="' + esc(v) + '">' + esc(v) + '</option>'; }).join('');
                    if (current) sel.value = current;
                    window._stVrViewLoaded = true;
                } catch (e) { /* sessiz */ }
            }
            if (!window._stVrUsersLoaded) {
                try {
                    var r2 = await fetch('/Notes/CompanyUsersJson', { credentials: 'same-origin' });
                    var users = await r2.json() || [];
                    var usel = document.getElementById('stfVrUserPick');
                    usel.innerHTML = '<option value="">— şirket kullanıcısı ekle —</option>' +
                        users.filter(function(u){ return u.email; })
                             .map(function(u){ return '<option value="' + esc(u.email) + '" data-name="' + esc(u.fullName) + '">' + esc(u.fullName) + ' · ' + esc(u.email) + '</option>'; }).join('');
                    usel.onchange = function () {
                        var v = usel.value;
                        if (!v) return;
                        var label = usel.options[usel.selectedIndex].dataset.name || v;
                        stVrAddRecipient(v, label);
                        usel.value = '';
                    };
                    window._stVrUsersLoaded = true;
                } catch (e) { /* sessiz */ }
            }
        }

        function stVrAddRecipient(email, label) {
            email = (email || '').trim();
            if (!email) return;
            if (window._stVrRecipients.some(function (r) { return r.email.toLowerCase() === email.toLowerCase(); })) return;
            window._stVrRecipients.push({ email: email, label: label || email });
            stVrRenderRecipients();
        }

        function stVrRemoveRecipient(email) {
            window._stVrRecipients = window._stVrRecipients.filter(function (r) { return r.email !== email; });
            stVrRenderRecipients();
        }

        function stVrRenderRecipients() {
            var c = document.getElementById('stfVrRecipients');
            if (!c) return;
            if (window._stVrRecipients.length === 0) {
                c.innerHTML = '<span class="st-chip-list-empty">henüz alıcı yok</span>';
                return;
            }
            c.innerHTML = window._stVrRecipients.map(function (r) {
                return '<span class="st-chip" title="' + esc(r.email) + '">' +
                    esc(r.label) +
                    '<button type="button" class="st-chip-x" onclick="stVrRemoveRecipient(\'' + esc(r.email) + '\')">×</button>' +
                '</span>';
            }).join('');
        }

        window.stVrAddFreeMail = function () {
            var inp = document.getElementById('stfVrFreeMail');
            var v = (inp.value || '').trim();
            if (!v) return;
            if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(v)) { stNotify('Geçersiz mail adresi.', 'warning'); return; }
            stVrAddRecipient(v, v);
            inp.value = '';
        };
        window.stVrRemoveRecipient = stVrRemoveRecipient;

        function stSelectSchedule(st) {
            document.querySelectorAll('.st-schedule-row').forEach(function(el){
                var active = parseInt(el.dataset.sch, 10) === st;
                el.classList.toggle('is-active', active);
                var radio = el.querySelector('input[type=radio]');
                if (radio) radio.checked = active;
            });
        }
        window.stSelectSchedule = stSelectSchedule;

        // ── Key-Value list helpers ────────────────────────────────
        // SQL parametre listesinde (stfSqlParams) parametre degeri "manuel" veya
        // sirket kaynakli token ({COMPANY_ID}, {INTEGRATION_DB} ...) olabilir.
        // HTTP header listesi (stfHttpHeaders) eski davranisi korur — sadece manuel.
        var KV_TOKEN_SOURCES = [
            { v: 'manual',                  label: 'Manuel' },
            { v: 'COMPANY_ID',              label: 'Şirket ID' },
            { v: 'COMPANY_NAME',            label: 'Şirket Adı' },
            { v: 'COMPANY_TITLE',           label: 'Şirket Unvanı' },
            { v: 'COMPANY_TAX_NO',          label: 'Vergi Numarası' },
            { v: 'COMPANY_TAX_OFFICE',      label: 'Vergi Dairesi' },
            { v: 'INTEGRATION_DB',          label: 'Entegrasyon DB Adı' },
            { v: 'INTEGRATION_DB_USER',     label: 'Entegrasyon DB Kullanıcı' },
            { v: 'INTEGRATION_BRANCH_CODE', label: 'Entegrasyon Şube Kodu' },
            { v: 'INTEGRATION_DB_TYPE',     label: 'Entegrasyon DB Tipi' },
            { v: 'ERP_PROVIDER',            label: 'ERP Sağlayıcı' },
            { v: 'ERP_COMPANY',             label: 'ERP Şirket' },
            { v: 'ERP_BUSINESS',            label: 'ERP İş Yeri' },
            { v: 'ERP_BRANCH',              label: 'ERP Şube' },
            { v: 'ERP_USERNAME',            label: 'ERP Kullanıcı' }
        ];
        var KV_TOKEN_REGEX = /^\{([A-Z][A-Z0-9_]*)\}$/;

        function isKvWithSource(containerId) {
            return containerId === 'stfSqlParams';
        }
        function resetKvList(containerId, items, rowFnName) {
            var c = document.getElementById(containerId);
            c.innerHTML = '';
            var withSource = isKvWithSource(containerId);
            (items || []).forEach(function(it){
                var v = it.v == null ? '' : String(it.v);
                var src = null;
                if (withSource) {
                    var m = v.match(KV_TOKEN_REGEX);
                    if (m) { src = m[1]; v = ''; }
                }
                addKvRow(c, it.k, v, withSource, src);
            });
            if (!items || items.length === 0) addKvRow(c, '', '', withSource);
        }
        function addKvRow(container, k, v, withSource, source) {
            var row = document.createElement('div');
            row.className = 'st-kv-row' + (withSource ? ' has-source' : '');
            var src = source || 'manual';
            var keyInput = '<input type="text" class="st-input st-kv-key" placeholder="ad" value="' + esc(k || '') + '"/>';
            var removeBtn =
                '<button type="button" class="st-kv-remove" aria-label="Sil">' +
                    '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                '</button>';
            if (withSource) {
                var optsHtml = KV_TOKEN_SOURCES.map(function(o){
                    return '<option value="' + o.v + '"' + (o.v === src ? ' selected' : '') + '>' + esc(o.label) + '</option>';
                }).join('');
                var valDisabled = src !== 'manual';
                var valPlaceholder = valDisabled ? '{' + src + '}' : 'deger';
                row.innerHTML =
                    keyInput +
                    '<select class="st-select st-kv-source">' + optsHtml + '</select>' +
                    '<input type="text" class="st-input st-kv-val" placeholder="' + esc(valPlaceholder) + '" value="' + esc(v || '') + '"' + (valDisabled ? ' disabled' : '') + '/>' +
                    removeBtn;
                var sel = row.querySelector('.st-kv-source');
                var val = row.querySelector('.st-kv-val');
                sel.addEventListener('change', function(){
                    if (sel.value === 'manual') {
                        val.disabled = false;
                        val.placeholder = 'deger';
                    } else {
                        val.disabled = true;
                        val.placeholder = '{' + sel.value + '}';
                        val.value = '';
                    }
                });
            } else {
                row.innerHTML =
                    keyInput +
                    '<input type="text" class="st-input st-kv-val" placeholder="deger" value="' + esc(v || '') + '"/>' +
                    removeBtn;
            }
            row.querySelector('.st-kv-remove').onclick = function(){ row.remove(); };
            container.appendChild(row);
        }
        window.stAddKv = function(containerId){
            addKvRow(document.getElementById(containerId), '', '', isKvWithSource(containerId));
        };
        function readKvList(containerId) {
            var map = {};
            var withSource = isKvWithSource(containerId);
            document.querySelectorAll('#' + containerId + ' .st-kv-row').forEach(function(row){
                var keyEl = row.querySelector('.st-kv-key');
                var k = keyEl ? keyEl.value.trim() : '';
                if (!k) return;
                if (withSource) {
                    var sel = row.querySelector('.st-kv-source');
                    var src = sel ? sel.value : 'manual';
                    if (src && src !== 'manual') {
                        map[k] = '{' + src + '}';
                    } else {
                        var valEl = row.querySelector('.st-kv-val');
                        map[k] = valEl ? valEl.value.trim() : '';
                    }
                } else {
                    var v = row.querySelector('.st-kv-val');
                    map[k] = v ? v.value.trim() : '';
                }
            });
            return map;
        }

        // ── Grid render ───────────────────────────────────────────
        function statusCell(status, isRunning) {
            if (isRunning) return '<span class="st-status"><span class="st-dot st-dot--run"></span>Calisiyor</span>';
            if (status === 0)  return '<span class="st-status"><span class="st-dot st-dot--ok"></span>Basarili</span>';
            if (status === 1)  return '<span class="st-status"><span class="st-dot st-dot--err"></span>Hata</span>';
            return '<span class="st-status"><span class="st-dot st-dot--none"></span>—</span>';
        }
        function renderRow(t, i) {
            var isBuiltin = t.taskTypeName === 'Builtin';
            var canDelete = !isBuiltin;
            var canRun    = !isBuiltin && t.isEnabled && !t.isRunning;
            var canEdit   = !isBuiltin;
            return '<tr>' +
                '<td>' + (i+1) + '</td>' +
                '<td><div class="st-name">' + esc(t.name) + '</div>' + (t.description ? '<div class="st-desc">' + esc(t.description) + '</div>' : '') + '</td>' +
                '<td class="st-sched-cell">' + (t.scheduleDescription ? esc(t.scheduleDescription) : '—') + '</td>' +
                '<td>' + (t.lastRunAtLocal || '—') + (t.lastRunDurationMs ? ' <span style="color:#94a3b8;font-size:.72rem;">('+t.lastRunDurationMs+'ms)</span>' : '') + '</td>' +
                '<td>' + statusCell(t.lastRunStatus, t.isRunning) + '</td>' +
                '<td class="st-msg-cell">' + (t.lastRunMessage ? esc(t.lastRunMessage) : '—') + '</td>' +
                '<td>' + (t.nextRunAtLocal || '—') + '</td>' +
                '<td><div class="st-actions">' +
                  '<button class="st-action-btn st-action-btn--run"'+ (canRun?'':' disabled') + ' title="Simdi Calistir" onclick="stRunNow('+t.id+')"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></button>' +
                  '<button class="st-action-btn st-action-btn--toggle '+(t.isEnabled?'':'is-off')+'" title="' + (t.isEnabled?'Pasiflestir':'Etkinlestir') + '" onclick="stToggle('+t.id+',' + (!t.isEnabled) + ')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="' + (t.isEnabled ? 'M18 6L6 18 M6 6l12 12' : 'M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11') + '"/></svg></button>' +
                  '<button class="st-action-btn st-action-btn--hist" title="Gecmis" onclick="stOpenHistory('+t.id+',\'' + esc(t.name) + '\')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></button>' +
                  '<button class="st-action-btn st-action-btn--edit"'+(canEdit?'':' disabled')+' title="Duzenle" onclick="stOpenEdit('+t.id+')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></button>' +
                  '<button class="st-action-btn st-action-btn--del"'+(canDelete?'':' disabled')+' title="Sil" onclick="stDelete('+t.id+',\'' + esc(t.name) + '\')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>' +
                '</div></td>' +
            '</tr>';
        }

        window.stRefresh = async function () {
            try {
                var r = await fetch('/Admin/ScheduledTasks/List', { credentials: 'same-origin' });
                var list = await r.json() || [];
                var body = document.getElementById('stBody');
                if (!list.length) {
                    body.innerHTML = '<tr><td colspan="8" class="st-empty">Henuz kayitli zamanlanmis gorev yok. <strong>Yeni Gorev</strong> ile ekleyebilirsiniz.</td></tr>';
                    return;
                }
                body.innerHTML = list.map(renderRow).join('');
                window._stCache = list;
            } catch (e) { /* silent */ }
        };

        window.stRunNow = async function (id) {
            try {
                var fd = new FormData(); fd.append('__RequestVerificationToken', csrfToken());
                var r  = await fetch('/Admin/ScheduledTasks/' + id + '/RunNow', { method:'POST', body: fd, credentials:'same-origin' });
                var d  = await r.json();
                stNotify((d && d.message) || (d && d.success ? 'Tamamlandi' : 'Calistirilamadi'),
                         d && d.success ? 'success' : 'error');
                stRefresh();
            } catch (e) { stNotify('Hata: ' + e.message, 'error'); }
        };
        window.stToggle = async function (id, enabled) {
            try {
                var fd = new FormData(); fd.append('enabled', enabled); fd.append('__RequestVerificationToken', csrfToken());
                await fetch('/Admin/ScheduledTasks/' + id + '/Toggle', { method:'POST', body: fd, credentials:'same-origin' });
                stRefresh();
            } catch (e) { stNotify('Hata: ' + e.message, 'error'); }
        };
        window.stDelete = function (id, name) {
            stConfirm(
                'Görev silinsin mi?',
                '"' + name + '" adlı görev kalıcı olarak silinecek. Bu işlem geri alınamaz.',
                async function () {
                    try {
                        var fd = new FormData(); fd.append('__RequestVerificationToken', csrfToken());
                        var r  = await fetch('/Admin/ScheduledTasks/' + id + '/Delete', { method:'POST', body: fd, credentials:'same-origin' });
                        var d  = await r.json();
                        if (!d.success) {
                            stNotify('Silinemedi: ' + (d.message || ''), 'error');
                        } else {
                            stNotify('Görev silindi.', 'success');
                        }
                        stRefresh();
                    } catch (e) { stNotify('Hata: ' + e.message, 'error'); }
                }
            );
        };

        // Task type radio in sections — re-bind to switch forms
        function bindTaskTypeRadioFromLoad() {
            // Tip secimi normalde preset ile belirlenir; ama edit sirasinda direkt gormek isteyebiliriz.
            // Su an modal UI task type secimini dolayli yapiyor (preset + yuklenen kayit). Yeterli.
        }

        // ── Edit modal ────────────────────────────────────────────
        var editModal = document.getElementById('stEditModal');

        window.stOpenEdit = function (id) {
            // Form'u temiz baslat — onceki kayittan kalmis input degerleri olmasin.
            var defaultState = stDefaultStateForType(1);
            applyStateToForm(defaultState);

            if (id && window._stCache) {
                var t = window._stCache.find(x => x.id === id);
                if (t) {
                    document.getElementById('stEditTitle').textContent = 'Görev Düzenle';
                    window._stEditingId = t.id;
                    var state = stateFromTask(t);
                    applyStateToForm(state);
                    editModal.style.display = 'flex';
                    return;
                }
            }
            // Yeni kayit — varsayilan tip SQL Prosedur olarak baslar
            document.getElementById('stEditTitle').textContent = 'Yeni Görev';
            window._stEditingId = 0;
            editModal.style.display = 'flex';
        };
        window.stCloseEdit = function () { editModal.style.display = 'none'; };

        function stateFromTask(t) {
            var s = {
                name: t.name, description: t.description || '',
                taskType: t.taskType, scheduleType: t.scheduleType, isEnabled: t.isEnabled,
                prerequisiteTaskId: t.prerequisiteTaskId || null,
            };
            var params = t.parametersJson ? safeParse(t.parametersJson) : {};
            if (t.taskType === 1) {
                s.sqlProcName = params.procedureName || '';
                s.sqlTimeout  = params.timeoutSeconds || 300;
                s.sqlParams   = mapToKvArray(params.parameters);
            } else if (t.taskType === 2) {
                s.httpUrl         = params.url || '';
                s.httpMethod      = params.method || 'GET';
                s.httpTimeout     = params.timeoutSeconds || 60;
                s.httpContentType = params.contentType || 'application/json';
                s.httpBody        = params.body || '';
                s.httpHeaders     = mapToKvArray(params.headers);
            } else if (t.taskType === 5) {
                s.vrViewName   = params.viewName || '';
                s.vrRecipients = Array.isArray(params.recipients) ? params.recipients : [];
                s.vrFormat     = params.format || 'xlsx';
                s.vrSubject    = params.subject || '';
                s.vrBody       = params.bodyText || '';
                s.vrMaxRows    = params.maxRows || 10000;
            }
            // Schedule expression'i parcalara ayir
            var expr = t.scheduleExpression || '';
            if (t.scheduleType === 0) {
                var n = parseInt(expr, 10);
                if (!isNaN(n)) {
                    if (n % 3600 === 0) { s.intervalValue = n / 3600; s.intervalUnit = 'hours'; }
                    else if (n % 60 === 0) { s.intervalValue = n / 60; s.intervalUnit = 'minutes'; }
                    else { s.intervalValue = n; s.intervalUnit = 'seconds'; }
                }
            } else if (t.scheduleType === 2) {
                s.dailyTime = expr || '09:00';
            } else if (t.scheduleType === 3) {
                s.onceDateTime = expr;
            } else if (t.scheduleType === 1) {
                s.cronExpr = expr;
            } else if (t.scheduleType === 5) {
                var wp = expr.split('|');
                s.weeklyTime = wp[0] || '09:00';
                s.weeklyDays = (wp[1] || '').split(',').map(function (x) { return parseInt(x, 10); }).filter(function (x) { return !isNaN(x); });
            } else if (t.scheduleType === 6) {
                var mp = expr.split('|');
                s.monthlyTime = mp[0] || '09:00';
                s.monthlyDays = mp[1] || '';
            }
            return s;
        }
        function safeParse(j){ try { return JSON.parse(j); } catch { return {}; } }
        function mapToKvArray(obj){
            if (!obj) return [];
            return Object.keys(obj).map(function(k){ return { k: k, v: typeof obj[k] === 'object' ? JSON.stringify(obj[k]) : String(obj[k]) }; });
        }

        // Task type selector — preset form icindeyken sag ustte gosterilmeli (kullanici degistirebilsin)
        // Su an preset zaten task type'i belirliyor; manuel switch icin SQL/HTTP segcili buton ekleyelim
        // preset'ten "custom" secince de tip secebilsin diye. (Not: Simdilik preset ile kisitliyoruz.)

        window.stSubmitEdit = async function () {
            var name = document.getElementById('stfName').value.trim();
            if (!name) { stNotify('Isim zorunlu.', 'warning'); return; }
            // Code kolonu kaldirildi — Id zaten unique. Save body'sinde code yok.

            // Hangi task type secili — sol tabdaki secim window._stCurrentTaskType'e yazilir.
            var taskType = window._stCurrentTaskType || 1;

            // ParametersJson insa et (CurrencyRefresh vb. icin bos kalir)
            var paramsObj = {};
            if (taskType === 1) {
                var procName = document.getElementById('stfSqlProcName').value.trim();
                if (!procName) { stNotify('Prosedur adi zorunlu.', 'warning'); return; }
                paramsObj.procedureName  = procName;
                paramsObj.timeoutSeconds = parseInt(document.getElementById('stfSqlTimeout').value, 10) || 300;
                var sqlParams = readKvList('stfSqlParams');
                if (Object.keys(sqlParams).length > 0) paramsObj.parameters = sqlParams;
            } else if (taskType === 2) {
                var url = document.getElementById('stfHttpUrl').value.trim();
                if (!url) { stNotify('URL zorunlu.', 'warning'); return; }
                paramsObj.url            = url;
                paramsObj.method         = document.getElementById('stfHttpMethod').value;
                paramsObj.timeoutSeconds = parseInt(document.getElementById('stfHttpTimeout').value, 10) || 60;
                paramsObj.contentType    = document.getElementById('stfHttpContentType').value || 'application/json';
                var body                  = document.getElementById('stfHttpBody').value;
                if (body) paramsObj.body = body;
                var headers = readKvList('stfHttpHeaders');
                if (Object.keys(headers).length > 0) paramsObj.headers = headers;
            } else if (taskType === 5) {
                var viewName = document.getElementById('stfVrViewName').value.trim();
                if (!viewName) { stNotify('View seçimi zorunlu.', 'warning'); return; }
                if ((window._stVrRecipients || []).length === 0) { stNotify('En az bir alıcı ekleyin.', 'warning'); return; }
                paramsObj.viewName   = viewName;
                paramsObj.recipients = (window._stVrRecipients || []).map(function (r) { return r.email; });
                paramsObj.format     = document.getElementById('stfVrFormat').value || 'xlsx';
                paramsObj.subject    = document.getElementById('stfVrSubject').value.trim() || null;
                paramsObj.bodyText   = document.getElementById('stfVrBody').value.trim() || null;
                paramsObj.maxRows    = parseInt(document.getElementById('stfVrMaxRows').value, 10) || 10000;
            }

            // Schedule expression insa et
            var st = document.querySelector('input[name=stSchedType]:checked');
            var scheduleType = st ? parseInt(st.value, 10) : 0;
            var scheduleExpr = '';
            var scheduleDesc = '';
            if (scheduleType === 0) {
                var n = parseInt(document.getElementById('stfIntervalValue').value, 10) || 60;
                var u = document.getElementById('stfIntervalUnit').value;
                var secs = n * (u === 'hours' ? 3600 : u === 'minutes' ? 60 : 1);
                scheduleExpr = String(secs);
                scheduleDesc = 'Her ' + n + ' ' + (u === 'hours' ? 'saatte' : u === 'minutes' ? 'dakikada' : 'saniyede') + ' bir';
            } else if (scheduleType === 2) {
                scheduleExpr = document.getElementById('stfDailyTime').value || '09:00';
                scheduleDesc = 'Her gun ' + scheduleExpr;
            } else if (scheduleType === 3) {
                scheduleExpr = document.getElementById('stfOnceDateTime').value;
                if (!scheduleExpr) { stNotify('Tarih/saat secilmeli.', 'warning'); return; }
                scheduleDesc = 'Bir kez: ' + scheduleExpr.replace('T', ' ');
            } else if (scheduleType === 1) {
                scheduleExpr = document.getElementById('stfCronExpr').value.trim();
                if (!scheduleExpr) { stNotify('Cron ifadesi zorunlu.', 'warning'); return; }
                scheduleDesc = 'Cron: ' + scheduleExpr;
            } else if (scheduleType === 4) {
                scheduleExpr = '';
                scheduleDesc = 'Manuel';
            } else if (scheduleType === 5) {
                var wTime = document.getElementById('stfWeeklyTime').value || '09:00';
                var wDays = Array.from(document.querySelectorAll('#stfWeeklyDays .st-dow-pill.is-active'))
                    .map(function (b) { return parseInt(b.dataset.d, 10); }).sort();
                if (wDays.length === 0) { stNotify('En az bir gun secmelisin.', 'warning'); return; }
                scheduleExpr = wTime + '|' + wDays.join(',');
                var dowNames = ['Paz','Pzt','Sal','Car','Per','Cum','Cts'];
                scheduleDesc = 'Her ' + wDays.map(function(d){ return dowNames[d]; }).join(',') + ' ' + wTime;
            } else if (scheduleType === 6) {
                var mTime = document.getElementById('stfMonthlyTime').value || '09:00';
                var mDaysRaw = (document.getElementById('stfMonthlyDays').value || '').trim();
                var mDays = mDaysRaw.split(',')
                    .map(function (x) { return parseInt(x.trim(), 10); })
                    .filter(function (x) { return !isNaN(x) && x >= 1 && x <= 31; })
                    .sort(function (a,b) { return a - b; });
                if (mDays.length === 0) { stNotify('Ayin gunlerini gir (1..31, virgulle).', 'warning'); return; }
                scheduleExpr = mTime + '|' + mDays.join(',');
                scheduleDesc = 'Ayin ' + mDays.join(',') + ' gunu ' + mTime;
            }

            var prereqRaw = (document.getElementById('stfPrerequisite') || {}).value || '';
            var prereqId  = parseInt(prereqRaw, 10);
            var payload = {
                id:                  window._stEditingId || 0,
                name:                name,
                description:         document.getElementById('stfDescription').value.trim() || null,
                taskType:            taskType,
                parametersJson:      JSON.stringify(paramsObj),
                scheduleType:        scheduleType,
                scheduleExpression:  scheduleExpr || null,
                scheduleDescription: scheduleDesc || null,
                isEnabled:           window._stEditingIsEnabled !== false,
                prerequisiteTaskId:  isNaN(prereqId) || prereqId <= 0 ? null : prereqId,
            };
            try {
                var r = await fetch('/Admin/ScheduledTasks/Save', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken() },
                    body: JSON.stringify(payload)
                });
                var d = await r.json();
                if (!d.success) { stNotify('Kaydedilemedi: ' + (d.message || ''), 'error'); return; }
                stCloseEdit();
                stRefresh();
                stNotify('Gorev kaydedildi.', 'success');
            } catch (e) { stNotify('Hata: ' + e.message, 'error'); }
        };

        // ── History modal ─────────────────────────────────────────
        var histModal = document.getElementById('stHistoryModal');
        window.stOpenHistory = async function (id, name) {
            document.getElementById('stHistoryTitle').textContent = 'Calistirma Gecmisi — ' + name;
            document.getElementById('stHistoryBody').innerHTML = 'Yukleniyor...';
            histModal.style.display = 'flex';
            try {
                var r = await fetch('/Admin/ScheduledTasks/' + id + '/History?limit=50', { credentials:'same-origin' });
                var list = await r.json() || [];
                if (!list.length) {
                    document.getElementById('stHistoryBody').innerHTML = '<div class="st-empty">Henuz calistirma kaydi yok.</div>';
                    return;
                }
                // Komut detayini ayri modalda gostermek icin index bazli cache — uzun SQL
                // metni inline data-attribute'a sigdirmaktansa array referansi temiz.
                window._stCmdCache = list.map(function (h) { return h.executedCommand || ''; });
                var rows = list.map(function (h, idx) {
                    var msgHtml = h.message ? esc(h.message) : '—';
                    if (h.executedCommand) {
                        msgHtml += '<br/><button type="button" class="st-cmd-link" onclick="stShowCmd(' + idx + ')">' +
                            '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>' +
                            'Komutu göster' +
                        '</button>';
                    }
                    return '<tr>' +
                        '<td style="font-size:.8rem;">' + esc(h.startedAtLocal) + '</td>' +
                        '<td style="font-size:.8rem;">' + (h.completedAtLocal || '<em style="color:#f59e0b;">devam ediyor</em>') + '</td>' +
                        '<td>' + statusCell(h.status, false) + '</td>' +
                        '<td style="font-size:.78rem;color:#64748b;">' + (h.durationMs != null ? h.durationMs + ' ms' : '—') + '</td>' +
                        '<td><span class="st-code-badge">' + esc(h.triggerName) + '</span></td>' +
                        '<td class="st-msg-cell">' + msgHtml + '</td>' +
                        '</tr>';
                }).join('');
                document.getElementById('stHistoryBody').innerHTML =
                    '<table class="st-grid"><thead><tr>' +
                    '<th>Baslangic</th><th>Bitis</th><th>Durum</th><th>Sure</th><th>Tetik.</th><th>Mesaj</th>' +
                    '</tr></thead><tbody>' + rows + '</tbody></table>';
            } catch (e) { document.getElementById('stHistoryBody').innerHTML = '<div class="st-empty">Yuklenemedi: ' + esc(e.message) + '</div>'; }
        };
        window.stCloseHistory = function () { histModal.style.display = 'none'; };

        // ── Komut modal'i: history'deki "Komutu goster" linkinden cagrilir ─
        var cmdModal = document.getElementById('stCmdModal');
        window.stShowCmd = function (idx) {
            var cmd = (window._stCmdCache || [])[idx] || '';
            document.getElementById('stCmdModalContent').textContent = cmd;
            cmdModal.style.display = 'flex';
        };
        window.stCloseCmdModal = function () { cmdModal.style.display = 'none'; };
        window.stCopyCmd = async function () {
            var cmd = document.getElementById('stCmdModalContent').textContent || '';
            try {
                await navigator.clipboard.writeText(cmd);
                stNotify('Komut panoya kopyalandı.', 'success');
            } catch (e) {
                stNotify('Kopyalanamadı: ' + e.message, 'error');
            }
        };

        // Haftanin gunleri pill toggle — input'a tiklayinca event bubble'i kes,
        // satirin onclick'ini bozmadan tek tek tikle
        document.addEventListener('click', function (e) {
            var pill = e.target.closest('#stfWeeklyDays .st-dow-pill');
            if (!pill) return;
            e.stopPropagation();
            e.preventDefault();
            stSelectSchedule(5);
            pill.classList.toggle('is-active');
        });

        // Cron yardim popover toggle (info butonu)
        window.stToggleCronHelp = function (e) {
            e.stopPropagation();
            var pop = document.getElementById('stCronHelp');
            if (!pop) return;
            pop.style.display = pop.style.display === 'none' ? 'block' : 'none';
        };
        // Disariya tiklayinca kapat
        document.addEventListener('click', function (e) {
            var pop = document.getElementById('stCronHelp');
            if (!pop || pop.style.display === 'none') return;
            if (pop.contains(e.target)) return;
            if (e.target.closest('.st-info-btn')) return;
            pop.style.display = 'none';
        });

        // Initial
        stRefresh();
        setInterval(stRefresh, 10000);
    })();
</script>
<form style="display:none;">@Html.AntiForgeryToken()</form>
}
