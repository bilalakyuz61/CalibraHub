    .st-confirm-foot {
        display: flex; justify-content: flex-end; gap: 8px;
    }
    .st-confirm-btn {
        padding: 8px 16px; border-radius: 7px; cursor: pointer;
        font-size: .82rem; font-weight: 600; border: 1px solid transparent;
    }
    .st-confirm-btn--cancel {
        background: transparent; border-color: #cbd5e1; color: #475569;
    }
    .st-confirm-btn--cancel:hover { background: rgba(148,163,184,.1); }
    body.app-theme-dark .st-confirm-btn--cancel { border-color: #2a2f47; color: rgba(255,255,255,.72); }
    body.app-theme-dark .st-confirm-btn--cancel:hover { background: rgba(148,163,184,.15); }
    .st-confirm-btn--yes {
        background: linear-gradient(135deg,#ef4444,#dc2626); color: #fff;
    }
    .st-confirm-btn--yes:hover { filter: brightness(1.08); }

    /* ── Ortalanmis toast / uyari ─────────────────────────────── */
    .st-toast-bd {
        position: fixed; inset: 0; z-index: 10000;
        display: flex; align-items: center; justify-content: center;
        pointer-events: none;
        background: rgba(0,0,0,.18);
        backdrop-filter: blur(2px);
        animation: stToastBd .15s ease-out;
    }
    .st-toast {
        pointer-events: auto;
        background: #fff; border: 1px solid #e2e8f0; border-radius: 12px;
        padding: 16px 20px;
        min-width: 300px; max-width: 480px;
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
        display: flex; align-items: flex-start; gap: 14px;
        font-size: .88rem; color: #1e293b;
        animation: stToastIn .18s ease-out;
    }
    body.app-theme-dark .st-toast {
        background: #1a1e35; border-color: #2a2f47; color: rgba(255,255,255,.92);
    }
    .st-toast-icon {
        width: 32px; height: 32px; flex-shrink: 0;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; font-weight: 700;
    }
    .st-toast--success .st-toast-icon { color: #16a34a; background: rgba(34,197,94,.14); }
    .st-toast--error   .st-toast-icon { color: #dc2626; background: rgba(239,68,68,.14); }
    .st-toast--info    .st-toast-icon { color: #4f46e5; background: rgba(99,102,241,.14); }
    .st-toast--warning .st-toast-icon { color: #d97706; background: rgba(245,158,11,.14); }
    .st-toast-msg { flex: 1; line-height: 1.45; padding-top: 4px; word-break: break-word; }
    .st-toast-x {
        background: transparent; border: none; cursor: pointer;
        font-size: 1.3rem; line-height: 1; color: #94a3b8;
        padding: 0; width: 22px; height: 22px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 4px; flex-shrink: 0;
    }
    .st-toast-x:hover { background: rgba(148,163,184,.15); color: #475569; }
    body.app-theme-dark .st-toast-x:hover { background: rgba(255,255,255,.08); color: rgba(255,255,255,.9); }
    @@keyframes stToastBd { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes stToastIn { from { opacity: 0; transform: scale(.94) translateY(-6px); } to { opacity: 1; transform: scale(1) translateY(0); } }

    .st-back-link {
        background: transparent; border: none; cursor: pointer;
        color: #6366f1; font-size: .78rem; font-weight: 600;
        padding: 4px 8px; border-radius: 5px;
        display: inline-flex; align-items: center; gap: 4px;
    }
    body.app-theme-dark .st-back-link { color: #a5b4fc; }
    .st-back-link:hover { background: rgba(99,102,241,.08); }
</style>
}

