@model IReadOnlyList<CalibraHub.Domain.Entities.ScheduledTask>
@{
    ViewData["Title"] = "Zamanlanmış Görevler";
    ViewData["FormCode"] = "SCHEDULED_TASKS";
}

@section Styles {
<style>
    /* ── Genel sayfa ────────────────────────────────────────────── */
    .st-wrap { padding: 18px 22px; height: 100%; display: flex; flex-direction: column; gap: 14px; }
    .st-head { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .st-head h2 { margin: 0; font-size: 1.1rem; font-weight: 700; color: #1e293b; }
    body.app-theme-dark .st-head h2 { color: rgba(255,255,255,.92); }
    .st-head .st-sub { color: #64748b; font-size: .82rem; }
    body.app-theme-dark .st-head .st-sub { color: rgba(255,255,255,.55); }
    .st-head .st-btn {
        background: rgba(99,102,241,.12); border: 1px solid rgba(99,102,241,.28);
        color: #4f46e5; cursor: pointer;
        padding: 6px 12px; font-size: .8rem; border-radius: 7px;
        display: inline-flex; align-items: center; gap: 6px;
    }
    body.app-theme-dark .st-head .st-btn { color: #a5b4fc; background: rgba(99,102,241,.18); }
    .st-head .st-btn:hover { opacity: .85; }
    .st-head .st-btn--primary {
        background: linear-gradient(135deg,#6366f1,#4f46e5); color: #fff; border-color: transparent;
    }
    .st-head .st-btn--primary:hover { filter: brightness(1.1); }

    .st-grid-card {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 12px;
        flex: 1; min-height: 0; overflow: hidden; display: flex; flex-direction: column;
    }
    body.app-theme-dark .st-grid-card { background: rgba(21,24,43,.7); border-color: #2a2f47; }

    .st-grid { width: 100%; border-collapse: collapse; font-size: .85rem; }
    .st-grid thead th {
        position: sticky; top: 0; background: #f8fafc; z-index: 1;
        text-align: left; padding: 10px 12px; font-weight: 700;
        color: #475569; border-bottom: 1px solid #e2e8f0; white-space: nowrap;
    }
    body.app-theme-dark .st-grid thead th {
        background: rgba(15,17,30,.9); color: rgba(255,255,255,.75);
        border-bottom-color: #2a2f47;
    }
    .st-grid tbody td {
        padding: 10px 12px; border-bottom: 1px solid #f1f5f9; vertical-align: top;
        color: #1e293b;
    }
    body.app-theme-dark .st-grid tbody td {
        color: rgba(255,255,255,.85); border-bottom-color: rgba(255,255,255,.06);
    }
    .st-grid tbody tr:hover { background: rgba(99,102,241,.04); }
    body.app-theme-dark .st-grid tbody tr:hover { background: rgba(99,102,241,.1); }

    .st-name { font-weight: 600; }
    .st-desc { color: #64748b; font-size: .78rem; margin-top: 2px; }
    body.app-theme-dark .st-desc { color: rgba(255,255,255,.55); }
    .st-code-badge, .st-type-badge, .st-sched-badge {
        display: inline-block; font-size: .72rem; padding: 3px 9px; border-radius: 999px;
        font-family: ui-monospace, Consolas, monospace; font-weight: 600;
        line-height: 1.2; border: none;
    }
    /* Code badge — notr gri (kompakt referans) */
    .st-code-badge { background: rgba(148,163,184,.12); color: #64748b; }
    body.app-theme-dark .st-code-badge { background: rgba(148,163,184,.18); color: rgba(255,255,255,.65); }
    /* Tip badge — solid mor arka plan + beyaz yazi */
    .st-type-badge { background: #8b5cf6; color: #fff; }
    body.app-theme-dark .st-type-badge { background: #7c3aed; color: #fff; }
    /* Zamanlama badge — solid teal arka plan + beyaz yazi */
    .st-sched-badge { background: #06b6d4; color: #fff; }
    body.app-theme-dark .st-sched-badge { background: #0891b2; color: #fff; }
    .st-status { display: inline-flex; align-items: center; gap: 6px; font-size: .76rem; font-weight: 600; }
    .st-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .st-dot--ok { background: #22c55e; box-shadow: 0 0 6px rgba(34,197,94,.6); }
    .st-dot--err { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,.6); }
    .st-dot--run { background: #f59e0b; box-shadow: 0 0 6px rgba(245,158,11,.6); animation: st-pulse 1s infinite; }
    .st-dot--none { background: #94a3b8; }
    @@keyframes st-pulse { 50% { opacity: .45; } }

    .st-msg-cell { max-width: 360px; font-size: .76rem; color: #475569; }
    body.app-theme-dark .st-msg-cell { color: rgba(255,255,255,.65); }

    /* History modal mesaj hucresinde "Komutu goster" linki — komut tam halini ayri modalda gosterir */
    .st-cmd-link {
        display: inline-flex; align-items: center; gap: 4px;
        margin-top: 4px; padding: 2px 6px;
        background: transparent; border: none; cursor: pointer;
        color: #6366f1; font-weight: 600; font-size: .72rem;
        border-radius: 4px;
    }
    .st-cmd-link:hover { background: rgba(99,102,241,.1); }
    body.app-theme-dark .st-cmd-link { color: #a5b4fc; }
    body.app-theme-dark .st-cmd-link:hover { background: rgba(99,102,241,.18); }

    /* Komut modal'i icerigi — buyuk pre alani */
    .st-cmd-pre {
        margin: 0; padding: 14px 16px;
        background: rgba(15,23,42,.06);
        border: 1px solid rgba(148,163,184,.22);
        border-radius: 8px;
        font-family: ui-monospace, Consolas, monospace;
        font-size: .82rem; line-height: 1.5; color: #1e293b;
        white-space: pre-wrap; word-break: break-word;
        max-height: 60vh; overflow: auto;
    }
    body.app-theme-dark .st-cmd-pre {
        background: rgba(0,0,0,.32); border-color: #2a2f47; color: rgba(255,255,255,.9);
    }

    .st-empty { padding: 40px 20px; text-align: center; color: #94a3b8; font-style: italic; }
    body.app-theme-dark .st-empty { color: rgba(255,255,255,.45); }

    .st-actions { display: inline-flex; gap: 4px; }
    .st-action-btn {
        width: 28px; height: 28px; border-radius: 5px; border: none; cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center;
        transition: background .12s;
    }
    .st-action-btn[disabled] { opacity: .35; cursor: not-allowed; }
    .st-action-btn--run { background: rgba(34,197,94,.12); color: #16a34a; }
    .st-action-btn--run:hover { background: rgba(34,197,94,.22); }
    .st-action-btn--toggle { background: rgba(99,102,241,.12); color: #4f46e5; }
    .st-action-btn--toggle:hover { background: rgba(99,102,241,.22); }
    .st-action-btn--toggle.is-off { background: rgba(245,158,11,.12); color: #b45309; }
    .st-action-btn--hist { background: rgba(148,163,184,.12); color: #475569; }
    .st-action-btn--hist:hover { background: rgba(148,163,184,.22); }
    .st-action-btn--edit { background: rgba(6,182,212,.12); color: #0e7490; }
    .st-action-btn--edit:hover { background: rgba(6,182,212,.22); }
    .st-action-btn--del { background: rgba(239,68,68,.12); color: #dc2626; }
    .st-action-btn--del:hover { background: rgba(239,68,68,.22); }

    /* ── Modal — tema uyumlu ─────────────────────────────────── */
    .st-modal-bd {
        position: fixed; inset: 0; background: rgba(0,0,0,.7);
        backdrop-filter: blur(6px);
        z-index: 9999;
        display: flex; align-items: center; justify-content: center; padding: 20px;
    }
    .st-modal-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 0;
        max-width: 880px; width: 100%;
        max-height: 90vh; overflow: hidden;
        display: flex; flex-direction: column;
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
        color: #1e293b;
    }
    body.app-theme-dark .st-modal-card {
        background: linear-gradient(135deg,#15182b 0%,#1a1e35 100%);
        border-color: #2a2f47;
        color: rgba(255,255,255,.9);
    }
    .st-modal-head {
        display: flex; align-items: center; gap: 10px;
        padding: 12px 18px;
        border-bottom: 1px solid #e2e8f0;
    }
    body.app-theme-dark .st-modal-head { border-bottom-color: #2a2f47; }
    .st-modal-title { margin: 0; font-size: 1.05rem; font-weight: 700; flex: 1; }
    .st-modal-icon {
        width: 30px; height: 30px;
        border-radius: 8px;
        background: linear-gradient(135deg,rgba(99,102,241,.15),rgba(139,92,246,.15));
        color: #6366f1;
        display: flex; align-items: center; justify-content: center;
    }
    body.app-theme-dark .st-modal-icon { color: #a5b4fc; }
    .st-modal-body { padding: 18px 20px; overflow: auto; }

    /* Sol tabs + sag icerik — standart veri giris ekran iskeleti */
    .st-modal-body--tabbed {
        display: flex; padding: 0; min-height: 440px; flex: 1; overflow: hidden;
    }
    .st-tabs {
        width: 230px; flex-shrink: 0;
        border-right: 1px solid #e2e8f0;
        padding: 14px 0; background: rgba(248,250,252,.5);
        overflow-y: auto;
    }
    .st-tabs-group-title {
        padding: 0 18px 8px;
        font-size: .68rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .6px;
        color: #94a3b8;
    }
    body.app-theme-dark .st-tabs-group-title { color: rgba(255,255,255,.45); }
    body.app-theme-dark .st-tabs {
        border-right-color: #2a2f47; background: rgba(0,0,0,.15);
    }
    .st-tab {
        display: flex; align-items: center; gap: 10px; width: 100%;
        padding: 10px 18px; text-align: left;
        background: transparent; border: none; cursor: pointer;
        font-size: .82rem; font-weight: 600; color: #64748b;
        border-left: 3px solid transparent;
        transition: all .12s;
    }
    .st-tab:hover { background: rgba(99,102,241,.06); color: #4f46e5; }
    .st-tab.is-active {
        background: rgba(99,102,241,.1); color: #4f46e5;
        border-left-color: #6366f1;
    }
    body.app-theme-dark .st-tab { color: rgba(255,255,255,.7); }
    body.app-theme-dark .st-tab:hover { background: rgba(99,102,241,.14); color: #a5b4fc; }
    body.app-theme-dark .st-tab.is-active {
        background: rgba(99,102,241,.2); color: #c7d2fe;
        border-left-color: #a5b4fc;
    }
    .st-tab svg { width: 14px; height: 14px; flex-shrink: 0; }
    .st-tab-content {
        flex: 1; padding: 14px 18px; overflow-y: auto; min-width: 0;
    }
    .st-tab-panel { display: none; }
    .st-tab-panel.is-active { display: block; }
    .st-modal-foot {
        display: flex; justify-content: flex-end; gap: 8px;
        padding: 10px 18px;
        border-top: 1px solid #e2e8f0;
        background: rgba(148,163,184,.04);
        border-radius: 0 0 14px 14px;
    }
    body.app-theme-dark .st-modal-foot { border-top-color: #2a2f47; background: rgba(0,0,0,.15); }

    .st-section {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 14px;
        margin-bottom: 14px;
        background: rgba(248,250,252,.5);
    }
    body.app-theme-dark .st-section {
        border-color: #2a2f47;
        background: rgba(0,0,0,.15);
    }
    .st-section-title {
        font-size: .76rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .5px;
        color: #64748b;
        margin: 14px 0 6px;
        display: flex; align-items: center; gap: 6px;
    }
    .st-section-title:first-child { margin-top: 0; }
    body.app-theme-dark .st-section-title { color: rgba(255,255,255,.6); }
    .st-section-title svg { width: 13px; height: 13px; }

    .st-field { margin-bottom: 8px; }
    .st-field label { display: block; font-size: .74rem; font-weight: 600; color: #475569; margin-bottom: 3px; }
    body.app-theme-dark .st-field label { color: rgba(255,255,255,.72); }
    .st-field small { display: block; font-size: .7rem; color: #94a3b8; margin-top: 3px; }
    body.app-theme-dark .st-field small { color: rgba(255,255,255,.45); }

    .st-input, .st-select, .st-textarea {
        width: 100%;
        padding: 6px 10px;
        background: #fff;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        color: #1e293b;
        font-size: .82rem;
        font-family: inherit;
        transition: border-color .12s, box-shadow .12s;
    }
    .st-input:focus, .st-select:focus, .st-textarea:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,.15);
    }
    body.app-theme-dark .st-input, body.app-theme-dark .st-select, body.app-theme-dark .st-textarea {
        background: #0f1120; border-color: #2a2f47; color: rgba(255,255,255,.9);
    }
    body.app-theme-dark .st-input:focus, body.app-theme-dark .st-select:focus, body.app-theme-dark .st-textarea:focus {
        border-color: #a5b4fc; box-shadow: 0 0 0 3px rgba(165,180,252,.15);
    }
    .st-textarea { font-family: ui-monospace, Consolas, monospace; resize: vertical; }

    .st-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .st-row-3 { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 12px; }

    .st-kv-list { display: flex; flex-direction: column; gap: 6px; }
    .st-kv-row {
        display: grid; grid-template-columns: 1fr 2fr auto;
        gap: 6px; align-items: center;
    }
    /* SQL parametre satiri — kaynak dropdown'u olan 4-sutunlu varyant */
    .st-kv-row.has-source {
        grid-template-columns: 1fr 1.4fr 1.6fr auto;
    }
    .st-kv-row .st-kv-val[disabled] {
        opacity: .55; font-style: italic; cursor: not-allowed;
    }
    .st-kv-row .st-kv-remove {
        width: 28px; height: 28px; border-radius: 5px; border: none; cursor: pointer;
        background: rgba(239,68,68,.12); color: #dc2626;
        display: flex; align-items: center; justify-content: center;
    }
    .st-kv-add {
        margin-top: 8px;
        background: rgba(99,102,241,.1); border: 1px dashed rgba(99,102,241,.35);
        color: #4f46e5; cursor: pointer;
        padding: 7px 12px; font-size: .78rem; border-radius: 6px; font-weight: 600;
        display: inline-flex; align-items: center; gap: 6px;
    }
    body.app-theme-dark .st-kv-add { color: #a5b4fc; background: rgba(99,102,241,.18); }
    .st-kv-add:hover { opacity: .85; }

    .st-schedule-grid { display: flex; flex-direction: column; gap: 4px; }
    .st-schedule-row {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) minmax(0, 1.2fr);
        align-items: center; gap: 10px;
        padding: 6px 10px;
        border: 1px solid #e2e8f0; border-radius: 7px;
        cursor: pointer; transition: border-color .12s, background .12s;
    }
    body.app-theme-dark .st-schedule-row { border-color: #2a2f47; }
    .st-schedule-row:hover { border-color: #cbd5e1; background: rgba(148,163,184,.06); }
    body.app-theme-dark .st-schedule-row:hover { border-color: #3a3f5a; background: rgba(148,163,184,.1); }
    .st-schedule-row.is-active {
        border-color: #6366f1; background: rgba(99,102,241,.08);
    }
    .st-schedule-key {
        display: flex; align-items: center; gap: 10px;
    }
    /* Radio'yu gizle — yerine switch goster */
    .st-switch-input {
        position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0;
    }
    .st-switch {
        display: inline-block; flex-shrink: 0;
        width: 34px; height: 18px;
        background: #cbd5e1; border-radius: 999px;
        position: relative; cursor: pointer;
        transition: background .15s;
    }
    .st-switch::after {
        content: ''; position: absolute;
        top: 2px; left: 2px;
        width: 14px; height: 14px;
        background: #fff; border-radius: 50%;
        box-shadow: 0 1px 2px rgba(0,0,0,.18);
        transition: transform .18s ease;
    }
    .st-switch-input:checked + .st-switch {
        background: linear-gradient(135deg,#6366f1,#4f46e5);
    }
    .st-switch-input:checked + .st-switch::after {
        transform: translateX(16px);
    }
    body.app-theme-dark .st-switch { background: rgba(148,163,184,.28); }
    body.app-theme-dark .st-switch::after { background: #e2e8f0; }
    body.app-theme-dark .st-switch-input:checked + .st-switch {
        background: linear-gradient(135deg,#818cf8,#6366f1);
    }
    .st-schedule-label { font-size: .85rem; font-weight: 600; line-height: 1.25; }
    .st-schedule-hint { font-size: .72rem; color: #94a3b8; font-weight: 400; margin-left: 4px; }
    body.app-theme-dark .st-schedule-hint { color: rgba(255,255,255,.45); }
    .st-schedule-value {
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
    }
    .st-schedule-value .st-input,
    .st-schedule-value .st-select {
        padding: 5px 8px; font-size: .8rem; height: auto;
    }
    .st-schedule-value-empty {
        font-size: .72rem; color: #94a3b8; font-style: italic;
    }
    body.app-theme-dark .st-schedule-value-empty { color: rgba(255,255,255,.4); }
    .st-schedule-row:not(.is-active) .st-schedule-value { opacity: .55; pointer-events: none; }
    .st-schedule-row:not(.is-active) .st-schedule-value-empty { opacity: 1; }

    /* Info button + popover (cron yardim) */
    .st-info-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 26px; height: 26px;
        background: rgba(99,102,241,.1); border: 1px solid rgba(99,102,241,.25);
        color: #4f46e5; border-radius: 6px; cursor: pointer;
        transition: all .12s;
        flex-shrink: 0;
    }
    .st-info-btn:hover { background: rgba(99,102,241,.2); }
    body.app-theme-dark .st-info-btn {
        background: rgba(99,102,241,.18); border-color: rgba(165,180,252,.35); color: #a5b4fc;
    }
    body.app-theme-dark .st-info-btn:hover { background: rgba(99,102,241,.3); }
    .st-info-pop {
        position: absolute; right: 0; top: 100%; margin-top: 6px;
        z-index: 50;
        min-width: 320px; max-width: 420px;
        background: #fff; border: 1px solid #e2e8f0; border-radius: 10px;
        padding: 14px; font-size: .78rem; color: #1e293b;
        box-shadow: 0 12px 32px rgba(15,23,42,.18);
    }
    body.app-theme-dark .st-info-pop {
        background: #1a1e35; border-color: #2a2f47; color: rgba(255,255,255,.9);
    }
    .st-info-pop-title {
        font-weight: 700; font-size: .85rem; margin-bottom: 8px;
        color: #4f46e5;
    }
    body.app-theme-dark .st-info-pop-title { color: #a5b4fc; }
    .st-info-pop-row code {
        display: block; padding: 8px 10px;
        background: rgba(148,163,184,.1); border-radius: 6px;
        font-family: ui-monospace, Consolas, monospace; font-size: .72rem;
        line-height: 1.4; white-space: pre; overflow-x: auto;
    }
    body.app-theme-dark .st-info-pop-row code { background: rgba(0,0,0,.3); }
    .st-info-pop-section { margin-top: 10px; }
    .st-info-pop-subtitle {
        font-weight: 700; font-size: .72rem; text-transform: uppercase; letter-spacing: .5px;
        color: #64748b; margin-bottom: 5px;
    }
    body.app-theme-dark .st-info-pop-subtitle { color: rgba(255,255,255,.55); }
    .st-info-pop-table { width: 100%; border-collapse: collapse; }
    .st-info-pop-table td {
        padding: 4px 6px; vertical-align: top; font-size: .76rem;
    }
    .st-info-pop-table td:first-child { width: 40%; }
    .st-info-pop-table code {
        font-family: ui-monospace, Consolas, monospace; font-size: .72rem;
        padding: 2px 5px; border-radius: 3px;
        background: rgba(99,102,241,.12); color: #4f46e5;
    }
    body.app-theme-dark .st-info-pop-table code { background: rgba(165,180,252,.18); color: #c7d2fe; }
    .st-info-pop ul { padding-left: 16px; margin: 0; }
    .st-info-pop ul li { margin-bottom: 3px; font-size: .75rem; }
    .st-info-pop ul code {
        font-family: ui-monospace, Consolas, monospace; font-size: .72rem;
        padding: 1px 4px; background: rgba(99,102,241,.12); color: #4f46e5; border-radius: 3px;
    }
    body.app-theme-dark .st-info-pop ul code { background: rgba(165,180,252,.18); color: #c7d2fe; }

    /* Chip liste (alici mail) */
    .st-chip-wrap { display: flex; flex-direction: column; gap: 4px; }
    .st-chip-list {
        display: flex; flex-wrap: wrap; gap: 4px;
        min-height: 32px; padding: 5px 7px;
        background: #fff; border: 1px solid #cbd5e1; border-radius: 7px;
    }
    body.app-theme-dark .st-chip-list {
        background: #0f1120; border-color: #2a2f47;
    }
    .st-chip {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 4px 3px 10px;
        background: rgba(99,102,241,.12); color: #4f46e5;
        border-radius: 12px; font-size: .75rem; font-weight: 600;
    }
    body.app-theme-dark .st-chip { background: rgba(165,180,252,.18); color: #a5b4fc; }
    .st-chip-x {
        width: 18px; height: 18px; border: none; cursor: pointer;
        background: transparent; color: currentColor; opacity: .7;
        border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;
        font-size: 1rem; line-height: 1;
    }
    .st-chip-x:hover { opacity: 1; background: rgba(99,102,241,.2); }
    .st-chip-list-empty { color: #94a3b8; font-size: .75rem; font-style: italic; padding: 2px 4px; }
