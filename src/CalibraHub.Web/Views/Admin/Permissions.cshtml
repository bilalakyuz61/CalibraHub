@{
    ViewData["Title"] = "Yetki Yönetimi";
    ViewData["BodyClass"] = "page-permissions workspace-frame-body";
}

@section Styles {
<style>
    /* Full-height shell */
    .pm-shell {
        display: flex; flex-direction: column;
        height: 100dvh; min-height: 0; overflow: hidden;
        background: #f8fafc;
    }
    body.app-theme-dark .pm-shell { background: #0a0d17; }

    /* Top bar (radio + target + save) */
    .pm-topbar {
        display: flex; align-items: center; gap: 18px;
        padding: 14px 22px; flex-shrink: 0;
        background: rgba(255,255,255,0.96);
        border-bottom: 1px solid #e2e8f0;
        backdrop-filter: blur(12px);
    }
    body.app-theme-dark .pm-topbar {
        background: rgba(13,19,35,0.92);
        border-bottom-color: rgba(255,255,255,0.06);
    }
    /* Radio group — segmented pill */
    .pm-radio-group {
        display: inline-flex; gap: 0; padding: 4px;
        background: rgba(148,163,184,0.12); border-radius: 10px;
    }
    .pm-radio-group label {
        cursor: pointer; display: inline-flex; align-items: center;
    }
    .pm-radio-group input[type="radio"] { display: none; }
    /* Tüm label-span'lar AYNI dimensions — checked olunca sadece bg/color değişir */
    .pm-radio-group label span {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        color: #64748b;
        transition: background .12s, color .12s;
        line-height: 1.2;
    }
    .pm-radio-group input[type="radio"]:checked + span {
        background: #6366f1; color: #fff;
    }

    /* Field + select — label SOLDA, select sağda (inline) */
    .pm-field { display: inline-flex; align-items: center; gap: 10px; }
    .pm-field label {
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        color: #64748b; letter-spacing: .04em; white-space: nowrap;
    }
    .pm-field select {
        width: 360px; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 8px;
        font-size: 13px; background: #fff; color: #0f172a; outline: none;
    }
    body.app-theme-dark .pm-field select {
        background: #0f172a; color: #e2e8f0; border-color: rgba(148,163,184,.3);
    }

    .pm-btn { padding: 9px 18px; border-radius: 8px; font-weight: 600; font-size: 13px;
        cursor: pointer; border: 1px solid transparent; transition: background .12s; }
    .pm-btn--primary { background: #6366f1; color: #fff; border-color: #6366f1; }
    .pm-btn--primary:hover:not(:disabled) { background: #4f46e5; }
    .pm-btn:disabled { opacity: .5; cursor: not-allowed; }

    /* Departman bilgisi — kullanıcı seçilince topbar'da görünür */
    #permDeptBadge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 14px; border-radius: 999px;
        background: rgba(20,184,166,.12); color: #0d9488;
        border: 1px solid rgba(20,184,166,.25);
        font-size: 14px; font-weight: 600; white-space: nowrap;
    }
    #permDeptBadge::before { content: '🏢'; font-size: 13px; }
    body.app-theme-dark #permDeptBadge {
        background: rgba(20,184,166,.15); color: #2dd4bf;
        border-color: rgba(20,184,166,.3);
    }
    /* Hızlı filtre combobox — topbar'a taşındı */
    .pm-quick-filter-sel {
        height: 34px; padding: 0 10px;
        border-radius: 8px; border: 1px solid #cbd5e1;
        background: #fff; color: #334155;
        font-size: 13px; font-weight: 500; cursor: pointer;
        color-scheme: light;
    }
    body.app-theme-dark .pm-quick-filter-sel {
        background: #0f172a; color: #cbd5e1;
        border-color: rgba(148,163,184,.3); color-scheme: dark;
    }

    .pm-status { padding: 6px 22px; font-size: 12px; color: #64748b; min-height: 24px; flex-shrink: 0; }
    .pm-status.ok  { color: #10b981; }
    .pm-status.err { color: #ef4444; }

    /* Hızlı filtre çubuğu — hedef seçimi sonrası görünür, izinleri kategorize eder */
    .pm-filters {
        display: flex; gap: 6px; padding: 8px 22px; flex-shrink: 0; flex-wrap: wrap;
        background: rgba(248,250,252,0.6);
        border-bottom: 1px solid #e2e8f0;
        align-items: center;
    }
    body.app-theme-dark .pm-filters {
        background: rgba(13,19,35,0.5);
        border-bottom-color: rgba(255,255,255,0.06);
    }
    .pm-filters__label {
        font-size: 11px; font-weight: 700; text-transform: uppercase; color: #94a3b8;
        letter-spacing: .04em; margin-right: 4px;
    }
    .pm-filter {
        padding: 5px 12px; border-radius: 999px; border: 1px solid #cbd5e1;
        background: #fff; color: #475569; cursor: pointer;
        font-size: 12px; font-weight: 600; line-height: 1.2;
        transition: background .12s, color .12s, border-color .12s;
        display: inline-flex; align-items: center; gap: 6px;
    }
    body.app-theme-dark .pm-filter {
        background: #0f172a; color: #cbd5e1; border-color: rgba(148,163,184,.3);
    }
    .pm-filter:hover:not(:disabled) { border-color: #94a3b8; }
    .pm-filter:disabled {
        opacity: .4; cursor: not-allowed;
        pointer-events: none;
    }
    .pm-filter.is-active { background: #6366f1; color: #fff; border-color: #6366f1; }
    .pm-filter.is-active.is-allow { background: #10b981; border-color: #10b981; }
    .pm-filter.is-active.is-deny  { background: #ef4444; border-color: #ef4444; }
    .pm-filter.is-active.is-dept  { background: #14b8a6; border-color: #14b8a6; }
    .pm-filter.is-active.is-noDept { background: #f97316; border-color: #f97316; }
    .pm-filter[data-user-only] { display: none; }
    .pm-filters.is-user-mode .pm-filter[data-user-only] { display: inline-flex; }
    .pm-filter__count {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 16px; height: 16px; padding: 0 5px; border-radius: 9px;
        background: rgba(0,0,0,0.12); font-size: 10px; font-weight: 700;
    }
    .pm-filter.is-active .pm-filter__count { background: rgba(255,255,255,0.28); }

    /* Body (left aside + right content) */
    .pm-body {
        flex: 1 1 auto; min-height: 0; overflow: hidden;
        display: grid; grid-template-columns: 260px 1fr; gap: 0;
    }
    .pm-aside {
        background: #ffffff; border-right: 1px solid #e2e8f0;
        display: flex; flex-direction: column; min-height: 0;
    }
    body.app-theme-dark .pm-aside { background: #111827; border-right-color: rgba(255,255,255,0.06); }
    .pm-aside__list { overflow-y: auto; padding: 8px 0; flex: 1; }

    /* Arama input */
    .pm-search {
        position: relative; padding: 12px 14px 8px;
        border-bottom: 1px solid #e2e8f0; flex-shrink: 0;
    }
    body.app-theme-dark .pm-search { border-bottom-color: rgba(255,255,255,0.06); }
    .pm-search input {
        width: 100%; padding: 8px 32px 8px 12px;
        border: 1px solid #cbd5e1; border-radius: 8px;
        font-size: 13px; background: #fff; color: #0f172a; outline: none;
        transition: border-color .12s;
    }
    body.app-theme-dark .pm-search input {
        background: #0f172a; color: #e2e8f0; border-color: rgba(148,163,184,.3);
    }
    .pm-search input:focus { border-color: #6366f1; }
    .pm-search input::placeholder { color: #94a3b8; }
    .pm-search__icon {
        position: absolute; right: 24px; top: 50%; transform: translateY(-50%);
        color: #94a3b8; pointer-events: none;
    }

    .pm-form-item {
        display: flex; align-items: center; gap: 8px;
        padding: 9px 16px; cursor: pointer;
        border-left: 3px solid transparent;
        font-size: 13px; color: #475569;
        transition: background .12s, color .12s;
    }
    body.app-theme-dark .pm-form-item { color: #cbd5e1; }
    .pm-form-item:hover { background: rgba(99,102,241,.07); color: #0f172a; }
    body.app-theme-dark .pm-form-item:hover { color: #f1f5f9; }
    .pm-form-item.is-active {
        background: rgba(99,102,241,.10); color: #6366f1;
        border-left-color: #6366f1; font-weight: 600;
    }
    body.app-theme-dark .pm-form-item.is-active { color: #a5b4fc; border-left-color: #a5b4fc; }
    .pm-form-item__name { flex: 1; }
    .pm-form-item__badge {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 18px; height: 18px; padding: 0 6px; border-radius: 9px;
        background: #6366f1; color: #fff; font-size: 10px; font-weight: 700;
    }

    .pm-aside-empty { padding: 36px 22px; text-align: center; color: #94a3b8; font-size: 13px; }

    /* Content (right) */
    .pm-content {
        display: flex; flex-direction: column; min-height: 0;
    }
    .pm-content__header {
        padding: 20px 28px 12px; flex-shrink: 0;
        border-bottom: 1px solid #e2e8f0;
        display: flex; align-items: center; gap: 16px;
    }
    body.app-theme-dark .pm-content__header { border-bottom-color: rgba(255,255,255,0.06); }
    .pm-content__title-block { flex: 1; min-width: 0; }
    .pm-content__title { font-size: 18px; font-weight: 700; margin: 0; color: #0f172a; }
    body.app-theme-dark .pm-content__title { color: #f1f5f9; }
    .pm-content__sub { font-size: 12px; color: #94a3b8; margin-top: 4px; }

    .pm-content__search {
        position: relative; flex-shrink: 0;
    }
    .pm-content__search input {
        width: 280px; padding: 8px 32px 8px 12px;
        border: 1px solid #cbd5e1; border-radius: 8px;
        font-size: 13px; background: #fff; color: #0f172a; outline: none;
        transition: border-color .12s;
    }
    body.app-theme-dark .pm-content__search input {
        background: #0f172a; color: #e2e8f0; border-color: rgba(148,163,184,.3);
    }
    .pm-content__search input:focus { border-color: #6366f1; }
    .pm-content__search__icon {
        position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
        color: #94a3b8; pointer-events: none;
    }

    .pm-content__body { overflow-y: auto; padding: 12px 16px; flex: 1; }

    /* Sütun başlığı satırı — "Yetki | Miras | İzinli" */
    .pm-action-list-header {
        display: grid; grid-template-columns: 1fr auto;
        align-items: center; gap: 12px;
        padding: 0 12px 6px; margin-bottom: 2px;
    }
    .pm-action-list-header__label {
        font-size: 10px; font-weight: 700; text-transform: uppercase;
        letter-spacing: .05em; color: #94a3b8;
    }
    .pm-action-list-header__cols {
        display: flex; gap: 10px;
    }
    .pm-action-list-header__cols span {
        width: 42px; text-align: center;
        font-size: 10px; font-weight: 600;
        letter-spacing: .02em; color: #94a3b8;
    }

    .pm-action-list { display: flex; flex-direction: column; gap: 2px; }
    .pm-action-row {
        display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;
        padding: 4px 12px; background: #ffffff; border: 1px solid #e2e8f0; border-radius: 6px;
        transition: opacity .15s; min-height: 34px;
    }
    body.app-theme-dark .pm-action-row { background: #111827; border-color: rgba(255,255,255,0.06); }
    .pm-action-row__label { font-size: 13px; font-weight: 600; color: #0f172a; display: flex; align-items: center; }
    body.app-theme-dark .pm-action-row__label { color: #f1f5f9; }

    /* Yetki tipi ikon chip'leri */
    .pm-action-icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; border-radius: 5px; flex-shrink: 0; margin-right: 7px;
    }
    .pm-ai-view-own { background: rgba(124,58,237,.12); color: #7c3aed; }
    body.app-theme-dark .pm-ai-view-own { background: rgba(167,139,250,.15); color: #a78bfa; }
    .pm-ai-view { background: rgba(29,78,216,.12); color: #1d4ed8; }
    body.app-theme-dark .pm-ai-view { background: rgba(96,165,250,.15); color: #60a5fa; }
    .pm-ai-create { background: rgba(5,150,105,.12); color: #047857; }
    body.app-theme-dark .pm-ai-create { background: rgba(52,211,153,.15); color: #34d399; }
    .pm-ai-edit-own { background: rgba(180,83,9,.12); color: #b45309; }
    body.app-theme-dark .pm-ai-edit-own { background: rgba(251,191,36,.15); color: #fbbf24; }
    .pm-ai-edit-all { background: rgba(217,119,6,.14); color: #d97706; }
    body.app-theme-dark .pm-ai-edit-all { background: rgba(251,191,36,.18); color: #f59e0b; }
    .pm-ai-del-own { background: rgba(185,28,28,.11); color: #b91c1c; }
    body.app-theme-dark .pm-ai-del-own { background: rgba(248,113,113,.14); color: #f87171; }
    .pm-ai-del-all { background: rgba(220,38,38,.15); color: #dc2626; }
    body.app-theme-dark .pm-ai-del-all { background: rgba(248,113,113,.18); color: #ef4444; }
    .pm-ai-btn { background: rgba(100,116,139,.11); color: #64748b; }
    body.app-theme-dark .pm-ai-btn { background: rgba(148,163,184,.14); color: #94a3b8; }
    .pm-ai-view-dept { background: rgba(79,70,229,.12); color: #4f46e5; }
    body.app-theme-dark .pm-ai-view-dept { background: rgba(129,140,248,.15); color: #818cf8; }
    .pm-ai-edit-dept { background: rgba(202,138,4,.13); color: #ca8a04; }
    body.app-theme-dark .pm-ai-edit-dept { background: rgba(250,204,21,.15); color: #eab308; }
    .pm-ai-del-dept { background: rgba(194,65,12,.13); color: #c2410c; }
    body.app-theme-dark .pm-ai-del-dept { background: rgba(251,146,60,.16); color: #fb923c; }
    /* VIEW kapalıyken bağımlı action'lar gri + tıklanamaz */
    .pm-action-row.is-disabled { opacity: .45; pointer-events: none; }
    .pm-action-row__note {
        display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 10px;
        background: rgba(245,158,11,.18); color: #d97706; font-weight: 600; margin-left: 8px;
    }

    /* ── İki switch çifti (Miras | İzinli) — tüm yetki satırları için standart ── */
    .pm-perm-switches {
        display: flex; flex-direction: column; align-items: flex-end; gap: 1px;
    }
    .pm-perm-sw-pair {
        display: flex; align-items: center; gap: 10px;
    }
    .pm-perm-sw-wrap {
        display: flex; flex-direction: row; align-items: center; justify-content: center;
        gap: 4px; width: 42px;
    }
    .pm-perm-sw-wrap.is-passive { opacity: .4; pointer-events: none; cursor: default; }
    .pm-perm-sw-lbl {
        font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase;
        letter-spacing: .03em; white-space: nowrap;
    }
    body.app-theme-dark .pm-perm-sw-lbl { color: #94a3b8; }
    .pm-perm-sw-src {
        font-size: 9px; color: #94a3b8; white-space: nowrap; line-height: 1;
    }
    .pm-perm-sw-src.src-user { color: #6366f1; }
    .pm-perm-sw-src.src-dept { color: #14b8a6; }
    /* Departman kaynağı rozeti — Miras label'ı içinde inline, yükseklik etkilemez */
    .pm-dept-badge {
        display: inline-block; font-size: 8px; font-weight: 700; line-height: 1;
        padding: 1px 3px; border-radius: 3px; vertical-align: middle; margin-left: 3px;
        background: rgba(20,184,166,.15); color: #14b8a6;
    }
    body.app-theme-dark .pm-dept-badge { background: rgba(20,184,166,.2); color: #2dd4bf; }

    .pm-empty { padding: 60px 20px; text-align: center; color: #94a3b8; }
    .pm-empty__icon { font-size: 40px; margin-bottom: 12px; opacity: .5; }

    /* Admin-only form uyarısı — Operatör kullanıcıya AdminOnly formun izni verildiğinde */
    .pm-admin-warning {
        margin: 0 0 10px 0; padding: 12px 16px;
        background: rgba(245,158,11,.10); border: 1px solid rgba(245,158,11,.30);
        border-radius: 8px; display: flex; align-items: flex-start; gap: 10px;
        font-size: 13px;
    }
    body.app-theme-dark .pm-admin-warning {
        background: rgba(245,158,11,.08); border-color: rgba(245,158,11,.25);
    }
    .pm-admin-warning__icon { font-size: 16px; flex-shrink: 0; line-height: 1.4; }
    .pm-admin-warning__text { color: #92400e; line-height: 1.5; }
    body.app-theme-dark .pm-admin-warning__text { color: #fbbf24; }
    .pm-admin-warning__title { font-weight: 700; display: block; margin-bottom: 2px; }
    .pm-admin-warning__detail { font-size: 12px; opacity: .85; }

    /* Aside'daki admin-lock ikonu */
    .pm-form-item__lock {
        font-size: 10px; opacity: .55; flex-shrink: 0;
    }

    /* ── Switchkey ─────────────────────────────────────────────────────── */
    .pm-switch {
        display: inline-flex; align-items: center; cursor: pointer;
        user-select: none; gap: 0;
    }
    .pm-switch__track {
        width: 32px; height: 18px; border-radius: 9px;
        background: #cbd5e1; position: relative;
        transition: background .15s; flex-shrink: 0;
        border: 1px solid #e2e8f0;
    }
    body.app-theme-dark .pm-switch__track {
        background: rgba(148,163,184,.25); border-color: rgba(148,163,184,.2);
    }
    .pm-switch.is-on .pm-switch__track { background: #6366f1; border-color: #6366f1; }
    body.app-theme-dark .pm-switch.is-on .pm-switch__track { background: #6366f1; border-color: #6366f1; }
    .pm-switch__thumb {
        width: 12px; height: 12px; border-radius: 50%;
        background: #fff; position: absolute; top: 2px; left: 2px;
        transition: transform .15s; box-shadow: 0 1px 2px rgba(0,0,0,.25);
    }
    .pm-switch.is-on .pm-switch__thumb { transform: translateX(14px); }
    /* BUTTON:* satırında action-row arka planını biraz farklılaştır */
    .pm-action-row.is-btn-perm {
        background: rgba(99,102,241,.03);
    }
    body.app-theme-dark .pm-action-row.is-btn-perm {
        background: rgba(99,102,241,.06);
    }
    .pm-action-row__badge {
        display: inline-block; font-size: 10px; padding: 2px 7px; border-radius: 10px;
        background: rgba(99,102,241,.12); color: #6366f1; font-weight: 700;
        margin-left: 6px; vertical-align: middle;
    }
    body.app-theme-dark .pm-action-row__badge { background: rgba(99,102,241,.2); color: #a5b4fc; }

    /* ── Grup Yönetimi (2026-07-06) ─────────────────────────────────── */
    .pm-btn--ghost {
        background: transparent; color: var(--bs-body-color, #334155);
        border: 1px solid var(--app-border, #cbd5e1);
    }
    .pm-btn--ghost:hover { border-color: #818cf8; color: #6366f1; }
    body.app-theme-dark .pm-btn--ghost { color: #cbd5e1; border-color: rgba(255,255,255,.16); }
    body.app-theme-dark .pm-btn--ghost:hover { color: #a5b4fc; border-color: rgba(129,140,248,.5); }

    .pmg-backdrop {
        position: fixed; inset: 0; z-index: 9990; display: none;
        align-items: center; justify-content: center;
        background: rgba(15,23,42,.55); backdrop-filter: blur(4px);
    }
    .pmg-backdrop.open { display: flex; }
    .pmg-modal {
        width: min(640px, 94vw); max-height: 82vh; display: flex; flex-direction: column;
        border-radius: 14px; overflow: hidden;
        background: var(--app-surface, #ffffff);
        border: 1px solid var(--app-border, #e2e8f0);
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
    }
    body.app-theme-dark .pmg-modal { background: #0f172a; border-color: rgba(255,255,255,.1); }
    .pmg-head {
        display: flex; align-items: center; gap: 10px; padding: 14px 18px;
        border-bottom: 1px solid var(--app-border, #e2e8f0); flex-shrink: 0;
    }
    body.app-theme-dark .pmg-head { border-bottom-color: rgba(255,255,255,.08); }
    .pmg-title { font-size: .95rem; font-weight: 700; flex: 1; color: var(--bs-body-color, #0f172a); }
    body.app-theme-dark .pmg-title { color: #e2e8f0; }
    .pmg-close {
        width: 28px; height: 28px; border: none; background: transparent; cursor: pointer;
        color: #64748b; border-radius: 6px; font-size: 16px; line-height: 1;
    }
    .pmg-close:hover { background: rgba(148,163,184,.15); }
    .pmg-body { padding: 14px 18px; overflow-y: auto; flex: 1; }

    .pmg-new { display: flex; gap: 8px; margin-bottom: 14px; }
    .pmg-new input[type="text"] {
        flex: 1; padding: 7px 10px; border-radius: 8px; font-size: .82rem;
        border: 1px solid var(--app-border, #cbd5e1); background: var(--app-surface, #fff);
        color: var(--bs-body-color, #0f172a);
    }
    body.app-theme-dark .pmg-new input[type="text"] { background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.12); color: #e2e8f0; }
    .pmg-new input[type="text"]:focus { outline: none; border-color: #818cf8; }

    .pmg-row {
        display: flex; align-items: center; gap: 10px; padding: 9px 10px;
        border: 1px solid var(--app-border, #e2e8f0); border-radius: 10px; margin-bottom: 8px;
    }
    body.app-theme-dark .pmg-row { border-color: rgba(255,255,255,.08); }
    .pmg-row--inactive { opacity: .55; }
    .pmg-row-name { font-weight: 600; font-size: .84rem; color: var(--bs-body-color, #0f172a); }
    body.app-theme-dark .pmg-row-name { color: #e2e8f0; }
    .pmg-row-desc { font-size: .72rem; color: #64748b; }
    .pmg-row-main { flex: 1; min-width: 0; }
    .pmg-count {
        font-size: .7rem; font-weight: 700; padding: 2px 8px; border-radius: 999px;
        background: rgba(99,102,241,.12); color: #4f46e5; white-space: nowrap;
    }
    body.app-theme-dark .pmg-count { background: rgba(99,102,241,.2); color: #a5b4fc; }

    /* Switchkey — Aktif/Pasif (native checkbox ham düşmez) */
    .pmg-switch { position: relative; display: inline-block; width: 34px; height: 19px; flex-shrink: 0; cursor: pointer; }
    .pmg-switch input { opacity: 0; width: 0; height: 0; }
    .pmg-switch .tr {
        position: absolute; inset: 0; border-radius: 999px; transition: background .15s;
        background: #cbd5e1;
    }
    body.app-theme-dark .pmg-switch .tr { background: rgba(255,255,255,.18); }
    .pmg-switch .tr::after {
        content: ''; position: absolute; top: 2px; left: 2px; width: 15px; height: 15px;
        border-radius: 50%; background: #fff; transition: transform .15s;
        box-shadow: 0 1px 3px rgba(0,0,0,.3);
    }
    .pmg-switch input:checked + .tr { background: #6366f1; }
    .pmg-switch input:checked + .tr::after { transform: translateX(15px); }

    .pmg-member-search { width: 100%; margin-bottom: 8px; }
    .pmg-member-list { max-height: 300px; overflow-y: auto; border: 1px solid var(--app-border, #e2e8f0); border-radius: 10px; padding: 6px; }
    body.app-theme-dark .pmg-member-list { border-color: rgba(255,255,255,.08); }
    .pmg-member {
        display: flex; align-items: center; gap: 8px; padding: 6px 8px; border-radius: 7px;
        font-size: .8rem; cursor: pointer; color: var(--bs-body-color, #0f172a);
    }
    body.app-theme-dark .pmg-member { color: #e2e8f0; }
    .pmg-member:hover { background: rgba(99,102,241,.07); }
    .pmg-member input { accent-color: #6366f1; }
    .pmg-member-mail { font-size: .7rem; color: #64748b; }
    .pmg-foot {
        display: flex; gap: 8px; justify-content: flex-end; padding: 12px 18px;
        border-top: 1px solid var(--app-border, #e2e8f0); flex-shrink: 0;
    }
    body.app-theme-dark .pmg-foot { border-top-color: rgba(255,255,255,.08); }
</style>
}

<div class="pm-shell">
    <div class="pm-topbar">
        <div class="pm-radio-group" role="radiogroup" aria-label="Hedef Türü">
            <label>
                <input type="radio" name="permMode" value="dept" />
                <span>Departman</span>
            </label>
            <label>
                @* 2026-07-06 — Yetki grubu (rol): birden fazla kullanıcıya tek pakette izin.
                   Çözümleme: Kullanıcı override > Grup birleşimi > Departman > deny. *@
                <input type="radio" name="permMode" value="group" />
                <span>Grup</span>
            </label>
            <label>
                @* 2026-06-08 — Varsayılan mod: Kullanıcı. Tipik kullanım kullanıcıya yetki vermek;
                   departman yetkilendirmesi daha az sıklıkla yapılır. *@
                <input type="radio" name="permMode" value="user" checked />
                <span>Kullanıcı</span>
            </label>
        </div>

        <div class="pm-field">
            <label for="permTargetId">Hedef</label>
            <select id="permTargetId">
                <option value="">— Seçiniz —</option>
            </select>
        </div>

        <button type="button" id="permSaveBtn" class="pm-btn pm-btn--primary" disabled>Kaydet</button>
        <button type="button" id="permGroupsBtn" class="pm-btn pm-btn--ghost" style="display:none;">Grup Yönetimi</button>

        <select id="permQuickFilter" class="pm-quick-filter-sel" style="display:none;">
            <option value="all">Tümü</option>
            <option value="has">Sahip olduğu</option>
            <option value="no">Sahip olmadığı</option>
            <option value="fromGroup" data-user-only>Departmandan aldığı</option>
            <option value="noFromGroup" data-user-only>Kendinde var, departmanda yok</option>
        </select>

        <span id="permDeptBadge" class="pm-dept-badge" style="display:none;"></span>
    </div>

    <div id="permStatus" class="pm-status"></div>

    <div class="pm-body">
        <aside class="pm-aside">
            <div class="pm-search">
                <input type="text" id="permFormSearch" placeholder="Form ara…" autocomplete="off" />
                <svg class="pm-search__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
            </div>
            <div class="pm-aside__list" id="permAside">
                <div class="pm-aside-empty">Yukarıdan hedef seçin.</div>
            </div>
        </aside>
        <section class="pm-content" id="permContent">
            <div class="pm-empty" id="permEmptyState">
                <div class="pm-empty__icon">🛡️</div>
                <div>Soldan bir form seçin</div>
            </div>
        </section>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
(function () {
    var targetSel = document.getElementById('permTargetId');
    var saveBtn   = document.getElementById('permSaveBtn');
    var asideEl   = document.getElementById('permAside');
    var contentEl = document.getElementById('permContent');
    var statusEl  = document.getElementById('permStatus');

    var deptBadgeEl = document.getElementById('permDeptBadge');

    // Operatörlerin menüde görebileceği formlar (MenuDefinition.cs PermissionFormCode listesi).
    // Bu liste dışındaki formlar AdminOnly=true olup operatörlere menüde hiç gösterilmez;
    // yetki verilse dahi etkisizdir.
    // Sistem yönetimi ekranları HARİÇ tüm form kodları — bu listedeki kodlar için
    // yetki atanabilir ve operatör menüsünde göründüğünü UI uyarı vermez.
    // Sadece şu kodlar YOKTUR (AdminOnly, grant yapılsa da menüde çıkmaz):
    //   COMPANY_SETTINGS, COMPANY_PARAMETERS, COMPANY_USERS, DB_SCHEMA
    var OPERATOR_VISIBLE_FORM_CODES = [
        // Genel
        'NOTES', 'ORG_CHART', 'WHATSAPP', 'BULK_MAIL',
        // Raporlar
        'DASHBOARDS', 'REPORT_DESIGNER',
        // Onay İşlemleri
        'APPROVAL_PENDING', 'EINVOICE', 'EARCHIVE', 'EDISPATCH', 'APPROVAL_FLOWS',
        // Lojistik — Malzeme
        'MATERIAL_CARD_EDIT', 'PRODUCT_CONFIG', 'PRODUCT_FEATURE_EDIT', 'PRODUCT_COMBINATIONS',
        // Lojistik — Satış
        'SALES_QUOTE', 'SALES_QUOTE_NEW', 'SALES_QUOTE_EDIT', 'SALES_QUOTE_LINES',
        'SALES_ORDER', 'SALES_ORDER_NEW', 'SALES_ORDER_EDIT', 'SALES_ORDER_LINES',
        // Lojistik — Satın Alma
        'PURCHASE_REQUEST', 'PURCHASE_REQUEST_NEW', 'PURCHASE_REQUEST_EDIT', 'PURCHASE_REQUEST_LINES',
        'PURCHASE_FULFILLMENT',
        'PURCHASE_QUOTE', 'PURCHASE_QUOTE_NEW', 'PURCHASE_QUOTE_EDIT', 'PURCHASE_QUOTE_LINES',
        'PURCHASE_ORDER', 'PURCHASE_ORDER_NEW', 'PURCHASE_ORDER_EDIT', 'PURCHASE_ORDER_LINES',
        'PURCHASE_DEMAND', 'PURCHASE_DEMAND_NEW', 'PURCHASE_DEMAND_EDIT', 'PURCHASE_DEMAND_LINES',
        // Lojistik — Depo
        'TRANSFER', 'TRANSFER_LINES', 'STOCK_IN', 'STOCK_IN_LINES', 'STOCK_OUT', 'STOCK_OUT_LINES', 'INVENTORY_COUNT',
        // Üretim
        'BOM_EDIT',
        'WORK_ORDERS', 'WORK_ORDER_EDIT',
        'OPERATIONS', 'OPERATION_EDIT',
        'ROUTINGS', 'ROUTING_EDIT', 'ROUTING_OPERATION_EDIT',
        'PERSONNEL', 'PERSONNEL_EDIT',
        'SHIFTS', 'SHIFT_EDIT',
        'ACTIVITY_REASONS', 'ACTIVITY_REASON_EDIT',
        'SHOP_FLOOR', 'PRODUCTION_DEFS',
        // Finans (CONTACT_EDIT, CONTACTS ile birleştirildi — 2026-06-13)
        'CONTACTS',
        // Genel Tanımlamalar
        'SALES_REPS', 'CURRENCIES', 'LOCATIONS', 'MEASURE_UNITS',
        'MATERIAL_GROUPS', 'CARD_GROUPS', 'DEPARTMENTS', 'PRICE_LIST', 'PRICE_GROUPS',
        'MACHINES', 'MACHINE_TYPES',
        // Varlık Yönetimi
        'ASSETS',
        // Tasarım
        'DOC_TEMPLATES', 'DOC_LAYOUT_RULES', 'DOC_NUMBER_RULES',
        // Ayarlar
        'SCHEDULER', 'INTEGRATIONS', 'INTEGRATION_EVENTS',
        'VIEW_SETTINGS', 'SETUP_DEFINITIONS', 'PERMISSION_MGMT', 'DATA_VISIBILITY', 'APPROVAL_FLOWS',
    ];

    var state = {
        mode: 'user',
        targetId: null,
        targetRole: null,       // Backend'den dönen hedef kullanıcının rolü ('Operator', 'DepartmentManager', 'SystemAdmin')
        items: [],              // tüm izinler (360)
        byForm: {},             // { formCode: { name, items: [...] } }
        selectedFormCode: null,
        formSearchTerm: '',
        actionSearchTerm: '',
        quickFilter: 'all',     // 'all' | 'has' | 'no' | 'fromGroup' | 'noFromGroup'
        targetHasDept: false,   // Kullanıcı modunda seçili kullanıcının departmanı var mı?
        userDeptMap: {},        // { userId: { departmentId, departmentName } | null } — lookup yüklendiğinde dolar
    };

    var quickFilterSel = document.getElementById('permQuickFilter');

    // Her item için hızlı filtre testleri — Kullanıcının nihai izin durumu
    // (override + miras) sonrasında computeEffective ile karar verilir.
    // - has         : computeEffective(it) === true  (sahip olduğu yetkiler)
    // - no          : computeEffective(it) === false (sahip olmadığı yetkiler)
    // - fromGroup   : departmandan geliyor + sahip (gruptan aldığı)
    // - noFromGroup : kullanıcı sahip ama departmanında YOK (kendinde olup grubunda olmayan)
    function isFromGroup(it) {
        return it.source === 'DEPARTMENT' && it.isAllowed === true && it.mirasOn;
    }
    function passesQuickFilter(it) {
        var f = state.quickFilter;
        if (f === 'all') return true;
        var eff = computeEffective(it);
        if (f === 'has') return eff === true;
        if (f === 'no')  return eff === false;
        if (f === 'fromGroup')   return isFromGroup(it);
        if (f === 'noFromGroup') return eff === true && !isFromGroup(it);
        return true;
    }

    // Tüm filtre seçenekleri için option metinlerini sayıyla güncelle.
    function updateFilterCounts() {
        var counts = { all: 0, has: 0, no: 0, fromGroup: 0, noFromGroup: 0 };
        state.items.forEach(function (it) {
            counts.all++;
            var eff = computeEffective(it);
            if (eff) counts.has++; else counts.no++;
            if (isFromGroup(it)) counts.fromGroup++;
            if (eff && !isFromGroup(it)) counts.noFromGroup++;
        });
        var labels = { all: 'Tümü', has: 'Sahip olduğu', no: 'Sahip olmadığı',
                       fromGroup: 'Departmandan aldığı', noFromGroup: 'Kendinde var, departmanda yok' };
        quickFilterSel.querySelectorAll('option').forEach(function (opt) {
            var k = opt.value;
            if (labels[k] !== undefined) opt.textContent = labels[k] + ' (' + (counts[k] || 0) + ')';
        });
    }

    function token() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function setStatus(msg, cls) {
        statusEl.textContent = msg || '';
        statusEl.className = 'pm-status' + (cls ? ' ' + cls : '');
    }
    function escHtml(s) {
        return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    // ── Mode değişti ──────────────────────────────────────────────────
    document.querySelectorAll('input[name="permMode"]').forEach(function (r) {
        r.addEventListener('change', function () {
            if (!r.checked) return;
            state.mode = r.value;
            state.targetId = null;
            state.targetRole = null;
            state.quickFilter = 'all';
            applyFilterActiveClass();
            quickFilterSel.style.display = 'none';
            updateDeptBadge(null);
            asideEl.innerHTML = '<div class="pm-aside-empty">Yukarıdan hedef seçin.</div>';
            contentEl.innerHTML = '<div class="pm-empty"><div class="pm-empty__icon">🛡️</div><div>Soldan bir form seçin</div></div>';
            saveBtn.disabled = true;
            var groupsBtn = document.getElementById('permGroupsBtn');
            if (groupsBtn) groupsBtn.style.display = state.mode === 'group' ? 'inline-flex' : 'none';
            loadTargets();
        });
    });

    // ── Hızlı filtre combobox değişimi ───────────────────────────────
    quickFilterSel.addEventListener('change', function () {
        var f = quickFilterSel.value;
        if (!f || f === state.quickFilter) return;
        state.quickFilter = f;
        renderAside();
        if (state.selectedFormCode) {
            var grp = state.byForm[state.selectedFormCode];
            var matchCount = grp ? grp.items.filter(passesQuickFilter).length : 0;
            if (matchCount === 0) {
                var firstMatch = Object.keys(state.byForm).find(function (code) {
                    return state.byForm[code].items.some(passesQuickFilter);
                });
                if (firstMatch) { selectForm(firstMatch); return; }
            }
        }
        renderContent();
    });

    // Kullanıcı modu dışında (dept/grup) ve departmansız kullanıcıda user-only seçenekler anlamsız
    function applyFilterDisabledClass() {
        var disableUserOnly = state.mode !== 'user' || !state.targetHasDept;
        quickFilterSel.querySelectorAll('option[data-user-only]').forEach(function (opt) {
            opt.disabled = disableUserOnly;
        });
    }

    // Aktif filtreyi combobox'ta göster
    function applyFilterActiveClass() {
        quickFilterSel.value = state.quickFilter;
    }

    // ── Departman badge (topbar) ──────────────────────────────────────
    function updateDeptBadge(deptInfo) {
        if (!deptBadgeEl) return;
        if (deptInfo && deptInfo.name) {
            deptBadgeEl.textContent = deptInfo.name;
            deptBadgeEl.style.display = 'inline-flex';
        } else {
            deptBadgeEl.style.display = 'none';
        }
    }

    // ── Hedef dropdown'ı doldur ───────────────────────────────────────
    async function loadTargets() {
        targetSel.innerHTML = '<option value="">— Seçiniz —</option>';
        state.userDeptMap = {};

        // Grup modu: /Permission/Groups (aktifler seçilebilir, pasifler işaretli)
        if (state.mode === 'group') {
            try {
                var gr = await fetch('/Permission/Groups', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } });
                var gd = await gr.json();
                if (!gd.ok) throw new Error(gd.error || 'Grup listesi alınamadı.');
                state.groups = gd.groups || [];
                state.groups.forEach(function (g) {
                    var opt = document.createElement('option');
                    opt.value = g.id;
                    opt.textContent = g.name + ' (' + (g.memberCount || 0) + ' üye)' + (g.isActive ? '' : ' — pasif');
                    targetSel.appendChild(opt);
                });
                if (state.groups.length === 0)
                    setStatus('Henüz yetki grubu yok — "Grup Yönetimi" ile oluşturun.', '');
            } catch (e) {
                setStatus('Grup listesi yüklenemedi: ' + e.message, 'err');
            }
            return;
        }

        var url = state.mode === 'user' ? '/CompanyUser/UsersLookup' : '/Admin/GetDepartmentsLookup';
        try {
            var r = await fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } });
            var list = await r.json();
            (list || []).forEach(function (x) {
                var opt = document.createElement('option');
                var displayName = x.name || x.fullName || ('#' + x.id);
                opt.value = x.id; opt.textContent = x.email ? displayName + ' — ' + x.email : displayName;
                targetSel.appendChild(opt);
                // Kullanıcı modunda departman bilgisini cache'le (chip disable + topbar badge için)
                if (state.mode === 'user') {
                    state.userDeptMap[x.id] = x.departmentId
                        ? { id: x.departmentId, name: x.departmentName || null }
                        : null;
                }
            });
        } catch (e) {
            setStatus('Hedef listesi yüklenemedi: ' + e.message, 'err');
        }
    }

    targetSel.addEventListener('change', loadMatrix);

    // ── Matrix yükle ──────────────────────────────────────────────────
    async function loadMatrix() {
        var id = parseInt(targetSel.value, 10);
        if (!id) { updateDeptBadge(null); return; }
        state.targetId = id;
        setStatus('Yükleniyor...', '');

        var url = state.mode === 'user'  ? '/Permission/User/' + id
                : state.mode === 'group' ? '/Permission/Group/' + id
                :                          '/Permission/Department/' + id;
        try {
            var r = await fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } });
            if (!r.ok) throw new Error('HTTP ' + r.status);
            var data = await r.json();
            if (!data.ok) throw new Error(data.error || 'Yetki listesi alınamadı.');
            // Kullanıcı modunda hedefin rolünü kaydet — AdminOnly uyarısı için
            state.targetRole = (state.mode === 'user') ? (data.role || null) : null;
            var explicitSource = state.mode === 'user' ? 'USER' : state.mode === 'group' ? 'GROUP' : 'DEPARTMENT';
            state.items = (data.permissions || []).map(function (p) {
                var isExplicit = p.source === explicitSource;
                return {
                    permissionDefId: p.permissionDefId,
                    formCode: p.formCode,
                    actionCode: p.actionCode,
                    label: p.label,
                    source: p.source,
                    isAllowed: p.isAllowed,
                    formSortOrder: p.formSortOrder == null ? 999999 : p.formSortOrder,
                    // Bağımsız iki boolean: mirasOn (inherit mi?) + isGranted (açık izin var mı?)
                    mirasOn:   !isExplicit,
                    isGranted: isExplicit ? !!p.isAllowed : !!p.isAllowed,
                };
            });
            groupByForm();
            // Filtre combobox: hedef seçildikten sonra görünür, departmansız kullanıcıda user-only seçenekler disabled.
            quickFilterSel.style.display = 'inline-block';

            // Departman bağlantısı: kullanıcı modunda lookup'tan cache'lediğimiz departmentId'ye bak.
            // Departmansız kullanıcı için "Gruptan aldığı" ve "Grupta yok" anlamsız → disable.
            var deptInfo = state.mode === 'user' ? (state.userDeptMap[state.targetId] || null) : null;
            state.targetHasDept = state.mode === 'user'
                ? !!(deptInfo)
                : true; // departman modunda zaten hedef bir gruptur

            // Topbar departman badge'i
            updateDeptBadge(deptInfo);

            // Mode değişimi VEYA departmansız kullanıcı seçimi durumlarında user-only filtre
            // aktifse 'all'a düşür (disabled chip'in aktif kalması bug).
            if ((state.mode !== 'user' || !state.targetHasDept) &&
                (state.quickFilter === 'fromGroup' || state.quickFilter === 'noFromGroup')) {
                state.quickFilter = 'all';
            }
            applyFilterDisabledClass();
            applyFilterActiveClass();
            updateFilterCounts();
            renderAside();
            // Önceki seçimi koru; yoksa veya filtreyi geçmiyorsa ilk eşleşene geç
            var firstCode = Object.keys(state.byForm).find(function (code) {
                return state.byForm[code].items.some(passesQuickFilter);
            }) || Object.keys(state.byForm).sort()[0];
            var prevCode = state.selectedFormCode;
            var targetCode = (prevCode && state.byForm[prevCode] &&
                state.byForm[prevCode].items.some(passesQuickFilter))
                ? prevCode : firstCode;
            if (targetCode) selectForm(targetCode);
            setStatus('');
            saveBtn.disabled = false;
        } catch (e) {
            asideEl.innerHTML = '<div class="pm-aside-empty">Hata: ' + escHtml(e.message) + '</div>';
            contentEl.innerHTML = '';
            setStatus('Yükleme hatası: ' + e.message, 'err');
            saveBtn.disabled = true;
        }
    }

    // ── Form'a göre grupla ────────────────────────────────────────────
    function groupByForm() {
        state.byForm = {};
        state.items.forEach(function (it) {
            // Label format: "FormName — ActionLabel"
            var parts = (it.label || '').split(' — ');
            var formName = parts[0] || it.formCode;
            if (!state.byForm[it.formCode]) {
                state.byForm[it.formCode] = {
                    name: formName,
                    sortOrder: it.formSortOrder == null ? 999999 : it.formSortOrder,
                    items: [],
                };
            }
            state.byForm[it.formCode].items.push(it);
        });
    }

    // ── Sol pane (form listesi) ───────────────────────────────────────
    function renderAside() {
        var html = '';
        var term = (state.formSearchTerm || '').toLocaleLowerCase('tr-TR');
        var visibleCount = 0;
        Object.keys(state.byForm).sort(function (a, b) {
            // Menü sıralaması ile aynı: dbo.Forms.SortOrder ASC, eşitse FormName lokale ile alfabetik
            var aSort = state.byForm[a].sortOrder;
            var bSort = state.byForm[b].sortOrder;
            if (aSort !== bSort) return aSort - bSort;
            return state.byForm[a].name.localeCompare(state.byForm[b].name, 'tr');
        }).forEach(function (formCode) {
            var grp = state.byForm[formCode];
            if (term) {
                // İsim veya code içinde geçiyor mu
                var matchName = grp.name.toLocaleLowerCase('tr-TR').indexOf(term) !== -1;
                var matchCode = formCode.toLocaleLowerCase('tr-TR').indexOf(term) !== -1;
                if (!matchName && !matchCode) return;
            }
            // Hızlı filtre aktifken sadece eşleşen item'ı olan formlar görünür.
            var matchedItems = grp.items.filter(passesQuickFilter);
            if (state.quickFilter !== 'all' && matchedItems.length === 0) return;

            // Badge: filtre 'all' ise override sayısını, aktifse eşleşen item sayısını göster.
            var badgeCount;
            var badgeClass = 'pm-form-item__badge';
            if (state.quickFilter === 'all') {
                badgeCount = grp.items.filter(function (it) { return !it.mirasOn; }).length;
            } else {
                badgeCount = matchedItems.length;
            }
            var badge = badgeCount > 0 ? '<span class="' + badgeClass + '">' + badgeCount + '</span>' : '';
            // Operatöre admin-only form göstergeciği
            var lockIcon = '';
            if (state.mode === 'user' && state.targetRole === 'Operator'
                && OPERATOR_VISIBLE_FORM_CODES.indexOf(formCode.toUpperCase()) === -1) {
                lockIcon = '<span class="pm-form-item__lock" title="Bu form operatörlerin menüsünde görünmez">🔒</span>';
            }
            html += '<div class="pm-form-item' + (state.selectedFormCode === formCode ? ' is-active' : '') + '" data-form="' + escHtml(formCode) + '">'
                  + '<div class="pm-form-item__name">' + escHtml(grp.name) + '</div>'
                  + badge
                  + lockIcon
                  + '</div>';
            visibleCount++;
        });
        asideEl.innerHTML = html
            || '<div class="pm-aside-empty">' + (term ? 'Sonuç yok.' : 'Form yok.') + '</div>';
    }

    asideEl.addEventListener('click', function (e) {
        var item = e.target.closest && e.target.closest('.pm-form-item');
        if (!item) return;
        var code = item.getAttribute('data-form');
        if (code) selectForm(code);
    });

    function selectForm(code) {
        state.selectedFormCode = code;
        // Active class güncelle
        asideEl.querySelectorAll('.pm-form-item').forEach(function (el) {
            el.classList.toggle('is-active', el.getAttribute('data-form') === code);
        });
        renderContent();
    }

    // ── Sağ pane (seçili formun action'ları) ──────────────────────────
    function renderContent() {
        if (!state.selectedFormCode || !state.byForm[state.selectedFormCode]) {
            contentEl.innerHTML = '<div class="pm-empty" id="permEmptyState"><div class="pm-empty__icon">🛡️</div><div>Soldan bir form seçin</div></div>';
            return;
        }
        var grp = state.byForm[state.selectedFormCode];
        var term = (state.actionSearchTerm || '').toLocaleLowerCase('tr-TR');
        var filteredItems = grp.items.filter(function (it) {
            // Önce hızlı filtre (Sahip/Sahip değil/Gruptan/Grupta yok)
            if (!passesQuickFilter(it)) return false;
            // Sonra serbest arama
            if (!term) return true;
            var actionLabel = (it.label || '').split(' — ').slice(1).join(' — ') || it.actionCode;
            return actionLabel.toLocaleLowerCase('tr-TR').indexOf(term) !== -1
                || it.actionCode.toLocaleLowerCase('tr-TR').indexOf(term) !== -1;
        });

        // AdminOnly uyarısı: operatör kullanıcıya menüde hiç görünmeyecek form için
        var adminOnlyWarning = '';
        var isOperatorTarget = state.mode === 'user' && state.targetRole === 'Operator';
        var isAdminOnlyForm  = isOperatorTarget
            && OPERATOR_VISIBLE_FORM_CODES.indexOf((state.selectedFormCode || '').toUpperCase()) === -1;
        if (isAdminOnlyForm) {
            adminOnlyWarning = '<div class="pm-admin-warning">'
                + '<div class="pm-admin-warning__icon">🔒</div>'
                + '<div class="pm-admin-warning__text">'
                + '<span class="pm-admin-warning__title">Bu form operatör menüsünde görünmez</span>'
                + '<span class="pm-admin-warning__detail">'
                + 'Seçili kullanıcı <strong>Operatör</strong> rolündedir. Bu form menü ağacında yalnızca '
                + 'Yönetici (DepartmentManager veya SystemAdmin) kullanıcılara gösterilir. '
                + 'Verilen izinler DB\'ye kaydedilir ancak bu kullanıcının menüsünü etkilemez.'
                + '</span>'
                + '</div>'
                + '</div>';
        }

        var html = '<div class="pm-content__header">'
                 + '<div class="pm-content__title-block">'
                 + '<h2 class="pm-content__title">' + escHtml(grp.name) + '</h2>'
                 + '<div class="pm-content__sub">' + filteredItems.length + ' / ' + grp.items.length + ' yetki</div>'
                 + '</div>'
                 + '<div class="pm-content__search">'
                 + '<input type="text" id="permActionSearch" placeholder="Yetki ara…" value="' + escHtml(state.actionSearchTerm) + '" autocomplete="off" />'
                 + '<svg class="pm-content__search__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">'
                 + '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>'
                 + '</div>'
                 + '</div>';
        // Hiyerarşi (UI görsel ipucu — zorlama server-side'da):
        //   VIEW_OWN (Özel) → bağımsız temel izin
        // Triplet karşılıklı dışlama: her operasyon için sadece bir kapsam (Özel/Departman/Genel) aktif olabilir
        var viewItem       = grp.items.find(function (x) { return x.actionCode === 'VIEW'; });
        var viewDeptItem   = grp.items.find(function (x) { return x.actionCode === 'VIEW_DEPT'; });
        var viewOwnItem    = grp.items.find(function (x) { return x.actionCode === 'VIEW_OWN'; });
        var editOwnItem    = grp.items.find(function (x) { return x.actionCode === 'EDIT_OWN'; });
        var editDeptItem   = grp.items.find(function (x) { return x.actionCode === 'EDIT_DEPT'; });
        var editAllItem    = grp.items.find(function (x) { return x.actionCode === 'EDIT_ALL'; });
        var deleteOwnItem  = grp.items.find(function (x) { return x.actionCode === 'DELETE_OWN'; });
        var deleteDeptItem = grp.items.find(function (x) { return x.actionCode === 'DELETE_DEPT'; });
        var deleteAllItem  = grp.items.find(function (x) { return x.actionCode === 'DELETE_ALL'; });

        var viewEffectiveAllowed = computeEffective(viewItem);
        var viewDeptActive       = computeEffective(viewDeptItem);
        var viewOwnActive        = computeEffective(viewOwnItem);
        var editOwnActive        = computeEffective(editOwnItem);
        var editDeptActive       = computeEffective(editDeptItem);
        var editAllActive        = computeEffective(editAllItem);
        var deleteOwnActive      = computeEffective(deleteOwnItem);
        var deleteDeptActive     = computeEffective(deleteDeptItem);
        var deleteAllActive      = computeEffective(deleteAllItem);

        html += '<div class="pm-content__body">'
              + '<div class="pm-action-list-header">'
              + '<div class="pm-action-list-header__label">Yetki</div>'
              + '<div class="pm-action-list-header__cols">'
              + '<span>Miras</span><span>İzinli</span>'
              + '</div>'
              + '</div>'
              + '<div class="pm-action-list">';
        if (adminOnlyWarning) html += adminOnlyWarning;
        if (filteredItems.length === 0) {
            html += '<div class="pm-empty"><div>Sonuç yok.</div></div>';
        } else {
            filteredItems.forEach(function (it) {
                var actionLabel = (it.label || '').split(' — ').slice(1).join(' — ') || it.actionCode;
                var isBtn = isButtonPerm(it.actionCode);
                var anyViewActive = viewOwnActive || viewDeptActive || viewEffectiveAllowed;

                // ── Triplet karşılıklı dışlama (OWN/DEPT/ALL — biri aktifse diğerleri pasif)
                var isViewOwnExcluded  = it.actionCode === 'VIEW_OWN'    && (viewDeptActive   || viewEffectiveAllowed);
                var isViewDeptExcluded = it.actionCode === 'VIEW_DEPT'   && (viewOwnActive    || viewEffectiveAllowed);
                var isViewAllExcluded  = it.actionCode === 'VIEW'        && (viewOwnActive    || viewDeptActive);
                var isEditOwnExcluded  = it.actionCode === 'EDIT_OWN'   && (editDeptActive   || editAllActive);
                var isEditDeptExcluded = it.actionCode === 'EDIT_DEPT'  && (editOwnActive    || editAllActive);
                var isEditAllExcluded  = it.actionCode === 'EDIT_ALL'   && (editOwnActive    || editDeptActive);
                var isDelOwnExcluded   = it.actionCode === 'DELETE_OWN'  && (deleteDeptActive || deleteAllActive);
                var isDelDeptExcluded  = it.actionCode === 'DELETE_DEPT' && (deleteOwnActive  || deleteAllActive);
                var isDelAllExcluded   = it.actionCode === 'DELETE_ALL'  && (deleteOwnActive  || deleteDeptActive);

                // ── Ek kısıtlar: bağımlılık + VIEW_OWN → EDIT/DELETE_ALL engeli
                var isDependentOnViewOwn = it.actionCode === 'CREATE'
                                        || it.actionCode === 'EDIT_OWN'
                                        || it.actionCode === 'DELETE_OWN';
                var isDependentOnView = it.actionCode === 'EDIT_ALL' || it.actionCode === 'DELETE_ALL';
                var isOwnViewLimited  = (it.actionCode === 'EDIT_ALL'  && viewOwnActive)
                                     || (it.actionCode === 'DELETE_ALL' && viewOwnActive);

                var isDisabled = isViewOwnExcluded  || isViewDeptExcluded || isViewAllExcluded
                              || isEditOwnExcluded  || isEditDeptExcluded || isEditAllExcluded
                              || isDelOwnExcluded   || isDelDeptExcluded  || isDelAllExcluded
                              || isOwnViewLimited
                              || (isDependentOnViewOwn && !anyViewActive)
                              || (isDependentOnView && !viewEffectiveAllowed);

                // ── Not metni
                var noteText = '';
                if (isDisabled) {
                    if      (isViewOwnExcluded)  noteText = viewDeptActive   ? 'Departman izni aktif' : 'Genel izin aktif';
                    else if (isViewDeptExcluded) noteText = viewOwnActive    ? 'Özel izin aktif'      : 'Genel izin aktif';
                    else if (isViewAllExcluded)  noteText = viewOwnActive    ? 'Özel izin aktif'      : 'Departman izni aktif';
                    else if (isEditOwnExcluded)  noteText = editDeptActive   ? 'Departman izni aktif' : 'Genel izin aktif';
                    else if (isEditDeptExcluded) noteText = editOwnActive    ? 'Özel izin aktif'      : 'Genel izin aktif';
                    else if (isEditAllExcluded)  noteText = editOwnActive    ? 'Özel izin aktif'      : 'Departman izni aktif';
                    else if (isDelOwnExcluded)   noteText = deleteDeptActive ? 'Departman izni aktif' : 'Genel izin aktif';
                    else if (isDelDeptExcluded)  noteText = deleteOwnActive  ? 'Özel izin aktif'      : 'Genel izin aktif';
                    else if (isDelAllExcluded)   noteText = deleteOwnActive  ? 'Özel izin aktif'      : 'Departman izni aktif';
                    else if (isOwnViewLimited)   noteText = 'Özel izin aktif';
                    else if (isDependentOnViewOwn && !anyViewActive) noteText = 'İzleme gerekli';
                    else noteText = 'İzleme (Genel) gerekli';
                }
                var note = noteText ? ' <span class="pm-action-row__note">' + noteText + '</span>' : '';
                var badge = isBtn ? '<span class="pm-action-row__badge">Buton</span>' : '';
                html += '<div class="pm-action-row' + (isDisabled ? ' is-disabled' : '') + (isBtn ? ' is-btn-perm' : '') + '" data-perm-id="' + it.permissionDefId + '">'
                      + '<div class="pm-action-row__label">' + actionCodeIcon(it.actionCode) + escHtml(actionLabel) + badge + note + '</div>'
                      + '<div>' + renderPermSwitches(it) + '</div>'
                      + '</div>';
            });
        }
        html += '</div></div>';  // pm-action-list + pm-content__body
        contentEl.innerHTML = html;

        // Action search input listener — re-render sırasında DOM yenilenir,
        // her renderContent'te tekrar bind (focus korunması için)
        var actionSearchInp = document.getElementById('permActionSearch');
        if (actionSearchInp) {
            actionSearchInp.addEventListener('input', function () {
                state.actionSearchTerm = actionSearchInp.value;
                var caret = actionSearchInp.selectionStart;
                renderContent();
                // Focus geri al
                var newInp = document.getElementById('permActionSearch');
                if (newInp) {
                    newInp.focus();
                    try { newInp.setSelectionRange(caret, caret); } catch (e) {}
                }
            });
        }
    }

    function isButtonPerm(actionCode) {
        return typeof actionCode === 'string' && actionCode.indexOf('BUTTON:') === 0;
    }

    // SVG şablonları (Lucide-style, 24x24 viewBox, stroke)
    var _svgEye   = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    var _svgUser  = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';
    var _svgPlus  = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>';
    var _svgPen   = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>';
    var _svgPenAll= '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>';
    var _svgTrash = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M9 6V4h6v2"/></svg>';
    var _svgBtn   = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="8" width="16" height="8" rx="3"/><path d="M9 12h6"/></svg>';
    var _svgUsers = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>';

    function actionCodeIcon(code) {
        if (!code) return '';
        var c = code.toUpperCase();
        // VIEW_OWN: kişi ikonu (sadece kendi kayıtlarına erişim)
        if (c === 'VIEW_OWN')    return '<span class="pm-action-icon pm-ai-view-own">'  + _svgUser  + '</span>';
        // VIEW_DEPT: departman grubu ikonu (indigo)
        if (c === 'VIEW_DEPT')   return '<span class="pm-action-icon pm-ai-view-dept">' + _svgUsers + '</span>';
        // VIEW (Genel): göz ikonu (tüm kayıtlara erişim)
        if (c === 'VIEW')        return '<span class="pm-action-icon pm-ai-view">'      + _svgEye   + '</span>';
        // Yeni kayıt: artı-çember
        if (c === 'CREATE')      return '<span class="pm-action-icon pm-ai-create">'    + _svgPlus  + '</span>';
        // Düzenleme Özel: yalnız kalem (kendi kayıt)
        if (c === 'EDIT_OWN')   return '<span class="pm-action-icon pm-ai-edit-own">'   + _svgPen   + '</span>';
        // EDIT_DEPT: departman grubu + düzenleme (amber)
        if (c === 'EDIT_DEPT')   return '<span class="pm-action-icon pm-ai-edit-dept">'  + _svgUsers + '</span>';
        // Düzenleme Genel: pencil-square (tüm kayıtlar)
        if (c === 'EDIT_ALL')   return '<span class="pm-action-icon pm-ai-edit-all">'    + _svgPenAll + '</span>';
        // Silme Özel ve Genel: çöp kutusu
        if (c === 'DELETE_OWN') return '<span class="pm-action-icon pm-ai-del-own">'    + _svgTrash + '</span>';
        // DELETE_DEPT: departman grubu + silme (turuncu)
        if (c === 'DELETE_DEPT') return '<span class="pm-action-icon pm-ai-del-dept">'  + _svgUsers + '</span>';
        if (c === 'DELETE_ALL') return '<span class="pm-action-icon pm-ai-del-all">'    + _svgTrash + '</span>';
        // Buton izinleri
        if (c.indexOf('BUTTON:') === 0) return '<span class="pm-action-icon pm-ai-btn">' + _svgBtn + '</span>';
        return '';
    }

    function computeEffective(it) {
        if (!it) return false;
        if (!it.mirasOn) return !!it.isGranted;
        return !!it.isAllowed; // inherit: backend'den gelen değer
    }

    // Ortak iki-switch render: Miras toggle + Ver toggle
    // isInherit: Miras switch açık mı; isAllow: Ver switch açık mı; src: kaynak etiketi
    function renderDualSwitch(isInherit, isAllow, src) {
        var mirasCls  = 'pm-switch' + (isInherit ? ' is-on' : '') + ' pm-sw-miras';
        var verCls    = 'pm-switch' + (isAllow   ? ' is-on' : '') + ' pm-sw-ver';
        var verWrapCls = 'pm-perm-sw-wrap';
        var srcHtml = '';
        // Departman kaynağı varsa Miras label yanında inline rozet — hizalamayı bozmaz
        var deptBadge = (isInherit && src === 'DEPT') ? '<span class="pm-dept-badge">Dep</span>' : '';
        return '<div class="pm-perm-switches">'
            + '<div class="pm-perm-sw-pair">'
            + '<div class="pm-perm-sw-wrap">'
            + deptBadge
            + '<label class="' + mirasCls + '"><span class="pm-switch__track"><span class="pm-switch__thumb"></span></span></label>'
            + '</div>'
            + '<div class="' + verWrapCls + '">'
            + '<label class="' + verCls + '"><span class="pm-switch__track"><span class="pm-switch__thumb"></span></span></label>'
            + '</div>'
            + '</div>'
            + srcHtml
            + '</div>';
    }

    function renderPermSwitches(it) {
        var src = null;
        if (it.mirasOn) {
            if (it.source === 'USER')            src = 'USER';
            else if (it.source === 'DEPARTMENT') src = 'DEPT';
            else                                 src = 'Varsayılan';
        }
        return renderDualSwitch(it.mirasOn, it.isGranted, src);
    }

    // ── Switch click — delegated (Miras + Ver) ───────────────────────
    contentEl.addEventListener('click', function (e) {
        var sw = e.target.closest && e.target.closest('.pm-switch');
        if (!sw) return;

        // ── Tekil satır switch ───────────────────────────────────────
        var isMiras = sw.classList.contains('pm-sw-miras');
        var isVer   = sw.classList.contains('pm-sw-ver');
        if (!isMiras && !isVer) return;

        var row = sw.closest('.pm-action-row');
        if (!row || row.classList.contains('is-disabled')) return;

        var id = parseInt(row.getAttribute('data-perm-id'), 10);
        var item = state.items.find(function (x) { return x.permissionDefId === id; });
        if (!item) return;

        if (isMiras) {
            // Miras toggle — sadece mirasOn'u değiştirir, isGranted'a dokunmaz
            item.mirasOn = !item.mirasOn;
        } else {
            // İzinli toggle — sadece isGranted'ı değiştirir, mirasOn'a dokunmaz
            item.isGranted = !item.isGranted;
        }

        // Triplet üyelerinden biri değişince tüm karşılıklı dışlama yeniden hesaplanmalı
        var isTripletMember = item.actionCode === 'VIEW'       || item.actionCode === 'VIEW_DEPT'   || item.actionCode === 'VIEW_OWN'
                           || item.actionCode === 'EDIT_OWN'  || item.actionCode === 'EDIT_DEPT'   || item.actionCode === 'EDIT_ALL'
                           || item.actionCode === 'DELETE_OWN'|| item.actionCode === 'DELETE_DEPT' || item.actionCode === 'DELETE_ALL';
        if (isTripletMember) {
            renderContent();
        } else {
            row.children[1].innerHTML = renderPermSwitches(item);
        }
        updateFilterCounts(); renderAside();
    });

    // ── Kaydet ────────────────────────────────────────────────────────
    async function save() {
        if (!state.targetId) return;
        var items = state.items
            .filter(function (it) {
                // Miras=OFF → her zaman kaydet (explicit state)
                if (!it.mirasOn) return true;
                // Miras=ON → yalnızca İzinli başlangıçtaki inherited değerden farklıysa kaydet
                return it.isGranted !== !!it.isAllowed;
            })
            .map(function (it) {
                return { permissionDefId: it.permissionDefId, isGranted: it.isGranted };
            });

        var url = state.mode === 'user'  ? '/Permission/User/' + state.targetId + '/Save'
                : state.mode === 'group' ? '/Permission/Group/' + state.targetId + '/Save'
                :                          '/Permission/Department/' + state.targetId + '/Save';

        saveBtn.disabled = true;
        setStatus('Kaydediliyor...', '');
        try {
            var r = await fetch(url, {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({
                    userId: state.mode === 'user' ? state.targetId : null,
                    departmentId: state.mode === 'dept' ? state.targetId : null,
                    items: items,
                }),
            });
            var data = await r.json();
            if (!data.ok) throw new Error(data.error || 'Kaydedilemedi.');
            setStatus('Kaydedildi: ' + (data.count || 0) + ' satır.', 'ok');
            // Yetki değişikliğini tüm açık sekmelere bildir — Shell menüyü throttle'sız yeniler
            try { var _bc = new BroadcastChannel('calibra-menu-refresh'); _bc.postMessage(1); _bc.close(); } catch(e) {}
            // Reload yerine state'i yerinde güncelle — mirasOn'a dokunmadan isAllowed'ı senkronla
            // (loadMatrix() mirasOn = !isExplicit yapacağından Miras kapanırdı)
            var savedMap = {};
            items.forEach(function(it) { savedMap[it.permissionDefId] = it.isGranted; });
            state.items.forEach(function(it) {
                if (it.permissionDefId in savedMap) {
                    it.isAllowed = savedMap[it.permissionDefId]; // effective değeri güncelle
                }
            });
            updateFilterCounts(); renderAside(); renderContent();
        } catch (e) {
            setStatus('Hata: ' + e.message, 'err');
        } finally {
            saveBtn.disabled = false;
        }
    }

    saveBtn.addEventListener('click', save);

    // Form arama input listener
    var formSearchInp = document.getElementById('permFormSearch');
    if (formSearchInp) {
        formSearchInp.addEventListener('input', function () {
            state.formSearchTerm = formSearchInp.value;
            renderAside();
        });
    }

    // ── Grup Yönetimi modali (2026-07-06) ────────────────────────────
    (function initGroupManager() {
        var backdrop = document.getElementById('pmgBackdrop');
        var bodyEl = document.getElementById('pmgBody');
        var titleEl = document.getElementById('pmgTitle');
        var backBtn = document.getElementById('pmgBackBtn');
        var saveMembersBtn = document.getElementById('pmgSaveMembersBtn');
        if (!backdrop) return;

        var view = 'list';           // 'list' | 'members'
        var memberGroup = null;      // { id, name }
        var allUsers = [];           // UsersLookup cache
        var memberIds = {};          // { userId: true }
        var memberSearch = '';

        function openModal() { backdrop.classList.add('open'); renderList(); }
        function closeModal() { backdrop.classList.remove('open'); view = 'list'; }

        document.getElementById('permGroupsBtn').addEventListener('click', openModal);
        document.getElementById('pmgCloseBtn').addEventListener('click', closeModal);
        backdrop.addEventListener('click', function (e) { if (e.target === backdrop) closeModal(); });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && backdrop.classList.contains('open')) closeModal();
        });

        async function fetchGroups() {
            var r = await fetch('/Permission/Groups', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } });
            var d = await r.json();
            if (!d.ok) throw new Error(d.error || 'Grup listesi alınamadı.');
            state.groups = d.groups || [];
            return state.groups;
        }

        async function postJson(url, payload) {
            var r = await fetch(url, {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify(payload),
            });
            var d = await r.json();
            if (!d.ok) throw new Error(d.error || 'İşlem başarısız.');
            return d;
        }

        async function renderList() {
            view = 'list';
            titleEl.textContent = 'Yetki Grupları';
            backBtn.style.display = 'none';
            saveMembersBtn.style.display = 'none';
            bodyEl.innerHTML = '<div style="color:#64748b;font-size:.8rem;padding:12px">Yükleniyor…</div>';
            var groups;
            try { groups = await fetchGroups(); }
            catch (e) { bodyEl.innerHTML = '<div style="color:#ef4444;font-size:.8rem;padding:12px">' + escHtml(e.message) + '</div>'; return; }

            var html = '<div class="pmg-new">'
                + '<input type="text" id="pmgNewName" placeholder="Yeni grup adı (örn. Satış Ekibi)" />'
                + '<input type="text" id="pmgNewDesc" placeholder="Açıklama (opsiyonel)" />'
                + '<button type="button" class="pm-btn pm-btn--primary" id="pmgAddBtn">Ekle</button>'
                + '</div>';
            if (groups.length === 0) {
                html += '<div style="color:#64748b;font-size:.8rem;padding:8px 2px">Henüz grup yok. Yukarıdan ilk grubu oluşturun; ardından ana ekranda Grup modunda izinlerini işaretleyin.</div>';
            }
            groups.forEach(function (g) {
                html += '<div class="pmg-row' + (g.isActive ? '' : ' pmg-row--inactive') + '" data-gid="' + g.id + '">'
                    + '<div class="pmg-row-main">'
                    +   '<div class="pmg-row-name">' + escHtml(g.name) + '</div>'
                    +   (g.description ? '<div class="pmg-row-desc">' + escHtml(g.description) + '</div>' : '')
                    + '</div>'
                    + '<span class="pmg-count">' + (g.memberCount || 0) + ' üye</span>'
                    + '<button type="button" class="pm-btn pm-btn--ghost" data-members="' + g.id + '" data-name="' + escHtml(g.name) + '">Üyeler</button>'
                    + '<label class="pmg-switch" title="' + (g.isActive ? 'Aktif' : 'Pasif') + '">'
                    +   '<input type="checkbox" data-toggle="' + g.id + '"' + (g.isActive ? ' checked' : '') + ' />'
                    +   '<span class="tr"></span>'
                    + '</label>'
                    + '</div>';
            });
            bodyEl.innerHTML = html;

            document.getElementById('pmgAddBtn').addEventListener('click', async function () {
                var name = (document.getElementById('pmgNewName').value || '').trim();
                var desc = (document.getElementById('pmgNewDesc').value || '').trim();
                if (!name) { setStatus('Grup adı boş olamaz.', 'err'); return; }
                try {
                    await postJson('/Permission/Groups/Save', { id: null, name: name, description: desc || null, isActive: true });
                    setStatus('Grup oluşturuldu: ' + name, 'ok');
                    renderList();
                    if (state.mode === 'group') loadTargets();
                } catch (e) { setStatus('Hata: ' + e.message, 'err'); }
            });

            bodyEl.querySelectorAll('input[data-toggle]').forEach(function (sw) {
                sw.addEventListener('change', async function () {
                    var gid = parseInt(sw.getAttribute('data-toggle'), 10);
                    var g = (state.groups || []).find(function (x) { return x.id === gid; });
                    if (!g) return;
                    try {
                        await postJson('/Permission/Groups/Save', { id: gid, name: g.name, description: g.description, isActive: sw.checked });
                        setStatus(sw.checked ? 'Grup aktifleştirildi.' : 'Grup pasifleştirildi — izinleri çözümlemeye girmez.', 'ok');
                        renderList();
                        if (state.mode === 'group') loadTargets();
                    } catch (e) { setStatus('Hata: ' + e.message, 'err'); sw.checked = !sw.checked; }
                });
            });

            bodyEl.querySelectorAll('button[data-members]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    renderMembers(parseInt(btn.getAttribute('data-members'), 10), btn.getAttribute('data-name'));
                });
            });
        }

        async function renderMembers(groupId, groupName) {
            view = 'members';
            memberGroup = { id: groupId, name: groupName };
            memberSearch = '';
            titleEl.textContent = 'Üyeler — ' + groupName;
            backBtn.style.display = 'inline-flex';
            saveMembersBtn.style.display = 'inline-flex';
            bodyEl.innerHTML = '<div style="color:#64748b;font-size:.8rem;padding:12px">Yükleniyor…</div>';
            try {
                // Kullanıcı listesi (bir kez) + mevcut üyeler
                if (allUsers.length === 0) {
                    var ur = await fetch('/CompanyUser/UsersLookup', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } });
                    allUsers = (await ur.json()) || [];
                }
                var mr = await fetch('/Permission/Group/' + groupId + '/Members', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } });
                var md = await mr.json();
                if (!md.ok) throw new Error(md.error || 'Üyeler alınamadı.');
                memberIds = {};
                (md.members || []).forEach(function (m) { memberIds[m.userId] = true; });
                drawMemberList();
            } catch (e) {
                bodyEl.innerHTML = '<div style="color:#ef4444;font-size:.8rem;padding:12px">' + escHtml(e.message) + '</div>';
            }
        }

        function drawMemberList() {
            var q = memberSearch.toLocaleLowerCase('tr-TR');
            var html = '<input type="text" class="pmg-new-input pmg-member-search" id="pmgMemberSearch" placeholder="Kullanıcı ara…" value="' + escHtml(memberSearch) + '" style="padding:7px 10px;border-radius:8px;font-size:.82rem;border:1px solid var(--app-border,#cbd5e1);background:transparent;color:inherit" />'
                + '<div class="pmg-member-list">';
            allUsers.forEach(function (u) {
                var nm = u.name || u.fullName || ('#' + u.id);
                if (q && (nm + ' ' + (u.email || '')).toLocaleLowerCase('tr-TR').indexOf(q) === -1) return;
                html += '<label class="pmg-member">'
                    + '<input type="checkbox" data-uid="' + u.id + '"' + (memberIds[u.id] ? ' checked' : '') + ' />'
                    + '<span>' + escHtml(nm) + '</span>'
                    + (u.email ? '<span class="pmg-member-mail">' + escHtml(u.email) + '</span>' : '')
                    + '</label>';
            });
            html += '</div>';
            bodyEl.innerHTML = html;

            var si = document.getElementById('pmgMemberSearch');
            si.addEventListener('input', function () {
                memberSearch = si.value;
                var pos = si.selectionStart;
                drawMemberList();
                var si2 = document.getElementById('pmgMemberSearch');
                si2.focus(); try { si2.setSelectionRange(pos, pos); } catch (e) { /* ignore */ }
            });
            bodyEl.querySelectorAll('input[data-uid]').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var uid = parseInt(cb.getAttribute('data-uid'), 10);
                    if (cb.checked) memberIds[uid] = true; else delete memberIds[uid];
                });
            });
        }

        backBtn.addEventListener('click', renderList);

        saveMembersBtn.addEventListener('click', async function () {
            if (!memberGroup) return;
            var ids = Object.keys(memberIds).map(function (k) { return parseInt(k, 10); });
            try {
                await postJson('/Permission/Group/' + memberGroup.id + '/Members/Save', { userIds: ids });
                setStatus('Üyeler kaydedildi: ' + ids.length + ' kullanıcı.', 'ok');
                try { var _bc2 = new BroadcastChannel('calibra-menu-refresh'); _bc2.postMessage(1); _bc2.close(); } catch (e) { /* ignore */ }
                renderList();
                if (state.mode === 'group') loadTargets();
            } catch (e) { setStatus('Hata: ' + e.message, 'err'); }
        });
    })();

    loadTargets();
})();
</script>
}

<div class="pmg-backdrop" id="pmgBackdrop">
    <div class="pmg-modal">
        <div class="pmg-head">
            <button type="button" class="pm-btn pm-btn--ghost" id="pmgBackBtn" style="display:none;">← Gruplar</button>
            <div class="pmg-title" id="pmgTitle">Yetki Grupları</div>
            <button type="button" class="pmg-close" id="pmgCloseBtn" aria-label="Kapat">✕</button>
        </div>
        <div class="pmg-body" id="pmgBody"></div>
        <div class="pmg-foot">
            <button type="button" class="pm-btn pm-btn--primary" id="pmgSaveMembersBtn" style="display:none;">Üyeleri Kaydet</button>
        </div>
    </div>
</div>
