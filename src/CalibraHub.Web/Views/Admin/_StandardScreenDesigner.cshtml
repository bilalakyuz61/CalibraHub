@model CalibraHub.Web.Models.Admin.StandardScreenDesignViewModel

<section class="integrator-dashboard__group">
    <article class="integrator-card integrator-card--form entity-form-card" data-standard-screen-designer>
        <form method="post" asp-action="SaveScreenLayout" class="integrator-form" id="standardScreenDesignForm" autocomplete="off"
              data-collaboration-record-type="ADMIN_SCREEN_LAYOUT"
              data-collaboration-record-title="Ekran Düzeni">
            @Html.AntiForgeryToken()
            <input asp-for="ScreenCode" type="hidden" />
            <input asp-for="ScreenLabel" type="hidden" />

            <section class="integrator-form-section">
                <h3 class="material-form-card__title">Sekmeler</h3>
                <div class="integrator-table-wrap">
                    <table class="table integrator-table integrator-table--compact layout-designer-table">
                        <thead>
                        <tr>
                            <th>Teknik Ad</th>
                            <th>Baslik</th>
                            <th>Sira</th>
                            <th>Aktif</th>
                            <th class="text-end"></th>
                        </tr>
                        </thead>
                        <tbody data-layout-tabs-rows>
                        @for (var i = 0; i < Model.Tabs.Count; i++)
                        {
                            <tr data-layout-tab-row>
                                <td><input asp-for="Tabs[i].TabKey" class="form-control" data-tab-key-input /></td>
                                <td><input asp-for="Tabs[i].TabLabel" class="form-control" data-tab-label-input /></td>
                                <td><input asp-for="Tabs[i].DisplayOrder" class="form-control" type="number" min="0" /></td>
                                <td class="text-center"><input asp-for="Tabs[i].IsActive" class="form-check-input" /></td>
                                <td class="text-end"><button type="button" class="btn btn-outline-danger integrator-btn-tertiary" data-remove-layout-tab>Sil</button></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="integrator-form-section">
                <h3 class="material-form-card__title">Alan Yerlesimi</h3>
                <div class="integrator-table-wrap">
                    <table class="table integrator-table integrator-table--compact layout-designer-table">
                        <thead>
                        <tr>
                            <th>Alan</th>
                            <th>Sekme</th>
                            <th>Sira</th>
                            <th>Kolon</th>
                            <th>Gorunur</th>
                            <th>Zorunlu</th>
                        </tr>
                        </thead>
                        <tbody data-layout-items-rows>
                        @for (var i = 0; i < Model.Items.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input asp-for="Items[i].ItemKey" type="hidden" />
                                    <input asp-for="Items[i].ItemLabel" type="hidden" />
                                    <div class="layout-designer-table__label">@Model.Items[i].ItemLabel</div>
                                    <div class="integrator-table__subtext">@Model.Items[i].ItemKey</div>
                                </td>
                                <td>
                                    <select asp-for="Items[i].TabKey" class="form-select" data-item-tab-select>
                                        @foreach (var tab in Model.Tabs)
                                        {
                                            <option value="@tab.TabKey" selected="@(string.Equals(tab.TabKey, Model.Items[i].TabKey, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                                                @tab.TabLabel
                                            </option>
                                        }
                                    </select>
                                </td>
                                <td><input asp-for="Items[i].DisplayOrder" class="form-control" type="number" min="0" /></td>
                                <td><input asp-for="Items[i].ColumnSpan" class="form-control" type="number" min="1" max="3" /></td>
                                <td class="text-center"><input asp-for="Items[i].IsVisible" class="form-check-input" /></td>
                                <td class="text-center"><input asp-for="Items[i].IsRequired" class="form-check-input" /></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </section>
        </form>
    </article>
</section>
