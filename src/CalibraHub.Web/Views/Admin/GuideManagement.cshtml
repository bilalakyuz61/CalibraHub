        border-bottom: 1px solid rgba(255,255,255,.06);
        position: sticky; top: 0; z-index: 1;
    }
    .gm-mapping-fh { font-size: .7rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: .04em; }
    .gm-mapping-fh--key { width: 180px; flex-shrink: 0; }
    .gm-mapping-fh--label { width: 160px; flex-shrink: 0; }
    .gm-mapping-fh--guide { flex: 1; }
    .gm-mapping-fh--toggle { width: 56px; text-align: center; flex-shrink: 0; }
    .gm-mapping-fh--actions { width: 36px; flex-shrink: 0; }

    /* Alan satiri */
    .gm-mapping-field-row {
        border-bottom: 1px solid rgba(255,255,255,.04);
        transition: background .12s;
    }
    .gm-mapping-field-row:hover { background: rgba(255,255,255,.03); }
    .gm-mapping-field-row--mapped { background: rgba(6,182,212,.06); }
    .gm-mapping-field-row--mapped:hover { background: rgba(6,182,212,.1); }

    .gm-mapping-field-main {
        display: flex; align-items: center; gap: 8px; padding: 8px 16px;
    }
    .gm-mapping-field-key {
        width: 180px; flex-shrink: 0; font-family: monospace;
        font-size: .8rem; color: #a5b4fc; font-weight: 600;
    }
    .gm-mapping-field-label { width: 160px; flex-shrink: 0; font-size: .82rem; color: #e2e8f0; }
    .gm-mapping-field-guide { flex: 1; font-size: .78rem; color: #64748b; font-family: monospace; }
    .gm-mapping-field-guide--other { color: #fbbf24; }

    /* Toggle switch */
    .gm-mapping-toggle {
        position: relative; display: inline-block; width: 38px; height: 20px; flex-shrink: 0;
    }
    .gm-mapping-toggle input { opacity: 0; width: 0; height: 0; }
    .gm-mapping-toggle-slider {
        position: absolute; inset: 0; cursor: pointer;
        background: rgba(255,255,255,.12); border-radius: 20px;
        transition: background .2s;
    }
    .gm-mapping-toggle-slider::before {
        content: ''; position: absolute;
        width: 16px; height: 16px; left: 2px; top: 2px;
        background: #94a3b8; border-radius: 50%;
        transition: transform .2s, background .2s;
    }
    .gm-mapping-toggle input:checked + .gm-mapping-toggle-slider {
        background: rgba(6,182,212,.5);
    }
    .gm-mapping-toggle input:checked + .gm-mapping-toggle-slider::before {
        transform: translateX(18px); background: #67e8f9;
    }
    .gm-mapping-toggle input:disabled + .gm-mapping-toggle-slider {
        opacity: .4; cursor: not-allowed;
    }

    /* Kisit alani (ConstraintBuilder wrapper) */
    .gm-mapping-field-filter {
        padding: 4px 16px 10px 16px;
    }

    /* Zorunlu alan satiri */
    .gm-mapping-required-row {
