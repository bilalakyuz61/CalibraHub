@{
    ViewData["Title"] = "Rehber Merkezi";
    ViewData["BodyClass"] = "page-admin-guide-management";
}

@section Styles {
<link rel="stylesheet" href="/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)" />
<style>
    .page-admin-guide-management .integrator-dashboard__content {
        display: flex !important;
        flex-direction: column;
        width: 100% !important;
        max-width: none !important;
        min-height: 0;
        padding: 0;
        margin: 0 !important;
        overflow: hidden;
    }
    .guide-mgmt-mount {
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        min-height: 0;
        overflow: auto;
        padding: 24px;
    }

    /* ═══ Shared gm-* card styles ═══ */
    .gm-root { display: flex; flex-direction: column; gap: 18px; width: 100%; }

    /* Topbar */
    .gm-topbar { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .gm-topbar-left { display: flex; align-items: center; gap: 14px; }
    .gm-topbar-right { display: flex; align-items: center; gap: 8px; }
    .gm-topbar-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(251,191,36,.15); color: #fbbf24; flex-shrink: 0;
    }
    .gm-topbar-icon--indigo { background: rgba(99,102,241,.15); color: #a5b4fc; }
    .gm-title { font-size: 1.2rem; font-weight: 700; color: #f1f5f9; margin: 0; }
    .gm-subtitle { font-size: .78rem; color: #94a3b8; margin: 3px 0 0; }

    /* Buttons */
    .gm-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 8px; font-size: .84rem; font-weight: 600;
        border: none; cursor: pointer; transition: all .15s;
    }
    .gm-btn:disabled { opacity: .5; cursor: default; }
    .gm-btn--primary { background: linear-gradient(135deg,#f59e0b,#d97706); color: #fff; box-shadow: 0 2px 8px rgba(245,158,11,.3); }
    .gm-btn--primary:hover:not(:disabled) { background: linear-gradient(135deg,#fbbf24,#f59e0b); }
    .gm-btn--indigo { background: linear-gradient(135deg,#6366f1,#4f46e5); color: #fff; box-shadow: 0 2px 8px rgba(99,102,241,.3); }
    .gm-btn--indigo:hover:not(:disabled) { background: linear-gradient(135deg,#818cf8,#6366f1); }
    .gm-btn--ghost { background: rgba(255,255,255,.07); color: #f1f5f9; border: 1px solid rgba(255,255,255,.1); padding: 8px 10px; }
    .gm-btn--ghost:hover:not(:disabled) { background: rgba(255,255,255,.12); }
    .gm-btn--danger { background: linear-gradient(135deg,#ef4444,#dc2626); color: #fff; }
    .gm-btn--danger:hover:not(:disabled) { background: linear-gradient(135deg,#f87171,#ef4444); }

    /* Alert */
    .gm-alert {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 14px; background: rgba(239,68,68,.15);
        border: 1px solid rgba(239,68,68,.3); border-radius: 8px;
        color: #fca5a5; font-size: .84rem;
    }
    .gm-alert button { margin-left: auto; background: none; border: none; color: #fca5a5; cursor: pointer; font-size: 1.1rem; padding: 0 4px; }

    /* Search */
    .gm-search-wrap { position: relative; display: flex; align-items: center; }
    .gm-search-ico { position: absolute; left: 11px; color: #94a3b8; pointer-events: none; }
    .gm-search {
        width: 100%; max-width: 380px; padding: 8px 12px 8px 34px;
        background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
        border-radius: 8px; color: #f1f5f9; font-size: .84rem;
        outline: none; transition: border-color .15s;
    }
    .gm-search:focus { border-color: rgba(251,191,36,.45); }
    .gm-search-clear { position: absolute; right: 8px; background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 1.1rem; padding: 2px 6px; }

    /* States */
    .gm-center { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 60px; color: #94a3b8; }
    .gm-empty { display: flex; flex-direction: column; align-items: center; gap: 14px; padding: 72px 24px; text-align: center; color: #94a3b8; }
    .gm-empty svg { opacity: .3; }
    .gm-empty p { margin: 0; font-size: .9rem; }
    .gm-spin { animation: gm-spin .8s linear infinite; }
    @@keyframes gm-spin { to { transform: rotate(360deg); } }

    /* Card grid — yatay strip layout */
    .gm-grid {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    /* Card — dar şerit (strip) */
    .gm-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.09);
        border-radius: 10px;
        padding: 8px 14px;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 14px;
        transition: border-color .15s, box-shadow .15s;
    }
    .gm-card:hover {
        border-color: rgba(251,191,36,.3);
        background: rgba(255,255,255,.06);
    }
    .gm-card--inactive { opacity: .6; }

    /* Card header */
    .gm-card-header { display: flex; align-items: center; gap: 10px; flex: 0 0 280px; min-width: 0; }
    .gm-card-icon {
        width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: rgba(251,191,36,.12); color: #fbbf24;
    }
    .gm-card-icon--indigo { background: rgba(99,102,241,.12); color: #a5b4fc; }
    .gm-card-title-wrap { flex: 1; min-width: 0; }
    .gm-card-name { font-weight: 700; font-size: .92rem; color: #f1f5f9; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .gm-card-code { font-size: .72rem; color: #94a3b8; font-family: monospace; margin-top: 2px; }
    .gm-card-status { margin-left: auto; flex-shrink: 0; }

    /* Card meta — yatay yerleşim */
    .gm-card-meta { display: flex; flex-direction: row; align-items: center; gap: 16px; flex: 1; min-width: 0; }
    .gm-card-row { display: flex; align-items: center; gap: 5px; flex-wrap: nowrap; min-width: 0; }
    .gm-card-row-ico { color: #94a3b8; flex-shrink: 0; }
    .gm-card-sep { color: #94a3b8; font-size: .78rem; }

    /* Badges */
    .gm-badge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 2px 7px; border-radius: 5px;
        font-size: .72rem; font-weight: 500; font-family: monospace;
    }
    .gm-badge--view   { background: rgba(99,102,241,.15); color: #a5b4fc; border: 1px solid rgba(99,102,241,.25); }
    .gm-badge--col    { background: rgba(16,185,129,.12); color: #6ee7b7; border: 1px solid rgba(16,185,129,.2); }
    .gm-badge--count  { background: rgba(251,191,36,.1);  color: #fbbf24; border: 1px solid rgba(251,191,36,.2); }
    .gm-badge--module { background: rgba(168,85,247,.12); color: #c4b5fd; border: 1px solid rgba(168,85,247,.22); font-family: inherit; }

    /* Status chips */
    .gm-status { display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px; border-radius: 20px; font-size: .7rem; font-weight: 600; }
    .gm-status--on  { background: rgba(16,185,129,.15); color: #6ee7b7; border: 1px solid rgba(16,185,129,.25); }
    .gm-status--off { background: rgba(100,116,139,.15); color: #94a3b8; border: 1px solid rgba(100,116,139,.25); }

    /* Card actions */
    .gm-card-actions { display: flex; gap: 6px; margin-left: auto; flex-shrink: 0; }
    .gm-action-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 6px 12px; border-radius: 7px; font-size: .78rem; font-weight: 600;
        border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.05);
        color: #94a3b8; cursor: pointer; transition: all .12s;
    }
    .gm-action-btn--edit:hover  { background: rgba(99,102,241,.18); border-color: rgba(99,102,241,.4); color: #a5b4fc; }
    .gm-action-btn--try:hover  { background: rgba(16,185,129,.18); border-color: rgba(16,185,129,.4); color: #6ee7b7; }
    .gm-action-btn--delete { padding: 6px 10px; margin-left: auto; }
    .gm-action-btn--delete:hover { background: rgba(239,68,68,.18); border-color: rgba(239,68,68,.4); color: #fca5a5; }

    /* Footer */
    .gm-footer { font-size: .75rem; color: #94a3b8; padding: 2px 0; }

    /* Confirm dialog */
    .gm-backdrop { position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,.55); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; padding: 20px; }
    .gm-confirm { background: #1e293b; border: 1px solid rgba(255,255,255,.12); border-radius: 16px; padding: 32px 28px; max-width: 380px; width: 90vw; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 12px; box-shadow: 0 24px 64px rgba(0,0,0,.5); }
    .gm-confirm-ico { color: #ef4444; }
    .gm-confirm-title { font-size: 1.05rem; font-weight: 700; color: #f1f5f9; margin: 0; }
    .gm-confirm-text { font-size: .84rem; color: #94a3b8; margin: 0; }
    .gm-confirm-btns { display: flex; gap: 10px; margin-top: 8px; }

    /* ═══ GuideDefinitionModal stilleri ═══ */
    .guide-modal-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,.6); backdrop-filter: blur(5px);
        display: flex; align-items: center; justify-content: center; padding: 20px;
    }
    .guide-modal {
        background: #1e293b; border: 1px solid rgba(255,255,255,.13);
        border-radius: 16px; box-shadow: 0 24px 72px rgba(0,0,0,.6);
        width: min(620px,96vw); max-height: 90vh; display: flex; flex-direction: column; overflow: hidden;
        color: #f1f5f9;
    }
    .guide-modal-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid rgba(255,255,255,.1); flex-shrink: 0; background: rgba(0,0,0,.15); }
    .guide-modal-title-row { display: flex; align-items: center; gap: 10px; }
    .guide-modal-icon { color: #fbbf24; }
    .guide-modal-title { font-size: 1rem; font-weight: 700; color: #f1f5f9; margin: 0; }
    .guide-modal-close { background: none; border: none; color: #94a3b8; cursor: pointer; padding: 6px; border-radius: 6px; transition: background .12s,color .12s; display: flex; align-items: center; line-height: 1; }
    .guide-modal-close:hover:not(:disabled) { background: rgba(255,255,255,.1); color: #f1f5f9; }
    .guide-modal-body { padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; flex: 1; background: #1e293b; }
    .guide-modal-error { display: flex; align-items: center; gap: 8px; padding: 10px 12px; background: rgba(239,68,68,.18); border: 1px solid rgba(239,68,68,.35); border-radius: 8px; color: #fca5a5; font-size: .82rem; }
    .guide-modal-field { display: flex; flex-direction: column; gap: 6px; }
    .guide-modal-field--half { flex: 1 1 45%; }
    .guide-modal-cols-section { display: flex; flex-wrap: wrap; gap: 12px; }
    .guide-modal-label { display: flex; align-items: center; gap: 5px; font-size: .75rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: .05em; }
    .guide-modal-input, .guide-modal-select {
        padding: 9px 12px; background: rgba(15,23,42,.6); border: 1px solid rgba(255,255,255,.15);
        border-radius: 8px; color: #f1f5f9; font-size: .85rem; outline: none; transition: border-color .15s;
        width: 100%; box-sizing: border-box; -webkit-appearance: none; appearance: none;
    }
    .guide-modal-input:focus, .guide-modal-select:focus { border-color: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,.15); }
    .guide-modal-input::placeholder { color: #64748b; }
    .guide-modal-select option { background: #1e293b; color: #f1f5f9; }
    .guide-modal-hint { font-size: .78rem; color: #64748b; }
    .guide-modal-hint--warn { color: #fca5a5; }
    .guide-modal-loading { display: flex; align-items: center; gap: 8px; color: #94a3b8; font-size: .84rem; padding: 12px 0; }
    .guide-modal-checkboxes { display: flex; flex-wrap: wrap; gap: 8px; padding: 10px; background: rgba(15,23,42,.5); border: 1px solid rgba(255,255,255,.1); border-radius: 8px; max-height: 160px; overflow-y: auto; }
    .guide-modal-checkbox-item { display: inline-flex; align-items: center; gap: 6px; padding: 5px 10px; border-radius: 6px; border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.05); cursor: pointer; font-size: .78rem; color: #94a3b8; transition: background .12s,border-color .12s,color .12s; user-select: none; }
    .guide-modal-checkbox-item input[type="checkbox"] { display: none; }
    .guide-modal-checkbox-item--checked { background: rgba(251,191,36,.14); border-color: rgba(251,191,36,.4); color: #fbbf24; }
    .guide-modal-checkbox-indicator { display: inline-flex; align-items: center; justify-content: center; width: 15px; height: 15px; border-radius: 3px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.18); flex-shrink: 0; }
    .guide-modal-checkbox-item--checked .guide-modal-checkbox-indicator { background: #f59e0b; border-color: #f59e0b; color: #fff; }
    .guide-modal-checkbox-label { font-family: monospace; }
    .guide-modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 14px 20px; border-top: 1px solid rgba(255,255,255,.1); flex-shrink: 0; background: rgba(0,0,0,.2); }
    .guide-modal-btn { display: inline-flex; align-items: center; gap: 6px; padding: 9px 18px; border-radius: 8px; font-size: .84rem; font-weight: 600; border: none; cursor: pointer; transition: all .15s; }
    .guide-modal-btn:disabled { opacity: .55; cursor: default; }
    .guide-modal-btn--save { background: linear-gradient(135deg,#f59e0b,#d97706); color: #fff; box-shadow: 0 2px 8px rgba(245,158,11,.35); }
    .guide-modal-btn--save:hover:not(:disabled) { background: linear-gradient(135deg,#fbbf24,#f59e0b); }
    .guide-modal-btn--cancel { background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.14); color: #e2e8f0; }
    .guide-modal-btn--cancel:hover:not(:disabled) { background: rgba(255,255,255,.13); }

    /* ═══ Light mode overrides ═══ */
    body.app-theme-light .gm-title { color: #0f172a; }
    body.app-theme-light .gm-subtitle { color: #64748b; }
    body.app-theme-light .gm-center,
    body.app-theme-light .gm-empty { color: #64748b; }
    body.app-theme-light .gm-footer { color: #64748b; }
    body.app-theme-light .gm-search-ico { color: #94a3b8; }
    body.app-theme-light .gm-search-clear { color: #94a3b8; }
    body.app-theme-light .gm-card-row-ico { color: #94a3b8; }
    body.app-theme-light .gm-card-sep { color: #94a3b8; }

    body.app-theme-light .gm-btn--ghost {
        background: #f1f5f9; border: 1px solid #e2e8f0; color: #374151;
    }
    body.app-theme-light .gm-btn--ghost:hover:not(:disabled) { background: #e2e8f0; }

    body.app-theme-light .gm-search {
        background: #ffffff; border-color: #e2e8f0; color: #0f172a;
    }
    body.app-theme-light .gm-search:focus { border-color: rgba(245,158,11,.6); }

    body.app-theme-light .gm-card {
        background: #ffffff; border-color: #e2e8f0;
    }
    body.app-theme-light .gm-card:hover {
        border-color: #f59e0b; background: #fef3c7;
    }
    body.app-theme-light .gm-card-name { color: #0f172a; }
    body.app-theme-light .gm-card-code { color: #64748b; }
    body.app-theme-light .gm-card-actions { border-top-color: #f1f5f9; }
    body.app-theme-light .gm-action-btn {
        background: #f8fafc; border-color: #e2e8f0; color: #64748b;
    }

    body.app-theme-light .gm-confirm {
        background: #ffffff; border-color: #e2e8f0;
        box-shadow: 0 24px 64px rgba(0,0,0,.15);
    }
    body.app-theme-light .gm-confirm-title { color: #0f172a; }
    body.app-theme-light .gm-confirm-text { color: #64748b; }
    body.app-theme-light .gm-btn--ghost.gm-confirm-cancel {
        background: #f1f5f9; border-color: #e2e8f0; color: #374151;
    }

    /* Guide modal — light */
    body.app-theme-light .guide-modal {
        background: #ffffff; border-color: #e2e8f0; color: #0f172a;
    }
    body.app-theme-light .guide-modal-header {
        background: #f8fafc; border-bottom-color: #e2e8f0;
    }
    body.app-theme-light .guide-modal-title { color: #0f172a; }
    body.app-theme-light .guide-modal-close { color: #64748b; }
    body.app-theme-light .guide-modal-close:hover:not(:disabled) {
        background: rgba(0,0,0,.06); color: #0f172a;
    }
    body.app-theme-light .guide-modal-body {
        background: #ffffff;
    }
    body.app-theme-light .guide-modal-label { color: #64748b; }
    body.app-theme-light .guide-modal-input,
    body.app-theme-light .guide-modal-select {
        background: #f1f5f9; border-color: #cbd5e1; color: #0f172a;
    }
    body.app-theme-light .guide-modal-input::placeholder { color: #94a3b8; }
    body.app-theme-light .guide-modal-select option {
        background: #ffffff; color: #0f172a;
    }
    body.app-theme-light .guide-modal-hint { color: #94a3b8; }
    body.app-theme-light .guide-modal-loading { color: #64748b; }
    body.app-theme-light .guide-modal-checkboxes {
        background: #f8fafc; border-color: #e2e8f0;
    }
    body.app-theme-light .guide-modal-checkbox-item {
        background: #ffffff; border-color: #e2e8f0; color: #64748b;
    }
    body.app-theme-light .guide-modal-checkbox-indicator {
        background: #e2e8f0; border-color: #cbd5e1;
    }
    body.app-theme-light .guide-modal-footer {
        background: #f8fafc; border-top-color: #e2e8f0;
    }
    body.app-theme-light .guide-modal-btn--cancel {
        background: #f1f5f9; border-color: #e2e8f0; color: #374151;
    }
    body.app-theme-light .guide-modal-btn--cancel:hover:not(:disabled) { background: #e2e8f0; }

    /* ═══ GuideTryModal stilleri ═══ */
    .guide-try-backdrop {
        position: fixed; inset: 0; z-index: 10000;
        background: rgba(0,0,0,.65); backdrop-filter: blur(5px);
        display: flex; align-items: center; justify-content: center; padding: 20px;
    }
    .guide-try-modal {
        background: #1e293b; border: 1px solid rgba(255,255,255,.13);
        border-radius: 16px; box-shadow: 0 24px 72px rgba(0,0,0,.6);
        width: min(860px, 96vw); max-height: 86vh;
        display: flex; flex-direction: column; overflow: hidden; color: #f1f5f9;
    }

    /* Header */
    .guide-try-header {
        display: flex; align-items: center; gap: 10px;
        padding: 14px 18px; border-bottom: 1px solid rgba(255,255,255,.1);
        flex-shrink: 0; background: rgba(0,0,0,.18);
    }
    .guide-try-header-icon {
        width: 32px; height: 32px; border-radius: 9px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: rgba(16,185,129,.15); color: #6ee7b7;
    }
    .guide-try-header-text { display: flex; flex-direction: column; flex: 1; min-width: 0; }
    .guide-try-header-title { font-size: .88rem; font-weight: 700; color: #f1f5f9; }
    .guide-try-header-sub { font-size: .72rem; color: #94a3b8; }

    /* Info band */
    .guide-try-info {
        display: flex; align-items: center; gap: 8px;
        padding: 9px 16px; flex-shrink: 0;
        background: rgba(16,185,129,.06); border-bottom: 1px solid rgba(16,185,129,.15);
        font-size: .78rem;
    }
    .guide-try-info-ico { color: #6ee7b7; flex-shrink: 0; }
    .guide-try-info-text { color: #94a3b8; display: flex; align-items: center; flex-wrap: wrap; gap: 4px; }
    .guide-try-col-chip {
        display: inline-flex; align-items: center; gap: 3px;
        padding: 1px 7px; border-radius: 5px; font-family: monospace; font-size: .76rem; font-weight: 600;
    }
    .guide-try-col-chip--val  { background: rgba(99,102,241,.18); color: #a5b4fc; border: 1px solid rgba(99,102,241,.3); }
    .guide-try-col-chip--disp { background: rgba(245,158,11,.15); color: #fbbf24; border: 1px solid rgba(245,158,11,.3); }
    .guide-try-same-note { color: #64748b; font-style: italic; }

    /* Arama */
    .guide-try-search-wrap {
        position: relative; display: flex; align-items: center;
        padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,.07); flex-shrink: 0;
    }
    .guide-try-search-ico { position: absolute; left: 26px; color: #94a3b8; pointer-events: none; }
    .guide-try-search {
        width: 100%; padding: 8px 36px;
        background: rgba(15,23,42,.7); border: 1px solid rgba(255,255,255,.12);
        border-radius: 8px; color: #f1f5f9; font-size: .85rem;
        outline: none; transition: border-color .15s;
    }
    .guide-try-search:focus { border-color: rgba(16,185,129,.5); box-shadow: 0 0 0 3px rgba(16,185,129,.1); }
    .guide-try-search-spin { position: absolute; right: 26px; color: #94a3b8; }

    /* Tablo */
    .guide-try-table-wrap { flex: 1; overflow-y: auto; min-height: 0; }
    .guide-try-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
    .guide-try-th {
        position: sticky; top: 0; padding: 9px 12px;
        background: rgba(15,23,42,.95); border-bottom: 1px solid rgba(255,255,255,.1);
        text-align: left; font-size: .72rem; font-weight: 700; color: #94a3b8;
        white-space: nowrap; font-family: monospace;
    }
    .guide-try-th--val  { color: #a5b4fc; background: rgba(99,102,241,.08); }
