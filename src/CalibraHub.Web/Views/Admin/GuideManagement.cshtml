    }

    /* Sag header */
    .gm-mapping-right-header {
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
        padding: 10px 16px; border-bottom: 1px solid rgba(255,255,255,.08); flex-shrink: 0;
    }
    .gm-mapping-right-header-title { display: flex; align-items: center; gap: 8px; font-size: .88rem; font-weight: 600; }
    .gm-mapping-right-header-code { font-size: .72rem; color: #64748b; font-family: monospace; }
    .gm-mapping-right-header-actions { display: flex; gap: 6px; }

    /* Manuel alan ekleme */
    .gm-mapping-add-field {
        display: flex; align-items: center; gap: 8px;
