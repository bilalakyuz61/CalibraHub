<div class="integrator-dashboard__content">
    <div class="guide-mgmt-mount" id="guideManagementRoot"></div>
</div>

@section Scripts {
<script src="/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)"></script>
<script>
    (function () {
        var el = document.getElementById('guideManagementRoot')
        if (!el) return
        function doMount() {
            if (!window.CalibraHub || !window.CalibraHub.mountGuideManagement) {
                console.error('[GuideManagement] mount fonksiyonu bulunamadi'); return
            }
            try { window.CalibraHub.mountGuideManagement(el) }
            catch (ex) { console.error('[GuideManagement] mount hatasi:', ex) }
        }
        if (window.CalibraHub && window.CalibraHub.mountGuideManagement) { doMount(); return }
        var tries = 0
        var timer = setInterval(function () {
            tries++
            if (window.CalibraHub && window.CalibraHub.mountGuideManagement) { clearInterval(timer); doMount() }
            else if (tries >= 30) { clearInterval(timer); console.error('[GuideManagement] timeout') }
        }, 100)
    })()
</script>
}
