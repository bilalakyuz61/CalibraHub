    }
    body.app-theme-light .gm-mapping-required-label { color: #64748b; }

    /* ═══ ConstraintBuilder (.gm-cb-*) ═══ */
    .gm-cb-root { display: flex; flex-direction: column; gap: 4px; }
    .gm-cb-loading { font-size: .78rem; color: #64748b; display: flex; align-items: center; gap: 6px; padding: 4px 0; }

