@{
    ViewData["Title"] = "Genel Tanımlamalar";
}
@Html.AntiForgeryToken()

@section Styles {
<style>
    html body {
        --gdf-surface: #ffffff;
        --gdf-border: #e2e8f0;
        --gdf-text: #0f172a;
        --gdf-muted: #64748b;
        --gdf-head-bg: #f8fafc;
        --gdf-hover: rgba(99,102,241,.05);
    }
    body.app-theme-dark {
        --gdf-surface: #0f172a;
        --gdf-border: rgba(255,255,255,.08);
        --gdf-text: #e2e8f0;
        --gdf-muted: #94a3b8;
        --gdf-head-bg: rgba(255,255,255,.03);
        --gdf-hover: rgba(99,102,241,.10);
    }

    /* Workspace iframe overflow:hidden — scroll bu sayfanın sorumluluğu */
    .gdf-wrap {
        height: 100%; min-height: 0; width: 100%;
        max-width: 900px; margin: 0 auto;
        padding: 18px 16px 14px;
        display: flex; flex-direction: column;
    }
    .gdf-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-shrink: 0; }
    .gdf-header-icon {
        width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff;
        box-shadow: 0 4px 12px rgba(99,102,241,.35);
    }
    .gdf-title { font-size: 1.05rem; font-weight: 700; color: var(--gdf-text); line-height: 1.2; }
    .gdf-sub { font-size: .78rem; color: var(--gdf-muted); }

    .gdf-group-title {
        font-size: .8rem; font-weight: 700; color: var(--gdf-muted);
        margin: 4px 0 8px; flex-shrink: 0;
        display: flex; align-items: center; gap: 8px;
    }
    .gdf-group-title::after { content: ''; flex: 1; height: 1px; background: var(--gdf-border); }

    .gdf-tabs { display: flex; gap: 4px; flex-shrink: 0; margin-bottom: 10px; }
    .gdf-tab {
        padding: 7px 16px; border-radius: 9px 9px 0 0; font-size: .82rem; font-weight: 600;
        border: none; background: transparent; cursor: pointer;
        color: var(--gdf-muted); border-bottom: 2px solid transparent;
        transition: color .12s, border-color .12s;
    }
    .gdf-tab:hover { color: #6366f1; }
    .gdf-tab.active { color: #6366f1; border-bottom-color: #6366f1; }
    body.app-theme-dark .gdf-tab.active { color: #a5b4fc; border-bottom-color: #a5b4fc; }

    .gdf-pane { display: none; flex: 1 1 auto; min-height: 0; flex-direction: column; }
    .gdf-pane.active { display: flex; }

    .gdf-toolbar { display: flex; gap: 8px; align-items: center; margin-bottom: 10px; flex-wrap: wrap; flex-shrink: 0; }
    .gdf-select, .gdf-input {
        padding: 7px 10px; border-radius: 8px; font-size: .82rem;
        border: 1px solid var(--gdf-border); background: var(--gdf-surface); color: var(--gdf-text);
    }
    .gdf-select:focus, .gdf-input:focus { outline: none; border-color: #818cf8; }
    .gdf-input { flex: 1; min-width: 180px; }
    .gdf-select { min-width: 180px; }

    .gdf-btn {
        padding: 7px 16px; border-radius: 8px; font-size: .8rem; font-weight: 600;
        border: 1px solid transparent; cursor: pointer; transition: all .12s; white-space: nowrap;
    }
    .gdf-btn--primary { background: #6366f1; color: #fff; }
    .gdf-btn--primary:hover { background: #4f46e5; }
    .gdf-btn--ghost { background: transparent; color: var(--gdf-muted); border-color: var(--gdf-border); }
    .gdf-btn--ghost:hover { color: #6366f1; border-color: #818cf8; }
    .gdf-btn--danger-ghost { background: transparent; color: var(--gdf-muted); border-color: var(--gdf-border); }
    .gdf-btn--danger-ghost:hover { color: #ef4444; border-color: #ef4444; }

    .gdf-list-wrap {
        flex: 1 1 auto; min-height: 0; overflow: auto;
        border: 1px solid var(--gdf-border); border-radius: 12px; background: var(--gdf-surface);
    }
    table.gdf-table { width: 100%; border-collapse: collapse; font-size: .84rem; }
    .gdf-table th {
        text-align: left; padding: 9px 14px; font-size: .74rem; font-weight: 600;
        color: var(--gdf-muted); background: var(--gdf-head-bg);
        border-bottom: 1px solid var(--gdf-border); position: sticky; top: 0; z-index: 1;
    }
    .gdf-table td { padding: 8px 14px; border-bottom: 1px solid var(--gdf-border); color: var(--gdf-text); }
    .gdf-table tr:last-child td { border-bottom: none; }
    .gdf-table tr:hover td { background: var(--gdf-hover); }
    .gdf-count {
        font-size: .7rem; font-weight: 700; padding: 2px 8px; border-radius: 999px;
        background: rgba(99,102,241,.12); color: #4f46e5; white-space: nowrap;
    }
    body.app-theme-dark .gdf-count { background: rgba(99,102,241,.2); color: #a5b4fc; }
    .gdf-row-actions { display: flex; gap: 6px; justify-content: flex-end; }
    .gdf-empty { text-align: center; padding: 26px; color: var(--gdf-muted); font-size: .82rem; }

    .gdf-toast {
        position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%);
        padding: 9px 18px; border-radius: 10px; font-size: .8rem; font-weight: 600;
        color: #fff; background: #10b981; box-shadow: 0 8px 24px rgba(0,0,0,.25);
        opacity: 0; pointer-events: none; transition: opacity .18s; z-index: 9999;
    }
    .gdf-toast.err { background: #ef4444; }
    .gdf-toast.show { opacity: 1; }

    /* Silme onayı — ekran ortası (standart) */
    .gdf-modal-backdrop {
        position: fixed; inset: 0; z-index: 9998; display: none;
        align-items: center; justify-content: center;
        background: rgba(15,23,42,.55); backdrop-filter: blur(4px);
    }
    .gdf-modal-backdrop.open { display: flex; }
    .gdf-modal {
        width: min(420px, 92vw); border-radius: 14px; padding: 22px; text-align: center;
        background: var(--gdf-surface); border: 1px solid var(--gdf-border);
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
    }
    .gdf-modal-icon {
        width: 52px; height: 52px; border-radius: 50%; margin: 0 auto 10px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(239,68,68,.12); color: #ef4444;
    }
    .gdf-modal-title { font-size: .95rem; font-weight: 700; color: var(--gdf-text); margin-bottom: 6px; }
    .gdf-modal-msg { font-size: .8rem; color: var(--gdf-muted); margin-bottom: 16px; }
    .gdf-modal-btns { display: flex; gap: 10px; }
    .gdf-modal-btns .gdf-btn { flex: 1; padding: 9px 12px; }
    .gdf-btn--danger { background: #ef4444; color: #fff; }
    .gdf-btn--danger:hover { background: #dc2626; }
</style>
}

<div class="gdf-wrap">
    <div class="gdf-header">
        <div class="gdf-header-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        </div>
        <div>
            <div class="gdf-title">Genel Tanımlamalar</div>
            <div class="gdf-sub">Programın genelinde kullanılan ortak tanımlar — gruplar halinde yönetilir.</div>
        </div>
    </div>

    <div class="gdf-group-title">Adres Tanımlama</div>

    <div class="gdf-tabs">
        <button type="button" class="gdf-tab active" data-tab="country">Ülkeler</button>
        <button type="button" class="gdf-tab" data-tab="city">Şehirler</button>
        <button type="button" class="gdf-tab" data-tab="district">İlçeler</button>
    </div>

    <!-- Ülkeler -->
    <div class="gdf-pane active" data-pane="country">
        <div class="gdf-toolbar">
            <input type="text" id="gdfCountryName" class="gdf-input" placeholder="Yeni ülke adı..." maxlength="100" />
            <button type="button" class="gdf-btn gdf-btn--primary" id="gdfCountryAdd">Ekle</button>
        </div>
        <div class="gdf-list-wrap">
            <table class="gdf-table">
                <thead><tr><th>Ülke</th><th style="width:110px;">Şehir Sayısı</th><th style="width:170px;text-align:right;">İşlem</th></tr></thead>
                <tbody id="gdfCountryBody"></tbody>
            </table>
        </div>
    </div>

    <!-- Şehirler -->
    <div class="gdf-pane" data-pane="city">
        <div class="gdf-toolbar">
            <select id="gdfCityCountry" class="gdf-select"></select>
            <input type="text" id="gdfCityName" class="gdf-input" placeholder="Yeni şehir adı..." maxlength="100" />
            <button type="button" class="gdf-btn gdf-btn--primary" id="gdfCityAdd">Ekle</button>
        </div>
        <div class="gdf-list-wrap">
            <table class="gdf-table">
                <thead><tr><th>Şehir</th><th style="width:110px;">İlçe Sayısı</th><th style="width:170px;text-align:right;">İşlem</th></tr></thead>
                <tbody id="gdfCityBody"></tbody>
            </table>
        </div>
    </div>

    <!-- İlçeler -->
    <div class="gdf-pane" data-pane="district">
        <div class="gdf-toolbar">
            <select id="gdfDistCountry" class="gdf-select"></select>
            <select id="gdfDistCity" class="gdf-select"></select>
            <input type="text" id="gdfDistName" class="gdf-input" placeholder="Yeni ilçe adı..." maxlength="100" />
            <button type="button" class="gdf-btn gdf-btn--primary" id="gdfDistAdd">Ekle</button>
        </div>
        <div class="gdf-list-wrap">
            <table class="gdf-table">
                <thead><tr><th>İlçe</th><th style="width:170px;text-align:right;">İşlem</th></tr></thead>
                <tbody id="gdfDistBody"></tbody>
            </table>
        </div>
    </div>
</div>

<div class="gdf-modal-backdrop" id="gdfModal">
    <div class="gdf-modal">
        <div class="gdf-modal-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
        </div>
        <div class="gdf-modal-title">Silinsin mi?</div>
        <div class="gdf-modal-msg" id="gdfModalMsg"></div>
        <div class="gdf-modal-btns">
            <button type="button" class="gdf-btn gdf-btn--ghost" id="gdfModalCancel">Vazgeç</button>
            <button type="button" class="gdf-btn gdf-btn--danger" id="gdfModalOk">Sil</button>
        </div>
    </div>
</div>

<div class="gdf-toast" id="gdfToast"></div>

@section Scripts {
<script>
(function () {
    function gid(id) { return document.getElementById(id); }
    function esc(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
    function csrf() { var t = document.querySelector('input[name="__RequestVerificationToken"]'); return t ? t.value : ''; }

    function toast(msg, isErr) {
        var el = gid('gdfToast');
        el.textContent = msg;
        el.classList.toggle('err', !!isErr);
        el.classList.add('show');
        setTimeout(function () { el.classList.remove('show'); }, 2400);
    }

    async function getJson(url) {
        var r = await fetch(url, { credentials: 'same-origin' });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || 'Liste alınamadı');
        return d.rows || [];
    }
    async function postJson(url, payload) {
        var r = await fetch(url, {
            method: 'POST', credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrf() },
            body: JSON.stringify(payload),
        });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || 'İşlem başarısız');
        return d;
    }

    // ── Silme onayı (Promise) ─────────────────────────────────────
    var modalResolve = null;
    var modal = gid('gdfModal');
    function confirmDelete(msg) {
        gid('gdfModalMsg').textContent = msg;
        modal.classList.add('open');
        gid('gdfModalOk').focus();
        return new Promise(function (res) { modalResolve = res; });
    }
    function closeModal(ok) { modal.classList.remove('open'); if (modalResolve) { modalResolve(ok); modalResolve = null; } }
    gid('gdfModalCancel').addEventListener('click', function () { closeModal(false); });
    gid('gdfModalOk').addEventListener('click', function () { closeModal(true); });
    modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(false); });
    document.addEventListener('keydown', function (e) {
        if (!modal.classList.contains('open')) return;
        if (e.key === 'Escape') closeModal(false);
        else if (e.key === 'Enter') closeModal(true);
    });

    // ── Sekmeler ──────────────────────────────────────────────────
    document.querySelectorAll('.gdf-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.gdf-tab').forEach(function (b) { b.classList.toggle('active', b === btn); });
            var key = btn.getAttribute('data-tab');
            document.querySelectorAll('.gdf-pane').forEach(function (p) {
                p.classList.toggle('active', p.getAttribute('data-pane') === key);
            });
            if (key === 'city') initCityPane();
            else if (key === 'district') initDistrictPane();
        });
    });

    // ── Yardımcı: satır adı düzenleme (prompt yerine satır içi input) ──
    function makeRow(name, badgeHtml, onRename, onDelete) {
        var tr = document.createElement('tr');
        var tdName = document.createElement('td');
        tdName.textContent = name;
        var tdBadge = null;
        if (badgeHtml !== null) {
            tdBadge = document.createElement('td');
            tdBadge.innerHTML = badgeHtml;
        }
        var tdAct = document.createElement('td');
        tdAct.innerHTML = '<div class="gdf-row-actions">'
            + '<button type="button" class="gdf-btn gdf-btn--ghost" data-act="edit">Düzenle</button>'
            + '<button type="button" class="gdf-btn gdf-btn--danger-ghost" data-act="del">Sil</button>'
            + '</div>';
        tr.appendChild(tdName);
        if (tdBadge) tr.appendChild(tdBadge);
        tr.appendChild(tdAct);

        tdAct.querySelector('[data-act="del"]').addEventListener('click', onDelete);
        tdAct.querySelector('[data-act="edit"]').addEventListener('click', function () {
            var inp = document.createElement('input');
            inp.type = 'text'; inp.className = 'gdf-input'; inp.value = name; inp.maxLength = 100;
            inp.style.width = '100%';
            tdName.textContent = '';
            tdName.appendChild(inp);
            inp.focus(); inp.select();
            var done = false;
            function finish(saveIt) {
                if (done) return; done = true;
                var newName = (inp.value || '').trim();
                if (saveIt && newName && newName !== name) onRename(newName);
                else tdName.textContent = name;
            }
            inp.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') finish(true);
                else if (e.key === 'Escape') finish(false);
            });
            inp.addEventListener('blur', function () { finish(true); });
        });
        return tr;
    }

    function fillSelect(sel, rows, placeholder) {
        var prev = sel.value;
        sel.innerHTML = '';
        var ph = document.createElement('option');
        ph.value = ''; ph.textContent = placeholder;
        sel.appendChild(ph);
        rows.forEach(function (r) {
            var o = document.createElement('option');
            o.value = r.id; o.textContent = r.name;
            sel.appendChild(o);
        });
        if (prev && rows.some(function (r) { return String(r.id) === prev; })) sel.value = prev;
        else if (rows.length === 1) sel.value = String(rows[0].id);
        // Türkiye tek başına en üstteyse varsayılan seç
        else if (!sel.value && rows.length > 0 && placeholder.indexOf('Ülke') >= 0) sel.value = String(rows[0].id);
    }

    // ── Ülkeler ───────────────────────────────────────────────────
    async function loadCountries() {
        var rows;
        try { rows = await getJson('/GeneralDefs/Countries'); }
        catch (e) { toast(e.message, true); return []; }
        var body = gid('gdfCountryBody');
        body.innerHTML = '';
        if (rows.length === 0) {
            body.innerHTML = '<tr><td colspan="3" class="gdf-empty">Henüz ülke tanımlanmamış</td></tr>';
        }
        rows.forEach(function (c) {
            body.appendChild(makeRow(
                c.name,
                '<span class="gdf-count">' + (c.cityCount || 0) + ' şehir</span>',
                async function (newName) {
                    try { await postJson('/GeneralDefs/SaveCountry', { id: c.id, name: newName }); toast('Güncellendi'); loadCountries(); }
                    catch (e) { toast(e.message, true); loadCountries(); }
                },
                async function () {
                    var ok = await confirmDelete('"' + c.name + '" ülkesi silinecek.' + (c.cityCount > 0 ? ' Bu ülkeye bağlı ' + c.cityCount + ' şehir var — silme engellenecektir.' : ''));
                    if (!ok) return;
                    try { await postJson('/GeneralDefs/DeleteCountry', { id: c.id, name: '' }); toast('Silindi'); loadCountries(); }
                    catch (e) { toast(e.message, true); }
                }));
        });
        return rows;
    }

    gid('gdfCountryAdd').addEventListener('click', async function () {
        var name = (gid('gdfCountryName').value || '').trim();
        if (!name) { toast('Ülke adı boş olamaz', true); return; }
        try {
            await postJson('/GeneralDefs/SaveCountry', { id: null, name: name });
            gid('gdfCountryName').value = '';
            toast('Eklendi: ' + name);
            loadCountries();
        } catch (e) { toast(e.message, true); }
    });
    gid('gdfCountryName').addEventListener('keydown', function (e) { if (e.key === 'Enter') gid('gdfCountryAdd').click(); });

    // ── Şehirler ──────────────────────────────────────────────────
    async function initCityPane() {
        var countries;
        try { countries = await getJson('/GeneralDefs/Countries'); } catch (e) { toast(e.message, true); return; }
        fillSelect(gid('gdfCityCountry'), countries, 'Ülke seçin...');
        loadCities();
    }

    async function loadCities() {
        var countryId = parseInt(gid('gdfCityCountry').value, 10) || 0;
        var body = gid('gdfCityBody');
        body.innerHTML = '';
        if (!countryId) { body.innerHTML = '<tr><td colspan="3" class="gdf-empty">Önce ülke seçin</td></tr>'; return; }
        var rows;
        try { rows = await getJson('/GeneralDefs/Cities?countryId=' + countryId); }
        catch (e) { toast(e.message, true); return; }
        if (rows.length === 0) {
            body.innerHTML = '<tr><td colspan="3" class="gdf-empty">Bu ülkede henüz şehir tanımlanmamış</td></tr>';
        }
        rows.forEach(function (c) {
            body.appendChild(makeRow(
                c.name,
                '<span class="gdf-count">' + (c.districtCount || 0) + ' ilçe</span>',
                async function (newName) {
                    try { await postJson('/GeneralDefs/SaveCity', { id: c.id, parentId: c.countryId, name: newName }); toast('Güncellendi'); loadCities(); }
                    catch (e) { toast(e.message, true); loadCities(); }
                },
                async function () {
                    var ok = await confirmDelete('"' + c.name + '" şehri silinecek.' + (c.districtCount > 0 ? ' Bu şehre bağlı ' + c.districtCount + ' ilçe var — silme engellenecektir.' : ''));
                    if (!ok) return;
                    try { await postJson('/GeneralDefs/DeleteCity', { id: c.id, name: '' }); toast('Silindi'); loadCities(); }
                    catch (e) { toast(e.message, true); }
                }));
        });
    }

    gid('gdfCityCountry').addEventListener('change', loadCities);
    gid('gdfCityAdd').addEventListener('click', async function () {
        var countryId = parseInt(gid('gdfCityCountry').value, 10) || 0;
        var name = (gid('gdfCityName').value || '').trim();
        if (!countryId) { toast('Önce ülke seçin', true); return; }
        if (!name) { toast('Şehir adı boş olamaz', true); return; }
        try {
            await postJson('/GeneralDefs/SaveCity', { id: null, parentId: countryId, name: name });
            gid('gdfCityName').value = '';
            toast('Eklendi: ' + name);
            loadCities();
        } catch (e) { toast(e.message, true); }
    });
    gid('gdfCityName').addEventListener('keydown', function (e) { if (e.key === 'Enter') gid('gdfCityAdd').click(); });

    // ── İlçeler ───────────────────────────────────────────────────
    async function initDistrictPane() {
        var countries;
        try { countries = await getJson('/GeneralDefs/Countries'); } catch (e) { toast(e.message, true); return; }
        fillSelect(gid('gdfDistCountry'), countries, 'Ülke seçin...');
        await loadDistCityOptions();
        loadDistricts();
    }

    async function loadDistCityOptions() {
        var countryId = parseInt(gid('gdfDistCountry').value, 10) || 0;
        var sel = gid('gdfDistCity');
        if (!countryId) { sel.innerHTML = '<option value="">Şehir seçin...</option>'; return; }
        var rows;
        try { rows = await getJson('/GeneralDefs/Cities?countryId=' + countryId); }
        catch (e) { toast(e.message, true); return; }
        fillSelect(sel, rows, 'Şehir seçin...');
    }

    async function loadDistricts() {
        var cityId = parseInt(gid('gdfDistCity').value, 10) || 0;
        var body = gid('gdfDistBody');
        body.innerHTML = '';
        if (!cityId) { body.innerHTML = '<tr><td colspan="2" class="gdf-empty">Önce şehir seçin</td></tr>'; return; }
        var rows;
        try { rows = await getJson('/GeneralDefs/Districts?cityId=' + cityId); }
        catch (e) { toast(e.message, true); return; }
        if (rows.length === 0) {
            body.innerHTML = '<tr><td colspan="2" class="gdf-empty">Bu şehirde henüz ilçe tanımlanmamış</td></tr>';
        }
        rows.forEach(function (d) {
            body.appendChild(makeRow(
                d.name,
                null,
                async function (newName) {
                    try { await postJson('/GeneralDefs/SaveDistrict', { id: d.id, parentId: d.cityId, name: newName }); toast('Güncellendi'); loadDistricts(); }
                    catch (e) { toast(e.message, true); loadDistricts(); }
                },
                async function () {
                    var ok = await confirmDelete('"' + d.name + '" ilçesi silinecek.');
                    if (!ok) return;
                    try { await postJson('/GeneralDefs/DeleteDistrict', { id: d.id, name: '' }); toast('Silindi'); loadDistricts(); }
                    catch (e) { toast(e.message, true); }
                }));
        });
    }

    gid('gdfDistCountry').addEventListener('change', async function () { await loadDistCityOptions(); loadDistricts(); });
    gid('gdfDistCity').addEventListener('change', loadDistricts);
    gid('gdfDistAdd').addEventListener('click', async function () {
        var cityId = parseInt(gid('gdfDistCity').value, 10) || 0;
        var name = (gid('gdfDistName').value || '').trim();
        if (!cityId) { toast('Önce şehir seçin', true); return; }
        if (!name) { toast('İlçe adı boş olamaz', true); return; }
        try {
            await postJson('/GeneralDefs/SaveDistrict', { id: null, parentId: cityId, name: name });
            gid('gdfDistName').value = '';
            toast('Eklendi: ' + name);
            loadDistricts();
        } catch (e) { toast(e.message, true); }
    });
    gid('gdfDistName').addEventListener('keydown', function (e) { if (e.key === 'Enter') gid('gdfDistAdd').click(); });

    // İlk yükleme
    loadCountries();
})();
</script>
}
