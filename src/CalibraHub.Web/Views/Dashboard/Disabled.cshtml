@{
    ViewData["UseDashboardShell"] = true;
    ViewData["BodyClass"] = "page-dashboard-disabled";
}

<div class="dashboard-disabled-host">
    <div class="dashboard-disabled-card">
        <h2>Pano Servisi Devre Disi</h2>
        <p>
            Grafana entegrasyonu bu kurulumda etkin degil. Sistem yoneticiniz
            <code>appsettings.json</code> dosyasindaki <code>Grafana:Enabled</code>
            ayarini <code>true</code> yapip servisi yeniden baslatmasi gerekir.
        </p>
        <p class="dashboard-disabled-hint">
            Servis kurulumu icin: <code>installer/grafana/grafana-setup.ps1</code>
        </p>
    </div>
</div>

<style>
    .dashboard-disabled-host {
        flex: 1 1 0;
        min-height: 0;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }
    .dashboard-disabled-card {
        max-width: 520px;
        padding: 2rem;
        border-radius: 12px;
        background: var(--surface-elevated, rgba(255, 255, 255, 0.04));
        border: 1px solid var(--border-subtle, rgba(255, 255, 255, 0.08));
    }
    .dashboard-disabled-card h2 { margin: 0 0 1rem; }
    .dashboard-disabled-card p { line-height: 1.6; margin: 0 0 0.75rem; }
    .dashboard-disabled-hint { font-size: 0.875rem; opacity: 0.75; }
    .dashboard-disabled-card code {
        background: rgba(0, 0, 0, 0.3);
        padding: 0.125rem 0.375rem;
        border-radius: 4px;
        font-family: ui-monospace, monospace;
    }
</style>
