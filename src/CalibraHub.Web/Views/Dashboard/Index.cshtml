@{
    ViewData["Title"] = "Panolar";
    ViewData["BodyClass"] = "page-dashboard-list";
    var grafanaPath = (ViewData["GrafanaPublicPath"] as string ?? "/grafana").TrimEnd('/') + "/";
    var isDesigner = ViewData["GrafanaIsDesigner"] is bool b && b;
}

<div class="dashboard-md-host">
    <aside class="dashboard-md-side">
        <div class="dashboard-md-side-header">
            <h1>Panolar</h1>
            <p class="dashboard-md-subtitle" id="dashboard-md-subtitle">Yukleniyor...</p>
            <div class="dashboard-md-search">
                <input type="search" id="dashboard-md-search-input" placeholder="Pano ara..." autocomplete="off" />
            </div>
        </div>
        <div class="dashboard-md-list" id="dashboard-md-list" data-state="loading" aria-busy="true">
            <div class="dashboard-md-list-empty">
                <p>Yukleniyor...</p>
            </div>
        </div>
    </aside>

    <section class="dashboard-md-content" id="dashboard-md-content" data-state="empty">
        <div class="dashboard-md-empty">
            <p>Panoyu görüntülemek icin sol listeden bir pano sec.</p>
        </div>
    </section>
</div>

<style>
    .page-dashboard-list .workspace-action-bar { display: none !important; }

    .dashboard-md-host {
        display: flex;
        height: 100%;
        min-height: 0;
        box-sizing: border-box;
        background: var(--surface-base, #0a0d17);
    }

    .dashboard-md-side {
        flex: 0 0 280px;
        display: flex;
        flex-direction: column;
        min-height: 0;
        border-right: 1px solid var(--border-subtle, rgba(148, 163, 184, 0.18));
        background: var(--surface-elevated, rgba(15, 23, 42, 0.55));
    }

    .dashboard-md-side-header {
        padding: 1rem 1rem 0.75rem;
        border-bottom: 1px solid var(--border-subtle, rgba(148, 163, 184, 0.18));
        flex-shrink: 0;
    }
    .dashboard-md-side-header h1 {
        margin: 0;
        font-size: 1.0625rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--text-primary, #e2e8f0);
    }
    .dashboard-md-subtitle {
        margin: 0.125rem 0 0.625rem;
        font-size: 0.75rem;
        color: var(--text-muted, #94a3b8);
    }
    .dashboard-md-search input {
        width: 100%;
        padding: 0.4375rem 0.75rem;
        font-size: 0.8125rem;
        border-radius: 7px;
        border: 1px solid var(--border-subtle, rgba(148, 163, 184, 0.22));
        background: rgba(15, 23, 42, 0.5);
        color: var(--text-primary, #e2e8f0);
        outline: none;
        box-sizing: border-box;
        transition: border-color .15s, box-shadow .15s;
    }
    .dashboard-md-search input:focus {
        border-color: rgba(56, 189, 248, 0.55);
        box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.18);
    }

    .dashboard-md-list {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        padding: 0.5rem 0.5rem 0.75rem;
        display: flex; flex-direction: column;
        gap: 0.625rem;
    }

    .dashboard-md-folder { display: flex; flex-direction: column; gap: 0.125rem; }
    .dashboard-md-folder-title {
        margin: 0.5rem 0.625rem 0.25rem;
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted, #94a3b8);
    }

    .dashboard-md-item {
        display: flex; align-items: center; gap: 0.625rem;
        padding: 0.5rem 0.75rem;
        border-radius: 8px;
        border: 1px solid transparent;
        background: transparent;
        cursor: pointer;
        text-align: left;
        font: inherit; color: inherit;
        transition: background .12s, border-color .12s;
        width: 100%;
        box-sizing: border-box;
    }
    .dashboard-md-item:hover {
        background: rgba(56, 189, 248, 0.06);
        border-color: rgba(56, 189, 248, 0.18);
    }
    .dashboard-md-item.active {
        background: rgba(56, 189, 248, 0.14);
        border-color: rgba(56, 189, 248, 0.42);
    }
    .dashboard-md-item:focus-visible {
        outline: none;
        border-color: rgba(56, 189, 248, 0.7);
        box-shadow: 0 0 0 2px rgba(56, 189, 248, 0.25);
    }

    .dashboard-md-item-icon {
        flex-shrink: 0;
        width: 26px; height: 26px;
        border-radius: 7px;
        display: flex; align-items: center; justify-content: center;
        background: rgba(56, 189, 248, 0.14);
        border: 1px solid rgba(56, 189, 248, 0.18);
        color: #38bdf8;
    }
    .dashboard-md-item-icon svg { width: 14px; height: 14px; }

    .dashboard-md-item-text {
        display: flex; flex-direction: column; min-width: 0;
        flex: 1 1 auto;
    }
    .dashboard-md-item-title {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-primary, #e2e8f0);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .dashboard-md-item-tags {
        font-size: 0.6875rem;
        color: var(--text-muted, #94a3b8);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }

    .dashboard-md-list-empty {
        padding: 2rem 1rem;
        text-align: center;
        color: var(--text-muted, #94a3b8);
        font-size: 0.8125rem;
    }
    .dashboard-md-list-empty p { margin: 0 0 0.5rem; }
    .dashboard-md-list-empty a {
        color: #38bdf8;
        font-size: 0.75rem;
        text-decoration: none;
    }
    .dashboard-md-list-empty a:hover { text-decoration: underline; }

    .dashboard-md-content {
        flex: 1 1 auto;
        min-width: 0;
        display: flex;
        background: #0f172a;
        position: relative;
    }
    .dashboard-md-content[data-state="empty"] {
        align-items: center; justify-content: center;
    }
    .dashboard-md-content iframe {
        width: 100%;
        height: 100%;
        border: 0;
        background: transparent;
    }
    .dashboard-md-empty {
        padding: 2rem;
        text-align: center;
        color: var(--text-muted, #94a3b8);
        font-size: 0.9375rem;
    }
    .dashboard-md-empty p { margin: 0; }
</style>

<script>
    (function () {
        var GRAFANA_PATH = '@grafanaPath';
        // Designer/Admin → Grafana sol menusu/edit araclari acik (kiosk yok).
        // Viewer rolleri → kiosk=tv (sol menu gizli, sadece pano icerigi).
        var IS_DESIGNER = @(isDesigner ? "true" : "false");
        var listEl = document.getElementById('dashboard-md-list');
        var contentEl = document.getElementById('dashboard-md-content');
        var subtitleEl = document.getElementById('dashboard-md-subtitle');
        var searchInput = document.getElementById('dashboard-md-search-input');

        var state = {
            items: [],
            filtered: [],
            loaded: false,
            activeUid: null
        };

        var ICON_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
            '<path d="M3 3v18h18"/><path d="M7 16V9"/><path d="M12 16v-5"/><path d="M17 16V7"/></svg>';

        function escapeHtml(str) {
            if (str === null || str === undefined) return '';
            return String(str)
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        }

        function setActiveItem(uid) {
            state.activeUid = uid;
            var nodes = listEl.querySelectorAll('.dashboard-md-item');
            for (var i = 0; i < nodes.length; i++) {
                if (nodes[i].getAttribute('data-uid') === uid) nodes[i].classList.add('active');
                else nodes[i].classList.remove('active');
            }
        }

        function loadDashboard(item) {
            if (!item || !item.uid) return;
            setActiveItem(item.uid);
            var src = GRAFANA_PATH + 'd/' + encodeURIComponent(item.uid)
                + (IS_DESIGNER ? '/?theme=dark' : '/?kiosk=tv&theme=dark');
            contentEl.setAttribute('data-state', 'loaded');
            contentEl.innerHTML = '';
            var iframe = document.createElement('iframe');
            iframe.src = src;
            iframe.title = item.title || 'Pano';
            iframe.setAttribute('referrerpolicy', 'same-origin');
            iframe.setAttribute('loading', 'eager');
            contentEl.appendChild(iframe);
        }

        function renderListItem(item) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'dashboard-md-item';
            btn.setAttribute('data-uid', item.uid);

            var tagsText = '';
            if (item.tags && item.tags.length > 0) {
                tagsText = item.tags.slice(0, 3).join(' · ');
            }

            btn.innerHTML =
                '<span class="dashboard-md-item-icon">' + ICON_SVG + '</span>' +
                '<span class="dashboard-md-item-text">' +
                    '<span class="dashboard-md-item-title">' + escapeHtml(item.title) + '</span>' +
                    (tagsText ? '<span class="dashboard-md-item-tags">' + escapeHtml(tagsText) + '</span>' : '') +
                '</span>';

            btn.addEventListener('click', function () { loadDashboard(item); });
            return btn;
        }

        function renderListEmpty(reason) {
            listEl.innerHTML = '';
            listEl.setAttribute('data-state', 'empty');
            listEl.removeAttribute('aria-busy');

            var wrap = document.createElement('div');
            wrap.className = 'dashboard-md-list-empty';
            var p = document.createElement('p');
            p.textContent = reason || 'Henuz pano olusturulmamis.';
            wrap.appendChild(p);

            var a = document.createElement('a');
            a.href = '/Dashboard/Grafana';
            a.textContent = 'Grafana arayuzunu ac >';
            wrap.appendChild(a);

            listEl.appendChild(wrap);
        }

        function renderList(items) {
            listEl.innerHTML = '';
            listEl.removeAttribute('aria-busy');

            if (!items || items.length === 0) {
                if (state.loaded && state.items.length > 0) {
                    listEl.setAttribute('data-state', 'empty');
                    var wrap = document.createElement('div');
                    wrap.className = 'dashboard-md-list-empty';
                    var p = document.createElement('p');
                    p.textContent = 'Aramayla eslesen pano bulunamadi.';
                    wrap.appendChild(p);
                    listEl.appendChild(wrap);
                } else {
                    renderListEmpty();
                }
                return;
            }

            listEl.setAttribute('data-state', 'loaded');

            var groups = {};
            var groupOrder = [];
            items.forEach(function (it) {
                var key = it.folderTitle || 'Genel';
                if (!groups[key]) { groups[key] = []; groupOrder.push(key); }
                groups[key].push(it);
            });

            groupOrder.forEach(function (key) {
                var folder = document.createElement('section');
                folder.className = 'dashboard-md-folder';

                var h = document.createElement('h2');
                h.className = 'dashboard-md-folder-title';
                h.textContent = key;
                folder.appendChild(h);

                groups[key].forEach(function (it) { folder.appendChild(renderListItem(it)); });
                listEl.appendChild(folder);
            });

            // Aktif uid hala filtre sonucundaysa highlight, yoksa ilk panoyu yukle
            var stillActive = state.activeUid && items.some(function (it) { return it.uid === state.activeUid; });
            if (stillActive) {
                setActiveItem(state.activeUid);
            } else if (!state.activeUid) {
                loadDashboard(items[0]);
            }
        }

        function applyFilter() {
            var q = (searchInput.value || '').trim().toLowerCase();
            if (!q) {
                state.filtered = state.items.slice();
            } else {
                state.filtered = state.items.filter(function (it) {
                    if ((it.title || '').toLowerCase().indexOf(q) !== -1) return true;
                    if ((it.folderTitle || '').toLowerCase().indexOf(q) !== -1) return true;
                    if (it.tags && it.tags.length > 0) {
                        for (var i = 0; i < it.tags.length; i++) {
                            if ((it.tags[i] || '').toLowerCase().indexOf(q) !== -1) return true;
                        }
                    }
                    return false;
                });
            }
            renderList(state.filtered);
        }

        function updateSubtitle() {
            if (!subtitleEl) return;
            var n = state.items.length;
            subtitleEl.textContent = n === 0 ? 'Pano bulunamadi' : (n + ' pano');
        }

        function load() {
            fetch('/Dashboard/List', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
                .then(function (r) {
                    if (!r.ok) throw new Error('HTTP ' + r.status);
                    return r.json();
                })
                .then(function (items) {
                    state.items = Array.isArray(items) ? items : [];
                    state.filtered = state.items.slice();
                    state.loaded = true;
                    updateSubtitle();
                    renderList(state.filtered);
                })
                .catch(function (err) {
                    console.error('[Dashboard] List fetch failed', err);
                    state.items = [];
                    state.loaded = true;
                    updateSubtitle();
                    renderListEmpty('Pano listesi yuklenemedi.');
                });
        }

        var searchTimer = null;
        searchInput.addEventListener('input', function () {
            if (searchTimer) clearTimeout(searchTimer);
            searchTimer = setTimeout(applyFilter, 120);
        });

        load();
    })();
</script>
