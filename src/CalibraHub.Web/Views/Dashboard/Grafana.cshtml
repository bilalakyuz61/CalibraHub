@{
    // Layout=null: ust frame Grafana iframe'ini host eder, React Shell katmani gizli.
    // Workspace iframe icindeyken topbar gizlenir.
    Layout = null;
    var pageTitle = "Rapor Tasarımı - CalibraHub";
    var grafanaPath = (ViewData["GrafanaPublicPath"] as string ?? "/grafana").TrimEnd('/') + "/";
    var listUrl = Url.Action("Index", "Dashboard") ?? "/Dashboard";
    var isInWorkspace = string.Equals(Context.Request.Query["workspace"], "1", StringComparison.Ordinal)
                        || string.Equals(Context.Request.Headers["Sec-Fetch-Dest"], "iframe", StringComparison.OrdinalIgnoreCase);
    var isDesigner = ViewData["GrafanaIsDesigner"] is bool b && b;
    // Viewer rolleri kiosk=tv (sol menu gizli); Designer/Admin tam Grafana UI gorur.
    // Tema ve servis erisilebilirligi runtime'da client-side belirlenir:
    //   - Tema: parent Shell body.app-theme-* class'i okunur (fallback: prefers-color-scheme).
    //           Boylece light/dark her ikisinde de chrome + Grafana icerigi uyumlu.
    //   - Servis: /grafana/api/health probe (fetch — SW intercept etmez). Ayakta
    //           degilse temali "servis kapali" paneli + Yeniden Dene. Eski davranista
    //           SW app-offline.html'i iframe icine basip sonsuz reload dongusune
    //           giriyordu (geri sayim 10'da takiliyordu); artik bu sayfa kendi
    //           servis-durumunu yonetir.
    var healthUrl = grafanaPath + "api/health";        // "/grafana/api/health"
    var dashboardsPath = grafanaPath + "dashboards";    // "/grafana/dashboards"
    var kioskSuffix = isDesigner ? "" : "&kiosk=tv";
}<!DOCTYPE html>
<html lang="tr-TR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <style>
        /* Light varsayilan; dark override body.app-theme-dark altinda. Parent Shell
           tab iframe'lerine app-theme-* class'ini enjekte eder → tema canli takip edilir. */
        :root {
            color-scheme: light dark;
            --tb-bg: #f1f5f9;
            --tb-border: #e2e8f0;
            --tb-text: #334155;
            --tb-title: #0f172a;
            --tb-link: #4f46e5;
            --tb-link-hover: #6366f1;
            --stage-bg: #f8fafc;
            --panel-surface: #ffffff;
            --panel-border: #e2e8f0;
            --panel-title: #0f172a;
            --panel-muted: #64748b;
            --accent: #6366f1;
            --accent-soft: rgba(99, 102, 241, 0.10);
            --shadow: 0 24px 60px rgba(15, 23, 42, 0.10), 0 0 0 1px rgba(15, 23, 42, 0.04);
        }
        body.app-theme-dark {
            --tb-bg: #0b1220;
            --tb-border: rgba(255, 255, 255, 0.08);
            --tb-text: #cbd5e1;
            --tb-title: #e2e8f0;
            --tb-link: #38bdf8;
            --tb-link-hover: #7dd3fc;
            --stage-bg: #0f172a;
            --panel-surface: #111827;
            --panel-border: rgba(255, 255, 255, 0.07);
            --panel-title: #f1f5f9;
            --panel-muted: #94a3b8;
            --accent-soft: rgba(99, 102, 241, 0.14);
            --shadow: 0 24px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.04);
        }
        *, *::before, *::after { box-sizing: border-box; }
        html, body {
            margin: 0; padding: 0; height: 100dvh; overflow: hidden;
            background: var(--stage-bg);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        body { display: flex; flex-direction: column; }
        .grafana-topbar {
            flex: 0 0 auto; display: flex; align-items: center; gap: 1rem;
            padding: 0.5rem 1rem; background: var(--tb-bg);
            border-bottom: 1px solid var(--tb-border); color: var(--tb-text); font-size: 0.875rem;
        }
        .grafana-topbar a {
            color: var(--tb-link); text-decoration: none;
            display: inline-flex; align-items: center; gap: 0.375rem;
        }
        .grafana-topbar a:hover { color: var(--tb-link-hover); }
        .grafana-topbar .sep { opacity: 0.5; }
        .grafana-topbar .title { font-weight: 600; color: var(--tb-title); }
        .stage { flex: 1 1 auto; position: relative; width: 100%; min-height: 0; }
        .grafana-frame { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; background: transparent; }

        /* Yukleniyor / servis kapali temali panel */
        .state { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding: 24px; }
        .state[hidden] { display: none; }
        .state__card {
            width: 100%; max-width: 440px; text-align: center;
            background: var(--panel-surface); border: 1px solid var(--panel-border);
            border-radius: 18px; box-shadow: var(--shadow); padding: 34px 30px 28px;
        }
        .state__icon {
            width: 56px; height: 56px; margin: 0 auto 18px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            background: var(--accent-soft); color: var(--accent);
        }
        .state__icon svg { width: 28px; height: 28px; }
        .state__title { margin: 0 0 6px; font-size: 18px; font-weight: 700; color: var(--panel-title); letter-spacing: -0.01em; }
        .state__msg { margin: 0 0 22px; font-size: 13px; line-height: 1.55; color: var(--panel-muted); }
        .state__btn {
            display: inline-flex; align-items: center; gap: 0.45rem; padding: 9px 18px; border-radius: 10px;
            border: 1px solid var(--accent); background: var(--accent); color: #fff;
            font-size: 13px; font-weight: 600; cursor: pointer; transition: background .12s, opacity .12s;
        }
        .state__btn:hover { background: #4f46e5; }
        .state__btn[disabled] { opacity: .6; cursor: default; }
        .state__btn svg { width: 16px; height: 16px; }
        .spin { animation: cbspin 1s linear infinite; transform-origin: center; }
        @@keyframes cbspin { to { transform: rotate(360deg); } }
        .state__hint { margin: 14px 0 0; font-size: 11px; color: var(--panel-muted); min-height: 14px; }
    </style>
    <script>
        // Tema flash'ini onle: parent Shell body class'ini paint'ten once oku ve kok
        // arka plani hemen ayarla. body henuz olmadigi icin class'i DOMContentLoaded'da bas.
        (function () {
            var dark = false;
            try {
                var topBody = (window.top && window.top !== window && window.top.document)
                    ? window.top.document.body : null;
                var cls = topBody ? (topBody.className || '') : '';
                if (/app-theme-dark/.test(cls)) dark = true;
                else if (/app-theme-light/.test(cls)) dark = false;
                else dark = !!(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
            } catch (_) {
                dark = !!(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
            }
            var root = document.documentElement;
            root.style.colorScheme = dark ? 'dark' : 'light';
            root.style.background = dark ? '#0f172a' : '#f8fafc';
            document.addEventListener('DOMContentLoaded', function () {
                document.body.classList.add(dark ? 'app-theme-dark' : 'app-theme-light');
            });
        })();
    </script>
</head>
<body>
    @if (!isInWorkspace)
    {
        <div class="grafana-topbar">
            <a href="@listUrl" title="Panolara don">&larr; Panolar</a>
            <span class="sep">|</span>
            <span class="title">Rapor Tasarımı</span>
        </div>
    }
    <div class="stage" id="stage">
        <div class="state" id="state">
            <div class="state__card">
                <div class="state__icon" id="stateIcon">
                    <svg class="spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <path d="M21 12a9 9 0 1 1-6.219-8.56" />
                    </svg>
                </div>
                <h1 class="state__title" id="stateTitle">Tasarım servisi hazırlanıyor…</h1>
                <p class="state__msg" id="stateMsg">Bağlantı kuruluyor, lütfen bekleyin.</p>
                <button type="button" class="state__btn" id="stateBtn" hidden>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12a9 9 0 1 0 3-6.7L3 8" /><path d="M3 3v5h5" />
                    </svg>
                    <span>Yeniden dene</span>
                </button>
                <p class="state__hint" id="stateHint"></p>
            </div>
        </div>
    </div>

    <script>
    (function () {
        var HEALTH_URL = '@Html.Raw(healthUrl)';
        var DASH_PATH  = '@Html.Raw(dashboardsPath)';
        var KIOSK      = '@Html.Raw(kioskSuffix)';   // "" | "&kiosk=tv"

        var stage   = document.getElementById('stage');
        var stateEl = document.getElementById('state');
        var iconEl  = document.getElementById('stateIcon');
        var titleEl = document.getElementById('stateTitle');
        var msgEl   = document.getElementById('stateMsg');
        var btnEl   = document.getElementById('stateBtn');
        var hintEl  = document.getElementById('stateHint');
        var frame   = null;
        var checking = false;

        var SPINNER = '<svg class="spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
        var PLUG    = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z"/></svg>';

        function isDark() { return document.body.classList.contains('app-theme-dark'); }

        function showLoading() {
            iconEl.innerHTML = SPINNER;
            titleEl.textContent = 'Tasarım servisi hazırlanıyor…';
            msgEl.textContent   = 'Bağlantı kuruluyor, lütfen bekleyin.';
            btnEl.hidden = true; btnEl.disabled = true;
            hintEl.textContent = '';
            stateEl.hidden = false;
        }
        function showDown() {
            iconEl.innerHTML = PLUG;
            titleEl.textContent = 'Tasarım servisi şu anda çalışmıyor';
            msgEl.textContent   = 'Pano tasarım servisine (Grafana) ulaşılamıyor. Servis başlatıldığında “Yeniden dene” ile bu ekranı açabilirsiniz.';
            btnEl.hidden = false; btnEl.disabled = false;
            stateEl.hidden = false;
        }
        function mountFrame() {
            if (!frame) {
                frame = document.createElement('iframe');
                frame.className = 'grafana-frame';
                frame.title = 'Tasarım';
                frame.setAttribute('referrerpolicy', 'same-origin');
                frame.setAttribute('loading', 'eager');
                stage.appendChild(frame);
            }
            frame.src = DASH_PATH + '?theme=' + (isDark() ? 'dark' : 'light') + KIOSK;
            stateEl.hidden = true;
        }

        async function check(isRetry) {
            if (checking) return;
            checking = true;
            if (isRetry) { btnEl.disabled = true; hintEl.textContent = 'Kontrol ediliyor…'; }
            else { showLoading(); }
            try {
                var r = await fetch(HEALTH_URL, {
                    method: 'GET', credentials: 'same-origin', cache: 'no-store',
                    headers: { 'Accept': 'application/json' }
                });
                if (r.ok) { mountFrame(); checking = false; return; }
            } catch (_) { /* network/connection reddedildi — servis kapali */ }
            checking = false;
            showDown();
            if (isRetry) hintEl.textContent = 'Hâlâ ulaşılamıyor.';
        }

        btnEl.addEventListener('click', function () { check(true); });

        // Not: parent tema degisince host chrome CSS degiskenleriyle aninda takip eder.
        // Grafana iframe'inin theme param'i ilk yuklemede sabitlenir (jarring full
        // reload yapmamak icin canli degistirilmez; sonraki acilista dogru tema gelir).
        check(false);
    })();
    </script>
</body>
</html>
