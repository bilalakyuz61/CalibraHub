@{
    // Layout=null: top frame Grafana iframe'ini host eder, React Shell katmani gizli.
    // Workspace iframe icindeyken topbar gizlenir.
    Layout = null;
    var pageTitle = "Grafana - CalibraHub";
    var grafanaPath = (ViewData["GrafanaPublicPath"] as string ?? "/grafana").TrimEnd('/') + "/";
    var listUrl = Url.Action("Index", "Dashboard") ?? "/Dashboard";
    var isInWorkspace = string.Equals(Context.Request.Query["workspace"], "1", StringComparison.Ordinal)
                        || string.Equals(Context.Request.Headers["Sec-Fetch-Dest"], "iframe", StringComparison.OrdinalIgnoreCase);
    var isDesigner = ViewData["GrafanaIsDesigner"] is bool b && b;
    // Viewer rolleri kiosk=tv (sol menu gizli); Designer/Admin tam Grafana UI gorur.
    // Doğrudan Grafana root'una gitmek yerine Dashboards browse sayfasına yönlendir.
    // Grafana root, default home dashboard ararken (set edilmemişse) breadcrumb'ı
    // "Page not found > Home" olarak gösteriyor — kullanıcı kafası karışıyor.
    // /dashboards her zaman mevcut, temiz açılış noktası.
    var iframeSrc = grafanaPath + "dashboards" + (isDesigner ? "?theme=dark" : "?kiosk=tv&theme=dark");
}<!DOCTYPE html>
<html lang="tr-TR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <style>
        :root { color-scheme: dark; }
        html, body { margin: 0; padding: 0; height: 100dvh; overflow: hidden; background: #0f172a; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        body { display: flex; flex-direction: column; }
        .grafana-topbar {
            flex: 0 0 auto;
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.5rem 1rem;
            background: #0b1220;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            color: #cbd5e1;
            font-size: 0.875rem;
        }
        .grafana-topbar a {
            color: #38bdf8;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
        }
        .grafana-topbar a:hover { color: #7dd3fc; }
        .grafana-topbar .sep { opacity: 0.5; }
        .grafana-topbar .title { font-weight: 600; color: #e2e8f0; }
        .grafana-frame {
            flex: 1 1 auto;
            width: 100%;
            border: 0;
            background: transparent;
        }
    </style>
</head>
<body>
    @if (!isInWorkspace)
    {
        <div class="grafana-topbar">
            <a href="@listUrl" title="Panolara don">
                &larr; Panolar
            </a>
            <span class="sep">|</span>
            <span class="title">Grafana</span>
        </div>
    }
    <iframe class="grafana-frame"
            src="@iframeSrc"
            title="Grafana"
            referrerpolicy="same-origin"
            loading="eager"></iframe>
</body>
</html>
