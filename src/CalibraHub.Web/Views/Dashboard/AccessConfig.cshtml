@{
    ViewData["Title"] = "Pano Erişim Yönetimi";
}

<style>
    /* ── Layout ── */
    .pac-host { display: flex; height: 100%; min-height: 0; overflow: hidden; }

    /* Sol panel: pano listesi */
    .pac-left {
        flex: 0 0 300px; display: flex; flex-direction: column; min-height: 0;
        border-right: 1px solid var(--border-subtle, rgba(148,163,184,.18));
        background: var(--surface-elevated, var(--app-surface-alt, #f8fafc));
    }
    .pac-left-header {
        padding: .75rem 1rem .625rem; flex-shrink: 0;
        border-bottom: 1px solid var(--border-subtle, rgba(148,163,184,.18));
    }
    .pac-left-title { margin: 0 0 .5rem; font-size: .9375rem; font-weight: 700; color: var(--text-primary, #0f172a); }
    .pac-search {
        width: 100%; padding: .375rem .625rem; font-size: .8125rem; border-radius: 7px;
        border: 1px solid var(--border-subtle, rgba(148,163,184,.22));
        background: var(--app-surface, #fff); color: var(--text-primary, #0f172a);
        outline: none; box-sizing: border-box;
    }
    .pac-search:focus { border-color: rgba(99,102,241,.5); box-shadow: 0 0 0 3px rgba(99,102,241,.12); }

    .pac-list { flex: 1 1 auto; min-height: 0; overflow-y: auto; padding: .5rem; }
    .pac-folder-title {
        padding: .375rem .5rem .25rem; font-size: .625rem; font-weight: 700;
        letter-spacing: .08em; text-transform: uppercase; color: var(--text-muted, #94a3b8);
    }
    .pac-item {
        display: flex; align-items: center; gap: .5rem; padding: .4375rem .625rem;
        border-radius: 7px; border: 1px solid transparent; cursor: pointer;
        width: 100%; background: transparent; text-align: left; font: inherit;
        color: var(--text-primary, #0f172a); transition: background .1s, border-color .1s;
        box-sizing: border-box;
    }
    .pac-item:hover { background: rgba(99,102,241,.06); border-color: rgba(99,102,241,.15); }
    .pac-item.active { background: rgba(99,102,241,.12); border-color: rgba(99,102,241,.35); }
    .pac-item-name { flex: 1 1 auto; font-size: .8125rem; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pac-badge {
        flex-shrink: 0; font-size: .625rem; font-weight: 700; padding: .125rem .375rem;
        border-radius: 4px; letter-spacing: .04em;
    }
    .pac-badge--open  { background: rgba(16,185,129,.12); color: #059669; }
    .pac-badge--limit { background: rgba(239,68,68,.12);  color: #dc2626; }

    /* Sağ panel: erişim editörü */
    .pac-right {
        flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column;
        overflow: hidden; background: var(--app-surface, #fff);
    }
    .pac-empty {
        flex: 1 1 auto; display: flex; align-items: center; justify-content: center;
        color: var(--text-muted, #94a3b8); font-size: .9375rem;
    }
    .pac-editor { flex: 1 1 auto; display: flex; flex-direction: column; padding: 1.5rem; overflow-y: auto; gap: 1.25rem; }
    .pac-editor-title {
        margin: 0; font-size: 1.0625rem; font-weight: 700; color: var(--text-primary, #0f172a);
    }
    .pac-editor-folder { font-size: .8125rem; color: var(--text-muted, #94a3b8); margin: .125rem 0 0; }

    /* Erişim modu toggle */
    .pac-mode { display: flex; gap: .625rem; flex-wrap: wrap; }
    .pac-mode-btn {
        display: flex; align-items: center; gap: .375rem; padding: .5rem .875rem;
        border-radius: 8px; border: 1.5px solid var(--border-subtle, #e2e8f0);
        background: transparent; cursor: pointer; font-size: .8125rem; font-weight: 500;
        color: var(--text-secondary, #475569); transition: all .12s;
    }
    .pac-mode-btn.selected { border-color: #6366f1; background: rgba(99,102,241,.08); color: #6366f1; }
    .pac-mode-btn svg { width: 15px; height: 15px; }

    /* Kullanıcı / departman seçici */
    .pac-section-label { font-size: .8125rem; font-weight: 600; color: var(--text-secondary, #475569); margin: 0 0 .5rem; }
    .pac-picker {
        border: 1px solid var(--border-subtle, #e2e8f0); border-radius: 9px;
        overflow: hidden; background: var(--app-surface, #fff);
    }
    .pac-picker-search {
        width: 100%; padding: .375rem .625rem; border: 0; border-bottom: 1px solid var(--border-subtle, #e2e8f0);
        background: var(--surface-elevated, #f8fafc); font-size: .8125rem;
        color: var(--text-primary, #0f172a); outline: none; box-sizing: border-box;
    }
    .pac-picker-list { max-height: 160px; overflow-y: auto; }
    .pac-picker-item {
        display: flex; align-items: center; gap: .5rem; padding: .375rem .625rem;
        cursor: pointer; transition: background .1s;
    }
    .pac-picker-item:hover { background: rgba(99,102,241,.06); }
    .pac-picker-item input[type=checkbox] { cursor: pointer; accent-color: #6366f1; }
    .pac-picker-item label { font-size: .8125rem; cursor: pointer; color: var(--text-primary, #0f172a); }
    .pac-picker-empty { padding: .75rem .625rem; font-size: .8125rem; color: var(--text-muted, #94a3b8); }

    /* Footer */
    .pac-footer {
        padding: 1rem 1.5rem; border-top: 1px solid var(--border-subtle, #e2e8f0);
        display: flex; align-items: center; gap: .75rem;
        background: var(--surface-elevated, #f8fafc);
    }
    .pac-save-btn {
        padding: .5rem 1.125rem; border-radius: 8px; border: 0;
        background: #6366f1; color: #fff; font-size: .875rem; font-weight: 600;
        cursor: pointer; transition: background .12s, opacity .12s;
    }
    .pac-save-btn:hover { background: #4f46e5; }
    .pac-save-btn:disabled { opacity: .6; cursor: default; }
    .pac-status { font-size: .8125rem; color: var(--text-muted, #94a3b8); }
    .pac-status.ok   { color: #059669; }
    .pac-status.err  { color: #dc2626; }

    body.app-theme-dark .pac-left { background: var(--app-surface-alt, #0f172a); }
    body.app-theme-dark .pac-right { background: var(--app-surface, #111827); }
    body.app-theme-dark .pac-search,
    body.app-theme-dark .pac-picker-search { background: var(--app-surface, #111827); color: var(--text-primary, #e2e8f0); }
    body.app-theme-dark .pac-picker { background: var(--app-surface, #111827); }
    body.app-theme-dark .pac-footer { background: var(--app-surface-alt, #0f172a); }
    body.app-theme-dark .pac-mode-btn { color: var(--text-muted, #94a3b8); border-color: rgba(255,255,255,.1); }
    body.app-theme-dark .pac-mode-btn.selected { border-color: #818cf8; background: rgba(99,102,241,.15); color: #818cf8; }
    body.app-theme-dark .pac-editor-title { color: var(--text-primary, #e2e8f0); }
    body.app-theme-dark .pac-item { color: var(--text-primary, #e2e8f0); }
    body.app-theme-dark .pac-picker-item label { color: var(--text-primary, #e2e8f0); }
</style>

@Html.AntiForgeryToken()

<div class="pac-host" id="pac">
    <div class="pac-left">
        <div class="pac-left-header">
            <p class="pac-left-title">Panolar</p>
            <input class="pac-search" type="search" placeholder="Pano ara…" id="pac-search" autocomplete="off"/>
        </div>
        <div class="pac-list" id="pac-list">
            <p style="padding:.75rem .5rem;font-size:.8125rem;color:var(--text-muted,#94a3b8)">Yükleniyor…</p>
        </div>
    </div>

    <div class="pac-right" id="pac-right">
        <div class="pac-empty" id="pac-empty">Düzenlemek için sol listeden bir pano seçin.</div>
        <div style="display:none;flex:1 1 auto;flex-direction:column;overflow:hidden" id="pac-editor-wrap">
            <div class="pac-editor" id="pac-editor">
                <div>
                    <h1 class="pac-editor-title" id="pac-title"></h1>
                    <p class="pac-editor-folder" id="pac-folder"></p>
                </div>

                <div>
                    <p class="pac-section-label">Erişim Türü</p>
                    <div class="pac-mode">
                        <button type="button" class="pac-mode-btn selected" id="btn-open" onclick="setMode('open')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="m9 12 2 2 4-4"/></svg>
                            Herkese Açık
                        </button>
                        <button type="button" class="pac-mode-btn" id="btn-limit" onclick="setMode('limited')">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            Kısıtlı Erişim
                        </button>
                    </div>
                </div>

                <div id="pac-restricted-section" style="display:none;flex-direction:column;gap:1rem">
                    <div>
                        <p class="pac-section-label">Kullanıcılar</p>
                        <div class="pac-picker">
                            <input class="pac-picker-search" type="search" placeholder="Kullanıcı ara…"
                                   id="user-search" oninput="filterPicker('user-list','user-search')"/>
                            <div class="pac-picker-list" id="user-list"></div>
                        </div>
                    </div>
                    <div>
                        <p class="pac-section-label">Departmanlar</p>
                        <div class="pac-picker">
                            <input class="pac-picker-search" type="search" placeholder="Departman ara…"
                                   id="dept-search" oninput="filterPicker('dept-list','dept-search')"/>
                            <div class="pac-picker-list" id="dept-list"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pac-footer">
                <button type="button" class="pac-save-btn" id="pac-save" onclick="save()">Kaydet</button>
                <span class="pac-status" id="pac-status"></span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var state = { dashboards: [], users: [], departments: [], selected: null, mode: 'open' };
    var TOKEN = document.querySelector('input[name=__RequestVerificationToken]')?.value ?? '';

    /* ── Yükleme ── */
    fetch('/Dashboard/GetAllDashboardAccess', { credentials: 'same-origin' })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            state.dashboards  = data.dashboards  || [];
            state.users       = data.users       || [];
            state.departments = data.departments || [];
            renderList(state.dashboards);
            renderPickers();
        })
        .catch(function () {
            document.getElementById('pac-list').innerHTML =
                '<p style="padding:.75rem .5rem;font-size:.8125rem;color:#dc2626">Yüklenemedi.</p>';
        });

    /* ── Liste ── */
    function renderList(items) {
        var listEl = document.getElementById('pac-list');
        listEl.innerHTML = '';
        if (!items.length) {
            listEl.innerHTML = '<p style="padding:.75rem .5rem;font-size:.8125rem;color:var(--text-muted,#94a3b8)">Pano bulunamadı.</p>';
            return;
        }
        var groups = {}, order = [];
        items.forEach(function (d) {
            var g = d.folderTitle || 'Genel';
            if (!groups[g]) { groups[g] = []; order.push(g); }
            groups[g].push(d);
        });
        order.forEach(function (g) {
            var title = document.createElement('p');
            title.className = 'pac-folder-title';
            title.textContent = g;
            listEl.appendChild(title);
            groups[g].forEach(function (d) { listEl.appendChild(buildItem(d)); });
        });
    }

    function buildItem(d) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'pac-item' + (state.selected?.grafanaUid === d.grafanaUid ? ' active' : '');
        btn.dataset.uid = d.grafanaUid;
        var badge = d.isRestricted
            ? '<span class="pac-badge pac-badge--limit">Kısıtlı</span>'
            : '<span class="pac-badge pac-badge--open">Açık</span>';
        btn.innerHTML = '<span class="pac-item-name">' + esc(d.title) + '</span>' + badge;
        btn.addEventListener('click', function () { selectDashboard(d); });
        return btn;
    }

    function selectDashboard(d) {
        state.selected = d;
        document.querySelectorAll('.pac-item').forEach(function (el) {
            el.classList.toggle('active', el.dataset.uid === d.grafanaUid);
        });
        document.getElementById('pac-title').textContent  = d.title;
        document.getElementById('pac-folder').textContent = d.folderTitle ? '📁 ' + d.folderTitle : '';
        setMode(d.isRestricted ? 'limited' : 'open', true);
        setChecked('user-list',  d.allowedUserIds       || []);
        setChecked('dept-list', d.allowedDepartmentIds || []);
        document.getElementById('pac-empty').style.display       = 'none';
        document.getElementById('pac-editor-wrap').style.display = 'flex';
        document.getElementById('pac-status').textContent = '';
        document.getElementById('pac-status').className   = 'pac-status';
    }

    /* ── Picker'lar ── */
    function renderPickers() {
        renderPickerItems('user-list', state.users, 'fullName', []);
        renderPickerItems('dept-list', state.departments, 'name', []);
    }

    function renderPickerItems(listId, items, labelKey, checkedIds) {
        var el = document.getElementById(listId);
        el.innerHTML = '';
        if (!items.length) {
            el.innerHTML = '<p class="pac-picker-empty">Kayıt bulunamadı.</p>';
            return;
        }
        items.forEach(function (item) {
            var row = document.createElement('div');
            row.className = 'pac-picker-item';
            var cb = document.createElement('input');
            cb.type = 'checkbox'; cb.id = listId + '-' + item.id;
            cb.value = item.id; cb.checked = checkedIds.indexOf(item.id) !== -1;
            var lbl = document.createElement('label');
            lbl.htmlFor = cb.id; lbl.textContent = item[labelKey];
            row.appendChild(cb); row.appendChild(lbl);
            el.appendChild(row);
        });
    }

    function setChecked(listId, ids) {
        document.querySelectorAll('#' + listId + ' input[type=checkbox]').forEach(function (cb) {
            cb.checked = ids.indexOf(parseInt(cb.value)) !== -1;
        });
    }

    function filterPicker(listId, searchId) {
        var q = document.getElementById(searchId).value.toLowerCase();
        document.querySelectorAll('#' + listId + ' .pac-picker-item').forEach(function (row) {
            row.style.display = !q || row.textContent.toLowerCase().indexOf(q) !== -1 ? '' : 'none';
        });
    }
    window.filterPicker = filterPicker;

    /* ── Mod toggle ── */
    function setMode(mode, skipSection) {
        state.mode = mode;
        document.getElementById('btn-open').classList.toggle('selected', mode === 'open');
        document.getElementById('btn-limit').classList.toggle('selected', mode === 'limited');
        if (!skipSection) {
            var sec = document.getElementById('pac-restricted-section');
            sec.style.display = mode === 'limited' ? 'flex' : 'none';
        } else {
            document.getElementById('pac-restricted-section').style.display = mode === 'limited' ? 'flex' : 'none';
        }
    }
    window.setMode = setMode;

    /* ── Kaydet ── */
    function save() {
        if (!state.selected) return;
        var saveBtn  = document.getElementById('pac-save');
        var statusEl = document.getElementById('pac-status');
        saveBtn.disabled = true;
        statusEl.textContent = 'Kaydediliyor…';
        statusEl.className   = 'pac-status';

        var userIds = [], deptIds = [];
        if (state.mode === 'limited') {
            document.querySelectorAll('#user-list input:checked').forEach(function (cb) { userIds.push(parseInt(cb.value)); });
            document.querySelectorAll('#dept-list input:checked').forEach(function (cb) { deptIds.push(parseInt(cb.value)); });
        }

        fetch('/Dashboard/SetDashboardAccess', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': TOKEN },
            body: JSON.stringify({ grafanaUid: state.selected.grafanaUid, userIds: userIds, departmentIds: deptIds })
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            if (res.ok) {
                statusEl.textContent = 'Kaydedildi.';
                statusEl.className   = 'pac-status ok';
                // Lokal state güncelle ve listede badge yenile
                state.selected.isRestricted         = state.mode === 'limited';
                state.selected.allowedUserIds        = userIds;
                state.selected.allowedDepartmentIds  = deptIds;
                // Listedeki badge'i bul ve güncelle
                var btn = document.querySelector('.pac-item[data-uid="' + state.selected.grafanaUid + '"]');
                if (btn) {
                    var badge = btn.querySelector('.pac-badge');
                    if (badge) {
                        badge.className   = 'pac-badge ' + (state.selected.isRestricted ? 'pac-badge--limit' : 'pac-badge--open');
                        badge.textContent = state.selected.isRestricted ? 'Kısıtlı' : 'Açık';
                    }
                }
            } else {
                statusEl.textContent = 'Hata: ' + (res.error || 'Bilinmeyen hata');
                statusEl.className   = 'pac-status err';
            }
        })
        .catch(function () {
            statusEl.textContent = 'Bağlantı hatası.';
            statusEl.className   = 'pac-status err';
        })
        .finally(function () {
            saveBtn.disabled = false;
        });
    }
    window.save = save;

    /* ── Pano listesi arama ── */
    document.getElementById('pac-search').addEventListener('input', function () {
        var q = this.value.toLowerCase();
        if (!q) { renderList(state.dashboards); return; }
        renderList(state.dashboards.filter(function (d) {
            return d.title.toLowerCase().indexOf(q) !== -1 ||
                   (d.folderTitle || '').toLowerCase().indexOf(q) !== -1;
        }));
    });

    function esc(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
})();
</script>
}
