@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"]     = "Rapor";
    ViewData["BodyClass"] = "page-report-viewer";
    var designId  = (int)(ViewData["DesignId"] ?? 0);
    var csrfToken = Antiforgery.GetAndStoreTokens(Context).RequestToken ?? "";
}

<meta name="csrf-token" content="@csrfToken" />

<div id="reportViewerRoot" style="position:fixed;inset:0;z-index:1;"></div>

@section Scripts {
<script>
(function() {
    var BUNDLE_URL = '@FileVersionProvider.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js")';
    var CSS_URL    = '@FileVersionProvider.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css")';
    var el        = document.getElementById('reportViewerRoot');
    var DESIGN_ID = @designId;

    function doMount() {
        if (!window.CalibraHub || !window.CalibraHub.mountReportViewer) {
            el.innerHTML = '<div style="padding:2rem;color:#f87171;">mountReportViewer yüklenemedi</div>';
            return;
        }
        window.CalibraHub.mountReportViewer(el, {
            loadUrl: '/Dashboard/LoadView/' + DESIGN_ID,
            editUrl: '/Dashboard/DesignerEdit?load=' + DESIGN_ID,
        });
    }

    function loadCss() {
        if (document.querySelector('link[data-rd-bundle]')) return;
        var link = document.createElement('link');
        link.rel = 'stylesheet'; link.href = CSS_URL;
        link.setAttribute('data-rd-bundle', '1');
        document.head.appendChild(link);
    }

    function loadScript(cb) {
        if (document.querySelector('script[data-rd-bundle]')) { cb(); return; }
        var s = document.createElement('script');
        s.src = BUNDLE_URL;
        s.setAttribute('data-rd-bundle', '1');
        s.onload  = function() { setTimeout(cb, 0); };
        s.onerror = function() { el.innerHTML = '<div style="padding:2rem;color:#f87171;">Bundle yüklenemedi</div>'; };
        document.head.appendChild(s);
    }

    loadCss();
    if (window.CalibraHub && window.CalibraHub.mountReportViewer) {
        doMount();
    } else {
        loadScript(doMount);
    }
})();
</script>
}
