@model IReadOnlyCollection<CalibraHub.Domain.Entities.DesignTemplate>
@{
    ViewBag.Title       = "Şablon Tasarımcısı";
    ViewBag.PageTitle   = "Şablon Tasarımcısı";
    var filterType      = (string)(ViewBag.FilterType    ?? string.Empty);
    var filterSubType   = (string)(ViewBag.FilterSubType ?? string.Empty);

    // Belge alt türleri tanımları
    var docSubTypes = new (string Key, string Label, string Emoji)[]
    {
        ("sales_order",    "Satış Siparişi",       "🛒"),
        ("purchase_order", "Satın Alma Siparişi",  "📦"),
        ("sales_request",  "Satış Talebi",         "📋"),
        ("sales_offer",    "Satış Teklifi",        "📝"),
        ("invoice",        "Fatura",               "🧾"),
        ("delivery_note",  "İrsaliye",             "🚚"),
    };

    string SubTypeLabel(string? key) => key == null ? string.Empty
        : docSubTypes.FirstOrDefault(x => x.Key == key).Label ?? key;
}

@section Styles {
<style>
.designer-type-filter {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    align-items: center;
}

.type-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.74rem;
    font-weight: 600;
    border: 1px solid transparent;
}
.type-badge.document { background: #dbeafe; color: #1d4ed8; border-color: #bfdbfe; }
.type-badge.email    { background: #dcfce7; color: #15803d; border-color: #bbf7d0; }
.type-badge.report   { background: #fef9c3; color: #92400e; border-color: #fde68a; }
.type-badge.dashboard{ background: #f3e8ff; color: #6b21a8; border-color: #e9d5ff; }

.subtype-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 600;
    background: #f0f9ff;
    color: #0369a1;
    border: 1px solid #bae6fd;
}

.designer-subtype-filter {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
    padding: 8px 0 2px;
    border-top: 1px solid #f1f5f9;
    margin-top: 4px;
}

.designer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    padding: 4px 0;
}

.designer-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: box-shadow 0.15s, border-color 0.15s;
}
.designer-card:hover {
    box-shadow: 0 4px 16px rgba(15,23,42,0.10);
    border-color: #c7d7f0;
}

.designer-card__header {
    display: flex;
    align-items: flex-start;
    gap: 10px;
}

.designer-card__icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
}
.designer-card__icon.document { background: #dbeafe; }
.designer-card__icon.email    { background: #dcfce7; }
.designer-card__icon.report   { background: #fef9c3; }
.designer-card__icon.dashboard{ background: #f3e8ff; }

.designer-card__info { min-width: 0; flex: 1; }
.designer-card__name { font-weight: 700; font-size: 0.9rem; color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.designer-card__desc { font-size: 0.78rem; color: #64748b; margin-top: 2px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

.designer-card__meta { font-size: 0.72rem; color: #94a3b8; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.designer-card__actions { display: flex; gap: 8px; margin-top: 4px; }

.designer-empty {
    text-align: center;
    padding: 60px 20px;
    color: #94a3b8;
}
.designer-empty svg { opacity: 0.35; margin-bottom: 12px; }
.designer-empty p { font-size: 0.9rem; }
</style>
}

@{
    var newType    = string.IsNullOrEmpty(filterType)    ? "document" : filterType;
    var newSubType = string.IsNullOrEmpty(filterSubType) ? null       : filterSubType;
    bool isAll      = string.IsNullOrEmpty(filterType) && string.IsNullOrEmpty(filterSubType);
    bool isDocument = filterType == "document" && string.IsNullOrEmpty(filterSubType);
    bool isEmail    = filterType == "email";
    bool isReport   = filterType == "report";
    bool isDashboard= filterType == "dashboard";
}
<div class="workspace-action-bar" data-workspace-action-bar>
    <div class="workspace-action-bar__primary">
        <div class="entity-form-toolbar">
            <a asp-action="New" asp-route-type="@newType" asp-route-subType="@newSubType"
               class="btn btn-secondary integrator-btn-secondary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M12 5v14M5 12h14"/></svg>
                Yeni Şablon
            </a>
        </div>
    </div>
    @if (isAll)
    {
        <div class="workspace-action-bar__secondary">
            <div class="designer-type-filter">
                <a asp-action="Index"
                   class="btn btn-sm btn-primary">Tümü</a>
                <a asp-action="Index" asp-route-type="document"
                   class="btn btn-sm btn-outline-secondary">📄 Belgeler</a>
                <a asp-action="Index" asp-route-type="email"
                   class="btn btn-sm btn-outline-secondary">📧 E-postalar</a>
                <a asp-action="Index" asp-route-type="report"
                   class="btn btn-sm btn-outline-secondary">📊 Raporlar</a>
                <a asp-action="Index" asp-route-type="dashboard"
                   class="btn btn-sm btn-outline-secondary">🖥️ Dashboard</a>
            </div>
        </div>
    }
</div>

<div class="integrator-dashboard__content" style="padding: 20px 24px;">

    @if (!Model.Any())
    {
        <div class="designer-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="64" height="64">
                <rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 21V9"/>
            </svg>
            <p>Henüz şablon oluşturulmamış.</p>
            <a asp-action="New" asp-route-type="@newType" asp-route-subType="@newSubType"
               class="btn btn-primary btn-sm mt-2">İlk Şablonu Oluştur</a>
        </div>
    }
    else
    {
        <div class="designer-grid">
            @foreach (var t in Model)
            {
                var icon = t.Type switch { "email" => "📧", "report" => "📊", "dashboard" => "🖥️", _ => "📄" };
                <div class="designer-card">
                    <div class="designer-card__header">
                        <div class="designer-card__icon @t.Type">@icon</div>
                        <div class="designer-card__info">
                            <div class="designer-card__name" title="@t.Name">@t.Name</div>
                            @if (!string.IsNullOrWhiteSpace(t.Description))
                            {
                                <div class="designer-card__desc">@t.Description</div>
                            }
                        </div>
                    </div>
                    <div class="designer-card__meta">
                        @if (!string.IsNullOrWhiteSpace(t.SubType))
                        {
                            <span class="subtype-badge">@SubTypeLabel(t.SubType)</span>
                        }
                        <span>Güncellendi: @t.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <div class="designer-card__actions">
                        <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-primary flex-fill">
                            ✏️ Düzenle
                        </a>
                        <a asp-action="Preview" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary" target="_blank">
                            👁️
                        </a>
                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="tdDelete('@t.Id', this)">🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
function tdDelete(id, btn) {
    if (!confirm("Bu şablonu silmek istiyor musunuz?")) return;
    btn.disabled = true;
    fetch("/TemplateDesigner/DeleteJson?id=" + id, { method: "POST" })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) {
                var card = btn.closest(".designer-card");
                if (card) card.remove();
            } else {
                alert(d.message || "Silinemedi.");
                btn.disabled = false;
            }
        })
        .catch(function() { btn.disabled = false; });
}
</script>
}