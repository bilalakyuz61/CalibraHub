@model CalibraHub.Domain.Entities.DesignTemplate
@{
    Layout = null; // Standalone sayfa — header/footer yok
}<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Önizleme — @Model.Name</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
    body { margin: 0; padding: 0; background: #f8fafc; }
    .preview-bar {
        position: fixed; top: 0; left: 0; right: 0;
        height: 44px; background: #1e293b; color: #f8fafc;
        display: flex; align-items: center; gap: 12px; padding: 0 16px;
        font-size: 0.82rem; z-index: 1000; border-bottom: 1px solid rgba(148,163,184,0.2);
        print-color-adjust: exact; -webkit-print-color-adjust: exact;
    }
    @@media print { .preview-bar { display: none; } body { padding-top: 0 !important; } }
    .preview-bar__title { font-weight: 600; }
    .preview-bar__type  { font-size: 0.72rem; background: rgba(59,130,246,0.2); color: #93c5fd; padding: 2px 8px; border-radius: 20px; }
    .preview-content { padding-top: 44px; }
    @if (!string.IsNullOrWhiteSpace(Model.CssContent))
    {
        @Html.Raw("<style>" + Model.CssContent + "</style>")
    }
    </style>
</head>
<body>
    <div class="preview-bar">
        <button onclick="window.close()" style="background:none;border:none;color:#94a3b8;cursor:pointer;padding:4px 8px;border-radius:6px;border:1px solid rgba(148,163,184,0.3)">✕ Kapat</button>
        <span class="preview-bar__title">@Model.Name</span>
        <span class="preview-bar__type">@Model.Type</span>
        <span style="margin-left:auto;color:#64748b">@Model.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</span>
        <button onclick="window.print()" style="background:#2563eb;color:#fff;border:none;border-radius:6px;padding:4px 14px;cursor:pointer;font-size:0.78rem;font-weight:600">🖨️ Yazdır</button>
    </div>
    <div class="preview-content">
        @Html.Raw(Model.HtmlContent ?? "<p style='padding:40px;color:#64748b;text-align:center'>Bu şablonda henüz içerik yok.</p>")
    </div>
</body>
</html>
