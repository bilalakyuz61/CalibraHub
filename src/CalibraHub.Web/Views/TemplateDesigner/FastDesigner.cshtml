@section Scripts {
<script>
(function () {
    // Cetvel etiketleri (cm)
    var hLabels = document.getElementById('frdRulerHLabels');
    var vLabels = document.getElementById('frdRulerVLabels');
    if (hLabels) {
        var html = '';
        for (var i = 0; i <= 28; i++) {
            html += '<div class="frd-ruler-h__label">' + i + '</div>';
        }
        hLabels.innerHTML = html;
    }
    if (vLabels) {
        var v = '';
        for (var j = 0; j <= 30; j++) {
            v += '<div class="frd-ruler-v__label">' + j + '</div>';
        }
        vLabels.innerHTML = v;
    }

    // Loader: tarayici sayfayi tamamen yukledikten kisa bir sure sonra gizle
    function hideLoader() {
        var loader = document.getElementById('frdLoader');
        if (!loader) return;
        loader.classList.add('is-hidden');
        setTimeout(function () { loader.style.display = 'none'; }, 320);
    }
    if (document.readyState === 'complete') {
        setTimeout(hideLoader, 350);
    } else {
        window.addEventListener('load', function () {
            setTimeout(hideLoader, 350);
        });
    }
})();
</script>
}
