@section Styles {
<style>
/* ============= FastReport-benzeri tasarim ekrani =============== */
.frd-root {
    --frd-bg:        #d6d3cd;
    --frd-panel:     #ebeae4;
    --frd-panel-2:   #f3f2ee;
    --frd-border:    #b5b1a8;
    --frd-border-soft:#cbc7be;
    --frd-text:      #1a1a1a;
    --frd-muted:     #5d5a52;
    --frd-band:      linear-gradient(180deg,#e8a358 0%,#c8782a 100%);
    --frd-band-text: #fff;
    --frd-canvas:    #ffffff;
    --frd-ruler:     #f0eee8;
    --frd-ruler-text:#3b3b3b;
    --frd-accent:    #1976d2;
    --frd-icon:      #4a4a4a;

    display: flex;
    flex-direction: column;
    height: calc(100dvh - var(--layout-header-height) - var(--layout-footer-height));
    background: var(--frd-bg);
    color: var(--frd-text);
    font-family: "Segoe UI", Tahoma, Arial, sans-serif;
    font-size: 12px;
    overflow: hidden;
    user-select: none;
    position: relative;
}

/* ----- Title bar ----- */
.frd-title {
    display: flex; align-items: center; gap: 8px;
    height: 24px; padding: 0 8px;
    background: linear-gradient(180deg,#3a6ea5 0%,#1f4e79 100%);
    color: #fff; font-size: 12px; font-weight: 500;
}
.frd-title__icon {
    width: 14px; height: 14px; border-radius: 2px;
    background: linear-gradient(135deg,#fbbf24 0%,#dc2626 100%);
    flex-shrink: 0;
}
.frd-title__win {
    margin-left: auto; display: flex; gap: 0;
}
.frd-title__win span {
    width: 32px; height: 22px; display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: 11px;
}
.frd-title__win span:hover { background: rgba(255,255,255,.18); }
.frd-title__win span.close:hover { background: #e81123; }

/* ----- Menubar ----- */
.frd-menubar {
    display: flex; align-items: center;
    height: 24px; padding: 0 4px;
    background: var(--frd-panel);
    border-bottom: 1px solid var(--frd-border);
}
.frd-menubar__item {
    padding: 3px 10px; font-size: 12px; cursor: pointer;
    border: 1px solid transparent;
}
.frd-menubar__item:hover { background: #fff; border-color: var(--frd-border-soft); }

/* ----- Toolbars ----- */
.frd-toolbars {
    background: var(--frd-panel);
    border-bottom: 1px solid var(--frd-border);
    padding: 3px 4px;
    display: flex; flex-direction: column; gap: 3px;
}
.frd-toolbar {
    display: flex; align-items: center; gap: 1px; flex-wrap: wrap;
}
.frd-tbtn {
    width: 22px; height: 22px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--frd-icon);
    cursor: pointer; border: 1px solid transparent;
    font-size: 12px; line-height: 1;
}
.frd-tbtn:hover { background: #fff; border-color: var(--frd-border-soft); }
.frd-tbtn.is-active { background: #fff; border-color: var(--frd-border); }
.frd-tbtn.disabled { opacity: 0.4; cursor: default; }
.frd-tbtn-wide {
    width: auto; padding: 0 6px; gap: 4px;
}
.frd-tbtn-color {
    position: relative;
}
.frd-tbtn-color::after {
    content: ""; position: absolute; left: 3px; right: 3px; bottom: 2px;
    height: 3px; background: currentColor;
}
.frd-sep {
    width: 1px; height: 18px; background: var(--frd-border-soft); margin: 0 3px;
}
.frd-combo {
    height: 22px; padding: 0 6px; min-width: 90px;
    background: #fff; border: 1px solid var(--frd-border-soft); font-size: 12px;
    display: inline-flex; align-items: center; justify-content: space-between; gap: 4px;
}
.frd-combo small { color: var(--frd-muted); }
.frd-combo.frd-combo-num { min-width: 56px; }
.frd-combo.frd-combo-zoom { min-width: 64px; }

/* ----- Tabs (Code | Data | Page1) ----- */
.frd-tabs {
    display: flex; align-items: flex-end;
    background: var(--frd-panel);
    padding: 2px 6px 0;
    border-bottom: 1px solid var(--frd-border);
    height: 22px;
}
.frd-tab {
    padding: 2px 12px; font-size: 12px; cursor: pointer;
    border: 1px solid var(--frd-border-soft); border-bottom: none;
    background: var(--frd-panel-2); color: var(--frd-muted);
    margin-right: 1px;
    border-radius: 3px 3px 0 0;
}
.frd-tab.is-active {
    background: #fff; color: var(--frd-text);
    border-color: var(--frd-border);
    position: relative; top: 1px;
    padding-bottom: 3px;
}

/* ----- Body grid: left | left-tree | center | right ----- */
.frd-body {
    flex: 1 1 0; min-height: 0;
    display: grid;
    grid-template-columns: 28px 240px 1fr 230px;
    overflow: hidden;
}

/* ----- Toolbox (sol kenar – dikey iconlar) ----- */
.frd-toolbox {
    background: var(--frd-panel);
    border-right: 1px solid var(--frd-border);
    display: flex; flex-direction: column; align-items: center;
    padding: 4px 0; gap: 1px;
}
.frd-toolbox .frd-tbtn { width: 24px; height: 24px; }
.frd-toolbox .frd-sep { width: 18px; height: 1px; margin: 3px 0; }

/* ----- Sol kompozit panel: Object Inspector + Report Tree ----- */
.frd-leftpanel {
    background: var(--frd-panel);
    border-right: 1px solid var(--frd-border);
    display: flex; flex-direction: column;
    min-height: 0; overflow: hidden;
}
.frd-pan {
    display: flex; flex-direction: column;
    background: #fff;
    border: 1px solid var(--frd-border);
    margin: 4px;
    min-height: 0; overflow: hidden;
}
.frd-pan + .frd-pan { margin-top: 0; }
.frd-pan__head {
    display: flex; align-items: center; justify-content: space-between;
    height: 22px; padding: 0 6px;
    background: linear-gradient(180deg,#f3f2ee 0%,#dcd9d2 100%);
    border-bottom: 1px solid var(--frd-border-soft);
    font-size: 12px; font-weight: 500;
}
.frd-pan__head .frd-pan__close {
    width: 14px; height: 14px; display: inline-flex; align-items: center; justify-content: center;
    color: var(--frd-muted); cursor: pointer; font-size: 12px; line-height: 1;
}
.frd-pan__head .frd-pan__close:hover { color: #c00; }
.frd-pan__body {
    flex: 1 1 0; min-height: 0; overflow: auto;
}

/* Object Inspector */
.frd-oi__selector {
    display: flex; align-items: center; gap: 4px;
    padding: 4px 6px;
    border-bottom: 1px solid var(--frd-border-soft);
    background: var(--frd-panel-2);
}
.frd-oi__selector .frd-combo { flex: 1; }
.frd-oi__list { font-size: 12px; }
.frd-oi__row {
    display: grid; grid-template-columns: 110px 1fr;
    border-bottom: 1px solid #e4e2dc;
    height: 19px; align-items: center;
}
.frd-oi__row:hover { background: #f3f8ff; }
.frd-oi__row.is-bold .frd-oi__key { font-weight: 700; }
.frd-oi__key {
    padding: 0 6px;
    color: var(--frd-text);
    border-right: 1px solid #e4e2dc;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.frd-oi__val {
    padding: 0 6px;
    color: #1f3b66;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

/* Report Tree */
.frd-tree { padding: 4px 2px; font-size: 12px; }
.frd-tree__node {
    display: flex; align-items: center; gap: 4px;
    padding: 1px 4px; cursor: default; line-height: 18px;
}
.frd-tree__node:hover { background: #f3f8ff; }
.frd-tree__node.is-selected { background: #cfe3ff; }
.frd-tree__caret {
    width: 10px; display: inline-flex; justify-content: center; color: var(--frd-muted);
    font-size: 9px;
}
.frd-tree__icon {
    width: 14px; height: 14px; display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.frd-tree__icon.report { color: #b25612; }
.frd-tree__icon.data   { color: #2563eb; }
.frd-tree__icon.page   { color: #f59e0b; }
.frd-tree__icon.band   { color: #c8782a; }
.frd-tree__indent { display: inline-block; width: 0; }
.frd-tree__node[data-level="1"] .frd-tree__indent { width: 12px; }
.frd-tree__node[data-level="2"] .frd-tree__indent { width: 24px; }
.frd-tree__node[data-level="3"] .frd-tree__indent { width: 36px; }

/* ----- Center: ruler + canvas ----- */
.frd-center {
    display: grid;
    grid-template-columns: 22px 1fr;
    grid-template-rows: 22px 1fr;
    background: var(--frd-bg);
    min-width: 0; min-height: 0;
    overflow: hidden;
}
.frd-corner {
    background: var(--frd-ruler);
    border-right: 1px solid var(--frd-border);
    border-bottom: 1px solid var(--frd-border);
}
.frd-ruler-h, .frd-ruler-v {
    background: var(--frd-ruler);
    color: var(--frd-ruler-text);
    font-size: 9px;
    position: relative;
    overflow: hidden;
}
.frd-ruler-h { border-bottom: 1px solid var(--frd-border); }
.frd-ruler-v { border-right: 1px solid var(--frd-border); }
.frd-ruler-h__inner {
    height: 100%;
    background-image:
        linear-gradient(to right, #888 0 1px, transparent 1px 100%),
        linear-gradient(to right, #aaa 0 1px, transparent 1px 100%);
    background-size: 37.8px 100%, 7.56px 8px;
    background-position: 22px 12px, 22px bottom;
    background-repeat: repeat-x;
    position: relative;
}
.frd-ruler-h__labels {
    position: absolute; inset: 0;
    display: flex; align-items: flex-end; padding-bottom: 1px;
}
.frd-ruler-h__label {
    width: 37.8px; text-align: center; flex: 0 0 37.8px;
}
.frd-ruler-h__label:first-child { padding-left: 4px; text-align: left; }
.frd-ruler-v__inner {
    width: 100%; height: 100%;
    background-image:
        linear-gradient(to bottom, #888 0 1px, transparent 1px 100%),
        linear-gradient(to bottom, #aaa 0 1px, transparent 1px 100%);
    background-size: 100% 37.8px, 8px 7.56px;
    background-position: left 0, right 0;
    background-repeat: repeat-y;
    position: relative;
}
.frd-ruler-v__labels {
    position: absolute; inset: 0;
}
.frd-ruler-v__label {
    height: 37.8px; width: 100%;
    text-align: center; padding-top: 2px;
    box-sizing: border-box;
}

/* Canvas zemini */
.frd-canvas-wrap {
    overflow: auto;
    background: var(--frd-bg);
    padding: 12px 16px 28px;
    position: relative;
}
.frd-canvas {
    --page-w: 794px;   /* A4: 21,00 cm × 37,8 px/cm */
    --page-h: 1123px;  /* A4: 29,70 cm × 37,8 px/cm */
    width: var(--page-w);
    min-height: var(--page-h);
    background: var(--frd-canvas);
    box-shadow: 0 0 0 1px var(--frd-border), 3px 3px 10px rgba(0,0,0,.22);
    margin: 0 auto;
    position: relative;
}
.frd-canvas__pageLabel {
    position: absolute;
    top: -22px; right: 0;
    font-size: 10px; color: var(--frd-muted);
    background: rgba(255,255,255,.72);
    padding: 1px 6px; border-radius: 2px;
    border: 1px solid var(--frd-border-soft);
    pointer-events: none;
}

/* ----- Loading overlay (spinner) ----- */
.frd-loader {
    position: absolute; inset: 0;
    background: rgba(214,211,205,.95);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 14px;
    z-index: 200;
    transition: opacity .25s ease;
}
.frd-loader.is-hidden { opacity: 0; pointer-events: none; }
.frd-loader__spinner {
    width: 38px; height: 38px;
    border: 3px solid #cbc7be;
    border-top-color: #1f4e79;
    border-radius: 50%;
    animation: frd-spin .85s linear infinite;
}
.frd-loader__text {
    font-size: 12px; color: #1f4e79; font-weight: 600;
    letter-spacing: .2px;
}
@@keyframes frd-spin { to { transform: rotate(360deg); } }

/* Bandlar */
.frd-band {
    position: relative;
    border-bottom: 1px dashed #b8b4ab;
}
.frd-band__head {
    display: flex; align-items: center; justify-content: space-between;
    height: 18px; padding: 0 8px;
    background: var(--frd-band);
    color: var(--frd-band-text);
    font-size: 11px; font-weight: 600;
    text-shadow: 0 1px 0 rgba(0,0,0,.18);
}
.frd-band__head small {
    font-weight: 400; opacity: .9;
}
.frd-band__head .frd-band__ds {
    display: inline-flex; align-items: center; gap: 4px;
    background: rgba(255,255,255,.18); padding: 1px 6px; border-radius: 3px;
    font-weight: 500; font-size: 10px;
}
.frd-band__body {
    position: relative;
    background:
        linear-gradient(#e6e3da 1px, transparent 1px) 0 0/100% 7.56px,
        linear-gradient(90deg, #e6e3da 1px, transparent 1px) 0 0/7.56px 100%;
}
.frd-band--master .frd-band__body { height: 23px; }
.frd-band--detail .frd-band__body { height: 23px; }

/* Secili band — mavi handle'lar */
.frd-band.is-selected .frd-band__body {
    outline: 1px solid var(--frd-accent);
    outline-offset: -1px;
}
.frd-handle {
    position: absolute;
    width: 5px; height: 5px;
    background: var(--frd-accent);
    border: 1px solid #fff;
    box-sizing: content-box;
}
.frd-handle.tl { top: -3px; left: -3px; }
.frd-handle.tm { top: -3px; left: calc(50% - 3px); }
.frd-handle.tr { top: -3px; right: -3px; }
.frd-handle.ml { top: calc(50% - 3px); left: -3px; }
.frd-handle.mr { top: calc(50% - 3px); right: -3px; }
.frd-handle.bl { bottom: -3px; left: -3px; }
.frd-handle.bm { bottom: -3px; left: calc(50% - 3px); }
.frd-handle.br { bottom: -3px; right: -3px; }

/* ----- Sag panel: Data Tree ----- */
.frd-rightpanel {
    background: var(--frd-panel);
    border-left: 1px solid var(--frd-border);
    display: flex; flex-direction: column;
    min-height: 0; overflow: hidden;
}
.frd-rt__tabs {
    display: flex; gap: 0;
    padding: 4px 6px 0;
    border-bottom: 1px solid var(--frd-border-soft);
    background: var(--frd-panel-2);
}
.frd-rt__tab {
    padding: 3px 10px; font-size: 12px;
    border: 1px solid var(--frd-border-soft); border-bottom: none;
    background: var(--frd-panel); color: var(--frd-muted);
    cursor: pointer; margin-right: 1px;
    border-radius: 3px 3px 0 0;
}
.frd-rt__tab.is-active {
    background: #fff; color: var(--frd-text);
    position: relative; top: 1px; padding-bottom: 4px;
}
.frd-rt__toolbar {
    display: flex; align-items: center; gap: 1px;
    padding: 3px 4px;
    background: var(--frd-panel);
    border-bottom: 1px solid var(--frd-border-soft);
}
.frd-rt__search {
    flex: 1; height: 20px; padding: 0 6px;
    background: #fff; border: 1px solid var(--frd-border-soft);
    font-size: 12px;
    background-image: radial-gradient(circle 4px, transparent 3px, #888 3px 4px, transparent 4px);
    background-position: right 4px center; background-repeat: no-repeat;
    padding-right: 18px;
}
.frd-rt__body {
    flex: 1 1 0; min-height: 0; overflow: auto;
    background: #fff;
    padding: 4px 0;
    font-size: 12px;
}
.frd-rt__node {
    display: flex; align-items: center; gap: 4px;
    padding: 1px 6px; cursor: default; line-height: 18px;
}
.frd-rt__node:hover { background: #f3f8ff; }
.frd-rt__node[data-level="1"] { padding-left: 16px; }
.frd-rt__node[data-level="2"] { padding-left: 32px; }
.frd-rt__caret {
    width: 10px; display: inline-flex; justify-content: center; color: var(--frd-muted);
    font-size: 9px;
}
.frd-rt__icon {
    width: 14px; height: 14px; display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0; font-size: 11px;
}
.frd-rt__icon.kind-A {
    background: #f3e8d4; color: #b25612; border: 1px solid #d8b87f;
    font-weight: 700;
}
.frd-rt__icon.kind-0 {
    background: #e8efff; color: #1f3b66; border: 1px solid #9bb6e6;
    font-weight: 700;
}
.frd-rt__icon.folder { color: #b88a2c; }

/* ----- Status bar ----- */
.frd-statusbar {
    display: flex; align-items: center; gap: 0;
    height: 22px;
    background: var(--frd-panel);
    border-top: 1px solid var(--frd-border);
    font-size: 11px; color: var(--frd-text);
    padding: 0;
}
.frd-statusbar__item {
    padding: 2px 10px;
    border-right: 1px solid var(--frd-border-soft);
    height: 100%;
    display: inline-flex; align-items: center;
    min-width: 100px;
}
.frd-statusbar__item:last-child { flex: 1; }

/* Scrollbar lightening */
.frd-pan__body::-webkit-scrollbar,
.frd-rt__body::-webkit-scrollbar,
.frd-canvas-wrap::-webkit-scrollbar { width: 14px; height: 14px; background: var(--frd-panel); }
.frd-pan__body::-webkit-scrollbar-thumb,
.frd-rt__body::-webkit-scrollbar-thumb,
.frd-canvas-wrap::-webkit-scrollbar-thumb { background: #b9b6ad; border: 2px solid var(--frd-panel); }
</style>
}

<div class="frd-root" id="frdRoot">

    <!-- Title bar -->
    <div class="frd-title">
        <span class="frd-title__icon"></span>
        <span>FastReport - Untitled.fr3</span>
        <span class="frd-title__win">
            <span title="Minimize">&#x2014;</span>
            <span title="Maximize">&#x25A1;</span>
            <span class="close" title="Close">&times;</span>
        </span>
    </div>

    <!-- Menu bar -->
    <div class="frd-menubar">
        <div class="frd-menubar__item">File</div>
        <div class="frd-menubar__item">Edit</div>
        <div class="frd-menubar__item">Report</div>
        <div class="frd-menubar__item">View</div>
        <div class="frd-menubar__item">Help</div>
    </div>

    <!-- Toolbars -->
    <div class="frd-toolbars">
        <!-- Toolbar 1: dosya / temel islem -->
        <div class="frd-toolbar">
            <span class="frd-tbtn" title="New">&#128462;</span>
            <span class="frd-tbtn" title="Open">&#128194;</span>
            <span class="frd-tbtn" title="Save">&#128190;</span>
            <span class="frd-sep"></span>
            <span class="frd-tbtn" title="Preview">&#128065;</span>
            <span class="frd-sep"></span>
            <span class="frd-tbtn" title="Cut">&#9986;</span>
            <span class="frd-tbtn" title="Copy">&#128203;</span>
            <span class="frd-tbtn" title="Paste">&#128203;</span>
            <span class="frd-sep"></span>
            <span class="frd-tbtn" title="Undo">&#8630;</span>
            <span class="frd-tbtn" title="Redo">&#8631;</span>
            <span class="frd-sep"></span>
