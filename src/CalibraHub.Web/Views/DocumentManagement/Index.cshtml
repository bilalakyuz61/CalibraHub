@using System.Text.Json
@using System.Globalization
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"]     = "Döküman Yönetimi";
    ViewData["FormCode"]  = "DOC_MANAGEMENT";
    ViewData["BodyClass"] = "page-docmgmt";
    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;

    // ── Blueprint hero stat-tile verisi ── zaten üretilmiş BoardConfigJson'dan (entities[].widgets)
    // türetilir; ek backend çağrısı YOK. Parse edilemezse hero sade (0) kalır, akış bozulmaz.
    var boardConfigJson = (string?)ViewBag.BoardConfigJson;
    int heroTotalDocs = 0, heroThisMonthDocs = 0, heroTotalVersions = 0;
    if (!string.IsNullOrEmpty(boardConfigJson))
    {
        try
        {
            using var cfgDoc = JsonDocument.Parse(boardConfigJson);
            if (cfgDoc.RootElement.TryGetProperty("entities", out var entitiesEl) && entitiesEl.ValueKind == JsonValueKind.Array)
            {
                heroTotalDocs = entitiesEl.GetArrayLength();
                var now = DateTime.Now;
                foreach (var ent in entitiesEl.EnumerateArray())
                {
                    if (!ent.TryGetProperty("widgets", out var widgetsEl) || widgetsEl.ValueKind != JsonValueKind.Array) continue;
                    foreach (var w in widgetsEl.EnumerateArray())
                    {
                        var wid = w.TryGetProperty("id", out var idEl) ? idEl.GetString() : null;
                        var val = w.TryGetProperty("value", out var valEl) ? valEl.GetString() : null;
                        if (string.IsNullOrEmpty(val)) continue;
                        if (wid == "w_version")
                        {
                            var numPart = val.TrimStart('v', 'V');
                            if (int.TryParse(numPart, out var vNum)) heroTotalVersions += vNum;
                        }
                        else if (wid == "w_date"
                            && DateTime.TryParseExact(val, "dd.MM.yyyy", CultureInfo.InvariantCulture, DateTimeStyles.None, out var dt)
                            && dt.Year == now.Year && dt.Month == now.Month)
                        {
                            heroThisMonthDocs++;
                        }
                    }
                }
            }
        }
        catch { /* board config parse edilemezse hero sade kalır */ }
    }
}

<style>
/* ── Blueprint Hero (Komuta Güvertesi teması — bkz. wwwroot/css/arge.css) ───── */
