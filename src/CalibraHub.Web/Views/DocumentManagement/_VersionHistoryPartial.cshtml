@model IReadOnlyCollection<CalibraHub.Domain.Entities.Attachment>
@{
    static string FmtSize(long b) => b < 1024*1024 ? $"{b/1024.0:F1} KB" : $"{b/(1024.0*1024):F2} MB";
}
<style>
.dm-vh { font-family:inherit; }
.dm-vh table { width:100%; border-collapse:collapse; font-size:0.84rem; }
.dm-vh th { padding:8px 10px; font-size:0.72rem; font-weight:700; text-transform:uppercase;
    letter-spacing:.05em; color:var(--bs-secondary-color,#64748b); border-bottom:2px solid var(--app-border,#e2e8f0);
    text-align:left; white-space:nowrap; }
.dm-vh td { padding:9px 10px; border-bottom:1px solid var(--app-border,#f1f5f9); vertical-align:middle; }
.dm-vh tr.dm-vh-active td { background:rgba(99,102,241,.05); }
.dm-vh .dm-vh-badge {
    display:inline-block; padding:2px 8px; border-radius:4px; font-size:0.72rem; font-weight:700;
}
.dm-vh .dm-vh-badge--active { background:rgba(34,197,94,.15); color:#15803d; }
.dm-vh .dm-vh-badge--old    { background:rgba(100,116,139,.12); color:#64748b; }
.dm-vh .dm-vh-badge--ver    { background:rgba(245,158,11,.15); color:#b45309; }
.dm-vh .dm-vh-dl {
    padding:4px 10px; border-radius:5px; font-size:0.78rem; font-weight:600;
    background:rgba(99,102,241,.1); color:#6366f1; text-decoration:none; white-space:nowrap;
}
.dm-vh .dm-vh-dl:hover { background:#6366f1; color:#fff; }
.dm-vh .dm-vh-empty { text-align:center; padding:28px; color:var(--bs-secondary-color,#64748b); font-size:0.88rem; }
body.app-theme-dark .dm-vh th { color:#94a3b8; border-color:#334155; }
body.app-theme-dark .dm-vh td { border-color:#1e293b; }
body.app-theme-dark .dm-vh tr.dm-vh-active td { background:rgba(99,102,241,.1); }
</style>

<div class="dm-vh">
@if (!Model.Any())
{
    <div class="dm-vh-empty">Versiyon geçmişi bulunamadı.</div>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Versiyon</th>
            <th>Durum</th>
            <th>Dosya Adı</th>
            <th>Boyut</th>
            <th>Tarih</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var a in Model)
        {
            <tr class="@(a.IsActive ? "dm-vh-active" : "")">
                <td><span class="dm-vh-badge dm-vh-badge--ver">v@a.RevisionNumber</span></td>
                <td>
                    @if (a.IsActive)
                    {
                        <span class="dm-vh-badge dm-vh-badge--active">Güncel</span>
                    }
                    else
                    {
                        <span class="dm-vh-badge dm-vh-badge--old">Eski</span>
                    }
                </td>
                <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@a.FileName">@a.FileName</td>
                <td style="white-space:nowrap;">@FmtSize(a.FileSize)</td>
                <td style="white-space:nowrap;">@a.Created.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <a class="dm-vh-dl" href="/DocumentManagement/Download/@a.Id" download="@a.FileName">↓ İndir</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
</div>
