    .pl-existing-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid rgba(255,255,255,.08); }
    body.app-theme-light .pl-existing-wrap { border-color: #e2e8f0; }
    .pl-existing-table { width: 100%; border-collapse: collapse; font-size: .78rem; }
    .pl-existing-table th {
