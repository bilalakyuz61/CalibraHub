    body.app-theme-light .pl-cancel-inline { border-color: #e2e8f0; color: #94a3b8; }
    .pl-cancel-inline:hover { background: rgba(255,255,255,.07); color: rgba(255,255,255,.6); }
    body.app-theme-light .pl-cancel-inline:hover { background: #f1f5f9; color: #475569; }

    /* ── Footer ── */
    .pl-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 10px 20px; flex-shrink: 0;
        background: rgba(15,15,26,.8); border-top: 1px solid rgba(255,255,255,.06);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    }
    body.app-theme-light .pl-footer { background: rgba(248,250,252,.95); border-top-color: #e2e8f0; }

    /* ── Toast bildirim — sag alt kose, slide-in/fade-out ── */
    .pl-toast-container {
        position: fixed; bottom: 22px; right: 22px;
        z-index: 10000;
        display: flex; flex-direction: column-reverse; gap: 10px;
        pointer-events: none; max-width: 420px;
    }
    .pl-toast {
        pointer-events: auto;
        background: #1f2937; color: rgba(255,255,255,.92);
        border-radius: 10px;
        padding: 12px 14px;
        display: flex; align-items: flex-start; gap: 10px;
        box-shadow: 0 10px 28px rgba(0,0,0,.4);
        border-left: 4px solid #6366f1;
        min-width: 280px;
        transform: translateX(20px); opacity: 0;
        transition: transform .25s ease, opacity .25s ease;
    }
    .pl-toast.is-in  { transform: translateX(0); opacity: 1; }
    .pl-toast.is-out { transform: translateX(20px); opacity: 0; }
    .pl-toast--success { border-left-color: #22c55e; }
    .pl-toast--error   { border-left-color: #ef4444; }
    .pl-toast--warning { border-left-color: #f59e0b; }
    .pl-toast--info    { border-left-color: #6366f1; }
    .pl-toast__icon {
        width: 26px; height: 26px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .9rem; flex-shrink: 0;
    }
    .pl-toast--success .pl-toast__icon { background: rgba(34,197,94,.18);  color: #4ade80; }
    .pl-toast--error   .pl-toast__icon { background: rgba(239,68,68,.18);  color: #f87171; }
    .pl-toast--warning .pl-toast__icon { background: rgba(245,158,11,.18); color: #fbbf24; }
    .pl-toast--info    .pl-toast__icon { background: rgba(99,102,241,.18); color: #a5b4fc; }
    .pl-toast__msg { flex: 1; font-size: .85rem; line-height: 1.45; padding-top: 2px; word-break: break-word; }
    .pl-toast__close {
        background: transparent; border: none; cursor: pointer;
        color: rgba(255,255,255,.55); font-size: 1.25rem; line-height: 1;
        padding: 0; width: 22px; height: 22px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 4px; flex-shrink: 0;
    }
    .pl-toast__close:hover { background: rgba(255,255,255,.1); color: rgba(255,255,255,.95); }

    body.app-theme-light .pl-toast {
        background: #ffffff; color: #1e293b;
        border: 1px solid #e2e8f0; box-shadow: 0 10px 28px rgba(15,23,42,.18);
    }
    body.app-theme-light .pl-toast__close        { color: #64748b; }
    body.app-theme-light .pl-toast__close:hover  { background: #f1f5f9; color: #1e293b; }

    /* ── Empty state ── */
    .pl-empty {
        text-align: center; padding: 28px 16px;
        font-size: .78rem; color: rgba(255,255,255,.3); font-style: italic;
    }
    body.app-theme-light .pl-empty { color: #94a3b8; }

    /* Delete modal */
    .pl-modal-backdrop {
        display: none; position: fixed; inset: 0; z-index: 9000;
        background: rgba(0,0,0,.6); backdrop-filter: blur(4px);
        align-items: center; justify-content: center;
    }
    .pl-modal-backdrop.is-open { display: flex; }
    .pl-modal {
        background: #181c2e; border: 1px solid rgba(255,255,255,.1);
        border-radius: 14px; padding: 24px; min-width: 300px; max-width: 380px;
        box-shadow: 0 24px 60px rgba(0,0,0,.5);
    }
    body.app-theme-light .pl-modal { background: #fff; border-color: #e2e8f0; }
    .pl-modal-title { font-size: .88rem; font-weight: 700; color: rgba(255,255,255,.88); margin-bottom: 8px; }
    body.app-theme-light .pl-modal-title { color: #1e293b; }
    .pl-modal-body { font-size: .78rem; color: rgba(255,255,255,.5); margin-bottom: 20px; line-height: 1.5; }
    body.app-theme-light .pl-modal-body { color: #64748b; }
    .pl-modal-actions { display: flex; justify-content: flex-end; gap: 8px; }
    .pl-btn--del { background: rgba(239,68,68,.12); border-color: rgba(239,68,68,.35); color: #f87171; }
    .pl-btn--del:hover:not(:disabled) { background: rgba(239,68,68,.22); }
</style>
}

<div class="pl-shell">

    <!-- Action bar -->
    <div class="pl-action-bar">
        <span class="pl-action-bar__meta">
            Fiyat Grubu: &nbsp;<strong id="plGroupName">Yükleniyor…</strong>
        </span>
        <a id="plNavToReport" href="#" class="pl-btn pl-btn--secondary" title="Fiyat listesi düzenleme ekranına dön">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Düzenleme
        </a>
        <a href="/PriceList/PriceGroups" class="pl-btn pl-btn--secondary" title="Fiyat grup tanımlamaları">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            Fiyat Grupları
        </a>
    </div>

    <!-- Stepper -->
    <div class="pl-stepper">
        <div class="pl-step">
            <div class="pl-step__circle is-active" id="plCircle1">1</div>
            <span class="pl-step__label is-active" id="plLabel1">Döviz &amp; Tarih</span>
        </div>
        <div class="pl-step__line" id="plLine1"></div>
        <div class="pl-step">
            <div class="pl-step__circle" id="plCircle2">2</div>
            <span class="pl-step__label" id="plLabel2">Stok Seçimi</span>
        </div>
        <div class="pl-step__line" id="plLine2"></div>
        <div class="pl-step">
            <div class="pl-step__circle" id="plCircle3">3</div>
            <span class="pl-step__label" id="plLabel3">Fiyat Girişi</span>
        </div>
    </div>

    <!-- Content -->
    <div class="pl-content">

        <!-- Step 1 -->
        <div class="pl-pane is-active" id="plStep1">
            <div class="pl-card">
                <div class="pl-card-title">Döviz &amp; Geçerlilik Dönemi</div>
                <div class="pl-fields">
                    <div class="pl-field">
                        <label>Fiyat Tipi *</label>
                        <div class="pl-price-type-group">
                            <button type="button" class="pl-price-type-btn is-buy is-active" id="plPtBuy"  onclick="plSetPriceType('buy')">Alış</button>
                            <button type="button" class="pl-price-type-btn is-sell"          id="plPtSell" onclick="plSetPriceType('sell')">Satış</button>
                            <button type="button" class="pl-price-type-btn is-cost"          id="plPtCost" onclick="plSetPriceType('cost')">Maliyet</button>
                        </div>
                    </div>
                    <div class="pl-field">
                        <label>Döviz Tipi *</label>
                        <select id="plCurrency" class="pl-select">
                            <option value="">— Yükleniyor… —</option>
                        </select>
                    </div>
                    <div class="pl-field">
                        <label>Başlangıç Tarihi *</label>
                        <input id="plValidFrom" type="date" class="pl-input" />
                    </div>
                    <div class="pl-field">
                        <label>Bitiş Tarihi <span class="opt">(boş bırakılabilir)</span></label>
                        <input id="plValidTo" type="date" class="pl-input" />
                    </div>
                </div>
            </div>

            <!-- Mevcut kayıtlar — step 1'den de görünür -->
            <div id="plExistingSection" style="display:none;">
                <div class="pl-existing-hdr">
                    <span class="pl-existing-hdr-title">Mevcut Fiyat Kayıtları</span>
                    <span class="pl-entry-count" id="plEntryCount">0</span>
                </div>
                <div class="pl-existing-wrap">
                    <table class="pl-existing-table">
                        <thead>
                            <tr>
                                <th>Malzeme Kodu</th>
                                <th>Malzeme Adı</th>
                                <th>Kombinasyon</th>
                                <th>Döviz</th>
                                <th>Tip</th>
                                <th class="num">Fiyat</th>
                                <th>Başlangıç</th>
                                <th>Bitiş</th>
                                <th style="width:100px;"></th>
                            </tr>
                        </thead>
                        <tbody id="plExistingBody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Step 2 -->
        <div class="pl-pane" id="plStep2">
            <div class="pl-card">
                <div class="pl-card-title">Stok Seçimi</div>
                <div class="pl-stock-toolbar" style="margin-bottom:10px; display:flex; gap:8px; align-items:center;">
                    <input id="plStockSearch" type="search" class="pl-input" placeholder="Malzeme kodu veya adı ile filtrele…" style="flex:1; min-width:0;" />
                    <select id="plStockGroupFilter" class="pl-input" title="Stok grup koduna göre filtrele" style="width:auto; min-width:170px; flex-shrink:0;">
                        <option value="">— Tüm gruplar —</option>
                    </select>
                    <button type="button" class="pl-btn pl-btn--secondary" onclick="plSelectAllFiltered()" style="white-space:nowrap;">Tümünü Seç</button>
                    <button type="button" class="pl-btn pl-btn--ghost" onclick="plClearSelection()">Temizle</button>
                    <span class="pl-sel-count" id="plSelCount"></span>
                </div>
                <div class="pl-stock-list" id="plStockList">
                    <div class="pl-empty">Yükleniyor…</div>
                </div>
            </div>
        </div>

        <!-- Step 3 -->
        <div class="pl-pane" id="plStep3">
            <div class="pl-card">
                <div class="pl-card-title" id="plStep3Title">Fiyat Girişi</div>
                <div class="pl-price-wrap">
                    <table class="pl-price-table">
                        <thead id="plPriceHead">
                            <tr>
                                <th style="width:32px;">#</th>
                                <th>Malzeme Kodu</th>
                                <th>Malzeme Adı</th>
                                <th class="num" id="plThPrice">Fiyat</th>
                                <th style="width:40px;"></th>
                            </tr>
                        </thead>
                        <tbody id="plPriceBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="pl-footer">
        <button type="button" class="pl-btn pl-btn--secondary" id="plBtnPrev" onclick="plPrev()" style="display:none;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>Geri
        </button>
        <div></div>
        <button type="button" class="pl-btn pl-btn--primary" id="plBtnNext" onclick="plNext()" disabled>
            İleri<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:4px;"><path d="M9 18l6-6-6-6"/></svg>
        </button>
    </div>
</div>

<!-- Delete confirmation modal -->
<div class="pl-modal-backdrop" id="plDeleteModal">
    <div class="pl-modal">
        <div class="pl-modal-title">Fiyat Kaydını Sil</div>
        <div class="pl-modal-body" id="plDeleteModalBody">Bu fiyat kaydını silmek istediğinize emin misiniz?</div>
        <div class="pl-modal-actions">
            <button type="button" class="pl-btn pl-btn--ghost" onclick="plDeleteCancel()">Vazgeç</button>
            <button type="button" class="pl-btn pl-btn--del" id="plDeleteConfirmBtn" onclick="plDeleteConfirm()">Sil</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    'use strict';
    var API = function(a) { return '/PriceList/' + a; };
    var STEPS = 3;
    var step = 1;
    var groupId = parseInt(new URLSearchParams(window.location.search).get('groupId')) || 0;

    // Navigation: "Düzenleme" butonu groupId varsa Report ekranına, yoksa PriceGroups'a gider.
    var navBtn = document.getElementById('plNavToReport');
    if (navBtn) {
        navBtn.href = groupId
            ? ('/PriceList/Report?groupId=' + groupId)
            : '/PriceList/PriceGroups';
    }

    // Sunucu tarafli sayfalama state
    var serverStocks = [];        // yuklenmis stok listesi (page by page)
    var serverTotal = 0;          // toplam kayit sayisi (backend'den)
    var serverOffset = 0;         // sonraki sayfa offset
    var serverHasMore = false;    // daha fazla sayfa var mi
    var serverLoading = false;    // aktif yukleme var mi
    var currentSearch = '';       // aktif arama terimi
    var currentGroupCode = '';    // aktif grup kodu filtresi (bos = tum gruplar)
    var PAGE_SIZE = 50;
    var combosByMat = {};         // { materialCode: [{ configId, code, name, featureValues }] }
    var expandedMats = new Set(); // genisletilmis material code'lar
    var currenciesById = {};      // { id: { code, name, symbol } }
    var currenciesByCode = {};    // { code: { id, name, symbol } }

    // selectedStocks — her satir: { id:itemId, materialCode, materialName, configId, combinationCode, combinationName, price, existingPrice?, isUpdate? }
    // Not: materialCode/combinationCode/combinationName UI-only display; backend'e itemId/configId gonderilir.
    var selectedStocks = [];
    var pendingDeleteId = null;
    var priceType = 'buy'; // 'buy' / 'sell' / 'cost' — wizard step 1'de secilir, save'de 'b'/'s'/'m' kisaltmasi olarak gonderilir
    function priceTypeCode()  {
        if (priceType === 'buy')  return 'b';
        if (priceType === 'sell') return 's';
        if (priceType === 'cost') return 'm';
        return 'b';
    }
    function priceTypeLabel() {
        if (priceType === 'buy')  return 'Alış';
        if (priceType === 'sell') return 'Satış';
        if (priceType === 'cost') return 'Maliyet';
        return 'Alış';
    }

    // Selected key: stok+kombinasyon (kombinasyon yoksa sadece stok) — DOM lookup icin combinationCode kullan
    function keyOf(s) {
        return String(s.id || '') + '|' + (s.combinationCode || '');
    }

    function esc(s) {
        return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    function fmt(n) {
        return (n || 0).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 4 });
    }

    // ── Grup tipi kisidlari ──
    // Bu grup hangi fiyat tipini kabul ediyor? Default true (mevcut DB kayitlari icin
    // backward compat) — fetch /GetPriceGroup yanitinda guncellenir.
    var groupAllows = { b: true, s: true, m: true };
    function applyGroupTypeRestriction() {
        var map     = { 'plPtBuy': 'b', 'plPtSell': 's', 'plPtCost': 'm' };
        var allows  = { 'b': groupAllows.b, 's': groupAllows.s, 'm': groupAllows.m };
        var labels  = { 'b': 'Alış', 's': 'Satış', 'm': 'Maliyet' };
        var nameMap = { 'b': 'buy', 's': 'sell', 'm': 'cost' };
        Object.keys(map).forEach(function (id) {
            var btn = document.getElementById(id);
            if (!btn) return;
            var t = map[id];
            if (allows[t]) {
                btn.disabled = false; btn.style.opacity = ''; btn.style.cursor = ''; btn.title = '';
            } else {
                btn.disabled = true;  btn.style.opacity = '0.35'; btn.style.cursor = 'not-allowed';
                btn.title = 'Bu fiyat grubu ' + labels[t] + ' tipini kabul etmiyor';
                if (btn.classList.contains('is-active')) {
                    var fallback = ['b', 's', 'm'].filter(function (k) { return allows[k]; })[0];
                    if (fallback && typeof window.plSetPriceType === 'function')
                        window.plSetPriceType(nameMap[fallback]);
                }
            }
        });
    }

    // ── Group banner ──
    if (groupId) {
        fetch(API('GetPriceGroup') + '?id=' + groupId)
            .then(function(r) { return r.json(); })
            .then(function(d) {
                document.getElementById('plGroupName').textContent = d.code + ' \u2014 ' + d.name;
                groupAllows.b = d.allowsBuying  !== false;
                groupAllows.s = d.allowsSelling !== false;
                groupAllows.m = d.allowsCost    !== false;
                applyGroupTypeRestriction();
                loadExistingEntries(groupId);
            });
    } else {
        document.getElementById('plGroupName').textContent = 'Grup bulunamadı';
    }

    // ── Stepper ──
    function updateStepper() {
        for (var i = 1; i <= STEPS; i++) {
            var c = document.getElementById('plCircle' + i);
            var l = document.getElementById('plLabel' + i);
            c.className = 'pl-step__circle' + (i === step ? ' is-active' : i < step ? ' is-done' : '');
            c.textContent = i < step ? '\u2713' : String(i);
            l.className = 'pl-step__label' + (i === step ? ' is-active' : i < step ? ' is-done' : '');
            if (i < STEPS) {
                document.getElementById('plLine' + i).className = 'pl-step__line' + (i < step ? ' is-done' : '');
            }
            document.getElementById('plStep' + i).className = 'pl-pane' + (i === step ? ' is-active' : '');
        }
        document.getElementById('plBtnPrev').style.display = step > 1 ? '' : 'none';
        var nb = document.getElementById('plBtnNext');
        if (step === STEPS) {
            nb.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:4px;"><path d="M5 13l4 4L19 7"/></svg>Kaydet';
            nb.className = 'pl-btn pl-btn--success';
        } else {
            nb.innerHTML = 'İleri<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:4px;"><path d="M9 18l6-6-6-6"/></svg>';
            nb.className = 'pl-btn pl-btn--primary';
        }
        validateStep();
    }

    function validateStep() {
        var nb = document.getElementById('plBtnNext');
        if (step === 1) nb.disabled = !groupId || !document.getElementById('plCurrency').value || !document.getElementById('plValidFrom').value;
        else if (step === 2) nb.disabled = selectedStocks.length === 0;
        else nb.disabled = false;
    }

    window.plNext = function() {
        if (step === STEPS) { savePrices(); return; }
        if (step === 1) loadStocks();
        if (step === 2) renderPriceTable();
        step++;
        updateStepper();
        plMsg('');
    };
    window.plPrev = function() {
        if (step <= 1) return;
        step--;
        updateStepper();
        plMsg('');
    };

    // Sag alt kosede toast bildirim — eski plMsg API'si korunur (msg, ok bool).
    function plMsg(msg, ok) {
        if (!msg) return; // eski "temizle" cagrilari no-op
        plShowToast(msg, ok ? 'success' : 'error');
    }
    function plShowToast(msg, kind) {
        kind = kind || 'info';
        var icons = { success: '✓', error: '✕', warning: '!', info: 'i' };
        var icon = icons[kind] || 'i';

        var container = document.getElementById('plToastContainer');
        if (!container) {
            container = document.createElement('div');
            container.id = 'plToastContainer';
            container.className = 'pl-toast-container';
            document.body.appendChild(container);
        }

        var toast = document.createElement('div');
        toast.className = 'pl-toast pl-toast--' + kind;
        toast.innerHTML =
            '<div class="pl-toast__icon">' + icon + '</div>' +
            '<div class="pl-toast__msg">' + esc(msg) + '</div>' +
            '<button type="button" class="pl-toast__close" aria-label="Kapat">×</button>';
        container.appendChild(toast);

        // Slide-in (next frame — display kaydedildikten sonra transition tetiklensin)
        requestAnimationFrame(function () { toast.classList.add('is-in'); });

        var dismissed = false;
        function dismiss() {
            if (dismissed) return; dismissed = true;
            toast.classList.add('is-out');
            setTimeout(function () {
                if (toast.parentNode) toast.parentNode.removeChild(toast);
            }, 280);
        }

        toast.querySelector('.pl-toast__close').addEventListener('click', dismiss);
        // Hata/uyari biraz daha uzun kalsin
        var timeout = (kind === 'error' || kind === 'warning') ? 5500 : 3500;
        setTimeout(dismiss, timeout);
    }

    // ── Step 1: currencies ──
    function loadCurrencies() {
        fetch(API('GetCurrencies'))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                currenciesById = {};
                currenciesByCode = {};
                (data || []).forEach(function(c) {
                    currenciesById[c.id] = c;
                    currenciesByCode[c.code] = c;
                });
                var sel = document.getElementById('plCurrency');
                sel.innerHTML = '<option value="">— Döviz Seçiniz —</option>' +
                    data.map(function(c) {
                        return '<option value="' + c.id + '">' + esc(c.code) + ' \u2014 ' + esc(c.name) + (c.symbol ? ' (' + esc(c.symbol) + ')' : '') + '</option>';
                    }).join('');
                // Default secim: TRY varsa onun ID'si
                var tryC = currenciesByCode['TRY'];
                if (tryC) sel.value = String(tryC.id);
                validateStep();
            });
        document.getElementById('plValidFrom').value = new Date().toISOString().split('T')[0];
    }
    // ── Price type toggle (Alış / Satış / Maliyet — sadece tek tip secilir) ──
    window.plSetPriceType = function(type) {
        if (type !== 'buy' && type !== 'sell' && type !== 'cost') return;
        priceType = type;
        ['buy','sell','cost'].forEach(function(t) {
            var btn = document.getElementById('plPt' + t.charAt(0).toUpperCase() + t.slice(1));
            if (btn) btn.classList.toggle('is-active', t === type);
        });
        // Step 3 baslik + tablo basligi tip degisince guncellenmeli (henuz Step 3'e gelmediyse zarar yok)
        var th = document.getElementById('plThPrice');
        if (th) th.textContent = priceTypeLabel() + ' Fiyatı';
        var t3title = document.getElementById('plStep3Title');
        if (t3title) t3title.textContent = priceTypeLabel() + ' Fiyat Girişi';
    };

    document.getElementById('plCurrency').addEventListener('change', validateStep);
    document.getElementById('plValidFrom').addEventListener('change', validateStep);

    // ── Step 2: stok seçimi (sunucu tarafli pagination + kombinasyon) ──
    var stockTimer;
    document.getElementById('plStockSearch').addEventListener('input', function() {
        clearTimeout(stockTimer);
        stockTimer = setTimeout(function() {
            currentSearch = (document.getElementById('plStockSearch').value || '').trim();
            resetAndLoad();
        }, 300);
    });

    // Grup filtresi: degisince stok listesi sifirdan yuklenir.
    var groupSel = document.getElementById('plStockGroupFilter');
    if (groupSel) {
        groupSel.addEventListener('change', function () {
            currentGroupCode = groupSel.value || '';
            resetAndLoad();
        });
        // Grup listesini bir kez doldur (sayfa acilirken).
        fetch(API('GetMaterialGroups'))
            .then(function (r) { return r.json(); })
            .then(function (list) {
                if (!Array.isArray(list)) return;
                list.forEach(function (g) {
                    var opt = document.createElement('option');
                    opt.value = g.code;
                    opt.textContent = g.code + (g.description ? ' — ' + g.description : '');
                    groupSel.appendChild(opt);
                });
            })
            .catch(function () { /* sessiz: combobox bos kalir */ });
    }

    // Step 2'ye ilk giriste tetiklenir
    function loadStocks() {
        if (serverStocks.length === 0) resetAndLoad();
        else renderStockList();
    }

    function resetAndLoad() {
        serverStocks = [];
        serverOffset = 0;
        serverTotal = 0;
        serverHasMore = false;
        renderStockList(); // loading skeleton
        loadNextPage();
    }

    function loadNextPage() {
        if (serverLoading || (serverOffset > 0 && !serverHasMore)) return;
        serverLoading = true;
        var qParam = currentSearch ? '&q=' + encodeURIComponent(currentSearch) : '';
        var gParam = currentGroupCode ? '&groupCode=' + encodeURIComponent(currentGroupCode) : '';
        fetch(API('SearchStocks') + '?offset=' + serverOffset + '&pageSize=' + PAGE_SIZE + qParam + gParam)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                serverLoading = false;
                serverStocks  = serverStocks.concat(data.items || []);
                serverTotal   = data.totalCount || 0;
                serverHasMore = !!data.hasMore;
                serverOffset  = (data.offset || 0) + (data.items || []).length;
                renderStockList();
            })
            .catch(function() {
                serverLoading = false;
                renderStockList();
            });
    }

    function renderStockList() {
        var list = document.getElementById('plStockList');
        if (serverStocks.length === 0 && !serverLoading) {
            list.innerHTML = '<div class="pl-empty">Sonuç bulunamadı.</div>';
            updateSelectionUI(); return;
        }
        if (serverStocks.length === 0 && serverLoading) {
            list.innerHTML = '<div class="pl-empty">Yükleniyor…</div>';
            updateSelectionUI(); return;
        }

        var selSet = new Set(selectedStocks.map(keyOf));
        var html = '';
        serverStocks.forEach(function(s) {
            var stockKey = String(s.id) + '|';
            var chk = selSet.has(stockKey);
            if (s.trackCombinations) {
                var isOpen = expandedMats.has(s.materialCode);
                // Grup (ust seviye) toggle state'i — tum kombinasyonlar secili mi?
                var combosForStock = combosByMat[s.materialCode];
                var grpState = 'none'; // none | partial | all
                if (Array.isArray(combosForStock) && combosForStock.length > 0) {
                    var selectedCount = combosForStock.filter(function(c) {
                        return selSet.has(String(s.id) + '|' + c.code);
                    }).length;
                    if (selectedCount === combosForStock.length) grpState = 'all';
                    else if (selectedCount > 0) grpState = 'partial';
                }
                var grpChecked = grpState === 'all';
                var grpIndet   = grpState === 'partial';
                html += '<div class="pl-stock-item pl-stock-item--tracked' + (isOpen ? ' is-open' : '') + (grpChecked ? ' is-checked' : '') + '" onclick="plToggleExpand(\'' + esc(s.materialCode) + '\')">'
                    +   '<label class="pl-switch pl-switch--group" title="Tum kombinasyonlari sec/kaldir" onclick="event.stopPropagation();plToggleStockAllCombos(' + s.id + ',\'' + esc(s.materialCode) + '\',\'' + esc(s.materialName) + '\')">'
                    +     '<input type="checkbox"' + (grpChecked ? ' checked' : '') + (grpIndet ? ' data-indeterminate="1"' : '') + ' onclick="event.stopPropagation()" readonly />'
                    +     '<span class="pl-switch-track"></span>'
                    +   '</label>'
                    +   '<span class="pl-caret">' + (isOpen ? '▾' : '▸') + '</span>'
                    +   '<span class="pl-stock-code">' + esc(s.materialCode) + '</span>'
                    +   '<span class="pl-stock-name">' + esc(s.materialName) + '</span>'
                    +   '<span class="pl-config-badge" title="Yapılandırmalı stok">⚙</span>'
                    + '</div>';
                if (isOpen) {
                    var combos = combosByMat[s.materialCode];
                    if (!combos) {
                        html += '<div class="pl-combo-row pl-combo-loading">Kombinasyonlar yükleniyor…</div>';
                    } else if (combos.length === 0) {
                        html += '<div class="pl-combo-row pl-combo-empty">Tanımlı kombinasyon yok.</div>';
                    } else {
                        combos.forEach(function(c) {
                            var cKey = String(s.id) + '|' + c.code;
                            var cChk = selSet.has(cKey);
                            var label = (c.featureValues || []).map(function(fv) { return fv.feature + ': ' + fv.value; }).join(' · ');
                            html += '<div class="pl-combo-row' + (cChk ? ' is-checked' : '') + '" onclick="plToggleCombo(' + s.id + ',\'' + esc(s.materialCode) + '\',\'' + esc(s.materialName) + '\',\'' + esc(c.code) + '\',\'' + esc(c.name || label) + '\',' + (c.configId || 'null') + ')">'
                                +   '<label class="pl-switch" onclick="event.stopPropagation();plToggleCombo(' + s.id + ',\'' + esc(s.materialCode) + '\',\'' + esc(s.materialName) + '\',\'' + esc(c.code) + '\',\'' + esc(c.name || label) + '\',' + (c.configId || 'null') + ')">'
                                +     '<input type="checkbox"' + (cChk ? ' checked' : '') + ' onclick="event.stopPropagation()" readonly />'
                                +     '<span class="pl-switch-track"></span>'
                                +   '</label>'
                                +   '<span class="pl-combo-code">' + esc(c.code) + '</span>'
                                +   '<span class="pl-combo-desc">' + esc(label || c.name || '') + '</span>'
                                + '</div>';
                        });
                    }
                }
            } else {
                html += '<div class="pl-stock-item' + (chk ? ' is-checked' : '') + '" onclick="plToggleStock(' + s.id + ')">'
                    +   '<label class="pl-switch" onclick="event.stopPropagation();plToggleStock(' + s.id + ')">'
                    +     '<input type="checkbox"' + (chk ? ' checked' : '') + ' onclick="event.stopPropagation()" readonly />'
                    +     '<span class="pl-switch-track"></span>'
                    +   '</label>'
                    +   '<span class="pl-stock-code">' + esc(s.materialCode) + '</span>'
                    +   '<span class="pl-stock-name">' + esc(s.materialName) + '</span>'
                    + '</div>';
            }
        });

        if (serverHasMore || serverLoading) {
            html += '<div class="pl-scroll-sentinel" id="plSentinel">' + (serverLoading ? 'Yükleniyor…' : '') + '</div>';
        }
        list.innerHTML = html;

        // Indeterminate state — HTML attribute ile set edilemez, JS ile set et
        list.querySelectorAll('input[data-indeterminate="1"]').forEach(function(inp) { inp.indeterminate = true; });

        // IntersectionObserver — infinite scroll
        var sentinel = document.getElementById('plSentinel');
        if (sentinel && serverHasMore && !serverLoading) {
            var io = new IntersectionObserver(function(entries) {
                entries.forEach(function(ent) {
                    if (ent.isIntersecting) { io.disconnect(); loadNextPage(); }
                });
            }, { root: list, threshold: 0.1 });
            io.observe(sentinel);
        }

        updateSelectionUI();
    }

    window.plToggleStock = function(id) {
        var stockKey = String(id) + '|';
        var idx = selectedStocks.findIndex(function(s) { return keyOf(s) === stockKey; });
        if (idx >= 0) selectedStocks.splice(idx, 1);
        else {
            var s = serverStocks.find(function(x) { return x.id === id; });
            if (s) selectedStocks.push({
                id: s.id, materialCode: s.materialCode, materialName: s.materialName,
                combinationCode: null, combinationName: null,
                price: 0
            });
        }
        renderStockList(); validateStep();
    };

    window.plToggleCombo = function(stockId, matCode, matName, comboCode, comboName, configId) {
        var k = String(stockId) + '|' + comboCode;
        var idx = selectedStocks.findIndex(function(s) { return keyOf(s) === k; });
        if (idx >= 0) selectedStocks.splice(idx, 1);
        else selectedStocks.push({
            id: stockId, materialCode: matCode, materialName: matName,
            configId: configId || null,
            combinationCode: comboCode, combinationName: comboName,
            price: 0
        });
        renderStockList(); validateStep();
    };

    window.plToggleExpand = function(matCode) {
        if (expandedMats.has(matCode)) {
            expandedMats.delete(matCode);
            renderStockList();
            return;
        }
        expandedMats.add(matCode);
        if (combosByMat[matCode]) { renderStockList(); return; }
        // Kombinasyonlari lazy-fetch et
        renderStockList();
        fetch(API('GetCombinations') + '?materialCode=' + encodeURIComponent(matCode))
            .then(function(r) { return r.json(); })
            .then(function(data) { combosByMat[matCode] = Array.isArray(data) ? data : []; renderStockList(); })
            .catch(function() { combosByMat[matCode] = []; renderStockList(); });
    };

    // Bir tracked stok icin kombinasyonlari cek ve sec (zaten seciliyse atla).
    function pushCombosToSelected(s, combos) {
        var selSet = new Set(selectedStocks.map(keyOf));
        combos.forEach(function(c) {
            var label = (c.featureValues || []).map(function(fv) { return fv.feature + ': ' + fv.value; }).join(' · ');
            var k = String(s.id) + '|' + c.code;
            if (!selSet.has(k)) {
                selectedStocks.push({
                    id: s.id, materialCode: s.materialCode, materialName: s.materialName,
                    configId: c.configId || null,
                    combinationCode: c.code, combinationName: c.name || label || c.code,
                    price: 0
                });
            }
        });
    }

    function ensureCombosLoaded(matCode) {
        if (Array.isArray(combosByMat[matCode])) return Promise.resolve(combosByMat[matCode]);
        return fetch(API('GetCombinations') + '?materialCode=' + encodeURIComponent(matCode))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                combosByMat[matCode] = Array.isArray(data) ? data : [];
                return combosByMat[matCode];
            })
            .catch(function() { combosByMat[matCode] = []; return []; });
    }

    window.plSelectAllFiltered = function() {
        var selSet = new Set(selectedStocks.map(keyOf));
        var pending = [];
        serverStocks.forEach(function(s) {
            if (s.trackCombinations) {
                // Yapilandirmali stok: tum kombinasyonlarini sec (lazy fetch)
                pending.push(ensureCombosLoaded(s.materialCode).then(function(combos) {
                    if (combos && combos.length > 0) pushCombosToSelected(s, combos);
                }));
            } else {
                var k = String(s.id) + '|';
                if (!selSet.has(k)) {
                    selectedStocks.push({
                        id: s.id, materialCode: s.materialCode, materialName: s.materialName,
                        combinationCode: null, combinationName: null,
                        price: 0
                    });
                }
            }
        });
        Promise.all(pending).then(function() {
            renderStockList(); validateStep();
        });
    };

    window.plToggleStockAllCombos = function(stockId, matCode, matName) {
        var s = serverStocks.find(function(x) { return x.id === stockId; })
             || { id: stockId, materialCode: matCode, materialName: matName };
        ensureCombosLoaded(s.materialCode).then(function(combos) {
            if (!combos || combos.length === 0) { renderStockList(); return; }
            var selSet = new Set(selectedStocks.map(keyOf));
            var allSelected = combos.every(function(c) { return selSet.has(String(s.id) + '|' + c.code); });
            if (allSelected) {
                // Hepsini kaldir
                var comboCodes = new Set(combos.map(function(c) { return c.code; }));
                selectedStocks = selectedStocks.filter(function(row) {
                    return !(row.id === s.id && row.combinationCode && comboCodes.has(row.combinationCode));
                });
            } else {
                pushCombosToSelected(s, combos);
            }
            renderStockList(); validateStep();
        });
    };

    window.plClearSelection = function() { selectedStocks = []; renderStockList(); validateStep(); };
    window.plRemoveSelected = function(id) {
        selectedStocks = selectedStocks.filter(function(s) { return s.id !== id; });
        renderStockList(); validateStep();
    };

    function updateSelectionUI() {
        var cnt = document.getElementById('plSelCount');
        cnt.className = 'pl-sel-count' + (selectedStocks.length ? ' has-sel' : '');
        var totalTxt = serverTotal > 0 ? ' · ' + serverTotal + ' toplam stok' : '';
        cnt.textContent = (selectedStocks.length ? selectedStocks.length + ' seçildi' : '') + totalTxt;
    }

    // ── Step 3: fiyat girisi + onceki fiyat + durum (tek tip — wizard secimi) ─
    function renderPriceTable() {
        var theadEl = document.getElementById('plPriceHead');
        if (theadEl) {
            theadEl.innerHTML =
                '<tr>'
                + '<th style="width:32px;">#</th>'
                + '<th>Malzeme Kodu</th>'
                + '<th>Malzeme Adı</th>'
                + '<th>Kombinasyon</th>'
                + '<th class="num">Önceki ' + priceTypeLabel() + '</th>'
                + '<th class="num">' + priceTypeLabel() + ' Fiyatı</th>'
                + '<th style="width:110px;">Durum</th>'
                + '<th style="width:40px;"></th>'
                + '</tr>';
        }

        var titleEl = document.getElementById('plStep3Title');
        if (titleEl) titleEl.textContent = priceTypeLabel() + ' Fiyatı Girişi';

        loadExistingForSelection().finally(function() { renderPriceRows(); });
    }

    function loadExistingForSelection() {
        if (!selectedStocks.length) return Promise.resolve();
        var payload = {
            groupId:    groupId,
            currencyId: parseInt(document.getElementById('plCurrency').value) || 0,
            priceType:  priceTypeCode(),
            validFrom:  document.getElementById('plValidFrom').value,
            keys: selectedStocks.map(function(s) {
                return { itemId: s.id, configId: s.configId || null };
            })
        };
        return fetch(API('GetExistingPrices'), {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var map = {};
            (data || []).forEach(function(row) {
                var k = String(row.itemId || '') + '|' + (row.configId || '');
                map[k] = row;
            });
            selectedStocks.forEach(function(s) {
                var k = String(s.id) + '|' + (s.configId || '');
                var ex = map[k];
                if (ex) {
                    s.existingPrice = ex.price;
                    s.isUpdate = true;
                    if (!s.price) s.price = ex.price;
                } else {
                    s.existingPrice = null;
                    s.isUpdate = false;
                }
            });
        })
        .catch(function() { /* sessiz */ });
    }

    function renderPriceRows() {
        document.getElementById('plPriceBody').innerHTML = selectedStocks.map(function(s, i) {
            var comboCell = s.combinationCode
                ? '<td><span class="pl-combo-chip" title="' + esc(s.combinationName || '') + '">' + esc(s.combinationCode) + '</span></td>'
                : '<td><span class="pl-combo-chip pl-combo-chip--none">—</span></td>';

            var prevCell = '<td class="num pl-prev">' +
                (s.existingPrice != null ? fmt(s.existingPrice) : '<span class="pl-prev-empty">—</span>') +
                '</td>';

            var priceCell = '<td class="num"><input type="number" class="pl-input" step="0.01" min="0" value="' +
                (s.price || 0) + '" oninput="plUpdatePrice(' + i + ',this.value)" /></td>';

            var statusCell = s.isUpdate
                ? '<td><span class="pl-status pl-status--update">🔄 Güncelleme</span></td>'
                : '<td><span class="pl-status pl-status--new">🆕 Yeni</span></td>';

            return '<tr>'
                + '<td class="pl-row-num">' + (i + 1) + '</td>'
                + '<td class="pl-code-cell">' + esc(s.materialCode) + '</td>'
                + '<td class="pl-name-cell">' + esc(s.materialName) + '</td>'
                + comboCell
                + prevCell + priceCell + statusCell
                + '<td><button type="button" class="pl-btn pl-btn--danger-ghost" onclick="plRemoveFromTable(' + i + ')" title="Çıkar">'
                + '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>'
                + '</button></td>'
                + '</tr>';
        }).join('');
    }
    window.plUpdatePrice = function(idx, val) {
        selectedStocks[idx].price = parseFloat(val) || 0;
    };
    window.plRemoveFromTable = function(idx) {
        selectedStocks.splice(idx, 1);
        renderPriceTable();
        if (selectedStocks.length === 0) { step = 2; updateStepper(); }
    };

    // ── Save bulk (tek tip — wizard'daki secime gore) ──
    function savePrices() {
        var payload = {
            groupId:    groupId,
            currencyId: parseInt(document.getElementById('plCurrency').value) || 0,
            priceType:  priceTypeCode(),
            validFrom:  document.getElementById('plValidFrom').value,
            validTo:    document.getElementById('plValidTo').value || null,
            lines: selectedStocks.map(function(s) {
                return {
                    itemId:   s.id,
                    configId: s.configId || null,
                    price:    s.price || 0
                };
            })
        };
        var nb = document.getElementById('plBtnNext');
        nb.disabled = true;
        nb.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>Kaydediliyor…';

        fetch(API('SaveBulkPriceEntries'), {
            method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) {
                plMsg(d.message || 'Kaydedildi.', true);
                selectedStocks = [];
                step = 1; updateStepper();
                loadExistingEntries(groupId);
            } else {
                plMsg(d.message || 'Hata oluştu.', false);
                nb.disabled = false; updateStepper();
            }
        })
        .catch(function() { plMsg('Bağlantı hatası.', false); nb.disabled = false; updateStepper(); });
    }

    // ── Existing entries ──
    function loadExistingEntries(gid) {
        if (!gid) return;
        fetch(API('GetPriceListEntries') + '?groupId=' + gid)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var sec  = document.getElementById('plExistingSection');
                var body = document.getElementById('plExistingBody');
                var cnt  = document.getElementById('plEntryCount');
                if (!data || !data.length) { sec.style.display = 'none'; return; }
                sec.style.display = '';
                cnt.textContent = data.length;
                body.innerHTML = data.map(function(e) {
                    var comboTd = e.configCode
                        ? '<td><span class="pl-combo-chip" title="' + esc(e.configCode) + '">' + esc(e.configCode) + '</span></td>'
                        : '<td><span class="pl-combo-chip pl-combo-chip--none">—</span></td>';
                    var typeLabel = e.priceType === 'b' ? 'Alış'
                                  : e.priceType === 's' ? 'Satış'
                                  : e.priceType === 'm' ? 'Maliyet'
                                  : '—';
                    var typeCls   = e.priceType === 'b' ? 'pl-type-buy'
                                  : e.priceType === 's' ? 'pl-type-sell'
                                  : e.priceType === 'm' ? 'pl-type-cost'
                                  : '';
                    return '<tr id="plRow' + e.id + '">'
                        + '<td class="pl-entry-code">' + esc(e.itemCode) + '</td>'
                        + '<td class="pl-entry-name">' + esc(e.itemName) + '</td>'
                        + comboTd
                        + '<td><span class="pl-entry-cur">' + esc(e.currencyCode) + '</span></td>'
                        + '<td data-type-code="' + esc(e.priceType) + '"><span class="pl-type-badge ' + typeCls + '">' + typeLabel + '</span></td>'
                        + '<td class="num" id="plPriceDisp' + e.id + '">' + fmt(e.price) + '</td>'
                        + '<td class="pl-entry-date">' + esc(e.validFrom || '—') + '</td>'
                        + '<td class="pl-entry-date">' + esc(e.validTo || '—') + '</td>'
                        + '<td>'
                        +   '<div class="pl-edit-actions" id="plRowBtns' + e.id + '">'
                        +     '<button type="button" class="pl-btn pl-btn--ghost" style="padding:4px 8px;" onclick="plStartEdit(' + e.id + ',' + (e.price||0) + ')" title="Düzenle">'
                        +       '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>'
                        +     '</button>'
                        +     '<button type="button" class="pl-btn pl-btn--danger-ghost" style="padding:4px 8px;" onclick="plDeleteEntry(' + e.id + ',\'' + esc(e.itemCode) + '\')" title="Sil">'
                        +       '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>'
                        +     '</button>'
                        +   '</div>'
                        + '</td>'
                        + '</tr>';
                }).join('');
            });
    }

    // ── Inline edit (tüm alanlar: döviz, tip, fiyat, geçerlilik tarihleri) ─────
    // Düzenleme moduna geçince row'daki ilgili sütunlar input/select'e dönüşür.
    // Cancel'da orijinal değerlere geri dönülür (snapshot row.dataset).
    window.plStartEdit = function(id, priceOrig) {
        var row = document.getElementById('plRow' + id);
        var btns = document.getElementById('plRowBtns' + id);
        if (!row || row.classList.contains('is-editing')) return;
        row.classList.add('is-editing');

        // Mevcut row değerlerini DOM'dan topla — cancel için snapshot
        var cells = row.querySelectorAll('td');
        // Sıralama: 0=ItemCode 1=ItemName 2=Combo 3=Currency 4=Type 5=Price 6=ValidFrom 7=ValidTo 8=Actions
        var origCurrencyCode = (cells[3] && cells[3].textContent || '').trim();
        var origTypeCode     = cells[4] && cells[4].dataset && cells[4].dataset.typeCode || '';
        var origValidFrom    = (cells[6] && cells[6].textContent || '').trim();
        var origValidTo      = (cells[7] && cells[7].textContent || '').trim();
        row.dataset.origCurrencyCode = origCurrencyCode;
        row.dataset.origTypeCode     = origTypeCode;
        row.dataset.origValidFrom    = origValidFrom;
        row.dataset.origValidTo      = origValidTo;
        row.dataset.origPrice        = String(priceOrig);

        // Currency select
        var currencyOpts = '';
        Object.keys(currenciesById).forEach(function(cid) {
            var c = currenciesById[cid];
            var sel = (c.code === origCurrencyCode) ? ' selected' : '';
            currencyOpts += '<option value="' + cid + '"' + sel + '>' + esc(c.code) + '</option>';
        });
        cells[3].innerHTML =
            '<select class="pl-input" id="plCurInput' + id + '" style="padding:3px 5px;font-size:.75rem;">'
            + currencyOpts + '</select>';

        // PriceType select
        function typeOpt(val, lbl) {
            return '<option value="' + val + '"' + (val === origTypeCode ? ' selected' : '') + '>' + lbl + '</option>';
        }
        cells[4].innerHTML =
            '<select class="pl-input" id="plTypeInput' + id + '" style="padding:3px 5px;font-size:.75rem;">'
            + typeOpt('b', 'Alış') + typeOpt('s', 'Satış') + typeOpt('m', 'Maliyet')
            + '</select>';

        // Price input
        document.getElementById('plPriceDisp' + id).innerHTML =
            '<input type="number" class="pl-input" step="0.01" min="0" id="plPriceInput' + id + '" value="' + priceOrig + '" style="width:100px;text-align:right;" />';

        // Date inputs — convert ISO/dd.MM.yyyy to YYYY-MM-DD for date input
        function toDateInputValue(v) {
            if (!v || v === '—') return '';
            // ISO format (2026-05-10...) → YYYY-MM-DD
            var iso = /^(\d{4})-(\d{2})-(\d{2})/.exec(v);
            if (iso) return iso[1] + '-' + iso[2] + '-' + iso[3];
            // dd.MM.yyyy → YYYY-MM-DD
            var tr = /^(\d{2})\.(\d{2})\.(\d{4})/.exec(v);
            if (tr) return tr[3] + '-' + tr[2] + '-' + tr[1];
            return '';
        }
        cells[6].innerHTML =
            '<input type="date" class="pl-input" id="plFromInput' + id + '" value="' + toDateInputValue(origValidFrom) + '" style="font-size:.75rem;" />';
        cells[7].innerHTML =
            '<input type="date" class="pl-input" id="plToInput' + id + '" value="' + toDateInputValue(origValidTo) + '" style="font-size:.75rem;" placeholder="(boş)" />';

        btns.innerHTML =
            '<button type="button" class="pl-save-inline" onclick="plSaveInline(' + id + ')">'
            + '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>Kaydet'
            + '</button>'
            + '<button type="button" class="pl-cancel-inline" onclick="plCancelEdit(' + id + ')">İptal</button>';

        document.getElementById('plPriceInput' + id).focus();
        document.getElementById('plPriceInput' + id).select();
    };

    window.plCancelEdit = function(id) {
        // Cancel: row'u tamamen yeniden yüklemek en temiz (snapshot karışıklığını önler)
        loadExistingEntries(groupId);
    };

    window.plSaveInline = function(id) {
        var row = document.getElementById('plRow' + id);
        if (!row) return;
        var priceEl = document.getElementById('plPriceInput' + id);
        var curEl   = document.getElementById('plCurInput'   + id);
        var typeEl  = document.getElementById('plTypeInput'  + id);
        var fromEl  = document.getElementById('plFromInput'  + id);
        var toEl    = document.getElementById('plToInput'    + id);

        var price       = parseFloat(priceEl.value);
        var currencyId  = parseInt(curEl.value, 10) || 0;
        var priceType   = typeEl.value || 's';
        var validFrom   = fromEl.value || null;       // YYYY-MM-DD or null
        var validToVal  = toEl.value || '';
        var clearValidTo = (validToVal === '');
        var validTo     = clearValidTo ? null : validToVal;

        if (Number.isNaN(price) || price < 0) {
            plMsg('Geçerli bir fiyat girin.', false);
            priceEl.focus();
            return;
        }
        if (!currencyId) { plMsg('Döviz seçin.', false); curEl.focus(); return; }
        if (!validFrom)  { plMsg('Başlangıç tarihi zorunlu.', false); fromEl.focus(); return; }

        var btn = document.querySelector('#plRowBtns' + id + ' .pl-save-inline');
        if (btn) { btn.disabled = true; btn.textContent = '…'; }

        fetch(API('UpdatePriceListJson'), {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                id:           id,
                price:        price,
                currencyId:   currencyId,
                priceType:    priceType,
                validFrom:    validFrom,
                validTo:      validTo,
                clearValidTo: clearValidTo,
            })
        })
        .then(function(r) { return r.json().catch(function() { return { success: false, message: 'Geçersiz sunucu yanıtı (HTTP ' + r.status + ')' }; }); })
        .then(function(d) {
            if (d && d.success) {
                loadExistingEntries(groupId);
                plMsg('Kayıt güncellendi.', true);
            } else {
                plMsg((d && d.message) || 'Güncellenemedi.', false);
                if (btn) { btn.disabled = false; btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>Kaydet'; }
            }
        })
        .catch(function(e) {
            plMsg('Bağlantı hatası: ' + (e && e.message || ''), false);
            if (btn) { btn.disabled = false; btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>Kaydet'; }
        });
    };

    // ── Delete with modal ──
    window.plDeleteEntry = function(id, code) {
        pendingDeleteId = id;
        var body = document.getElementById('plDeleteModalBody');
        body.textContent = (code ? '"' + code + '"' : 'Bu') + ' fiyat kaydını silmek istediğinize emin misiniz?';
        document.getElementById('plDeleteModal').classList.add('is-open');
    };
    window.plDeleteCancel = function() {
        pendingDeleteId = null;
        document.getElementById('plDeleteModal').classList.remove('is-open');
    };
    window.plDeleteConfirm = function() {
        if (!pendingDeleteId) return;
        var btn = document.getElementById('plDeleteConfirmBtn');
        btn.disabled = true; btn.textContent = 'Siliniyor…';
        fetch(API('DeletePriceListJson') + '?id=' + pendingDeleteId, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                document.getElementById('plDeleteModal').classList.remove('is-open');
                btn.disabled = false; btn.textContent = 'Sil'; pendingDeleteId = null;
                if (d.success) loadExistingEntries(groupId);
                else plMsg(d.message || 'Silinemedi.', false);
            })
            .catch(function() {
                document.getElementById('plDeleteModal').classList.remove('is-open');
                btn.disabled = false; btn.textContent = 'Sil'; pendingDeleteId = null;
                plMsg('Bağlantı hatası.', false);
            });
    };
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') plDeleteCancel(); });

    // ── Init ──
    loadCurrencies();
    updateStepper();
})();
</script>
}
