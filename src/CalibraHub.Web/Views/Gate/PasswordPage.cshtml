@{
    ViewData["Title"] = "Sistem Yönetimi — Şifre Değiştir";
    ViewData["BodyClass"] = "page-system-mgmt";
    var pwdLastChanged = ViewBag.PasswordLastChanged as DateTime?;
}

@section Styles {
<style>
    .sm-panel {
        background: var(--surface-1, #ffffff);
        border: 1px solid rgba(148,163,184,.2);
        border-radius: 14px; padding: 24px; max-width: 480px; margin: 24px;
    }
    body.app-theme-dark .sm-panel { background: #111827; border-color: rgba(148,163,184,.15); }
    .sm-field { margin-bottom: 14px; }
    .sm-field label { display: block; font-size: .76rem; font-weight: 600; color: #475569; margin-bottom: 4px; }
    body.app-theme-dark .sm-field label { color: #94a3b8; }
    .sm-input {
        width: 100%; padding: 9px 12px;
        border: 1px solid rgba(148,163,184,.4); border-radius: 8px;
        font-size: .88rem; background: var(--surface-1, #fff); color: inherit; outline: none; box-sizing: border-box;
    }
    body.app-theme-dark .sm-input { background: #0f172a; border-color: rgba(148,163,184,.3); }
    .sm-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.15); }
    .sm-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .sm-btn { padding: 9px 20px; border-radius: 8px; border: none; cursor: pointer; background: #6366f1; color: #fff; font-size: .85rem; font-weight: 600; }
    .sm-btn:hover { background: #4f46e5; }
    .sm-btn:disabled { opacity: .6; cursor: not-allowed; }
    .sm-meter { height: 6px; border-radius: 3px; background: rgba(148,163,184,.2); overflow: hidden; margin-bottom: 10px; }
    .sm-meter-bar { height: 100%; width: 0; background: #ef4444; transition: width .2s, background .2s; }
</style>
}

<partial name="_SistemAyarlariTabs" model='"password"' />

<div class="sm-panel">
    <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:20px;">
        <div style="width:38px;height:38px;border-radius:10px;background:rgba(99,102,241,.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div>
            <div style="font-weight:700;font-size:.95rem;">Sistem Ayarları Şifresi</div>
            <div style="font-size:.78rem;color:#64748b;margin-top:2px;">
                @if (pwdLastChanged.HasValue)
                {
                    <span>Son değişiklik: @pwdLastChanged.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                }
                else { <span>Henüz değiştirilmedi</span> }
            </div>
        </div>
    </div>

    <div class="sm-field">
        <label>Mevcut Şifre</label>
        <input type="password" class="sm-input" id="pwdCurrent" autocomplete="current-password" />
    </div>
    <div class="sm-row2">
        <div class="sm-field">
            <label>Yeni Şifre</label>
            <input type="password" class="sm-input" id="pwdNew" autocomplete="new-password" oninput="pwdMeter()" />
        </div>
        <div class="sm-field">
            <label>Yeni Şifre (Tekrar)</label>
            <input type="password" class="sm-input" id="pwdNew2" autocomplete="new-password" />
        </div>
    </div>
    <div class="sm-meter"><div class="sm-meter-bar" id="pwdBar"></div></div>
    <div style="font-size:.74rem;color:#64748b;margin-bottom:14px;">En az 10 karakter, büyük/küçük harf, rakam ve özel karakter içermelidir.</div>
    <button type="button" class="sm-btn" id="pwdBtn">Şifreyi Değiştir</button>
    <div id="pwdMsg" style="margin-top:8px;min-height:24px;font-size:.76rem;"></div>
</div>

<form id="pwdAfForm" style="display:none;">@Html.AntiForgeryToken()</form>

@section Scripts {
<script>
(function () {
    function getAf() { return (document.querySelector('#pwdAfForm input[name="__RequestVerificationToken"]') || {}).value || ''; }
    function setMsg(text, ok) {
        var el = document.getElementById('pwdMsg');
        var cls = ok === true ? 'color:#16a34a' : ok === false ? 'color:#dc2626' : 'color:#64748b';
        el.innerHTML = text ? '<span style="' + cls + '">' + text + '</span>' : '';
    }
    window.pwdMeter = function () {
        var v = document.getElementById('pwdNew').value;
        var score = [v.length >= 10, /[A-Z]/.test(v), /[a-z]/.test(v), /\d/.test(v), /[^A-Za-z0-9]/.test(v)].filter(Boolean).length;
        var bar = document.getElementById('pwdBar');
        bar.style.width = (score / 5 * 100) + '%';
        bar.style.background = score <= 2 ? '#ef4444' : score === 3 ? '#f59e0b' : score === 4 ? '#eab308' : '#22c55e';
    };
    document.getElementById('pwdBtn').addEventListener('click', function () {
        var cur = document.getElementById('pwdCurrent').value;
        var n1  = document.getElementById('pwdNew').value;
        var n2  = document.getElementById('pwdNew2').value;
        if (!cur || !n1 || !n2) { setMsg('Tüm alanlar dolu olmalı.', false); return; }
        if (n1 !== n2) { setMsg('Yeni şifreler eşleşmiyor.', false); return; }
        var btn = document.getElementById('pwdBtn');
        btn.disabled = true; btn.textContent = 'Değiştiriliyor…';
        setMsg('', null);
        var fd = new FormData();
        fd.append('currentPassword', cur); fd.append('newPassword', n1);
        fd.append('__RequestVerificationToken', getAf());
        fetch('/Gate/Password/Change', { method:'POST', body:fd, credentials:'same-origin' })
            .then(function(r){return r.json();})
            .then(function(d){
                btn.disabled = false; btn.textContent = 'Şifreyi Değiştir';
                setMsg((d.success?'✓ ':'✗ ')+(d.message||(d.success?'Şifre değiştirildi.':'Hata.')), d.success);
                if (d.success) {
                    document.getElementById('pwdCurrent').value=''; document.getElementById('pwdNew').value=''; document.getElementById('pwdNew2').value=''; pwdMeter();
                    setTimeout(function(){location.href='/Gate/Logout';}, 1000);
                }
            })
            .catch(function(ex){btn.disabled=false;btn.textContent='Şifreyi Değiştir';setMsg('Hata: '+ex.message,false);});
    });
})();
</script>
}
