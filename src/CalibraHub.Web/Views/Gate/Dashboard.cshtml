@{
    Layout = null;
    ViewData["Title"] = "Sistem Ayarları";
    var license = ViewBag.License as CalibraHub.Domain.Entities.LicenseRecord;
    var machineId = (string)(ViewBag.MachineId ?? "");
    var pwdLastChanged = ViewBag.PasswordLastChanged as DateTime?;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0; min-height: 100vh;
            background: linear-gradient(135deg, #0f172a, #1e1b4b 100%);
            color: #e2e8f0;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }
        .sa-wrap { max-width: 960px; margin: 0 auto; padding: 32px 24px; }
        .sa-head { display: flex; align-items: center; gap: 14px; margin-bottom: 24px; flex-wrap: wrap; }
        .sa-icon {
            width: 44px; height: 44px; border-radius: 12px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex; align-items: center; justify-content: center;
        }
        .sa-title { font-size: 1.4rem; font-weight: 700; margin: 0; }
        .sa-sub { color: rgba(255,255,255,.55); font-size: .82rem; margin-top: 2px; }
        .sa-logout {
            margin-left: auto;
            background: rgba(239,68,68,.12); border: 1px solid rgba(239,68,68,.3);
            color: #fca5a5; cursor: pointer;
            padding: 7px 14px; border-radius: 7px; font-size: .8rem; text-decoration: none;
        }
        .sa-logout:hover { background: rgba(239,68,68,.22); }
        .sa-back {
            background: rgba(99,102,241,.12); border: 1px solid rgba(99,102,241,.3);
            color: #a5b4fc; cursor: pointer;
            padding: 7px 14px; border-radius: 7px; font-size: .8rem; text-decoration: none;
        }
        .sa-back:hover { background: rgba(99,102,241,.22); }

        .sa-tabs { display: flex; gap: 4px; margin-bottom: 18px; border-bottom: 1px solid rgba(255,255,255,.1); }
        .sa-tab {
            padding: 10px 18px;
            color: rgba(255,255,255,.55); cursor: pointer;
            border: none; background: none; font-size: .88rem; font-weight: 600;
            border-bottom: 2px solid transparent;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .sa-tab:hover { color: rgba(255,255,255,.85); }
        .sa-tab.is-active {
            color: #a5b4fc;
            border-bottom-color: #6366f1;
        }

        .sa-panel { background: rgba(21,24,43,.6); border: 1px solid rgba(99,102,241,.18); border-radius: 14px; padding: 24px; }

        .sa-field { margin-bottom: 14px; }
        .sa-field label { display: block; font-size: .76rem; font-weight: 600; color: rgba(255,255,255,.72); margin-bottom: 4px; }
        .sa-input, .sa-textarea {
            width: 100%; padding: 9px 12px;
            background: #0f1120; border: 1px solid #2a2f47; border-radius: 8px;
            color: #e2e8f0; font-size: .88rem;
        }
        .sa-textarea { font-family: ui-monospace, Consolas, monospace; font-size: .8rem; resize: vertical; min-height: 90px; }
        .sa-input:focus, .sa-textarea:focus { outline: none; border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.2); }

        .sa-btn {
            padding: 9px 18px; border-radius: 8px; border: none; cursor: pointer;
            background: linear-gradient(135deg, #6366f1, #4f46e5); color: #fff;
            font-size: .85rem; font-weight: 600;
        }
        .sa-btn:hover { filter: brightness(1.1); }
        .sa-btn[disabled] { opacity: .5; cursor: not-allowed; }
        .sa-btn--sec {
            background: rgba(148,163,184,.1); color: rgba(255,255,255,.85);
            border: 1px solid rgba(148,163,184,.25);
        }
        .sa-btn--sec:hover { background: rgba(148,163,184,.18); }

        .sa-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

        .sa-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 18px; }
        .sa-info-box {
            padding: 12px 14px;
            background: rgba(0,0,0,.2);
            border: 1px solid rgba(99,102,241,.15);
            border-radius: 8px;
        }
        .sa-info-label { font-size: .7rem; color: rgba(255,255,255,.5); text-transform: uppercase; letter-spacing: .5px; font-weight: 600; margin-bottom: 4px; }
        .sa-info-value { font-size: .9rem; font-weight: 600; color: #e2e8f0; font-family: ui-monospace, Consolas, monospace; }

        .sa-license-status {
            padding: 14px 16px; border-radius: 10px; margin-bottom: 16px;
            display: flex; align-items: center; gap: 12px;
        }
        .sa-license-status--ok  { background: rgba(34,197,94,.1);  border: 1px solid rgba(34,197,94,.3); }
        .sa-license-status--err { background: rgba(239,68,68,.1);  border: 1px solid rgba(239,68,68,.3); }
        .sa-license-status--none{ background: rgba(148,163,184,.08); border: 1px solid rgba(148,163,184,.2); }
        .sa-license-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
        .sa-license-status--ok  .sa-license-dot { background: #22c55e; box-shadow: 0 0 10px rgba(34,197,94,.6); }
        .sa-license-status--err .sa-license-dot { background: #ef4444; box-shadow: 0 0 10px rgba(239,68,68,.6); }
        .sa-license-status--none .sa-license-dot { background: #94a3b8; }
        .sa-license-status-text { flex: 1; }
        .sa-license-status-title { font-weight: 700; font-size: .9rem; }
        .sa-license-status-msg { font-size: .76rem; color: rgba(255,255,255,.6); margin-top: 2px; }
    </style>
</head>
<body>
    <div class="sa-wrap">
        <div class="sa-head">
            <div class="sa-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </div>
            <div>
                <h1 class="sa-title">Sistem Ayarları</h1>
                <div class="sa-sub">Veri tabanı yönetimi ve lisans</div>
            </div>
            <a href="/Gate/Logout?returnUrl=%2F" class="sa-back">← Ana Sayfa</a>
            <a href="/Gate/Logout" class="sa-logout">🔒 Kilitle</a>
        </div>

        <div class="sa-tabs">
            <button class="sa-tab is-active" data-tab="license" onclick="saTab('license')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="7" y1="9" x2="17" y2="9"/><line x1="7" y1="13" x2="14" y2="13"/></svg>
                Lisans Yönetimi
            </button>
            <button class="sa-tab" data-tab="db" onclick="saTab('db')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 11v6c0 1.66 4 3 9 3s9-1.34 9-3v-6"/></svg>
                Veri Tabanı Ayarları
            </button>
            <button class="sa-tab" data-tab="pwd" onclick="saTab('pwd')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Şifre Değiştir
            </button>
        </div>

        <div class="sa-panel" id="tab-license">
            @{
                var statusCls = license is null ? "none" : (license.IsValid ? "ok" : "err");
                var statusTitle = license is null ? "Lisans Yok"
                    : (license.IsValid ? "Aktif Lisans"
                    : $"Geçersiz: {license.LastError}");
                var statusMsg = license is null ? "Henuz lisans kaydedilmedi. Asagidaki alana lisans anahtarinizi yapistirin."
                    : (license.IsValid
                        ? $"Gecerlilik: {license.ExpiryDate:dd.MM.yyyy} · Eszamanli: {(license.ConcurrentLimit == 0 ? "Limitsiz" : license.ConcurrentLimit?.ToString() ?? "-")} · Toplam: {(license.TotalUserLimit == 0 ? "Limitsiz" : license.TotalUserLimit?.ToString() ?? "-")}"
                        : $"Son dogrulama: {license.LastValidatedAt:dd.MM.yyyy HH:mm}");
            }
            <div class="sa-license-status sa-license-status--@statusCls">
                <div class="sa-license-dot"></div>
                <div class="sa-license-status-text">
                    <div class="sa-license-status-title">@statusTitle</div>
                    <div class="sa-license-status-msg">@statusMsg</div>
                </div>
            </div>

            <div class="sa-info-grid">
                <div class="sa-info-box">
                    <div class="sa-info-label">Makine ID (binding)</div>
                    <div class="sa-info-value">@machineId</div>
                </div>
                <div class="sa-info-box">
                    <div class="sa-info-label">Durum</div>
                    <div class="sa-info-value">@(license?.IsValid == true ? "✓ Gecerli" : license is null ? "— Tanimsiz" : "✗ Gecersiz")</div>
                </div>
            </div>

            <div class="sa-field">
                <label>Lisans Anahtarı</label>
                <textarea class="sa-textarea" id="licKey" placeholder="Lisans anahtarınızı buraya yapistirin...">@license?.LicenseKey</textarea>
                <div style="font-size:.72rem; color:rgba(255,255,255,.5); margin-top:4px;">
                    Lisans anahtarınız <b>son kullanma tarihi</b>, <b>eş zamanlı kullanıcı limiti</b> ve
                    <b>toplam kullanıcı sayısı</b> bilgilerini içerir. Bu makineye (Makine ID) bağlıdır.
                </div>
            </div>
            <div style="display:flex; gap:8px;">
                <button type="button" class="sa-btn" onclick="saSaveLicense()">Kaydet ve Dogrula</button>
            </div>
        </div>

        <div class="sa-panel" id="tab-db" style="display:none;">
            <div style="display:flex; align-items:flex-start; gap:14px; margin-bottom:18px;">
                <div style="flex-shrink:0; width:38px; height:38px; border-radius:10px; background:rgba(99,102,241,.12); display:flex; align-items:center; justify-content:center;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 11v6c0 1.66 4 3 9 3s9-1.34 9-3v-6"/></svg>
                </div>
                <div>
                    <div style="font-weight:700; font-size:.95rem;">SQL Server Bağlantısı</div>
                    <div style="font-size:.78rem; color:rgba(255,255,255,.55); margin-top:2px;">
                        Sistem veri tabanına bağlantı bilgileri. Kayıt sonrası uygulamanın yeniden başlatılması gerekir.
                    </div>
                </div>
            </div>

            <div class="sa-field">
                <label>Sunucu Adı</label>
                <input id="dbServer" type="text" class="sa-input" placeholder="localhost veya 192.168.1.1\SQLEXPRESS" autocomplete="off" />
            </div>
            <div class="sa-field">
                <label>Veri Tabanı Adı</label>
                <input id="dbDatabase" type="text" class="sa-input" placeholder="CalibraHub" autocomplete="off" />
            </div>
            <div class="sa-row">
                <div class="sa-field">
                    <label>Kullanıcı Adı</label>
                    <input id="dbUser" type="text" class="sa-input" placeholder="sa" autocomplete="off" />
                </div>
                <div class="sa-field">
                    <label>Şifre</label>
                    <input id="dbPassword" type="password" class="sa-input" placeholder="Değiştirmek için girin" autocomplete="new-password" />
                </div>
            </div>

            <div id="dbMsg" style="margin: 6px 0 14px; min-height: 24px; font-size: .76rem;"></div>

            <div style="display:flex; gap:8px; flex-wrap:wrap;">
                <button type="button" class="sa-btn sa-btn--sec" onclick="saTestDb()">Bağlantıyı Test Et</button>
                <button type="button" class="sa-btn" onclick="saSaveDb()">Kaydet</button>
            </div>
        </div>

        <div class="sa-panel" id="tab-pwd" style="display:none;">
            <div style="display:flex; align-items:flex-start; gap:14px; margin-bottom:18px;">
                <div style="flex-shrink:0; width:38px; height:38px; border-radius:10px; background:rgba(99,102,241,.12); display:flex; align-items:center; justify-content:center;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
                <div>
                    <div style="font-weight:700; font-size:.95rem;">Sistem Ayarları Şifresi</div>
                    <div style="font-size:.78rem; color:rgba(255,255,255,.55); margin-top:2px;">
                        @if (pwdLastChanged.HasValue)
                        {
                            <span>Son değişiklik: @pwdLastChanged.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        }
                        else
                        {
                            <span>Henüz değiştirilmedi</span>
                        }
                    </div>
                </div>
            </div>

            <div class="sa-field">
                <label>Mevcut Şifre</label>
                <input type="password" class="sa-input" id="pwdCurrent" autocomplete="current-password" />
            </div>
            <div class="sa-row">
                <div class="sa-field">
                    <label>Yeni Şifre</label>
                    <input type="password" class="sa-input" id="pwdNew" autocomplete="new-password"
                           oninput="saPwdMeter()" />
                </div>
                <div class="sa-field">
                    <label>Yeni Şifre (Tekrar)</label>
                    <input type="password" class="sa-input" id="pwdNew2" autocomplete="new-password" />
                </div>
            </div>
            <div id="pwdMeter" style="height:6px; border-radius:3px; background:rgba(255,255,255,.08); overflow:hidden; margin-bottom:8px;">
                <div id="pwdMeterBar" style="height:100%; width:0; background:#ef4444; transition: width .2s, background .2s;"></div>
            </div>
            <div style="font-size:.74rem; color:rgba(255,255,255,.55); line-height:1.5; margin-bottom:14px;">
                <b>Kurallar:</b> en az 10 karakter, en az bir büyük harf, bir küçük harf, bir rakam ve bir özel karakter (örn. <code>.!@@#$</code>).
            </div>
            <button type="button" class="sa-btn" onclick="saChangePwd()">Şifreyi Değiştir</button>
        </div>

    </div>

    <form id="csrfForm" style="display:none;">@Html.AntiForgeryToken()</form>
    <script>
        function saTab(name) {
            document.querySelectorAll('.sa-tab').forEach(function(t){ t.classList.toggle('is-active', t.dataset.tab === name); });
            document.getElementById('tab-license').style.display = (name === 'license' ? '' : 'none');
            document.getElementById('tab-db').style.display      = (name === 'db'      ? '' : 'none');
            document.getElementById('tab-pwd').style.display     = (name === 'pwd'     ? '' : 'none');
            if (name === 'db' && !window.__dbLoaded) { saLoadDb(); window.__dbLoaded = true; }
        }
        function saDbMsg(text, ok) {
            var el = document.getElementById('dbMsg');
            if (!text) { el.innerHTML = ''; return; }
            var bg = ok === null ? 'rgba(148,163,184,.1)'  : (ok ? 'rgba(34,197,94,.12)' : 'rgba(239,68,68,.12)');
            var cl = ok === null ? 'rgba(255,255,255,.7)'  : (ok ? '#86efac' : '#fca5a5');
            var br = ok === null ? 'rgba(148,163,184,.25)' : (ok ? 'rgba(34,197,94,.3)' : 'rgba(239,68,68,.3)');
            el.innerHTML = '<span style="display:inline-block;padding:5px 12px;border-radius:6px;background:'
                + bg + ';color:' + cl + ';border:1px solid ' + br + ';">' + text + '</span>';
        }
        function saLoadDb() {
            saDbMsg('Mevcut ayarlar okunuyor...', null);
            fetch('/Account/GetDbSettings', { credentials:'same-origin' })
                .then(function(r){ return r.json(); })
                .then(function(d){
                    if (d.success) {
                        document.getElementById('dbServer').value   = d.server   || '';
                        document.getElementById('dbDatabase').value = d.database || '';
                        document.getElementById('dbUser').value     = d.user     || '';
                        document.getElementById('dbPassword').value = '';
                        saDbMsg('', null);
                    } else {
                        saDbMsg('Mevcut ayarlar okunamadi: ' + (d.message || ''), false);
                    }
                })
                .catch(function(){ saDbMsg('Mevcut ayarlar okunamadi.', false); });
        }
        function saDbPayload() {
            return {
                server:   document.getElementById('dbServer').value.trim(),
                database: document.getElementById('dbDatabase').value.trim(),
                user:     document.getElementById('dbUser').value.trim(),
                password: document.getElementById('dbPassword').value
            };
        }
        function saTestDb() {
            saDbMsg('Baglanti test ediliyor...', null);
            fetch('/Account/TestDbSettings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(saDbPayload()),
                credentials:'same-origin'
            })
                .then(function(r){ return r.json(); })
                .then(function(d){ saDbMsg(d.message || (d.success ? 'Baglanti basarili.' : 'Hata.'), d.success); })
                .catch(function(e){ saDbMsg('Hata: ' + e.message, false); });
        }
        function saSaveDb() {
            saDbMsg('Test ediliyor, basarili ise kaydedilecek...', null);
            fetch('/Account/SaveDbSettings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(saDbPayload()),
                credentials:'same-origin'
            })
                .then(function(r){ return r.json(); })
                .then(function(d){ saDbMsg(d.message || (d.success ? 'Kaydedildi. Uygulamayi yeniden baslatin.' : 'Hata.'), d.success); })
                .catch(function(e){ saDbMsg('Hata: ' + e.message, false); });
        }
        function saPwdMeter() {
            var v = document.getElementById('pwdNew').value;
            var score = 0;
            if (v.length >= 10) score++;
            if (/[A-Z]/.test(v)) score++;
            if (/[a-z]/.test(v)) score++;
            if (/\d/.test(v)) score++;
            if (/[^A-Za-z0-9]/.test(v)) score++;
            var bar = document.getElementById('pwdMeterBar');
            var pct = (score / 5) * 100;
            bar.style.width = pct + '%';
            bar.style.background = score <= 2 ? '#ef4444' : score === 3 ? '#f59e0b' : score === 4 ? '#eab308' : '#22c55e';
        }
        function saChangePwd() {
            var cur = document.getElementById('pwdCurrent').value;
            var n1  = document.getElementById('pwdNew').value;
            var n2  = document.getElementById('pwdNew2').value;
            if (!cur || !n1 || !n2) { alert('Tum alanlar dolu olmali.'); return; }
            if (n1 !== n2) { alert('Yeni sifreler eslesmiyor.'); return; }
            var fd = new FormData();
            fd.append('currentPassword', cur);
            fd.append('newPassword', n1);
            fd.append('__RequestVerificationToken', getCsrf());
            fetch('/Gate/Password/Change', { method:'POST', body: fd, credentials:'same-origin' })
                .then(function(r){ return r.json(); })
                .then(function(d){
                    alert((d.success ? '✓ ' : '✗ ') + (d.message || (d.success ? 'Sifre degistirildi.' : 'Hata.')));
                    if (d.success) {
                        document.getElementById('pwdCurrent').value = '';
                        document.getElementById('pwdNew').value = '';
                        document.getElementById('pwdNew2').value = '';
                        saPwdMeter();
                        // Yeni sifre ile tekrar giris yapmasi icin Logout'a yonlendir
                        setTimeout(function(){ location.href = '/Gate/Logout'; }, 800);
                    }
                });
        }
        function getCsrf() { return document.querySelector('input[name="__RequestVerificationToken"]').value; }
        function saSaveLicense() {
            var keyEl = document.getElementById('licKey');
            var key = keyEl.value.trim();
            if (!key) {
                keyEl.style.borderColor = '#ef4444';
                keyEl.focus();
                setTimeout(function(){ keyEl.style.borderColor = ''; }, 2000);
                return;
            }
            var fd = new FormData();
            fd.append('licenseKey', key);
            fd.append('__RequestVerificationToken', getCsrf());
            fetch('/Gate/License/Save', { method:'POST', body: fd, credentials:'same-origin' })
                .then(function(r){ return r.json(); })
                .then(function(){ location.reload(); });
        }
    </script>
</body>
</html>
