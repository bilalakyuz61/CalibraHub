@{
    ViewData["Title"] = "Sistem Yönetimi — Şirket Tanımları";
    ViewData["BodyClass"] = "page-system-mgmt";
}

@section Styles {
<style>
    .page-system-mgmt .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-system-mgmt .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important;
        margin: 0 !important; overflow: hidden !important;
    }
    .workspace-frame-body.page-system-mgmt .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-system-mgmt .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    /* Company modal */
    .sc-modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(15,23,42,.62);
        backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        z-index: 9000; padding: 20px;
        animation: sc-fade-in .18s ease-out;
    }
    @@keyframes sc-fade-in { from { opacity:0; } to { opacity:1; } }
    .sc-modal {
        background: var(--surface-1, #ffffff);
        color: var(--text-1, #0f172a);
        border-radius: 14px;
        box-shadow: 0 24px 48px rgba(15,23,42,.32), 0 0 0 1px rgba(99,102,241,.18);
        width: 100%; max-width: 480px;
        max-height: calc(100vh - 40px);
        display: flex; flex-direction: column; overflow: hidden;
        animation: sc-slide-up .22s ease-out;
    }
    @@keyframes sc-slide-up { from { transform:translateY(12px); opacity:0; } to { transform:translateY(0); opacity:1; } }
    body.app-theme-dark .sc-modal { background:#111827; color:#e5e7eb; }
    .sc-modal__header {
        display: flex; align-items: center; gap: 12px;
        padding: 16px 20px;
        border-bottom: 1px solid rgba(148,163,184,.18);
        background: linear-gradient(180deg, rgba(99,102,241,.10) 0%, rgba(99,102,241,.02) 100%);
    }
    .sc-modal__icon {
        width: 36px; height: 36px; border-radius: 10px;
        background: linear-gradient(135deg, #6366f1, #818cf8);
        color: #fff; display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .sc-modal__title { font-size: 16px; font-weight: 600; margin: 0; flex: 1; }
    .sc-modal__close {
        border: none; background: transparent; cursor: pointer;
        padding: 6px; border-radius: 6px; color: #64748b;
    }
    .sc-modal__close:hover { background: rgba(148,163,184,.18); }
    .sc-modal__body { padding: 16px 20px; overflow-y: auto; flex: 1; }
    .sc-modal__footer {
        padding: 14px 20px; border-top: 1px solid rgba(148,163,184,.18);
        display: flex; justify-content: flex-end; gap: 8px;
        background: rgba(248,250,252,.6);
    }
    body.app-theme-dark .sc-modal__footer { background: rgba(15,23,42,.6); }

    .sc-row { display: grid; grid-template-columns: 100px 1fr; align-items: center; gap: 0 8px; margin-bottom: 8px; }
    .sc-row label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: #64748b; text-align: right; }
    body.app-theme-dark .sc-row label { color: #94a3b8; }
    .sc-row input[type=text], .sc-row input[type=password] {
        width: 100%; padding: 7px 10px;
        border: 1px solid rgba(148,163,184,.4); border-radius: 7px;
        font-size: .82rem; font-family: inherit;
        background: transparent; color: inherit; outline: none; box-sizing: border-box;
    }
    .sc-row input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.15); }
    body.app-theme-dark .sc-row input { border-color: rgba(148,163,184,.3); }

    .sc-section-head {
        font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
        color: #64748b; padding: 10px 0 6px; border-top: 1px solid rgba(148,163,184,.2); margin-top: 4px;
    }
    .sc-switch-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .sc-switch-row > span { font-size: .82rem; font-weight: 600; color: #334155; }
    body.app-theme-dark .sc-switch-row > span { color: #cbd5e1; }
    .sc-switch { position: relative; display: inline-block; width: 44px; height: 24px; }
    .sc-switch input { opacity: 0; width: 0; height: 0; }
    .sc-switch__track {
        position: absolute; cursor: pointer; inset: 0;
        background: #cbd5e1; border-radius: 24px; transition: background .2s;
    }
    .sc-switch__track::before {
        content: ""; position: absolute;
        height: 18px; width: 18px; left: 3px; top: 3px;
        background: #fff; border-radius: 50%;
        transition: transform .2s; box-shadow: 0 1px 3px rgba(0,0,0,.18);
    }
    .sc-switch input:checked + .sc-switch__track { background: #6366f1; }
    .sc-switch input:checked + .sc-switch__track::before { transform: translateX(20px); }

    .sc-btn {
        padding: 8px 18px; border-radius: 8px; font-size: 13px; font-weight: 600;
        border: 1px solid transparent; cursor: pointer;
    }
    .sc-btn--ghost { background: transparent; color: #475569; border-color: rgba(148,163,184,.4); }
    .sc-btn--ghost:hover { background: rgba(148,163,184,.1); }
    body.app-theme-dark .sc-btn--ghost { color: #cbd5e1; }
    .sc-btn--primary { background: #6366f1; color: #fff; border-color: #6366f1; }
    .sc-btn--primary:hover { background: #4f46e5; }
    .sc-btn--primary:disabled { opacity: .6; cursor: not-allowed; }
    .sc-btn--sec { background: rgba(148,163,184,.08); color: #475569; border-color: rgba(148,163,184,.3); font-size: 12px; padding: 6px 12px; }
    .sc-btn--sec:hover { background: rgba(148,163,184,.18); }
    body.app-theme-dark .sc-btn--sec { color: #cbd5e1; }

    .sc-error {
        margin-top: 8px; padding: 8px 12px;
        background: rgba(239,68,68,.1); color: #dc2626;
        border: 1px solid rgba(239,68,68,.3);
        border-radius: 6px; font-size: 12px;
    }
    body.app-theme-dark .sc-error { color: #fca5a5; }

    .sc-test-msg { font-size: .75rem; margin-top: 6px; padding: 5px 10px; border-radius: 6px; display: none; }
    .sc-test-msg.ok  { background: rgba(34,197,94,.1);  color: #16a34a; border: 1px solid rgba(34,197,94,.3); display: block; }
    .sc-test-msg.err { background: rgba(239,68,68,.1);  color: #dc2626; border: 1px solid rgba(239,68,68,.3); display: block; }
    .sc-test-msg.inf { background: rgba(99,102,241,.1); color: #4f46e5; border: 1px solid rgba(99,102,241,.3); display: block; }
    body.app-theme-dark .sc-test-msg.ok  { color: #86efac; }
    body.app-theme-dark .sc-test-msg.err { color: #fca5a5; }
    body.app-theme-dark .sc-test-msg.inf { color: #a5b4fc; }
</style>
}

<partial name="_SistemAyarlariTabs" model='"companies"' />

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">
    <div id="reactSmartBoard" style="flex:1 1 auto;min-height:0;overflow:hidden;"></div>
</section>

@* Company add/edit modal *@
<div id="scModalRoot" style="display:none;">
    <div class="sc-modal-backdrop" id="scModalBackdrop">
        <div class="sc-modal" role="dialog" aria-modal="true">
            <div class="sc-modal__header">
                <div class="sc-modal__icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/></svg>
                </div>
                <h3 class="sc-modal__title" id="scModalTitle">Yeni Şirket</h3>
                <button type="button" class="sc-modal__close" id="scModalClose">✕</button>
            </div>
            <div class="sc-modal__body">
                <form id="scForm">
                    <input type="hidden" id="scId" />
                    <div class="sc-row">
                        <label>Şirket Adı <span style="color:#dc2626">*</span></label>
                        <input type="text" id="scName" required maxlength="200" autocomplete="off" />
                    </div>
                    <div class="sc-row" style="margin-bottom:6px;">
                        <label>Aktif</label>
                        <label class="sc-switch" style="justify-self:start;">
                            <input type="checkbox" id="scIsActive" checked />
                            <span class="sc-switch__track"></span>
                        </label>
                    </div>

                    <div id="scError" class="sc-error" style="display:none;"></div>
                </form>
            </div>
            <div class="sc-modal__footer">
                <button type="button" class="sc-btn sc-btn--ghost" id="scCancelBtn">Vazgeç</button>
                <button type="button" class="sc-btn sc-btn--primary" id="scSaveBtn">Kaydet</button>
            </div>
        </div>
    </div>
</div>

<form id="scAfForm" style="display:none;">@Html.AntiForgeryToken()</form>

@section Scripts {
<script>
(function () {
    var BUNDLE_URL = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
    var CSS_URL    = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
    var el = document.getElementById('reactSmartBoard');

    function getAf() {
        var inp = document.querySelector('#scAfForm input[name="__RequestVerificationToken"]');
        return inp ? inp.value : '';
    }

    function showBoardError(msg) {
        el.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#f87171;padding:20px;">' + msg + '</div>';
    }

    function mountBoard(config) {
        if (!window.CalibraHub || !window.CalibraHub.mountSmartBoard) { showBoardError('SmartBoard yüklenemedi'); return; }
        try { window.CalibraHub.mountSmartBoard(el, config); }
        catch (ex) { showBoardError('Mount hatası: ' + (ex.message || ex)); }
    }

    function loadAndMount() {
        fetch('/Setup/CompanyBoardConfig', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (cfg) { mountBoard(cfg); })
            .catch(function (ex) { showBoardError('Config yüklenemedi: ' + ex.message); });
    }

    function loadCss() {
        if (document.querySelector('link[data-sc-sb]')) return;
        var l = document.createElement('link');
        l.rel = 'stylesheet'; l.href = CSS_URL;
        l.setAttribute('data-sc-sb', '1');
        document.head.appendChild(l);
    }

    function initBoard() {
        loadCss();
        if (window.CalibraHub && window.CalibraHub.mountSmartBoard) loadAndMount();
        else {
            var s = document.createElement('script');
            s.src = BUNDLE_URL; s.setAttribute('data-sc-sb', '1');
            s.onload = function () { setTimeout(loadAndMount, 0); };
            s.onerror = function () { showBoardError('Bundle yüklenemedi'); };
            document.head.appendChild(s);
        }
    }
    initBoard();

    // ── Modal (guard: React Shell outer context'te modal HTML olmayabilir) ──
    if (!document.getElementById('scModalRoot')) return;
    var modalRoot   = document.getElementById('scModalRoot');
    var modalTitle  = document.getElementById('scModalTitle');
    var scId        = document.getElementById('scId');
    var scName      = document.getElementById('scName');
    var scIsActive  = document.getElementById('scIsActive');
    var scError     = document.getElementById('scError');
    var scSaveBtn   = document.getElementById('scSaveBtn');

    function showErr(msg) { scError.textContent = msg; scError.style.display = 'block'; }
    function clearErr()   { scError.style.display = 'none'; scError.textContent = ''; }

    function openModal(companyId) {
        clearErr();
        modalRoot.style.display = 'block';
        if (companyId) {
            modalTitle.textContent = 'Şirket Düzenle';
            fetch('/Setup/GetCompaniesJson', { credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (list) {
                    var c = (list || []).find(function (x) { return x.id == companyId; });
                    if (!c) { showErr('Şirket bulunamadı.'); return; }
                    scId.value         = c.id;
                    scName.value       = c.name || '';
                    scIsActive.checked = !!c.isActive;
                    setTimeout(function () { scName.focus(); }, 30);
                });
        } else {
            modalTitle.textContent = 'Yeni Şirket';
            scId.value = ''; scName.value = ''; scIsActive.checked = true;
            setTimeout(function () { scName.focus(); }, 30);
        }
    }

    function closeModal() {
        modalRoot.style.display = 'none';
        if (location.hash) history.replaceState(null, '', location.pathname + location.search);
    }

    document.getElementById('scModalClose').addEventListener('click', closeModal);
    document.getElementById('scCancelBtn').addEventListener('click', closeModal);
    document.getElementById('scModalBackdrop').addEventListener('click', function (e) {
        if (e.target === document.getElementById('scModalBackdrop')) closeModal();
    });
    document.addEventListener('keydown', function (e) {
        if (modalRoot.style.display !== 'none') {
            if (e.key === 'Escape') closeModal();
        }
    });

    scSaveBtn.addEventListener('click', function () {
        clearErr();
        var name = (scName.value || '').trim();
        if (!name) { showErr('Şirket adı zorunludur.'); scName.focus(); return; }

        scSaveBtn.disabled = true; scSaveBtn.textContent = 'Kaydediliyor…';
        fetch('/Setup/SaveCompanyJson', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAf() },
            body: JSON.stringify({
                id: scId.value ? parseInt(scId.value) : null,
                name: name,
                isActive: !!scIsActive.checked
                // Şirket bazlı DB özelliği kaldırıldı — tüm şirketler sistem DB'sini kullanır.
            })
        })
        .then(function (r) { return r.json(); })
        .then(function (d) {
            scSaveBtn.disabled = false; scSaveBtn.textContent = 'Kaydet';
            if (d.success) {
                closeModal();
                if (typeof window._smartBoardRefreshAll === 'function') window._smartBoardRefreshAll();
                else location.reload();
            } else {
                showErr(d.message || 'Kayıt başarısız.');
            }
        })
        .catch(function (ex) {
            scSaveBtn.disabled = false; scSaveBtn.textContent = 'Kaydet';
            showErr('Sunucu hatası: ' + ex.message);
        });
    });

    // Hash listener
    function handleHash() {
        var h = (location.hash || '').replace(/^#/, '').split('?')[0];
        if (h === 'open-new-company-modal') openModal(null);
        else if (h.startsWith('edit-company-')) openModal(h.substring('edit-company-'.length));
    }
    window.addEventListener('hashchange', handleHash);
    if (location.hash) setTimeout(handleHash, 200);
    window.addEventListener('pageshow', function (e) { if (e.persisted) location.reload(); });
})();
</script>
}
