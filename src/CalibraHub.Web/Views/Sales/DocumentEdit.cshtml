    /**
     * Stok karti pattern: Cari Kod input'a el ile yazip blur (Tab/Enter/disari tik)
     * yapilinca DB'de lookup. Varsa otomatik dolar (Id+Name+SalesRepId), yoksa
     * yeni cari ekranina (ContactEdit) yonlendirir — code parametresi ile.
     * AttachGuide rehber pick'i hala calisir; bu el-yazimi alternatif.
     */
    (function attachCustomerCodeLookup() {
        var disp = document.getElementById('sqCustomerDisplay');
        if (!disp) return;
        var idEl   = document.getElementById('sqCustomerId');
        var nameEl = document.getElementById('sqCustomerName');
        var repEl  = document.getElementById('sqSalesRepId');

        // Last-fetched code — ayni kod tekrar lookup yapmasin (tab toggling).
        var lastChecked = '';

        async function lookupAndFill() {
            var code = (disp.value || '').trim();
            if (!code || code === lastChecked) return;
            // Eger zaten Id dolu ve display ona ait kod ise atla (rehberden secim)
            if (idEl && idEl.value && idEl.getAttribute('data-display') === code) {
                lastChecked = code;
                return;
            }
            lastChecked = code;

            try {
                var r = await fetch('/Finance/GetContact?code=' + encodeURIComponent(code),
                    { credentials: 'same-origin' });
                if (r.ok) {
                    // BULDU — dolduran alanlar (rehberden gelmis gibi)
                    var c = await r.json();
                    if (idEl)   { idEl.value = c.id; idEl.setAttribute('data-display', c.accountCode); }
                    if (nameEl)  nameEl.textContent = c.accountTitle || c.accountCode || '';
                    if (repEl && c.salesRepId) repEl.value = c.salesRepId;
                    disp.value = c.accountCode;
                    disp.classList.remove('is-invalid');
                    // ffl-sync — diger lookup-bagimli alanlari tetikle
                    try { disp.dispatchEvent(new CustomEvent('ffl-sync', { bubbles: true })); } catch (_) {}
                    return;
                }
                if (r.status === 404) {
                    // YOK — kullaniciya sor; istiyorsa yeni cari ekrani ac
                    var msg = '"' + code + '" kodlu cari bulunamadi.\n\nYeni cari hesap olusturmak ister misiniz?';
                    var ok = (window.CalibraAlert && CalibraAlert.confirm)
                        ? await CalibraAlert.confirm(msg, { title: 'Cari Bulunamadi', okText: 'Yeni Cari Ekle', cancelText: 'Vazgec' })
                        : window.confirm(msg);
                    if (ok) {
                        // Yeni sekme: cari karti olustur, code on-fill
                        var url = '/Finance/ContactEdit?new=1&code=' + encodeURIComponent(code);
                        window.open(url, '_blank', 'noopener');
                    }
                    // Reset: kullanici tekrar denesin
                    disp.value = '';
                    if (idEl) { idEl.value = ''; idEl.removeAttribute('data-display'); }
                    if (nameEl) nameEl.textContent = '';
                    lastChecked = '';
                }
            } catch (e) {
                if (window.CalibraHub && CalibraHub.toast)
                    CalibraHub.toast('Cari lookup hatasi: ' + e.message, 'err');
            }
        }

        disp.addEventListener('blur', lookupAndFill);
        disp.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === 'Tab') {
                // Enter: lookup et + form'un submit edilmesini engelle
                if (e.key === 'Enter') e.preventDefault();
                lookupAndFill();
            }
        });
    })();

    /**
     * openOrderLookup — Sipariş modu (window.__CALIBRA_DOC_TYPE__.isOrder) iken,
     * sipariş no'nun yanındaki rehber butonu tarafından çağrılır.
     * SALES_ORDERS standart rehberini (cbv_Guide_SalesOrders) açar; secilen
     * sipariş için DocumentEdit'e ?id= ile yonlendirir.
     */
    function openOrderLookup() {
        if (!window.CalibraHub || !window.CalibraHub.openGuideLookup) {
            console.warn('[SQE] openGuideLookup hazir degil');
            return;
        }
        window.CalibraHub.openGuideLookup('SALES_ORDERS', {
            guideLabel: 'Tekliften Olusturulan Siparisler',
            onPick: function (row) {
                var id = row && row.cells && row.cells.Id;
                if (!id) {
                    console.warn('[SQE] order lookup: secilen satirda Id yok', row);
                    return;
                }
                // currentQuoteId ayni ise tekrar yukleme
                if (typeof currentQuoteId !== 'undefined' && Number(id) === Number(currentQuoteId)) return;
                window.location.href = '/Sales/DocumentEdit?id=' + id;
            }
        });
    }

    async function loadCustomers() {
        // 1) window.CalibraHub.attachGuide hazir olana kadar bekle — bundle async.
        // 2) attachGuide cagirildiktan sonra React kendi wrapper'ini ASENKRON render eder.
        //    Wrapper DOM'a eklenip icinde cocuklar olusana kadar bekleyip Promise'i
        //    oyle resolve ederiz; boylece sqLoadQuote degerleri yazdiginda React
        //    bileseninin useEffect'i zaten mount olmus ve data-display kontrolunu
        //    yapar → "sonradan dolma" hissi olusmaz.
        return new Promise(function (resolve) {
            function whenGuideAttached(cb) {
                if (attachCustomerGuide()) { cb(); return; }
                var attempts = 0;
                var t = setInterval(function () {
                    if (attachCustomerGuide()) { clearInterval(t); cb(); return; }
                    if (++attempts > 60) { clearInterval(t); cb(); } // ~6s sonra vazgec
                }, 100);
            }
            function whenWrapperReady(cb) {
                var attempts = 0;
                var tries = setInterval(function () {
                    var disp = document.getElementById('sqCustomerDisplay');
                    var wrap = disp && disp.parentNode
                        ? disp.parentNode.querySelector('.ffl-wrapper') : null;
                    // React render tamamlandiginda wrapper'da en az bir child (buton/SVG) olur
                    if (wrap && wrap.children.length > 0) { clearInterval(tries); cb(); return; }
                    if (++attempts > 30) { clearInterval(tries); cb(); } // ~3s
                }, 100);
            }
            whenGuideAttached(function () { whenWrapperReady(resolve); });
        });
    }

