                var opts = list ? list.querySelectorAll('.sqe-rep-option:not(.sqe-rep-no-result)') : [];
                var active = list ? list.querySelector('.is-active') : null;
                if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
                    e.preventDefault();
                    var idx = active ? Array.from(opts).indexOf(active) : -1;
                    if (active) active.classList.remove('is-active');
                    var next = e.key === 'ArrowDown' ? opts[idx + 1] || opts[0] : opts[idx - 1] || opts[opts.length - 1];
                    if (next) { next.classList.add('is-active'); next.scrollIntoView({ block: 'nearest' }); }
                } else if (e.key === 'Enter') {
                    e.preventDefault();
                    var target = active || (opts.length === 1 ? opts[0] : null);
                    if (target) sqRepSelect(target.dataset.val);
                } else if (e.key === 'Escape') {
                    sqRepClose();
                }
            });
        }

        if (list) {
            list.addEventListener('click', function (e) {
                var opt = e.target.closest('.sqe-rep-option');
                if (opt) sqRepSelect(opt.dataset.val);
            });
        }
    });

