                '<span class="sqe-att-item__meta">' + sqFormatBytes(a.fileSize) + '</span>' +
                '<button type="button" class="sqe-att-item__btn" onclick="event.stopPropagation();sqAttDownload(' + a.id + ')">İndir</button>' +
                '<button type="button" class="sqe-att-item__btn is-danger" onclick="event.stopPropagation();sqAttDelete(' + a.id + ')">Sil</button>' +
