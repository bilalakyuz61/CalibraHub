            }
            return r;
        });
        if (typeof setGridRows === 'function') setGridRows(updated);
    };

    /* ── Currency dropdown: dinamik yukleme + ID/code map ─────────────────
       Backend Document.CurrencyId int FK tutar; dropdown value=id, data-code=ISO.
       Sayfa load'da /PriceList/GetCurrencies'ten option'lar doldurulur.
       sqSetCurrencyById(id) ID ile select'i ayarlar + 'sq:currency' event firlatir
       (kalem grid'i + diger dinleyiciler kod stringini bilmek istiyor). */
    var __sqCurrencyMap = { 1: 'TRY' };  // fallback — endpoint yuklenmeden once
    function sqSetCurrencyById(id) {
        var el = document.getElementById('sqCurrency');
        if (!el) return;
        var idStr = String(id || 1);
        el.value = idStr;
        var opt = el.options[el.selectedIndex];
        var code = (opt && opt.getAttribute('data-code')) || __sqCurrencyMap[id] || 'TRY';
        try {
            window.dispatchEvent(new CustomEvent('sq:currency', {
                detail: { id: parseInt(idStr) || 1, code: code }
            }));
        } catch (_) {}
    }
    window.sqSetCurrencyById = sqSetCurrencyById;

    function sqLoadCurrencies() {
        return fetch('/PriceList/GetCurrencies', { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (list) {
                var sel = document.getElementById('sqCurrency');
                if (!sel || !Array.isArray(list) || list.length === 0) return;
                var currentId = sel.value || sel.getAttribute('data-current-id') || '1';
                __sqCurrencyMap = {};
                sel.innerHTML = list.map(function (c) {
                    __sqCurrencyMap[c.id] = c.code;
                    return '<option value="' + c.id + '" data-code="' + c.code + '">' + c.code + '</option>';
                }).join('');
                // Onceden secili id varsa onu koru (option'lar yenilendi)
                if (Array.from(sel.options).some(function (o) { return o.value === currentId; })) {
                    sel.value = currentId;
                }
            })
            .catch(function () { /* sessiz: TRY fallback option zaten render edilmis */ });
    }
