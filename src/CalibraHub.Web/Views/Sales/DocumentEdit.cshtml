@model CalibraHub.Web.Models.Sales.DocumentEditViewModel
@{
    var isOrder = string.Equals(Model.DocumentTypeCode, "satis_siparisi", StringComparison.OrdinalIgnoreCase);
    var isPurchaseOrder = string.Equals(Model.DocumentTypeCode, "alis_siparisi", StringComparison.OrdinalIgnoreCase);
    var isPurchase = CalibraHub.Web.Models.Sales.DocumentTypeFormMap.IsPurchase(Model.DocumentTypeCode);
    // Satin Alma Talebi (alis_talebi) — sirket icinden gelen talep; bu asamada henuz
    // tedarikci de fiyatlandirma da belli degil. Para Birimi / Cari Kod alanlari gizlenir.
    var isPurchaseRequest = string.Equals(Model.DocumentTypeCode, "alis_talebi", StringComparison.OrdinalIgnoreCase);
    // Cari Kod rehberi: purchase belgelerinde Tedarikci, sales/talep'te musteri.
    var customerGuideCode = isPurchase ? "SUPPLIERS" : "CUSTOMERS";
    // 2026-05-23: Satis tarafinda "Teklif/Siparis" labellari kullaniliyordu; satin alma
    // belgeleri icin de label haritasi gerek. Satin alma: talep/teklif/siparis.
    string entityLabel = Model.DocumentTypeCode switch
    {
        "satis_siparisi"  => "Siparis",
        "alis_talebi"     => "İhtiyaç",   // tam ad: "İhtiyaç Kaydı"; alt etiketlerde kisa kullanim
        "alis_teklifi"    => "Teklif",
        "alis_siparisi"   => "Siparis",
        _                  => "Teklif",
    };
    // Form kodlari artik VM'den geliyor (controller DocumentTypeFormMap helper'i ile doldurur).
    // 5 belge tipi (satis_teklifi/siparisi + alis_talebi/teklifi/siparisi) ayni view ile render edilir.
    var headerFormCode = Model.HeaderFormCode;
    var lineFormCode   = Model.LineFormCode;
    // Save / Delete sonrasi geri donulecek liste sayfasi.
    // Faz N — DocumentType.ListUrl tek-noktadan gelir (controller doldurur).
    // Yeni belge tipleri (alış irsaliyesi, satınalma siparişi vb.) eklenince
    // sadece DB seed'i guncellenir; bu view dokunulmaz.
    var listReturnUrl  = !string.IsNullOrWhiteSpace(Model.ListReturnUrl)
        ? Model.ListReturnUrl
        : (isOrder ? "/Sales/Orders" : "/Sales/Quotes");   // teklif yeni route + siparis ayri
    // 2026-06-16: iframe-aware — query'ye workspace=1 ekle. _Layout.cshtml bu flag'i
    // görünce React Shell'i mount etmez (matruska kabuk / duplicate sidebar önlenir).
    // Bazı tarayıcılarda JS-driven window.location.href navigate'inde Sec-Fetch-Dest
    // "document" gelir → workspace=1 olmadan Shell tekrar render edilir.
    if (!listReturnUrl.Contains("workspace=", StringComparison.Ordinal))
        listReturnUrl += (listReturnUrl.Contains('?') ? "&" : "?") + "workspace=1";
    ViewData["Title"] = Model.DocumentId.HasValue ? entityLabel + " Duzenle" : "Yeni " + entityLabel;
    ViewData["FormCode"] = headerFormCode;
    ViewData["BodyClass"] = "page-sales-quote-edit";
    ViewData["DbInfo"] = "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr style='border-bottom:1px solid #e2e8f0;'><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>sales_quotes</td><td style='padding:6px 8px;'>Satis teklifi master bilgileri (belge no, tarih, cari hesap, temsilci, durum)</td></tr>"
        + "<tr style='border-bottom:1px solid #e2e8f0;'><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>sales_quote_lines</td><td style='padding:6px 8px;'>Teklif satirlari (malzeme, miktar, birim, fiyat, kombinasyon)</td></tr>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>sales_quote_line_details</td><td style='padding:6px 8px;'>Satir detaylari (kombinasyon ozellik aciklamalari)</td></tr>"
        + "</table>";
    var editId = Model.DocumentId;
}

@section Styles {
@* flatpickr css + CalibraHub takvim teması artık _Layout'tan global gelir (calibra-datepicker) *@
<style>
    /* Sayfa genelinde number input spinner'larini gizle (yukari/asagi ok tuslari) */
    .page-sales-quote-edit input[type="number"]::-webkit-outer-spin-button,
    .page-sales-quote-edit input[type="number"]::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    .page-sales-quote-edit input[type="number"] {
        -moz-appearance: textfield;
    }
    .page-sales-quote-edit .integrator-dashboard { height: 100%; min-height: 0; }
    .page-sales-quote-edit .integrator-dashboard__content {
        display: flex !important; flex-direction: column;
        width: 100% !important; max-width: none !important;
        min-height: 0; padding: 0; margin: 0 !important; overflow: hidden;
    }
    .workspace-frame-body.page-sales-quote-edit .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column; overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-sales-quote-edit .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }
    /* Scrollable container */
    .sqe-scroll-container {
        flex: 1 1 auto; overflow-y: auto; padding: 16px;
        display: flex; flex-direction: column; gap: 16px;
    }
    /* Card — artik <details> elementi, katlanir */
    details.sqe-card {
        background: var(--app-surface, #fff);
        border: 1px solid var(--app-border, #d4dfeb);
        border-radius: 12px;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.05);
        flex-shrink: 0;
        overflow: hidden;
    }
    /* Backwards compat: eski .sqe-card div'leri hala calissin */
    div.sqe-card {
        background: var(--app-surface, #fff);
        border: 1px solid var(--app-border, #d4dfeb);
        border-radius: 12px;
        box-shadow: 0 4px 14px rgba(15, 23, 42, 0.05);
        flex-shrink: 0;
    }
    summary.sqe-card__header,
    .sqe-card__header {
        padding: 12px 18px;
        border-bottom: 1px solid var(--app-border-light, #e9eef5);
        display: flex; align-items: center; justify-content: space-between;
        list-style: none;              /* Default marker kaldir */
        cursor: pointer;
        user-select: none;
        transition: background 0.15s ease;
    }
    summary.sqe-card__header::-webkit-details-marker { display: none; }
    summary.sqe-card__header::marker { display: none; content: ''; }
    summary.sqe-card__header:hover {
        background: rgba(15, 23, 42, 0.025);
    }
    summary.sqe-card__header h3 {
        margin: 0; font-size: 0.95rem;
        font-weight: 700;
        color: var(--app-text, #334155);
        display: flex; align-items: center; gap: 10px;
    }
    /* Chevron — <details> acildiginda 90 derece doner */
    summary.sqe-card__header h3::before {
        content: '';
        display: inline-block;
        width: 0; height: 0;
        border-top: 4px solid transparent;
        border-bottom: 4px solid transparent;
        border-left: 5px solid currentColor;
        transition: transform 0.2s ease;
        opacity: 0.55;
        flex-shrink: 0;
    }
    details.sqe-card[open] > summary.sqe-card__header h3::before {
        transform: rotate(90deg);
    }
    /* Katlandığında header border-bottom'i kaybolmasin (acikken olsun) */
    details.sqe-card:not([open]) > summary.sqe-card__header {
        border-bottom-color: transparent;
    }
    .sqe-card__header h3 { /* old div header — chevron yok */
        margin: 0; font-size: 0.95rem;
        font-weight: 700;
        color: var(--app-text, #334155);
    }
    .sqe-card__body { padding: 16px 18px; }

    /* NOT: .sqe-link-group / .sqe-link-btn / .sqe-lookup-group widgetField.css'e
       tasindi (DynamicWidgetRenderer/widgetField.css). Renderer artik wf-link-group,
       wf-link-btn, wf-lookup-group emit ediyor — tek nokta tasarim sistemi. Asagidaki
       .sqe-lookup-btn / .sqe-lookup-clear / .sqe-lookup-modal* legacy buton + modal
       (FixedFieldLookupBridge / Razor inline lookup) icin burada kalir. */

    /* Lookup widget legacy buton (FixedFieldLookupBridge / sabit alan) */
    .sqe-lookup-btn, .sqe-lookup-clear {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 34px; min-height: 34px; padding: 0 10px;
        border-radius: 10px; cursor: pointer; flex-shrink: 0;
        border: 1px solid rgba(99, 102, 241, 0.45);
        background: rgba(99, 102, 241, 0.12);
        color: #6366f1;
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        transition: all .18s ease;
    }
    .sqe-lookup-btn:hover:not(:disabled) {
        background: rgba(99, 102, 241, 0.22);
        border-color: rgba(99, 102, 241, 0.65);
        transform: translateY(-1px); box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    }
    .sqe-lookup-btn:disabled { opacity: .35; cursor: not-allowed; }
    .sqe-lookup-clear {
        background: rgba(244, 63, 94, 0.08);
        border-color: rgba(244, 63, 94, 0.4);
        color: #e11d48;
    }
    .sqe-lookup-clear:hover {
        background: rgba(244, 63, 94, 0.18);
        border-color: rgba(244, 63, 94, 0.6);
    }
    body.app-theme-dark .sqe-lookup-btn {
        color: #fcd34d;
        background: rgba(99, 102, 241, 0.14);
    }
    body.app-theme-dark .sqe-lookup-clear { color: #fda4af; }

    .sqe-lookup-modal-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        animation: sqeLookupFadeIn .15s ease-out;
    }
    @@keyframes sqeLookupFadeIn { from { opacity: 0; } to { opacity: 1; } }
    .sqe-lookup-modal {
        width: min(900px, 95vw); max-height: 80vh;
        display: flex; flex-direction: column;
        background: var(--app-surface, #ffffff);
        border: 1px solid var(--app-border, #e2e8f0);
        border-radius: 16px;
        box-shadow: 0 24px 72px rgba(0, 0, 0, 0.4);
        overflow: hidden;
        animation: sqeLookupSlideIn .2s cubic-bezier(0.23, 1, 0.32, 1);
    }
    @@keyframes sqeLookupSlideIn {
        from { transform: translateY(12px) scale(0.98); opacity: 0; }
        to { transform: translateY(0) scale(1); opacity: 1; }
    }
    .sqe-lookup-modal header {
        padding: 14px 18px; display: flex; align-items: center; gap: 10px;
        border-bottom: 1px solid var(--app-border, #e2e8f0);
        color: #6366f1;
    }
    .sqe-lookup-modal header input {
        flex: 1; min-width: 0;
        background: var(--app-muted-surface, #f8fafc);
        border: 1px solid var(--app-border, #e2e8f0);
        border-radius: 8px; padding: 8px 12px; color: inherit;
        font-size: .85rem; outline: none;
    }
    .sqe-lookup-modal header input:focus {
        border-color: rgba(99, 102, 241, 0.55);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
    }
    .sqe-lookup-close {
        background: transparent; border: none; color: inherit; cursor: pointer;
        padding: 6px; border-radius: 6px; transition: background .15s;
        display: inline-flex; align-items: center; justify-content: center;
    }
    .sqe-lookup-close:hover { background: rgba(0, 0, 0, 0.06); }
    .sqe-lookup-error {
        padding: 10px 18px; background: rgba(239, 68, 68, 0.08);
        color: #b91c1c; font-size: .75rem;
        border-bottom: 1px solid rgba(239, 68, 68, 0.2);
    }
    .sqe-lookup-scroll { flex: 1; overflow-y: auto; min-height: 0; }
    .sqe-lookup-table { width: 100%; border-collapse: collapse; font-size: .78rem; }
    .sqe-lookup-table thead th {
        position: sticky; top: 0; z-index: 1;
        background: var(--app-muted-surface, #f8fafc);
        text-align: left; padding: 10px 14px;
        font-weight: 700;
        font-size: .78rem; color: #4f46e5;
        border-bottom: 1px solid var(--app-border, #e2e8f0);
    }
    .sqe-lookup-table tbody tr {
        cursor: pointer;
        border-bottom: 1px solid var(--app-border, #f1f5f9);
        transition: background .12s;
    }
    .sqe-lookup-table tbody tr:hover { background: rgba(99, 102, 241, 0.09); }
    .sqe-lookup-table td { padding: 9px 14px; color: var(--app-text, #334155); }
    .sqe-lookup-empty, .sqe-lookup-sentinel {
        text-align: center; padding: 20px;
        color: var(--app-text-muted, #94a3b8); font-size: .75rem;
    }
    .sqe-lookup-sentinel span { display: inline-flex; align-items: center; gap: 6px; }
    .sqe-lookup-sentinel .spin { animation: sqeLookupSpin .9s linear infinite; }
    @@keyframes sqeLookupSpin { from { transform: rotate(0); } to { transform: rotate(360deg); } }
    .sqe-lookup-footer {
        padding: 10px 18px; font-size: .7rem; opacity: .6;
        border-top: 1px solid var(--app-border, #e2e8f0);
    }
    /* ── Kolon basligi (distinct filtre ikonu icerebilir) ── */
    .sqe-lookup-th-inner { display: flex; align-items: center; gap: 6px; }
    .sqe-lookup-th-label { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; }
    .sqe-lookup-col-filter {
        background: transparent; border: none; cursor: pointer;
        padding: 3px; border-radius: 4px;
        color: rgba(0,0,0,0.35);
        display: inline-flex; align-items: center; gap: 3px;
        transition: all .12s;
    }
    .sqe-lookup-col-filter:hover {
        background: rgba(99, 102, 241, 0.12);
        color: #4f46e5;
    }
    .sqe-lookup-col-filter--active {
        background: rgba(99, 102, 241, 0.18) !important;
        color: #4f46e5 !important;
    }
    .sqe-lookup-col-filter-count {
        font-size: .58rem; font-weight: 700;
        background: #6366f1; color: #fff;
        padding: 1px 5px; border-radius: 999px;
        line-height: 1.1; min-width: 12px; text-align: center;
    }
    body.app-theme-dark .sqe-lookup-col-filter { color: rgba(255,255,255,0.40); }
    body.app-theme-dark .sqe-lookup-col-filter:hover {
        background: rgba(165, 180, 252, 0.14); color: #a5b4fc;
    }
    body.app-theme-dark .sqe-lookup-col-filter--active {
        background: rgba(165, 180, 252, 0.18) !important; color: #a5b4fc !important;
    }
    .sqe-lookup-footer-filter {
        margin-left: auto;
        font-size: .68rem; font-weight: 600;
        color: #6366f1;
    }
    body.app-theme-dark .sqe-lookup-footer-filter { color: #a5b4fc; }

    /* ── Excel-tarzi kolon filtre acilir popover'i ──
       NOT: body.app-theme-dark CSS degiskenleri (--app-surface vb.) tanimlamiyor;
       o yuzden dark icin explicit override gerekli (yoksa fallback #ffffff kalir). */
    .sqe-lookup-popover {
        background: var(--app-surface, #ffffff);
        border: 1px solid var(--app-border, #e2e8f0);
        border-radius: 12px;
        box-shadow: 0 22px 64px rgba(0, 0, 0, 0.20);
        overflow: hidden;
        display: flex; flex-direction: column;
        animation: sqeLookupPopIn .12s ease-out;
        font-size: .75rem;
        color: var(--app-text, #334155);
    }
    body.app-theme-dark .sqe-lookup-popover {
        background: #1a1f2e;
        border-color: rgba(255, 255, 255, 0.10);
        box-shadow: 0 22px 64px rgba(0, 0, 0, 0.65), 0 0 0 1px rgba(255, 255, 255, 0.02);
        color: rgba(255, 255, 255, 0.85);
    }
    @@keyframes sqeLookupPopIn {
        from { opacity: 0; transform: translateY(-4px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .sqe-lookup-popover-title {
        display: flex; align-items: center; gap: 6px;
        padding: 9px 12px 8px;
        font-size: .68rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .55px;
        color: #475569;
        border-bottom: 1px solid #e2e8f0;
    }
    body.app-theme-dark .sqe-lookup-popover-title {
        color: rgba(255, 255, 255, 0.82);
        border-bottom-color: rgba(255, 255, 255, 0.06);
    }
    .sqe-lookup-popover-title svg { color: #6366f1; opacity: .9; }
    body.app-theme-dark .sqe-lookup-popover-title svg { color: #a5b4fc; }
    .sqe-lookup-popover-search-wrap {
        position: relative;
        padding: 8px 10px 4px;
    }
    .sqe-lookup-popover-search-ico {
        position: absolute;
        left: 18px; top: 50%; transform: translateY(-30%);
        opacity: .45; pointer-events: none;
    }
    .sqe-lookup-popover-search {
        width: 100%; padding: 6px 8px 6px 26px;
        font-size: .72rem;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #f8fafc;
        color: inherit; outline: none;
    }
    .sqe-lookup-popover-search:focus {
        border-color: rgba(99, 102, 241, 0.55);
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.12);
    }
    body.app-theme-dark .sqe-lookup-popover-search {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.10);
        color: rgba(255, 255, 255, 0.85);
    }
    .sqe-lookup-popover-actions {
        display: flex; align-items: center; gap: 6px;
        padding: 4px 12px 6px;
        font-size: .68rem;
    }
    .sqe-lookup-popover-actions button {
        background: transparent; border: none; cursor: pointer;
        color: #6366f1; font-weight: 600;
        padding: 2px 4px; border-radius: 4px;
        transition: background .12s;
    }
    .sqe-lookup-popover-actions button:hover { background: rgba(99, 102, 241, 0.12); }
    body.app-theme-dark .sqe-lookup-popover-actions button { color: #a5b4fc; }
    body.app-theme-dark .sqe-lookup-popover-actions button:hover { background: rgba(165, 180, 252, 0.12); }
    .sqe-lookup-popover-divider { opacity: .35; }
    .sqe-lookup-popover-count {
        margin-left: auto; opacity: .55; font-weight: 500;
    }
    .sqe-lookup-popover-list {
        flex: 1; overflow-y: auto;
        max-height: 240px;
        padding: 2px 0;
        border-top: 1px solid #e2e8f0;
        border-bottom: 1px solid #e2e8f0;
    }
    body.app-theme-dark .sqe-lookup-popover-list {
        border-top-color: rgba(255, 255, 255, 0.06);
        border-bottom-color: rgba(255, 255, 255, 0.06);
    }
    .sqe-lookup-popover-empty {
        text-align: center; padding: 16px 8px;
        font-size: .7rem; opacity: .55;
    }
    .sqe-lookup-popover-row {
        display: flex; align-items: center; gap: 8px;
        padding: 5px 12px;
        cursor: pointer;
        transition: background .1s;
        font-size: .72rem;
        user-select: none;
    }
    .sqe-lookup-popover-row:hover { background: rgba(99, 102, 241, 0.10); }
    body.app-theme-dark .sqe-lookup-popover-row:hover { background: rgba(165, 180, 252, 0.10); }
    .sqe-lookup-popover-row--checked {
        background: rgba(99, 102, 241, 0.15);
        font-weight: 600;
        color: #4f46e5;
    }
    body.app-theme-dark .sqe-lookup-popover-row--checked {
        background: rgba(165, 180, 252, 0.18);
        color: #c7d2fe;
    }
    .sqe-lookup-popover-row--checked:hover { background: rgba(99, 102, 241, 0.22) !important; }
    body.app-theme-dark .sqe-lookup-popover-row--checked:hover { background: rgba(165, 180, 252, 0.26) !important; }
    .sqe-lookup-popover-checkbox {
        width: 14px; height: 14px;
        border: 1.5px solid #cbd5e1;
        border-radius: 3px;
        background: #ffffff;
        display: inline-flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        color: #fff;
        transition: all .1s;
    }
    .sqe-lookup-popover-row--checked .sqe-lookup-popover-checkbox {
        background: #6366f1;
        border-color: #6366f1;
    }
    body.app-theme-dark .sqe-lookup-popover-checkbox {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.25);
    }
    .sqe-lookup-popover-row-label {
        flex: 1; min-width: 0;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sqe-lookup-popover-footer {
        display: flex; gap: 6px; justify-content: flex-end;
        padding: 8px 10px;
    }
    .sqe-lookup-popover-btn {
        padding: 5px 12px; border-radius: 6px; cursor: pointer;
        font-size: .72rem; font-weight: 600;
        border: 1px solid transparent;
        transition: all .12s;
    }
    .sqe-lookup-popover-btn--ghost {
        background: transparent;
        border-color: #e2e8f0;
        color: inherit;
    }
    .sqe-lookup-popover-btn--ghost:hover {
        background: #f1f5f9;
    }
    body.app-theme-dark .sqe-lookup-popover-btn--ghost {
        border-color: rgba(255, 255, 255, 0.10);
    }
    body.app-theme-dark .sqe-lookup-popover-btn--ghost:hover {
        background: rgba(255, 255, 255, 0.05);
    }
    .sqe-lookup-popover-btn--primary {
        background: #6366f1; color: #fff; border-color: #6366f1;
    }
    .sqe-lookup-popover-btn--primary:hover { background: #4f46e5; border-color: #4f46e5; }

    /* ══════════════════════════════════════════════════════════
       Grid (Alt Tablo / Master-Detail) widget — Faz E
       Card-based row list + portal modal with embedded renderer
       ══════════════════════════════════════════════════════════ */
    .sqe-field--grid { grid-column: 1 / -1; }

    .sqe-grid-wrap {
        border-radius: 14px;
        background: var(--app-muted-surface, #f8fafc);
        border: 1px solid var(--app-border, #e2e8f0);
        padding: 14px 16px 16px;
    }
    .sqe-grid-header {
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px; margin-bottom: 12px;
    }
    .sqe-grid-header__title {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.85rem; font-weight: 700;
        color: #2563eb;
    }
    .sqe-grid-add-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 14px; min-height: 34px;
        border-radius: 10px; font-size: 0.78rem; font-weight: 600;
        color: #1d4ed8;
        background: rgba(59, 130, 246, 0.12);
        border: 1px solid rgba(59, 130, 246, 0.45);
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        transition: all 0.18s ease; cursor: pointer;
    }
    .sqe-grid-add-btn:hover:not(:disabled) {
        background: rgba(59, 130, 246, 0.22);
        border-color: rgba(59, 130, 246, 0.65);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(59, 130, 246, 0.18);
    }
    .sqe-grid-add-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .sqe-grid-error {
        padding: 10px 14px; margin-bottom: 10px;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.25);
        border-radius: 10px; color: #b91c1c; font-size: 0.75rem;
    }
    .sqe-grid-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 6px; padding: 32px 16px;
        border-radius: 12px;
        border: 1.5px dashed var(--app-border, #e2e8f0);
        color: var(--app-text-muted, #94a3b8); font-size: 0.82rem;
    }
    .sqe-grid-empty small { font-size: 0.7rem; opacity: 0.7; }
    .sqe-grid-rows { display: flex; flex-direction: column; gap: 10px; }
    .sqe-grid-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center; gap: 14px;
        padding: 12px 14px;
        border-radius: 12px;
        background: var(--app-surface, #ffffff);
        border: 1px solid var(--app-border, #e2e8f0);
        transition: all 0.18s ease;
    }
    .sqe-grid-row:hover {
        background: #eff6ff;
        border-color: #bfdbfe;
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(59, 130, 246, 0.1);
    }
    .sqe-grid-row__index {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 28px; height: 28px;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.14);
        border: 1px solid rgba(59, 130, 246, 0.35);
        color: #1d4ed8; font-size: 0.7rem; font-weight: 700;
    }
    .sqe-grid-row__cells {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 10px 18px; min-width: 0;
    }
    .sqe-grid-row__cell { display: flex; flex-direction: column; min-width: 0; }
    .sqe-grid-row__label {
        font-size: 0.72rem; font-weight: 600;
        color: var(--app-text-muted, #64748b); margin-bottom: 2px;
    }
    .sqe-grid-row__value {
        font-size: 0.82rem; color: var(--app-text, #1e293b);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sqe-grid-row__actions { display: flex; gap: 6px; flex-shrink: 0; }
    .sqe-grid-row__edit, .sqe-grid-row__delete {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px;
        border-radius: 8px; cursor: pointer;
        background: #ffffff;
        border: 1px solid var(--app-border, #e2e8f0);
        color: #64748b;
        transition: all 0.15s;
    }
    .sqe-grid-row__edit:hover {
        background: rgba(59, 130, 246, 0.15);
        border-color: rgba(59, 130, 246, 0.5);
        color: #1d4ed8;
    }
    .sqe-grid-row__delete:hover {
        background: rgba(239, 68, 68, 0.12);
        border-color: rgba(239, 68, 68, 0.5);
        color: #be123c;
    }

    .sqe-grid-modal-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        animation: sqeGridFadeIn 0.15s ease-out;
    }
    @@keyframes sqeGridFadeIn { from { opacity: 0; } to { opacity: 1; } }
    .sqe-grid-modal {
        width: min(780px, 95vw); max-height: 85vh;
        display: flex; flex-direction: column;
        background: var(--app-surface, #ffffff);
        border: 1px solid var(--app-border, #e2e8f0);
        border-radius: 16px;
        box-shadow: 0 24px 72px rgba(0, 0, 0, 0.4);
        overflow: hidden;
        animation: sqeGridSlide 0.22s cubic-bezier(0.23, 1, 0.32, 1);
    }
    @@keyframes sqeGridSlide {
        from { transform: translateY(16px) scale(0.97); opacity: 0; }
        to { transform: translateY(0) scale(1); opacity: 1; }
    }
    /* Zorunlu alan validasyonu — kirmizi cerceve + shake */
    .sqe-input.is-invalid, .sqe-select.is-invalid {
        border-color: #ef4444 !important;
        background: rgba(239,68,68,.06) !important;
        box-shadow: 0 0 0 3px rgba(239,68,68,.2) !important;
        animation: sqeShake 0.45s cubic-bezier(.36,.07,.19,.97) both;
    }
    @@keyframes sqeShake {
        10%, 90% { transform: translateX(-2px); }
        20%, 80% { transform: translateX(3px); }
        30%, 50%, 70% { transform: translateX(-4px); }
        40%, 60% { transform: translateX(4px); }
    }
    .sqe-grid-modal header {
        padding: 16px 20px; display: flex; align-items: center; gap: 10px;
        border-bottom: 1px solid var(--app-border, #e2e8f0);
        color: #2563eb;
    }
    .sqe-grid-modal__title {
        flex: 1; font-size: 0.88rem; font-weight: 700;
        color: var(--app-text, #1e293b);
    }
    .sqe-grid-modal__close {
        background: transparent; border: none; color: inherit;
        cursor: pointer; padding: 6px; border-radius: 6px;
        display: inline-flex; align-items: center; justify-content: center;
        transition: background 0.15s;
    }
    .sqe-grid-modal__close:hover { background: rgba(0, 0, 0, 0.06); }
    .sqe-grid-modal__body { flex: 1; overflow-y: auto; padding: 18px 20px; }
    .sqe-grid-modal__footer {
        padding: 14px 20px; display: flex; justify-content: flex-end; gap: 10px;
        border-top: 1px solid var(--app-border, #e2e8f0);
    }
    .sqe-grid-modal__cancel, .sqe-grid-modal__confirm {
        padding: 8px 18px; min-height: 36px;
        border-radius: 10px; cursor: pointer;
        font-size: 0.78rem; font-weight: 600;
        transition: all 0.15s;
    }
    .sqe-grid-modal__cancel {
        background: #ffffff;
        border: 1px solid var(--app-border, #e2e8f0);
        color: #64748b;
    }
    .sqe-grid-modal__cancel:hover { background: #f1f5f9; }
    .sqe-grid-modal__confirm {
        background: rgba(59, 130, 246, 0.15);
        border: 1px solid rgba(59, 130, 246, 0.55);
        color: #1d4ed8;
    }
    .sqe-grid-modal__confirm:hover {
        background: rgba(59, 130, 246, 0.25);
        border-color: rgba(59, 130, 246, 0.75);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(59, 130, 246, 0.2);
    }

    /* ══════════════════════════════════════════════════════════
       Rule Engine (Faz G) — visibility / disabled / formula / error
       ══════════════════════════════════════════════════════════ */
    .sqe-field--readonly .sqe-field__readonly-wrap {
        opacity: 0.62;
        cursor: not-allowed;
        position: relative;
    }
    .sqe-field--readonly .sqe-field__readonly-wrap::after {
        content: '';
        position: absolute; inset: 0;
        border-radius: 8px;
        background: repeating-linear-gradient(
            45deg,
            rgba(15, 23, 42, 0.02),
            rgba(15, 23, 42, 0.02) 8px,
            rgba(15, 23, 42, 0.04) 8px,
            rgba(15, 23, 42, 0.04) 16px
        );
        pointer-events: none;
    }
    .sqe-field--formula .sqe-label::after {
        content: ' ƒ';
        display: inline-block;
        margin-left: 4px;
        padding: 1px 6px;
        border-radius: 6px;
        font-size: 0.62rem;
        font-weight: 700;
        font-family: 'Courier New', monospace;
        color: #7c3aed;
        background: rgba(139, 92, 246, 0.12);
        border: 1px solid rgba(139, 92, 246, 0.32);
    }
    .sqe-rule-error {
        display: flex; align-items: flex-start; gap: 5px;
        margin-top: 4px; padding: 5px 9px;
        font-size: 0.7rem; line-height: 1.35;
        color: #b91c1c;
        background: rgba(239, 68, 68, 0.06);
        border: 1px solid rgba(239, 68, 68, 0.28);
        border-radius: 8px;
    }
    .sqe-rule-error::before {
        content: '⚠'; flex-shrink: 0;
        color: #dc2626; font-size: 0.78rem;
    }
    .sqe-rule-cycle {
        padding: 18px 22px;
        background: rgba(239, 68, 68, 0.07);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 12px;
        color: #991b1b;
    }
    .sqe-rule-cycle strong { color: #dc2626; }
    .sqe-rule-cycle code {
        display: inline-block; margin-top: 4px;
        padding: 3px 9px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #7f1d1d;
        border-radius: 6px;
        font-family: 'Courier New', monospace;
    }
    /* 2-column form grid */
    .sqe-form-grid {
        display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px;
    }
    .sqe-form-field label.sqe-label {
        display: block; margin-bottom: 5px; font-size: 0.75rem;
        font-weight: 600; color: var(--app-text-muted, #64748b);
    }
    .sqe-form-field--full { grid-column: 1 / -1; }

    /* ── Horizontal form (etiket yanında alan) ── */
    .sqe-hform {
        display: flex; flex-direction: column; gap: 10px;
        padding: 16px 20px; max-width: 720px;
    }
    .sqe-hrow {
        display: flex; align-items: center; gap: 12px; min-height: 38px;
    }
    .sqe-hlabel {
        flex: 0 0 150px; text-align: left;
        font-size: 0.86rem; font-weight: 600;
        color: var(--app-text-muted, #64748b);
        white-space: nowrap; user-select: none;
    }
    body.app-theme-dark .sqe-hlabel {
        color: rgba(255,255,255,.78);
    }
    /* Cari Isim: input degil, salt-okunur etiket (span) */
    .sqe-hlabel-value {
        display: inline-block;
        padding: 4px 0;
        font-size: 0.9rem;
        font-weight: 600;
        color: #1e293b;
        min-height: 1.4em;
    }
    body.app-theme-dark .sqe-hlabel-value {
        color: rgba(255,255,255,.92);
    }
    .sqe-hlabel-value:empty::before {
        content: attr(data-placeholder);
        color: rgba(100,116,139,.55);
        font-weight: 400;
        font-style: italic;
    }
    body.app-theme-dark .sqe-hlabel-value:empty::before {
        color: rgba(255,255,255,.35);
    }
    /* Cari Isim — Cari Kod kartinin yaninda, hafif indigo-tinted badge */
    .sqe-customer-name.sqe-hlabel-value {
        display: inline-block;
        margin-left: 4px;
        padding: 0;
        font-size: 0.92rem;
        font-weight: 600;
        color: #4f46e5;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 320px;
        min-height: 0;
    }
    .sqe-customer-name.sqe-hlabel-value:empty { display: none; }
    body.app-theme-dark .sqe-customer-name.sqe-hlabel-value {
        color: #c7d2fe;
    }
    .sqe-hinput {
        flex: 1; max-width: 280px;
    }
    /* ── Yumusak hat alani: form-control-sm / form-select-sm Bootstrap defaultlarini
       sadece bu sayfaya ozgu olarak premium hisse cevirir (LookupCard ile uyumlu) ── */
    .sqe-hform .form-control,
    .sqe-hform .form-select,
    .sqe-tab-pane.is-active input.form-control,
    .sqe-tab-pane.is-active select.form-select,
    .sqe-tab-pane.is-active textarea.form-control {
        height: 38px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background-color: #ffffff;
        box-shadow: 0 1px 2px rgba(15,23,42,.04);
        padding: 0 12px;
        font-size: 0.875rem;
        font-weight: 500;
        color: #0f172a;
        transition: border-color .12s, box-shadow .12s, background-color .12s;
    }
    /* select icin Bootstrap'in ok ikonu padding'ini koru */
    .sqe-hform .form-select,
    .sqe-tab-pane.is-active select.form-select {
        padding-right: 2.25rem;
    }
    .sqe-tab-pane.is-active textarea.form-control {
        height: auto;
        min-height: 96px;
        padding: 10px 12px;
        line-height: 1.45;
    }
    .sqe-hform .form-control:hover:not(:disabled):not([readonly]),
    .sqe-hform .form-select:hover:not(:disabled),
    .sqe-tab-pane.is-active input.form-control:hover:not(:disabled):not([readonly]),
    .sqe-tab-pane.is-active select.form-select:hover:not(:disabled),
    .sqe-tab-pane.is-active textarea.form-control:hover:not(:disabled):not([readonly]) {
        border-color: #c7d2fe;
    }
    .sqe-hform .form-control:focus,
    .sqe-hform .form-select:focus,
    .sqe-tab-pane.is-active input.form-control:focus,
    .sqe-tab-pane.is-active select.form-select:focus,
    .sqe-tab-pane.is-active textarea.form-control:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,.18);
        outline: none;
    }
    body.app-theme-dark .sqe-hform .form-control,
    body.app-theme-dark .sqe-hform .form-select,
    body.app-theme-dark .sqe-tab-pane.is-active input.form-control,
    body.app-theme-dark .sqe-tab-pane.is-active select.form-select,
    body.app-theme-dark .sqe-tab-pane.is-active textarea.form-control {
        background-color: rgba(255,255,255,.04);
        border-color: rgba(255,255,255,.08);
        color: #f1f5f9;
        box-shadow: none;
    }
    body.app-theme-dark .sqe-hform .form-control:hover:not(:disabled):not([readonly]),
    body.app-theme-dark .sqe-tab-pane.is-active input.form-control:hover:not(:disabled):not([readonly]),
    body.app-theme-dark .sqe-tab-pane.is-active select.form-select:hover:not(:disabled),
    body.app-theme-dark .sqe-tab-pane.is-active textarea.form-control:hover:not(:disabled):not([readonly]) {
        border-color: rgba(165,180,252,.35);
    }
    body.app-theme-dark .sqe-hform .form-control:focus,
    body.app-theme-dark .sqe-tab-pane.is-active input.form-control:focus,
    body.app-theme-dark .sqe-tab-pane.is-active select.form-select:focus,
    body.app-theme-dark .sqe-tab-pane.is-active textarea.form-control:focus {
        border-color: #a5b4fc;
        box-shadow: 0 0 0 3px rgba(99,102,241,.25);
        background-color: rgba(255,255,255,.06);
    }
    /* Date input takvim ikonu: yumusak hat icinde nefes alabilsin */
    .sqe-hform .form-control[type="date"],
    .sqe-tab-pane.is-active input.form-control[type="date"] {
        padding-right: 8px;
    }
    .sqe-hinput.is-locked {
        background-color: rgba(148, 163, 184, 0.12) !important;
        cursor: not-allowed;
        color: var(--app-text-muted, #64748b);
    }
    body.app-theme-dark .sqe-hinput.is-locked {
        background-color: rgba(255, 255, 255, 0.04) !important;
        color: rgba(255, 255, 255, 0.5);
    }
    .sqe-hinput.sqe-flash {
        animation: sqeShake 0.45s cubic-bezier(.36,.07,.19,.97) both;
    }
    /* 2026-06-01: Bootstrap'in `<select>.is-invalid` icin eklediği ünlem işareti
       SVG background-image'i bastir — sadece kirmizi border + shake gostermek
       istiyoruz, alani ünlem deseniyle doldurmasin. */
    select.sqe-hinput.is-invalid,
    select.sqe-hinput.is-invalid:focus {
        background-image: none !important;
        padding-right: 0.75rem !important;
    }
    /* ── Aranabilir temsilci combobox ── */
    .sqe-rep-cb { position: relative; }
    .sqe-rep-btn {
        display: flex; align-items: center; justify-content: space-between;
        width: 100%; height: 38px;
        border-radius: 10px; border: 1px solid #e2e8f0;
        background-color: #ffffff;
        padding: 0 10px 0 12px;
        font-size: .875rem; font-weight: 500; color: #0f172a;
        box-shadow: 0 1px 2px rgba(15,23,42,.04);
        cursor: pointer; text-align: left;
        transition: border-color .12s, box-shadow .12s, background-color .12s;
    }
    .sqe-rep-btn:hover { border-color: #c7d2fe; }
    .sqe-rep-btn:focus  { outline: none; border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.18); }
    .sqe-rep-btn[aria-expanded="true"] { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.18); }
    .sqe-rep-label { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .sqe-rep-label.is-placeholder { color: #94a3b8; }
    .sqe-rep-chevron { flex-shrink: 0; width: 14px; height: 14px; color: #64748b; transition: transform .15s; }
    .sqe-rep-btn[aria-expanded="true"] .sqe-rep-chevron { transform: rotate(180deg); }
    .sqe-rep-panel {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0; z-index: 1050;
        background: #ffffff; border-radius: 10px;
        border: 1px solid #e2e8f0; box-shadow: 0 8px 24px rgba(15,23,42,.14);
        overflow: hidden;
    }
    .sqe-rep-search-wrap {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 10px; border-bottom: 1px solid #f1f5f9;
    }
    .sqe-rep-search-icon { flex-shrink: 0; width: 14px; height: 14px; color: #94a3b8; }
    .sqe-rep-filter {
        flex: 1; border: none; outline: none; background: transparent;
        font-size: .875rem; color: #0f172a;
    }
    .sqe-rep-filter::placeholder { color: #94a3b8; }
    .sqe-rep-list { max-height: 200px; overflow-y: auto; padding: 4px 0; }
    .sqe-rep-option {
        padding: 8px 12px; cursor: pointer;
        font-size: .875rem; color: #0f172a;
        transition: background-color .08s;
    }
    .sqe-rep-option:hover, .sqe-rep-option.is-active { background-color: rgba(99,102,241,.08); }
    .sqe-rep-option.is-selected { font-weight: 600; color: #6366f1; }
    .sqe-rep-no-result { padding: 10px 12px; font-size: .8rem; color: #94a3b8; text-align: center; }
    body.app-theme-dark .sqe-rep-btn {
        background-color: rgba(255,255,255,.04); border-color: rgba(255,255,255,.08);
        color: #f1f5f9; box-shadow: none;
    }
    body.app-theme-dark .sqe-rep-btn:hover { border-color: rgba(165,180,252,.35); }
    body.app-theme-dark .sqe-rep-btn:focus,
    body.app-theme-dark .sqe-rep-btn[aria-expanded="true"] { border-color: #a5b4fc; box-shadow: 0 0 0 3px rgba(99,102,241,.25); }
    body.app-theme-dark .sqe-rep-chevron { color: rgba(255,255,255,.4); }
    body.app-theme-dark .sqe-rep-panel {
        background: #1e2130; border-color: rgba(255,255,255,.08);
        box-shadow: 0 8px 32px rgba(0,0,0,.45);
    }
    body.app-theme-dark .sqe-rep-search-wrap { border-bottom-color: rgba(255,255,255,.06); }
    body.app-theme-dark .sqe-rep-filter { color: #f1f5f9; }
    body.app-theme-dark .sqe-rep-filter::placeholder { color: rgba(255,255,255,.3); }
    body.app-theme-dark .sqe-rep-option { color: #e2e8f0; }
    body.app-theme-dark .sqe-rep-option:hover,
    body.app-theme-dark .sqe-rep-option.is-active { background-color: rgba(99,102,241,.15); }
    body.app-theme-dark .sqe-rep-option.is-selected { color: #a5b4fc; }
    body.app-theme-dark .sqe-rep-no-result { color: rgba(255,255,255,.3); }
    .sqe-customer-warn {
        display: none;
        margin-left: 132px;
        margin-top: 2px;
        font-size: .76rem;
        color: #ef4444;
        font-weight: 600;
    }
    .sqe-customer-warn.is-visible { display: block; }
    /* ── Cari Kod (LookupCard) wrapper: React .gl-wrapper'a 280px genislik ver ki
       diger alanlarla ayni hizada bitsin. Bos birakilirsa icerige gore daralir. ── */
    .sqe-hform .sqe-hrow .gl-wrapper {
        flex: 0 0 280px;
        max-width: 280px;
        min-width: 0;
    }

    /* ── Sure + Tarih combo: tek satirda 280px paylasiyorlar (diger alanlarla hizali) ── */
    .sqe-hform .sqe-hcombo {
        flex: 0 0 280px;
        max-width: 280px;
        display: flex;
        gap: 6px;
        align-items: center;
    }
    .sqe-hform .sqe-hcombo > input.sqe-hinput,
    .sqe-hform .sqe-hcombo > input.flatpickr-input,
    .sqe-hform .sqe-hcombo > input.sqe-fp-input {
        flex: 1 1 0;
        min-width: 0;
        max-width: none !important;
    }
    .sqe-hform .sqe-hcombo > input.sqe-fp-days {
        flex: 0 0 72px;
        max-width: 72px !important;
        text-align: center;
    }
    .sqe-hlabel--link {
        cursor: pointer; text-decoration: underline dotted; text-underline-offset: 3px;
        text-decoration-color: rgba(99,102,241,.4);
    }
    .sqe-hlabel--link:hover {
        color: #6366f1; text-decoration-color: #6366f1;
    }
    /* Lines container */
    .sqe-lines-container {
        display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px;
    }
    /* Line item inner card */
    .sqe-line-card {
        border: 1px solid var(--app-border, #e2e8f0);
        border-radius: 10px; background: var(--app-muted-surface, #f8fafc);
        overflow: hidden;
    }
    .sqe-line-card__header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 6px 12px; border-bottom: 1px solid var(--app-border-light, #e9eef5);
        background: #f1f5f9;
    }
    .sqe-line-card__num { font-size: 0.78rem; font-weight: 700; color: #64748b; }
    .sqe-line-card__body { padding: 10px 12px; }
    .sqe-line-card__row { display: flex; gap: 10px; align-items: flex-end; }
    .sqe-line-card__row + .sqe-line-card__row { margin-top: 8px; }
    .sqe-line-card__field { flex: 1 1 0; min-width: 0; }
    .sqe-line-card__field--wide { flex: 2 1 0; }
    .sqe-line-card__field label {
        display: block; font-size: 0.75rem; font-weight: 600;
        color: #64748b; margin-bottom: 3px;
    }
    .sqe-line-card__field--total span {
        display: block; font-size: 0.88rem; font-weight: 700; color: #1e40af;
        padding: 6px 0; text-align: right;
    }
    /* Satir ekle butonu */
    .sqe-add-line-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 34px; height: 34px; border-radius: 50%; cursor: pointer;
        border: 1.5px solid #bfdbfe; background: #eff6ff; color: #3b82f6;
        transition: all .16s; flex-shrink: 0;
    }
    .sqe-add-line-btn:hover { background: #dbeafe; border-color: #93c5fd; color: #2563eb; }
    /* Satir sil butonu */
    .sq-btn-del {
        display: inline-flex; align-items: center; justify-content: center;
        width: 26px; height: 26px; border-radius: 6px; cursor: pointer;
        border: 1px solid #fecaca; background: #fff5f5; color: #dc2626;
        transition: all .14s; flex-shrink: 0;
    }
    .sq-btn-del:hover { background: #fee2e2; border-color: #f87171; }
    /* Kombinasyon butonu */
    .sq-ln-combobtn {
        display: none; align-items: center; justify-content: center;
        width: 26px; height: 26px; border-radius: 6px; cursor: pointer;
        border: 1px solid #ddd6fe; background: #f5f3ff; color: #7c3aed;
        font-size: 0.72rem; font-weight: 700;
        transition: all .14s;
    }
    .sq-ln-combobtn:hover { background: #ede9fe; border-color: #c4b5fd; }
    .sq-ln-combdisplay { font-size: 0.7rem; color: #7c3aed; display: none; margin-top: 2px; }
    /* Toplamlar */
    /* Toplamlar: 3 kolon grid — etiket | kontrol (input/boş) | tutar. Her satir
       grid'e katildigi icin tutarlar her zaman ayni X kolonunda hizalanir. */
    .sqe-totals {
        display: grid;
        grid-template-columns: auto 56px 120px;
        column-gap: 14px; row-gap: 6px;
        justify-content: end; align-items: center;
        padding: 10px 8px;
        font-size: 0.84rem;
    }
    .sqe-kdv-rows { display: contents; }
    .sqe-total-label { color: rgba(255,255,255,.55); font-weight: 600; text-align: right; white-space: nowrap; }
    body.app-theme-light .sqe-total-label { color: #64748b; }
    .sqe-total-control { justify-self: end; width: 100%; }
    .sqe-total-value { font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; color: rgba(255,255,255,.85); }
    body.app-theme-light .sqe-total-value { color: #1e293b; }
    /* Genel İskonto input — tema uyumlu, dar, ortalanmis (% degeri) */
    .sqe-total-input {
        width: 100%;
        max-width: 50px;
        padding: 3px 4px;
        border-radius: 6px;
        font-size: 0.82rem;
        text-align: center;
        font-variant-numeric: tabular-nums;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.12);
        color: rgba(255,255,255,.92);
        transition: border-color .12s, background .12s;
    }
    body.app-theme-light .sqe-total-input {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #1e293b;
    }
    .sqe-total-input:hover {
        background: rgba(255,255,255,.1);
        border-color: rgba(255,255,255,.18);
    }
    body.app-theme-light .sqe-total-input:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
    }
    .sqe-total-input:focus {
        outline: none;
        border-color: #6366f1;
        background: rgba(99,102,241,.08);
        box-shadow: 0 0 0 3px rgba(99,102,241,.15);
    }
    body.app-theme-light .sqe-total-input:focus {
        background: #eef2ff;
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79,70,229,.15);
    }
    /* Sayisal alanlarda yukari/asagi ok tuslarini gizle */
    .sq-no-spinner::-webkit-outer-spin-button,
    .sq-no-spinner::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    .sq-no-spinner { -moz-appearance: textfield; }
    .sqe-grand-total { font-size: 1rem; color: #1d4ed8; font-weight: 800; }
    /* Status badge */
    .sqe-status-badge { font-size: 0.78rem; font-weight: 600; padding: 3px 10px; border-radius: 12px; margin-left: 8px; }
    .sqe-status-Draft { background: #f1f5f9; color: #475569; }
    .sqe-status-Sent { background: #dbeafe; color: #1d4ed8; }
    .sqe-status-Approved { background: #dcfce7; color: #166534; }
    .sqe-status-Rejected { background: #fee2e2; color: #991b1b; }

    /* ══════════════════════════════════════════════════════════════
       Dark tema — Glassmorphism override'lari
       ══════════════════════════════════════════════════════════════
       Sayfa React Shell icinde iframe olarak acildiginda body'ye
       `app-theme-dark` class'i gelir. Bu blok eski light stilleri
       ezer ve mesh + glass gorunumune gecirir. */
    body.app-theme-dark.page-sales-quote-edit,
    body.app-theme-dark .sqe-scroll-container {
        background-color: #0a0d17;
        background-image:
            radial-gradient(at 12% 8%, rgba(99,102,241,0.18) 0px, transparent 50%),
            radial-gradient(at 88% 12%, rgba(14,165,233,0.12) 0px, transparent 50%),
            radial-gradient(at 50% 100%, rgba(168,85,247,0.12) 0px, transparent 50%),
            radial-gradient(at 95% 85%, rgba(20,184,166,0.08) 0px, transparent 50%);
    }
    body.app-theme-dark details.sqe-card,
    body.app-theme-dark div.sqe-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        box-shadow: 0 2px 14px rgba(0, 0, 0, 0.25);
    }
    body.app-theme-dark summary.sqe-card__header,
    body.app-theme-dark .sqe-card__header {
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        background: transparent;
    }
    body.app-theme-dark summary.sqe-card__header:hover {
        background: rgba(255, 255, 255, 0.025);
    }
    body.app-theme-dark summary.sqe-card__header h3,
    body.app-theme-dark .sqe-card__header h3 {
        color: rgba(255, 255, 255, 0.6);
    }
    body.app-theme-dark details.sqe-card:not([open]) > summary.sqe-card__header {
        border-bottom-color: transparent;
    }
    body.app-theme-dark .sqe-form-field label.sqe-label {
        color: rgba(255, 255, 255, 0.55);
        font-weight: 600;
        font-size: 0.75rem;
    }
    /* Tum form input/select/textarea'lar — glass effect */
    body.app-theme-dark .sqe-card input.form-control,
    body.app-theme-dark .sqe-tab-pane input.form-control,
    body.app-theme-dark .sqe-card select.form-select,
    body.app-theme-dark .sqe-tab-pane select.form-select,
    body.app-theme-dark .sqe-card textarea.form-control,
    body.app-theme-dark .sqe-tab-pane textarea.form-control,
    body.app-theme-dark .entity-form-toolbar select.form-select {
        background: rgba(255, 255, 255, 0.04) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: rgba(255, 255, 255, 0.9) !important;
        transition: all 0.18s ease;
    }
    body.app-theme-dark .sqe-card input.form-control::placeholder,
    body.app-theme-dark .sqe-tab-pane input.form-control::placeholder,
    body.app-theme-dark .sqe-card textarea.form-control::placeholder,
    body.app-theme-dark .sqe-tab-pane textarea.form-control::placeholder {
        color: rgba(255, 255, 255, 0.25);
    }
    body.app-theme-dark .sqe-card input.form-control:focus,
    body.app-theme-dark .sqe-tab-pane input.form-control:focus,
    body.app-theme-dark .sqe-card select.form-select:focus,
    body.app-theme-dark .sqe-tab-pane select.form-select:focus,
    body.app-theme-dark .sqe-card textarea.form-control:focus,
    body.app-theme-dark .sqe-tab-pane textarea.form-control:focus {
        background: rgba(255, 255, 255, 0.07) !important;
        border-color: rgba(99, 102, 241, 0.55) !important;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.18) !important;
        color: #fff !important;
        outline: none;
    }
    /* Readonly inputs (Teklif No gibi) — daha sonuk */
    body.app-theme-dark .sqe-card input.form-control[readonly],
    body.app-theme-dark .sqe-tab-pane input.form-control[readonly] {
        background: rgba(255, 255, 255, 0.02) !important;
        color: rgba(255, 255, 255, 0.45) !important;
        cursor: default;
    }
    /* Native select dropdown oklarini beyaz yap */
    body.app-theme-dark .sqe-card select.form-select,
    body.app-theme-dark .sqe-tab-pane select.form-select {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff80' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e") !important;
        background-repeat: no-repeat !important;
        background-position: right 0.5rem center !important;
        background-size: 14px 14px !important;
        padding-right: 28px !important;
    }
    body.app-theme-dark .sqe-card select.form-select option,
    body.app-theme-dark .sqe-tab-pane select.form-select option {
        background: #0c0f1a;
        color: #fff;
    }

    /* Totals */
    body.app-theme-dark .sqe-totals {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding-top: 14px;
        margin-top: 4px;
    }
    body.app-theme-dark .sqe-total-label { color: rgba(255, 255, 255, 0.45); }
    body.app-theme-dark .sqe-total-value {
        color: rgba(255, 255, 255, 0.85);
        font-family: ui-monospace, 'SF Mono', Monaco, 'Cascadia Mono', monospace;
        font-variant-numeric: tabular-nums;
    }
    body.app-theme-dark .sqe-grand-total {
        color: #a5b4fc;
        font-size: 1.05rem;
    }
    body.app-theme-dark .sqe-grand-total .sqe-total-value {
        color: #a5b4fc;
    }

    /* Status badges — dark tema */
    body.app-theme-dark .sqe-status-Draft { background: rgba(100, 116, 139, 0.2); color: #cbd5e1; border: 1px solid rgba(100, 116, 139, 0.3); }
    body.app-theme-dark .sqe-status-Sent { background: rgba(59, 130, 246, 0.2); color: #93c5fd; border: 1px solid rgba(59, 130, 246, 0.35); }
    body.app-theme-dark .sqe-status-Approved { background: rgba(34, 197, 94, 0.2); color: #86efac; border: 1px solid rgba(34, 197, 94, 0.35); }
    body.app-theme-dark .sqe-status-Rejected { background: rgba(239, 68, 68, 0.2); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.35); }
    body.app-theme-dark .sqe-status-Cancelled { background: rgba(100, 116, 139, 0.15); color: #94a3b8; border: 1px solid rgba(100, 116, 139, 0.3); }

    /* ── Aksiyon seridi (sabit, tabsheet altinda) ── */
    .sqe-action-bar {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px; flex-shrink: 0;
        background: rgba(15,15,26,0.85); border-bottom: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        position: relative; overflow: hidden;
    }
    /* Kaydet basarisi — K.I.T.T. on tarayici tarzi; basari icin yesil.
       Ince yesil bir "goz" seridin alt kenarinda soldan saga ve geri surukleniyor. */
    .sqe-action-bar::before {
        content: ''; position: absolute;
        left: 0; right: 0; bottom: 0;
        height: 2px;
        pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,
            rgba(0, 60, 20, 0) 0%,
            rgba(10, 120, 40, .55) 50%,
            rgba(0, 60, 20, 0) 100%);
    }
    .sqe-action-bar::after {
        content: ''; position: absolute;
        left: 0; bottom: -1px;
        width: 18%; height: 4px;
        pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,
            transparent 0%,
            rgba(34, 197, 94, .35) 18%,
            rgba(74, 255, 140, 1) 50%,
            rgba(34, 197, 94, .35) 82%,
            transparent 100%);
        box-shadow:
            0 0 10px 2px rgba(34, 197, 94, .95),
            0 0 22px 6px rgba(34, 197, 94, .55),
            0 0 40px 12px rgba(34, 197, 94, .22);
        border-radius: 50%;
    }
    .sqe-action-bar.is-save-flash::before { animation: sqeKittBg   1800ms ease-out forwards; }
    .sqe-action-bar.is-save-flash::after  { animation: sqeKittScan 1800ms cubic-bezier(.45,.05,.55,.95) forwards; }
    @@keyframes sqeKittBg {
        0%, 100% { opacity: 0; }
        10%, 90% { opacity: 1; }
    }
    @@keyframes sqeKittScan {
        0%   { opacity: 0; left: 0; }
        8%   { opacity: 1; }
        48%  { opacity: 1; left: 82%; }
        52%  { opacity: 1; left: 82%; }
        92%  { opacity: 1; left: 0; }
        100% { opacity: 0; left: 0; }
    }
    body.app-theme-light .sqe-action-bar {
        background: rgba(248,250,252,0.92); border-bottom-color: #e2e8f0;
    }
    .sqe-action-bar .sqe-meta {
        margin-left: auto; font-size: 0.72rem; color: rgba(255,255,255,0.55); font-weight: 500;
    }
    body.app-theme-light .sqe-action-bar .sqe-meta { color: #94a3b8; }
    .sqe-action-bar .sqe-meta strong { color: rgba(255,255,255,0.7); font-weight: 700; }
    body.app-theme-light .sqe-action-bar .sqe-meta strong { color: #334155; }

    /* ── Islemler menusu (cark ikonu + dropdown) ───────────────── */
    .sqe-actions-menu {
        position: relative;
        margin-left: auto;   /* sqe-meta bos iken bile en saga yaslansin */
        display: flex; align-items: center;
    }
    /* Leading varyant: sol basta konumlanir (eski sag konumun yerine).
       Lock banner'a alan birakmak icin auto-margin temizlenir. */
    .sqe-actions-menu--leading {
        margin-left: 0;
        margin-right: 4px;
    }
    .sqe-action-bar .sqe-meta + .sqe-actions-menu { margin-left: 12px; }  /* meta dolu ise yanina yakin */
    .sqe-actions-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 12px;
        font-size: 0.78rem; font-weight: 600;
        color: rgba(255,255,255,0.78);
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.10);
        border-radius: 8px;
        cursor: pointer;
        transition: background .12s, color .12s, border-color .12s, transform .12s;
    }
    /* Icon-only varyant: sadece cark ikonu, kompakt kare buton */
    .sqe-actions-btn--icon-only {
        padding: 8px;
        gap: 0;
        width: 36px; height: 36px;
        justify-content: center;
    }
    .sqe-actions-btn:hover {
        background: rgba(255,255,255,0.08);
        color: #fff;
        border-color: rgba(255,255,255,0.18);
    }
    .sqe-actions-btn svg { flex-shrink: 0; }
    .sqe-actions-btn .sqe-actions-caret { transition: transform .15s; opacity: 0.7; }
    .sqe-actions-menu.is-open .sqe-actions-btn { background: rgba(99,102,241,0.16); color: #c7d2fe; border-color: rgba(99,102,241,0.40); }
    .sqe-actions-menu.is-open .sqe-actions-btn .sqe-actions-caret { transform: rotate(180deg); opacity: 1; }
    body.app-theme-light .sqe-actions-btn {
        color: #334155; background: #fff; border-color: #e2e8f0;
    }
    body.app-theme-light .sqe-actions-btn:hover {
        background: #f8fafc; border-color: #cbd5e1; color: #0f172a;
    }
    body.app-theme-light .sqe-actions-menu.is-open .sqe-actions-btn {
        background: rgba(99,102,241,0.08); color: #4338ca; border-color: rgba(99,102,241,0.45);
    }

    /* position: fixed — .sqe-action-bar'da overflow:hidden oldugu icin
       absolute konumlu dropdown kesiliyordu. Fixed + JS ile viewport-relative
       top/left set edilir (sqToggleActionsMenu hesaplar). */
    .sqe-actions-dropdown {
        position: fixed;
        top: 0; left: 0;
        min-width: 180px;
        display: none;
        flex-direction: column;
        gap: 2px;
        padding: 6px;
        border-radius: 10px;
        background: rgba(15, 19, 30, 0.98);
        border: 1px solid rgba(255, 255, 255, 0.10);
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(99,102,241,0.08);
        z-index: 10000;
        animation: sqeActionsDropIn 140ms cubic-bezier(.2,.8,.3,1);
    }
    .sqe-actions-dropdown.is-open { display: flex; }
    body.app-theme-light .sqe-actions-dropdown {
        background: #fff;
        border-color: #e2e8f0;
        box-shadow: 0 12px 40px rgba(15, 23, 42, 0.16);
    }
    @@keyframes sqeActionsDropIn {
        from { opacity: 0; transform: translateY(-4px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0)    scale(1);    }
    }
    .sqe-actions-item {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 10px;
        font-size: 0.78rem; font-weight: 500;
        color: rgba(255,255,255,0.82);
        background: transparent;
        border: 1px solid transparent;
        border-radius: 7px;
        cursor: pointer;
        text-align: left;
        transition: background .1s, color .1s, border-color .1s;
    }
    .sqe-actions-item:hover {
        background: rgba(99,102,241,0.14);
        color: #c7d2fe;
        border-color: rgba(99,102,241,0.28);
    }
    .sqe-actions-item:focus-visible {
        outline: none;
        box-shadow: 0 0 0 2px rgba(99,102,241,0.35);
    }
    .sqe-actions-item svg { flex-shrink: 0; opacity: 0.8; }
    .sqe-actions-item:hover svg { opacity: 1; }
    body.app-theme-light .sqe-actions-item { color: #334155; }
    body.app-theme-light .sqe-actions-item:hover {
        background: rgba(99,102,241,0.08); color: #4338ca; border-color: rgba(99,102,241,0.25);
    }

    /* Has-sub item — saga ok bayragi gosterir */
    .sqe-actions-item--has-sub.is-open {
        background: rgba(99,102,241,0.10);
        color: #c7d2fe;
        border-color: rgba(99,102,241,0.22);
    }
    body.app-theme-light .sqe-actions-item--has-sub.is-open {
        background: rgba(99,102,241,0.08);
        color: #4338ca;
        border-color: rgba(99,102,241,0.25);
    }

    /* Sub-popup (Durum Degistir liste) */
    .sqe-status-sub {
        display: none; flex-direction: column; gap: 2px;
        position: fixed; min-width: 180px; padding: 6px;
        background: linear-gradient(180deg, rgba(28,32,48,0.97) 0%, rgba(20,24,38,0.97) 100%);
        border: 1px solid rgba(99,102,241,0.18);
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.55), 0 6px 20px rgba(99,102,241,0.18);
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
        z-index: 4001;  /* actions dropdown z-index'inin uzerinde */
    }
    body.app-theme-light .sqe-status-sub {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border-color: rgba(99,102,241,0.20);
        box-shadow: 0 12px 36px rgba(15,23,42,0.14), 0 4px 14px rgba(99,102,241,0.10);
    }
    .sqe-status-sub.is-open { display: flex; }

    .sqe-actions-item__dot {
        display: inline-block; width: 8px; height: 8px; border-radius: 50%;
        flex-shrink: 0; margin-right: 4px;
        box-shadow: 0 0 0 2px rgba(255,255,255,0.06);
    }
    body.app-theme-light .sqe-actions-item__dot { box-shadow: 0 0 0 2px #f8fafc; }
    .sqe-status-dot--draft     { background: #94a3b8; }
    .sqe-status-dot--sent      { background: #38bdf8; }
    .sqe-status-dot--approved  { background: #34d399; }
    .sqe-status-dot--rejected  { background: #f87171; }
    .sqe-status-dot--cancelled { background: #fb923c; }

    /* ── Sol tab + sag icerik body ── */
    .sqe-body { display: flex; flex: 1 1 auto; min-height: 0; overflow: hidden; }
    .sqe-tab-nav {
        width: 200px; flex-shrink: 0;
        border-right: 1px solid var(--app-border,#dde3ee);
        background: var(--app-surface,#fff);
        padding: 10px 10px;
        display: flex; flex-direction: column;
        overflow-y: auto;
    }
    body.app-theme-dark .sqe-tab-nav {
        background: rgba(255,255,255,.02); border-right-color: rgba(255,255,255,.06);
    }
    .sqe-tab-btn {
        display: block; width: 100%; text-align: left;
        padding: 10px 16px; font-size: 0.92rem; font-weight: 600;
        color: var(--app-text-muted,#64748b); background: none;
        border: 1px solid transparent; border-radius: 8px;
        margin-bottom: 4px;
        border-left: 3px solid transparent; cursor: pointer;
        transition: color .12s, background .12s, border-color .12s;
        letter-spacing: .005em;
    }
    .sqe-tab-btn:hover {
        background: var(--app-muted-surface,#f3f5f7); color: var(--app-text,#333);
        border-color: var(--app-border,#e2e8f0);
    }
    body.app-theme-dark .sqe-tab-btn:hover {
        background: rgba(255,255,255,.06); color: #e2e8f0;
        border-color: rgba(255,255,255,.1);
    }
    .sqe-tab-btn.is-active {
        color: #15803d;
        background: rgba(34,197,94,.10);
        border-color: rgba(34,197,94,.30);
        box-shadow: 0 1px 4px rgba(34,197,94,.15);
    }
    body.app-theme-dark .sqe-tab-btn.is-active {
        color: #86efac;
        background: rgba(34,197,94,.14);
        border-color: rgba(74,222,128,.35);
        box-shadow: 0 1px 6px rgba(34,197,94,.20);
    }
    /* Malzeme Kartı sol-menü paritesi (2026-07-11): ikon yok → ring→dolu+glow dot indikatör (::before). Aktif renk/border değişmez. */
    .sqe-tab-btn { display: flex; align-items: center; gap: 9px; }
    .sqe-tab-btn::before {
        content: ''; width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
        border: 1.5px solid #cbd5e1; background: transparent; transition: all .18s;
    }
    .sqe-tab-btn:hover::before { border-color: #94a3b8; }
    .sqe-tab-btn.is-active::before {
        background: #6366f1; border-color: #6366f1; box-shadow: 0 0 7px rgba(99,102,241,.5);
    }
    body.app-theme-dark .sqe-tab-btn::before { border-color: rgba(255,255,255,.24); }
    body.app-theme-dark .sqe-tab-btn:hover::before { border-color: rgba(255,255,255,.48); }
    body.app-theme-dark .sqe-tab-btn.is-active::before {
        background: #6366f1; border-color: #6366f1; box-shadow: 0 0 7px rgba(99,102,241,.55);
    }
    .sqe-tab-content {
        flex: 1 1 auto; min-width: 0; overflow-y: auto; padding: 16px 20px;
        /* Tab degisimlerinde scrollbar gelip gitme ile panel genisligi kaymasin */
        scrollbar-gutter: stable;
    }
    .sqe-tab-pane { display: none; }
    .sqe-tab-pane.is-active { display: block; }

    /* ── Ek Alanlar — grup alt sekmeleri (yatay) ── */
    .sqe-sub-tab-nav {
        display: flex; flex-wrap: wrap; gap: 4px;
        padding: 0 2px 10px 2px; margin-bottom: 10px;
        border-bottom: 1px solid var(--app-border,#e2e8f0);
    }
    .sqe-sub-tab-nav:empty { display: none; }
    body.app-theme-dark .sqe-sub-tab-nav { border-bottom-color: rgba(255,255,255,.08); }
    .sqe-sub-tab-btn {
        padding: 6px 14px; font-size: 0.78rem; font-weight: 600;
        color: var(--app-text-muted,#64748b); background: none;
        border: 1px solid transparent; border-radius: 999px;
        cursor: pointer; transition: color .12s, background .12s, border-color .12s;
    }
    .sqe-sub-tab-btn:hover {
        background: var(--app-muted-surface,#f3f5f7); color: var(--app-text,#333);
        border-color: var(--app-border,#e2e8f0);
    }
    body.app-theme-dark .sqe-sub-tab-btn:hover {
        background: rgba(255,255,255,.05); color: #e2e8f0;
        border-color: rgba(255,255,255,.1);
    }
    .sqe-sub-tab-btn.is-active {
        color: #15803d; background: rgba(34,197,94,.12);
        border-color: rgba(34,197,94,.35);
    }
    body.app-theme-dark .sqe-sub-tab-btn.is-active {
        color: #86efac; background: rgba(34,197,94,.16);
        border-color: rgba(74,222,128,.40);
    }

    /* Kalem Ek Alanlari modali — sag panel stilleri.
       Sol panelde grup ismi zaten tab olarak gorundugu icin sagdaki <details>
       kart cercevesi ve basligi (summary) gizlenir; alanlar label-solda +
       deger-sagda yatay grid seklinde zarifce dizilir. */
    .sqe-extras-fields { color: rgba(255,255,255,0.92); }
    .sqe-extras-fields .sqe-dyn-root {
        display: flex; flex-direction: column; gap: 6px;
    }
    .sqe-extras-fields details.sqe-card,
    .sqe-extras-fields .sqe-card {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        border-radius: 0 !important;
        margin-bottom: 0 !important;
        overflow: visible !important;
    }
    .sqe-extras-fields details.sqe-card > summary,
    .sqe-extras-fields .sqe-card > summary.sqe-card-title,
    .sqe-extras-fields .sqe-card > summary {
        display: none !important;
    }
    /* Eskiden tek sutun flex-column'a zorluyordu; simdi renderer'in 12-col
       grid'i (colSpan) gecerli olsun diye sadece gap tanimliyoruz. */
    .sqe-extras-fields .sqe-grid-2 {
        gap: 14px; margin-top: 0 !important;
    }
    .sqe-extras-fields .sqe-field {
        display: grid;
        grid-template-columns: 180px 1fr;
        align-items: center;
        gap: 12px;
        padding: 4px 2px;
        border: none;
        background: transparent;
    }
    .sqe-extras-fields .sqe-field > label.sqe-label {
        font-size: 13px; font-weight: 600;
        color: rgba(255,255,255,0.78);
        letter-spacing: 0.01em;
        margin: 0; padding: 0;
        text-transform: none;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sqe-extras-fields .sqe-field > *:not(label) {
        min-width: 0;
    }
    .sqe-extras-fields .sqe-input,
    .sqe-extras-fields .sqe-select,
    .sqe-extras-fields input.sqe-input,
    .sqe-extras-fields select.sqe-select,
    .sqe-extras-fields textarea {
        width: 100%;
        font-size: 13px;
        padding: 7px 10px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(10,14,24,0.55);
        color: rgba(255,255,255,0.92);
        outline: none;
        transition: border-color .12s, box-shadow .12s;
    }
    .sqe-extras-fields .sqe-input:focus,
    .sqe-extras-fields .sqe-select:focus,
    .sqe-extras-fields textarea:focus {
        border-color: rgba(99,102,241,0.55);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    .sqe-extras-fields .sqe-input.is-invalid,
    .sqe-extras-fields .sqe-select.is-invalid,
    .sqe-extras-fields textarea.is-invalid {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 3px rgba(239,68,68,.22) !important;
    }
    .sqe-extras-fields .sqe-rule-error {
        grid-column: 2 / -1;
        font-size: 11px; color: #fca5a5; margin-top: 3px;
    }

    /* Widget wrapper — Ek Alanlar pane icindeki ana kap.
       Gruplar ARTIK DIKEY olarak alt alta siralanir; sub-tab bar ise scroll-to
       nav olarak calisir. Her grubun <summary> etiketi gorunur section header
       olur; kart cercevesi minimal, bolmeler arasi bolucu cizgi var. */
    .sqe-widget-wrap { display: block; color: rgba(255,255,255,0.92); }
    body.app-theme-light .sqe-widget-wrap { color: #1e293b; }
    /* Gruplar dikeyde alt alta dizilir. */
    .sqe-widget-wrap .sqe-dyn-root {
        display: flex; flex-direction: column; gap: 28px;
    }
    .sqe-widget-wrap details.sqe-card,
    .sqe-widget-wrap .sqe-card {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        border-radius: 0 !important;
        margin-bottom: 0 !important;
        overflow: visible !important;
        padding: 0 !important;
        scroll-margin-top: 20px;  /* pill'e tiklayinca header altina denk gelsin */
    }
    /* Grup basligi — section header (eskiden gizliydi, simdi gorunur) */
    .sqe-widget-wrap details.sqe-card > summary,
    .sqe-widget-wrap .sqe-card > summary.sqe-card-title {
        display: flex !important;
        align-items: center;
        gap: 10px;
        padding: 0 2px 12px 2px !important;
        margin: 0 0 12px 0 !important;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        font-size: 0.92rem;
        font-weight: 700;
        color: rgba(255,255,255,0.88);
        letter-spacing: 0.01em;
        list-style: none !important;
        cursor: default !important;
        user-select: none;
    }
    body.app-theme-light .sqe-widget-wrap details.sqe-card > summary,
    body.app-theme-light .sqe-widget-wrap .sqe-card > summary.sqe-card-title {
        border-bottom-color: rgba(15,23,42,0.10);
        color: #0f172a;
    }
    .sqe-widget-wrap details.sqe-card > summary::-webkit-details-marker,
    .sqe-widget-wrap details.sqe-card > summary::marker {
        display: none; content: '';
    }
    /* Sol tarafina kucuk renkli bir isaret koy — grup ayrici olarak */
    .sqe-widget-wrap details.sqe-card > summary::before {
        content: '';
        width: 3px; height: 14px; border-radius: 2px;
        background: linear-gradient(180deg, #6366f1 0%, #a855f7 100%);
        flex-shrink: 0;
    }
    /* Grid-2 konteyneri — React inline olarak 12-kolonlu grid + gap uygular
       (colSpan feature). CSS burada sadece default gap/margin tanimlar;
       !important ile override etmiyoruz ki renderer'in 12-col grid'i calissin. */
    .sqe-widget-wrap .sqe-grid-2 {
        gap: 14px;
        margin-top: 0 !important;
    }
    /* Her alan kendi iç kutusunu korur (label-solda / input-sagda) ama
       disarida colSpan'a gore grid hucresine yerlesir. Dis cerceve/background
       KALDIRILDI — modern label kendi outlined cercevesini cizer, standart
       label'da input kendi border'ini tasir; ek kart/rectangle gereksiz. */
    /* Klasik baslik: label + input AYNI satirda. Label kendi genisliginde
       (max-content), sonra kucuk bosluk, input kalan alani doldurur.
       Cell daraldiginda label truncate olur (0'a kadar kuculebilir). */
    .sqe-widget-wrap .sqe-field {
        display: grid;
        grid-template-columns: minmax(0, max-content) 1fr;
        align-items: center;
        column-gap: 10px;
        padding: 4px 2px;
        border: none;
        background: transparent;
    }
    .sqe-widget-wrap .sqe-field > label.sqe-label {
        font-size: 13.5px; font-weight: 600;
        color: rgba(255,255,255,0.78);
        letter-spacing: 0.01em;
        margin: 0; padding: 0;
        text-transform: none;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    body.app-theme-light .sqe-widget-wrap .sqe-field > label.sqe-label {
        color: #334155;
    }
    .sqe-widget-wrap .sqe-field > *:not(label) { min-width: 0; }
    /* ── Karisik label stilli satir hizalamasi ──────────────────
       Ayni grid satirinda hem klasik (label-solda, .sqe-field) hem modern
       (floating label, .calibra-modern-wrap) alanlar bulununca input ust
       kenarlari hizalanmiyordu (modern 12px padding-top ile floating label
       icin yer ayirirken, klasik bunu yapmiyordu). Cozum: satirdaki butun
       cocuklari TOP hizasina sabitle ve klasik alana ayni 12px ust bosluk
       ver — boylece iki turdeki input ust noktasi ayni Y'ye duser. */
    .sqe-widget-wrap .sqe-grid-2:has(.calibra-modern-wrap) {
        align-items: start;
    }
    .sqe-widget-wrap .sqe-grid-2:has(.calibra-modern-wrap) .sqe-field {
        padding-top: 14px;
    }
    .sqe-widget-wrap .sqe-input,
    .sqe-widget-wrap .sqe-select,
    .sqe-widget-wrap input.sqe-input,
    .sqe-widget-wrap select.sqe-select,
    .sqe-widget-wrap textarea,
    .sqe-widget-wrap input[type="text"],
    .sqe-widget-wrap input[type="number"],
    .sqe-widget-wrap input[type="date"],
    .sqe-widget-wrap input[type="datetime-local"],
    .sqe-widget-wrap input[type="time"],
    .sqe-widget-wrap select {
        width: 100%;
        font-size: 13px;
        padding: 8px 10px;
        border-radius: 8px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(10,14,24,0.55);
        color: rgba(255,255,255,0.92);
        outline: none;
        transition: border-color .12s, box-shadow .12s;
        font-family: inherit;
    }
    body.app-theme-light .sqe-widget-wrap .sqe-input,
    body.app-theme-light .sqe-widget-wrap .sqe-select,
    body.app-theme-light .sqe-widget-wrap input[type="text"],
    body.app-theme-light .sqe-widget-wrap input[type="number"],
    body.app-theme-light .sqe-widget-wrap input[type="date"],
    body.app-theme-light .sqe-widget-wrap input[type="datetime-local"],
    body.app-theme-light .sqe-widget-wrap input[type="time"],
    body.app-theme-light .sqe-widget-wrap select,
    body.app-theme-light .sqe-widget-wrap textarea {
        background: #fff;
        border-color: #e2e8f0;
        color: #1e293b;
    }
    .sqe-widget-wrap .sqe-input:focus,
    .sqe-widget-wrap .sqe-select:focus,
    .sqe-widget-wrap textarea:focus,
    .sqe-widget-wrap input:focus,
    .sqe-widget-wrap select:focus {
        border-color: rgba(99,102,241,0.55);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    .sqe-widget-wrap .sqe-input.is-invalid,
    .sqe-widget-wrap .sqe-select.is-invalid,
    .sqe-widget-wrap textarea.is-invalid,
    .sqe-widget-wrap input.is-invalid,
    .sqe-widget-wrap select.is-invalid {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 3px rgba(239,68,68,.22) !important;
    }

    /* Tema tutarliligi — kalem Ek Alanlari modali icindeki tum input/select/textarea.
       Modal backdrop zaten dark; icerdeki form elemanlari semi-transparan bg yerine
       OPAQUE tema rengini alir. Modern floating-label (.calibra-modern-wrap) icinde
       de ayni kural gecerli — label "kesim" efekti icin input bg ile uyumlu kalir. */
    body.app-theme-dark .sqe-widget-wrap input.sqe-input,
    body.app-theme-dark .sqe-widget-wrap select.sqe-select,
    body.app-theme-dark .sqe-widget-wrap textarea,
    body.app-theme-dark .sqe-widget-wrap .calibra-modern-wrap input,
    body.app-theme-dark .sqe-widget-wrap .calibra-modern-wrap select,
    body.app-theme-dark .sqe-widget-wrap .calibra-modern-wrap textarea {
        background: rgba(12, 17, 28, 0.92) !important;
        border-color: rgba(148, 163, 184, 0.22) !important;
        color: rgba(255, 255, 255, 0.92) !important;
    }
    body.app-theme-light .sqe-widget-wrap input.sqe-input,
    body.app-theme-light .sqe-widget-wrap select.sqe-select,
    body.app-theme-light .sqe-widget-wrap textarea,
    body.app-theme-light .sqe-widget-wrap .calibra-modern-wrap input,
    body.app-theme-light .sqe-widget-wrap .calibra-modern-wrap select,
    body.app-theme-light .sqe-widget-wrap .calibra-modern-wrap textarea {
        background: #ffffff !important;
        border-color: #e2e8f0 !important;
        color: #1e293b !important;
    }
    /* Focus tema uyumlu */
    body.app-theme-dark .sqe-widget-wrap input.sqe-input:focus,
    body.app-theme-dark .sqe-widget-wrap select.sqe-select:focus,
    body.app-theme-dark .sqe-widget-wrap textarea:focus {
        background: rgba(20, 27, 42, 0.95) !important;
        border-color: #6366f1 !important;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.22) !important;
    }
    body.app-theme-light .sqe-widget-wrap input.sqe-input:focus,
    body.app-theme-light .sqe-widget-wrap select.sqe-select:focus,
    body.app-theme-light .sqe-widget-wrap textarea:focus {
        background: #ffffff !important;
        border-color: #6366f1 !important;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15) !important;
    }
    /* Modern label — arka plan seffaf; sadece metin rengini tema'ya gore ayarla. */
    body.app-theme-dark .sqe-widget-wrap .calibra-modern-label {
        color: rgba(165, 180, 252, 0.92) !important;
    }
    body.app-theme-light .sqe-widget-wrap .calibra-modern-label {
        color: #475569 !important;
    }
    /* Date input — tarayicinin kendi acilir simgesi (calendar picker) dark tema
       ile zit renk gostermesin. WebKit picker indicator'unu invert eder. */
    body.app-theme-dark .sqe-widget-wrap input[type="date"]::-webkit-calendar-picker-indicator,
    body.app-theme-dark .sqe-widget-wrap input[type="datetime-local"]::-webkit-calendar-picker-indicator,
    body.app-theme-dark .sqe-widget-wrap input[type="time"]::-webkit-calendar-picker-indicator {
        filter: invert(1) opacity(0.7);
    }

    .sqe-widget-wrap .sqe-rule-error {
        grid-column: 2 / -1;
        font-size: 11px; color: #fca5a5; margin-top: 3px;
    }
    /* Date picker ikon rengi dark temada beyaza yakin olsun */
    .sqe-widget-wrap input[type="date"]::-webkit-calendar-picker-indicator,
    .sqe-widget-wrap input[type="datetime-local"]::-webkit-calendar-picker-indicator,
    .sqe-widget-wrap input[type="time"]::-webkit-calendar-picker-indicator {
        filter: invert(0.8);
        cursor: pointer;
        opacity: 0.7;
    }
    body.app-theme-light .sqe-widget-wrap input[type="date"]::-webkit-calendar-picker-indicator,
    body.app-theme-light .sqe-widget-wrap input[type="datetime-local"]::-webkit-calendar-picker-indicator,
    body.app-theme-light .sqe-widget-wrap input[type="time"]::-webkit-calendar-picker-indicator {
        filter: none;
        opacity: 0.6;
    }
    .sqe-widget-empty {
        padding: 24px 16px; text-align: center;
        font-size: 0.82rem; color: var(--app-text-muted,#64748b);
        border: 1px dashed var(--app-border,#cbd5e1);
        border-radius: 12px;
        background: var(--app-muted-surface,#f8fafc);
    }
    body.app-theme-dark .sqe-widget-empty {
        color: rgba(255,255,255,.45);
        border-color: rgba(255,255,255,.12);
        background: rgba(255,255,255,.02);
    }
    .sqe-widget-empty.is-hidden { display: none; }

    /* Ekli Dosyalar tabi */
    .sqe-att-wrap { display: flex; flex-direction: column; gap: 14px; padding: 8px 2px; }
    .sqe-att-drop {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 10px; padding: 28px 18px;
        border: 2px dashed var(--app-border,#cbd5e1);
        border-radius: 14px;
        background: var(--app-muted-surface,#f8fafc);
        color: var(--app-text-muted,#64748b);
        font-size: 0.85rem; font-weight: 500;
        cursor: pointer; transition: border-color .15s, background .15s, color .15s;
    }
    .sqe-att-drop:hover { border-color: #22c55e; color: #15803d; background: rgba(34,197,94,.06); }
    body.app-theme-dark .sqe-att-drop {
        border-color: rgba(255,255,255,.12);
        background: rgba(255,255,255,.03);
        color: rgba(255,255,255,.55);
    }
    body.app-theme-dark .sqe-att-drop:hover {
        border-color: rgba(74,222,128,.5); color: #86efac; background: rgba(34,197,94,.08);
    }
    .sqe-att-list { display: flex; flex-direction: column; gap: 8px; }
    .sqe-att-empty { text-align: center; padding: 14px; font-size: 0.78rem; color: var(--app-text-muted,#94a3b8); }
    .sqe-att-item {
        display: flex; align-items: center; gap: 10px;
        padding: 9px 12px; border-radius: 10px;
        background: var(--app-surface,#fff);
        border: 1px solid var(--app-border,#e2e8f0);
        font-size: 0.82rem;
    }
    body.app-theme-dark .sqe-att-item {
        background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.08); color: rgba(255,255,255,.85);
    }
    .sqe-att-item__name { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600; }
    .sqe-att-item__meta { font-size: 0.72rem; color: var(--app-text-muted,#94a3b8); }
    .sqe-att-item__btn {
        border: none; background: transparent; cursor: pointer;
        padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; font-weight: 600;
        color: #64748b;
    }
    .sqe-att-item__btn:hover { background: rgba(99,102,241,.10); color: #4f46e5; }
    .sqe-att-item__btn.is-danger:hover { background: rgba(239,68,68,.10); color: #ef4444; }
    body.app-theme-dark .sqe-att-item__btn { color: rgba(255,255,255,.55); }
    body.app-theme-dark .sqe-att-item__btn:hover { background: rgba(99,102,241,.15); color: #a5b4fc; }
    body.app-theme-dark .sqe-att-item__btn.is-danger:hover { background: rgba(239,68,68,.18); color: #fca5a5; }

    .sqe-header { display: none; }
    .sqe-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 14px; border-radius: 10px; border: 1px solid;
        font-size: 0.8rem; font-weight: 600; cursor: pointer;
        transition: all 0.15s ease; background: transparent;
        text-decoration: none;
    }
    .sqe-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .sqe-btn--primary {
        background: #6366f1; border-color: #4f46e5; color: #fff;
    }
    .sqe-btn--primary:hover { background: #4f46e5; color: #fff; }
    .sqe-btn--secondary {
        background: rgba(255,255,255,0.06);
        border-color: rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.75);
    }
    body.app-theme-light .sqe-btn--secondary {
        background: #fff; border-color: #e2e8f0; color: #475569;
    }
    .sqe-btn--secondary:hover { background: rgba(255,255,255,0.1); color: #fff; }
    body.app-theme-light .sqe-btn--secondary:hover { background: #f1f5f9; color: #1e293b; }
    .sqe-btn--danger {
        background: rgba(239,68,68,0.1);
        border-color: rgba(239,68,68,0.3);
        color: #f87171;
    }
    body.app-theme-light .sqe-btn--danger { color: #dc2626; }
    .sqe-btn--danger:hover:not(:disabled) { background: rgba(239,68,68,0.2); }

    /* Entity form toolbar — Kaydet / Listeye Don / Sil (legacy, kullanilmiyor) */
    body.app-theme-dark .entity-form-toolbar {
        background: rgba(255, 255, 255, 0.03);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }
    body.app-theme-dark .entity-form-toolbar .btn.integrator-btn-secondary,
    body.app-theme-dark .entity-form-toolbar .btn.integrator-btn-tertiary {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: rgba(255, 255, 255, 0.75) !important;
    }
    body.app-theme-dark .entity-form-toolbar .btn.integrator-btn-secondary:hover,
    body.app-theme-dark .entity-form-toolbar .btn.integrator-btn-tertiary:hover {
        background: rgba(255, 255, 255, 0.08) !important;
        color: #fff !important;
    }
    body.app-theme-dark .entity-form-toolbar .btn.integrator-btn-tertiary:not(:disabled) {
        color: rgba(248, 113, 113, 0.9) !important;
        border-color: rgba(248, 113, 113, 0.3) !important;
    }
    body.app-theme-dark .entity-form-toolbar .btn.integrator-btn-tertiary:not(:disabled):hover {
        background: rgba(248, 113, 113, 0.1) !important;
        color: #fca5a5 !important;
    }

    /* ── Yukleme maskesi — edit modunda alan flashini engeller ──
       Fade kaldirildi: transition opacity sirasinda semi-transparent maske
       arkasindan field'lar gorunur ve "sonradan dolma" izlenimi yaratiyordu.
       Artik opak (koyu/acik tema) zemin + display:none ile tamamen sakli. */
    .sqe-loading-mask {
        position: absolute;
        inset: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        pointer-events: none;
        border-radius: inherit;
    }
    body.app-theme-dark  .sqe-loading-mask { background: #0b1020; }
    body.app-theme-light .sqe-loading-mask { background: #f8fafc; }
    .sqe-loading-mask.is-hidden { display: none !important; }
    .sqe-loading-mask__spinner {
        width: 18px; height: 18px;
        border-radius: 50%;
        border: 2px solid rgba(99,102,241,0.25);
        border-top-color: #6366f1;
        animation: sqe-spin 0.7s linear infinite;
    }
    .sqe-loading-mask__text {
        font-size: 12px;
        font-weight: 500;
    }
    body.app-theme-dark  .sqe-loading-mask__text { color: rgba(255,255,255,0.5); }
    body.app-theme-light .sqe-loading-mask__text { color: #64748b; }
    @@keyframes sqe-spin { to { transform: rotate(360deg); } }
    /* Maskenin konumlanabilmesi icin ebeveyni relative olmali */
    .sqe-body { position: relative; }

    /* Notlar textarea — icerige gore buyur, ic scroll olmaz */
    .sqe-notes-area {
        display: block;
        width: 100%;
        resize: vertical;
        overflow-y: hidden;   /* ic scroll yok → scroll olaylari uste gider */
        min-height: 120px;
        line-height: 1.6;
        transition: min-height 0.1s;
    }

    /* flatpickr takvim teması: global calibra-datepicker.css'e taşındı (2026-07-06) */
</style>
}

@{
    var _colId = editId.HasValue ? editId.Value.ToString() : $"new-{Guid.NewGuid():N}";
    var _colTitle = editId.HasValue ? $"{entityLabel} #{editId.Value}" : $"Yeni {entityLabel}";
}
<form class="integrator-form" style="display:none" aria-hidden="true"
      data-collaboration-record-type="@headerFormCode"
      data-collaboration-record-id="@_colId"
      data-collaboration-record-title="@_colTitle"></form>

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">

    <!-- Aksiyon Şeridi — CalibraHub standart butonlar (.pte-btn--icon).
         Container .sqe-action-bar korundu: KITT flash + collaboration lock banner
         host + status akışı buna bağlı. Sadece butonlar standart tile'a çevrildi. -->
    <div class="sqe-action-bar" data-no-proxy data-collaboration-banner-host>
        <a href="@listReturnUrl" class="pte-btn pte-btn--secondary pte-btn--icon" id="ptBtnList" aria-label="Liste" title="Liste">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </a>
        <button type="button" class="pte-btn pte-btn--primary pte-btn--icon" data-collaboration-write="true" onclick="sqSave({ validate: true })" aria-label="Kaydet">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
            <span class="pte-btn__label">Kaydet</span>
        </button>
        <button type="button" class="pte-btn pte-btn--danger pte-btn--icon" id="sqBtnDelete" data-collaboration-write="true" disabled onclick="sqDelete()" aria-label="Sil">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            <span class="pte-btn__label">Sil</span>
        </button>
        @if ((isOrder || isPurchaseOrder) && Model.DocumentId.HasValue)
        {
            var dlvLabel   = isPurchaseOrder ? "Mal Kabul" : "Teslim Et";
            var dlvEndpoint = isPurchaseOrder ? "/Warehouse/ReceivePurchaseOrderJson" : "/Warehouse/DeliverSalesOrderJson";
            var dlvTitle   = isPurchaseOrder
                ? "Açık kalemleri mal kabul et — Alış İrsaliyesi oluşturur, stok girişi yazar"
                : "Açık kalemleri teslim et — Satış İrsaliyesi oluşturur, stok çıkışı yazar";
            var dlvConfirm = isPurchaseOrder
                ? "Bu siparişin açık (kabul edilmemiş) kalemleri için Alış İrsaliyesi oluşturulacak: stok girişi yazılacak. Devam edilsin mi?"
                : "Bu siparişin açık (teslim edilmemiş) kalemleri için Satış İrsaliyesi oluşturulacak: stok çıkışı yazılacak. Devam edilsin mi?";
            <button type="button" class="pte-btn pte-btn--secondary pte-btn--icon" id="sqBtnDeliver" data-collaboration-allow onclick="sqDeliverOrder()" title="@dlvTitle" aria-label="@dlvLabel">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span class="pte-btn__label">@dlvLabel</span>
            </button>
            <script>
            var _sqDlvEndpoint = '@dlvEndpoint';
            var _sqDlvLabel = '@dlvLabel';
            function sqDeliverOrder() {
                var oid = @(Model.DocumentId ?? 0);
                if (!oid) return;
                _sqDlvConfirm(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(dlvConfirm)), function () {
                    var tokEl = document.querySelector('input[name="__RequestVerificationToken"]');
                    var btn = document.getElementById('sqBtnDeliver'); if (btn) btn.disabled = true;
                    fetch(_sqDlvEndpoint + '?orderId=' + oid, {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'RequestVerificationToken': tokEl ? tokEl.value : '' }
                    }).then(function (r) { return r.json(); }).then(function (d) {
                        if (d && d.success) { _sqDlvToast('İrsaliye oluşturuldu: ' + (d.docNo || ('#' + d.id)) + '. Stok hareketi yazıldı.', true); setTimeout(function () { window.location.reload(); }, 1100); }
                        else { _sqDlvToast((d && d.message) || (_sqDlvLabel + ' başarısız.'), false); if (btn) btn.disabled = false; }
                    }).catch(function (e) { _sqDlvToast('İşlem sırasında hata: ' + e, false); if (btn) btn.disabled = false; });
                });
            }
            function _sqDlvConfirm(msg, onOk) {
                var bd = document.createElement('div');
                bd.style.cssText = 'position:fixed;inset:0;z-index:100000;background:rgba(2,6,23,.6);display:flex;align-items:center;justify-content:center;';
                bd.innerHTML = '<div style="max-width:420px;width:92%;background:var(--app-surface,#1a1f2e);border:1px solid var(--app-border,#334155);border-radius:14px;padding:20px;color:var(--bs-body-color,#e2e8f0);box-shadow:0 20px 60px rgba(0,0,0,.5)">'
                    + '<div style="font-size:1rem;font-weight:700;margin-bottom:8px">' + _sqDlvLabel + ' → İrsaliye</div>'
                    + '<div style="font-size:.86rem;line-height:1.5;opacity:.85;margin-bottom:18px"></div>'
                    + '<div style="display:flex;gap:8px;justify-content:flex-end">'
                    + '<button id="_sqDlvCancel" style="padding:8px 14px;border-radius:8px;border:1px solid var(--app-border,#334155);background:transparent;color:inherit;cursor:pointer;font-weight:600">Vazgeç</button>'
                    + '<button id="_sqDlvOk" style="padding:8px 16px;border-radius:8px;border:none;background:#10b981;color:#fff;cursor:pointer;font-weight:600">' + _sqDlvLabel + '</button>'
                    + '</div></div>';
                bd.querySelector('div > div').textContent = msg;
                document.body.appendChild(bd);
                function close() { if (bd.parentNode) bd.parentNode.removeChild(bd); }
                bd.addEventListener('click', function (e) { if (e.target === bd) close(); });
                bd.querySelector('#_sqDlvCancel').onclick = close;
                bd.querySelector('#_sqDlvOk').onclick = function () { close(); onOk(); };
                bd.querySelector('#_sqDlvOk').focus();
            }
            function _sqDlvToast(msg, ok) {
                var t = document.createElement('div');
                t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:100001;padding:12px 18px;border-radius:10px;font-size:.85rem;font-weight:600;color:#fff;box-shadow:0 10px 30px rgba(0,0,0,.4);max-width:90%;background:' + (ok ? '#10b981' : '#ef4444');
                t.textContent = msg;
                document.body.appendChild(t);
                setTimeout(function () { if (t.parentNode) t.parentNode.removeChild(t); }, 4000);
            }
            </script>
        }
        <!-- Status select gizli — UI uzerinden direkt degistirilmiyor; sqActionStatus
             (Islemler dropdown'undan) deger atayip change tetikliyor. Badge gorunur kaldi. -->
        <select id="sqStatusSelect" class="form-select form-select-sm" style="display:none;" onchange="sqChangeStatus()">
            <option value="Draft">Taslak</option>
            <option value="Sent">Gonderildi</option>
            <option value="Approved">Onaylandi</option>
            <option value="Rejected">Reddedildi</option>
            <option value="Cancelled">Iptal</option>
        </select>
        <span id="sqStatusBadge"></span>
        <span class="sqe-meta" id="sqMeta"></span>
        <!-- İşlemler menüsü butonu — standart tile, meta'dan sonra sağda. -->
        <div class="sqe-actions-menu" id="sqActionsMenu">
            <button type="button"
                    class="pte-btn pte-btn--actions pte-btn--icon"
                    id="sqActionsBtn"
                    aria-haspopup="menu"
                    aria-expanded="false"
                    data-collaboration-allow
                    title="İşlemler"
                    onclick="sqToggleActionsMenu(event)"
                    aria-label="İşlemler">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82 1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
                <span class="pte-btn__label">İşlemler</span>
            </button>
        </div>
    </div>

    <!-- Islemler Dropdown — aksiyon sertinin DISINDA ki backdrop-filter +
         overflow stacking context'i icin kesilmesin. JS ile sqActionsBtn'in
         viewport koordinatlarina gore pozisyonlanir. -->
    <div class="sqe-actions-dropdown" role="menu" id="sqActionsDropdown">
        <button type="button" role="menuitem" class="sqe-actions-item" onclick="sqActionPrint(event)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 6 2 18 2 18 9"/>
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
                <rect x="6" y="14" width="12" height="8"/>
            </svg>
            <span>Yazdir</span>
        </button>
        <button type="button" role="menuitem" class="sqe-actions-item" onclick="sqActionSendMail(event)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
            </svg>
            <span>Mail Gönder</span>
        </button>
        <button type="button" role="menuitem" class="sqe-actions-item" onclick="sqActionShowAllCosts(event)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="4" y="2" width="16" height="20" rx="2"/>
                <line x1="8" y1="6" x2="16" y2="6"/>
                <line x1="8" y1="10" x2="16" y2="10"/>
                <line x1="8" y1="14" x2="16" y2="14"/>
                <line x1="8" y1="18" x2="13" y2="18"/>
            </svg>
            <span>Tüm Ürünlerin Maliyeti</span>
        </button>
        <!-- Durum Degistir — tek item, hover/click ile yan acilan sub-popup -->
        <button type="button" role="menuitem"
                class="sqe-actions-item sqe-actions-item--has-sub"
                aria-haspopup="menu"
                aria-expanded="false"
                onclick="sqToggleStatusSubmenu(event)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9"/>
                <polyline points="12 7 12 12 15 14"/>
            </svg>
            <span style="flex:1;">Durum Değiştir</span>
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </button>
        @* Entegrasyonlar — bu form icin Manual trigger'li aktif entegrasyonlar
           dinamik olarak divider + header + items seklinde dropdown'a eklenir.
           Hicbiri yoksa goruunmez (placeholder gizli kalir).

           ÖNEMLI (bug fix 2026-05-20): Wizard'da kullanici "Satıs Teklifi" altinda
           ya SALES_QUOTE_NEW ya SALES_QUOTE_EDIT kodunu secebilir (Forms tablosunda
           ikisi de var). Edit ekraninda her ikisini de gostermek icin partial'a
           VIRGULLE AYRILMIS form kod listesi gonderiyoruz. _IntegrationActionItems
           her birini ayri sorgulayip dedup ile birlestirir. *@
        @{
            // 2026-05-23: VM'den okuyoruz — 5 belge tipi icin de "EDIT,NEW" cifti.
            var integrationFormCodes = $"{Model.HeaderFormCode},{Model.HeaderFormCodeNew}";
        }
        @await Html.PartialAsync("_IntegrationActionItems",
            new CalibraHub.Web.Models.IntegrationButtonsModel {
                FormCode = integrationFormCodes,
                RecordId = (editId ?? 0).ToString()
            })
    </div>

    <!-- Durum Degistir alt-popup — actions dropdown'unun yan tarafinda acilir.
         JS pozisyonu sqStatusSubBtn (yukaridaki has-sub item) referans alir. -->
    <div class="sqe-status-sub" role="menu" id="sqStatusSubmenu">
        <button type="button" role="menuitem" class="sqe-actions-item" data-status="Draft"     onclick="sqActionStatus('Draft', event)">
            <span class="sqe-actions-item__dot sqe-status-dot--draft"></span>
            <span>Taslak</span>
        </button>
        <button type="button" role="menuitem" class="sqe-actions-item" data-status="Sent"      onclick="sqActionStatus('Sent', event)">
            <span class="sqe-actions-item__dot sqe-status-dot--sent"></span>
            <span>Gonderildi</span>
        </button>
        <button type="button" role="menuitem" class="sqe-actions-item" data-status="Approved"  onclick="sqActionStatus('Approved', event)">
            <span class="sqe-actions-item__dot sqe-status-dot--approved"></span>
            <span>Onaylandi</span>
        </button>
        <button type="button" role="menuitem" class="sqe-actions-item" data-status="Rejected"  onclick="sqActionStatus('Rejected', event)">
            <span class="sqe-actions-item__dot sqe-status-dot--rejected"></span>
            <span>Reddedildi</span>
        </button>
        <button type="button" role="menuitem" class="sqe-actions-item" data-status="Cancelled" onclick="sqActionStatus('Cancelled', event)">
            <span class="sqe-actions-item__dot sqe-status-dot--cancelled"></span>
            <span>Iptal</span>
        </button>
    </div>

    <!-- Sol tab + sag icerik -->
    <div class="sqe-body">

        <!-- Yukleme maskesi: edit modunda veri gelene kadar bos alan flashini onler -->
        <div id="sqLoadingMask" class="sqe-loading-mask@(editId.HasValue ? "" : " is-hidden")" aria-hidden="true">
            <div class="sqe-loading-mask__spinner"></div>
            <span class="sqe-loading-mask__text">Yukleniyor…</span>
        </div>

        <nav class="sqe-tab-nav">
            <button type="button" class="sqe-tab-btn is-active" data-sqe-tab-btn="general" onclick="sqSwitchTab('general')">Genel Bilgiler</button>
            <button type="button" class="sqe-tab-btn" data-sqe-tab-btn="lines" onclick="sqSwitchTab('lines')">Kalem Bilgileri</button>
            <button type="button" class="sqe-tab-btn" data-sqe-tab-btn="conditions" onclick="sqSwitchTab('conditions')">Kosullar</button>
            <button type="button" class="sqe-tab-btn" data-sqe-tab-btn="notes" onclick="sqSwitchTab('notes')">Notlar</button>
            <button type="button" class="sqe-tab-btn" data-sqe-tab-btn="widgets" onclick="sqSwitchTab('widgets')">Ek Alanlar</button>
            <button type="button" class="sqe-tab-btn" data-sqe-tab-btn="attachments" onclick="sqSwitchTab('attachments')">Ekli Dosyalar</button>
            @if (Model.DocumentId.HasValue)
            {
                <button type="button" class="sqe-tab-btn" data-sqe-tab-btn="workflow" onclick="sqSwitchTab('workflow')">Onay Akışı</button>
                <button type="button" class="sqe-tab-btn" data-sqe-tab-btn="lineage" onclick="sqSwitchTab('lineage')">İlişkili Belgeler</button>
                <button type="button" class="sqe-tab-btn" data-sqe-tab-btn="audittrail" onclick="sqSwitchTab('audittrail')">Değişiklik Geçmişi</button>
            }
        </nav>
        <div class="sqe-tab-content">

        <!-- TAB 1: Genel Bilgiler -->
        <div class="sqe-tab-pane is-active" data-sqe-pane="general">
            <div class="sqe-hform">
                <div class="sqe-hrow">
                    @* 2026-05-23: 5 belge tipini destekler — entityLabel switch'ten gelir.
                       satis_teklifi → "Teklif No", satis_siparisi → "Siparis No",
                       alis_talebi → "İhtiyaç No", alis_teklifi → "Teklif No", alis_siparisi → "Siparis No" *@
                    <label class="sqe-hlabel">@(entityLabel) No</label>
                    <div class="sqe-hcombo" style="align-items:center;gap:6px;">
                        <input id="sqQuoteNumber" class="form-control form-control-sm sqe-hinput" readonly placeholder="Kaydedildiginde olusturulur" style="font-size:1rem; font-weight:600;" />
                        @if (isOrder)
                        {
                            <button type="button" id="sqOrderLookupBtn" class="sqe-lookup-btn" title="Tekliften olusturulan siparislerden sec" onclick="openOrderLookup()" style="flex-shrink:0;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <circle cx="11" cy="11" r="7"></circle>
                                    <path d="m21 21-4.3-4.3"></path>
                                </svg>
                            </button>
                        }
                    </div>
                </div>
                <div class="sqe-hrow">
                    <label class="sqe-hlabel">Tarih</label>
                    <input id="sqQuoteDate" type="date" class="form-control form-control-sm sqe-hinput" oninput="sqRecalcValidFromDays()" />
                </div>
                @if (isOrder)
                {
                    @* Siparis: Teslim Gun + Tarih (iki input) *@
                    <div class="sqe-hrow">
                        <label class="sqe-hlabel">Teslim Gun/Tarih</label>
                        <div class="sqe-hcombo">
                            <input id="sqValidDays" type="number" min="0" class="form-control form-control-sm sqe-hinput sqe-fp-days" placeholder="Gun" oninput="sqRecalcValidFromDays()" />
                            <input id="sqValidUntil" type="date" class="form-control form-control-sm sqe-hinput" oninput="sqRecalcDaysFromValid()" />
                        </div>
                    </div>
                }
                else
                {
                    @* Teklif / İhtiyaç Kaydı: Gecerlilik Gun + Tarih (iki input)
                       2026-06-01: alis_talebi (İhtiyaç Kaydı) icin varsayilan Gun=0 —
                       talep anlik bir is olusumudur, "kac gun gecerli" anlami yok.
                       Teklif (satis_teklifi / alis_teklifi) icin bos kalir, kullanici girer. *@
                    <div class="sqe-hrow">
                        <label class="sqe-hlabel">Gecerlilik Gun/Tarih</label>
                        <div class="sqe-hcombo">
                            <input id="sqValidDays" type="number" min="0" class="form-control form-control-sm sqe-hinput sqe-fp-days" placeholder="Gun" value="@(isPurchaseRequest ? "0" : "")" oninput="sqRecalcValidFromDays()" />
                            <input id="sqValidUntil" type="date" class="form-control form-control-sm sqe-hinput" oninput="sqRecalcDaysFromValid()" />
                        </div>
                    </div>
                }
                @* 2026-05-23: Satin Alma Talebi belge tipinde Para Birimi ve Cari Kod
                   gizlenir — talep iç hareket, fiyatlandırma teklifle gelir, tedarikçi
                   sipariş aşamasında belli olur. Diğer 4 belge tipinde her ikisi de görünür.
                   Inputlar DOM'da hala mevcut (hidden) — JS save akışı bos string gönderir,
                   backend default değerleri (CurrencyId=1, ContactId=NULL) uygular. *@
                <div class="sqe-hrow" style="@(isPurchaseRequest ? "display:none;" : "")">
                    <label class="sqe-hlabel">Para Birimi</label>
                    <!-- ID-bazli FK (CurrencyId): value=currencies.id, data-code attribute'unda
                         ISO kodu (TRY/USD/EUR) tasinir — event listener'lar code'u okur.
                         Options sayfa load'da /Finance/GetCurrenciesLookup'tan dinamik dolar. -->
                    <select id="sqCurrency" class="form-select form-select-sm sqe-hinput" style="max-width:90px;"
                            data-current-id="1"
                            onchange="(function(el){
                                try {
                                    var opt = el.options[el.selectedIndex];
                                    var code = (opt && opt.getAttribute('data-code')) || 'TRY';
                                    window.dispatchEvent(new CustomEvent('sq:currency', { detail: { id: parseInt(el.value) || 1, code: code } }));
                                } catch(e) {}
                            })(this)">
                        <option value="1" data-code="TRY">TRY</option>
                    </select>
                </div>
                <div class="sqe-hrow" style="@(isPurchaseRequest ? "display:none;" : "")">
                    @* 2026-05-23: Satin alma belgelerinde label "Tedarikci", satista "Cari Kod".
                       Element id'leri (sqCustomerDisplay/sqCustomerId) bilincli olarak ayni —
                       JS handler'lari ve save akisi degismez. *@
                    <label class="sqe-hlabel sqe-hlabel--link" title="@(isPurchase ? "Tedarikci karta gitmek icin cift tiklayin" : "Cari karta gitmek icin cift tiklayin")" ondblclick="sqGoToCustomerCard()">@(isPurchase ? "Tedarikçi" : "Cari Kod")</label>
                    <!-- Stok karti pattern: yazinca lookup; varsa otomatik dolar, yoksa yeni cari ekranina yonlendirir.
                         attachGuide rehber butonu hala calisir, ek olarak elle yazma destegi (readonly KALDIRILDI). -->
                    <input type="text" id="sqCustomerDisplay" class="form-control form-control-sm sqe-hinput"
                           placeholder="Kod yazin veya rehberden secin" autocomplete="off" />
                    <input type="hidden" id="sqCustomerId" />
                    <span id="sqCustomerName" class="sqe-hlabel-value sqe-customer-name" data-placeholder="Cari secildiginde otomatik dolar"></span>
                </div>
                @if (!isPurchaseRequest)
                {
                <div class="sqe-hrow">
                    <label class="sqe-hlabel">Temsilci</label>
                    <div class="sqe-rep-cb sqe-hinput" id="sqSalesRepWrapper">
                        <button type="button" class="sqe-rep-btn" id="sqSalesRepBtn" aria-haspopup="listbox" aria-expanded="false">
                            <span class="sqe-rep-label is-placeholder" id="sqSalesRepLabel">Seçiniz</span>
                            <svg class="sqe-rep-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>
                        <input type="hidden" id="sqSalesRepId" />
                        <div class="sqe-rep-panel" id="sqSalesRepPanel" hidden role="listbox">
                            <div class="sqe-rep-search-wrap" data-nodirty>
                                <svg class="sqe-rep-search-icon" viewBox="0 0 16 16" fill="none"><circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 10l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                                <input type="text" class="sqe-rep-filter" id="sqSalesRepFilter" placeholder="İsimde ara…" autocomplete="off" />
                            </div>
                            <div class="sqe-rep-list" id="sqSalesRepList"></div>
                        </div>
                    </div>
                </div>
                }
                @if (isPurchaseRequest)
                {
                    var personnels         = ViewData["RequesterPersonnels"] as System.Collections.IEnumerable;
                    var requesterLocked    = (bool)(ViewData["RequesterLocked"] ?? false);
                    var curPersonnelId     = ViewData["CurrentUserPersonnelId"] as int?;
                    var locationList       = ViewData["LocationList"] as System.Collections.IEnumerable;
                    var curLocationId      = ViewData["CurrentLocationId"] as int?;
                    <div class="sqe-hrow">
                        <label class="sqe-hlabel">Talep Eden</label>
                        <select id="sqRequesterId" class="form-select form-select-sm sqe-hinput"
                            @(requesterLocked ? "disabled" : "")>
                            <option value="">Seçiniz…</option>
                            @if (personnels != null)
                            {
                                foreach (dynamic p in personnels)
                                {
                                    <option value="@p.Id" data-dept="@p.Dept">@p.Name</option>
                                }
                            }
                        </select>
                        @if (requesterLocked && curPersonnelId == null)
                        {
                            <small class="text-warning ms-1" title="Hesabınıza bağlı personel kaydı bulunamadı.">⚠ Personel kaydı yok</small>
                        }
                    </div>
                    @if (curPersonnelId.HasValue)
                    {
                        <script>
                        (function(){
                            var sel = document.getElementById('sqRequesterId');
                            if (sel) { sel.value = '@curPersonnelId'; }
                        })();
                        </script>
                    }

                    <div class="sqe-hrow">
                        <label class="sqe-hlabel">Hedef Depo</label>
                        <select id="sqLocationId" class="form-select form-select-sm sqe-hinput" onchange="sqPropagateHeaderLocation()">
                            <option value="">Seçiniz…</option>
                            @if (locationList != null)
                            {
                                foreach (dynamic loc in locationList)
                                {
                                    <option value="@loc.Id">@loc.LocationName</option>
                                }
                            }
                        </select>
                    </div>
                    @if (curLocationId.HasValue)
                    {
                        <script>
                        (function(){
                            var sel = document.getElementById('sqLocationId');
                            if (sel) { sel.value = '@curLocationId'; }
                        })();
                        </script>
                    }
                }
            </div>
        </div>

        <!-- TAB 2: Kalem Bilgileri -->
        <div class="sqe-tab-pane" data-sqe-pane="lines">
            <div id="reactDocumentLineGrid" style="min-height:220px;"></div>
            @if (!isPurchaseRequest)
            {
            <div class="sqe-totals">
                <span class="sqe-total-label">Ara Toplam (Brut):</span>
                <span class="sqe-total-control"></span>
                <span class="sqe-total-value" id="sqSubTotal">0,00</span>

                <span class="sqe-total-label">Kalem Iskontosu:</span>
                <span class="sqe-total-control"></span>
                <span class="sqe-total-value" id="sqLineDiscountAmount">0,00</span>

                <span class="sqe-total-label">Genel Iskonto %</span>
                <input id="sqDiscountRate" type="number" class="sqe-total-input sq-no-spinner sq-no-negative" value="0" min="0" max="100" step="0.01"
                       oninput="(function(el){var v=parseFloat(el.value);if(isNaN(v))return;if(v<0)el.value=0;else if(v>100)el.value=100;sqRecalc();})(this)"
                       onchange="(function(el){var v=parseFloat(el.value);if(isNaN(v))el.value=0;else if(v<0)el.value=0;else if(v>100)el.value=100;sqRecalc();})(this)" />
                <span class="sqe-total-value" id="sqDiscountAmount">0,00</span>

                <!-- Dinamik KDV satirlari — sqRecalc tarafindan doldurulur -->
                <div id="sqKdvRows" class="sqe-kdv-rows"></div>

                <span class="sqe-total-label sqe-grand-total">Genel Toplam:</span>
                <span class="sqe-total-control"></span>
                <span class="sqe-total-value sqe-grand-total" id="sqGrandTotal">0,00</span>
            </div>
            }
        </div>

        <!-- TAB 3: Kosullar -->
        <div class="sqe-tab-pane" data-sqe-pane="conditions">
            <div class="sqe-form-grid">
                <div class="sqe-form-field sqe-form-field--full">
                    <label class="sqe-label">Odeme Kosulu</label>
                    <input id="sqPaymentTerms" class="form-control form-control-sm" placeholder="ornegin: 30 gun vadeli" />
                </div>
                <div class="sqe-form-field sqe-form-field--full">
                    <label class="sqe-label">Teslimat</label>
                    <input id="sqDeliveryTerms" class="form-control form-control-sm" placeholder="ornegin: Fabrika teslim" />
                </div>
                <div class="sqe-form-field sqe-form-field--full">
                    <label class="sqe-label">Teslimat Adresi</label>
                    <input id="sqDeliveryAddress" class="form-control form-control-sm" />
                </div>
            </div>
        </div>

        <!-- TAB 4: Notlar -->
        <div class="sqe-tab-pane" data-sqe-pane="notes">
            <textarea id="sqNotes" class="form-control sqe-notes-area" rows="6" placeholder="Teklif notlari..."></textarea>
        </div>

        <!-- TAB 5: Ek Alanlar -->
        <div class="sqe-tab-pane" data-sqe-pane="widgets">
            <!-- Not: eskiden sqWidgetSubTabs yatay pill'leri vardi; kullanici her grup
                 basligini zaten <summary> olarak bir kez gorunur istiyor — sub-tab
                 kaldirildi. Gruplar DynamicWidgetRenderer tarafindan dikey (alt alta)
                 basilir, her biri kendi section header'i ile (sqe-widget-wrap CSS). -->
            <div id="sqWidgetCardWrap" class="sqe-widget-wrap">
                <div id="sqDynamicWidgets"
                     data-form-code="@headerFormCode"
                     data-record-id="">
                </div>
            </div>
            <div id="sqWidgetEmpty" class="sqe-widget-empty is-hidden" data-sq-ext-v="2026-04-21-b">
                <div id="sqWidgetEmptyMsg">
                    <div>Widget API teshisi bekleniyor…</div>
                </div>
                <div style="margin-top:10px;">
                    <button type="button" id="sqWidgetReloadBtn" class="btn btn-sm"
                            style="font-size:0.72rem;padding:4px 10px;"
                            onclick="sqReloadWidgets()">Yeniden yukle</button>
                </div>
                <div style="margin-top:8px;font-size:0.64rem;opacity:0.35;font-family:monospace;">
                    ext-v: 2026-04-21-b
                </div>
            </div>
        </div>

        <!-- TAB 6: Ekli Dosyalar -->
        <div class="sqe-tab-pane" data-sqe-pane="attachments">
            <div class="sqe-att-wrap">
                <label class="sqe-att-drop" for="sqAttFile">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <span>Dosya yuklemek icin tiklayin veya surukleyip birakin</span>
                    <input type="file" id="sqAttFile" multiple style="display:none;" onchange="sqAttUpload(this.files)" />
                </label>
                <div id="sqAttList" class="sqe-att-list">
                    <div class="sqe-att-empty">Henuz ekli dosya yok.</div>
                </div>
            </div>
        </div>

        @if (Model.DocumentId.HasValue)
        {
            <div class="sqe-tab-pane" data-sqe-pane="workflow">
                <partial name="~/Views/Approval/_WorkflowPanel.cshtml" model="@Model.DocumentId.Value" />
            </div>
            <div class="sqe-tab-pane" data-sqe-pane="lineage">
                <div id="sqLineageHost" data-doc-id="@Model.DocumentId.Value">
                    <div class="dlg-empty">Yükleniyor…</div>
                </div>
            </div>
            <div class="sqe-tab-pane" data-sqe-pane="audittrail" style="padding:14px 6px;">
                @await Html.PartialAsync("_AuditTrailHost", new CalibraHub.Web.Models.Shared.AuditTrailHostModel {
                    Entity = Model.DocumentTypeCode ?? "belge",
                    RecordId = Model.DocumentId.Value.ToString(),
                    WidgetFormCode = CalibraHub.Web.Models.Sales.DocumentTypeFormMap.Resolve(Model.DocumentTypeCode).Header,
                    HostId = "sqAuditTrail",
                })
            </div>
        }

        </div><!-- /sqe-tab-content -->
    </div><!-- /sqe-body -->
</section>

@Html.AntiForgeryToken()

