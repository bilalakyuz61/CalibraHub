@section Scripts {
<script>
    /* Tarih inputlari global standarttan flatpickr olur (calibra-datepicker.js):
       TR locale + altInput d.m.Y + click-only open. Takvim secimi orijinal input'a
       'input' event'i yansitir — sqQuoteDate/sqValidUntil inline oninput recalc'lari
       (sqRecalcValidFromDays / sqRecalcDaysFromValid) ayni sekilde calisir. */

    /* sqSetDateValue: programatik deger atamada flatpickr-uyumlu helper.
       Flatpickr binding varsa setDate() kullanir; yoksa native value. */
    window.sqSetDateValue = function (id, isoValue) {
        var el = document.getElementById(id);
        if (!el) return;
        if (el._flatpickr) el._flatpickr.setDate(isoValue || null, false);
        else el.value = isoValue || '';
    };
</script>
<script>
    // ══════════════════════════════════════════════════════════════
    // CalibraLineItemsGrid inline config — server-side hazirlandi
    // (SalesController.BuildDocumentLineGridConfig). Kolonlar ve
    // meta bilgi tamamen C#'tan gelir — React bileseni hardcode yapmaz.
    // ══════════════════════════════════════════════════════════════
    window.__CALIBRA_SALES_QUOTE_LINE_GRID__ = @Html.Raw(Model.LineGridConfigJson);
    // 2026-06-01: Grid'in satir context menusunden Fiyat Geçmişi/Maliyet/Revize'yi
    // alis_talebi (İhtiyaç Kaydı) icin gizlemek uzere documentTypeCode'u config'e enjekte.
    try { window.__CALIBRA_SALES_QUOTE_LINE_GRID__.documentTypeCode = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DocumentTypeCode ?? "")); } catch (e) { }
    // 2026-06-02: Satir ek alanlari modal'i + schema fetch dogru form code'u
    // kullansin diye config'e enjekte. Onceden grid hardcoded SALES_QUOTE_LINES
    // kullaniyordu; alis_talebi'nde modal yanlis form widget'larini gosteriyor +
    // backend dogru formu kontrol edip eksik gorerek gear'i kirmizi tutuyordu.
    try { window.__CALIBRA_SALES_QUOTE_LINE_GRID__.lineFormCode = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LineFormCode ?? "SALES_QUOTE_LINES")); } catch (e) { }
    // Belge tipi server-side resolve — SaveDocument body'sine documentTypeId set etmek
    // ve UI label/davranis ayrimlari icin (teklif vs siparis).
    window.__CALIBRA_DOC_TYPE__ = {
        id: @(Model.DocumentTypeId?.ToString() ?? "null"),
        code: '@Model.DocumentTypeCode',
        isOrder: @(string.Equals(Model.DocumentTypeCode, "satis_siparisi", StringComparison.OrdinalIgnoreCase) ? "true" : "false")
    };
</script>
<script>
(function () {
    // ── Tab gecis ──────────────────────────────────────────
    /**
     * Cari bilgisi girilmemisse "Genel Bilgiler" disindaki sekmelere gecisi engelle.
     * Kaydedilmis belge (currentQuoteId) oldugunda mumkun — ama kayit sonrasi zaten
     * customerId dolu olur. Yeni teklifte bos birakilinca bloke eder.
     */
    function hasCustomer() {
        // Oncelik: numeric Id; Id bos ise AccountCode (display input) uzerinden kontrol et
        var idVal = document.getElementById('sqCustomerId');
        if (idVal && idVal.value && idVal.value.trim() !== '') return true;
        var disp = document.getElementById('sqCustomerDisplay');
        if (disp && disp.value && disp.value.trim() !== '') return true;
        return false;
    }

    function flashCustomerRequired() {
        var disp = document.getElementById('sqCustomerDisplay');
        if (!disp) return;
        // Kirmizi cerceve + shake animasyonu; kullanici input'a ilk karakter yazdiginda temizlenir
        disp.classList.add('is-invalid', 'sqe-flash');
        setTimeout(function() { disp.classList.remove('sqe-flash'); }, 600);
        var clearInvalid = function() {
            disp.classList.remove('is-invalid');
            disp.removeEventListener('input', clearInvalid);
            disp.removeEventListener('change', clearInvalid);
        };
        disp.addEventListener('input', clearInvalid);
        disp.addEventListener('change', clearInvalid);
        // Genel Bilgiler sekmesine don ve focus ver
        sqActivateTab('general');
        setTimeout(function() { disp.focus(); }, 50);
    }

    // Talep Eden zorunlu uyarisi — flashCustomerRequired pattern'i ile ayni:
    // kirmizi cerceve + shake animasyonu, kullanici seciminde temizlenir,
    // Genel Bilgiler sekmesi acilir, focus verilir.
    function flashRequesterRequired() {
        var sel = document.getElementById('sqRequesterId');
        if (!sel) return;
        sel.classList.add('is-invalid', 'sqe-flash');
        setTimeout(function() { sel.classList.remove('sqe-flash'); }, 600);
        var clearInvalid = function() {
            sel.classList.remove('is-invalid');
            sel.removeEventListener('change', clearInvalid);
        };
        sel.addEventListener('change', clearInvalid);
        sqActivateTab('general');
        setTimeout(function() { sel.focus(); }, 50);
    }

    function sqActivateTab(tabKey) {
        document.querySelectorAll('[data-sqe-tab-btn]').forEach(function(btn) {
            btn.classList.toggle('is-active', btn.getAttribute('data-sqe-tab-btn') === tabKey);
        });
        document.querySelectorAll('[data-sqe-pane]').forEach(function(pane) {
            pane.classList.toggle('is-active', pane.getAttribute('data-sqe-pane') === tabKey);
        });
        try { localStorage.setItem('sqe-active-tab', tabKey); } catch(e) {}
    }

    window.sqSwitchTab = function(tabKey) {
        sqActivateTab(tabKey);
        if (tabKey === 'attachments') sqAttLoad();
        if (tabKey === 'lineage') sqLineageLoad();
        // Notlar sekmesi ilk kez acildiginda textarea gizliyken scrollHeight=0
        // donduruluyor ve sqLoadQuote icindeki autoResizeTextarea cagirisi boyu
        // dogru hesaplayamiyor. Gorunur hale geldiginde yeniden boyutlandir.
        if (tabKey === 'notes') {
            var sqNotesEl3 = document.getElementById('sqNotes');
            if (sqNotesEl3) autoResizeTextarea(sqNotesEl3);
        }
        // Ek Alanlar sekmesi her aktiflendiginde probe'u tetikle — admin'de
        // tanim degisse bile (ya da ilk yuklemede race varsa) kullanici
        // dogru teshisi hemen gorur.
        if (tabKey === 'widgets' && typeof window.sqProbeWidgets === 'function') {
            window.sqProbeWidgets();
        }
    };

    // ── İlişkili Belgeler / Akış (belge soyağacı) ─────────────────────────────
    var _sqLineageLoaded = false;
    window.sqLineageLoad = function() {
        if (_sqLineageLoaded) return;
        var host = document.getElementById('sqLineageHost');
        if (!host) return;
        var docId = host.getAttribute('data-doc-id');
        if (!docId) return;
        _sqLineageLoaded = true;
        host.innerHTML = '<div class="dlg-empty">Yükleniyor…</div>';
        fetch('/Document/Lineage?id=' + encodeURIComponent(docId), { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) { sqRenderLineage(host, data); })
            .catch(function() { host.innerHTML = '<div class="dlg-empty">İlişkili belgeler yüklenemedi.</div>'; });
    };

    function sqLinEsc(s) { return String(s == null ? '' : s).replace(/[&<>"]/g, function(c) { return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]; }); }

    function sqLinStatus(st) {
        switch (st) {
            case 'Approved':  return { label: 'Onaylandı',     cls: 'dlg-st--ok'    };
            case 'Rejected':  return { label: 'Reddedildi',    cls: 'dlg-st--rej'   };
            case 'Sent':      return { label: 'Onayda',        cls: 'dlg-st--pend'  };
            case 'Cancelled': return { label: 'İptal',         cls: 'dlg-st--mut'   };
            case 'Closed':    return { label: 'Kapalı',        cls: 'dlg-st--mut'   };
            case 'Converted': return { label: 'Dönüştürüldü',  cls: 'dlg-st--mut'   };
            case 'Deleted':   return { label: 'Silinmiş',      cls: 'dlg-st--rej'   };
            default:          return { label: st || 'Taslak',  cls: 'dlg-st--draft' };
        }
    }

    function sqRenderLineage(host, data) {
        var nodes = (data && data.nodes) || [];
        if (nodes.length <= 1) {
            host.innerHTML = '<div class="dlg-empty">Bu belgeyle ilişkili başka belge yok.</div>';
            return;
        }
        var byDepth = {};
        nodes.forEach(function(n) { (byDepth[n.depth] = byDepth[n.depth] || []).push(n); });
        var depths = Object.keys(byDepth).map(Number).sort(function(a, b) { return a - b; });
        var html = '<div class="dlg-hint">Seçili belgenin öncesindeki (kaynak) ve sonrasındaki (türeyen) belgeler. Yetkiniz olan belgeye tıklayınca yeni sekmede açılır.</div>';
        html += '<div class="dlg-flow">';
        depths.forEach(function(dep, i) {
            if (i > 0) html += '<div class="dlg-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></div>';
            html += '<div class="dlg-col">';
            var label = dep < 0 ? 'Önceki' : dep > 0 ? 'Sonraki' : 'Bu Belge';
            html += '<div class="dlg-col-lbl">' + label + '</div>';
            byDepth[dep].forEach(function(n) {
                var si = sqLinStatus(n.status);
                var clickable = n.canView && n.url && !n.isRoot;
                var d = n.date ? new Date(n.date).toLocaleDateString('tr-TR') : '';
                html += '<div class="dlg-card' + (n.isRoot ? ' dlg-card--root' : '') + (clickable ? ' dlg-card--link' : '') + (!n.canView ? ' dlg-card--noauth' : '') + '"'
                    + (clickable ? ' data-url="' + sqLinEsc(n.url) + '" data-title="' + sqLinEsc(n.typeName + ' ' + n.documentNumber) + '"' : '')
                    + (!n.canView ? ' title="Bu belgeyi görüntüleme yetkiniz yok"' : '') + '>'
                    + '<div class="dlg-card-type">' + sqLinEsc(n.typeName) + '</div>'
                    + '<div class="dlg-card-no">' + sqLinEsc(n.documentNumber || '—') + (!n.canView ? ' <span class="dlg-lock">🔒</span>' : '') + '</div>'
                    + '<div class="dlg-card-meta"><span class="dlg-st ' + si.cls + '">' + sqLinEsc(si.label) + '</span>' + (d ? '<span class="dlg-card-date">' + d + '</span>' : '') + '</div>'
                    + '</div>';
            });
            html += '</div>';
        });
        html += '</div>';
        host.innerHTML = html;
        host.querySelectorAll('.dlg-card--link').forEach(function(card) {
            card.addEventListener('click', function() {
                var url = card.getAttribute('data-url');
                var title = card.getAttribute('data-title');
                if (!url) return;
                if (window.calibraOpenWorkspaceTab) window.calibraOpenWorkspaceTab(url, title);
                else window.location.href = url;
            });
        });
    }

    // ── Ekli Dosyalar yonetimi ──
    function sqFormatBytes(n) {
        if (!n || n < 0) return '0 B';
        var k = 1024, u = ['B','KB','MB','GB'];
        var i = Math.min(Math.floor(Math.log(n)/Math.log(k)), u.length - 1);
        return (n/Math.pow(k,i)).toFixed(i === 0 ? 0 : 1) + ' ' + u[i];
    }

    // fetch + Blob URL ile indir — anchor navigasyon olmaz (iframe/workspace uyumlu)
    window.sqAttDownload = function(id) {
        fetch('/Sales/DownloadDocumentAttachment?id=' + id, { credentials: 'same-origin' })
            .then(function(r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                var disp = r.headers.get('content-disposition') || '';
                var star  = disp.match(/filename\*=UTF-8''([^;\s\r\n]+)/i);
                var plain = disp.match(/filename="([^"]+)"/i);
                var name  = star ? decodeURIComponent(star[1]) : (plain ? plain[1] : 'dosya');
                return r.blob().then(function(b) { return { blob: b, name: name }; });
            })
            .then(function(d) {
                var url = URL.createObjectURL(d.blob);
                var el = document.createElement('a');
                el.href = url; el.download = d.name; el.style.display = 'none';
                document.body.appendChild(el); el.click();
                setTimeout(function() { URL.revokeObjectURL(url); el.remove(); }, 100);
            })
            .catch(function(e) {
                if (window.CalibraAlert) CalibraAlert.error('İndirme hatası: ' + (e.message || e));
            });
    };

    async function sqAttLoad() {
