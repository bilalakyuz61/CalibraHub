    async function sqAttUpload(files) {
        if (!currentQuoteId) {
            CalibraAlert.warning('Dosya eklemek icin once teklifi kaydedin.');
            document.getElementById('sqAttFile').value = '';
            return;
        }
        if (!files || files.length === 0) return;
        var fd = new FormData();
        fd.append('documentId', currentQuoteId);
        for (var i = 0; i < files.length; i++) fd.append('files', files[i]);
        var csrfEl = document.querySelector('input[name="__RequestVerificationToken"]');
        if (csrfEl) fd.append('__RequestVerificationToken', csrfEl.value);
        try {
            var resp = await fetch('/Sales/UploadDocumentAttachment', { method: 'POST', body: fd });
            if (!resp.ok) throw new Error('HTTP ' + resp.status);
        } catch (e) {
            CalibraAlert.error('Yukleme hatasi: ' + (e.message||e));
        } finally {
            document.getElementById('sqAttFile').value = '';
            sqAttLoad();
        }
    }
