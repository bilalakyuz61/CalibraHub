    /**
     * Gecerlilik sure (gun) <-> tarih senkronu.
     * Tarih veya gun degistiginde otomatik gecerlilik tarihi hesaplar.
     */
    function sqRecalcValidFromDays() {
        var dateEl = document.getElementById('sqQuoteDate');
        var daysEl = document.getElementById('sqValidDays');
        var validEl = document.getElementById('sqValidUntil');
        if (!dateEl || !daysEl || !validEl) return;
        var dateStr = dateEl.value;
        var daysVal = daysEl.value;
        if (!dateStr || daysVal === '' || daysVal == null) return;
        var days = parseInt(daysVal, 10);
        if (isNaN(days) || days < 0) return;
        var d = new Date(dateStr + 'T00:00:00');
        if (isNaN(d.getTime())) return;
        d.setDate(d.getDate() + days);
        var yyyy = d.getFullYear();
        var mm = String(d.getMonth() + 1).padStart(2, '0');
        var dd = String(d.getDate()).padStart(2, '0');
        var newVal = yyyy + '-' + mm + '-' + dd;
        if (validEl._flatpickr) validEl._flatpickr.setDate(newVal, false);
        else validEl.value = newVal;
    }

    function sqRecalcDaysFromValid() {
        var dateEl = document.getElementById('sqQuoteDate');
        var validEl = document.getElementById('sqValidUntil');
        var daysEl = document.getElementById('sqValidDays');
        if (!dateEl || !daysEl || !validEl) return;
        var dateStr = dateEl.value;
        var validStr = validEl.value;
        if (!dateStr || !validStr) { daysEl.value = ''; return; }
        var d1 = new Date(dateStr + 'T00:00:00');
        var d2 = new Date(validStr + 'T00:00:00');
        if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return;
        var diffMs = d2.getTime() - d1.getTime();
        var days = Math.round(diffMs / (1000 * 60 * 60 * 24));
        daysEl.value = days >= 0 ? days : 0;
    }
    /* Inline oninput="..." attribute'larinin global scope'ta gormesi icin window'a bagla */
    window.sqRecalcValidFromDays = sqRecalcValidFromDays;
    window.sqRecalcDaysFromValid = sqRecalcDaysFromValid;

