@section Scripts {
<script>
    // ══════════════════════════════════════════════════════════════
    // CalibraLineItemsGrid inline config — server-side hazirlandi
    // (SalesController.BuildDocumentLineGridConfig). Kolonlar ve
    // meta bilgi tamamen C#'tan gelir — React bileseni hardcode yapmaz.
    // ══════════════════════════════════════════════════════════════
    window.__CALIBRA_SALES_QUOTE_LINE_GRID__ = @Html.Raw(Model.LineGridConfigJson);
</script>
<script>
(function () {
    // ── Tab gecis ──────────────────────────────────────────
    /**
     * Cari bilgisi girilmemisse "Genel Bilgiler" disindaki sekmelere gecisi engelle.
     * Kaydedilmis belge (currentQuoteId) oldugunda mumkun — ama kayit sonrasi zaten
     * customerId dolu olur. Yeni teklifte bos birakilinca bloke eder.
     */
    function hasCustomer() {
        // Oncelik: numeric Id; Id bos ise AccountCode (display input) uzerinden kontrol et
        var idVal = document.getElementById('sqCustomerId');
        if (idVal && idVal.value && idVal.value.trim() !== '') return true;
        var disp = document.getElementById('sqCustomerDisplay');
        if (disp && disp.value && disp.value.trim() !== '') return true;
        return false;
    }

    function flashCustomerRequired() {
        var disp = document.getElementById('sqCustomerDisplay');
        if (!disp) return;
        // Kirmizi cerceve + shake animasyonu; kullanici input'a ilk karakter yazdiginda temizlenir
        disp.classList.add('is-invalid', 'sqe-flash');
        setTimeout(function() { disp.classList.remove('sqe-flash'); }, 600);
        var clearInvalid = function() {
            disp.classList.remove('is-invalid');
            disp.removeEventListener('input', clearInvalid);
            disp.removeEventListener('change', clearInvalid);
        };
        disp.addEventListener('input', clearInvalid);
        disp.addEventListener('change', clearInvalid);
        // Genel Bilgiler sekmesine don ve focus ver
        sqActivateTab('general');
        setTimeout(function() { disp.focus(); }, 50);
    }

    function sqActivateTab(tabKey) {
        document.querySelectorAll('[data-sqe-tab-btn]').forEach(function(btn) {
            btn.classList.toggle('is-active', btn.getAttribute('data-sqe-tab-btn') === tabKey);
        });
        document.querySelectorAll('[data-sqe-pane]').forEach(function(pane) {
            pane.classList.toggle('is-active', pane.getAttribute('data-sqe-pane') === tabKey);
        });
        try { localStorage.setItem('sqe-active-tab', tabKey); } catch(e) {}
    }

    window.sqSwitchTab = function(tabKey) {
        // Genel Bilgiler disinda bir sekmeye gecilecekse musteri zorunlu
        if (tabKey !== 'general' && !hasCustomer()) {
            flashCustomerRequired();
            return;
        }
        sqActivateTab(tabKey);
        if (tabKey === 'attachments') sqAttLoad();
        // Notlar sekmesi ilk kez acildiginda textarea gizliyken scrollHeight=0
        // donduruluyor ve sqLoadQuote icindeki autoResizeTextarea cagirisi boyu
        // dogru hesaplayamiyor. Gorunur hale geldiginde yeniden boyutlandir.
        if (tabKey === 'notes') {
            var sqNotesEl3 = document.getElementById('sqNotes');
            if (sqNotesEl3) autoResizeTextarea(sqNotesEl3);
        }
        // Ek Alanlar sekmesi her aktiflendiginde probe'u tetikle — admin'de
        // tanim degisse bile (ya da ilk yuklemede race varsa) kullanici
        // dogru teshisi hemen gorur.
        if (tabKey === 'widgets' && typeof window.sqProbeWidgets === 'function') {
            window.sqProbeWidgets();
        }
    };

    // ── Ekli Dosyalar yonetimi ──
    function sqFormatBytes(n) {
        if (!n || n < 0) return '0 B';
        var k = 1024, u = ['B','KB','MB','GB'];
        var i = Math.min(Math.floor(Math.log(n)/Math.log(k)), u.length - 1);
        return (n/Math.pow(k,i)).toFixed(i === 0 ? 0 : 1) + ' ' + u[i];
    }

    async function sqAttLoad() {
        var listEl = document.getElementById('sqAttList');
        if (!listEl) return;
        if (!currentQuoteId) {
            listEl.innerHTML = '<div class="sqe-att-empty">Ekleme yapmak icin once teklifi kaydedin.</div>';
            return;
        }
        listEl.innerHTML = '<div class="sqe-att-empty">Yukleniyor...</div>';
        try {
            var resp = await fetch('/Sales/GetQuoteAttachments?quoteId=' + encodeURIComponent(currentQuoteId));
            if (!resp.ok) throw new Error('HTTP ' + resp.status);
            var data = await resp.json();
            sqAttRender(data || []);
        } catch (e) {
            listEl.innerHTML = '<div class="sqe-att-empty">Liste yuklenemedi: ' + (e.message||e) + '</div>';
        }
    }

    function sqAttRender(items) {
        var listEl = document.getElementById('sqAttList');
        if (!listEl) return;
        if (!items || items.length === 0) {
            listEl.innerHTML = '<div class="sqe-att-empty">Henuz ekli dosya yok.</div>';
            return;
        }
        listEl.innerHTML = items.map(function(a) {
            return '<div class="sqe-att-item">' +
                '<span class="sqe-att-item__name" title="' + a.fileName.replace(/"/g,'&quot;') + '">' + a.fileName + '</span>' +
                '<span class="sqe-att-item__meta">' + sqFormatBytes(a.fileSize) + '</span>' +
                '<a class="sqe-att-item__btn" href="/Sales/DownloadQuoteAttachment?id=' + a.id + '" target="_blank" rel="noopener">Indir</a>' +
                '<button type="button" class="sqe-att-item__btn is-danger" onclick="sqAttDelete(\'' + a.id + '\')">Sil</button>' +
                '</div>';
        }).join('');
    }

    async function sqAttUpload(files) {
        if (!currentQuoteId) {
            CalibraAlert.warning('Dosya eklemek icin once teklifi kaydedin.');
            document.getElementById('sqAttFile').value = '';
            return;
        }
        if (!files || files.length === 0) return;
        var fd = new FormData();
        fd.append('quoteId', currentQuoteId);
        for (var i = 0; i < files.length; i++) fd.append('files', files[i]);
        try {
            var resp = await fetch('/Sales/UploadQuoteAttachment', { method: 'POST', body: fd });
            if (!resp.ok) throw new Error('HTTP ' + resp.status);
        } catch (e) {
            CalibraAlert.error('Yukleme hatasi: ' + (e.message||e));
        } finally {
            document.getElementById('sqAttFile').value = '';
            sqAttLoad();
        }
    }
    window.sqAttUpload = sqAttUpload;

    window.sqAttDelete = async function(id) {
        if (!confirm('Dosya silinecek. Emin misiniz?')) return;
        try {
            await fetch('/Sales/DeleteQuoteAttachment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id })
            });
        } catch (e) { CalibraAlert.error('Silme hatasi: ' + (e.message||e)); }
        sqAttLoad();
    };
    // Her zaman Genel Bilgiler tab'indan basla
    sqSwitchTab('general');

    var searchTimer = null;
    var currentQuoteId = @Html.Raw(editId.HasValue ? $"'{editId.Value}'" : "null");
    var materials = [];
    var customers = [];

    // ── React CalibraLineItemsGrid bridge ─────────────────────────
    // Grid satirlari window.__SQ_LINES__ uzerinde tutulur; sqRecalc ve
    // sqSave bunu okur. Grid mount'tan once gelen setRows istekleri
    // kuyruga alinir, grid hazir olunca flush edilir.
    window.__SQ_LINES__ = [];
    var _gridReady = false;
    var _pendingRows = null;

    function setGridRows(rows) {
        if (_gridReady && window.CalibraHub && window.CalibraHub.salesLineGrid) {
            window.CalibraHub.salesLineGrid.setRows(rows || []);
        } else {
            _pendingRows = rows || [];
        }
    }

    function bootstrapLineGrid() {
        var BUNDLE_URL = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
        var CSS_URL = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';

        function mountGrid() {
            var el = document.getElementById('reactDocumentLineGrid');
            if (!el) { console.error('[SQE] grid mount element yok'); return; }
            if (!window.CalibraHub || !window.CalibraHub.mountLineItemsGrid) {
                console.error('[SQE] mountLineItemsGrid fonksiyonu yok');
                return;
            }
            try {
                window.CalibraHub.mountLineItemsGrid(el, window.__CALIBRA_SALES_QUOTE_LINE_GRID__, {
                    onRowsChange: function (rows) {
                        window.__SQ_LINES__ = rows || [];
                        if (typeof window.sqRecalc === 'function') window.sqRecalc();
                        // Anlamli kalem (materialCode dolu) varsa cari kilitlenir
                        if (typeof window.applyCustomerLock === 'function') {
                            var hasLine = (rows || []).some(function (r) {
                                return r && r.materialCode && String(r.materialCode).trim() !== '';
                            });
                            window.applyCustomerLock(hasLine);
                        }
                    }
                });
                // Imperative API (setRows/getRows) useEffect sonrasi hazir —
                // polling ile bekle
                var tries = 0;
                var timer = setInterval(function () {
                    if (window.CalibraHub && window.CalibraHub.salesLineGrid) {
                        clearInterval(timer);
                        _gridReady = true;
                        if (_pendingRows) {
                            window.CalibraHub.salesLineGrid.setRows(_pendingRows);
                            _pendingRows = null;
                        }
                        console.log('[SQE] line grid hazir');
                    } else if (++tries > 50) {
                        clearInterval(timer);
                        console.error('[SQE] grid API zaman asimi');
                    }
                }, 20);
            } catch (ex) {
                console.error('[SQE] grid mount exception:', ex);
            }
        }

        // CSS
        if (!document.querySelector('link[data-sqe-grid-css]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet';
            link.href = CSS_URL;
            link.setAttribute('data-sqe-grid-css', '1');
            document.head.appendChild(link);
        }

        // JS bundle
        if (window.CalibraHub && window.CalibraHub.mountLineItemsGrid) {
            mountGrid();
        } else {
            var script = document.createElement('script');
            script.src = BUNDLE_URL;
            script.setAttribute('data-sqe-grid-js', '1');
            script.onload = function () { setTimeout(mountGrid, 0); };
            script.onerror = function () { console.error('[SQE] bundle yuklenemedi'); };
            document.head.appendChild(script);
        }
    }

    // ── Katlanir kart state persist (localStorage) ─────────────
    // 4 kartin (genel / lines / conditions / notes) acik/kapali durumu
    // localStorage'da tutulur. Kullanici tercih ettigi sekli koruyor.
    function initCollapsiblePersistence() {
        var LS_KEY = 'sqe.card-groups-open';
        var state = {};
        try { state = JSON.parse(localStorage.getItem(LS_KEY) || '{}') || {}; }
        catch (e) { state = {}; }

        document.querySelectorAll('details.sqe-card[data-sqe-group]').forEach(function (d) {
            var key = d.getAttribute('data-sqe-group');
            if (!key) return;
            // Kayitli durum false ise kapat (default: acik)
            if (state[key] === false) d.open = false;
            d.addEventListener('toggle', function () {
                state[key] = d.open;
                try { localStorage.setItem(LS_KEY, JSON.stringify(state)); }
                catch (e) { /* quota/private — sessiz gec */ }
            });
        });
    }

    // Textarea'yi icerigi kadar buyutir — ic scroll olmaz, sayfa scroll'u calisir
    function autoResizeTextarea(el) {
        el.style.height = 'auto';
        el.style.height = el.scrollHeight + 'px';
    }

    document.addEventListener('DOMContentLoaded', function () {
        // React grid'i non-blocking olarak mount et (bundle async yuklenir)
        bootstrapLineGrid();

        // Notlar textarea auto-resize
        var sqNotesEl = document.getElementById('sqNotes');
        if (sqNotesEl) {
            sqNotesEl.addEventListener('input', function () { autoResizeTextarea(sqNotesEl); });
        }

        // Sekmeler arasi veri senkronizasyonu:
        // Baska bir sekmede (ornek malzeme karti) stok/birim/KDV degisirse,
        // bu sayfaya geri donuldugunde cache'lenmis materials ve units snapshot'lari
        // stale olabilir. Focus/visibility alindiginda cache'leri invalide et.
        function sqRefreshLookupCaches() {
            try {
                if (window.CalibraHub && window.CalibraHub.clearLookupCache) {
                    window.CalibraHub.clearLookupCache();
                }
            } catch (e) { /* sessizce gec */ }
            // Materyal snapshot'ini yeniden fetch et (bridge fallback'leri icin)
            loadMaterials().catch(function (e) { console.warn('[SQ] materials refresh hatasi:', e); });
        }
        window.addEventListener('focus', sqRefreshLookupCaches);
        document.addEventListener('visibilitychange', function () {
            if (document.visibilityState === 'visible') sqRefreshLookupCaches();
        });

        // Sayisal input'lari koru: eksi girisi engelle + spinner'lar CSS ile gizli.
        // Capturing phase — React'in kendi handler'lari calismadan once devreye girer.
        document.addEventListener('input', function (e) {
            var t = e.target;
            if (t && t.tagName === 'INPUT' && t.type === 'number') {
                if (parseFloat(t.value) < 0) t.value = '0';
            }
        }, true);
        document.addEventListener('keydown', function (e) {
            var t = e.target;
            if (t && t.tagName === 'INPUT' && t.type === 'number' && (e.key === '-' || e.key === 'Subtract')) {
                e.preventDefault();
            }
        }, true);

        // Katlanir kart persist — markup hazir oldugunda baglan
        initCollapsiblePersistence();

        // Veri yukleme — uc baslangic fetch'i birbirinden bagimsiz, paralel cek.
        // loadCustomers rehber React bundle'ini beklemeyi icerir (attach ile birlikte).
        // Tum ustu tamamlandiktan sonra sqLoadQuote alanlari tek seferde doldurur ve
        // maske kalkar. Bu sayede kullanici field'lari "sonradan dolma" gormez.
        (async function () {
            try {
                await Promise.all([
                    loadCustomers().catch(function(e) { console.error('loadCustomers hatasi:', e); }),
                    loadSalesReps().catch(function(e) { console.error('loadSalesReps hatasi:', e); }),
                    loadMaterials().catch(function(e) { console.error('loadMaterials hatasi:', e); }),
                ]);
            } catch (e) { console.error('Paralel yukleme hatasi:', e); }

            if (currentQuoteId) {
                try { await sqLoadQuote(currentQuoteId); }
                catch (e) { console.error('sqLoadQuote hatasi:', e); }
            } else {
                sqInitNew();
            }

            // Son bir rAF — React wrapper/layout shift'leri bu frame'de settle eder,
            // maske bir sonraki frame'de kalktiginda tum alanlar zaten tam ayarlanmistir.
            requestAnimationFrame(function () {
                var mask = document.getElementById('sqLoadingMask');
                if (mask) mask.classList.add('is-hidden');
            });
        })();
    });

    window.sqGoToCustomerCard = function () {
        var custId = document.getElementById('sqCustomerId').value
        if (!custId) return
        window.location.href = '/Finance/ContactEdit?id=' + custId
    }

    function attachCustomerGuide() {
        if (window.CalibraHub && window.CalibraHub.attachGuide) {
            window.CalibraHub.attachGuide('#sqCustomerDisplay', 'CUSTOMERS', {
                formCode: 'SALES_QUOTE_EDIT',
                fillMap: { '#sqCustomerId': 'Id', '#sqCustomerName': 'AccountTitle' }
            });
            return true;
        }
        return false;
    }

    async function loadCustomers() {
        // 1) window.CalibraHub.attachGuide hazir olana kadar bekle — bundle async.
        // 2) attachGuide cagirildiktan sonra React kendi wrapper'ini ASENKRON render eder.
        //    Wrapper DOM'a eklenip icinde cocuklar olusana kadar bekleyip Promise'i
        //    oyle resolve ederiz; boylece sqLoadQuote degerleri yazdiginda React
        //    bileseninin useEffect'i zaten mount olmus ve data-display kontrolunu
        //    yapar → "sonradan dolma" hissi olusmaz.
        return new Promise(function (resolve) {
            function whenGuideAttached(cb) {
                if (attachCustomerGuide()) { cb(); return; }
                var attempts = 0;
                var t = setInterval(function () {
                    if (attachCustomerGuide()) { clearInterval(t); cb(); return; }
                    if (++attempts > 60) { clearInterval(t); cb(); } // ~6s sonra vazgec
                }, 100);
            }
            function whenWrapperReady(cb) {
                var attempts = 0;
                var tries = setInterval(function () {
                    var disp = document.getElementById('sqCustomerDisplay');
                    var wrap = disp && disp.parentNode
                        ? disp.parentNode.querySelector('.ffl-wrapper') : null;
                    // React render tamamlandiginda wrapper'da en az bir child (buton/SVG) olur
                    if (wrap && wrap.children.length > 0) { clearInterval(tries); cb(); return; }
                    if (++attempts > 30) { clearInterval(tries); cb(); } // ~3s
                }, 100);
            }
            whenGuideAttached(function () { whenWrapperReady(resolve); });
        });
    }

    async function loadSalesReps() {
        var resp = await fetch('/GeneralDefinitions/GetSalesReps');
        if (!resp.ok) throw new Error('GetSalesReps HTTP ' + resp.status);
        var reps = await resp.json();
        var sel = document.getElementById('sqSalesRepId');
        sel.innerHTML = '<option value="">Seciniz</option>';
        reps.forEach(function (r) {
            if (r.isActive) sel.innerHTML += '<option value="' + r.id + '">' + r.repCode + ' - ' + r.repName + '</option>';
        });
    }

    async function loadMaterials() {
        var resp = await fetch('/Sales/GetMaterials');
        if (!resp.ok) throw new Error('GetMaterials HTTP ' + resp.status);
        materials = await resp.json();
        // React CombinationLookupCell icin fallback snapshot — row.trackCombinations
        // lookupFillMap ile gelmezse bu global'den materialCode ile cozuluyor.
        window.__SQ_MATERIALS__ = materials;
    }

    /**
     * Kalemi olan belgenin cari kodu degistirilemez.
     * Kullanici Gridde bir satir ekledigi anda (materialCode girildiginde)
     * tetiklenir. Cari kod input'u + rehber butonu pasiflesir.
     */
    window.applyCustomerLock = function(lock) {
        var disp = document.getElementById('sqCustomerDisplay');
        if (!disp) return;
        var wrapper = disp.parentNode; // ffl-wrapper host
        if (lock) {
            disp.setAttribute('readonly', 'readonly');
            disp.classList.add('is-locked');
            disp.title = 'Kalem girilmis belgenin cari kodu degistirilemez.';
            // Yan sibling olarak React'in enjekte ettigi wrapper'i pasiflestir
            var fflWrap = wrapper && wrapper.querySelector ? wrapper.querySelector('.ffl-wrapper') : null;
            if (fflWrap) fflWrap.style.pointerEvents = 'none';
            if (fflWrap) fflWrap.style.opacity = '0.45';
        } else {
            disp.removeAttribute('readonly');
            disp.classList.remove('is-locked');
            disp.title = '';
            var fflWrap2 = wrapper && wrapper.querySelector ? wrapper.querySelector('.ffl-wrapper') : null;
            if (fflWrap2) fflWrap2.style.pointerEvents = '';
            if (fflWrap2) fflWrap2.style.opacity = '';
        }
    };

    async function sqInitNew() {
        window.applyCustomerLock(false);
        document.getElementById('sqQuoteDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('sqValidUntil').value = '';
        document.getElementById('sqCustomerId').value = '';
        document.getElementById('sqCustomerDisplay').value = '';
        document.getElementById('sqCustomerDisplay').removeAttribute('data-value');
        document.getElementById('sqCustomerDisplay').removeAttribute('data-display');
        document.getElementById('sqCustomerName').textContent = '';
        document.getElementById('sqSalesRepId').value = '';
        document.getElementById('sqCurrency').value = 'TRY';
        document.getElementById('sqDiscountRate').value = '0';
        document.getElementById('sqPaymentTerms').value = '';
        document.getElementById('sqDeliveryTerms').value = '';
        document.getElementById('sqDeliveryAddress').value = '';
        document.getElementById('sqNotes').value = '';
        // Yeni teklifte kullaniciya "+ Yeni Kalem" butonuna tiklamadan
        // dogrudan yazabilmesi icin 1 bos satir seeding yapariz.
        setGridRows([{
            materialCode: '',
            materialName: '',
            unitId: null,
            quantity: 1,
            unitPrice: 0,
            discountRate: 0,
            locationId: null,
            notes: null,
        }]);
        document.getElementById('sqBtnDelete').disabled = true;
        document.getElementById('sqStatusSelect').style.display = 'none';
        document.getElementById('sqStatusBadge').innerHTML = '';
        sqRecalc();
        document.getElementById('sqQuoteNumber').value = '';
    }

    async function sqLoadQuote(id) {
        try {
            var resp = await fetch('/Sales/GetQuote?id=' + id);
            if (!resp.ok) throw new Error('GetQuote HTTP ' + resp.status + ' — id: ' + id);
            var data = await resp.json();
            if (!data || !data.quote) throw new Error('GetQuote bos veya gecersiz yanit dondu.');
            var q = data.quote;
            currentQuoteId = q.id;
            document.getElementById('sqQuoteNumber').value = q.documentNumber || '';
            var docDate = q.documentDate || q.quoteDate;
            document.getElementById('sqQuoteDate').value = docDate ? docDate.split('T')[0] : '';
            document.getElementById('sqValidUntil').value = q.validUntil ? q.validUntil.split('T')[0] : '';
            document.getElementById('sqCustomerId').value = q.contactId != null ? q.contactId : '';
            // Rehber display alanını doldur — Cari Kod + Cari İsim
            var custDisp = document.getElementById('sqCustomerDisplay');
            // Cari Kod alani yalnizca AccountCode'u gosterir; isim ayri alanda
            custDisp.value = q.contactCode || '';
            custDisp.setAttribute('data-value', q.contactCode || '');
            custDisp.setAttribute('data-display', q.contactCode || '');
            document.getElementById('sqCustomerName').textContent = q.contactName || '';
            document.getElementById('sqSalesRepId').value = q.salesRepId != null ? q.salesRepId : '';
            document.getElementById('sqCurrency').value = q.currency || 'TRY';
            document.getElementById('sqDiscountRate').value = q.discountRate ?? 0;
            document.getElementById('sqPaymentTerms').value = q.paymentTerms || '';
            document.getElementById('sqDeliveryTerms').value = q.deliveryTerms || '';
            document.getElementById('sqDeliveryAddress').value = q.deliveryAddress || '';
            var sqNotesEl2 = document.getElementById('sqNotes');
            sqNotesEl2.value = q.notes || '';
            autoResizeTextarea(sqNotesEl2);
            document.getElementById('sqBtnDelete').disabled = false;
            document.getElementById('sqStatusSelect').style.display = '';
            document.getElementById('sqStatusSelect').value = q.status;
            document.getElementById('sqStatusBadge').innerHTML = '<span class="sqe-status-badge sqe-status-' + q.status + '">' + statusLabel(q.status) + '</span>';

            var custName = q.contactName || '';
            var tabTitle = q.documentNumber || 'Teklif';
            document.title = tabTitle + (custName ? ' - ' + custName : '') + ' - CalibraHub';

            // Header kartinda baslik + subtitle'i guncelle (MaterialCardEdit pattern'i)
            var sqMetaEl = document.getElementById('sqMeta');
            if (sqMetaEl) sqMetaEl.innerHTML = '<strong>' + tabTitle + '</strong>' + (custName ? ' — ' + custName : '');
            var wsTab = document.querySelector('[data-workspace-title]');
            if (wsTab) wsTab.setAttribute('data-workspace-title', tabTitle + (custName ? ' — ' + custName : ''));
            try {
                var activeTab = parent.document.querySelector('.workspace-tabs__scroller .workspace-tab.is-active .workspace-tab__label');
                if (activeTab) activeTab.textContent = tabTitle;
                var activeTabEl = parent.document.querySelector('.workspace-tabs__scroller .workspace-tab.is-active');
                if (activeTabEl) activeTabEl.title = tabTitle + (custName ? ' — ' + custName : '');
            } catch(e) {}

            // React grid'e initial satirlari ver (bridge kuyruklar eger hazir degilse).
            // ln.itemId DB source-of-truth; materialCode/materialName/combinationCode ise server
            // JOIN ile Item + ProductConfiguration'dan turetilen display degerler. Grid row
            // stockCardId alani icin itemId'yi kullanir (legacy alias).
            var initialLines = (data.lines || []).map(function (ln) {
                var m = (materials || []).find(function (x) { return x.id === ln.itemId });
                return Object.assign({}, ln, {
                    stockCardId:       ln.itemId,
                    trackCombinations: m ? m.trackCombinations === true : false,
                    taxRate:           ln.taxRate != null ? ln.taxRate : (m && m.taxRate != null ? m.taxRate : 20),
                });
            });
            setGridRows(initialLines);
            sqRecalc();

            // Kalemi olan belgelerde cari kodu degistirilemez
            window.applyCustomerLock(initialLines.length > 0);

            // Satirlardaki eksik zorunlu widget bilgisi (⚙ rengi icin)
            var initialInvalid = Array.isArray(data.invalidLineIds) ? data.invalidLineIds : [];
            // Grid hazir olana kadar kucuk bir delay — setRows sonrasi state'i bas.
            setTimeout(function () {
                if (window.CalibraHub && window.CalibraHub.salesLineGrid
                    && typeof window.CalibraHub.salesLineGrid.setInvalidLines === 'function') {
                    window.CalibraHub.salesLineGrid.setInvalidLines(initialInvalid);
                }
            }, 80);

            // Ek alanlar renderer'ina integer Id'yi recordId olarak yansit.
            // Polling: renderer ve ic handleRef hazir olana kadar bekle, sonra reload.
            if (q.id) sqReloadRenderer(String(q.id));
        } catch (e) {
            console.error('sqLoadQuote hatasi:', e);
            CalibraAlert.error('Teklif yuklenemedi: ' + e.message);
        }
    }

    window.sqAddLine = function () { addLineRow(null); };

    function addLineRow(ln) {
        var body = document.getElementById('sqLinesBody');
        var idx = body.children.length + 1;
        var card = document.createElement('div');
        card.className = 'sqe-line-card';

        var matOptions = '<option value="">Seciniz</option>' + materials.map(function (m) {
            var sel = (ln != null) ? (ln.materialCode === m.materialCode ? ' selected' : '') : '';
            return '<option value="' + m.id + '|' + m.materialCode + '|' + m.materialName + '|' + (m.taxRate || 20) + '|' + (m.trackCombinations ? '1' : '0') + '"' + sel + '>' + m.materialCode + ' - ' + m.materialName + '</option>';
        }).join('');

        var combCode = ln ? (ln.combinationCode || '') : '';
        var unitVal  = ln ? (ln.unitName || '') : '';

        card.innerHTML =
            '<div class="sqe-line-card__header">' +
                '<span class="sqe-line-card__num">#' + idx + '</span>' +
                '<button type="button" class="sq-btn-del" onclick="sqDeleteRow(this)" title="Kalemi Sil"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg></button>' +
            '</div>' +
            '<div class="sqe-line-card__body">' +
                '<div class="sqe-line-card__row">' +
                    '<div class="sqe-line-card__field sqe-line-card__field--wide">' +
                        '<label>Malzeme</label>' +
                        '<div style="display:flex;align-items:center;gap:4px;">' +
                            '<select class="form-select form-select-sm sq-ln-material" onchange="sqOnMaterialChange(this)" style="flex:1;">' + matOptions + '</select>' +
                            '<button type="button" class="sq-ln-combobtn" onclick="openCombModal(this)" title="Kombinasyon Sec">K</button>' +
                        '</div>' +
                        '<input type="hidden" class="sq-ln-combcode" value="' + sqEscAttr(combCode) + '" />' +
                        '<div class="sq-ln-combdisplay"' + (combCode ? ' style="display:block;"' : '') + '>' + sqEsc(combCode) + '</div>' +
                    '</div>' +
                    '<div class="sqe-line-card__field">' +
                        '<label>Birim</label>' +
                        '<select class="form-select form-select-sm sq-ln-unit"><option value="">-</option></select>' +
                    '</div>' +
                '</div>' +
                '<div class="sqe-line-card__row">' +
                    '<div class="sqe-line-card__field">' +
                        '<label>Miktar</label>' +
                        '<input type="number" class="form-control form-control-sm sq-ln-qty" value="' + (ln ? ln.quantity : 1) + '" min="0" step="0.01" style="text-align:right;" onchange="sqRecalc()" />' +
                    '</div>' +
                    '<div class="sqe-line-card__field">' +
                        '<label>Birim Fiyat</label>' +
                        '<input type="number" class="form-control form-control-sm sq-ln-price" value="' + (ln ? ln.unitPrice : 0) + '" min="0" step="0.01" style="text-align:right;" onchange="sqRecalc()" />' +
                    '</div>' +
                    '<div class="sqe-line-card__field">' +
                        '<label>Isk.%</label>' +
                        '<input type="number" class="form-control form-control-sm sq-ln-disc" value="' + (ln ? ln.discountRate : 0) + '" min="0" max="100" step="0.01" style="text-align:right;" onchange="sqRecalc()" />' +
                    '</div>' +
                    '<div class="sqe-line-card__field sqe-line-card__field--total">' +
                        '<label>Toplam</label>' +
                        '<span class="sq-ln-total">' + formatMoney(ln ? ln.lineTotal : 0) + '</span>' +
                    '</div>' +
                '</div>' +
            '</div>';

        body.appendChild(card);

        // Mevcut kalem yukleniyorsa: birimi yukle ve sec
        if (ln && ln.materialCode) {
            var unitSel  = card.querySelector('.sq-ln-unit');
            var savedUnit = unitVal;
            fetch('/Sales/GetMaterialUnits?materialCode=' + encodeURIComponent(ln.materialCode))
                .then(function(r) { return r.json(); })
                .then(function(units) {
                    if (!unitSel) return;
                    if (units.length === 0 && savedUnit) {
                        unitSel.innerHTML = '<option value="' + sqEscAttr(savedUnit) + '" selected>' + sqEsc(savedUnit) + '</option>';
                    } else {
                        unitSel.innerHTML = '<option value="">-</option>' + units.map(function(u) {
                            var isSel = (u.code === savedUnit || u.name === savedUnit) ? ' selected' : '';
                            return '<option value="' + sqEscAttr(u.code) + '"' + isSel + '>' + sqEsc(u.name) + '</option>';
                        }).join('');
                        if (savedUnit && !units.some(function(u) { return u.code === savedUnit || u.name === savedUnit; })) {
                            unitSel.innerHTML += '<option value="' + sqEscAttr(savedUnit) + '" selected>' + sqEsc(savedUnit) + '</option>';
                        }
                    }
                })
                .catch(function() {});

            // Kombinasyon butonunu goster/gizle
            var combBtn = card.querySelector('.sq-ln-combobtn');
            var found = materials.find(function(m) { return m.materialCode === ln.materialCode; });
            if (combBtn && found && found.trackCombinations) combBtn.style.display = 'inline-flex';
        }
    }

    // Satir sil (onayli)
    window.sqDeleteRow = function(btn) {
        var card = btn.closest('.sqe-line-card');
        var idx = Array.from(document.getElementById('sqLinesBody').children).indexOf(card) + 1;
        if (!confirm(idx + '. kalemi silmek istediginizden emin misiniz?')) return;
        card.remove();
        // Sira numaralarini guncelle
        Array.from(document.getElementById('sqLinesBody').children).forEach(function(el, i) {
            var numEl = el.querySelector('.sqe-line-card__num');
            if (numEl) numEl.textContent = '#' + (i + 1);
        });
        sqRecalc();
    };

    window.sqOnMaterialChange = function (sel) {
        var val    = sel.value || '';
        var parts  = val.split('|');
        var card   = sel.closest('.sqe-line-card');
        var combBtn    = card.querySelector('.sq-ln-combobtn');
        var combInput  = card.querySelector('.sq-ln-combcode');
        var combDisplay = card.querySelector('.sq-ln-combdisplay');
        var unitSel    = card.querySelector('.sq-ln-unit');

        if (parts.length >= 5) {
            var trackCombs = parts[4] === '1';
            if (combBtn) combBtn.style.display = trackCombs ? 'inline-flex' : 'none';
            if (!trackCombs) {
                if (combInput)   { combInput.value = ''; }
                if (combDisplay) { combDisplay.textContent = ''; combDisplay.style.display = 'none'; }
            }
            var matCode = parts[1];
            if (unitSel) { unitSel.innerHTML = '<option value="">Yukleniyor...</option>'; }
            fetch('/Sales/GetMaterialUnits?materialCode=' + encodeURIComponent(matCode))
                .then(function(r) { return r.json(); })
                .then(function(units) {
                    if (!unitSel) return;
                    if (units.length === 0) {
                        unitSel.innerHTML = '<option value="">-</option>';
                    } else {
                        unitSel.innerHTML = units.map(function(u, i) {
                            return '<option value="' + sqEscAttr(u.code) + '"' + (i === 0 ? ' selected' : '') + '>' + sqEsc(u.name) + '</option>';
                        }).join('');
                    }
                })
                .catch(function() { if (unitSel) unitSel.innerHTML = '<option value="">-</option>'; });
        } else {
            if (combBtn) combBtn.style.display = 'none';
            if (unitSel) unitSel.innerHTML = '<option value="">-</option>';
        }
        sqRecalc();
    };

    window.sqRecalc = function () {
        // Her satir icin qty*price = brut, iskonto ve kdv oranlari uygulanir.
        // Genel iskonto tum satirlara orantili yansir. KDV, her satirin kendi
        // oranina gore hesaplanir ve oranlar bazinda gruplanir — farkli oranlar
        // varsa alt kisimda ayri satir olarak gosterilir.
        var lines = window.__SQ_LINES__ || [];
        var grossSubTotal = 0;
        var lineDiscountTotal = 0;
        var perLineAfterLine = [];  // [{ afterLine, taxRate }]
        lines.forEach(function (r) {
            // Kod (materialCode) girilmemis satirlar toplamlara ve KDV oran
            // bucket'larina dahil edilmez — yeni eklenen bos satirin varsayilan
            // KDV orani (%20) alt kisimda "KDV (%20): 0,00" olarak gorunmesin.
            var code = r.materialCode;
            if (code == null || String(code).trim() === '') return;
            var qty   = Number(r.quantity)     || 0;
            var price = Number(r.unitPrice)    || 0;
            var disc  = Number(r.discountRate) || 0;
            var tax   = Number(r.taxRate);
            if (!isFinite(tax)) tax = 20;
            var gross     = qty * price;
            var lineDisc  = gross * (disc / 100);
            var afterLine = gross - lineDisc;
            grossSubTotal     += gross;
            lineDiscountTotal += lineDisc;
            perLineAfterLine.push({ afterLine: afterLine, taxRate: tax });
        });
        var discRateInput = document.getElementById('sqDiscountRate');
        var discRate = parseFloat(discRateInput.value);
        if (!isFinite(discRate) || discRate < 0) discRate = 0;

        var netAfterLineDisc = grossSubTotal - lineDiscountTotal;
        var globalDiscAmount = netAfterLineDisc * (discRate / 100);
        var afterAllDisc     = netAfterLineDisc - globalDiscAmount;
        var globalDiscFactor = netAfterLineDisc > 0 ? (afterAllDisc / netAfterLineDisc) : 1;

        // KDV gruplama — her oran icin toplam KDV tutari
        var taxBuckets = {};
        perLineAfterLine.forEach(function (x) {
            var netLine = x.afterLine * globalDiscFactor;
            var taxAmt  = netLine * (x.taxRate / 100);
            var key     = x.taxRate.toFixed(2);
            if (!taxBuckets[key]) taxBuckets[key] = { rate: x.taxRate, amount: 0 };
            taxBuckets[key].amount += taxAmt;
        });
        var taxTotal = 0;
        Object.values(taxBuckets).forEach(function (b) { taxTotal += b.amount; });
        var grandTotal = afterAllDisc + taxTotal;

        document.getElementById('sqSubTotal').textContent           = formatMoney(grossSubTotal);
        document.getElementById('sqLineDiscountAmount').textContent = formatMoney(lineDiscountTotal);
        document.getElementById('sqDiscountAmount').textContent     = formatMoney(globalDiscAmount);
        document.getElementById('sqGrandTotal').textContent         = formatMoney(grandTotal);

        // KDV satirlarini render et — artan oran siralamasi
        var kdvHost = document.getElementById('sqKdvRows');
        kdvHost.innerHTML = '';
        var bucketList = Object.values(taxBuckets).sort(function (a, b) { return a.rate - b.rate; });
        if (bucketList.length === 0) {
            kdvHost.innerHTML =
                '<span class="sqe-total-label">KDV:</span>' +
                '<span class="sqe-total-control"></span>' +
                '<span class="sqe-total-value">0,00</span>';
        } else {
            bucketList.forEach(function (b) {
                var ratePct = Number(b.rate).toLocaleString('tr-TR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
                kdvHost.insertAdjacentHTML('beforeend',
                    '<span class="sqe-total-label">KDV (%' + ratePct + '):</span>' +
                    '<span class="sqe-total-control"></span>' +
                    '<span class="sqe-total-value">' + formatMoney(b.amount) + '</span>'
                );
            });
        }
    };

    // Zorunlu alanlara kirmizi cerceve + shake animasyonu ekle
    function sqMarkInvalid(ids) {
        ids.forEach(function(id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.classList.remove('is-invalid');
            void el.offsetWidth; // reflow — animasyonu yeniden tetikle
            el.classList.add('is-invalid');
            var clear = function() {
                el.classList.remove('is-invalid');
                el.removeEventListener('input', clear);
                el.removeEventListener('change', clear);
            };
            el.addEventListener('input', clear);
            el.addEventListener('change', clear);
        });
        if (ids.length) {
            var first = document.getElementById(ids[0]);
            if (first) first.focus();
        }
    }

    window.sqSave = async function (opts) {
        // opts.silent === true ise basari KITT animasyonu atlanir (satir-ici otomatik kayit icin).
        var _silent = !!(opts && opts.silent);
        // Ek alan (widget) zorunlu kontrolu — fetch'ten ONCE.
        // Eksik alan varsa kullanici "Ek Alanlar" sekmesinde degilse otomatik o
        // sekmeye yonlendirilir, sonra kirmizi titreme animasyonu calisir. Aksi
        // halde shake tetiklenir ama kullanici hangi sekmede oldugundan haberi
        // olmaz (display:none olan panede animasyon gorunmez).
        if (window._sqDynRenderer && window._sqDynRenderer.validate) {
            var dynValidation = window._sqDynRenderer.validate();
            if (!dynValidation.valid) {
                var shakeIds = (dynValidation.errorIds || []).map(function(id) { return 'dyn_' + id; });
                // Once Ek Alanlar sekmesine gec — pane gorunur olsun.
                sqActivateTab('widgets');
                // Reflow sonrasi shake — pane display:block'a dondukten sonra animasyon gorunur
                requestAnimationFrame(function () {
                    if (shakeIds.length) sqMarkInvalid(shakeIds);
                });
                return;
            }
        }

        // Satirlari React CalibraLineItemsGrid'ten al (bridge)
        var rawLines = window.__SQ_LINES__ || [];
        if (window.CalibraHub && window.CalibraHub.salesLineGrid) {
            // Daha taze okuma — grid imperative API mevcut ise oradan cek
            try { rawLines = window.CalibraHub.salesLineGrid.getRows() || rawLines; } catch (e) {}
        }
        var rowsFilled = rawLines.filter(function (r) { return r && (r.materialCode || r.materialName); });

        // Kombinasyon takipli stoklarda combinationId zorunlu — Kaydet oncesi kontrol et.
        // materials snapshot'undan trackCombinations bayragini okur (sayfa acilirken dolduruldu).
        var missingCombos = rowsFilled.filter(function (r) {
            var m = (materials || []).find(function (x) { return x.materialCode === r.materialCode; });
            var needs = m ? m.trackCombinations === true : r.trackCombinations === true;
            var hasComboId = r.combinationId != null && r.combinationId !== '' && parseInt(r.combinationId, 10) > 0;
            return needs && !hasComboId;
        });
        if (missingCombos.length > 0) {
            sqActivateTab('lines');
            // Modal yerine kombinasyon butonlarini titret — kullanici hangi satir oldugunu
            // dogrudan gorur, ekranda bilgilendirme mesaji cikmaz (içeriği itelmez).
            requestAnimationFrame(function () {
                document.querySelectorAll('[data-comb-btn][data-needs-combo="1"]').forEach(function (btn) {
                    btn.classList.remove('cb-invalid-shake');
                    void btn.offsetWidth; // reflow — animasyonu yeniden tetikle
                    btn.classList.add('cb-invalid-shake');
                    setTimeout(function () { btn.classList.remove('cb-invalid-shake'); }, 600);
                });
            });
            return;
        }

        var lines = rowsFilled
            .map(function (r) {
                // ItemId DB'de source-of-truth; materialCode/materialName tabloda tutulmaz,
                // server JOIN ile Item'dan turetir. unitId, combinationId ve locationId ayni sekilde.
                // Id dolu gelirse UPSERT (UPDATE) — widget kayitlari orphanlanmaz.
                return {
                    id:                 r.id != null && r.id !== '' && Number(r.id) > 0 ? Number(r.id) : null,
                    itemId:             r.stockCardId != null && r.stockCardId !== '' ? parseInt(r.stockCardId, 10) : 0,
                    trackCombinations:  r.trackCombinations === true,
                    unitId:             r.unitId != null && r.unitId !== '' ? parseInt(r.unitId, 10) : null,
                    quantity:           Number(r.quantity) || 0,
                    unitPrice:          Number(r.unitPrice) || 0,
                    discountRate:       Number(r.discountRate) || 0,
                    combinationId:      r.combinationId != null && r.combinationId !== '' ? parseInt(r.combinationId, 10) : null,
                    locationId:         r.locationId != null && r.locationId !== '' ? parseInt(r.locationId, 10) : null,
                    combinationDetails: Array.isArray(r.combinationDetails) ? r.combinationDetails : [],
                    notes:              r.notes || null,
                    notesPinned:        r.notesPinned === true,
                    // Revize zinciri — yeni revize satirlarda dolu gelir, orijinal
                    // satirlarda null. Server INSERT'te revised_from_id kolonuna yazilir.
                    revisedFromId:      r.revisedFromId != null && Number(r.revisedFromId) > 0 ? Number(r.revisedFromId) : null
                };
            });
        var custIdVal  = document.getElementById('sqCustomerId').value;
        var custCodeVal = (document.getElementById('sqCustomerDisplay').value || '').trim();
        // Cari isim artik label (span) — save'e gonderilmiyor; server contact_id'den Contact.AccountTitle'i turetir.
        var custText   = null;

        // Cari zorunlu kontrolu — ekran ortasi uyari yerine input'ta kirmizi shake
        if (!custIdVal && !custCodeVal && !custText) {
            flashCustomerRequired();
            return;
        }

        var payload  = {
            id: currentQuoteId,
            documentDate:    document.getElementById('sqQuoteDate').value,
            validUntil:      document.getElementById('sqValidUntil').value || null,
            contactId:       parseInt(custIdVal) || null,
            contactCode:     custCodeVal || null,
            contactName:     custText,
            contactAddress:  null,
            salesRepId:      parseInt(document.getElementById('sqSalesRepId').value) || null,
            currency:        document.getElementById('sqCurrency').value,
            discountRate:    parseFloat(document.getElementById('sqDiscountRate').value || 0),
            // Satir bazli KDV hesaplandigi icin belge basligindaki TaxRate legacy —
            // ilk satirin orani, yoksa 20 gonder (sunucu hala bu alani bekliyor).
            taxRate:         (function () {
                var ls = window.__SQ_LINES__ || [];
                for (var i = 0; i < ls.length; i++) {
                    var t = Number(ls[i].taxRate);
                    if (isFinite(t)) return t;
                }
                return 20;
            })(),
            paymentTerms:    document.getElementById('sqPaymentTerms').value || null,
            deliveryTerms:   document.getElementById('sqDeliveryTerms').value || null,
            deliveryAddress: document.getElementById('sqDeliveryAddress')?.value || null,
            notes:           document.getElementById('sqNotes').value || null,
            lines: lines
        };
        try {
            var resp = await fetch('/Sales/SaveDocument', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            var data = await resp.json();
            // invalidLineIds varsa: belge DB'de olustu/guncellendi ama satirlardan bazilarinda
            // zorunlu widget eksik. ⚙ butonlari kirmizi yanip titresir, KITT tetiklenmez.
            var invalidLineIds = Array.isArray(data.invalidLineIds) ? data.invalidLineIds : [];
            if (!data.success) {
                if (data.quote && data.quote.id) {
                    currentQuoteId = data.quote.id;
                    var sqNumEl = document.getElementById('sqQuoteNumber');
                    if (sqNumEl && data.quote.documentNumber) sqNumEl.value = data.quote.documentNumber;
                    var sqMetaErr = document.getElementById('sqMeta');
                    if (sqMetaErr) sqMetaErr.innerHTML = '<strong>' + (data.quote.documentNumber || '') + '</strong>';
                    // Satirlari yeniden cek ki line.id'ler gunce olsun + widget state yenilensin.
                    try {
                        var refreshResp = await fetch('/Sales/GetQuote?id=' + currentQuoteId);
                        if (refreshResp.ok) {
                            var refreshData = await refreshResp.json();
                            var refreshedLines = (refreshData.lines || []).map(function (ln) {
                                var m = (materials || []).find(function (x) { return x.id === ln.itemId });
                                return Object.assign({}, ln, {
                                    stockCardId:       ln.itemId,
                                    trackCombinations: m ? m.trackCombinations === true : false,
                                    taxRate:           ln.taxRate != null ? ln.taxRate : (m && m.taxRate != null ? m.taxRate : 20),
                                });
                            });
                            if (window.CalibraHub && window.CalibraHub.salesLineGrid) {
                                window.CalibraHub.salesLineGrid.setRows(refreshedLines);
                            }
                        }
                    } catch (refreshErr) { /* ignore */ }
                }
                // Ekrani uyari modalı ile kesmeyelim — sadece gorsel feedback (⚙ kirmiziya dons+titre).
                // Kullanici baska bir sekmedeyse once Kalemler sekmesine yonlendir. Tab gecis +
                // titre tek rAF icinde — panel "genislemeden" once butonlar kirmizi+titre halinde
                // gorunur, kullanici layout'un iki defa yerlesmesini hissetmez.
                if (invalidLineIds.length > 0) {
                    // Onceden ⚙ state'ini kirmiziya cevir ki tab acildiginda direk kirmizi gorunsunler.
                    if (window.CalibraHub && window.CalibraHub.salesLineGrid
                        && typeof window.CalibraHub.salesLineGrid.setInvalidLines === 'function') {
                        window.CalibraHub.salesLineGrid.setInvalidLines(invalidLineIds);
                    }
                    // Tab'a gecis — sqActivateTab senkron, display:block atar.
                    if (typeof sqActivateTab === 'function') sqActivateTab('lines');
                    // Shake animasyonunu bir rAF sonra tetikle ki DOM gorunur hale geldikten sonra
                    // calışsın. Panel-genisleme hissini azaltmak icin setTimeout(200) kullanmiyoruz.
                    requestAnimationFrame(function () {
                        if (window.CalibraHub && window.CalibraHub.salesLineGrid
                            && typeof window.CalibraHub.salesLineGrid.flashInvalidLines === 'function') {
                            window.CalibraHub.salesLineGrid.flashInvalidLines(invalidLineIds);
                        }
                    });
                }
                if (data.message && !invalidLineIds.length) {
                    // Validation disi gercek bir hata — artik sessiz kalmamak icin konsola log yaz.
                    console.warn('[SQ] save failed:', data.message);
                }
                return;
            }
            currentQuoteId = data.quote.id;
            // Basarili kayit sonrasi: eksik yok, grid'e temiz state sinyali ver.
            if (window.CalibraHub && window.CalibraHub.salesLineGrid
                && typeof window.CalibraHub.salesLineGrid.setInvalidLines === 'function') {
                window.CalibraHub.salesLineGrid.setInvalidLines([]);
            }
            document.getElementById('sqQuoteNumber').value = data.quote.documentNumber;
            document.getElementById('sqBtnDelete').disabled = false;
            document.getElementById('sqStatusSelect').style.display = '';
            document.getElementById('sqStatusSelect').value = data.quote.status;
            document.getElementById('sqStatusBadge').innerHTML = '<span class="sqe-status-badge sqe-status-' + data.quote.status + '">' + statusLabel(data.quote.status) + '</span>';

            // Header kart baslik + subtitle guncelle (yeni kayit → 'Teklif Duzenle')
            var sqMetaEl2 = document.getElementById('sqMeta');
            if (sqMetaEl2) sqMetaEl2.innerHTML = '<strong>' + (data.quote.documentNumber || '') + '</strong>';

            // ── Satir ek alanlarini (SALES_QUOTE_LINES) senkronize et ──
            // Kaydedilmemis satirda kullanici ⚙ modal'dan deger girmisse row.__extras
            // icinde local tutuluyordu. Ana kayittan sonra satir id'leri DB'de olustu;
            // /Sales/GetQuote ile taze listeyi cek, siraya gore __extras degerlerini
            // widget API'siyle iliskilendir.
            var localRowsForSync = rowsFilled; // SaveDocument'a gonderdigimiz ayni sira
            var hasAnyPending = localRowsForSync.some(function (r) {
                return r && r.__extras && Object.keys(r.__extras).length > 0;
            });
            if (hasAnyPending) {
                try {
                    var refResp = await fetch('/Sales/GetQuote?id=' + currentQuoteId);
                    if (refResp.ok) {
                        var refData  = await refResp.json();
                        var refLines = Array.isArray(refData.lines) ? refData.lines : [];
                        // Index esleme: rowsFilled[i] → refLines[i] (server sirayi korur).
                        // Ana POST'ta yeni satirlar icin id:null gonderildi; servertarafinda
                        // UPSERT sonrasi tum satirlar bir id'ye sahip olarak geri doner.
                        for (var i = 0; i < localRowsForSync.length && i < refLines.length; i++) {
                            var lr = localRowsForSync[i];
                            if (!lr.__extras || Object.keys(lr.__extras).length === 0) continue;
                            var targetId = refLines[i].id;
                            if (!(targetId > 0)) continue;
                            try {
                                await fetch('/api/widgets/forms/SALES_QUOTE_LINES/records/' + encodeURIComponent(String(targetId)), {
                                    method: 'POST',
                                    credentials: 'same-origin',
                                    headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                                    body: JSON.stringify({ values: lr.__extras, grids: null }),
                                });
                            } catch (extrasErr) {
                                console.warn('[SQ] satir ek alan kaydi basarisiz (id=' + targetId + '):', extrasErr);
                            }
                        }
                        // Grid'i refresh edilmis veriyle senkronize et (__extras temizlenir,
                        // id'ler yerlesir, ⚙ butonlari kayitli duruma gecer).
                        if (window.CalibraHub && window.CalibraHub.salesLineGrid) {
                            var syncedLines = refLines.map(function (ln) {
                                var m = (materials || []).find(function (x) { return x.id === ln.itemId; });
                                return Object.assign({}, ln, {
                                    stockCardId:       ln.itemId,
                                    trackCombinations: m ? m.trackCombinations === true : false,
                                    taxRate:           ln.taxRate != null ? ln.taxRate : (m && m.taxRate != null ? m.taxRate : 20),
                                });
                            });
                            window.CalibraHub.salesLineGrid.setRows(syncedLines);
                        }
                    }
                } catch (syncErr) {
                    console.warn('[SQ] satir ek alan senkronizasyonu hatasi:', syncErr);
                }
            }

            // ── Ek alanlari (WidgetMas/WidgetTra) kaydet — belge basligi ──
            // RecordId = sales_quotes.Id (integer PK). Renderer mount race'lerine karsi
            // kisa bir polling ile hazir olmasini bekle; degerler verilerle birlikte
            // gidebilsin. Ayrica sonucu kullaniciya gorunur toast olarak bildir.
            await saveHeaderWidgets(data.quote.id);
            // Kayit sonrasi widget'lari taze yukle — degerler formda reopen'a gerek
            // kalmadan gorunur kalsin (save+reload dongusu kirilmasin).
            sqReloadRenderer(String(data.quote.id));

            if (!_silent) {
                // Basari KITT sweep animasyonu — kullanici kaydin gectiğini gorur.
                sqFlashSaveSuccess();
                // Kayit sonrasi teklif kart listesine geri don. Flash animasyonu
                // 1850ms; 1100ms'de nav edersek kullanici yesil sweep'i yakalar,
                // sonra Documents sayfasina yumusakca dusur.
                setTimeout(function () {
                    window.location.href = '/Sales/Documents';
                }, 1100);
            }
        } catch (e) { CalibraAlert.error('Kayit hatasi: ' + e.message); }
    };

    /* Renderer reload — React proxy.reload ic handleRef null iken sessizce
       no-op oldugu icin cagriyi birkaç kez tekrar ederiz (idempotent).
       Ilk basarili aramadan sonra sonraki tekrarlar cok ucuz (setState same).
       Ek olarak renderer henuz mount olmadiysa polling ile onu da bekleriz. */
    function sqReloadRenderer(recordId) {
        var delays = [0, 80, 250, 600, 1200, 2500]; // ms
        var mountAttempts = 0;
        function fireReloadChain() {
            delays.forEach(function (d) {
                setTimeout(function () {
                    if (!window._sqDynRenderer || !window._sqDynRenderer.reload) return;
                    try { window._sqDynRenderer.reload({ recordId: recordId }); }
                    catch (e) { console.warn('[SQ] reload fire hata:', e); }
                }, d);
            });
            console.log('[SQ] sqReloadRenderer — recordId=' + recordId + ' (multi-fire)');
        }
        (function waitForMount() {
            if (window._sqDynRenderer) return fireReloadChain();
            if (++mountAttempts < 80) return setTimeout(waitForMount, 80);
            console.warn('[SQ] sqReloadRenderer — renderer mount olmadi (80 deneme)');
        })();
    }

    /* Belge basligi widget'larini kaydet — renderer hazir degilse 2 saniye bekle,
       sonra POST. Basari/hata sonucunu kullaniciya toast ile bildir. */
    async function saveHeaderWidgets(quoteId) {
        // Renderer hazir olana kadar kisa bir polling
        var waited = 0;
        while (!window._sqDynRenderer && waited < 2000) {
            await new Promise(function (r) { setTimeout(r, 80); });
            waited += 80;
        }
        if (!window._sqDynRenderer) {
            console.warn('[SQ] widget save atlandi — renderer hazir degil');
            if (window.CalibraAlert && CalibraAlert.warn) {
                CalibraAlert.warn('Ek alanlar kaydedilmedi — sayfayi yenileyip tekrar deneyin.');
            }
            return;
        }
        try {
            var dynResult = await window._sqDynRenderer.save({ recordId: String(quoteId) });
            if (dynResult && dynResult.success === false) {
                console.warn('[SQ] widget save basarisiz:', dynResult.message);
                if (window.CalibraAlert && CalibraAlert.error) {
                    CalibraAlert.error('Ek alan kaydi basarisiz: ' + (dynResult.message || 'Bilinmeyen hata'));
                }
            } else {
                console.log('[SQ] widget save OK recordId=' + quoteId);
            }
        } catch (dynErr) {
            console.warn('[SQ] widget save hatasi:', dynErr);
            if (window.CalibraAlert && CalibraAlert.error) {
                CalibraAlert.error('Ek alan kaydi hatasi: ' + (dynErr && dynErr.message ? dynErr.message : dynErr));
            }
        }
    }

    /* Kaydet onayi icin K.I.T.T. on tarayici tarama efekti aksiyon seridinin altinda. */
    function sqFlashSaveSuccess() {
        var bar = document.querySelector('.sqe-action-bar');
        if (!bar) return;
        bar.classList.remove('is-save-flash');
        void bar.offsetWidth; // reflow — animasyonu yeniden tetikle
        bar.classList.add('is-save-flash');
        setTimeout(function () { bar.classList.remove('is-save-flash'); }, 1850);
    }

    // ── Islemler menusu (cark ikonu) — ac/kapa, disari tik kapa, Esc kapa ──
    // Dropdown position:fixed kullaniyor cunku .sqe-action-bar'da overflow:hidden var
    // (KITT save flash efekti icin). Viewport-relative koordinatlari her acilista
    // butonun getBoundingClientRect'inden hesaplayip inline style olarak veririz;
    // scroll/resize olaylarinda da yeniden hesapla.
    function sqPositionActionsDropdown() {
        var btn  = document.getElementById('sqActionsBtn');
        var drop = document.getElementById('sqActionsDropdown');
        if (!btn || !drop) return;
        var r = btn.getBoundingClientRect();
        var vw = window.innerWidth || document.documentElement.clientWidth;
        var vh = window.innerHeight || document.documentElement.clientHeight;
        // Dropdown genisligini oku (display:flex'iken minWidth en az 180px)
        var dw = Math.max(drop.offsetWidth, 180);
        var dh = drop.offsetHeight || 100;
        // Sag kenara yaslan — right edge butonun sag kenari ile aynI hizada
        var left = Math.max(8, Math.min(vw - dw - 8, r.right - dw));
        // Asagi acilmasi yeterli yer varsa butonun altina, yoksa ustune
        var top  = r.bottom + 6;
        if (top + dh > vh - 8) top = Math.max(8, r.top - dh - 6);
        drop.style.left = left + 'px';
        drop.style.top  = top  + 'px';
    }
    window.sqToggleActionsMenu = function (ev) {
        if (ev) ev.stopPropagation();
        var menu = document.getElementById('sqActionsMenu');
        var drop = document.getElementById('sqActionsDropdown');
        var btn  = document.getElementById('sqActionsBtn');
        if (!drop) return;
        var willOpen = !drop.classList.contains('is-open');
        drop.classList.toggle('is-open', willOpen);
        if (menu) menu.classList.toggle('is-open', willOpen); // buton vurgusu icin
        if (btn) btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        if (willOpen) {
            // DOM'a eklendikten sonra pozisyon hesapla (display:flex gereklidir)
            requestAnimationFrame(sqPositionActionsDropdown);
        }
    };
    function sqCloseActionsMenu() {
        var menu = document.getElementById('sqActionsMenu');
        var drop = document.getElementById('sqActionsDropdown');
        var btn  = document.getElementById('sqActionsBtn');
        if (drop) drop.classList.remove('is-open');
        if (menu) menu.classList.remove('is-open');
        if (btn) btn.setAttribute('aria-expanded', 'false');
    }
    document.addEventListener('click', function (e) {
        var drop = document.getElementById('sqActionsDropdown');
        if (!drop || !drop.classList.contains('is-open')) return;
        var menu = document.getElementById('sqActionsMenu');
        if (menu && menu.contains(e.target)) return; // buton veya cevresi
        if (drop.contains(e.target)) return;          // dropdown item'lari
        sqCloseActionsMenu();
    });
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') sqCloseActionsMenu();
    });
    // Scroll / resize'ta acik menunun pozisyonunu yeniden hesapla
    window.addEventListener('scroll', function () {
        var drop = document.getElementById('sqActionsDropdown');
        if (drop && drop.classList.contains('is-open')) sqPositionActionsDropdown();
    }, true);
    window.addEventListener('resize', function () {
        var drop = document.getElementById('sqActionsDropdown');
        if (drop && drop.classList.contains('is-open')) sqPositionActionsDropdown();
    });

    // ── Islemler: Yazdir ──
    // Belge turune tanimlanmis varsayilan FastReport sablonu ile cikti
    // secenekleri (Baski onizle / PDF kaydet / Mail gonder) modalini acar.
    window.sqActionPrint = async function (ev) {
        if (ev) ev.stopPropagation();
        sqCloseActionsMenu();

        if (!currentQuoteId || Number(currentQuoteId) <= 0) {
            if (window.CalibraAlert && CalibraAlert.warn) {
                CalibraAlert.warn('Yazdirmak icin once teklifi kaydedin.');
            } else {
                alert('Yazdirmak icin once teklifi kaydedin.');
            }
            return;
        }

        try {
            var resp = await fetch('/Document/DefaultTemplate?typeCode=satis_teklifi', { credentials: 'same-origin' });
            var data = await resp.json();
            if (!data.success || !data.id) {
                var msg = data.message || 'Tanimlanmis sablon yok. Tasarim → Belge Sablonlari ekraninda ekleyin.';
                if (window.CalibraAlert && CalibraAlert.warn) CalibraAlert.warn(msg); else alert(msg);
                return;
            }
            // Sablonun kayitli cikti ayari varsa: modal acmadan direkt uygula
            var savedOpts = null;
            if (data.outputOptions) {
                try { savedOpts = JSON.parse(data.outputOptions); } catch (_) { savedOpts = null; }
            }
            if (savedOpts && (savedOpts.preview || savedOpts.pdf || savedOpts.mail)) {
                sqApplyOutputOptions(data.id, currentQuoteId, savedOpts);
            } else {
                sqOpenOutputOptionsModal(data.id, currentQuoteId);
            }
        } catch (e) {
            console.warn('[SQ] yazdir hatasi:', e);
            if (window.CalibraAlert && CalibraAlert.error) {
                CalibraAlert.error('Yazdirma hatasi: ' + (e && e.message ? e.message : 'Bilinmeyen'));
            } else {
                alert('Yazdirma hatasi: ' + (e && e.message ? e.message : 'Bilinmeyen'));
            }
        }
    };

    // Kayitli cikti ayarlarini direkt uygular (modal acmaz).
    // opts: { preview, pdf, mail, mailTo, mailSubject, mailBody }
    async function sqApplyOutputOptions(templateId, recordId, opts) {
        var baseUrl = '/Document/Preview/' + templateId + '/' + recordId;

        if (opts.pdf) {
            var a = document.createElement('a');
            a.href = baseUrl + '?download=1';
            a.style.display = 'none';
            document.body.appendChild(a);
            a.click();
            setTimeout(function () { a.remove(); }, 200);
        }

        if (opts.preview && !opts.pdf) {
            sqOpenPrintModal(baseUrl);
        }

        if (opts.mail) {
            var subject = (opts.mailSubject || 'Satis Teklifi').trim();
            var body    = (opts.mailBody || '').trim();
            try {
                var resp = await fetch('/Document/SendEmail', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        templateId: templateId,
                        recordId:   recordId,
                        toEmail:    null,
                        subject:    subject,
                        bodyText:   body,
                        bodyHtml:   null
                    })
                });
                var json = await resp.json();
                if (json && json.success) {
                    if (window.CalibraAlert && CalibraAlert.success) CalibraAlert.success('Mail gonderildi.'); else alert('Mail gonderildi.');
                } else {
                    var emsg = (json && json.message) || 'Mail gonderilemedi.';
                    if (window.CalibraAlert && CalibraAlert.error) CalibraAlert.error(emsg); else alert(emsg);
                }
            } catch (err) {
                if (window.CalibraAlert && CalibraAlert.error) CalibraAlert.error('Mail hatasi: ' + (err && err.message ? err.message : 'Bilinmeyen')); else alert('Mail hatasi.');
            }
        }
    }

    // Cikti secenekleri modal'i:
    //  - Baski onizle: iframe modali (sqOpenPrintModal)
    //  - PDF olarak kaydet: /Document/Preview/{tid}/{rid}?download=1 ile indir
    //  - Mail gonderim: alici/konu/mesaj alanlari acilir, /Document/SendEmail'e POST
    //  PDF kaydet secildiginde Baski onizle anlamsiz oldugu icin pasiflesir.
    function sqOpenOutputOptionsModal(templateId, recordId) {
        var existing = document.getElementById('sqOutputOptionsOverlay');
        if (existing) existing.remove();

        if (!document.getElementById('sqOutputOptionsStyles')) {
            var st = document.createElement('style');
            st.id = 'sqOutputOptionsStyles';
            st.textContent = [
                '#sqOutputOptionsOverlay { position:fixed; inset:0; background:rgba(15,23,42,.62); z-index:9998; display:flex; align-items:center; justify-content:center; padding:24px; animation: sqOptFade .15s ease; }',
                '#sqOutputOptionsOverlay .opt-modal { width:min(94vw,520px); background:#fff; border-radius:12px; box-shadow:0 18px 50px rgba(0,0,0,.4); overflow:hidden; display:flex; flex-direction:column; }',
                '#sqOutputOptionsOverlay .opt-head { padding:14px 18px; background:#1f2937; color:#f8fafc; display:flex; align-items:center; justify-content:space-between; }',
                '#sqOutputOptionsOverlay .opt-head h3 { margin:0; font-size:14px; font-weight:600; }',
                '#sqOutputOptionsOverlay .opt-head .opt-x { background:transparent; border:none; color:#f8fafc; font-size:22px; cursor:pointer; line-height:1; padding:0 4px; }',
                '#sqOutputOptionsOverlay .opt-body { padding:16px 18px; display:flex; flex-direction:column; gap:10px; }',
                '#sqOutputOptionsOverlay .opt-row { display:flex; align-items:flex-start; gap:10px; padding:10px 12px; border:1px solid #e2e8f0; border-radius:8px; cursor:pointer; transition:border-color .15s, background .15s; }',
                '#sqOutputOptionsOverlay .opt-row:hover { border-color:#94a3b8; background:#f8fafc; }',
                '#sqOutputOptionsOverlay .opt-row.is-checked { border-color:#2563eb; background:#eff6ff; }',
                '#sqOutputOptionsOverlay .opt-row.is-disabled { opacity:.45; pointer-events:none; }',
                '#sqOutputOptionsOverlay .opt-row input { margin-top:3px; cursor:pointer; }',
                '#sqOutputOptionsOverlay .opt-row .opt-text { display:flex; flex-direction:column; gap:2px; }',
                '#sqOutputOptionsOverlay .opt-row .opt-title { font-weight:600; font-size:13px; color:#0f172a; }',
                '#sqOutputOptionsOverlay .opt-row .opt-desc { font-size:11.5px; color:#64748b; }',
                '#sqOutputOptionsOverlay .opt-mail { display:none; flex-direction:column; gap:8px; padding:12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; margin-top:2px; }',
                '#sqOutputOptionsOverlay .opt-mail.is-open { display:flex; }',
                '#sqOutputOptionsOverlay .opt-mail label { font-size:11.5px; font-weight:600; color:#475569; }',
                '#sqOutputOptionsOverlay .opt-mail input, #sqOutputOptionsOverlay .opt-mail textarea { width:100%; padding:7px 10px; border:1px solid #cbd5e1; border-radius:6px; font-size:12.5px; font-family:inherit; box-sizing:border-box; }',
                '#sqOutputOptionsOverlay .opt-mail textarea { resize:vertical; min-height:70px; }',
                '#sqOutputOptionsOverlay .opt-foot { padding:12px 18px; background:#f8fafc; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end; gap:8px; }',
                '#sqOutputOptionsOverlay .opt-btn { padding:7px 14px; font-size:12.5px; font-weight:600; border-radius:7px; cursor:pointer; border:1px solid transparent; }',
                '#sqOutputOptionsOverlay .opt-btn-secondary { background:#fff; color:#475569; border-color:#e2e8f0; }',
                '#sqOutputOptionsOverlay .opt-btn-secondary:hover { background:#f1f5f9; }',
                '#sqOutputOptionsOverlay .opt-btn-primary { background:#2563eb; color:#fff; border-color:#2563eb; }',
                '#sqOutputOptionsOverlay .opt-btn-primary:hover { background:#1d4ed8; }',
                '#sqOutputOptionsOverlay .opt-btn-primary:disabled { background:#93c5fd; border-color:#93c5fd; cursor:not-allowed; }',
                '@@keyframes sqOptFade { from { opacity:0; } to { opacity:1; } }'
            ].join('\n');
            document.head.appendChild(st);
        }

        var overlay = document.createElement('div');
        overlay.id = 'sqOutputOptionsOverlay';
        overlay.innerHTML =
            '<div class="opt-modal" role="dialog" aria-label="Cikti Secenekleri">' +
                '<div class="opt-head">' +
                    '<h3>Cikti Secenekleri</h3>' +
                    '<button type="button" class="opt-x" aria-label="Kapat">&times;</button>' +
                '</div>' +
                '<div class="opt-body">' +
                    '<label class="opt-row is-checked" data-opt="preview">' +
                        '<input type="checkbox" id="sqOptPreview" checked />' +
                        '<span class="opt-text">' +
                            '<span class="opt-title">Baski onizle</span>' +
                            '<span class="opt-desc">Belgeyi modal icinde PDF olarak goruntule.</span>' +
                        '</span>' +
                    '</label>' +
                    '<label class="opt-row" data-opt="pdf">' +
                        '<input type="checkbox" id="sqOptPdf" />' +
                        '<span class="opt-text">' +
                            '<span class="opt-title">PDF olarak kaydet</span>' +
                            '<span class="opt-desc">Belgeyi PDF dosyasi olarak indir. Secilirse baski onizleme pasiflesir.</span>' +
                        '</span>' +
                    '</label>' +
                    '<label class="opt-row" data-opt="mail">' +
                        '<input type="checkbox" id="sqOptMail" />' +
                        '<span class="opt-text">' +
                            '<span class="opt-title">Mail gonderim</span>' +
                            '<span class="opt-desc">PDF eki ile e-posta gonder.</span>' +
                        '</span>' +
                    '</label>' +
                    '<div class="opt-mail" id="sqOptMailFields">' +
                        '<div style="font-size:11.5px; color:#1d4ed8; padding:6px 10px; background:#eff6ff; border-left:3px solid #3b82f6; border-radius:4px;">' +
                            'Alici e-postasi teklife ait <strong>cari kart</strong>tan otomatik alinir.' +
                        '</div>' +
                        '<div><label for="sqOptMailSubject">Konu</label>' +
                        '<input type="text" id="sqOptMailSubject" placeholder="Satis Teklifi" /></div>' +
                        '<div><label for="sqOptMailBody">Mesaj</label>' +
                        '<textarea id="sqOptMailBody" placeholder="Ekte teklifimizi bulabilirsiniz..."></textarea></div>' +
                    '</div>' +
                '</div>' +
                '<div class="opt-foot">' +
                    '<button type="button" class="opt-btn opt-btn-secondary" id="sqOptCancel">Vazgec</button>' +
                    '<button type="button" class="opt-btn opt-btn-primary" id="sqOptRun">Calistir</button>' +
                '</div>' +
            '</div>';
        document.body.appendChild(overlay);

        var optPreview  = overlay.querySelector('#sqOptPreview');
        var optPdf      = overlay.querySelector('#sqOptPdf');
        var optMail     = overlay.querySelector('#sqOptMail');
        var rowPreview  = overlay.querySelector('[data-opt="preview"]');
        var rowPdf      = overlay.querySelector('[data-opt="pdf"]');
        var rowMail     = overlay.querySelector('[data-opt="mail"]');
        var mailFields  = overlay.querySelector('#sqOptMailFields');
        var runBtn      = overlay.querySelector('#sqOptRun');

        function refresh() {
            if (optPdf.checked) {
                optPreview.checked = false;
                rowPreview.classList.add('is-disabled');
            } else {
                rowPreview.classList.remove('is-disabled');
            }
            rowPreview.classList.toggle('is-checked', optPreview.checked);
            rowPdf.classList.toggle('is-checked',     optPdf.checked);
            rowMail.classList.toggle('is-checked',    optMail.checked);
            mailFields.classList.toggle('is-open',    optMail.checked);
            runBtn.disabled = !(optPreview.checked || optPdf.checked || optMail.checked);
        }
        [optPreview, optPdf, optMail].forEach(function (cb) {
            cb.addEventListener('change', refresh);
        });
        refresh();

        function close() {
            overlay.remove();
            document.removeEventListener('keydown', esc);
        }
        function esc(e) { if (e.key === 'Escape') close(); }
        document.addEventListener('keydown', esc);
        overlay.querySelector('.opt-x').onclick       = close;
        overlay.querySelector('#sqOptCancel').onclick = close;
        overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });

        runBtn.onclick = async function () {
            var baseUrl = '/Document/Preview/' + templateId + '/' + recordId;

            if (optPdf.checked) {
                var a = document.createElement('a');
                a.href = baseUrl + '?download=1';
                a.style.display = 'none';
                document.body.appendChild(a);
                a.click();
                setTimeout(function () { a.remove(); }, 200);
            }

            if (optPreview.checked && !optPdf.checked) {
                sqOpenPrintModal(baseUrl);
            }

            if (optMail.checked) {
                var subject = (overlay.querySelector('#sqOptMailSubject').value || '').trim();
                var body    = (overlay.querySelector('#sqOptMailBody').value || '').trim();
                if (!subject) subject = 'Satis Teklifi';
                runBtn.disabled = true;
                runBtn.textContent = 'Gonderiliyor...';
                try {
                    var resp = await fetch('/Document/SendEmail', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            templateId: templateId,
                            recordId:   recordId,
                            toEmail:    null,
                            subject:    subject,
                            bodyText:   body,
                            bodyHtml:   null
                        })
                    });
                    var json = await resp.json();
                    if (json && json.success) {
                        if (window.CalibraAlert && CalibraAlert.success) CalibraAlert.success('Mail gonderildi.'); else alert('Mail gonderildi.');
                    } else {
                        var emsg = (json && json.message) || 'Mail gonderilemedi.';
                        if (window.CalibraAlert && CalibraAlert.error) CalibraAlert.error(emsg); else alert(emsg);
                    }
                } catch (err) {
                    if (window.CalibraAlert && CalibraAlert.error) CalibraAlert.error('Mail hatasi: ' + (err && err.message ? err.message : 'Bilinmeyen')); else alert('Mail hatasi.');
                } finally {
                    runBtn.disabled = false;
                    runBtn.textContent = 'Calistir';
                }
            }

            close();
        };
    }

    // PDF onizleme modal'i: header yok, iframe arka alani tam doldurur.
    // PDF viewer'in kendi alt toolbar'inda yazdir + indir butonlari oldugu icin
    // tekrar buton koymuyoruz. Sadece sag-ust kosede absolute X kapatma butonu.
    // ESC ve overlay tiklamasi ile de kapanir.
    function sqOpenPrintModal(url) {
        var existing = document.getElementById('sqPrintModalOverlay');
        if (existing) existing.remove();

        var overlay = document.createElement('div');
        overlay.id = 'sqPrintModalOverlay';
        overlay.style.cssText =
            'position:fixed; inset:0; background:rgba(15,23,42,.72); z-index:9999;' +
            'display:flex; align-items:center; justify-content:center; padding:16px;' +
            'animation: sqPrintFade .15s ease;';

        var modal = document.createElement('div');
        modal.style.cssText =
            'position:relative; width:98vw; height:96vh; background:#525659;' +
            'border-radius:8px; overflow:hidden;' +
            'box-shadow:0 18px 50px rgba(0,0,0,.55);';

        // Sag-ust kose: tek X kapatma. iframe'in uzerinde z-index ile garanti.
        var closeBtn = document.createElement('button');
        closeBtn.type = 'button';
        closeBtn.setAttribute('aria-label', 'Kapat');
        closeBtn.title = 'Kapat (Esc)';
        closeBtn.innerHTML = '&times;';
        closeBtn.style.cssText =
            'position:absolute; top:10px; right:12px; z-index:10;' +
            'width:36px; height:36px; border-radius:50%;' +
            'background:rgba(15,23,42,.78); color:#fff;' +
            'border:1px solid rgba(255,255,255,.22);' +
            'font-size:22px; line-height:1; cursor:pointer;' +
            'display:inline-flex; align-items:center; justify-content:center;' +
            'box-shadow:0 4px 12px rgba(0,0,0,.35); transition:background .15s;';
        closeBtn.onmouseenter = function () { closeBtn.style.background = 'rgba(220,38,38,.85)'; };
        closeBtn.onmouseleave = function () { closeBtn.style.background = 'rgba(15,23,42,.78)'; };

        var loader = document.createElement('div');
        loader.id = 'sqPrintLoader';
        loader.style.cssText =
            'position:absolute; inset:0; background:rgba(82,86,89,.94); color:#fff;' +
            'display:flex; align-items:center; justify-content:center;' +
            'flex-direction:column; gap:14px; transition:opacity .25s; z-index:5;';
        loader.innerHTML =
            '<div style="width:38px; height:38px; border:3px solid rgba(255,255,255,.25);' +
            'border-top-color:#60a5fa; border-radius:50%; animation: sqPrintSpin .85s linear infinite;"></div>' +
            '<div style="font-size:12px; font-weight:500;">Onizleme yukleniyor...</div>';

        var iframe = document.createElement('iframe');
        iframe.id = 'sqPrintIframe';
        iframe.src = url;
        iframe.style.cssText = 'position:absolute; inset:0; width:100%; height:100%; border:none; background:#525659; z-index:1;';
        iframe.onload = function () {
            loader.style.opacity = '0';
            setTimeout(function () { loader.remove(); }, 280);
        };

        modal.appendChild(iframe);
        modal.appendChild(loader);
        modal.appendChild(closeBtn);
        overlay.appendChild(modal);

        // Animasyon stil tagi (idempotent)
        if (!document.getElementById('sqPrintModalStyles')) {
            var st = document.createElement('style');
            st.id = 'sqPrintModalStyles';
            st.textContent =
                '@@keyframes sqPrintFade { from { opacity:0; } to { opacity:1; } }' +
                '@@keyframes sqPrintSpin { to { transform: rotate(360deg); } }';
            document.head.appendChild(st);
        }

        function closeModal() {
            overlay.remove();
            document.removeEventListener('keydown', escHandler);
        }
        function escHandler(e) { if (e.key === 'Escape') closeModal(); }
        document.addEventListener('keydown', escHandler);
        closeBtn.addEventListener('click', closeModal);
        overlay.addEventListener('click', function (e) {
            if (e.target === overlay) closeModal();
        });

        document.body.appendChild(overlay);
    }

    // ── Islemler: Tur Degistir ──
    // Belge turunu (SalesQuote → Order/Proforma vb.) degistirmek icin stub.
    // Backend donusturme endpoint'i henuz yoksa kullaniciya bilgi mesaji doner.
    window.sqActionChangeType = function (ev) {
        if (ev) ev.stopPropagation();
        sqCloseActionsMenu();
        if (!currentQuoteId) {
            if (window.CalibraAlert && CalibraAlert.warn) {
                CalibraAlert.warn('Tur degistirmek icin once teklifi kaydedin.');
            } else {
                alert('Tur degistirmek icin once teklifi kaydedin.');
            }
            return;
        }
        if (window.CalibraAlert && CalibraAlert.info) {
            CalibraAlert.info('Belge turu donusumu yakinda aktiflestirilecek.');
        } else {
            alert('Belge turu donusumu yakinda aktiflestirilecek.');
        }
    };

    window.sqDelete = async function () {
        if (!currentQuoteId) return;
        var ok = await CalibraAlert.confirm('Bu teklif silinecek. Devam edilsin mi?', {
            title: 'Teklifi Sil',
            okText: 'Evet, Sil',
            cancelText: 'Iptal',
            danger: true
        });
        if (!ok) return;
        try {
            await fetch('/Sales/DeleteDocument', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: currentQuoteId })
            });
            window.location.href = '/Sales/Documents';
        } catch {}
    };

    window.sqChangeStatus = async function () {
        if (!currentQuoteId) return;
        var status = document.getElementById('sqStatusSelect').value;
        try {
            var resp = await fetch('/Sales/ChangeQuoteStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: currentQuoteId, status: status })
            });
            var data = await resp.json();
            if (!data.success) { CalibraAlert.error(data.message || 'Bilinmeyen hata'); return; }
            document.getElementById('sqStatusBadge').innerHTML = '<span class="sqe-status-badge sqe-status-' + status + '">' + statusLabel(status) + '</span>';
        } catch {}
    };

    function formatMoney(val) { return (val || 0).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
    function statusLabel(s) { return { Draft:'Taslak', Sent:'Gonderildi', Approved:'Onaylandi', Rejected:'Reddedildi', Revised:'Revize', Cancelled:'Iptal' }[s] || s; }
    function sqEsc(s)     { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }
    function sqEscAttr(s) { return (s || '').replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }

    // ── Kombinasyon Modal ──────────────────────────────────────────
    var _combModalRow = null;

    window.openCombModal = function(btn) {
        _combModalRow = btn.closest('.sqe-line-card');
        var sel   = _combModalRow.querySelector('.sq-ln-material');
        var parts = (sel.value || '').split('|');
        if (parts.length < 2) return;
        var materialCode = parts[1];

        var combList = document.getElementById('combListBody');
        combList.innerHTML = '<tr><td colspan="3" style="text-align:center;color:#94a3b8;padding:12px;">Yukleniyor...</td></tr>';

        fetch('/Sales/GetCombinations?materialCode=' + encodeURIComponent(materialCode))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.length === 0) {
                    combList.innerHTML = '<tr><td colspan="3" style="text-align:center;color:#94a3b8;padding:12px;">Kombinasyon bulunamadi.</td></tr>';
                } else {
                    combList.innerHTML = data.map(function(c) {
                        var feats = c.features.map(function(f) { return f.feature + ': ' + f.value; }).join(', ');
                        return '<tr style="cursor:pointer;border-bottom:1px solid #f1f5f9;" onclick="selectCombination(\'' + sqEsc(c.code) + '\', this)">' +
                            '<td style="padding:4px 8px;font-weight:600;">' + sqEsc(c.code) + '</td>' +
                            '<td style="padding:4px 8px;font-size:0.76rem;color:#64748b;">' + sqEsc(feats) + '</td>' +
                            '<td style="padding:4px 8px;"><button type="button" class="btn btn-sm btn-primary" style="font-size:0.7rem;padding:1px 8px;">Sec</button></td></tr>';
                    }).join('');
                }
            });

        var featBody = document.getElementById('combFeatBody');
        featBody.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:12px;">Yukleniyor...</div>';

        fetch('/Sales/GetMaterialFeatures?materialCode=' + encodeURIComponent(materialCode))
            .then(function(r) { return r.json(); })
            .then(function(features) {
                if (features.length === 0) {
                    featBody.innerHTML = '<div style="color:#94a3b8;padding:12px;">Bu malzeme icin ozellik tanimlanmamis.</div>';
                } else {
                    featBody.innerHTML = features.map(function(f) {
                        var opts = '<option value="">-- Seciniz --</option>' + f.values.map(function(v) {
                            return '<option value="' + sqEsc(v.code) + '">' + sqEsc(v.name) + '</option>';
                        }).join('');
                        return '<div class="cs-line" style="padding:4px 0;">' +
                            '<label style="width:120px;flex-shrink:0;font-size:0.78rem;font-weight:600;color:#64748b;text-align:right;padding-right:8px;">' + sqEsc(f.featureName) + '</label>' +
                            '<select class="form-select form-select-sm comb-feat-sel" data-feature="' + sqEsc(f.featureName) + '" style="max-width:160px;">' + opts + '</select>' +
                            '<input type="text" class="form-control form-control-sm comb-feat-desc" placeholder="Aciklama" style="flex:1;font-size:0.76rem;" />' +
                            '</div>';
                    }).join('');
                }
            });

        document.getElementById('combModal').style.display = 'flex';
        showCombTab('list');
    };

    window.showCombTab = function(tab) {
        document.getElementById('combTabList').style.display = tab === 'list' ? 'block' : 'none';
        document.getElementById('combTabFeatures').style.display = tab === 'features' ? 'block' : 'none';
        document.querySelectorAll('.comb-tab-btn').forEach(function(b) { b.classList.toggle('active', b.dataset.tab === tab); });
    };

    window.selectCombination = function(code) {
        if (!_combModalRow) return;
        _combModalRow.querySelector('.sq-ln-combcode').value = code;
        var disp = _combModalRow.querySelector('.sq-ln-combdisplay');
        disp.textContent = code;
        disp.style.display = 'block';
        closeCombModal();
    };

    window.applyCombFeatures = function() {
        if (!_combModalRow) return;
        var sels = document.querySelectorAll('#combFeatBody .comb-feat-sel');
        var codes = [];
        sels.forEach(function(s) { if (s.value) codes.push(s.value); });

        var matSel  = _combModalRow.querySelector('.sq-ln-material');
        var parts   = (matSel.value || '').split('|');
        var matCode = parts.length >= 2 ? parts[1] : '';
        var combCode = codes.length > 0 ? matCode + '-' + codes.join('-') : '';

        _combModalRow.querySelector('.sq-ln-combcode').value = combCode;
        var disp = _combModalRow.querySelector('.sq-ln-combdisplay');
        if (combCode) { disp.textContent = combCode; disp.style.display = 'block'; }
        closeCombModal();
    };

    window.closeCombModal = function() {
        document.getElementById('combModal').style.display = 'none';
        _combModalRow = null;
    };

    // DynamicWidgetRenderer mount — initial recordId bos, sqLoadQuote reload ile override eder.
    // React bundle (bootstrapLineGrid tarafindan dinamik yuklenir) hazir olmadan mount
    // denemesi sessizce basarisiz oluyordu — bu yuzden polling ile bekle.
    (function mountDynRenderer() {
        var el = document.getElementById('sqDynamicWidgets');
        if (!el) return;
        function tryMount() {
            if (window._sqDynRenderer) return true; // zaten mounted
            if (!window.CalibraHub || !window.CalibraHub.mountDynamicWidgetRenderer) return false;
            try {
                window._sqDynRenderer = window.CalibraHub.mountDynamicWidgetRenderer(el, {
                    formCode: el.getAttribute('data-form-code') || 'SALES_QUOTE_EDIT',
                    recordId: el.getAttribute('data-record-id') || '',
                    classPrefix: 'sqe'
                });
                console.log('[SQ] DynamicWidgetRenderer mounted');
                // Yuklenmis bir quote varsa recordId'yi guncelle — handleRef
                // hazir olunca reload eder.
                if (typeof currentQuoteId !== 'undefined' && currentQuoteId) {
                    sqReloadRenderer(String(currentQuoteId));
                }
                return true;
            } catch (e) {
                console.warn('[SQ] mountDynamicWidgetRenderer hatasi:', e);
                return false;
            }
        }
        if (tryMount()) return;
        // Bundle henuz hazir degil — bootstrapLineGrid async yukluyor — polling ile bekle.
        var tries = 0;
        var t = setInterval(function () {
            if (tryMount() || ++tries > 100) clearInterval(t);
        }, 50);
    })();

    // ── Widget API teshis probe'u ─────────────────────────────────
    // Bazi durumlarda widget'lar admin'de tanimli olsa bile Ek Alanlar panesinde
    // gorunmuyor (ornegin form DB'de yok, widget aktif degil, ya da farkli
    // sirketin tanimi). Probe /api/widgets API'sini dogrudan cagirip yaniti
    // konsola loglar ve bos durum mesajini duruma gore ozellestirir.
    window.sqProbeWidgets = async function () {
        var el = document.getElementById('sqDynamicWidgets');
        var msgEl = document.getElementById('sqWidgetEmptyMsg');
        var emptyEl = document.getElementById('sqWidgetEmpty');
        if (!el) return;
        var formCode = el.getAttribute('data-form-code') || 'SALES_QUOTE_EDIT';
        var recordId = el.getAttribute('data-record-id') || '';
        var probeUrl = '/api/widgets/forms/' + encodeURIComponent(formCode)
            + '/records/' + encodeURIComponent(recordId || '-');
        try {
            var resp = await fetch(probeUrl, { credentials: 'same-origin', headers: { 'Accept': 'application/json' } });
            if (resp.status === 404) {
                console.warn('[SQ probe] Form DB\'de bulunamadi — formCode=' + formCode);
                if (msgEl) msgEl.innerHTML =
                    '<div>"<strong>' + formCode + '</strong>" form kaydi veritabaninda bulunamadi.</div>'
                    + '<div style="margin-top:6px;">Widget Kayit ekranindan once formu tanimlayip aktiflestirin.</div>'
                    + '<div style="margin-top:10px;font-family:monospace;font-size:0.68rem;opacity:0.6;">API: GET ' + probeUrl + ' → 404</div>';
                if (emptyEl) emptyEl.classList.remove('is-hidden');
                return;
            }
            if (!resp.ok) {
                console.warn('[SQ probe] HTTP ' + resp.status + ' ' + probeUrl);
                if (msgEl) msgEl.innerHTML = 'API hatasi: HTTP ' + resp.status
                    + '<div style="margin-top:6px;font-family:monospace;font-size:0.68rem;opacity:0.6;">' + probeUrl + '</div>';
                if (emptyEl) emptyEl.classList.remove('is-hidden');
                return;
            }
            var data = await resp.json();
            var widgets = Array.isArray(data.widgets) ? data.widgets : [];
            var groups  = widgets.filter(function (w) { return w.dataType === 'group'; });
            var fields  = widgets.filter(function (w) { return w.dataType !== 'group'; });
            console.info('[SQ probe] formCode=' + formCode + ' formId=' + data.formId
                + ' widgets=' + widgets.length + ' groups=' + groups.length + ' fields=' + fields.length, widgets);

            // Parent-child baglantisini teshis et — orphan field'lari isaretle
            var groupIds = {};
            groups.forEach(function (g) { groupIds[String(g.id)] = g; });
            var orphans = fields.filter(function (f) {
                return f.parentId != null && !groupIds[String(f.parentId)];
            });

            // Diagnostic ozet (her seferinde gosterilir — sub-tab gorundugunde empty zaten gizlenir)
            var summary = '<div style="font-family:monospace;font-size:0.68rem;opacity:0.75;margin-top:10px;text-align:left;max-width:700px;margin-left:auto;margin-right:auto;">'
                + '<div><strong>Teshis:</strong> formCode=<code>' + formCode + '</code> formId=<code>' + (data.formId || '?') + '</code></div>'
                + '<div>Toplam widget: <code>' + widgets.length + '</code> — grup: <code>' + groups.length + '</code>, alan: <code>' + fields.length + '</code>'
                + (orphans.length > 0 ? ', <span style="color:#fca5a5">orphan: ' + orphans.length + '</span>' : '')
                + '</div>';
            if (widgets.length > 0) {
                summary += '<div style="margin-top:6px;opacity:0.8;"><strong>Linkage:</strong></div>';
                summary += '<div style="margin-top:2px;opacity:0.7;">';
                widgets.forEach(function (w) {
                    var isGroup = w.dataType === 'group';
                    var parentInfo = '';
                    if (!isGroup) {
                        if (w.parentId == null) parentInfo = ' parent=<code>null</code> (ungrouped)';
                        else if (groupIds[String(w.parentId)]) parentInfo = ' parent=<code>' + w.parentId + '</code>→' + groupIds[String(w.parentId)].label;
                        else parentInfo = ' <span style="color:#fca5a5">parent=<code>' + w.parentId + '</code> (ORPHAN — grup yok!)</span>';
                    }
                    summary += '<div>' + (isGroup ? '▼ GROUP' : '·') + ' id=<code>' + w.id + '</code> code=<code>' + w.widgetId + '</code> label="' + w.label + '" type=' + w.dataType + parentInfo + '</div>';
                });
                summary += '</div>';
            }
            // Renderer'in mevcut DOM durumu — loading / error / cards?
            var rendererRoot = document.getElementById('sqDynamicWidgets');
            summary += '<div style="margin-top:8px;opacity:0.8;"><strong>Renderer DOM:</strong></div>';
            if (!rendererRoot) {
                summary += '<div style="color:#fca5a5;">#sqDynamicWidgets bulunamadi</div>';
            } else {
                var errBlock = rendererRoot.querySelector('.sqe-rule-cycle, .sqe-dyn-error');
                var loadingBlock = rendererRoot.querySelector('.sqe-dyn-loading');
                var rootEl = rendererRoot.querySelector('[data-widget-renderer]');
                var cardEls = rendererRoot.querySelectorAll('[data-dyn-group-id]');
                summary += '<div style="font-size:0.66rem;opacity:0.75;">';
                summary += '  children: <code>' + rendererRoot.children.length + '</code>';
                summary += ', loading: <code>' + (loadingBlock ? 'yes' : 'no') + '</code>';
                summary += ', rootEl: <code>' + (rootEl ? 'yes' : 'no') + '</code>';
                summary += ', cards: <code>' + cardEls.length + '</code>';
                summary += '</div>';
                // React imperative handle'dan dogrudan state oku
                if (window._sqDynRenderer) {
                    var rh = window._sqDynRenderer;
                    var hwGetter = (typeof rh.getHasWidgets === 'function') ? rh.getHasWidgets() : '?';
                    var valCount = '?';
                    try { valCount = Object.keys((rh.getValues && rh.getValues()) || {}).length; } catch (_) {}
                    summary += '<div style="font-size:0.66rem;opacity:0.75;margin-top:2px;">';
                    summary += '  React handle: getHasWidgets=<code>' + hwGetter + '</code>';
                    summary += ', getValues.keys=<code>' + valCount + '</code>';
                    summary += ', reloadFn=<code>' + (typeof rh.reload === 'function' ? 'yes' : 'no') + '</code>';
                    summary += '</div>';
                } else {
                    // window._sqDynRenderer yok — ne kadar bundle hazir?
                    var ch = window.CalibraHub;
                    summary += '<div style="font-size:0.66rem;color:#fca5a5;margin-top:2px;">';
                    summary += 'window._sqDynRenderer yok — ';
                    summary += 'CalibraHub=<code>' + (typeof ch) + '</code>';
                    if (ch) {
                        summary += ', mountDynamicWidgetRenderer=<code>' + (typeof ch.mountDynamicWidgetRenderer) + '</code>';
                        summary += ', mountLineItemsGrid=<code>' + (typeof ch.mountLineItemsGrid) + '</code>';
                    }
                    summary += '</div>';
                    // Self-heal: bundle varsa hemen mount et
                    if (ch && typeof ch.mountDynamicWidgetRenderer === 'function') {
                        try {
                            window._sqDynRenderer = ch.mountDynamicWidgetRenderer(rendererRoot, {
                                formCode: rendererRoot.getAttribute('data-form-code') || 'SALES_QUOTE_EDIT',
                                recordId: rendererRoot.getAttribute('data-record-id') || '',
                                classPrefix: 'sqe'
                            });
                            summary += '<div style="font-size:0.66rem;color:#86efac;margin-top:2px;">Probe self-heal: mount tetiklendi — 500ms sonra tekrar yukle</div>';
                            setTimeout(function () {
                                if (typeof window.sqProbeWidgets === 'function') window.sqProbeWidgets();
                            }, 500);
                        } catch (mountErr) {
                            summary += '<div style="font-size:0.66rem;color:#fca5a5;margin-top:2px;">Self-heal mount hatasi: '
                                + (mountErr && mountErr.message ? mountErr.message : String(mountErr)) + '</div>';
                        }
                    }
                }
                if (errBlock) {
                    summary += '<div style="margin-top:6px;color:#fca5a5;"><strong>Renderer hata:</strong> '
                        + (errBlock.textContent || '').trim().substring(0, 400) + '</div>';
                }
                // Ilk 400 karakter renderer HTML'si — karti bulamadiysak React ne bastiysa goster
                if (rendererRoot.children.length > 0 && cardEls.length === 0) {
                    var htmlPreview = (rendererRoot.innerHTML || '').substring(0, 400);
                    summary += '<div style="margin-top:4px;color:#fca5a5;font-size:0.62rem;white-space:pre-wrap;word-break:break-all;">'
                        + 'HTML: ' + htmlPreview.replace(/</g, '&lt;') + '…</div>';
                }
            }
            summary += '</div>';

            if (widgets.length === 0) {
                if (msgEl) msgEl.innerHTML =
                    '<div>"<strong>' + formCode + '</strong>" formunda aktif widget bulunmuyor.</div>'
                    + '<div style="margin-top:6px;">Widget Kayit ekranindan ekleyip aktiflestirin.</div>'
                    + summary;
                if (emptyEl) emptyEl.classList.remove('is-hidden');
            } else if (fields.length === 0) {
                if (msgEl) msgEl.innerHTML =
                    '<div>"<strong>' + formCode + '</strong>" formunda sadece grup tanimlari var.</div>'
                    + '<div style="margin-top:6px;">Her grubun altina en az bir field widget ekleyin.</div>'
                    + summary;
                if (emptyEl) emptyEl.classList.remove('is-hidden');
            } else {
                // Widget tanimi DB'de var — render edilmis mi kontrol et.
                // Render oldu ise empty state'i tamamen gizle; olmadiysa "bekleniyor +
                // teshis" goster (race: API dondu, React henuz basmadi).
                var rendererEl2 = document.getElementById('sqDynamicWidgets');
                var hasCards = rendererEl2 && rendererEl2.querySelectorAll('[data-dyn-group-id]').length > 0;
                if (hasCards) {
                    console.info('[SQ probe] ' + fields.length + ' field widget render edildi');
                    if (emptyEl) emptyEl.classList.add('is-hidden');
                } else {
                    console.info('[SQ probe] ' + fields.length + ' field widget bekleniyor — renderer bassinca gorunecek');
                    if (msgEl) msgEl.innerHTML =
                        '<div>Widget tanimlari alindi, renderer hazirlaniyor…</div>'
                        + summary;
                    if (emptyEl) emptyEl.classList.remove('is-hidden');
                    // Kisa suredur bir sonraki cycle'da kontrol et — React render edince gizlensin.
                    setTimeout(function () {
                        var cardsNow = rendererEl2 && rendererEl2.querySelectorAll('[data-dyn-group-id]').length;
                        if (cardsNow > 0 && emptyEl) emptyEl.classList.add('is-hidden');
                    }, 400);
                }
            }
        } catch (err) {
            console.warn('[SQ probe] hatasi:', err);
            if (msgEl) msgEl.innerHTML = 'API cagrisi basarisiz: ' + (err && err.message ? err.message : err);
            if (emptyEl) emptyEl.classList.remove('is-hidden');
        }
    };
    // Probe'u mount sonrasi tetikle — renderer fetch'i paralel yapiyor zaten,
    // bizim probe sadece teshis amacli.
    setTimeout(window.sqProbeWidgets, 200);

    // "Yeniden yukle" butonu: renderer'a reload sinyali + probe tekrar.
    window.sqReloadWidgets = function () {
        try {
            if (window._sqDynRenderer && window._sqDynRenderer.reload) {
                window._sqDynRenderer.reload({ recordId: currentQuoteId ? String(currentQuoteId) : '' });
            }
        } catch (e) { /* ignore */ }
        setTimeout(window.sqProbeWidgets, 200);
    };

    /* ──────────────────────────────────────────────────────────────
       Widget gruplarini "Ek Alanlar" panesinin icindeki yatay alt
       sekmelere donustur. Statik "Ek Alanlar" ust sekmesi ayni yerde
       kalir; secilince acilan panelde her widget grubu bir alt sekme
       olur (ParentId=null olan field'lar __ungrouped -> "Ek Alanlar"
       etiketli varsayilan alt sekmede gosterilir).
       ────────────────────────────────────────────────────────────── */
    // Grup basligindaki pill'e tiklandiginda hem aktif pill guncellenir hem
    // ilgili grup kartinin yanina scroll yapilir. Gruplar artik dikey olarak
    // Sub-tab pill bar kaldirildi — kullanici her grup basligi bir kez
    // gorunsun istedi. Gruplar dikey alt alta stacked; her biri kendi
    // <summary> section header'i ile basilir (sqe-widget-wrap CSS).
    // sqShowOnlyWidgetGroup / sqInjectWidgetSubTabs artik no-op — eski
    // scroll-to API'si kirilsin diye bos stub tutulur.
    function sqShowOnlyWidgetGroup(gid) { /* no-op: pill bar kaldirildi */ }
    function sqInjectWidgetSubTabs() {
        var rendererEl = document.getElementById('sqDynamicWidgets');
        var emptyEl = document.getElementById('sqWidgetEmpty');
        if (!rendererEl) return false;
        var cards = rendererEl.querySelectorAll('[data-dyn-group-id]');
        if (cards.length > 0 && emptyEl) emptyEl.classList.add('is-hidden');
        return cards.length > 0;
    }

    // Renderer mount + schema load asenkron — MutationObserver ile kartlari bekle.
    (function observeRenderer() {
        var rendererEl = document.getElementById('sqDynamicWidgets');
        if (!rendererEl) return;
        var done = false;
        function tryInject() {
            if (done) return;
            if (sqInjectWidgetSubTabs()) { done = true; }
        }
        // Initial poll (cached schema hemen render olabilir)
        var attempts = 0;
        var timer = setInterval(function () {
            if (done || ++attempts > 50) { clearInterval(timer); return; }
            tryInject();
        }, 150);
        // MutationObserver — reload (recordId degisimi) sonrasi tekrar inject
        var obs = new MutationObserver(function () {
            var cards = rendererEl.querySelectorAll('[data-dyn-group-id]');
            if (cards.length > 0) {
                done = false;
                tryInject();
            }
        });
        obs.observe(rendererEl, { childList: true, subtree: true });
    })();
})();
</script>
}

<!-- Kombinasyon Secim Modal -->
<div id="combModal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:9999;background:rgba(0,0,0,0.4);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:12px;width:680px;max-height:80vh;display:flex;flex-direction:column;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
        <div style="display:flex;align-items:center;padding:12px 16px;border-bottom:1px solid #e2e8f0;">
            <h4 style="margin:0;font-size:0.92rem;font-weight:700;flex:1;">Kombinasyon Secimi</h4>
            <button type="button" onclick="closeCombModal()" style="border:none;background:none;font-size:1.2rem;cursor:pointer;color:#94a3b8;">&times;</button>
        </div>
        <div style="display:flex;gap:0;border-bottom:1px solid #e2e8f0;">
            <button type="button" class="comb-tab-btn active" data-tab="list" onclick="showCombTab('list')" style="flex:1;padding:8px;font-size:0.78rem;font-weight:600;border:none;border-bottom:2px solid transparent;background:none;cursor:pointer;">Mevcut Kombinasyonlar</button>
            <button type="button" class="comb-tab-btn" data-tab="features" onclick="showCombTab('features')" style="flex:1;padding:8px;font-size:0.78rem;font-weight:600;border:none;border-bottom:2px solid transparent;background:none;cursor:pointer;">Ozelliklerden Sec</button>
        </div>
        <div style="flex:1;overflow-y:auto;padding:12px 16px;">
            <!-- Tab 1: Mevcut Kombinasyonlar -->
            <div id="combTabList">
                <table style="width:100%;font-size:0.78rem;border-collapse:collapse;">
                    <thead><tr style="border-bottom:2px solid #e2e8f0;"><th style="padding:4px 8px;text-align:left;color:#64748b;">Kod</th><th style="padding:4px 8px;text-align:left;color:#64748b;">Ozellikler</th><th style="width:60px;"></th></tr></thead>
                    <tbody id="combListBody"></tbody>
                </table>
            </div>
            <!-- Tab 2: Ozelliklerden Sec -->
            <div id="combTabFeatures" style="display:none;">
                <div id="combFeatBody"></div>
                <div style="margin-top:12px;text-align:right;">
                    <button type="button" onclick="applyCombFeatures()" class="btn btn-primary btn-sm" style="font-size:0.78rem;">Uygula</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.comb-tab-btn.active { border-bottom-color: #2563eb !important; color: #2563eb; }
#combListBody tr:hover { background: #f8fafc; }
</style>
