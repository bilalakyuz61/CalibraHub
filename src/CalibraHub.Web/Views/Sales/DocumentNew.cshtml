@model CalibraHub.Web.Models.Sales.DocumentEditViewModel
@{
    ViewData["Title"] = "Yeni Satış Teklifi";
    ViewData["FormCode"] = "SALES_QUOTE_NEW";
    ViewData["BodyClass"] = "page-sales-quote-new";
}

@section Styles {
<style>
/* ═══════════════════════════════════════════════════════════════
   WIZARD — Satış Teklifi Oluşturma Sihirbazı
   Tasarım: Premium dark-uyumlu, animasyonlu adım geçişleri.
   ═══════════════════════════════════════════════════════════════ */

/* Tam yükseklik kapsayıcı */
.page-sales-quote-new .integrator-dashboard {
    height: 100% !important;
    min-height: 0 !important;
    padding: 0 !important;
    max-width: none !important;
    background: transparent !important;
    box-shadow: none !important;
    border: none !important;
    border-radius: 0 !important;
}
.page-sales-quote-new .integrator-dashboard__content {
    display: flex !important;
    flex-direction: column !important;
    width: 100% !important;
    max-width: none !important;
    min-height: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
    overflow: hidden !important;
}
.workspace-frame-body.page-sales-quote-new .app-content-area--workspace-frame {
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
}
.workspace-frame-body.page-sales-quote-new .integrator-dashboard {
    flex: 1 1 auto;
    min-height: 0;
    height: 100%;
}

/* ── Stepper / Header ── */
.wiz-header {
    flex: 0 0 auto;
    background: var(--app-surface, #fff);
    border-bottom: 1px solid var(--app-border, #e2e8f0);
    padding: 0 24px;
    position: relative;
}
.wiz-stepper {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 16px 0 12px;
    gap: 0;
    max-width: 700px;
    margin: 0 auto;
}
.wiz-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    flex: 1;
    position: relative;
    cursor: default;
}
/* Connector line */
.wiz-step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 18px;
    left: calc(50% + 20px);
    right: calc(-50% + 20px);
    height: 2px;
    background: var(--app-border, #e2e8f0);
    transition: background 0.4s ease;
    z-index: 0;
}
.wiz-step.is-done:not(:last-child)::after {
    background: #10b981;
}
/* Dot circle */
.wiz-step__dot {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.82rem;
    font-weight: 700;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    z-index: 1;
    background: var(--app-muted-surface, #f1f5f9);
    color: #94a3b8;
    border: 2px solid var(--app-border, #e2e8f0);
}
.wiz-step.is-active .wiz-step__dot {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 4px 14px rgba(99, 102, 241, 0.45);
    transform: scale(1.12);
}
.wiz-step.is-done .wiz-step__dot {
    background: #10b981;
    color: #fff;
    border-color: transparent;
    box-shadow: 0 4px 10px rgba(16, 185, 129, 0.35);
}
.wiz-step__label {
    font-size: 0.72rem;
    font-weight: 600;
    color: #94a3b8;
    text-align: center;
    line-height: 1.3;
    transition: color 0.25s;
    white-space: nowrap;
}
.wiz-step.is-active .wiz-step__label { color: #6366f1; }
.wiz-step.is-done .wiz-step__label { color: #10b981; }

/* Check mark SVG for done steps */
.wiz-check-icon { display: none; }
.wiz-step.is-done .wiz-check-icon { display: block; }
.wiz-step.is-done .wiz-step-num { display: none; }

/* ── Panels Container ── */
.wiz-panels-wrap {
    flex: 1 1 auto;
    min-height: 0;
    position: relative;
    overflow: hidden;
}
.wiz-panel {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    opacity: 0;
    pointer-events: none;
    transform: translateX(28px);
    transition: opacity 0.25s ease, transform 0.25s ease;
}
.wiz-panel.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
    z-index: 1;
}
.wiz-panel.slide-back {
    transform: translateX(-28px);
}
/* Center panel content */
.wiz-panel-inner {
    max-width: 780px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

/* ── Navigation Footer ── */
.wiz-nav-footer {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    background: var(--app-surface, #fff);
    border-top: 1px solid var(--app-border, #e2e8f0);
    gap: 12px;
}
.wiz-progress {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    justify-content: center;
}
.wiz-progress__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--app-border, #e2e8f0);
    transition: all 0.25s ease;
}
.wiz-progress__dot.is-active {
    background: #6366f1;
    width: 24px;
    border-radius: 4px;
}
.wiz-progress__dot.is-done {
    background: #10b981;
}
.wiz-btn-nav {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.18s ease;
    border: 1.5px solid transparent;
}
.wiz-btn-back {
    background: transparent;
    border-color: var(--app-border, #e2e8f0);
    color: var(--app-text-muted, #64748b);
}
.wiz-btn-back:hover { background: var(--app-muted-surface, #f8fafc); }
.wiz-btn-back:disabled { opacity: 0.4; cursor: default; }
.wiz-btn-next {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.35);
}
.wiz-btn-next:hover { box-shadow: 0 6px 18px rgba(99, 102, 241, 0.45); transform: translateY(-1px); }
.wiz-btn-next:active { transform: translateY(0); }
.wiz-btn-save {
    background: linear-gradient(135deg, #10b981, #059669);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.35);
}
.wiz-btn-save:hover { box-shadow: 0 6px 18px rgba(16, 185, 129, 0.45); transform: translateY(-1px); }

/* ── Section heading inside panel ── */
.wiz-section-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--app-text, #334155);
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.wiz-section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--app-border-light, #e9eef5);
}

/* ── Form card ── */
.wiz-card {
    background: var(--app-surface, #fff);
    border: 1px solid var(--app-border, #d4dfeb);
    border-radius: 14px;
    box-shadow: 0 4px 18px rgba(15, 23, 42, 0.05);
    overflow: hidden;
}
.wiz-card__body { padding: 20px; }

/* ── Form grid ── */
.wiz-form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
}
.wiz-form-field label.wiz-label {
    display: block;
    margin-bottom: 5px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--app-text-muted, #64748b);
}
.wiz-form-field--full { grid-column: 1 / -1; }

/* ── Horizontal form (etiket yanında alan) ── */
.wiz-hform {
    display: flex; flex-direction: column; gap: 8px;
    padding: 4px 0; max-width: 560px;
}
.wiz-hrow {
    display: flex; align-items: center; gap: 12px; min-height: 32px;
}
.wiz-hlabel {
    flex: 0 0 120px; text-align: left;
    font-size: 0.75rem; font-weight: 600;
    color: var(--app-text-muted, #64748b);
    white-space: nowrap; user-select: none;
}
body.app-theme-dark .wiz-hlabel {
    color: rgba(255,255,255,.7);
}
.wiz-hinput {
    flex: 1; max-width: 280px;
}
.wiz-hinput[type="date"] {
    max-width: 160px;
}
.wiz-hlabel--link {
    cursor: pointer; text-decoration: underline dotted; text-underline-offset: 3px;
    text-decoration-color: rgba(99,102,241,.4);
}
.wiz-hlabel--link:hover {
    color: #6366f1; text-decoration-color: #6366f1;
}

/* ── Customer selector card ── */
.wiz-customer-select {
    border: 2px dashed var(--app-border, #d4dfeb);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s;
}
.wiz-customer-select:focus-within { border-color: #6366f1; border-style: solid; }

/* ── Step 2: Products ── */
.wiz-products-card .wiz-card__body { padding: 0; }
#wizReactGrid { min-height: 240px; }
.wiz-line-totals {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    padding: 10px 20px 14px;
    border-top: 1px solid var(--app-border-light, #e9eef5);
    font-size: 0.84rem;
}
.wiz-total-row { display: flex; gap: 16px; align-items: center; }
.wiz-total-lbl { color: var(--app-text-muted, #64748b); font-weight: 600; min-width: 120px; text-align: right; }
.wiz-total-val { font-weight: 700; min-width: 100px; text-align: right; color: var(--app-text, #1e293b); }
.wiz-grand-total .wiz-total-lbl,
.wiz-grand-total .wiz-total-val { color: #4f46e5; font-size: 1rem; }

/* ── Step 4: Summary ── */
.wiz-summary-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    border-bottom: 1px solid var(--app-border-light, #e9eef5);
}
.wiz-summary-avatar {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.4rem;
    font-weight: 700;
    flex-shrink: 0;
}
.wiz-summary-name { font-size: 1rem; font-weight: 700; color: var(--app-text, #1e293b); }
.wiz-summary-meta { font-size: 0.8rem; color: var(--app-text-muted, #64748b); margin-top: 2px; }
.wiz-meta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--app-border-light, #e9eef5);
}
.wiz-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.76rem;
    font-weight: 600;
    background: var(--app-muted-surface, #f1f5f9);
    color: var(--app-text-muted, #64748b);
    border: 1px solid var(--app-border, #e2e8f0);
}
.wiz-chip--accent { background: #ede9fe; color: #6d28d9; border-color: #ddd6fe; }
.wiz-lines-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
}
.wiz-lines-table th {
    padding: 8px 12px;
    text-align: left;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--app-text-muted, #64748b);
    border-bottom: 2px solid var(--app-border, #e2e8f0);
    background: var(--app-muted-surface, #f8fafc);
}
.wiz-lines-table td {
    padding: 9px 12px;
    border-bottom: 1px solid var(--app-border-light, #f1f5f9);
    vertical-align: middle;
}
.wiz-lines-table tr:last-child td { border-bottom: none; }
.wiz-lines-table .td-num { text-align: right; font-variant-numeric: tabular-nums; }
.wiz-lines-table .td-total { font-weight: 700; color: #4f46e5; text-align: right; }
.wiz-summary-totals {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-end;
    padding: 14px 20px;
    border-top: 1px solid var(--app-border, #e2e8f0);
}
.wiz-s-total-row { display: flex; gap: 20px; font-size: 0.84rem; }
.wiz-s-total-row .lbl { color: var(--app-text-muted, #64748b); min-width: 130px; text-align: right; }
.wiz-s-total-row .val { font-weight: 700; min-width: 90px; text-align: right; }
.wiz-s-grand { font-size: 1.05rem; }
.wiz-s-grand .lbl, .wiz-s-grand .val { color: #4f46e5; }

/* ── Empty lines warning ── */
.wiz-empty-warn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-radius: 10px;
    background: #fff7ed;
    border: 1px solid #fed7aa;
    color: #c2410c;
    font-size: 0.84rem;
    font-weight: 600;
}

/* ── Validation error highlight ── */
.form-control.is-invalid, .form-select.is-invalid {
    border-color: #f87171 !important;
    box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.18);
}
.wiz-field-error {
    font-size: 0.74rem;
    color: #ef4444;
    margin-top: 3px;
    display: none;
}
.wiz-field-error.visible { display: block; }

/* ── Success overlay ── */
.wiz-success-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.55);
    display: none;
    align-items: center;
    justify-content: center;
}
.wiz-success-overlay.visible { display: flex; }
.wiz-success-box {
    background: var(--app-surface, #fff);
    border-radius: 20px;
    padding: 40px 44px;
    text-align: center;
    max-width: 380px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    animation: successPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@@keyframes successPop {
    from { transform: scale(0.85); opacity: 0; }
    to   { transform: scale(1);    opacity: 1; }
}
.wiz-success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #10b981, #059669);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.4);
}
.wiz-success-title { font-size: 1.15rem; font-weight: 800; margin-bottom: 6px; color: var(--app-text, #1e293b); }
.wiz-success-sub { font-size: 0.85rem; color: var(--app-text-muted, #64748b); margin-bottom: 22px; }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">

    <!-- ════════════════════ STEP INDICATOR ════════════════════ -->
    <div class="wiz-header">
        <div class="wiz-stepper" id="wizStepper">
            <!-- Step 1 -->
            <div class="wiz-step is-active" data-wiz-step="1">
                <div class="wiz-step__dot">
                    <svg class="wiz-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="wiz-step-num">1</span>
                </div>
                <div class="wiz-step__label">Müşteri &amp;<br>Genel</div>
            </div>
            <!-- Step 2 -->
            <div class="wiz-step" data-wiz-step="2">
                <div class="wiz-step__dot">
                    <svg class="wiz-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="wiz-step-num">2</span>
                </div>
                <div class="wiz-step__label">Ürünler</div>
            </div>
            <!-- Step 3 -->
            <div class="wiz-step" data-wiz-step="3">
                <div class="wiz-step__dot">
                    <svg class="wiz-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="wiz-step-num">3</span>
                </div>
                <div class="wiz-step__label">Koşullar &amp;<br>Notlar</div>
            </div>
            <!-- Step 4 -->
            <div class="wiz-step" data-wiz-step="4">
                <div class="wiz-step__dot">
                    <svg class="wiz-check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="wiz-step-num">4</span>
                </div>
                <div class="wiz-step__label">Özet &amp;<br>Kaydet</div>
            </div>
        </div>
    </div>

    <!-- ════════════════════ PANELS ════════════════════ -->
    <div class="wiz-panels-wrap">

        <!-- ── ADIM 1: Müşteri & Genel Bilgiler ── -->
        <div class="wiz-panel is-active" data-panel="1">
            <div class="wiz-panel-inner">
                <div class="wiz-card">
                    <div class="wiz-card__body">
                        <div class="wiz-hform">
                            <div class="wiz-hrow">
                                <label class="wiz-hlabel wiz-hlabel--link" title="Cari karta gitmek icin cift tiklayin" ondblclick="wizGoToCustomerCard()">Cari Kod <span style="color:#ef4444">*</span></label>
                                <input type="text" id="wizCustomerDisplay" class="form-control form-control-sm wiz-hinput" readonly placeholder="Rehberden seciniz" />
                                <input type="hidden" id="wizCustomerId" />
                            </div>
                            <div class="wiz-hrow">
                                <label class="wiz-hlabel">Cari Isim</label>
                                <input type="text" id="wizCustomerName" class="form-control form-control-sm wiz-hinput" readonly placeholder="Cari secildiginde otomatik dolar" />
                            </div>
                            <div class="wiz-field-error" id="errCustomer" style="margin-left:122px;">Lütfen bir müşteri seçiniz.</div>
                            <div class="wiz-hrow">
                                <label class="wiz-hlabel">Tarih <span style="color:#ef4444">*</span></label>
                                <input id="wizQuoteDate" type="date" class="form-control form-control-sm wiz-hinput" />
                            </div>
                            <div class="wiz-field-error" id="errDate" style="margin-left:122px;">Tarih zorunludur.</div>
                            <div class="wiz-hrow">
                                <label class="wiz-hlabel">Gecerlilik</label>
                                <input id="wizValidUntil" type="date" class="form-control form-control-sm wiz-hinput" />
                            </div>
                            <div class="wiz-hrow">
                                <label class="wiz-hlabel">Para Birimi</label>
                                <select id="wizCurrency" class="form-select form-select-sm wiz-hinput" style="max-width:120px;">
                                    <option value="TRY">TRY — Türk Lirası</option>
                                    <option value="USD">USD — Dolar</option>
                                    <option value="EUR">EUR — Euro</option>
                                </select>
                            </div>
                            <div class="wiz-hrow">
                                <label class="wiz-hlabel">Temsilci</label>
                                <select id="wizSalesRepId" class="form-select form-select-sm wiz-hinput">
                                    <option value="">— Seçiniz —</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── ADIM 2: Ürünler (CalibraLineItemsGrid) ── -->
        <div class="wiz-panel" data-panel="2">
            <div class="wiz-panel-inner">
                <p class="wiz-section-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    Ürün / Hizmet Kalemleri
                </p>
                <div class="wiz-card wiz-products-card">
                    <div class="wiz-card__body" style="padding:0;">
                        <div id="wizReactGrid" style="min-height:260px;"></div>
                        <div class="wiz-line-totals">
                            <div class="wiz-total-row">
                                <span class="wiz-total-lbl">Ara Toplam:</span>
                                <span class="wiz-total-val" id="wizSubTotal">0,00</span>
                            </div>
                            <div class="wiz-total-row">
                                <span class="wiz-total-lbl">İskonto %</span>
                                <input id="wizDiscountRate" type="number" class="form-control form-control-sm" value="0" min="0" max="100" step="0.01" style="width:68px;text-align:right;" oninput="wizRecalc()" />
                                <span class="wiz-total-val" id="wizDiscountAmt">0,00</span>
                            </div>
                            <div class="wiz-total-row">
                                <span class="wiz-total-lbl">KDV %</span>
                                <input id="wizTaxRate" type="number" class="form-control form-control-sm" value="20" min="0" max="100" step="0.01" style="width:68px;text-align:right;" oninput="wizRecalc()" />
                                <span class="wiz-total-val" id="wizTaxAmt">0,00</span>
                            </div>
                            <div class="wiz-total-row wiz-grand-total" style="margin-top:4px;padding-top:6px;border-top:1.5px solid #e2e8f0;">
                                <span class="wiz-total-lbl">Genel Toplam:</span>
                                <span class="wiz-total-val" id="wizGrandTotal">0,00</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="wizLinesWarn" class="wiz-empty-warn" style="display:none;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    En az bir ürün kalemi eklemelisiniz.
                </div>
            </div>
        </div>

        <!-- ── ADIM 3: Koşullar & Notlar ── -->
        <div class="wiz-panel" data-panel="3">
            <div class="wiz-panel-inner">
                <p class="wiz-section-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                    Ticari Koşullar
                </p>
                <div class="wiz-card">
                    <div class="wiz-card__body">
                        <div class="wiz-form-grid">
                            <div class="wiz-form-field wiz-form-field--full">
                                <label class="wiz-label">Ödeme Koşulu</label>
                                <input id="wizPaymentTerms" class="form-control form-control-sm" placeholder="örneğin: 30 gün vadeli" />
                            </div>
                            <div class="wiz-form-field wiz-form-field--full">
                                <label class="wiz-label">Teslimat Koşulu</label>
                                <input id="wizDeliveryTerms" class="form-control form-control-sm" placeholder="örneğin: Fabrika teslim (EXW)" />
                            </div>
                            <div class="wiz-form-field wiz-form-field--full">
                                <label class="wiz-label">Teslimat Adresi</label>
                                <input id="wizDeliveryAddress" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <p class="wiz-section-title" style="margin-top:4px;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Notlar
                </p>
                <div class="wiz-card">
                    <div class="wiz-card__body">
                        <div class="wiz-form-field">
                            <label class="wiz-label">Teklif Notu</label>
                            <textarea id="wizNotes" class="form-control" rows="5" placeholder="Teklife özel notlarınızı buraya yazabilirsiniz..."></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── ADIM 4: Özet & Kaydet ── -->
        <div class="wiz-panel" data-panel="4">
            <div class="wiz-panel-inner">
                <p class="wiz-section-title">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    Teklif Özeti
                </p>

                <div class="wiz-card" id="wizSummaryCard">
                    <!-- JS tarafından dolduruluyor -->
                    <div class="wiz-summary-header" id="wizSummaryHeader"></div>
                    <div class="wiz-meta-chips" id="wizSummaryChips"></div>
                    <div style="overflow-x:auto;">
                        <table class="wiz-lines-table" id="wizSummaryTable">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Malzeme</th>
                                    <th>Birim</th>
                                    <th class="td-num">Miktar</th>
                                    <th class="td-num">Birim Fiyat</th>
                                    <th class="td-num">İsk.%</th>
                                    <th class="td-total">Satır Top.</th>
                                </tr>
                            </thead>
                            <tbody id="wizSummaryLines"></tbody>
                        </table>
                    </div>
                    <div class="wiz-summary-totals" id="wizSummaryTotals"></div>
                </div>
            </div>
        </div>

    </div><!-- /wiz-panels-wrap -->

    <!-- ════════════════════ NAV FOOTER ════════════════════ -->
    <div class="wiz-nav-footer">
        <button class="wiz-btn-nav wiz-btn-back" id="wizBtnBack" onclick="wizNav(-1)" disabled>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            Geri
        </button>
        <div class="wiz-progress" id="wizProgress">
            <div class="wiz-progress__dot is-active" data-prog="1"></div>
            <div class="wiz-progress__dot" data-prog="2"></div>
            <div class="wiz-progress__dot" data-prog="3"></div>
            <div class="wiz-progress__dot" data-prog="4"></div>
        </div>
        <button class="wiz-btn-nav wiz-btn-next" id="wizBtnNext" onclick="wizNav(1)">
            Devam Et
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
    </div>

</section>

<!-- ════════════════════ SUCCESS OVERLAY ════════════════════ -->
<div class="wiz-success-overlay" id="wizSuccessOverlay">
    <div class="wiz-success-box">
        <div class="wiz-success-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="wiz-success-title">Teklif Oluşturuldu!</div>
        <div class="wiz-success-sub" id="wizSuccessSub">Teklif numarası atanıyor...</div>
        <div style="color:#94a3b8;font-size:0.8rem;">Düzenleme sayfasına yönlendiriliyorsunuz...</div>
    </div>
</div>

@section Scripts {
<script>
    // ══════════════════════════════════════════════════════════════
    // CalibraLineItemsGrid inline config (server-side hazırlandı)
    // ══════════════════════════════════════════════════════════════
    window.__CALIBRA_SALES_QUOTE_LINE_GRID__ = @Html.Raw(Model.LineGridConfigJson);
</script>
<script>
(function () {
    'use strict';

    // ── State ─────────────────────────────────────────────────────
    var wiz = {
        current: 1,
        total: 4,
        gridMounted: false,
        gridReady: false,
        pendingRows: null,
        customers: [],
        salesReps: [],
    };
    window.__WIZ_LINES__ = [];

    // ── DOM helpers ───────────────────────────────────────────────
    function $id(id)  { return document.getElementById(id); }
    function fmt(v)   { return (v || 0).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
    function esc(s)   { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

    // ── Init ──────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        // Bugünü tarih alanına yaz
        $id('wizQuoteDate').value = new Date().toISOString().split('T')[0];

        (async function () {
            try { await loadSalesReps(); } catch (e) { console.error('[Wiz] salesReps:', e); }
            // Müşteri rehber butonu — React bundle yüklendikten sonra bağla
            attachCustomerGuide();
        })();

        wizUpdateStepper();
        wizUpdateFooter();
    });

    // ── Data loaders ──────────────────────────────────────────────
    window.wizGoToCustomerCard = function () {
        var custId = $id('wizCustomerId').value
        if (!custId) return
        window.location.href = '/Finance/ContactEdit?id=' + custId
    }

    function attachCustomerGuide() {
        function tryAttach() {
            if (window.CalibraHub && window.CalibraHub.attachGuide) {
                window.CalibraHub.attachGuide('#wizCustomerDisplay', 'CUSTOMERS', {
                    formCode: 'SALES_QUOTE_NEW',
                    fillMap: { '#wizCustomerId': 'Id', '#wizCustomerName': 'AccountTitle' }
                });
                // Seçim yapılınca hidden input'a id yaz
                var display = $id('wizCustomerDisplay');
                display.addEventListener('change', function () {
                    var val = display.getAttribute('data-value') || '';
                    // Guide value = AccountCode, Id fillMap ile #wizCustomerId'ye yazılıyor
                });
                return true;
            }
            return false;
        }
        if (tryAttach()) return;

        // React bundle henüz yüklenmemiş — bundle'ı yükle sonra bağla
        var BUNDLE_URL = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
        var CSS_URL    = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';

        if (!document.querySelector('link[data-wiz-css]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet'; link.href = CSS_URL;
            link.setAttribute('data-wiz-css', '1');
            document.head.appendChild(link);
        }

        if (!document.querySelector('script[data-wiz-js]')) {
            var s = document.createElement('script');
            s.src = BUNDLE_URL;
            s.setAttribute('data-wiz-js', '1');
            s.onload = function () { setTimeout(tryAttach, 50); };
            document.head.appendChild(s);
        } else {
            // Script zaten yükleniyor, bekle
            var t = setInterval(function () {
                if (tryAttach()) clearInterval(t);
            }, 100);
            setTimeout(function () { clearInterval(t); }, 10000);
        }
    }

    async function loadSalesReps() {
        var resp = await fetch('/GeneralDefinitions/GetSalesReps');
        if (!resp.ok) return;
        var reps = await resp.json();
        var sel = $id('wizSalesRepId');
        sel.innerHTML = '<option value="">— Seçiniz —</option>';
        reps.forEach(function (r) {
            if (!r.isActive) return;
            var opt = document.createElement('option');
            opt.value = r.id;
            opt.textContent = r.repCode + ' — ' + r.repName;
            sel.appendChild(opt);
        });
    }

    // ── React Grid Bootstrap ──────────────────────────────────────
    function bootstrapLineGrid() {
        if (wiz.gridMounted) return;
        wiz.gridMounted = true;

        var BUNDLE_URL = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
        var CSS_URL    = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';

        function mountGrid() {
            var el = $id('wizReactGrid');
            if (!el) { console.error('[Wiz] grid mount element yok'); return; }
            if (!window.CalibraHub || !window.CalibraHub.mountLineItemsGrid) {
                console.error('[Wiz] mountLineItemsGrid yok'); return;
            }
            try {
                window.CalibraHub.mountLineItemsGrid(el, window.__CALIBRA_SALES_QUOTE_LINE_GRID__, {
                    onRowsChange: function (rows) {
                        window.__WIZ_LINES__ = rows || [];
                        wizRecalc();
                    }
                });
                // Imperative API bekle
                var tries = 0;
                var t = setInterval(function () {
                    if (window.CalibraHub && window.CalibraHub.salesLineGrid) {
                        clearInterval(t);
                        wiz.gridReady = true;
                        if (wiz.pendingRows) {
                            window.CalibraHub.salesLineGrid.setRows(wiz.pendingRows);
                            wiz.pendingRows = null;
                        } else {
                            // Boş başlangıç satırı
                            window.CalibraHub.salesLineGrid.setRows([{
                                materialCode: '', materialName: '', unitName: '',
                                quantity: 1, unitPrice: 0, discountRate: 0, notes: null
                            }]);
                        }
                        console.log('[Wiz] line grid hazır');
                    } else if (++tries > 60) {
                        clearInterval(t); console.error('[Wiz] grid API zaman aşımı');
                    }
                }, 20);
            } catch (ex) { console.error('[Wiz] grid mount exception:', ex); }
        }

        if (!document.querySelector('link[data-wiz-css]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet'; link.href = CSS_URL;
            link.setAttribute('data-wiz-css', '1');
            document.head.appendChild(link);
        }

        if (window.CalibraHub && window.CalibraHub.mountLineItemsGrid) {
            mountGrid();
        } else {
            var s = document.createElement('script');
            s.src = BUNDLE_URL;
            s.setAttribute('data-wiz-js', '1');
            s.onload = function () { setTimeout(mountGrid, 0); };
            s.onerror = function () { console.error('[Wiz] bundle yüklenemedi'); };
            document.head.appendChild(s);
        }
    }

    // ── Recalc totals ─────────────────────────────────────────────
    window.wizRecalc = function () {
        var lines = window.__WIZ_LINES__ || [];
        var sub = 0;
        lines.forEach(function (r) {
            var lt = Number(r.lineTotal);
            if (isNaN(lt) || !isFinite(lt)) {
                lt = (Number(r.quantity)||0) * (Number(r.unitPrice)||0) * (1 - (Number(r.discountRate)||0)/100);
            }
            sub += lt;
        });
        var dRate  = parseFloat($id('wizDiscountRate').value || 0);
        var tRate  = parseFloat($id('wizTaxRate').value || 0);
        var dAmt   = sub * (dRate / 100);
        var after  = sub - dAmt;
        var tAmt   = after * (tRate / 100);
        var grand  = after + tAmt;
        $id('wizSubTotal').textContent   = fmt(sub);
        $id('wizDiscountAmt').textContent = fmt(dAmt);
        $id('wizTaxAmt').textContent      = fmt(tAmt);
        $id('wizGrandTotal').textContent  = fmt(grand);
    };

    // ── Validation ────────────────────────────────────────────────
    function wizValidate(step) {
        var ok = true;
        if (step === 1) {
            // Cari kod zorunlu (Id veya AccountCode'dan biri dolu olmali)
            var custId = $id('wizCustomerId').value;
            var custCode = ($id('wizCustomerDisplay').value || '').trim();
            var cErr = $id('errCustomer');
            var custInput = $id('wizCustomerDisplay');
            if (!custId && !custCode) {
                custInput.classList.add('is-invalid');
                cErr.classList.add('visible');
                ok = false;
            } else {
                custInput.classList.remove('is-invalid');
                cErr.classList.remove('visible');
            }
            // Tarih zorunlu
            var dt = $id('wizQuoteDate').value;
            var dErr = $id('errDate');
            if (!dt) {
                $id('wizQuoteDate').classList.add('is-invalid');
                dErr.classList.add('visible');
                ok = false;
            } else {
                $id('wizQuoteDate').classList.remove('is-invalid');
                dErr.classList.remove('visible');
            }
        }
        if (step === 2) {
            // En az 1 satır materialCode dolu olmalı
            var lines = window.__WIZ_LINES__ || [];
            if (window.CalibraHub && window.CalibraHub.salesLineGrid) {
                try { lines = window.CalibraHub.salesLineGrid.getRows() || lines; } catch (e) {}
            }
            var hasLine = lines.some(function (r) { return r && r.materialCode; });
            $id('wizLinesWarn').style.display = hasLine ? 'none' : 'flex';
            if (!hasLine) ok = false;
        }
        return ok;
    }

    // ── Navigation ────────────────────────────────────────────────
    window.wizNav = function (direction) {
        var target = wiz.current + direction;
        if (target < 1 || target > wiz.total) return;

        // Validate current before going forward
        if (direction > 0 && !wizValidate(wiz.current)) return;

        // Mount grid on first visit to step 2
        if (target === 2 && !wiz.gridMounted) bootstrapLineGrid();

        // Build summary when entering step 4
        if (target === 4) wizBuildSummary();

        var curPanel = document.querySelector('.wiz-panel.is-active');
        var nxtPanel = document.querySelector('.wiz-panel[data-panel="' + target + '"]');

        if (!nxtPanel) return;

        if (curPanel) {
            curPanel.classList.add(direction > 0 ? 'slide-back' : '');
            setTimeout(function () {
                curPanel.classList.remove('is-active', 'slide-back');
                curPanel.style.transform = '';
            }, 230);
        }

        // Prepare entry direction
        nxtPanel.style.transform = direction > 0 ? 'translateX(28px)' : 'translateX(-28px)';
        nxtPanel.style.opacity = '0';
        nxtPanel.style.pointerEvents = '';

        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                nxtPanel.style.transform = '';
                nxtPanel.style.opacity   = '';
                nxtPanel.classList.add('is-active');
            });
        });

        wiz.current = target;
        wizUpdateStepper();
        wizUpdateFooter();
    };

    // ── Stepper update ────────────────────────────────────────────
    function wizUpdateStepper() {
        document.querySelectorAll('.wiz-step').forEach(function (el) {
            var s = parseInt(el.dataset.wizStep);
            el.classList.toggle('is-active', s === wiz.current);
            el.classList.toggle('is-done',   s < wiz.current);
        });
        // Progress dots
        document.querySelectorAll('.wiz-progress__dot').forEach(function (el) {
            var p = parseInt(el.dataset.prog);
            el.classList.toggle('is-active', p === wiz.current);
            el.classList.toggle('is-done',   p < wiz.current);
        });
    }

    // ── Footer update ─────────────────────────────────────────────
    function wizUpdateFooter() {
        var back = $id('wizBtnBack');
        var next = $id('wizBtnNext');
        back.disabled = wiz.current === 1;

        if (wiz.current === wiz.total) {
            next.className = 'wiz-btn-nav wiz-btn-save';
            next.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Teklifi Oluştur';
            next.onclick = wizSave;
        } else {
            next.className = 'wiz-btn-nav wiz-btn-next';
            next.innerHTML = 'Devam Et <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>';
            next.onclick = function () { wizNav(1); };
        }
    }

    // ── Summary builder ───────────────────────────────────────────
    function wizBuildSummary() {
        // Customer — Cari Kod + Cari İsim
        var custCode = ($id('wizCustomerDisplay').getAttribute('data-display') || $id('wizCustomerDisplay').value || '').trim();
        var custName = ($id('wizCustomerName') ? $id('wizCustomerName').value : '') || '';
        var custText = custName || custCode || '(Müşteri seçilmedi)';
        var custInitial = (custText || '?')[0].toUpperCase();

        $id('wizSummaryHeader').innerHTML =
            '<div class="wiz-summary-avatar">' + esc(custInitial) + '</div>' +
            '<div>' +
                '<div class="wiz-summary-name">' + esc(custText) + '</div>' +
                '<div class="wiz-summary-meta">Yeni Satış Teklifi</div>' +
            '</div>';

        // Chips
        var cur  = $id('wizCurrency').value;
        var date = $id('wizQuoteDate').value || '—';
        var vld  = $id('wizValidUntil').value || '—';
        var repSel = $id('wizSalesRepId');
        var repText = repSel.selectedIndex > 0 ? repSel.options[repSel.selectedIndex].text : '—';

        $id('wizSummaryChips').innerHTML =
            '<span class="wiz-chip"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' + esc(date) + '</span>' +
            '<span class="wiz-chip">Geç: ' + esc(vld) + '</span>' +
            '<span class="wiz-chip wiz-chip--accent">' + esc(cur) + '</span>' +
            '<span class="wiz-chip">Tmslcİ: ' + esc(repText) + '</span>';

        // Lines table
        var lines = window.__WIZ_LINES__ || [];
        if (window.CalibraHub && window.CalibraHub.salesLineGrid) {
            try { lines = window.CalibraHub.salesLineGrid.getRows() || lines; } catch (e) {}
        }
        var validLines = lines.filter(function (r) { return r && r.materialCode; });
        var tbody = $id('wizSummaryLines');
        if (validLines.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:20px;color:#94a3b8;">Kalem eklenmemiş</td></tr>';
        } else {
            tbody.innerHTML = validLines.map(function (r, i) {
                var lt = Number(r.lineTotal);
                if (isNaN(lt)||!isFinite(lt)) lt = (Number(r.quantity)||0)*(Number(r.unitPrice)||0)*(1-(Number(r.discountRate)||0)/100);
                return '<tr>' +
                    '<td style="color:#94a3b8;font-size:0.74rem;">' + (i+1) + '</td>' +
                    '<td><div style="font-weight:600;">' + esc(r.materialCode) + '</div>' +
                    '<div style="font-size:0.75rem;color:#94a3b8;">' + esc(r.materialName) + '</div></td>' +
                    '<td>' + esc(r.unitName || '—') + '</td>' +
                    '<td class="td-num">' + fmt(r.quantity) + '</td>' +
                    '<td class="td-num">' + fmt(r.unitPrice) + '</td>' +
                    '<td class="td-num">' + (Number(r.discountRate)||0) + '%</td>' +
                    '<td class="td-total">' + fmt(lt) + '</td>' +
                    '</tr>';
            }).join('');
        }

        // Totals
        var sub    = parseFloat($id('wizSubTotal').textContent.replace(/\./g,'').replace(',','.')) || 0;
        var dAmt   = parseFloat($id('wizDiscountAmt').textContent.replace(/\./g,'').replace(',','.')) || 0;
        var tAmt   = parseFloat($id('wizTaxAmt').textContent.replace(/\./g,'').replace(',','.')) || 0;
        var grand  = parseFloat($id('wizGrandTotal').textContent.replace(/\./g,'').replace(',','.')) || 0;
        var dRate  = $id('wizDiscountRate').value || '0';
        var tRate  = $id('wizTaxRate').value || '20';

        $id('wizSummaryTotals').innerHTML =
            '<div class="wiz-s-total-row"><span class="lbl">Ara Toplam:</span><span class="val">' + fmt(sub) + ' ' + cur + '</span></div>' +
            '<div class="wiz-s-total-row"><span class="lbl">İskonto (' + dRate + '%):</span><span class="val">- ' + fmt(dAmt) + '</span></div>' +
            '<div class="wiz-s-total-row"><span class="lbl">KDV (' + tRate + '%):</span><span class="val">+ ' + fmt(tAmt) + '</span></div>' +
            '<div class="wiz-s-total-row wiz-s-grand"><span class="lbl">Genel Toplam:</span><span class="val">' + fmt(grand) + ' ' + cur + '</span></div>';
    }

    // ── Save ──────────────────────────────────────────────────────
    async function wizSave() {
        var rawLines = window.__WIZ_LINES__ || [];
        if (window.CalibraHub && window.CalibraHub.salesLineGrid) {
            try { rawLines = window.CalibraHub.salesLineGrid.getRows() || rawLines; } catch (e) {}
        }
        var lines = rawLines
            .filter(function (r) { return r && r.materialCode; })
            .map(function (r) {
                return {
                    stockCardId:        r.stockCardId != null && r.stockCardId !== '' ? parseInt(r.stockCardId, 10) : null,
                    materialCode:       r.materialCode || '',
                    materialName:       r.materialName || '',
                    unitName:           r.unitName || null,
                    quantity:           Number(r.quantity) || 0,
                    unitPrice:          Number(r.unitPrice) || 0,
                    discountRate:       Number(r.discountRate) || 0,
                    combinationCode:    r.combinationCode || null,
                    combinationDetails: Array.isArray(r.combinationDetails) ? r.combinationDetails : [],
                    notes:              r.notes || null,
                };
            });

        var custIdVal  = $id('wizCustomerId').value;
        var custCodeVal = ($id('wizCustomerDisplay').value || '').trim();
        var custText = ($id('wizCustomerName') ? $id('wizCustomerName').value : '').trim() || null;

        var payload = {
            id: null,
            quoteDate:       $id('wizQuoteDate').value,
            validUntil:      $id('wizValidUntil').value || null,
            customerId:      parseInt(custIdVal) || null,
            customerCode:    custCodeVal || null,
            customerName:    custText,
            customerAddress: null,
            salesRepId:      parseInt($id('wizSalesRepId').value) || null,
            currency:        $id('wizCurrency').value,
            discountRate:    parseFloat($id('wizDiscountRate').value || 0),
            taxRate:         parseFloat($id('wizTaxRate').value || 0),
            paymentTerms:    $id('wizPaymentTerms').value || null,
            deliveryTerms:   $id('wizDeliveryTerms').value || null,
            deliveryAddress: $id('wizDeliveryAddress').value || null,
            notes:           $id('wizNotes').value || null,
            lines: lines,
        };

        // Buton loading state
        var btn = $id('wizBtnNext');
        btn.disabled = true;
        btn.textContent = 'Kaydediliyor...';

        try {
            var resp = await fetch('/Sales/SaveDocument', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            });
            var data = await resp.json();
            if (!data.success) {
                btn.disabled = false;
                wizUpdateFooter();
                alert('Kayıt hatası: ' + (data.message || 'Bilinmeyen hata'));
                return;
            }

            // ── Başarı ────────────────────────────────────────────
            var quoteNum = data.quote && data.quote.quoteNumber ? data.quote.quoteNumber : 'Oluşturuldu';
            var quoteId  = data.quote && data.quote.id ? data.quote.id : null;
            $id('wizSuccessSub').textContent = 'Teklif No: ' + quoteNum;
            $id('wizSuccessOverlay').classList.add('visible');

            setTimeout(function () {
                var dest = quoteId
                    ? '/Sales/DocumentEdit?id=' + quoteId
                    : '/Sales/Documents';
                window.location.href = dest;
            }, 1800);

        } catch (ex) {
            btn.disabled = false;
            wizUpdateFooter();
            alert('Bağlantı hatası: ' + ex.message);
        }
    }

    window.wizNav  = window.wizNav;  // expose
    window.wizSave = wizSave;        // expose

})();
</script>
}
