@*
    _ComingSoon — Henuz tamamlanmamis sayfalar icin ortak placeholder.
    Kullanim:
        return View("_ComingSoon", new ComingSoonViewModel {
            Title = "Satin Alma Talep",
            Description = "Talep olusturma + onay akisi sayfa iskeleti yakinda.",
            Icon = "ClipboardList"  // Lucide ikon adi (opsiyonel)
        });
*@
@model CalibraHub.Web.Models.ComingSoonViewModel
@{
    ViewData["Title"] = Model?.Title ?? "Yakında";
    var title = Model?.Title ?? "Yakında";
    var desc  = Model?.Description ?? "Bu ekran yapım aşamasındadır.";
}

<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;
            min-height:60vh;padding:48px 24px;text-align:center;font-family:'Segoe UI',system-ui,sans-serif;">
    <div style="width:96px;height:96px;border-radius:50%;
                background:linear-gradient(135deg,#6366f1 0%,#8b5cf6 100%);
                display:flex;align-items:center;justify-content:center;
                box-shadow:0 20px 50px rgba(99,102,241,.35);margin-bottom:24px;">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.6"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <path d="M16 2v4M8 2v4M3 10h18"/>
            <path d="M8 14h2M14 14h2M8 18h2M14 18h2"/>
        </svg>
    </div>
    <h1 style="font-size:24px;font-weight:700;color:var(--app-text,#0f172a);margin:0 0 10px;">
        @title
    </h1>
    <p style="font-size:14px;color:var(--app-text-muted,#64748b);max-width:520px;line-height:1.6;margin:0 0 24px;">
        @desc
    </p>
    <span style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:999px;
                 background:rgba(99,102,241,.10);color:#6366f1;font-size:12px;font-weight:600;
                 border:1px solid rgba(99,102,241,.25);">
        Yapım aşamasında
    </span>
</div>
