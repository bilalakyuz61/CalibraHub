@using System.Security.Claims
@using CalibraHub.Application.Security
@using CalibraHub.Domain.Enums
@inject CalibraHub.Web.Infrastructure.Ui.IUiTextService UiText
@inject CalibraHub.Application.Abstractions.Services.IPermissionService MenuPermService
@{
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var currentKind = (Context.Request.Query["kind"].ToString() ?? string.Empty).ToLowerInvariant();
    var approvalEInvoiceActive = controller == "approval" && (action == "einvoice" || currentKind == "einvoice");
    var approvalEArchiveActive = controller == "approval" && (action == "earchive" || currentKind == "earchive");
    var approvalEDispatchActive = controller == "approval" && (action == "edispatch" || currentKind == "edispatch");
    var onayOpen = controller == "approval";
    var documentModuleOpen = onayOpen;
    var logisticsOpen = controller == "logistics" && action != "producttrees" && action != "saveproducttree" && action != "deleteproducttree";
    var uretimOpen = (controller == "logistics" && action is "producttrees" or "saveproducttree" or "deleteproducttree"
                                                      or "boms" or "bomedit" or "savebom" or "getbom" or "getbombyid" or "deletebomjson" or "getbomspage")
                     || (controller == "production" && action is "workorders" or "workorderedit");
    var productionWorkOrdersActive = controller == "production" && action is "workorders" or "workorderedit";
    var adminParametersActive = controller == "admin" && action == "parameters";
    var settingsOpen = controller == "admin" || controller == "setup" || controller == "gate";
    var setupDefinitionsActive = controller == "setupuser";
    var viewSettingsActive = controller == "admin" && action == "viewsettings";
    var isSystemAdmin = string.Equals(
        User.FindFirstValue(ClaimTypes.Email), "admin@calibra.local",
        StringComparison.OrdinalIgnoreCase);
    var cardGroupsActive = controller == "definitions" && action == "cardgroups";
    var logisticsMachinesActive = controller == "logistics" && action == "machines";
    var generalOpen = controller == "notes" || controller == "definitions" || controller == "orgchart" || controller == "whatsapp";
    var notesActive = controller == "notes" && action is "index" or "save" or "delete" or "addreminder" or "deletereminder" or "addshare" or "deleteshare";
    var orgChartActive = controller == "orgchart";
    var whatsappActive = controller == "whatsapp";
    var logisticsConfigurationActive = controller == "logistics" &&
                                       action is "configurationdefinitions" or
                                           "productconfiguration" or
                                           "savestockcard" or
                                           "saveproperty" or
                                           "savepropertyvalue" or
                                           "savestockpropertylink" or
                                           "savestockpropertymapping" or
                                           "saveproductfeature" or
                                           "saveproductvalue" or
                                           "saveproductconfig" or
                                           "productcombinations";
    var logisticsMaterialCardsActive = controller == "logistics" &&
                                       action is "materialcards" or "savematerialcard" or "deletematerialcard";
    var logisticsBOMsActive = controller == "logistics" &&
                                      action is "boms" or "bomedit" or "savebom" or "getbom" or "getbombyid" or "deletebomjson" or "getbomspage";
    var logisticsMeasureUnitsActive = controller == "logistics" &&
                                      action is "measureunitdefinitions" or "savemeasureunitdefinition" or "deletemeasureunitdefinition";
    var logisticsMaterialGroupsActive = controller == "logistics" &&
                                        action is "materialgroups" or "savematerialgroup" or "deletematerialgroup";
    var financeOpen = controller == "finance";
    var financeContactsActive = controller == "finance" && action == "contactaccounts";
    var ui = await UiText.GetFormAsync("shared.main_menu");
    var collapseMenuText = ui.Text("collapse_menu");
    var searchPlaceholderText = ui.Text("search_placeholder");
    var favoritesTitleText = ui.Text("favorites_title");
    var approvalProcessesText = ui.Text("approval_processes");
    var electronicDocumentsText = ui.Text("electronic_documents");
    var eInvoiceText = ui.Text("e_invoice");
    var eArchiveText = ui.Text("e_archive");
    var eDispatchText = ui.Text("e_dispatch");
    var logisticsText = ui.Text("logistics");
    var purchaseText = ui.Text("purchase");
    var salesText = ui.Text("sales");
    var productConfigurationText = ui.Text("product_configuration");
    var materialCardsText = ui.Text("items");
    var productTreesText = "Ürün Ağacı";
    var fixedDefinitionsText = ui.Text("fixed_definitions");
    var warehouseLocationsText = ui.Text("locations");
    var measureUnitsText = ui.Text("measure_units");
    var settingsText = ui.Text("settings");
    var companyDefinitionText = ui.Text("company_definition");
    var integratorSettingsText = ui.Text("integrator_settings");
    var mailSettingsText = ui.Text("mail_settings");
    var erpSettingsText = ui.Text("erp_settings");
    var appearanceText = ui.Text("appearance");
    var projectInstructionsText = "Proje Talimatlari";
    var materialCardDesignText = ui.Text("screen_design_settings");
    var systemLogReportText = ui.Text("system_log_report");
    var logisticsLocationsActive = controller == "logistics" &&
                                            action is "warehouselocations" or
                                                "savewarehouselocation" or
                                                "deletewarehouselocation";
    var logisticsFixedDefinitionsOpen =
        logisticsConfigurationActive ||
        logisticsMaterialCardsActive;
    var companySettingsActive = controller == "admin" && action == "companysettings";
    var integratorSettingsActive = controller == "admin" && action == "integratorsettings";
    var mailSettingsActive = controller == "admin" && action == "mailsettings";
    var erpSettingsActive = controller == "admin" && action == "erpsettings";
    var appearanceActive = controller == "admin" && action == "appearance";
    var projectInstructionsActive = controller == "admin" && action == "projectinstructions";
    var materialCardDesignActive = controller == "admin" && (action == "materialcardviewsettings" || action == "viewsettings");
    var systemLogsActive = controller == "admin" && action == "logs";
    var guideManagementActive = controller == "admin" && action == "guidemanagement";

    var dashboardsActive = controller == "dashboard" && action == "index";
    var reportDesignerActive = controller == "dashboard" && action == "designer";
    var docDesignerActive = controller == "docdesigner";
    var reportsGroupOpen = dashboardsActive || reportDesignerActive;

    var canViewDashboards = false;
    if (UserAuthorizationCatalog.TryParseRole(User.FindFirstValue(ClaimTypes.Role), out var dashboardRole))
    {
        canViewDashboards = UserAuthorizationCatalog.GetAllowedPermissions(dashboardRole)
            .Contains(UserPermission.ViewDashboards);
    }

    // ── Permission-based menu filtering ────────────────────────────────────────
    var menuUserIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
    var menuRoleStr   = User.FindFirstValue(ClaimTypes.Role) ?? string.Empty;
    var menuDeptStr   = User.FindFirstValue("department_id");
    int.TryParse(menuUserIdStr, out var menuUserId);
    int? menuDeptId = int.TryParse(menuDeptStr, out var menuDeptIdRaw) && menuDeptIdRaw > 0 ? menuDeptIdRaw : null;
    UserAuthorizationCatalog.TryParseRole(menuRoleStr, out var menuRole);
    var isMenuAdmin = menuRole == UserRole.SystemAdmin || menuRole == UserRole.DepartmentManager;

    HashSet<string>? menuAllowedForms = null;
    if (!isMenuAdmin && menuUserId > 0)
    {
        var menuPerms = await MenuPermService.GetEffectivePermissionsAsync(menuUserId, menuRole, menuDeptId, CancellationToken.None);
        menuAllowedForms = menuPerms
            .Where(p => p.IsAllowed && p.ActionCode == CalibraHub.Domain.Entities.PermissionDef.StandardActions.View)
            .Select(p => p.FormCode)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    Func<string, bool> canView = code => isMenuAdmin || (menuAllowedForms?.Contains(code) == true);
    var permissionsActive = controller == "admin" && action == "permissions";
}

<nav class="side-nav" data-menu-root data-menu-scope="main">
    <div class="side-nav-header">
        <div class="menu-search-wrap">
            <input type="search"
                   class="menu-search-input"
                   data-menu-search
                   placeholder="@searchPlaceholderText"
                   autocomplete="off" />
        </div>
    </div>

    <section class="favorites-panel" data-favorites-panel hidden>
        <h3 class="favorites-title">@favoritesTitleText</h3>
        <div class="favorites-list" data-favorites-list></div>
    </section>


    @if (isMenuAdmin || canView("NOTES"))
    {
    <details class="side-group" @(generalOpen ? "open" : null)>
        <summary>
            <span class="menu-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M3 5h18M3 12h18M3 19h18"></path></svg>
            </span>
            <span class="menu-text">Genel</span>
        </summary>

        <div class="menu-group-content">
            <div class="menu-group-content-inner">

                @if (canView("NOTES"))
                {
                <div class="menu-entry" data-menu-entry data-favorite-key="main-general-notes">
                    <a class="side-subitem @(notesActive ? "active" : string.Empty)"
                       asp-controller="Notes" asp-action="Index"
                       title="Notlar">
                        <span class="menu-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M7 4h7l5 5v11H7z"></path><path d="M14 4v5h5"></path><path d="M10 12h6"></path><path d="M10 16h4"></path></svg>
                        </span>
                        <span class="menu-text">Notlar</span>
                    </a>
                    <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="Notlar favorilere ekle">
                        <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                    </button>
                </div>
                }

                @if (isMenuAdmin)
                {
                <div class="menu-entry" data-menu-entry data-favorite-key="main-general-orgchart">
                    <a class="side-subitem @(orgChartActive ? "active" : string.Empty)"
                       asp-controller="OrgChart" asp-action="Index"
                       title="Organizasyon Şeması">
                        <span class="menu-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                        </span>
                        <span class="menu-text">Organizasyon Şeması</span>
                    </a>
                    <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="Organizasyon Şeması favorilere ekle">
                        <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                    </button>
                </div>

                <div class="menu-entry" data-menu-entry data-favorite-key="main-general-whatsapp">
                    <a class="side-subitem @(whatsappActive ? "active" : string.Empty)"
                       asp-controller="Whatsapp" asp-action="Index"
                       title="WhatsApp">
                        <span class="menu-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.4 8.4 0 0 1 3.8-.9h.5a8.5 8.5 0 0 1 8 8v.5z"/></svg>
                        </span>
                        <span class="menu-text">WhatsApp</span>
                    </a>
                    <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="WhatsApp favorilere ekle">
                        <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                    </button>
                </div>
                }

            </div>
        </div>
    </details>
    }

    @if (isMenuAdmin)
    {
    <details class="side-group" @(onayOpen ? "open" : null)>
        <summary>
            <span class="menu-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M4 7h10"></path><path d="M4 12h16"></path><path d="M4 17h12"></path></svg>
