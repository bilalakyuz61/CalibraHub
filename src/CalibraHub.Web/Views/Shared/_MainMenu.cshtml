                                <span class="menu-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                                </span>
                                <span class="menu-text">Satın Alma Talebi</span>
                            </a>
                            <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="Satın Alma Talebi favorilere ekle">
                                <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                            </button>
                        </div>
                        }
                        @if (isMenuAdmin || canView("PURCHASE_QUOTE"))
                        {
                        <div class="menu-entry" data-menu-entry data-favorite-key="main-purchase-quotes">
                            <a class="side-subitem @(purchaseOpen && ViewContext.RouteData.Values["action"]?.ToString() == "Quotes" ? "active" : "")"
                               href="/Purchase/Quotes" title="Satın Alma Teklifi">
                                <span class="menu-icon" aria-hidden="true">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                                </span>
                                <span class="menu-text">SA Teklifi</span>
                            </a>
                            <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="SA Teklifi favorilere ekle">
                                <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                            </button>
