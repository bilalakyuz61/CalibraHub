                                </button>
                            </div>

                            <div class="menu-entry" data-menu-entry data-favorite-key="main-approval-edispatch">
                                <a class="side-subitem @(approvalEDispatchActive ? "active" : string.Empty)"
                                   asp-controller="Approval" asp-action="EDispatch"
                                   title="@eDispatchText">
