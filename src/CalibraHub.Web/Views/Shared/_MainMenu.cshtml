                        }
                        @if (isMenuAdmin || canView("PURCHASE_DEMAND"))
                        {
                        <div class="menu-entry" data-menu-entry data-favorite-key="main-purchase-demands">
                            <a class="side-subitem @(purchaseOpen && ViewContext.RouteData.Values["action"]?.ToString() == "PurchaseDemands" ? "active" : "")"
