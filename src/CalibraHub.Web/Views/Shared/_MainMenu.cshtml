                                    </span>
                                    <span class="menu-text">@eDispatchText</span>
                                </a>
                                <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="@($"{eDispatchText} favorilere ekle")">
                                    <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </details>
            </div>
        </div>
    </details>
    }

    @if (isMenuAdmin || canView("ITEMS") || canView("PRODUCT_CONFIG") || canView("SALES_QUOTE"))
    {
    <details class="side-group" @(logisticsOpen ? "open" : null)>
        <summary>
            <span class="menu-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M3 7h13v10H3z"></path><path d="M16 10h3l2 2v5h-5z"></path><circle cx="7" cy="18" r="2"></circle><circle cx="18" cy="18" r="2"></circle></svg>
            </span>
            <span class="menu-text">@logisticsText</span>
        </summary>

        <div class="menu-group-content">
            <div class="menu-group-content-inner">
                @if (canView("ITEMS") || canView("PRODUCT_CONFIG"))
                {
                <details class="side-group side-group-nested" @(logisticsFixedDefinitionsOpen ? "open" : null)>
                    <summary>
                        <span class="menu-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24"><path d="M4 6h16"></path><path d="M4 12h16"></path><path d="M4 18h16"></path></svg>
                        </span>
                        <span class="menu-text">@fixedDefinitionsText</span>
                    </summary>

                    <div class="menu-group-content">
                        <div class="menu-group-content-inner">
                            @if (canView("ITEMS"))
                            {
                            <div class="menu-entry" data-menu-entry data-favorite-key="main-logistics-material-cards">
                                <a class="side-subitem @(logisticsMaterialCardsActive ? "active" : string.Empty)"
                                   asp-controller="Logistics" asp-action="MaterialCards"
                                   title="@materialCardsText">
                                    <span class="menu-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24"><rect x="3.5" y="5" width="17" height="14" rx="2"></rect><path d="M3.5 10h17"></path><path d="M8 15h4"></path></svg>
                                    </span>
                                    <span class="menu-text">@materialCardsText</span>
                                </a>
                                <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="@($"{materialCardsText} favorilere ekle")">
                                    <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                                </button>
                            </div>
                            }

                            @if (canView("PRODUCT_CONFIG"))
                            {
                            <div class="menu-entry" data-menu-entry data-favorite-key="main-logistics-configuration-definitions">
                                <a class="side-subitem @(logisticsConfigurationActive ? "active" : string.Empty)"
                                   asp-controller="Logistics" asp-action="ProductConfiguration"
                                   title="@productConfigurationText">
                                    <span class="menu-icon" aria-hidden="true">
                                        <svg viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16"></path><circle cx="8" cy="7" r="1.5"></circle><circle cx="16" cy="12" r="1.5"></circle><circle cx="10" cy="17" r="1.5"></circle></svg>
                                    </span>
                                    <span class="menu-text">@productConfigurationText</span>
                                </a>
                                <button type="button" class="favorite-toggle" data-favorite-toggle aria-label="@($"{productConfigurationText} favorilere ekle")">
                                    <svg viewBox="0 0 24 24"><path d="m12 3 2.9 5.8 6.4.9-4.6 4.5 1.1 6.3L12 17.4 6.2 20.5l1.1-6.3L2.7 9.7l6.4-.9z"></path></svg>
                                </button>
                            </div>
                            }

                            @* Malzeme Grupları → Genel > Grup Tanımlamaları *@
                        </div>
                    </div>
                </details>
                }

                @{
                    var purchaseOpen = ViewContext.RouteData.Values["controller"]?.ToString() == "Purchase";
                }
                @if (isMenuAdmin || canView("PURCHASE_REQUEST") || canView("PURCHASE_DEMAND") || canView("PURCHASE_QUOTE") || canView("PURCHASE_ORDER") || canView("PURCHASE_FULFILLMENT"))
                {
                <details class="side-group side-group-nested" @(purchaseOpen ? "open" : null)>
                    <summary>
                        <span class="menu-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
