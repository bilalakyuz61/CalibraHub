<script>
(function () {
    var STORAGE_KEY = 'calibra_menu_open_groups';
    var groups = document.querySelectorAll('details.side-group, details.admin-group');
    if (!groups.length) return;

    // localStorage'dan kayıtlı durumu yükle
    var saved = {};
    try { saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch (_) {}

    // Kayıtlı durum varsa uygula (server-side açık olanları koru)
    groups.forEach(function (g) {
        var key = g.dataset.menuGroup || g.querySelector('summary')?.textContent?.trim() || '';
        if (!key) return;
        if (key in saved) {
            if (saved[key]) { g.setAttribute('open', ''); }
            // else: kapalı bırak — ama server-side 'open' ile geliyorsa dokunma
        }
    });

    // Kullanıcı toggle yapınca kaydet
    groups.forEach(function (g) {
        var key = g.dataset.menuGroup || g.querySelector('summary')?.textContent?.trim() || '';
        if (!key) return;
        g.addEventListener('toggle', function () {
            try {
                var state = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
                state[key] = g.open;
                localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
            } catch (_) {}
        });
    });
})();
</script>
