@using System.Security.Claims
@inject CalibraHub.Web.Infrastructure.Ui.IUiTextService UiText
@{
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();
    var currentKind = (Context.Request.Query["kind"].ToString() ?? string.Empty).ToLowerInvariant();
    var approvalEInvoiceActive = controller == "approval" && (action == "einvoice" || currentKind == "einvoice");
    var approvalEArchiveActive = controller == "approval" && (action == "earchive" || currentKind == "earchive");
    var approvalEDispatchActive = controller == "approval" && (action == "edispatch" || currentKind == "edispatch");
    var onayOpen = controller == "approval";
    var documentModuleOpen = onayOpen;
    var logisticsOpen = controller == "logistics" && action != "producttrees" && action != "saveproducttree" && action != "deleteproducttree";
    var uretimOpen = controller == "logistics" && action is "producttrees" or "saveproducttree" or "deleteproducttree";
    var settingsOpen = controller == "admin" || controller == "setup";
    var setupDefinitionsActive = controller == "setup" && action == "definitions";
    var integrationEventsActive = controller == "admin" && action == "integrationevents";
    var viewSettingsActive = controller == "admin" && action == "viewsettings";
    var isSystemAdmin = string.Equals(
        User.FindFirstValue(ClaimTypes.Email), "admin@calibra.local",
        StringComparison.OrdinalIgnoreCase);
    var cardGroupsActive = controller == "definitions" && action == "cardgroups";
    var generalOpen = controller == "notes" || controller == "definitions" || controller == "orgchart";
    var notesActive = controller == "notes" && action is "index" or "save" or "delete" or "addreminder" or "deletereminder" or "addshare" or "deleteshare";
    var orgChartActive = controller == "orgchart";
    var logisticsConfigurationActive = controller == "logistics" &&
                                       action is "configurationdefinitions" or
                                           "productconfiguration" or
                                           "savestockcard" or
                                           "saveproperty" or
                                           "savepropertyvalue" or
                                           "savestockpropertylink" or
                                           "savestockpropertymapping" or
                                           "saveproductfeature" or
                                           "saveproductvalue" or
                                           "saveproductconfig" or
                                           "productcombinations";
    var logisticsMaterialCardsActive = controller == "logistics" &&
                                       action is "materialcards" or "savematerialcard" or "deletematerialcard";
    var logisticsBOMsActive = controller == "logistics" &&
                                      action is "producttrees" or "saveproducttree" or "deleteproducttree";
    var logisticsMeasureUnitsActive = controller == "logistics" &&
                                      action is "measureunitdefinitions" or "savemeasureunitdefinition" or "deletemeasureunitdefinition";
    var logisticsMaterialGroupsActive = controller == "logistics" &&
                                        action is "materialgroups" or "savematerialgroup" or "deletematerialgroup";
    var financeOpen = controller == "finance";
    var financeContactsActive = controller == "finance" && action == "contactaccounts";
    var ui = await UiText.GetFormAsync("shared.main_menu");
    var collapseMenuText = ui.Text("collapse_menu");
    var searchPlaceholderText = ui.Text("search_placeholder");
    var favoritesTitleText = ui.Text("favorites_title");
    var approvalProcessesText = ui.Text("approval_processes");
    var electronicDocumentsText = ui.Text("electronic_documents");
    var eInvoiceText = ui.Text("e_invoice");
    var eArchiveText = ui.Text("e_archive");
    var eDispatchText = ui.Text("e_dispatch");
    var logisticsText = ui.Text("logistics");
    var purchaseText = ui.Text("purchase");
    var salesText = ui.Text("sales");
    var productConfigurationText = ui.Text("product_configuration");
    var materialCardsText = ui.Text("items");
    var productTreesText = "Ürün Ağacı";
    var fixedDefinitionsText = ui.Text("fixed_definitions");
    var warehouseLocationsText = ui.Text("locations");
    var measureUnitsText = ui.Text("measure_units");
    var settingsText = ui.Text("settings");
    var companyDefinitionText = ui.Text("company_definition");
    var integratorSettingsText = ui.Text("integrator_settings");
    var mailSettingsText = ui.Text("mail_settings");
    var erpSettingsText = ui.Text("erp_settings");
    var appearanceText = ui.Text("appearance");
    var projectInstructionsText = "Proje Talimatlari";
    var materialCardDesignText = ui.Text("screen_design_settings");
    var systemLogReportText = ui.Text("system_log_report");
    var logisticsLocationsActive = controller == "logistics" &&
                                            action is "warehouselocations" or
                                                "savewarehouselocation" or
                                                "deletewarehouselocation";
    var logisticsFixedDefinitionsOpen =
        logisticsConfigurationActive ||
        logisticsMaterialCardsActive;
    var companySettingsActive = controller == "admin" && action == "companysettings";
    var integratorSettingsActive = controller == "admin" && action == "integratorsettings";
    var mailSettingsActive = controller == "admin" && action == "mailsettings";
    var erpSettingsActive = controller == "admin" && action == "erpsettings";
    var appearanceActive = controller == "admin" && action == "appearance";
    var projectInstructionsActive = controller == "admin" && action == "projectinstructions";
    var materialCardDesignActive = controller == "admin" && (action == "materialcardviewsettings" || action == "viewsettings");
    var systemLogsActive = controller == "admin" && action == "logs";
    var guideManagementActive = controller == "admin" && action == "guidemanagement";
}

<nav class="side-nav" data-menu-root data-menu-scope="main">
    <div class="side-nav-header">
        <div class="menu-search-wrap">
            <input type="search"
                   class="menu-search-input"
                   data-menu-search
