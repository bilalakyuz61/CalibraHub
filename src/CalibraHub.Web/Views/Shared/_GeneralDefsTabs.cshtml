@*
   Genel Tanımlamalar sekme barı — iki katman:
     1) Grup sekmeleri (tabsheet): "Adres Tanımlamaları" | "Lokasyon Tanımlamaları"
     2) Alt sekmeler: seçili grubun ekranları

   Her view üst kısma çağırır:
       <partial name="_GeneralDefsTabs" model='"countries"' />
   model = aktif alt-sekme key. Grup, alt-sekme key'inden türetilir:
     adres    → countries / cities / districts / localities
     lokasyon → sections / subsections
   pdt-* data attribute'ları korunur — mevcut PJAX mekanizması alt sekmelerde çalışır.
*@
@model string

@{
    var current = (Model ?? string.Empty).ToLowerInvariant();
    var isLokasyon = current is "sections" or "subsections";
    string TabClass(string key) =>
        string.Equals(key, current, StringComparison.OrdinalIgnoreCase) ? "pdt-tab active" : "pdt-tab";
}

<style>
    .pdt-tabs {
        display: flex; gap: 0; padding: 0 16px;
        background: transparent;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        flex-shrink: 0;
    }
    .pdt-tab {
        padding: 10px 16px; font-size: 13px; font-weight: 500; cursor: pointer;
        background: transparent;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        color: rgba(148, 163, 184, 0.85);
        text-decoration: none;
        display: inline-flex; align-items: center; gap: 7px;
        transition: color .12s, border-color .12s;
    }
    .pdt-tab:hover { color: #6366f1; }
    .pdt-tab.active {
        color: #6366f1;
        border-bottom-color: #6366f1;
        font-weight: 600;
    }
    body.app-theme-dark .pdt-tab.active { color: #a5b4fc; border-bottom-color: #a5b4fc; }
    body.app-theme-dark .pdt-tab:hover  { color: #a5b4fc; }
    .pdt-tab svg { opacity: 0.85; }

    /* ── Grup katmanı (tabsheet) — üst seviye, daha belirgin ── */
    .gdt-groups {
        display: flex; gap: 4px; padding: 8px 16px 0;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        flex-shrink: 0;
    }
    .gdt-group-tab {
        padding: 8px 18px; font-size: 13px; font-weight: 600; cursor: pointer;
        text-decoration: none;
        display: inline-flex; align-items: center; gap: 8px;
        color: rgba(148, 163, 184, 0.85);
        border: 1px solid transparent; border-bottom: none;
        border-radius: 10px 10px 0 0;
        margin-bottom: -1px;
        transition: color .12s, background .12s, border-color .12s;
    }
    .gdt-group-tab:hover { color: #6366f1; }
    .gdt-group-tab.active {
        color: #6366f1;
        background: rgba(99, 102, 241, 0.06);
        border-color: rgba(148, 163, 184, 0.25);
        border-bottom: 1px solid transparent;
    }
    body.app-theme-dark .gdt-group-tab.active {
        color: #a5b4fc;
        background: rgba(99, 102, 241, 0.10);
        border-color: rgba(255, 255, 255, 0.10);
    }
    body.app-theme-dark .gdt-group-tab:hover { color: #a5b4fc; }
    .gdt-group-tab svg { opacity: 0.85; }

    /* Alt sekme barı grup içinde — hafif zemin tonu, girinti */
    .pdt-tabs--sub {
        padding-left: 24px;
        background: rgba(99, 102, 241, 0.03);
    }
    body.app-theme-dark .pdt-tabs--sub { background: rgba(99, 102, 241, 0.05); }
    .pdt-tabs--sub .pdt-tab { padding: 8px 14px; font-size: 12.5px; }
</style>

@* 1. katman — grup sekmeleri (tabsheet). Grup değişimi tam sayfa geçiştir
   (PJAX değil) — her grubun alt sekme barı farklıdır. *@
<div class="gdt-groups">
    <a href="/GeneralDefs/Countries" class="gdt-group-tab @(isLokasyon ? "" : "active")" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
            <circle cx="12" cy="10" r="3"/>
        </svg>
        Adres Tanımlamaları
    </a>
    <a href="/GeneralDefs/Sections" class="gdt-group-tab @(isLokasyon ? "active" : "")" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="7" height="7" x="3" y="3" rx="1"/>
            <rect width="7" height="7" x="14" y="3" rx="1"/>
            <rect width="7" height="7" x="14" y="14" rx="1"/>
            <rect width="7" height="7" x="3" y="14" rx="1"/>
        </svg>
        Lokasyon Tanımlamaları
    </a>
</div>

@* 2. katman — seçili grubun alt sekmeleri *@
@if (!isLokasyon)
{
<div class="pdt-tabs pdt-tabs--sub" data-pdt-tabbar="1">
    <a href="/GeneralDefs/Countries" class="@TabClass("countries")" data-pdt-tab="countries" data-pdt-body-class="page-gdf-countries" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
            <path d="M2 12h20"/>
        </svg>
        Ülkeler
    </a>
    <a href="/GeneralDefs/Cities" class="@TabClass("cities")" data-pdt-tab="cities" data-pdt-body-class="page-gdf-cities" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/>
            <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/>
            <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>
            <path d="M10 6h4"/>
            <path d="M10 10h4"/>
            <path d="M10 14h4"/>
            <path d="M10 18h4"/>
        </svg>
        Şehirler
    </a>
    <a href="/GeneralDefs/Districts" class="@TabClass("districts")" data-pdt-tab="districts" data-pdt-body-class="page-gdf-districts" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
            <circle cx="12" cy="10" r="3"/>
        </svg>
        İlçeler
    </a>
    @* Mahalle ile köy aynı idari düzeyde — tek birleşik sekme (tür rozetiyle ayrışır) *@
    <a href="/GeneralDefs/Localities" class="@TabClass("localities")" data-pdt-tab="localities" data-pdt-body-class="page-gdf-localities" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Mahalle / Köy
    </a>
</div>
}
else
{
<div class="pdt-tabs pdt-tabs--sub" data-pdt-tabbar="1">
    <a href="/GeneralDefs/Sections" class="@TabClass("sections")" data-pdt-tab="sections" data-pdt-body-class="page-gdf-sections" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2"/>
            <path d="M3 9h18"/>
            <path d="M9 21V9"/>
        </svg>
        Bölümler
    </a>
    <a href="/GeneralDefs/SubSections" class="@TabClass("subsections")" data-pdt-tab="subsections" data-pdt-body-class="page-gdf-subsections" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2"/>
            <path d="M3 9h18"/>
            <path d="M3 15h18"/>
            <path d="M9 9v12"/>
            <path d="M15 9v12"/>
        </svg>
        Alt Bölümler
    </a>
</div>
}
