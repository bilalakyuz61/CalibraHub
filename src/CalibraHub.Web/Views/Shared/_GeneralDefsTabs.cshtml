@*
   Genel Tanımlamalar sekme barı — _ProductionDefsTabs (pdt-tabs) pattern'i birebir.
   2026-07-06: Adres Tanımlama grubu — Ülkeler / Şehirler / İlçeler ekranları tek
   kavramsal "Genel Tanımlamalar" altında sekmeyle gezilir. İleride yeni genel
   tanım grupları buraya sekme olarak eklenir.

   Her view üst kısma çağırır:
       <partial name="_GeneralDefsTabs" model='"countries"' />
   model = aktif tab key. pdt-* class + data attribute'ları korunur — mevcut
   PJAX (production-defs-pjax.js) aynı mekanizmayla bu sekmelerde de çalışır.
*@
@model string

@{
    var current = (Model ?? string.Empty).ToLowerInvariant();
    string TabClass(string key) =>
        string.Equals(key, current, StringComparison.OrdinalIgnoreCase) ? "pdt-tab active" : "pdt-tab";
}

<style>
    .pdt-tabs {
        display: flex; gap: 0; padding: 0 16px;
        background: transparent;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        flex-shrink: 0;
    }
    .pdt-tab {
        padding: 10px 16px; font-size: 13px; font-weight: 500; cursor: pointer;
        background: transparent;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        color: rgba(148, 163, 184, 0.85);
        text-decoration: none;
        display: inline-flex; align-items: center; gap: 7px;
        transition: color .12s, border-color .12s;
    }
    .pdt-tab:hover { color: #6366f1; }
    .pdt-tab.active {
        color: #6366f1;
        border-bottom-color: #6366f1;
        font-weight: 600;
    }
    body.app-theme-dark .pdt-tab.active { color: #a5b4fc; border-bottom-color: #a5b4fc; }
    body.app-theme-dark .pdt-tab:hover  { color: #a5b4fc; }
    .pdt-tab svg { opacity: 0.85; }
</style>

<div class="pdt-tabs" data-pdt-tabbar="1">
    <a href="/GeneralDefs/Countries" class="@TabClass("countries")" data-pdt-tab="countries" data-pdt-body-class="page-gdf-countries" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
            <path d="M2 12h20"/>
        </svg>
        Ülkeler
    </a>
    <a href="/GeneralDefs/Cities" class="@TabClass("cities")" data-pdt-tab="cities" data-pdt-body-class="page-gdf-cities" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/>
            <path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/>
            <path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>
            <path d="M10 6h4"/>
            <path d="M10 10h4"/>
            <path d="M10 14h4"/>
            <path d="M10 18h4"/>
        </svg>
        Şehirler
    </a>
    <a href="/GeneralDefs/Districts" class="@TabClass("districts")" data-pdt-tab="districts" data-pdt-body-class="page-gdf-districts" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
            <circle cx="12" cy="10" r="3"/>
        </svg>
        İlçeler
    </a>
</div>
