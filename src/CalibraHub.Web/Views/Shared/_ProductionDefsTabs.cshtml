@*
   Üretim Tanımlamaları sekme barı — Tasarım Kuralları (dlr-tabs) pattern'i.
   2026-05-21: Personel / Operasyon / Makine / Rota / Aktivite Sebepleri ekranları
   tek bir kavramsal "Üretim Tanımlamaları" altında sekmeyle gezilir.

   Her view bunu üst kısma çağırır:
       <partial name="_ProductionDefsTabs" model='"personnel"' />
   model = aktif tab key (büyük/küçük duyarsız). Boş veya tanımsızsa hiçbir tab active olmaz.
*@
@model string

@{
    var current = (Model ?? string.Empty).ToLowerInvariant();
    string TabClass(string key) =>
        string.Equals(key, current, StringComparison.OrdinalIgnoreCase) ? "pdt-tab active" : "pdt-tab";
}

<style>
    /* Üretim Tanımlamaları tab navigasyonu — DocLayoutRule dlr-tabs ile birebir görsel.
       Tema bağımsız (light/dark için ayrı override). */
    .pdt-tabs {
        display: flex; gap: 0; padding: 0 16px;
        background: transparent;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
        flex-shrink: 0;
    }
    .pdt-tab {
        padding: 10px 16px; font-size: 13px; font-weight: 500; cursor: pointer;
        background: transparent;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        color: rgba(148, 163, 184, 0.85);
        text-decoration: none;
        display: inline-flex; align-items: center; gap: 7px;
        transition: color .12s, border-color .12s;
    }
    .pdt-tab:hover { color: #6366f1; }
    .pdt-tab.active {
        color: #6366f1;
        border-bottom-color: #6366f1;
        font-weight: 600;
    }
    body.app-theme-dark .pdt-tab.active { color: #a5b4fc; border-bottom-color: #a5b4fc; }
    body.app-theme-dark .pdt-tab:hover  { color: #a5b4fc; }
    .pdt-tab svg { opacity: 0.85; }
</style>

<div class="pdt-tabs" data-pdt-tabbar="1">
    <a href="/Production/Personnel" class="@TabClass("personnel")" data-pdt-tab="personnel" data-pdt-body-class="page-personnel" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Personel
    </a>
    <a href="/Production/Operations" class="@TabClass("operations")" data-pdt-tab="operations" data-pdt-body-class="page-operations" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h0a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v0a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
        Operasyon
    </a>
    <a href="/Logistics/Machines" class="@TabClass("machines")" data-pdt-tab="machines" data-pdt-body-class="page-machines" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M9 3v18"/>
            <path d="M15 3v18"/>
            <path d="M3 9h18"/>
            <path d="M3 15h18"/>
        </svg>
        Makine
    </a>
    <a href="/Production/Routings" class="@TabClass("routings")" data-pdt-tab="routings" data-pdt-body-class="page-routings" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 6 2 18 2 18 9"/>
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
            <rect x="6" y="14" width="12" height="8"/>
        </svg>
        Rota
    </a>
    <a href="/Production/ActivityReasons" class="@TabClass("activityreasons")" data-pdt-tab="activityreasons" data-pdt-body-class="page-activity-reasons" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 9v4"/>
            <path d="M12 17h.01"/>
            <circle cx="12" cy="12" r="10"/>
        </svg>
        Aktivite Sebepleri
    </a>
    <a href="/Production/Shifts" class="@TabClass("shifts")" data-pdt-tab="shifts" data-pdt-body-class="page-shifts" data-workspace-ignore>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
        </svg>
        Vardiya
    </a>
</div>
