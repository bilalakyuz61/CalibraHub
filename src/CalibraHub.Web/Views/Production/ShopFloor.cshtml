    }

    /* ── Machines ── */
    async function loadMachines() {
        var grid = document.getElementById('machinesGrid');
        grid.innerHTML = '<div class="loader"></div>';
        try {
            var r = await fetch('/Production/ShopFloor/Machines?locationId=' + encodeURIComponent(state.locationId), { credentials: 'same-origin' });
            var list = await r.json();
            if (!Array.isArray(list) || list.length === 0) {
                grid.innerHTML = '<div class="empty"><div class="empty-icon">⚙️</div>Bu lokasyonda aktif makine yok.</div>';
