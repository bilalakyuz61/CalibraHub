@{
    Layout = null;
    ViewData["Title"] = "Üretim Kontrol Paneli";
}
<!DOCTYPE html>
<html lang="tr-TR" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#080c17" />
    <title>@ViewData["Title"]</title>
    @* 2026-05-22: Sayfa workspace iframe disi (top-level) yuklendiyse Shell'e yonlendir —
       Ctrl+Shift+R sonrasi sidebar/tab bar kaybolma sorununu cozer. Genuine kiosk modu
       icin URL'ye ?kiosk=1 eklenir (terminal tabletler bu modu kullanir, redirect olmaz).
       Workspace iframe icindeyse (?workspace=1) zaten dogru context, redirect yok. *@
    <script>
        (function () {
            var qs = window.location.search;
            var isKiosk = qs.indexOf('kiosk=1') !== -1;
            var isWorkspaceFrame = qs.indexOf('workspace=1') !== -1;
            var isTopLevel = window.top === window.self;
            if (isTopLevel && !isKiosk && !isWorkspaceFrame) {
                // Standalone yuklendi ama kiosk degil → Shell'e don, Shell tab'i restore eder
                window.location.replace('/');
            }
        })();
    </script>
    @* Premium design tokens (--surface-*, --text-*, --accent-*, --motion-*).
       Kiosk her zaman dark kalir — uretim alaninda LED ekran/gozyorgunlugu
       icin tercih edilen mod. body.app-theme-dark zorla aktif. *@
    <link rel="stylesheet" href="@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/css/tokens.css")" />
    <style>
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; user-select: none; -webkit-user-select: none; }
        html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
        body {
            font-family: var(--font-stack, 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif);
            background: var(--surface-base);
            color: var(--text-primary);
            font-size: 16px;
            color-scheme: dark;
        }
        a, button, input, select { font-family: inherit; }
        input { user-select: text; -webkit-user-select: text; }

        /* ── Layout: tek viewport, header + content ── */
        .shop-app { display: flex; flex-direction: column; height: 100dvh; min-height: 100dvh; }
        .shop-header {
            display: flex; align-items: center; gap: 16px;
            padding: 12px 24px;
            background: var(--surface-glass);
            border-bottom: 1px solid var(--border-subtle);
            backdrop-filter: blur(var(--blur-strength)) saturate(var(--blur-saturate));
            -webkit-backdrop-filter: blur(var(--blur-strength)) saturate(var(--blur-saturate));
            min-height: 64px; flex-shrink: 0;
        }
        .shop-header h1 {
            margin: 0; font-size: 20px;
            font-weight: var(--font-weight-semibold);
            flex: 1; letter-spacing: -.01em;
            color: var(--text-primary);
        }
        .shop-header .crumb {
            display: flex; align-items: center; gap: 8px; font-size: 14px;
            color: var(--text-secondary);
        }
        .shop-header .crumb-item {
            padding: 4px 12px; border-radius: 999px;
            background: var(--accent-soft-bg); color: var(--accent-soft-fg);
            font-weight: var(--font-weight-medium);
        }
        .shop-header .crumb-sep { opacity: .4; font-size: 18px; }
        .shop-header .who {
            display: flex; align-items: center; gap: 10px;
            padding: 6px 14px; border-radius: 999px;
            background: var(--success-soft-bg);
            border: 1px solid transparent;
            color: var(--success-soft-fg);
            font-size: 14px; font-weight: var(--font-weight-medium);
        }
        .shop-header .who-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: rgba(52,211,153,.3);
            display: flex; align-items: center; justify-content: center;
            font-weight: var(--font-weight-semibold);
            font-size: 12px; color: #6ee7b7;
        }
        .shop-header button.exit {
            display: inline-flex; align-items: center; gap: 8px;
            background: var(--danger-soft-bg);
            border: 1px solid transparent;
            color: var(--danger-soft-fg);
            padding: 10px 18px; border-radius: var(--radius-md);
            font-size: 15px; cursor: pointer;
            font-weight: var(--font-weight-semibold);
            min-height: 44px;
            transition: background var(--motion-fast) var(--motion-ease-out),
                        color      var(--motion-fast) var(--motion-ease-out);
        }
        .shop-header button.exit:hover { background: var(--danger); color: #fff; }
        .shop-header button.exit svg { width: 18px; height: 18px; flex-shrink: 0; }
        /* Tam ekran toggle */
        .shop-header button.fs {
            background: var(--surface-elev-2);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary);
            padding: 0; border-radius: var(--radius-md);
            width: 44px; height: 44px;
            display: inline-flex; align-items: center; justify-content: center;
            cursor: pointer; flex-shrink: 0;
            transition: background var(--motion-fast) var(--motion-ease-out),
                        color      var(--motion-fast) var(--motion-ease-out),
                        border-color var(--motion-fast) var(--motion-ease-out);
        }
        .shop-header button.fs:hover { background: var(--surface-elev-1); color: var(--text-primary); border-color: var(--border-strong); }
        .shop-header button.fs.is-active {
            background: var(--accent-soft-bg);
            border-color: transparent;
            color: var(--accent-soft-fg);
        }
        .shop-header button.fs svg { width: 20px; height: 20px; }
        .shop-header button.back {
            background: var(--accent-soft-bg);
            border: 1px solid transparent;
            color: var(--accent-soft-fg);
            padding: 10px 16px; border-radius: var(--radius-md);
            font-size: 15px; cursor: pointer;
            font-weight: var(--font-weight-semibold);
            min-height: 44px; min-width: 44px;
            transition: background var(--motion-fast) var(--motion-ease-out),
                        color      var(--motion-fast) var(--motion-ease-out);
        }
        .shop-header button.back:hover { background: var(--accent); color: #fff; }

        .shop-content { flex: 1 1 auto; min-height: 0; overflow: auto; padding: var(--space-5); }
        /* 2026-06-08: PIN ekranındayken dış padding'i kaldır — viewport'a göre clamp'lar
           içeride zaten boşluk sağlıyor; tek scroll'suz panel olarak çalışsın. */
        .shop-content:has(.shop-screen.is-active[data-screen="pin"]) { padding: 0; overflow: hidden; }
        .shop-screen[data-screen="pin"].is-active { height: 100%; }
        .shop-screen { display: none; }
        .shop-screen.is-active { display: block; }

        /* ── PIN entry screen ──
           2026-06-08: tüm boyutlar viewport-yüksekliğe duyarlı (clamp) — küçük
           ekranlarda scroll çıkmadan sığsın, büyük ekranlarda da nefes alsın. */
        .pin-screen {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            gap: clamp(8px, 1.6vh, 18px);
            height: 100%; min-height: 0;
            padding: clamp(8px, 1.5vh, 20px);
        }
        .pin-title {
            font-size: clamp(20px, 2.6vh, 28px);
            font-weight: var(--font-weight-bold, 700);
            text-align: center;
            margin: 0;
            color: var(--text-primary);
            letter-spacing: -.02em;
        }
        .pin-subtitle {
            font-size: clamp(12px, 1.5vh, 16px);
            color: var(--text-muted);
            text-align: center;
            margin: 0; max-width: 480px;
        }
        /* 2026-05-22 Sicil row */
        .sicil-row {
            display: flex; flex-direction: column; align-items: center;
            gap: 4px; margin: 0;
        }
        .sicil-label {
            font-size: 11px; color: var(--text-muted, #94a3b8);
            letter-spacing: 1px;
        }
        .sicil-input {
            width: 280px; max-width: 88vw;
            text-align: center;
            font-size: clamp(16px, 2vh, 22px);
            font-weight: 600;
            letter-spacing: 2px; text-transform: uppercase;
            padding: clamp(8px, 1.2vh, 12px) 18px;
            border-radius: 10px;
            background: var(--surface-elev-1, #ffffff);
            /* Tema-bağımsız orta-gri border — hem açık hem koyu arkaplanlarda görünür */
            border: 1.5px solid var(--border-strong, #94a3b8);
            color: var(--text-primary, #0f172a);
            outline: none; transition: border-color .12s, box-shadow .12s;
        }
        .sicil-input:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,.22);
        }
        /* Sicil boşken PIN denenirse — kırmızı border + shake. Mevcut pin-shake keyframe reuse. */
        .sicil-input.is-error {
            border-color: var(--danger, #ef4444);
            box-shadow: 0 0 0 3px rgba(239,68,68,.22);
        }
        .sicil-input.is-shake {
            animation: pin-shake .42s cubic-bezier(.36,.07,.19,.97) both;
        }
        .pin-display {
            display: flex; gap: clamp(8px, 1.4vh, 14px); justify-content: center;
            align-items: center;
        }
        .pin-dot {
            width: clamp(44px, 6.5vh, 64px); height: clamp(44px, 6.5vh, 64px);
            border-radius: 50%;
            background: var(--surface-elev-2);
            border: 2px solid var(--border-subtle);
            color: var(--text-muted);
            display: flex; align-items: center; justify-content: center;
            font-size: clamp(22px, 3vh, 30px);
            font-weight: var(--font-weight-bold, 700);
            transition: background var(--motion-fast) var(--motion-ease-out),
                        border-color var(--motion-fast) var(--motion-ease-out),
                        color var(--motion-fast) var(--motion-ease-out),
                        transform var(--motion-fast) var(--motion-ease-spring);
        }
        .pin-dot.filled {
            background: var(--accent-soft-bg);
            border-color: var(--accent);
            color: var(--accent-soft-fg);
            transform: scale(1.02);
        }
        .pin-display.is-error .pin-dot {
            background: var(--danger-soft-bg);
            border-color: var(--danger);
            color: var(--danger-soft-fg);
        }
        .pin-display.is-shake { animation: pin-shake .42s cubic-bezier(.36,.07,.19,.97) both; }
        @@keyframes pin-shake {
            10%, 90%   { transform: translateX(-2px); }
            20%, 80%   { transform: translateX(4px); }
            30%, 50%, 70% { transform: translateX(-8px); }
            40%, 60%   { transform: translateX(8px); }
        }
        .pin-display.is-busy { opacity: .6; pointer-events: none; }
        .pin-keypad {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: clamp(8px, 1.2vh, 14px);
            max-width: 360px; width: 100%;
        }
        .shop-touch-btn {
            min-height: clamp(54px, 8vh, 76px); min-width: clamp(54px, 8vh, 76px);
            border: 1px solid var(--border-subtle);
            background: var(--surface-elev-1);
            color: var(--text-primary);
            border-radius: var(--radius-lg);
            font-size: clamp(20px, 2.8vh, 28px);
            font-weight: var(--font-weight-semibold);
            cursor: pointer;
            transition: transform var(--motion-fast) var(--motion-ease-out),
                        background var(--motion-fast) var(--motion-ease-out),
                        border-color var(--motion-fast) var(--motion-ease-out);
            display: flex; align-items: center; justify-content: center;
        }
        .shop-touch-btn:hover { background: var(--surface-elev-2); border-color: var(--border-strong); }
        .shop-touch-btn:active { transform: scale(0.95); background: var(--accent-soft-bg); }
        .shop-touch-btn.is-action {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
            border-color: #4f46e5; color: #fff;
            font-size: 16px; font-weight: var(--font-weight-semibold);
            box-shadow: 0 1px 0 rgba(255,255,255,.14) inset, var(--shadow-elev-1);
        }
        .shop-touch-btn.is-action:hover { filter: brightness(1.08); }
        .shop-touch-btn.is-clear {
            background: var(--danger-soft-bg);
            border-color: transparent;
            color: var(--danger-soft-fg);
            font-size: 18px;
        }
        .shop-touch-btn.is-clear:hover { background: var(--danger); color: #fff; }
        .shop-touch-btn.is-secondary {
            background: var(--surface-elev-2);
            border-color: var(--border-subtle);
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: var(--font-weight-medium);
        }
        .pin-actions {
            display: flex; gap: 12px; justify-content: center; margin-top: 8px;
            flex-wrap: wrap;
        }
        .pin-error {
            color: var(--danger-soft-fg);
            font-size: 15px; min-height: 16px;
            text-align: center;
            font-weight: var(--font-weight-medium);
            margin-top: -6px; margin-bottom: -6px;
        }
        .pin-nfc-hint {
            margin-top: 8px;
            padding: 14px 22px;
            border-radius: var(--radius-lg);
            background: var(--success-soft-bg);
            border: 1px solid transparent;
            color: var(--success-soft-fg);
            font-size: 14px;
            display: flex; align-items: center; gap: 10px;
        }

        /* ── Card grid (Locations + Machines) ── */
        .shop-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: var(--space-4);
        }
        .shop-card {
            min-height: 140px;
            padding: 18px 20px;
            background: var(--surface-elev-1);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            display: flex; flex-direction: column; gap: 6px;
            cursor: pointer;
            box-shadow: var(--shadow-elev-1);
            transition: transform var(--motion-fast) var(--motion-ease-out),
                        background var(--motion-fast) var(--motion-ease-out),
                        border-color var(--motion-fast) var(--motion-ease-out),
                        box-shadow var(--motion-fast) var(--motion-ease-out);
        }
        .shop-card:hover {
            background: var(--accent-soft-bg);
            border-color: var(--accent);
            box-shadow: var(--shadow-elev-2);
            transform: translateY(-1px);
        }
        .shop-card:active { transform: scale(0.98); }
        .shop-card .icon {
            width: 40px; height: 40px;
            border-radius: var(--radius-md);
            background: var(--accent-soft-bg);
            color: var(--accent-soft-fg);
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 4px; flex-shrink: 0;
        }
        .shop-card .icon svg { width: 22px; height: 22px; }
        .shop-card .title {
            font-size: 17px;
            font-weight: var(--font-weight-semibold);
            color: var(--text-primary);
            line-height: 1.25;
            letter-spacing: -.01em;
        }
        .shop-card .subtitle { font-size: 13px; color: var(--text-muted); }
        .shop-card .stats { display: flex; gap: 10px; margin-top: auto; flex-wrap: wrap; }
        .shop-card .stat-pill {
            padding: 4px 10px; border-radius: 999px;
            font-size: 12px;
            font-weight: var(--font-weight-semibold);
            background: var(--surface-elev-2);
            color: var(--text-secondary);
            border: 1px solid var(--border-subtle);
        }
        .shop-card .stat-pill.is-busy { background: rgba(59,130,246,.18); color: #93c5fd; border-color: transparent; }
        .shop-card .stat-pill.is-pending { background: var(--warning-soft-bg); color: var(--warning-soft-fg); border-color: transparent; }

        /* ── Queue list ── */
        .queue-list { display: flex; flex-direction: column; gap: var(--space-3); }
        .queue-row {
            background: var(--surface-elev-1);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            padding: 16px 18px;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 12px; align-items: center;
            box-shadow: var(--shadow-elev-1);
            transition: border-color var(--motion-fast) var(--motion-ease-out),
                        box-shadow   var(--motion-fast) var(--motion-ease-out);
        }
        .queue-row .info { min-width: 0; }
        .queue-row .order {
            font-size: 16px;
            font-weight: var(--font-weight-semibold);
            color: var(--text-primary);
            letter-spacing: -.005em;
        }
        .queue-row .meta {
            font-size: 13px; color: var(--text-muted);
            margin-top: 2px;
            display: flex; flex-wrap: wrap; gap: 6px 14px;
        }
        .queue-row .meta strong { color: var(--text-primary); font-weight: var(--font-weight-medium); }
        .queue-row .actions { display: flex; gap: 10px; flex-wrap: wrap; }
        .queue-row .actions button { min-height: 56px; min-width: 110px; font-size: 14px; }
        .queue-row .actions .start    { background: linear-gradient(135deg, #16a34a 0%, #059669 100%); border-color: #059669; color: #fff; box-shadow: 0 1px 0 rgba(255,255,255,.14) inset, var(--shadow-elev-1); }
        .queue-row .actions .partial  { background: var(--warning-soft-bg); border-color: transparent; color: var(--warning-soft-fg); }
        .queue-row .actions .complete { background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); border-color: #4f46e5; color: #fff; box-shadow: 0 1px 0 rgba(255,255,255,.14) inset, var(--shadow-elev-1); }
        .queue-row.is-progress {
            border-color: rgba(59,130,246,.4);
            background: rgba(59,130,246,.06);
            box-shadow: var(--shadow-elev-2);
        }
        .queue-row .status-pill {
            display: inline-block; padding: 3px 10px; border-radius: 999px;
            font-size: 11px;
            font-weight: var(--font-weight-semibold);
            letter-spacing: .04em;
            background: var(--surface-elev-2); color: var(--text-secondary);
            border: 1px solid var(--border-subtle);
            margin-bottom: 4px;
        }
        .queue-row .status-pill.is-pending  { background: var(--warning-soft-bg); color: var(--warning-soft-fg); border-color: transparent; }
        .queue-row .status-pill.is-progress { background: rgba(59,130,246,.20); color: #93c5fd; border-color: transparent; }

        /* ── Faz 3 ShopFloor UX zenginlikleri ── */
        /* Mamul satırı — operasyon başlığı altında muted ufak metin */
        .queue-row .item-line {
            font-size: 13px; color: var(--text-secondary);
            margin-top: 3px;
            font-weight: var(--font-weight-medium);
        }
        .queue-row .item-line strong { color: var(--text-primary); font-weight: var(--font-weight-semibold); }

        /* Notlar badge'i — operasyonda not varsa amber kart üstünde */
        .queue-row .notes-badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 5px 10px; border-radius: var(--radius-md);
            font-size: 12.5px;
            font-weight: var(--font-weight-semibold);
            background: var(--warning-soft-bg);
            color: var(--warning-soft-fg);
            border: 1px solid transparent;
            margin-top: 6px; max-width: 100%;
        }
        .queue-row .notes-badge::before { content: '📝'; }

        /* İlerleme bar — üretilen/planlanan oran */
        .queue-row .progress-block {
            margin-top: 8px;
            display: flex; flex-direction: column; gap: 4px;
        }
        .queue-row .progress-bar {
            height: 8px; border-radius: 999px;
            background: var(--surface-elev-2);
            border: 1px solid var(--border-subtle);
            overflow: hidden;
        }
        .queue-row .progress-bar > span {
            display: block; height: 100%;
            background: linear-gradient(90deg, #16a34a, #22d3ee);
            border-radius: 999px;
            transition: width var(--motion-slow) var(--motion-ease-out);
        }
        .queue-row .progress-bar.is-over > span {
            background: linear-gradient(90deg, #f59e0b, #ef4444);
        }
        .queue-row .progress-info {
            display: flex; justify-content: space-between;
            font-size: 12px; color: var(--text-muted);
            font-variant-numeric: tabular-nums;
        }

        /* Canlı timer — "Devam ediyor" satırlarında StartedAt'tan beri geçen süre */
        .queue-row .timer-pill {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 4px 10px; border-radius: 999px;
            font-size: 12px;
            font-weight: var(--font-weight-semibold);
            background: rgba(59,130,246,.18); color: #93c5fd;
            border: 1px solid transparent;
            font-variant-numeric: tabular-nums;
            margin-left: 8px;
        }
        .queue-row .timer-pill.is-over {
            background: var(--danger-soft-bg);
            color: var(--danger-soft-fg);
            border-color: transparent;
            animation: timerPulse 1.4s ease-in-out infinite;
        }
        @@keyframes timerPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0); }
            50%      { box-shadow: 0 0 0 6px rgba(239,68,68,.15); }
        }
        .queue-row .timer-pill::before { content: '⏱'; font-size: 14px; }

        /* Modal — Kısmi bitir hızlı butonlar (Tüm + ayarla) */
        .modal-quick-btns {
            display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap;
        }
        .modal-quick-btns button {
            flex: 1 1 auto; min-height: 44px; min-width: 64px;
            padding: 8px 14px;
            font-size: 13px;
            font-weight: var(--font-weight-semibold);
            background: var(--accent-soft-bg);
            color: var(--accent-soft-fg);
            border: 1px solid transparent;
            border-radius: var(--radius-md);
            cursor: pointer;
            transition: background var(--motion-fast) var(--motion-ease-out),
                        color      var(--motion-fast) var(--motion-ease-out);
        }
        .modal-quick-btns button:hover { background: var(--accent); color: #fff; }
        .modal-quick-btns .quick-all {
            background: var(--success-soft-bg);
            color: var(--success-soft-fg);
            border-color: transparent;
        }
        .modal-quick-btns .quick-all:hover { background: var(--success); color: #fff; }

        .empty {
            text-align: center; padding: 60px 20px;
            color: var(--text-muted); font-size: 15px;
        }
        .empty-icon {
            font-size: 56px; margin-bottom: 12px;
        }

        /* ── Modal (Kısmi Bitir / Bitir miktar girişi) ── */
        .modal-backdrop {
            position: fixed; inset: 0; z-index: 200;
            background: rgba(0, 0, 0, 0.55);
            backdrop-filter: blur(8px) saturate(160%);
            -webkit-backdrop-filter: blur(8px) saturate(160%);
            display: flex; align-items: center; justify-content: center;
            padding: var(--space-5);
        }
        .modal-card {
            width: min(520px, 100%);
            background: var(--surface-elev-1);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-xl);
            padding: var(--space-5);
            box-shadow: var(--shadow-elev-3);
            color: var(--text-primary);
        }
        .modal-card h2 {
            margin: 0 0 6px;
            font-size: 22px;
            font-weight: var(--font-weight-bold, 700);
            letter-spacing: -.015em;
            color: var(--text-primary);
        }
        .modal-card .modal-hint {
            color: var(--text-muted);
            font-size: 14px;
            margin-bottom: 18px;
        }
        .modal-row { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
        .modal-row label {
            font-size: 11px;
            letter-spacing: .06em;
            color: var(--text-muted);
            font-weight: var(--font-weight-semibold);
        }
        .modal-row input[type=number] {
            width: 100%; padding: 14px 16px;
            font-size: 22px;
            font-weight: var(--font-weight-semibold);
            background: var(--surface-elev-2);
            color: var(--text-primary);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-md);
            outline: none; text-align: right;
            font-variant-numeric: tabular-nums;
            transition: border-color var(--motion-fast) var(--motion-ease-out),
                        box-shadow   var(--motion-fast) var(--motion-ease-out);
        }
        .modal-row input[type=number]:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 var(--ring-width) var(--ring-color);
        }
        .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 18px; flex-wrap: wrap; }
        .modal-actions button { min-height: 52px; min-width: 110px; font-size: 15px; font-weight: var(--font-weight-semibold); }

        /* Toast */
        #toast {
            position: fixed; left: 50%; top: 90px; transform: translateX(-50%);
            padding: 14px 22px;
            border-radius: var(--radius-lg);
            font-size: 15px;
            font-weight: var(--font-weight-semibold);
            z-index: 300;
            box-shadow: var(--shadow-elev-3);
            display: none;
            min-width: 240px; text-align: center;
            border: 1px solid;
            backdrop-filter: blur(var(--blur-strength)) saturate(var(--blur-saturate));
            -webkit-backdrop-filter: blur(var(--blur-strength)) saturate(var(--blur-saturate));
        }
        #toast.ok  { background: var(--success-soft-bg); color: var(--success-soft-fg); border-color: var(--success); }
        #toast.err { background: var(--danger-soft-bg);  color: var(--danger-soft-fg);  border-color: var(--danger); }

        /* Spinner */
        .loader {
            width: 36px; height: 36px;
            border: 4px solid var(--border-subtle);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin .8s linear infinite;
            margin: 40px auto;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        /* ── 2026-05-20 Faz 1 MVP: Aktivite log UI ── */
        /* Aktif aktivite pill — status pill + timer pill yaninda. Tip bazli renk. */
        .activity-pill {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 4px 10px; border-radius: 999px;
            font-size: 12px; font-weight: var(--font-weight-semibold);
            background: rgba(99,102,241,.18); color: #a5b4fc;
            border: 1px solid rgba(99,102,241,.35);
            margin-left: 8px;
        }
        .activity-pill.is-production    { background: rgba(34,197,94,.16);  color: #4ade80; border-color: rgba(34,197,94,.4); }
        .activity-pill.is-setup         { background: rgba(99,102,241,.16); color: #a5b4fc; border-color: rgba(99,102,241,.4); }
        .activity-pill.is-wait          { background: rgba(245,158,11,.16); color: #fbbf24; border-color: rgba(245,158,11,.4); }
        .activity-pill.is-breakdown     { background: rgba(239,68,68,.16);  color: #f87171; border-color: rgba(239,68,68,.4); }
        .activity-pill.is-quality       { background: rgba(14,165,233,.16); color: #38bdf8; border-color: rgba(14,165,233,.4); }
        .activity-pill.is-break         { background: rgba(168,85,247,.16); color: #c084fc; border-color: rgba(168,85,247,.4); }
        .activity-pill.is-shift         { background: rgba(244,114,182,.16);color: #f472b6; border-color: rgba(244,114,182,.4); }
        .activity-pill.is-planned       { background: rgba(100,116,139,.18);color: #94a3b8; border-color: rgba(100,116,139,.4); }
        .activity-pill.is-other         { background: rgba(255,255,255,.06);color: #e2e8f0; border-color: rgba(255,255,255,.15); }

        /* Aktivite tip secimi modal — buyuk dokunmatik butonlar grid */
        .activity-grid {
            display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;
            margin-top: 6px;
        }
        .activity-grid button {
            min-height: 64px;
            padding: 12px 14px; border-radius: var(--radius-md);
            background: var(--surface-elev-2); color: var(--text-primary);
            border: 1px solid var(--border-subtle);
            font-size: 14px; font-weight: var(--font-weight-semibold);
            cursor: pointer; text-align: left;
            display: flex; flex-direction: column; gap: 2px;
            transition: background .12s, border-color .12s;
        }
        .activity-grid button:hover { background: rgba(99,102,241,.12); border-color: rgba(99,102,241,.5); }
        .activity-grid button.is-current { background: rgba(99,102,241,.18); border-color: rgba(99,102,241,.7); }
        .activity-grid button small { font-size: 11px; color: var(--text-muted); font-weight: var(--font-weight-regular); }

        /* Hareket Gecmisi tablosu */
        .history-table {
            width: 100%; border-collapse: collapse; font-size: 13px;
            background: var(--surface-elev-2); border-radius: var(--radius-md); overflow: hidden;
        }
        .history-table th, .history-table td {
            padding: 8px 10px; text-align: left;
            border-bottom: 1px solid var(--border-subtle);
        }
        .history-table th {
            background: rgba(255,255,255,.04); color: var(--text-muted);
            font-size: 11px; letter-spacing: .05em;
        }
        .history-table td.num { text-align: right; font-variant-numeric: tabular-nums; }
        .history-table tr.is-active td { background: rgba(34,197,94,.08); }
        .history-empty { padding: 24px; text-align: center; color: var(--text-muted); }
    </style>
</head>
<body>
<div class="shop-app">
    <div class="shop-header">
        <button class="back" id="btnBack" style="display:none;" title="Geri">←</button>
        <h1 id="screenTitle">Üretim Kontrol</h1>
        <div class="crumb" id="crumb"></div>
        <div class="who" id="whoBadge" style="display:none;">
            <div class="who-avatar" id="whoAvatar">?</div>
            <span id="whoName">—</span>
        </div>
        <button class="fs" id="btnFullscreen" title="Tam ekran (F11)" aria-label="Tam ekran">
            <svg id="fsIconEnter" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-5h-4m4 0v4m0-4l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
            </svg>
            <svg id="fsIconExit" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V5m0 4H5m4 0L4 4m11 5h4m-4 0V5m0 4l5-5M9 15v4m0-4H5m4 0l-5 5m11-5h4m-4 0v4m0-4l5 5"/>
            </svg>
        </button>
        <button class="exit" id="btnExit" style="display:none;" title="Operatör çıkışı (PIN ekranına dön)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            <span>Çıkış</span>
        </button>
    </div>

    <div class="shop-content">
        <!-- 1: PIN entry -->
        <div class="shop-screen is-active" data-screen="pin">
            <div class="pin-screen">
                <h2 class="pin-title">Operatör Girişi</h2>
                <p class="pin-subtitle">Sicil numaranızı + PIN kodunuzu girin, veya NFC kartınızı okutun.</p>

                @* 2026-05-22: Sicil No (PersonnelCode) zorunlu — PIN brute-force koruması.
                   Kullanici once sicil yazar (manuel klavye veya barkod), sonra keypad ile PIN.
                   Auto-submit PIN 4. karakterde sicil dolu ise calisir. *@
                <div class="sicil-row">
                    <label class="sicil-label" for="sicilInput">Sicil No</label>
                    <input type="text" id="sicilInput" class="sicil-input"
                           autocomplete="off"
                           autocapitalize="characters" inputmode="text"
                           maxlength="30" />
                </div>

                <div class="pin-display" id="pinDisplay"></div>
                <div class="pin-error" id="pinError">&nbsp;</div>
                <div class="pin-keypad">
                    <button type="button" class="shop-touch-btn" data-pin-key="1">1</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="2">2</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="3">3</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="4">4</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="5">5</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="6">6</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="7">7</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="8">8</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="9">9</button>
                    <button type="button" class="shop-touch-btn is-clear" id="pinClear">⌫</button>
                    <button type="button" class="shop-touch-btn" data-pin-key="0">0</button>
                    <button type="button" class="shop-touch-btn is-action" id="pinSubmit">Giriş</button>
                </div>
                <div class="pin-actions">
                    <button type="button" class="shop-touch-btn is-secondary" id="pinNfcBtn" style="min-height:52px;min-width:auto;padding:0 22px;">NFC Kart Okut</button>
                </div>
                <div class="pin-nfc-hint" id="pinNfcHint" style="display:none;">
                    <span>📡</span>
                    <span>Kartınızı tablete yaklaştırın…</span>
                </div>
            </div>
        </div>

        <!-- 2: Locations -->
        <div class="shop-screen" data-screen="locations">
            <div class="shop-grid" id="locationsGrid">
                <div class="loader"></div>
            </div>
        </div>

        <!-- 3: Machines -->
        <div class="shop-screen" data-screen="machines">
            <div class="shop-grid" id="machinesGrid">
                <div class="loader"></div>
            </div>
        </div>

        <!-- 4: Queue -->
        <div class="shop-screen" data-screen="queue">
            <div class="queue-list" id="queueList">
                <div class="loader"></div>
            </div>
        </div>
    </div>
</div>

<div id="toast"></div>
@Html.AntiForgeryToken()

<script>
(function () {
    'use strict';

    var IDLE_MS = 5 * 60 * 1000; // 5 dakika idle → PIN ekrana dön
    var REFRESH_MS = 15 * 1000;  // 15 sn'de bir queue refresh

    var state = {
        pin: '',
        operator: null,        // { id, fullName, code, ... }
        locationId: null, locationName: null,
        machineId: null, machineName: null,
        screen: 'pin',
        idleTimer: null,
        refreshTimer: null,
        nfcSupported: false,
    };

    function token() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }

    // 2026-05-22: ShopFloor session persistence —
    // localStorage kullaniliyor (sessionStorage degil) cunku ekran workspace tab
    // sisteminin iframe'i icinde calisiyor. Ctrl+Shift+R'da iframe browsing context
    // resetleniyor ve iframe-scoped sessionStorage temizleniyor. localStorage origin
    // bazli oldugu icin iframe re-mount'tan etkilenmez.
    //
    // Guvenlik notu: localStorage paylasimli (ayni origin'deki tum sekme + iframeler).
    // Operator PIN'i saklamiyoruz, sadece auth sonrasi backend'in dondugu basit
    // {id, name, code} objesi + secilen lokasyon/makine. Idle timeout (5dk) ve 8sa
    // hard cap ile eski oturumlar otomatik gecersiz.
    var SESSION_KEY = 'calibrahub.shopfloor.session';
    function saveSession() {
        try {
            if (!state.operator) { localStorage.removeItem(SESSION_KEY); return; }
            localStorage.setItem(SESSION_KEY, JSON.stringify({
                operator: state.operator,
                locationId: state.locationId, locationName: state.locationName,
                machineId: state.machineId, machineName: state.machineName,
                screen: state.screen,
                ts: Date.now(),
            }));
        } catch (e) { /* quota — sessizce gec */ }
    }
    function restoreSession() {
        try {
            var raw = localStorage.getItem(SESSION_KEY);
            if (!raw) return false;
            var data = JSON.parse(raw);
            if (!data || !data.operator || !data.operator.id) return false;
            // 8 saatten eski oturum geçersiz say (cron olarak sürekli açık kalan tabletler için)
            if (data.ts && (Date.now() - data.ts) > 8 * 60 * 60 * 1000) {
                localStorage.removeItem(SESSION_KEY);
                return false;
            }
            state.operator   = data.operator;
            state.locationId = data.locationId || null;
            state.locationName = data.locationName || null;
            state.machineId  = data.machineId || null;
            state.machineName = data.machineName || null;
            // Restore screen — locationsId/machineId varsa o ekrana git, yoksa locations
            var target = data.screen || 'locations';
            if (target === 'queue' && !state.machineId) target = 'machines';
            if (target === 'machines' && !state.locationId) target = 'locations';
            if (target === 'pin') target = 'locations';   // PIN durumu kaydedilmez
            gotoScreen(target);
            return true;
        } catch (e) { return false; }
    }
    function clearSession() {
        try { localStorage.removeItem(SESSION_KEY); } catch (e) {}
    }
    function escapeHtml(s) { return (s == null ? '' : String(s)).replace(/[&<>"']/g, function (c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
    function toast(msg, ok) {
        var el = document.getElementById('toast');
        el.textContent = msg; el.className = ok ? 'ok' : 'err'; el.style.display = 'block';
        clearTimeout(window.__toastTm);
        window.__toastTm = setTimeout(function(){ el.style.display = 'none'; }, 3500);
    }

    function gotoScreen(name) {
        state.screen = name;
        var screens = document.querySelectorAll('.shop-screen');
        for (var i = 0; i < screens.length; i++) {
            screens[i].classList.toggle('is-active', screens[i].getAttribute('data-screen') === name);
        }
        var back = document.getElementById('btnBack');
        var exit = document.getElementById('btnExit');
        var who = document.getElementById('whoBadge');
        var title = document.getElementById('screenTitle');
        var crumb = document.getElementById('crumb');
        if (name === 'pin') {
            back.style.display = 'none'; exit.style.display = 'none'; who.style.display = 'none';
            title.textContent = 'Üretim Kontrol';
            crumb.innerHTML = '';
            state.pin = ''; renderPinDisplay();
            document.getElementById('pinError').textContent = '';
            // 2026-05-22: Sicil input'u da temizle ve focus ver
            var sicilEl = document.getElementById('sicilInput');
            if (sicilEl) { sicilEl.value = ''; setTimeout(function() { sicilEl.focus(); }, 50); }
        } else {
            back.style.display = 'inline-flex'; exit.style.display = 'inline-flex'; who.style.display = 'inline-flex';
            if (state.operator) {
                document.getElementById('whoName').textContent = state.operator.fullName + (state.operator.code ? ' · ' + state.operator.code : '');
                document.getElementById('whoAvatar').textContent = (state.operator.fullName || '').slice(0,1).toUpperCase();
            }
        }
        if (name === 'locations') {
            title.textContent = 'Lokasyon Seç';
            crumb.innerHTML = '';
            loadLocations();
        }
        if (name === 'machines') {
            title.textContent = 'Makine Seç';
            crumb.innerHTML = '<span class="crumb-item">' + escapeHtml(state.locationName || '') + '</span>';
            loadMachines();
        }
        if (name === 'queue') {
            title.textContent = 'Kuyruk';
            crumb.innerHTML = '<span class="crumb-item">' + escapeHtml(state.locationName || '') + '</span><span class="crumb-sep">→</span><span class="crumb-item">' + escapeHtml(state.machineName || '') + '</span>';
            loadQueue();
            startQueueRefresh();
        } else {
            stopQueueRefresh();
        }
        // 2026-05-22: Ekran degisiminde session'i guncelle (refresh sonrasi son ekrana donsun)
        if (name !== 'pin' && state.operator) saveSession();
        resetIdle();
    }

    /* ── Idle timer: 5 dk inaktif → PIN ekran ── */
    function resetIdle() {
        clearTimeout(state.idleTimer);
        if (state.screen === 'pin') return; // PIN ekranındaysa zaten beklemede
        state.idleTimer = setTimeout(function() {
            logout('Otomatik çıkış: 5 dakika hareket yok.');
        }, IDLE_MS);
    }
    ['mousedown','keydown','touchstart','pointerdown'].forEach(function (ev) {
        document.addEventListener(ev, resetIdle, { passive: true });
    });

    function logout(reason) {
        stopQueueRefresh();
        state.operator = null;
        state.locationId = state.locationName = null;
        state.machineId = state.machineName = null;
        state.pin = '';
        clearSession();   // 2026-05-22: persisted session sil
        gotoScreen('pin');
        if (reason) toast(reason, false);
    }

    /* ── PIN keypad ──
       Davranış:
       - 4. karakter girilince otomatik authByPin() tetiklenir.
       - Doğru ise → lokasyon ekranına geçer.
       - Yanlış ise → noktalar kırmızı + 0.42sn shake; bittiğinde PIN sıfırlanır,
         klavye tekrar aktif olur.
       - Operatör 4 hane PIN seçemese de 5-6 hane girmek isteyebilir → 4 sn'lik
         "ekstra hane" toleransı: 4. karakterde otomatik submit yerine 800ms
         bekleyip ek tuş gelmediyse submit edelim. Böylece 5-10 haneli PIN'ler
         kullanılabilir kalır. */
    var PIN_AUTO_LEN = 4;          // ne zaman auto-submit denemeye başla
    var PIN_AUTO_DELAY = 800;      // ms — ek tuş bekleme süresi
    var pinAutoTm = null;

    function setPinError(active) {
        var el = document.getElementById('pinDisplay');
        if (!el) return;
        if (active) {
            el.classList.remove('is-shake'); // restart animation
            // force reflow
            void el.offsetWidth;
            el.classList.add('is-error', 'is-shake');
        } else {
            el.classList.remove('is-error', 'is-shake');
        }
    }

    function setPinBusy(busy) {
        var el = document.getElementById('pinDisplay');
        if (!el) return;
        el.classList.toggle('is-busy', !!busy);
    }

    /* Sicil input'u kırmızı çerçeve + shake — PIN girilip sicil boş kalırsa. */
    function setSicilError(active) {
        var el = document.getElementById('sicilInput');
        if (!el) return;
        if (active) {
            el.classList.remove('is-shake');
            void el.offsetWidth; // animasyonu yeniden başlatmak için reflow
            el.classList.add('is-error', 'is-shake');
        } else {
            el.classList.remove('is-error', 'is-shake');
        }
    }
    // Kullanıcı sicil yazmaya başlar başlamaz hata state'i kalksın.
    (function () {
        var el = document.getElementById('sicilInput');
        if (el) {
            el.addEventListener('input', function () { setSicilError(false); });
            el.addEventListener('focus', function () { setSicilError(false); });
        }
    })();

    function renderPinDisplay() {
        var el = document.getElementById('pinDisplay');
        var len = Math.max(state.pin.length, 4);
        var html = '';
        for (var i = 0; i < len; i++) {
            var ch = i < state.pin.length ? '•' : '';
            html += '<div class="pin-dot' + (ch ? ' filled' : '') + '">' + ch + '</div>';
        }
        // Hata state'ini ve shake'i koruyalım — class list innerHTML değiştirmiyor.
        el.innerHTML = html;
    }

    function schedulePinAutoSubmit() {
        if (pinAutoTm) { clearTimeout(pinAutoTm); pinAutoTm = null; }
        if (state.pin.length < PIN_AUTO_LEN) return;
        pinAutoTm = setTimeout(function () {
            pinAutoTm = null;
            // Hâlâ aynı PIN'deysek ve ekrandaysak — submit
            if (state.screen === 'pin' && state.pin.length >= PIN_AUTO_LEN) authByPin();
        }, PIN_AUTO_DELAY);
    }

    function pinKeyPressed(digit) {
        if (state.pin.length >= 10) return;
        // Önceki hata state'ini temizle (kullanıcı yeniden deneyince)
        setPinError(false);
        document.getElementById('pinError').textContent = '';
        state.pin += digit; renderPinDisplay();
        schedulePinAutoSubmit();
    }

    function pinBackspace() {
        if (pinAutoTm) { clearTimeout(pinAutoTm); pinAutoTm = null; }
        setPinError(false);
        document.getElementById('pinError').textContent = '';
        state.pin = state.pin.slice(0, -1); renderPinDisplay();
    }

    document.querySelectorAll('[data-pin-key]').forEach(function (b) {
        b.addEventListener('click', function() { pinKeyPressed(b.dataset.pinKey); });
    });
    document.getElementById('pinClear').addEventListener('click', pinBackspace);
    document.getElementById('pinSubmit').addEventListener('click', function () {
        if (pinAutoTm) { clearTimeout(pinAutoTm); pinAutoTm = null; }
        authByPin();
    });
    document.addEventListener('keydown', function(e) {
        if (state.screen !== 'pin') return;
        if (/^[0-9]$/.test(e.key)) { pinKeyPressed(e.key); }
        else if (e.key === 'Backspace') { pinBackspace(); }
        else if (e.key === 'Enter') {
            if (pinAutoTm) { clearTimeout(pinAutoTm); pinAutoTm = null; }
            authByPin();
        }
    });

    async function authByPin() {
        if (!state.pin) { document.getElementById('pinError').textContent = 'PIN girmediniz.'; return; }
        // 2026-05-22: Sicil zorunlu — PIN ile birlikte gönder
        var sicilEl = document.getElementById('sicilInput');
        var sicil = sicilEl ? sicilEl.value.trim() : '';
        if (!sicil) {
            document.getElementById('pinError').textContent = 'Sicil numarası girilmedi.';
            setSicilError(true);
            sicilEl && sicilEl.focus();
            return;
        }
        await authOperator({ personnelCode: sicil, pinCode: state.pin });
    }

    async function authOperator(body) {
        setPinBusy(true);
        try {
            var r = await fetch('/Production/AuthOperator', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify(body)
            });
            var data = await r.json();
            if (!data.ok) {
                // Yanlış PIN → noktaları kırmızı yap + shake, PIN sıfırla
                document.getElementById('pinError').textContent = data.error || 'Giriş başarısız.';
                setPinError(true);
                state.pin = ''; renderPinDisplay();
                // Animasyon bitince error state'i bırak (yeni tuş zaten temizliyor)
                return;
            }
            state.operator = data.operator_;
            document.getElementById('pinError').textContent = '';
            setPinError(false);
            saveSession();   // 2026-05-22: operatör girişi sonrası persist
            gotoScreen('locations');
        } catch (ex) {
            document.getElementById('pinError').textContent = 'İstek hatası: ' + ex.message;
            setPinError(true);
            state.pin = ''; renderPinDisplay();
        } finally {
            setPinBusy(false);
        }
    }

    /* ── NFC (Web NFC API) — Chrome Android destekli ── */
    var nfcReader = null;
    var nfcAbort = null;
    document.getElementById('pinNfcBtn').addEventListener('click', async function () {
        var hint = document.getElementById('pinNfcHint');
        if (!('NDEFReader' in window)) {
            toast('Bu cihaz / tarayıcı NFC API desteklemiyor.', false);
            return;
        }
        try {
            nfcAbort = new AbortController();
            nfcReader = new window.NDEFReader();
            await nfcReader.scan({ signal: nfcAbort.signal });
            hint.style.display = 'flex';
            nfcReader.onreading = async function (event) {
                var serial = (event.serialNumber || '').replace(/:/g, '').toUpperCase();
                hint.style.display = 'none';
                if (nfcAbort) nfcAbort.abort();
                if (serial) await authOperator({ cardNo: serial });
            };
            nfcReader.onreadingerror = function () { toast('NFC okuma hatası.', false); hint.style.display = 'none'; };
        } catch (e) {
            toast('NFC başlatılamadı: ' + e.message, false);
        }
    });

