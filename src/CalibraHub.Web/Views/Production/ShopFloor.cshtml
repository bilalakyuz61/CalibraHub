    /* ── Queue + actions ── */
    function statusLabel(s) {
        s = Number(s) || 0;
        if (s === 0) return { label: 'Bekliyor', cls: 'is-pending' };
        if (s === 1) return { label: 'Devam ediyor', cls: 'is-progress' };
        if (s === 2) return { label: 'Tamamlandı', cls: '' };
        if (s === 3) return { label: 'Atlandı', cls: '' };
        return { label: '?', cls: '' };
    }
    function fmtNum(v) { return Number(v || 0).toFixed(2); }
    function fmtDur(d, unit) { if (d == null) return '—'; return Number(d).toFixed(2) + (unit === 2 ? ' sa' : ' dk'); }

    // Faz 3 ShopFloor UX — küçük yardımcılar
    function vibrate(pattern) {
        try { if (navigator.vibrate) navigator.vibrate(pattern); } catch (_) { /* ignore */ }
    }
    var _audioCtx = null;
    function beep(freq, durationMs, vol) {
        // Web Audio API ile kısa bip — gürültülü atölyede toast'a ek işitsel geri bildirim.
        try {
            if (!_audioCtx) {
                var Ctx = window.AudioContext || window.webkitAudioContext;
                if (!Ctx) return;
                _audioCtx = new Ctx();
            }
            var osc = _audioCtx.createOscillator();
            var gain = _audioCtx.createGain();
            osc.type = 'sine';
            osc.frequency.value = freq || 800;
            gain.gain.value = vol == null ? 0.06 : vol;
            osc.connect(gain); gain.connect(_audioCtx.destination);
            osc.start();
            osc.stop(_audioCtx.currentTime + (durationMs || 120) / 1000);
        } catch (_) { /* ignore */ }
    }
    function notify(msg, ok) {
        toast(msg, ok);
        if (ok) { vibrate(40); beep(880, 100, 0.05); }
        else    { vibrate([60, 40, 60]); beep(220, 200, 0.07); }
    }

    // Planlanan süreyi (dk/sa) saniye'ye çevir — timer karşılaştırması için.
    function plannedSeconds(d, unit) {
        if (d == null) return null;
        var n = Number(d) || 0;
        return Number(unit) === 2 ? n * 3600 : n * 60;
    }
    function fmtElapsed(secs) {
        if (secs == null || secs < 0) return '—';
        var s = Math.floor(secs);
        var h = Math.floor(s / 3600); s -= h * 3600;
        var m = Math.floor(s / 60);   s -= m * 60;
        var pad = function (n) { return n < 10 ? '0' + n : String(n); };
        return (h > 0 ? h + ':' + pad(m) : m) + ':' + pad(s);
    }

    async function loadQueue() {
        var list = document.getElementById('queueList');
        list.innerHTML = '<div class="loader"></div>';
        try {
            var r = await fetch('/Production/ShopFloor/Queue?machineId=' + encodeURIComponent(state.machineId), { credentials: 'same-origin' });
            var arr = await r.json();
            if (!Array.isArray(arr) || arr.length === 0) {
                list.innerHTML = '<div class="empty"><div class="empty-icon">✓</div>Bu makinede bekleyen iş yok.</div>';
                return;
            }
            list.innerHTML = arr.map(function (op) {
                var s = statusLabel(op.status);
                var isInProgress = (op.status || 0) === 1;

                // Mamul satırı (Faz 3 UX zenginlik)
                var woNum = op.workOrderNumber ? escapeHtml(op.workOrderNumber) : ('#' + op.workOrderId);
                var itemLine = (op.itemCode || op.itemName)
                    ? '<div class="item-line"><strong>' + escapeHtml(op.itemCode || '') + '</strong>'
                        + (op.itemName ? ' · ' + escapeHtml(op.itemName) : '') + '</div>'
                    : '';

                // İlerleme bar (üretilen / WO planlanan miktar)
                var planned  = Number(op.workOrderPlannedQuantity || 0);
                var produced = Number(op.producedQuantity || 0);
                var pct      = planned > 0 ? Math.min(100, (produced / planned) * 100) : 0;
                var isOverQty = planned > 0 && produced > planned;
                var progressBlock = planned > 0
                    ? '<div class="progress-block">'
                        + '<div class="progress-bar' + (isOverQty ? ' is-over' : '') + '"><span style="width:' + pct.toFixed(1) + '%;"></span></div>'
                        + '<div class="progress-info">'
                        +   '<span>Üretilen ' + fmtNum(produced) + ' / Planlanan ' + fmtNum(planned) + '</span>'
                        +   '<span>%' + pct.toFixed(1) + (isOverQty ? ' • aşım' : '') + '</span>'
                        + '</div>'
                      + '</div>'
                    : '';

                // Notlar badge'i (rota/op notu)
                var notesBadge = op.notes
                    ? '<div class="notes-badge">' + escapeHtml(op.notes) + '</div>'
                    : '';

                // Canlı timer placeholder — startedAt ISO ve plannedSec data-attribute'larında
                var timerHtml = '';
                if (isInProgress && op.startedAt) {
                    var ps = plannedSeconds(op.plannedDuration, op.durationUnit);
                    timerHtml = '<span class="timer-pill" data-timer-start="' + escapeHtml(op.startedAt)
                        + '" data-planned-sec="' + (ps == null ? '' : ps) + '">⏱ —</span>';
                }

                return '<div class="queue-row' + (isInProgress ? ' is-progress' : '') + '" data-id="' + op.id + '" data-planned-qty="' + planned + '" data-produced-qty="' + produced + '">'
                    + '<div class="info">'
                    +   '<div class="status-pill ' + s.cls + '">' + s.label + '</div>' + timerHtml
                    +   '<div class="order">İŞ EMRİ ' + woNum + ' · Sıra ' + (op.sequence || 0) + ' — ' + escapeHtml(op.operationName || op.operationCode || ('Op#' + op.operationId)) + '</div>'
                    +   itemLine
                    +   notesBadge
                    +   progressBlock
                    +   '<div class="meta">'
                    +     '<span><strong>Süre:</strong> ' + fmtDur(op.plannedDuration, op.durationUnit) + '</span>'
                    +     '<span><strong>Fire:</strong> ' + fmtNum(op.scrapQuantity) + '</span>'
                    +     (op.startedByPersonnelName ? '<span><strong>Başlatan:</strong> ' + escapeHtml(op.startedByPersonnelName) + '</span>' : '')
                    +   '</div>'
                    + '</div>'
                    + '<div class="actions">'
                    +   (isInProgress ? '' : '<button class="shop-touch-btn start" data-act="start">▶ Başlat</button>')
                    +   (isInProgress ? '<button class="shop-touch-btn partial" data-act="partial">+ Kısmi Bitir</button>' : '')
                    +   (isInProgress ? '<button class="shop-touch-btn complete" data-act="complete">✓ Bitir</button>' : '')
                    + '</div>'
                    + '</div>';
            }).join('');
            list.querySelectorAll('.queue-row').forEach(function (row) {
                var opId = Number(row.dataset.id);
                row.querySelector('[data-act="start"]')?.addEventListener('click', function () { actStart(opId); });
                row.querySelector('[data-act="partial"]')?.addEventListener('click', function () { actPartial(opId); });
                row.querySelector('[data-act="complete"]')?.addEventListener('click', function () { actComplete(opId); });
            });
            // İlk timer tickini hemen at — sonra setInterval canlı tutar
            tickTimers();
        } catch (e) {
            list.innerHTML = '<div class="empty">Yüklenemedi: ' + escapeHtml(e.message) + '</div>';
        }
    }

    function startQueueRefresh() {
        stopQueueRefresh();
        state.refreshTimer = setInterval(function () { if (state.screen === 'queue') loadQueue(); }, REFRESH_MS);
    }
    function stopQueueRefresh() { if (state.refreshTimer) { clearInterval(state.refreshTimer); state.refreshTimer = null; } }

    // ── Canlı timer — 1 sn'lik interval, "Devam ediyor" satırlarındaki ⏱ pill'ini günceller.
    // Başlama anından beri geçen süreyi hh:mm:ss / mm:ss biçiminde basar; planlanan
    // süre aşıldıysa rose renge geçer + pulse animasyonu (CSS'te tanımlı).
    function tickTimers() {
        var now = Date.now();
        document.querySelectorAll('.timer-pill[data-timer-start]').forEach(function (el) {
            var startedIso = el.getAttribute('data-timer-start');
            if (!startedIso) return;
            var startedMs = Date.parse(startedIso);
            if (isNaN(startedMs)) return;
            var elapsedSec = (now - startedMs) / 1000;
            el.textContent = '⏱ ' + fmtElapsed(elapsedSec);
            var plannedSec = parseFloat(el.getAttribute('data-planned-sec'));
            if (!isNaN(plannedSec) && plannedSec > 0 && elapsedSec > plannedSec) {
                el.classList.add('is-over');
            } else {
                el.classList.remove('is-over');
            }
        });
    }
    setInterval(tickTimers, 1000);

    async function actStart(opId) {
        try {
            var r = await fetch('/Production/ShopFloor/Start', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({ workOrderOperationId: opId, operatorPersonnelId: state.operator.id })
            });
            var d = await r.json();
            if (!d.ok) { notify(d.error || 'Başlatılamadı.', false); return; }
            notify('Başlatıldı.', true); loadQueue();
        } catch (e) { notify('Hata: ' + e.message, false); }
    }

    function showQuantityModal(opts) {
        return new Promise(function (resolve) {
            var bd = document.createElement('div');
            bd.className = 'modal-backdrop';

            // Quick butonlar — "Tüm" (kalanı tek tıkla doldur), ½, ¼ kısayolları.
            // remainingQty (planlanan - üretilen) verildiyse oluşturulur.
            var remaining = opts.remainingQty;
            var hasRemaining = (remaining != null && Number(remaining) > 0);
            var quickHtml = '';
            if (hasRemaining) {
                var half    = (Number(remaining) / 2).toFixed(2);
                var quarter = (Number(remaining) / 4).toFixed(2);
                quickHtml = '<div class="modal-quick-btns">'
                    + '<button type="button" data-quick="' + quarter + '">¼ · ' + quarter + '</button>'
                    + '<button type="button" data-quick="' + half + '">½ · ' + half + '</button>'
                    + '<button type="button" class="quick-all" data-quick="' + Number(remaining).toFixed(2) + '">Tüm · ' + Number(remaining).toFixed(2) + '</button>'
                    + '</div>';
            }

            bd.innerHTML = '<div class="modal-card">'
                + '<h2>' + escapeHtml(opts.title) + '</h2>'
                + '<div class="modal-hint">' + escapeHtml(opts.hint || '') + '</div>'
                + '<div class="modal-row"><label>' + escapeHtml(opts.qtyLabel || 'Miktar') + '</label><input type="number" inputmode="decimal" id="modalQty" step="0.01" min="0" value="' + (opts.defaultQty != null ? opts.defaultQty : '') + '" />'
                +   quickHtml
                + '</div>'
                + (opts.showScrap ? '<div class="modal-row"><label>Fire (opsiyonel)</label><input type="number" inputmode="decimal" id="modalScrap" step="0.01" min="0" value="" /></div>' : '')
                + '<div class="modal-actions">'
                +   '<button class="shop-touch-btn is-secondary" id="modalCancel">Vazgeç</button>'
                +   '<button class="shop-touch-btn is-action" id="modalOk">' + escapeHtml(opts.okLabel || 'Tamam') + '</button>'
                + '</div></div>';
            document.body.appendChild(bd);
            var qtyEl = bd.querySelector('#modalQty');
            var scrapEl = bd.querySelector('#modalScrap');
            setTimeout(function () { qtyEl.focus(); qtyEl.select(); }, 50);
            function close(val) { document.body.removeChild(bd); resolve(val); }
            bd.querySelector('#modalCancel').addEventListener('click', function () { close(null); });
            bd.querySelectorAll('[data-quick]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    qtyEl.value = btn.getAttribute('data-quick');
                    qtyEl.focus(); qtyEl.select();
                });
            });
            bd.querySelector('#modalOk').addEventListener('click', async function () {
                var q = parseFloat(qtyEl.value);
                if (Number.isNaN(q)) { qtyEl.focus(); return; }
                // Aşma onayı — hasRemaining ise ve girilen miktar kalan miktardan büyükse uyar (rapor §6.6 — CalibraAlert.confirm).
                if (hasRemaining && q > Number(remaining) + 0.0001) {
                    var msg = 'Girilen miktar (' + q.toFixed(2)
                        + ') planlanan kalan miktarı (' + Number(remaining).toFixed(2) + ') aşıyor.';
                    var ok = window.CalibraAlert && window.CalibraAlert.confirm
                        ? await window.CalibraAlert.confirm({ title: 'Miktar aşımı', message: msg, okLabel: 'Devam Et' })
                        : confirm(msg + '\n\nDevam edilsin mi?');
                    if (!ok) { qtyEl.focus(); qtyEl.select(); return; }
                }
                var s = scrapEl ? parseFloat(scrapEl.value) : NaN;
                close({ quantity: q, scrap: Number.isNaN(s) ? null : s });
            });
            bd.addEventListener('click', function (e) { if (e.target === bd) close(null); });
        });
    }

    // Kuyruk satırından kalan miktarı hesapla — modal'da quick button + aşma onayı için.
    function remainingFor(opId) {
        var row = document.querySelector('.queue-row[data-id="' + opId + '"]');
        if (!row) return null;
        var planned  = parseFloat(row.getAttribute('data-planned-qty')) || 0;
        var produced = parseFloat(row.getAttribute('data-produced-qty')) || 0;
        if (planned <= 0) return null;
        var rem = planned - produced;
        return rem > 0 ? rem : null;
    }

    async function actPartial(opId) {
        var rem = remainingFor(opId);
        var v = await showQuantityModal({
            title: 'Kısmi Bitir',
            hint: rem != null
                ? 'Bu seferki üretim miktarını ve varsa fireyi girin. Kalan: ' + rem.toFixed(2)
                : 'Bu seferki üretim miktarını ve varsa fireyi girin.',
            qtyLabel: 'Üretilen Miktar', okLabel: 'Kısmi Bitir',
            showScrap: true,
            remainingQty: rem,
        });
        if (!v) return;
        if (v.quantity <= 0) { notify('Miktar 0\'dan büyük olmalı.', false); return; }
        try {
            var r = await fetch('/Production/ShopFloor/PartialComplete', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({
                    workOrderOperationId: opId, operatorPersonnelId: state.operator.id,
                    quantity: v.quantity, scrapQuantity: v.scrap
                })
            });
            var d = await r.json();
            if (!d.ok) { notify(d.error || 'Hata.', false); return; }
            notify('Kısmi bitiş kaydedildi.', true); loadQueue();
        } catch (e) { notify('Hata: ' + e.message, false); }
    }

    async function actComplete(opId) {
        var rem = remainingFor(opId);
        var v = await showQuantityModal({
            title: 'Operasyonu Bitir',
            hint: rem != null
                ? 'Final üretim miktarını girin. Kalan: ' + rem.toFixed(2) + ' (boş bırakılırsa mevcut üretilen miktar kullanılır).'
                : 'Final üretim miktarını girin (boş bırakılırsa mevcut üretilen miktar kullanılır).',
            qtyLabel: 'Final Miktar', okLabel: 'Bitir',
            showScrap: false, defaultQty: '',
            remainingQty: rem,
        });
        if (!v) return;
        try {
            var r = await fetch('/Production/ShopFloor/Complete', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({
                    workOrderOperationId: opId, operatorPersonnelId: state.operator.id,
                    finalQuantity: (v.quantity > 0 ? v.quantity : null)
                })
            });
            var d = await r.json();
            if (!d.ok) { notify(d.error || 'Hata.', false); return; }
            notify('Operasyon tamamlandı.', true); loadQueue();
        } catch (e) { notify('Hata: ' + e.message, false); }
    }

    /* ── Header navigation ── */
    document.getElementById('btnBack').addEventListener('click', function () {
        if (state.screen === 'queue') gotoScreen('machines');
        else if (state.screen === 'machines') gotoScreen('locations');
        else if (state.screen === 'locations') logout();
    });
    document.getElementById('btnExit').addEventListener('click', function () {
        logout();
    });

    /* ── Fullscreen toggle ──
       Tablet kiosk modu için tarayıcı kromunu gizler.
       Workspace iframe içinde Fullscreen API kısıtlı olduğu için, ilk
       tıklamada page top-window'a yönlendirilir (iframe shell'den çıkar),
       sonraki istek native fullscreen olur. F11 her zaman çalışır. */
    function isFullscreen() {
        return !!(document.fullscreenElement || document.webkitFullscreenElement);
    }
    function enterFullscreen() {
        var el = document.documentElement;
        var req = el.requestFullscreen || el.webkitRequestFullscreen || el.msRequestFullscreen;
        if (!req) return Promise.reject(new Error('Fullscreen API desteklenmiyor.'));
        var p = req.call(el);
        return (p && p.then) ? p : Promise.resolve();
    }
    function exitFullscreen() {
        var fn = document.exitFullscreen || document.webkitExitFullscreen || document.msExitFullscreen;
        if (!fn) return Promise.reject(new Error('Fullscreen API desteklenmiyor.'));
        var p = fn.call(document);
        return (p && p.then) ? p : Promise.resolve();
    }
    function syncFullscreenIcon() {
        var btn = document.getElementById('btnFullscreen');
        var enter = document.getElementById('fsIconEnter');
        var exitIcon = document.getElementById('fsIconExit');
        if (!btn || !enter || !exitIcon) return;
        var fs = isFullscreen();
        btn.classList.toggle('is-active', fs);
        enter.style.display = fs ? 'none' : '';
        exitIcon.style.display = fs ? '' : 'none';
        btn.title = fs ? 'Tam ekrandan çık (Esc)' : 'Tam ekran (F11)';
    }
    document.getElementById('btnFullscreen').addEventListener('click', function () {
        // Workspace iframe `allow="fullscreen"` ile yetkilendirildi (Shell.jsx),
        // doğrudan iframe içindeki document'i tam ekrana al — kullanıcı sol
        // menüden kopmaz, normal Esc / butonla çıkınca shell hâlâ orada.
        if (isFullscreen()) {
            exitFullscreen().catch(function (e) {
                if (window.CalibraHub && window.CalibraHub.toast) window.CalibraHub.toast(e.message, 'warn');
                else toast(e.message, false);
            });
        } else {
            enterFullscreen().catch(function (e) {
                var msg = (e && e.message) || 'Tam ekran başlatılamadı.';
                if (msg.toLowerCase().indexOf('permission') !== -1 || msg.toLowerCase().indexOf('denied') !== -1) {
                    msg = 'Tarayıcı tam ekrana izin vermedi. F11 tuşuna basabilirsiniz.';
                }
                toast(msg, false);
            });
        }
    });
    document.addEventListener('fullscreenchange', syncFullscreenIcon);
    document.addEventListener('webkitfullscreenchange', syncFullscreenIcon);
    syncFullscreenIcon();

    /* Boot */
    renderPinDisplay();
    state.nfcSupported = ('NDEFReader' in window);
    if (!state.nfcSupported) {
        document.getElementById('pinNfcBtn').style.display = 'none';
        var sub = document.querySelector('.pin-subtitle');
        if (sub) sub.textContent = 'PIN kodunuzu girin.';
    }
})();
</script>
</body>
</html>
