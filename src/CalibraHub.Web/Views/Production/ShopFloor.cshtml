    /* ── Queue + actions ── */
    // Backend (System.Text.Json default) enum'u STRING olarak gonderiyor: "Pending",
    // "InProgress", "Completed", "Skipped". Sayisal karsilik gerekirse Domain.Enums
    // WorkOrderOperationStatus ile birebir uyumlu. Eski Number() yaklasimi her stringi
    // 0'a cevirip TUM satirlari "Bekliyor" gosteriyordu — buton seciminde de bug.
    function toStatusInt(s) {
        if (typeof s === 'number') return s;
        var t = String(s || '').trim().toLowerCase();
        if (t === '0' || t === 'pending')    return 0;
        if (t === '1' || t === 'inprogress') return 1;
        if (t === '2' || t === 'completed')  return 2;
        if (t === '3' || t === 'skipped')    return 3;
        return 0;
    }
    function statusLabel(s) {
        var n = toStatusInt(s);
        if (n === 0) return { label: 'Bekliyor', cls: 'is-pending' };
        if (n === 1) return { label: 'Devam ediyor', cls: 'is-progress' };
        if (n === 2) return { label: 'Tamamlandı', cls: '' };
        if (n === 3) return { label: 'Atlandı', cls: '' };
        return { label: '?', cls: '' };
    }
    function fmtNum(v) { return Number(v || 0).toFixed(2); }
    function fmtDur(d, unit) { if (d == null) return '—'; return Number(d).toFixed(2) + (unit === 2 ? ' sa' : ' dk'); }

    // Faz 3 ShopFloor UX — küçük yardımcılar
    function vibrate(pattern) {
        try { if (navigator.vibrate) navigator.vibrate(pattern); } catch (_) { /* ignore */ }
    }
    var _audioCtx = null;
    function beep(freq, durationMs, vol) {
        // Web Audio API ile kısa bip — gürültülü atölyede toast'a ek işitsel geri bildirim.
        try {
            if (!_audioCtx) {
                var Ctx = window.AudioContext || window.webkitAudioContext;
                if (!Ctx) return;
                _audioCtx = new Ctx();
            }
            var osc = _audioCtx.createOscillator();
            var gain = _audioCtx.createGain();
            osc.type = 'sine';
            osc.frequency.value = freq || 800;
            gain.gain.value = vol == null ? 0.06 : vol;
            osc.connect(gain); gain.connect(_audioCtx.destination);
            osc.start();
            osc.stop(_audioCtx.currentTime + (durationMs || 120) / 1000);
        } catch (_) { /* ignore */ }
    }
    function notify(msg, ok) {
        toast(msg, ok);
        if (ok) { vibrate(40); beep(880, 100, 0.05); }
        else    { vibrate([60, 40, 60]); beep(220, 200, 0.07); }
    }

    // Planlanan süreyi (dk/sa) saniye'ye çevir — timer karşılaştırması için.
    function plannedSeconds(d, unit) {
        if (d == null) return null;
        var n = Number(d) || 0;
        return Number(unit) === 2 ? n * 3600 : n * 60;
    }
    function fmtElapsed(secs) {
        if (secs == null || secs < 0) return '—';
        var s = Math.floor(secs);
        var h = Math.floor(s / 3600); s -= h * 3600;
        var m = Math.floor(s / 60);   s -= m * 60;
        var pad = function (n) { return n < 10 ? '0' + n : String(n); };
        return (h > 0 ? h + ':' + pad(m) : m) + ':' + pad(s);
    }

    async function loadQueue() {
        var list = document.getElementById('queueList');
        list.innerHTML = '<div class="loader"></div>';
        try {
            var r = await fetch('/Production/ShopFloor/Queue?machineId=' + encodeURIComponent(state.machineId), { credentials: 'same-origin' });
            var arr = await r.json();
            if (!Array.isArray(arr) || arr.length === 0) {
                list.innerHTML = '<div class="empty"><div class="empty-icon">✓</div>Bu makinede bekleyen iş yok.</div>';
                return;
            }
            list.innerHTML = arr.map(function (op) {
                var s = statusLabel(op.status);
                var isInProgress = toStatusInt(op.status) === 1;

                // Mamul satırı (Faz 3 UX zenginlik)
                var woNum = op.workOrderNumber ? escapeHtml(op.workOrderNumber) : ('#' + op.workOrderId);
                var itemLine = (op.itemCode || op.itemName)
                    ? '<div class="item-line"><strong>' + escapeHtml(op.itemCode || '') + '</strong>'
                        + (op.itemName ? ' · ' + escapeHtml(op.itemName) : '') + '</div>'
                    : '';

                // İlerleme bar (üretilen / WO planlanan miktar)
                var planned  = Number(op.workOrderPlannedQuantity || 0);
                var produced = Number(op.producedQuantity || 0);
                var pct      = planned > 0 ? Math.min(100, (produced / planned) * 100) : 0;
                var isOverQty = planned > 0 && produced > planned;
                // 2026-05-22: Upstream cap — onceki op'larin net uretimi. produced bu degeri asamaz.
                // Sequence=ilk op (UpstreamCap=PlannedQty) → cap label gosterme. Sonraki op'larda goster.
                var upstreamCap = Number(op.upstreamCap || 0);
                var upstreamRemaining = Math.max(0, upstreamCap - produced);
                var isFirstOp = (op.sequence || 0) <= 10 && upstreamCap === planned;
                var upstreamLabel = (!isFirstOp && upstreamCap < planned)
                    ? '<span title="Önceki operasyon(lar) net üretimi">Upstream: ' + fmtNum(upstreamCap) + '</span>'
                    : '';
                var progressBlock = planned > 0
                    ? '<div class="progress-block">'
                        + '<div class="progress-bar' + (isOverQty ? ' is-over' : '') + '"><span style="width:' + pct.toFixed(1) + '%;"></span></div>'
                        + '<div class="progress-info">'
                        +   '<span>Üretilen ' + fmtNum(produced) + ' / Planlanan ' + fmtNum(planned) + '</span>'
                        +   '<span>%' + pct.toFixed(1) + (isOverQty ? ' • aşım' : '') + '</span>'
                        +   upstreamLabel
                        + '</div>'
                      + '</div>'
                    : '';

                // Notlar badge'i (rota/op notu)
                var notesBadge = op.notes
                    ? '<div class="notes-badge">' + escapeHtml(op.notes) + '</div>'
                    : '';

                // Canlı timer placeholder — startedAt ISO ve plannedSec data-attribute'larında
                var timerHtml = '';
                if (isInProgress && op.startedAt) {
                    var ps = plannedSeconds(op.plannedDuration, op.durationUnit);
                    timerHtml = '<span class="timer-pill" data-timer-start="' + escapeHtml(op.startedAt)
                        + '" data-planned-sec="' + (ps == null ? '' : ps) + '">⏱ —</span>';
                }

                // Faz 1 MVP (2026-05-20): Aktif aktivite pill placeholder (asenkron dolar).
                // Sadece InProgress satirlarda gosterilir — bekleyen satirlarda anlamsiz.
                var activityPlaceholder = isInProgress
                    ? '<div class="activity-pill" data-activity-pill="' + op.id + '">⋯</div>'
                    : '';

                // 2026-05-22: Upstream=0 ise Başlat disabled — önceki op henüz üretim yapmadı.
                var canStart = !isInProgress && upstreamCap > 0;
                var startBlocked = !isInProgress && upstreamCap <= 0;
                var startTitle = startBlocked
                    ? 'Önceki operasyon henüz üretim yapmadı — bu işi başlatamazsınız.'
                    : 'İşi başlat';
                var startBtn = isInProgress ? '' :
                    canStart
                      ? '<button class="shop-touch-btn start" data-act="start" title="' + escapeHtml(startTitle) + '">▶ Başlat</button>'
                      : '<button class="shop-touch-btn start" data-act="start" disabled style="opacity:.5; cursor:not-allowed;" title="' + escapeHtml(startTitle) + '">▶ Başlat</button>';

                return '<div class="queue-row' + (isInProgress ? ' is-progress' : '') + '" data-id="' + op.id + '" data-planned-qty="' + planned + '" data-produced-qty="' + produced + '" data-upstream-cap="' + upstreamCap + '">'
                    + '<div class="info">'
                    +   '<div class="status-pill ' + s.cls + '">' + s.label + '</div>' + timerHtml + activityPlaceholder
                    +   '<div class="order">İŞ EMRİ ' + woNum + ' · Sıra ' + (op.sequence || 0) + ' — ' + escapeHtml(op.operationName || op.operationCode || ('Op#' + op.operationId)) + '</div>'
                    +   itemLine
                    +   notesBadge
                    +   progressBlock
                    +   '<div class="meta">'
                    +     '<span><strong>Süre:</strong> ' + fmtDur(op.plannedDuration, op.durationUnit) + '</span>'
                    +     '<span><strong>Fire:</strong> ' + fmtNum(op.scrapQuantity) + '</span>'
                    +     (op.startedByPersonnelName ? '<span><strong>Başlatan:</strong> ' + escapeHtml(op.startedByPersonnelName) + '</span>' : '')
                    +   '</div>'
                    + '</div>'
                    + '<div class="actions">'
                    +   startBtn
                    +   (isInProgress ? '<button class="shop-touch-btn activity" data-act="activity">⇄ Durum Değiştir</button>' : '')
                    +   (isInProgress ? '<button class="shop-touch-btn partial" data-act="partial">+ Kısmi Bitir</button>' : '')
                    +   (isInProgress ? '<button class="shop-touch-btn complete" data-act="complete">✓ Bitir</button>' : '')
                    +   '<button class="shop-touch-btn is-secondary history" data-act="history">📋 Geçmiş</button>'
                    + '</div>'
                    + '</div>';
            }).join('');
            list.querySelectorAll('.queue-row').forEach(function (row) {
                var opId = Number(row.dataset.id);
                row.querySelector('[data-act="start"]')?.addEventListener('click', function () { actStart(opId); });
                row.querySelector('[data-act="partial"]')?.addEventListener('click', function () { actPartial(opId); });
                row.querySelector('[data-act="complete"]')?.addEventListener('click', function () { actComplete(opId); });
                row.querySelector('[data-act="activity"]')?.addEventListener('click', function () { actChangeActivity(opId); });
                row.querySelector('[data-act="history"]')?.addEventListener('click', function () { actShowHistory(opId); });
            });
            // İlk timer tickini hemen at — sonra setInterval canlı tutar
            tickTimers();
            // InProgress satirlardaki aktif aktivite pill'lerini asenkron doldur
            list.querySelectorAll('[data-activity-pill]').forEach(function (el) {
                refreshActivityPill(Number(el.getAttribute('data-activity-pill')));
            });
        } catch (e) {
            list.innerHTML = '<div class="empty">Yüklenemedi: ' + escapeHtml(e.message) + '</div>';
        }
    }

    function startQueueRefresh() {
        stopQueueRefresh();
        state.refreshTimer = setInterval(function () { if (state.screen === 'queue') loadQueue(); }, REFRESH_MS);
    }
    function stopQueueRefresh() { if (state.refreshTimer) { clearInterval(state.refreshTimer); state.refreshTimer = null; } }

    // ── Canlı timer — 1 sn'lik interval, "Devam ediyor" satırlarındaki ⏱ pill'ini günceller.
    // Başlama anından beri geçen süreyi hh:mm:ss / mm:ss biçiminde basar; planlanan
    // süre aşıldıysa rose renge geçer + pulse animasyonu (CSS'te tanımlı).
    function tickTimers() {
        var now = Date.now();
        document.querySelectorAll('.timer-pill[data-timer-start]').forEach(function (el) {
            var startedIso = el.getAttribute('data-timer-start');
            if (!startedIso) return;
            var startedMs = Date.parse(startedIso);
            if (isNaN(startedMs)) return;
            var elapsedSec = (now - startedMs) / 1000;
            el.textContent = '⏱ ' + fmtElapsed(elapsedSec);
            var plannedSec = parseFloat(el.getAttribute('data-planned-sec'));
            if (!isNaN(plannedSec) && plannedSec > 0 && elapsedSec > plannedSec) {
                el.classList.add('is-over');
            } else {
                el.classList.remove('is-over');
            }
        });
    }
    setInterval(tickTimers, 1000);

    async function actStart(opId) {
        try {
            var r = await fetch('/Production/ShopFloor/Start', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({ workOrderOperationId: opId, operatorPersonnelId: state.operator.id })
            });
            var d = await r.json();
            if (!d.ok) { notify(d.error || 'Başlatılamadı.', false); return; }
            // 2026-05-20 Faz 1 MVP: Operasyon ilk başladığında varsayılan olarak "Hazırlık"
            // aktivitesi açılır. Operatör hazırlık bitince "Durum Değiştir" → Üretim'e geçer.
            // Sebep: sahaya en yakın gerçek davranış — başlat = önce hazırlık. Hata olursa
            // sessizce yutuyoruz (WO başlatma zaten başarıyla yapıldı).
            try {
                await fetch('/Production/ShopFloor/StartActivity', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                    body: JSON.stringify({
                        workOrderOperationId: opId,
                        operatorPersonnelId:  state.operator.id,
                        activityType:         0,    // Setup
                        activityReasonId:     null,
                        notes:                null
                    })
                });
            } catch (_) { /* default activity hata atarsa yutuyoruz */ }
            notify('Başlatıldı (Hazırlık).', true); loadQueue();
        } catch (e) { notify('Hata: ' + e.message, false); }
    }

    function showQuantityModal(opts) {
        return new Promise(function (resolve) {
            var bd = document.createElement('div');
            bd.className = 'modal-backdrop';

            // Quick butonlar — "Tüm" (kalanı tek tıkla doldur), ½, ¼ kısayolları.
            // remainingQty (planlanan - üretilen) verildiyse oluşturulur.
            var remaining = opts.remainingQty;
            var hasRemaining = (remaining != null && Number(remaining) > 0);
            var quickHtml = '';
            if (hasRemaining) {
                var half    = (Number(remaining) / 2).toFixed(2);
                var quarter = (Number(remaining) / 4).toFixed(2);
                quickHtml = '<div class="modal-quick-btns">'
                    + '<button type="button" data-quick="' + quarter + '">¼ · ' + quarter + '</button>'
                    + '<button type="button" data-quick="' + half + '">½ · ' + half + '</button>'
                    + '<button type="button" class="quick-all" data-quick="' + Number(remaining).toFixed(2) + '">Tüm · ' + Number(remaining).toFixed(2) + '</button>'
                    + '</div>';
            }

            bd.innerHTML = '<div class="modal-card">'
                + '<h2>' + escapeHtml(opts.title) + '</h2>'
                + '<div class="modal-hint">' + escapeHtml(opts.hint || '') + '</div>'
                + '<div class="modal-row"><label>' + escapeHtml(opts.qtyLabel || 'Miktar') + '</label><input type="number" inputmode="decimal" id="modalQty" step="0.01" min="0" value="' + (opts.defaultQty != null ? opts.defaultQty : '') + '" />'
                +   quickHtml
                + '</div>'
                + (opts.showScrap ? '<div class="modal-row"><label>Fire (opsiyonel)</label><input type="number" inputmode="decimal" id="modalScrap" step="0.01" min="0" value="" /></div>' : '')
                + '<div class="modal-actions">'
                +   '<button class="shop-touch-btn is-secondary" id="modalCancel">Vazgeç</button>'
                +   '<button class="shop-touch-btn is-action" id="modalOk">' + escapeHtml(opts.okLabel || 'Tamam') + '</button>'
                + '</div></div>';
            document.body.appendChild(bd);
            var qtyEl = bd.querySelector('#modalQty');
            var scrapEl = bd.querySelector('#modalScrap');
            setTimeout(function () { qtyEl.focus(); qtyEl.select(); }, 50);
            function close(val) { document.body.removeChild(bd); resolve(val); }
            bd.querySelector('#modalCancel').addEventListener('click', function () { close(null); });
            bd.querySelectorAll('[data-quick]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    qtyEl.value = btn.getAttribute('data-quick');
                    qtyEl.focus(); qtyEl.select();
                });
            });
            bd.querySelector('#modalOk').addEventListener('click', async function () {
                var q = parseFloat(qtyEl.value);
                if (Number.isNaN(q)) { qtyEl.focus(); return; }
                // Aşma onayı — hasRemaining ise ve girilen miktar kalan miktardan büyükse uyar (rapor §6.6 — CalibraAlert.confirm).
                if (hasRemaining && q > Number(remaining) + 0.0001) {
                    var msg = 'Girilen miktar (' + q.toFixed(2)
                        + ') planlanan kalan miktarı (' + Number(remaining).toFixed(2) + ') aşıyor.';
                    var ok = window.CalibraAlert && window.CalibraAlert.confirm
                        ? await window.CalibraAlert.confirm({ title: 'Miktar aşımı', message: msg, okLabel: 'Devam Et' })
                        : confirm(msg + '\n\nDevam edilsin mi?');
                    if (!ok) { qtyEl.focus(); qtyEl.select(); return; }
                }
                var s = scrapEl ? parseFloat(scrapEl.value) : NaN;
                close({ quantity: q, scrap: Number.isNaN(s) ? null : s });
            });
            bd.addEventListener('click', function (e) { if (e.target === bd) close(null); });
        });
    }

    // Kuyruk satırından kalan miktarı hesapla — modal'da quick button + aşma onayı için.
    function remainingFor(opId) {
        var row = document.querySelector('.queue-row[data-id="' + opId + '"]');
        if (!row) return null;
        var planned  = parseFloat(row.getAttribute('data-planned-qty')) || 0;
        var produced = parseFloat(row.getAttribute('data-produced-qty')) || 0;
        if (planned <= 0) return null;
        var rem = planned - produced;
        return rem > 0 ? rem : null;
    }

    async function actPartial(opId) {
        var rem = remainingFor(opId);
        var v = await showQuantityModal({
            title: 'Kısmi Bitir',
            hint: rem != null
                ? 'Bu seferki üretim miktarını ve varsa fireyi girin. Kalan: ' + rem.toFixed(2)
                : 'Bu seferki üretim miktarını ve varsa fireyi girin.',
            qtyLabel: 'Üretilen Miktar', okLabel: 'Kısmi Bitir',
            showScrap: true,
            remainingQty: rem,
        });
        if (!v) return;
        if (v.quantity <= 0) { notify('Miktar 0\'dan büyük olmalı.', false); return; }
        try {
            var r = await fetch('/Production/ShopFloor/PartialComplete', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({
                    workOrderOperationId: opId, operatorPersonnelId: state.operator.id,
                    quantity: v.quantity, scrapQuantity: v.scrap
                })
            });
            var d = await r.json();
            if (!d.ok) { notify(d.error || 'Hata.', false); return; }
            notify('Kısmi bitiş kaydedildi.', true); loadQueue();
        } catch (e) { notify('Hata: ' + e.message, false); }
    }

    async function actComplete(opId) {
        var rem = remainingFor(opId);
        var v = await showQuantityModal({
            title: 'Operasyonu Bitir',
            hint: rem != null
                ? 'Final üretim miktarını girin. Kalan: ' + rem.toFixed(2) + ' (boş bırakılırsa mevcut üretilen miktar kullanılır).'
                : 'Final üretim miktarını girin (boş bırakılırsa mevcut üretilen miktar kullanılır).',
            qtyLabel: 'Final Miktar', okLabel: 'Bitir',
            showScrap: false, defaultQty: '',
            remainingQty: rem,
        });
        if (!v) return;
        try {
            var r = await fetch('/Production/ShopFloor/Complete', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({
                    workOrderOperationId: opId, operatorPersonnelId: state.operator.id,
                    finalQuantity: (v.quantity > 0 ? v.quantity : null)
                })
            });
            var d = await r.json();
            if (!d.ok) { notify(d.error || 'Hata.', false); return; }
            notify('Operasyon tamamlandı.', true); loadQueue();
        } catch (e) { notify('Hata: ' + e.message, false); }
    }

    /* ── 2026-05-20 Faz 1 MVP: Saha aktivite log ─────────────────────────
       - actChangeActivity: aktivite tipi sec ve baslat (eski aktif otomatik kapanir)
       - actShowHistory: operasyon hareket gecmisi modali
       - refreshActivityPill: aktif aktivite pill'ini asenkron doldurur */

    // Aktivite tip cache (ilk cagrida fetch — Description metadata'sindan beslenir)
    var _activityTypesCache = null;
    async function loadActivityTypes() {
        if (_activityTypesCache) return _activityTypesCache;
        try {
            var r = await fetch('/Production/ShopFloor/ActivityTypes', { credentials: 'same-origin' });
            _activityTypesCache = await r.json();
        } catch (e) { _activityTypesCache = []; }
        return _activityTypesCache;
    }

    // Aktivite tipinden CSS class + emoji turetme (UI gorseli icin)
    function activityVisual(typeId) {
        // Enum byte → { cls, emoji }
        switch (Number(typeId)) {
            case 0: return { cls: 'is-setup',      emoji: '🔧' };
            case 1: return { cls: 'is-production', emoji: '▶' };
            case 2: return { cls: 'is-wait',       emoji: '⏸' };
            case 3: return { cls: 'is-breakdown',  emoji: '🛠' };
            case 4: return { cls: 'is-quality',    emoji: '📊' };
            case 5: return { cls: 'is-break',      emoji: '🍴' };
            case 6: return { cls: 'is-shift',      emoji: '🔄' };
            case 7: return { cls: 'is-planned',    emoji: '🗓' };
            case 99:return { cls: 'is-other',      emoji: '📝' };
            default:return { cls: 'is-other',      emoji: '•' };
        }
    }

    async function refreshActivityPill(opId) {
        var pillEl = document.querySelector('[data-activity-pill="' + opId + '"]');
        if (!pillEl) return;
        try {
            var r = await fetch('/Production/ShopFloor/ActiveActivity?workOrderOperationId=' + opId,
                                { credentials: 'same-origin' });
            var data = await r.json();
            if (!data || !data.activityType) {
                pillEl.textContent = '— Aktivite yok';
                pillEl.className = 'activity-pill is-other';
                pillEl.removeAttribute('data-activity-type');
                return;
            }
            var v = activityVisual(data.activityType);
            pillEl.className = 'activity-pill ' + v.cls;
            pillEl.textContent = v.emoji + ' ' + (data.activityTypeLabel || '?');
            pillEl.setAttribute('data-activity-type', String(data.activityType));
        } catch (e) {
            pillEl.textContent = '!';
        }
    }

    async function actChangeActivity(opId) {
        var types = await loadActivityTypes();
        if (!types || !types.length) {
            notify('Aktivite tipleri yüklenemedi.', false); return;
        }
        // Mevcut aktiviteyi cek — UI'da "su an" isaretle
        var current = null;
        try {
            var rc = await fetch('/Production/ShopFloor/ActiveActivity?workOrderOperationId=' + opId,
                                 { credentials: 'same-origin' });
            current = await rc.json();
        } catch (_) { /* ignore */ }
        var currentType = current ? Number(current.activityType) : null;

        var picked = await showActivityPickerModal(types, currentType);
        if (!picked) return;

        // 2026-05-21 Faz 2: Secilen tip icin admin tanimli sebep listesi cek.
        // Sebep varsa kullaniciya sebep secimi sun (opsiyonel). 'Diger' tipinde
        // ayrica Notes zorunlu (sebep secilse bile aciklama isteyelim).
        var reasons = await loadReasonsForType(picked.id);
        var reasonId = null;
        if (reasons && reasons.length > 0) {
            var pickedReason = await showReasonPickerModal(picked.label, reasons);
            if (pickedReason === '__CANCEL__') return; // kullanici vazgecti
            reasonId = pickedReason; // null veya id
        }

        var notes = null;
        if (Number(picked.id) === 99) {
            notes = window.prompt('Diğer aktivite için açıklama girin (zorunlu):');
            if (notes == null || !notes.trim()) { notify('Açıklama boş geçilemez.', false); return; }
            notes = notes.trim();
        }
        try {
            var r = await fetch('/Production/ShopFloor/StartActivity', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({
                    workOrderOperationId: opId,
                    operatorPersonnelId:  state.operator.id,
                    activityType:         Number(picked.id),
                    activityReasonId:     reasonId,
                    notes:                notes
                })
            });
            var d = await r.json();
            if (!d.ok) { notify(d.error || 'Aktivite başlatılamadı.', false); return; }
            notify('Aktivite başlatıldı: ' + picked.label, true);
            refreshActivityPill(opId);
        } catch (e) { notify('Hata: ' + e.message, false); }
    }

    // 2026-05-21 Faz 2: Aktivite tipi -> sebep listesi cache (per type id)
    var _reasonsCache = {};
    async function loadReasonsForType(typeId) {
        var k = String(typeId);
        if (_reasonsCache[k] != null) return _reasonsCache[k];
        try {
            var r = await fetch('/Production/ActivityReasonsList?activityType=' + typeId + '&includeInactive=false',
                                 { credentials: 'same-origin' });
            var arr = await r.json();
            _reasonsCache[k] = Array.isArray(arr) ? arr : [];
        } catch (e) { _reasonsCache[k] = []; }
        return _reasonsCache[k];
    }

    // Sebep secim modal'i — basit liste, "Sebep belirtme" opsiyonu da var (null doner)
    function showReasonPickerModal(activityLabel, reasons) {
        return new Promise(function (resolve) {
            var bd = document.createElement('div');
            bd.className = 'modal-backdrop';
            var rowsHtml = reasons.map(function (r) {
                var color = r.colorHex || '#94a3b8';
                return '<button type="button" data-reason-id="' + r.id + '" style="display:flex;align-items:center;gap:10px;padding:14px 12px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:8px;cursor:pointer;text-align:left;color:inherit;width:100%;min-height:54px;">'
                    + '<span style="width:10px;height:10px;border-radius:50%;background:' + color + ';flex:0 0 auto;"></span>'
                    + '<span style="flex:1;"><strong>' + escapeHtml(r.name) + '</strong>'
                    +   (r.description ? '<br><small style="opacity:.7;">' + escapeHtml(r.description) + '</small>' : '')
                    + '</span>'
                    + '<span style="font-size:11px;opacity:.5;font-family:ui-monospace, Menlo, Consolas, monospace;">' + escapeHtml(r.code) + '</span>'
                  + '</button>';
            }).join('');
            bd.innerHTML = '<div class="modal-card" style="width:min(540px,100%);">'
                + '<h2>Sebep Seç</h2>'
                + '<div class="modal-hint">' + escapeHtml(activityLabel) + ' — alt sebebi seçin (opsiyonel).</div>'
                + '<div style="display:flex;flex-direction:column;gap:8px;max-height:50vh;overflow:auto;">' + rowsHtml + '</div>'
                + '<div class="modal-actions">'
                +   '<button class="shop-touch-btn is-secondary" id="reasonCancel">Vazgeç</button>'
                +   '<button class="shop-touch-btn is-secondary" id="reasonNone">Sebep Belirtme</button>'
                + '</div></div>';
            document.body.appendChild(bd);
            function close(val) { document.body.removeChild(bd); resolve(val); }
            bd.querySelector('#reasonCancel').addEventListener('click', function () { close('__CANCEL__'); });
            bd.querySelector('#reasonNone').addEventListener('click', function () { close(null); });
            bd.addEventListener('click', function (e) { if (e.target === bd) close('__CANCEL__'); });
            bd.querySelectorAll('button[data-reason-id]').forEach(function (b) {
                b.addEventListener('click', function () {
                    close(parseInt(b.getAttribute('data-reason-id'), 10));
                });
            });
        });
    }

    function showActivityPickerModal(types, currentTypeId) {
        return new Promise(function (resolve) {
            var bd = document.createElement('div');
            bd.className = 'modal-backdrop';
            var btnsHtml = types.map(function (t) {
                var v = activityVisual(t.id);
                var isCur = (currentTypeId != null && Number(currentTypeId) === Number(t.id));
                return '<button type="button" class="' + (isCur ? 'is-current' : '') + '" data-type-id="' + t.id + '" data-type-label="' + escapeHtml(t.label) + '">'
                     +    '<span>' + v.emoji + ' ' + escapeHtml(t.label) + '</span>'
                     +    (isCur ? '<small>şu an aktif</small>' : '<small>başlatmak için tıkla</small>')
                     +  '</button>';
            }).join('');
            bd.innerHTML = '<div class="modal-card">'
                + '<h2>Aktivite Değiştir</h2>'
                + '<div class="modal-hint">Hangi işi yapmaya başladığını seç — eski aktivite (varsa) otomatik kapanır.</div>'
                + '<div class="activity-grid">' + btnsHtml + '</div>'
                + '<div class="modal-actions">'
                +   '<button class="shop-touch-btn is-secondary" id="actPickCancel">Vazgeç</button>'
                + '</div></div>';
            document.body.appendChild(bd);
            function close(val) { document.body.removeChild(bd); resolve(val); }
            bd.querySelector('#actPickCancel').addEventListener('click', function () { close(null); });
            bd.addEventListener('click', function (e) { if (e.target === bd) close(null); });
            bd.querySelectorAll('button[data-type-id]').forEach(function (b) {
                b.addEventListener('click', function () {
                    close({ id: b.getAttribute('data-type-id'), label: b.getAttribute('data-type-label') });
                });
            });
        });
    }

    async function actShowHistory(opId) {
        try {
            var r = await fetch('/Production/ShopFloor/ActivityHistory?workOrderOperationId=' + opId,
                                { credentials: 'same-origin' });
            var list = await r.json();
            showHistoryModal(opId, Array.isArray(list) ? list : []);
        } catch (e) { notify('Geçmiş yüklenemedi: ' + e.message, false); }
    }

    function fmtDateTime(iso) {
        if (!iso) return '—';
        try {
            var d = new Date(iso);
            return d.toLocaleString('tr-TR', { day: '2-digit', month: '2-digit', year: 'numeric',
                                                hour: '2-digit', minute: '2-digit', second: '2-digit' });
        } catch (e) { return iso; }
    }
    function fmtDurationSec(sec) {
        if (sec == null) return '— (devam)';
        var h = Math.floor(sec / 3600);
        var m = Math.floor((sec % 3600) / 60);
        var s = sec % 60;
        return (h > 0 ? h + 's ' : '') + (m + 'd ') + (s + 'sn');
    }

    function showHistoryModal(opId, items) {
        var bd = document.createElement('div');
        bd.className = 'modal-backdrop';
        var rowsHtml;
        if (!items.length) {
            rowsHtml = '<div class="history-empty">Bu operasyonda henüz hareket kaydı yok.</div>';
        } else {
            rowsHtml = '<table class="history-table">'
                + '<thead><tr><th>Tip</th><th>Başlangıç</th><th>Bitiş</th><th class="num">Süre</th>'
                +          '<th class="num">Miktar</th><th>Operatör</th><th>Not</th></tr></thead>'
                + '<tbody>' + items.map(function (a) {
                    var v = activityVisual(a.activityType);
                    var isActive = !a.endedAt;
                    return '<tr class="' + (isActive ? 'is-active' : '') + '">'
                        + '<td>' + v.emoji + ' ' + escapeHtml(a.activityTypeLabel || '') + '</td>'
                        + '<td>' + escapeHtml(fmtDateTime(a.startedAt)) + '</td>'
                        + '<td>' + escapeHtml(fmtDateTime(a.endedAt)) + '</td>'
                        + '<td class="num">' + escapeHtml(fmtDurationSec(a.durationSeconds)) + '</td>'
                        + '<td class="num">' + (a.quantity != null ? Number(a.quantity).toFixed(2) : '—') + '</td>'
                        + '<td>' + escapeHtml(a.personnelName || '#' + a.personnelId) + '</td>'
                        + '<td>' + escapeHtml(a.notes || '') + '</td>'
                        + '</tr>';
                }).join('') + '</tbody></table>';
        }
        bd.innerHTML = '<div class="modal-card" style="width:min(880px,100%);">'
            + '<h2>Hareket Geçmişi · İş Emri Op #' + opId + '</h2>'
            + '<div class="modal-hint">En yeni hareket üstte. Yeşil satır şu an aktif (henüz bitmemiş).</div>'
            + rowsHtml
            + '<div class="modal-actions"><button class="shop-touch-btn is-secondary" id="histClose">Kapat</button></div>'
            + '</div>';
        document.body.appendChild(bd);
        function close() { document.body.removeChild(bd); }
        bd.querySelector('#histClose').addEventListener('click', close);
        bd.addEventListener('click', function (e) { if (e.target === bd) close(); });
    }

    /* ── Header navigation ── */
    document.getElementById('btnBack').addEventListener('click', function () {
        if (state.screen === 'queue') gotoScreen('machines');
        else if (state.screen === 'machines') gotoScreen('locations');
        else if (state.screen === 'locations') logout();
    });
    document.getElementById('btnExit').addEventListener('click', function () {
        logout();
    });

    /* ── Fullscreen toggle ──
       Tablet kiosk modu için tarayıcı kromunu gizler.
       Workspace iframe içinde Fullscreen API kısıtlı olduğu için, ilk
       tıklamada page top-window'a yönlendirilir (iframe shell'den çıkar),
       sonraki istek native fullscreen olur. F11 her zaman çalışır. */
    function isFullscreen() {
        return !!(document.fullscreenElement || document.webkitFullscreenElement);
    }
    function enterFullscreen() {
        var el = document.documentElement;
        var req = el.requestFullscreen || el.webkitRequestFullscreen || el.msRequestFullscreen;
        if (!req) return Promise.reject(new Error('Fullscreen API desteklenmiyor.'));
        var p = req.call(el);
        return (p && p.then) ? p : Promise.resolve();
    }
    function exitFullscreen() {
        var fn = document.exitFullscreen || document.webkitExitFullscreen || document.msExitFullscreen;
        if (!fn) return Promise.reject(new Error('Fullscreen API desteklenmiyor.'));
        var p = fn.call(document);
        return (p && p.then) ? p : Promise.resolve();
    }
    function syncFullscreenIcon() {
        var btn = document.getElementById('btnFullscreen');
        var enter = document.getElementById('fsIconEnter');
        var exitIcon = document.getElementById('fsIconExit');
        if (!btn || !enter || !exitIcon) return;
        var fs = isFullscreen();
        btn.classList.toggle('is-active', fs);
        enter.style.display = fs ? 'none' : '';
        exitIcon.style.display = fs ? '' : 'none';
        btn.title = fs ? 'Tam ekrandan çık (Esc)' : 'Tam ekran (F11)';
    }
    document.getElementById('btnFullscreen').addEventListener('click', function () {
        // Workspace iframe `allow="fullscreen"` ile yetkilendirildi (Shell.jsx),
        // doğrudan iframe içindeki document'i tam ekrana al — kullanıcı sol
        // menüden kopmaz, normal Esc / butonla çıkınca shell hâlâ orada.
        if (isFullscreen()) {
            exitFullscreen().catch(function (e) {
                if (window.CalibraHub && window.CalibraHub.toast) window.CalibraHub.toast(e.message, 'warn');
                else toast(e.message, false);
            });
        } else {
            enterFullscreen().catch(function (e) {
                var msg = (e && e.message) || 'Tam ekran başlatılamadı.';
                if (msg.toLowerCase().indexOf('permission') !== -1 || msg.toLowerCase().indexOf('denied') !== -1) {
                    msg = 'Tarayıcı tam ekrana izin vermedi. F11 tuşuna basabilirsiniz.';
                }
                toast(msg, false);
            });
        }
    });
    document.addEventListener('fullscreenchange', syncFullscreenIcon);
    document.addEventListener('webkitfullscreenchange', syncFullscreenIcon);
    syncFullscreenIcon();

    /* Boot */
    renderPinDisplay();
    state.nfcSupported = ('NDEFReader' in window);
    if (!state.nfcSupported) {
        document.getElementById('pinNfcBtn').style.display = 'none';
        var sub = document.querySelector('.pin-subtitle');
        if (sub) sub.textContent = 'PIN kodunuzu girin.';
    }

    // 2026-05-22: Hard refresh sonrasi (Ctrl+F5) persisted session'i restore et —
    // operator + son ekran (lokasyon/makine/queue) geri yuklenir. Aksi halde PIN ekrani.
    restoreSession();
})();
</script>
</body>
</html>
