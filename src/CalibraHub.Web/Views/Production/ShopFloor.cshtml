            }
            grid.innerHTML = list.map(function (m) {
                var stats = '';
                if (m.inProgressCount > 0) stats += '<span class="stat-pill is-busy">▶ ' + m.inProgressCount + ' devam</span>';
                if (m.pendingCount > 0)    stats += '<span class="stat-pill is-pending">⏳ ' + m.pendingCount + ' bekleyen</span>';
                if (!stats) stats = '<span class="stat-pill">Boş</span>';
                return '<button class="shop-card" data-mch-id="' + m.id + '" data-mch-name="' + escapeHtml(m.name) + '">'
                    + '<div class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div>'
                    + '<div class="title">' + escapeHtml(m.name) + '</div>'
                    + '<div class="subtitle">' + escapeHtml(m.code || '') + (m.machineType ? ' · ' + escapeHtml(m.machineType) : '') + '</div>'
                    + '<div class="stats">' + stats + '</div>'
                    + '</button>';
            }).join('');
            grid.querySelectorAll('[data-mch-id]').forEach(function (btn) {
                btn.addEventListener('click', function () {
