@model CalibraHub.Application.Contracts.RoutingDto
@using CalibraHub.Application.Contracts
@{
    var isNew = Model is null;
    ViewData["Title"] = isNew ? "Yeni Rota" : $"Rota: {Model!.Code}";
    ViewData["FormCode"] = "ROUTING_EDIT";
    ViewData["BodyClass"] = "page-routing-edit workspace-frame-body";

    var operations = ViewBag.Operations as IReadOnlyCollection<RoutingOperationDto>
                  ?? Array.Empty<RoutingOperationDto>();
}

<partial name="_ProductionDefsTabs" model='"routings"' />

@* PJAX wrapper — style + shell + scripts hepsi içinde, PJAX swap'ta yeniden uygulanır *@
<div id="pdt-tab-content" data-pdt-key="routings" data-pdt-body-class="page-routing-edit">

<style>
.re-page {
    --re-bg:           #f8fafc;
    --re-surface:      #ffffff;
    --re-surface2:     #f1f5f9;
    --re-border:       #e2e8f0;
    --re-border-light: #f1f5f9;
    --re-text:         #0f172a;
    --re-text-muted:   #64748b;
    --re-input-bg:     #ffffff;
    --re-accent:       var(--theme-accent, #2563eb);
    --re-toast-ok-bg:  #d1fae5;
    --re-toast-ok-tx:  #065f46;
    --re-toast-er-bg:  #fee2e2;
    --re-toast-er-tx:  #991b1b;
}
body.app-theme-dark .re-page {
    --re-bg:           #080c17;
    --re-surface:      #0d1323;
    --re-surface2:     #111827;
    --re-border:       rgba(255,255,255,.09);
    --re-border-light: rgba(255,255,255,.04);
    --re-text:         #e2e8f0;
    --re-text-muted:   #94a3b8;
    --re-input-bg:     rgba(255,255,255,.06);
    --re-accent:       var(--theme-accent, #6366f1);
    --re-toast-ok-bg:  rgba(34,197,94,.18);
    --re-toast-ok-tx:  #4ade80;
    --re-toast-er-bg:  rgba(239,68,68,.18);
    --re-toast-er-tx:  #f87171;
}

.re-page {
    padding: 16px 24px; height: 100%;
    display: flex; flex-direction: column; min-height: 0; gap: 12px;
    overflow: auto;
    background: var(--re-bg); color: var(--re-text);
}
.re-toolbar {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--re-border);
}
.re-toolbar h1 { font-size: 18px; margin: 0; color: var(--re-text); }
.re-toolbar .spacer { flex: 1; }
.re-back { color: var(--re-text-muted); text-decoration: none; font-size: 13px; }
.re-back:hover { color: var(--re-text); }
.re-btn {
    padding: 7px 14px; border-radius: 7px;
    border: 1px solid var(--re-border);
    background: var(--re-surface); color: var(--re-text);
    cursor: pointer; font-size: 13px; font-weight: 500;
    transition: background .12s, border-color .12s;
    text-decoration: none; display: inline-block;
}
.re-btn:hover:not(:disabled) { background: var(--re-surface2); border-color: var(--re-accent); }
.re-btn:disabled { opacity: .4; cursor: not-allowed; }
.re-btn--primary { background: linear-gradient(135deg, #6366f1, #4f46e5); color: #fff; border-color: #4f46e5; }
.re-btn--primary:hover:not(:disabled) { filter: brightness(1.07); border-color: #4f46e5; }
.re-btn--danger  { background: #fef2f2; color: #991b1b; border-color: #fecaca; }
body.app-theme-dark .re-btn--danger { background: rgba(239,68,68,.12); color: #fca5a5; border-color: rgba(239,68,68,.32); }

/* Sol-tab + sağ-pane */
.re-tabbed {
    display: flex; min-height: 380px; gap: 0;
    background: var(--re-surface);
    border: 1px solid var(--re-border); border-radius: 10px;
    overflow: hidden; flex: 1 1 auto;
}
.re-nav {
    width: 220px; flex-shrink: 0;
    background: var(--re-surface2);
    border-right: 1px solid var(--re-border);
    padding: 10px 0; display: flex; flex-direction: column;
}
.re-nav-grouptitle {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px;
    color: var(--re-text-muted); padding: 10px 14px 4px; margin: 0;
}
.re-nav-btn {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 9px 14px;
    border: none; background: transparent;
    text-align: left; cursor: pointer;
    color: var(--re-text); font-size: 13px; font-weight: 500;
    border-left: 3px solid transparent;
    transition: background .12s, color .12s;
}
.re-nav-btn:hover { background: rgba(99,102,241,.08); }
.re-nav-btn.is-active {
    border-left-color: var(--re-accent);
    background: rgba(99,102,241,.14);
    font-weight: 600;
}
.re-nav-icon { width: 14px; height: 14px; flex-shrink: 0; opacity: .7; }
.re-nav-btn.is-active .re-nav-icon { opacity: 1; }
.re-nav-count {
    margin-left: auto; padding: 1px 7px; border-radius: 999px;
    font-size: 10px; font-weight: 700; font-family: ui-monospace, monospace;
    background: rgba(99,102,241,.14); color: #4f46e5;
    border: 1px solid rgba(99,102,241,.28);
}
body.app-theme-dark .re-nav-count { color: #a5b4fc; }

.re-pane { flex: 1 1 auto; min-width: 0; padding: 18px 22px; overflow-y: auto; }
.re-pane-section { display: none; }
.re-pane-section.is-active { display: block; }
.re-pane h2 { margin: 0 0 4px; font-size: 15px; color: var(--re-text); font-weight: 700; }
.re-pane .pane-hint { font-size: 12px; color: var(--re-text-muted); margin-bottom: 14px; }

/* Form */
.re-row { display: grid; grid-template-columns: 160px 1fr; gap: 10px; align-items: center; margin-bottom: 10px; }
.re-row label { font-size: 12px; color: var(--re-text-muted); font-weight: 500; }
.re-row input, .re-row select, .re-row textarea {
    padding: 7px 10px; border-radius: 6px;
    border: 1px solid var(--re-border);
    background: var(--re-input-bg); color: var(--re-text);
    font-size: 13px; outline: none;
}
.re-row input:focus, .re-row select:focus, .re-row textarea:focus {
    border-color: var(--re-accent); box-shadow: 0 0 0 2px rgba(99,102,241,.18);
}
body.app-theme-dark .re-row select,
html.dark .re-row select { color-scheme: dark; }
.re-row select > * { background: var(--re-surface); color: var(--re-text); }
body.app-theme-dark .re-row select > *,
html.dark .re-row select > * { background-color: #0d1323; color: #e2e8f0; }
.re-row textarea { min-height: 60px; resize: vertical; }
.re-row .inline-pair { display: flex; gap: 8px; align-items: center; }
.re-row .inline-pair input { flex: 1; }
.re-row .inline-pair .read-label {
    flex: 0 0 auto; padding: 7px 10px; font-size: 12px;
    color: var(--re-text-muted); border-radius: 6px;
    background: var(--re-surface2); min-width: 140px;
}

/* Operasyonlar (inline in genel tab) */
.re-ops-section {
    margin-top: 20px; padding-top: 16px;
    border-top: 1px solid var(--re-border);
}
.re-ops-section-header {
    display: flex; align-items: center; gap: 10px; margin-bottom: 12px;
}
.re-ops-section-label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .6px; color: var(--re-text-muted);
}
.re-ops-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.re-ops-table th, .re-ops-table td {
    padding: 6px 8px; border-bottom: 1px solid var(--re-border-light);
    text-align: left; color: var(--re-text);
}
.re-ops-table th {
    background: var(--re-surface2); font-size: 11px;
    text-transform: uppercase; letter-spacing: .5px;
    color: var(--re-text-muted);
    border-bottom: 1px solid var(--re-border);
    position: sticky; top: 0;
}
.re-ops-table input {
    width: 100%; padding: 5px 8px; border-radius: 5px;
    border: 1px solid var(--re-border);
    background: var(--re-input-bg); color: var(--re-text);
    font-size: 12px; outline: none;
}
.re-ops-table input:focus {
    border-color: var(--re-accent);
    box-shadow: 0 0 0 2px rgba(99,102,241,.18);
}
.re-ops-table input[type="number"] { text-align: right; }
.re-ops-table .col-seq    { width: 70px; }
.re-ops-table .col-action { width: 90px; text-align: center; }
.re-ops-table .row-empty {
    text-align: center; color: var(--re-text-muted);
    padding: 28px 12px; font-size: 13px;
}
.re-icon-btn {
    background: transparent; border: 0; cursor: pointer;
    color: var(--re-text-muted); padding: 4px 6px; border-radius: 4px;
    font-size: 16px; line-height: 1;
}
.re-icon-btn:hover { background: var(--re-surface2); color: var(--re-text); }
.re-icon-btn--del:hover { color: #ef4444; background: rgba(239,68,68,.12); }
.re-icon-btn--up:hover, .re-icon-btn--down:hover { color: var(--re-accent); }

.re-add-row {
    margin-top: 12px; padding: 10px 12px;
    border: 1px dashed var(--re-border); border-radius: 8px;
    background: var(--re-surface2);
}
.re-add-row .grid {
    display: grid;
    grid-template-columns: 70px 1fr 1fr auto;
    gap: 8px; align-items: end;
}
.re-add-row .field { display: flex; flex-direction: column; gap: 4px; }
.re-add-row .field label { font-size: 11px; color: var(--re-text-muted); }
.re-add-row .field input {
    padding: 6px 8px; border-radius: 5px;
    border: 1px solid var(--re-border);
    background: var(--re-input-bg); color: var(--re-text);
    font-size: 12px; outline: none;
}

.re-status-pill {
    padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600;
    background: rgba(34,197,94,.18); color: #16a34a;
}
.re-status-pill--off { background: rgba(148,163,184,.18); color: var(--re-text-muted); }
body.app-theme-dark .re-status-pill { color: #86efac; }

.re-meta {
    margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--re-border-light);
    display: flex; gap: 14px; flex-wrap: wrap;
    font-size: 11px; color: var(--re-text-muted);
}

#reDynamicWidgets { width: 100%; }
.re-placeholder {
    padding: 18px; border: 1px dashed var(--re-border); border-radius: 8px;
    color: var(--re-text-muted); font-size: 13px;
    background: var(--re-surface2);
}

#re-flash { position: fixed; top: 16px; right: 16px; z-index: 9999;
    padding: 10px 16px; border-radius: 8px; font-size: 13px;
    box-shadow: 0 4px 12px rgba(0,0,0,.25);
    display: none; max-width: 360px;
}
#re-flash.ok  { background: var(--re-toast-ok-bg); color: var(--re-toast-ok-tx); }
#re-flash.err { background: var(--re-toast-er-bg); color: var(--re-toast-er-tx); }

/* ── Guide modals (Stok Rehberi style — always dark) ── */
.cg-modal-backdrop {
    position: fixed; inset: 0; z-index: 9998;
    background: rgba(8,12,24,.65);
    backdrop-filter: blur(4px);
    display: none; align-items: flex-start; justify-content: center;
    padding-top: 7vh;
}
.cg-modal-backdrop.is-open { display: flex; }
.cg-modal {
    background: #0d1323;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 14px;
    width: min(540px,96vw); max-height: 74vh;
    display: flex; flex-direction: column;
    box-shadow: 0 20px 60px rgba(0,0,0,.55);
    overflow: hidden;
    color: #e2e8f0;
}
.cg-modal-header {
    padding: 14px 18px;
    border-bottom: 1px solid rgba(255,255,255,.08);
    display: flex; align-items: center; gap: 10px;
    flex-shrink: 0;
}
.cg-modal-header-icon {
    width: 30px; height: 30px; border-radius: 8px;
    background: rgba(99,102,241,.22);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.cg-modal-title { font-size: 14px; font-weight: 700; color: #f1f5f9; flex: 1; }
.cg-modal-header-close {
    background: transparent; border: 0; cursor: pointer;
    color: #64748b; padding: 4px 6px; border-radius: 5px;
    font-size: 18px; line-height: 1;
    transition: color .12s, background .12s;
}
.cg-modal-header-close:hover { color: #e2e8f0; background: rgba(255,255,255,.08); }
.cg-modal-search-wrap {
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255,255,255,.07);
    flex-shrink: 0; position: relative;
}
.cg-modal-search-icon {
    position: absolute; left: 28px; top: 50%; transform: translateY(-50%);
    color: #64748b; pointer-events: none; display: flex; align-items: center;
}
.cg-modal-search {
    width: 100%; padding: 9px 10px 9px 36px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,.1);
    background: rgba(255,255,255,.06); color: #e2e8f0;
    font-size: 13px; outline: none;
    box-sizing: border-box;
}
.cg-modal-search::placeholder { color: #64748b; }
.cg-modal-search:focus { border-color: rgba(99,102,241,.5); box-shadow: 0 0 0 2px rgba(99,102,241,.15); }
.cg-section-label {
    padding: 8px 18px 4px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.9px;
    text-transform: uppercase; color: #4b5563;
}
.cg-modal-list {
    flex: 1 1 auto; overflow-y: auto; min-height: 0;
}
.cg-modal-row {
    display: flex; align-items: center; gap: 12px;
    padding: 9px 18px;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,.05);
    transition: background .1s;
}
.cg-modal-row:hover { background: rgba(99,102,241,.14); }
.cg-modal-row-code {
    font-size: 12px; font-weight: 700; font-family: ui-monospace, monospace;
    color: #818cf8; flex-shrink: 0; min-width: 90px;
}
.cg-modal-row-name { font-size: 13px; color: #e2e8f0; flex: 1; }
.cg-modal-row-sub { font-size: 11px; color: #6b7280; }
.cg-modal-empty {
    padding: 36px 18px; text-align: center;
    color: #4b5563; font-size: 13px;
}
.cg-modal-footer {
    padding: 10px 18px;
    border-top: 1px solid rgba(255,255,255,.08);
    display: flex; align-items: center; justify-content: space-between;
    flex-shrink: 0;
}
.cg-modal-footer-count { font-size: 11px; color: #4b5563; }
.cg-modal-footer-close {
    padding: 6px 16px; border-radius: 7px;
    border: 1px solid rgba(255,255,255,.15);
    background: transparent; color: #94a3b8;
    font-size: 12px; cursor: pointer;
    transition: background .12s, color .12s;
}
.cg-modal-footer-close:hover { background: rgba(255,255,255,.06); color: #e2e8f0; }
.cg-modal-back-btn {
    padding: 6px 12px; border-radius: 7px;
    border: 1px solid rgba(255,255,255,.12);
    background: transparent; color: #818cf8;
    font-size: 12px; cursor: pointer;
    transition: background .12s;
}
.cg-modal-back-btn:hover { background: rgba(99,102,241,.12); }
.cg-modal-add-btn {
    padding: 6px 14px; border-radius: 7px;
    border: 1px solid rgba(99,102,241,.4);
    background: rgba(99,102,241,.18); color: #a5b4fc;
    font-size: 12px; cursor: pointer;
    transition: background .12s;
}
.cg-modal-add-btn:hover { background: rgba(99,102,241,.28); }

/* ── Mamul Eşleştirme rows ── */
.map-rows-list { display: flex; flex-direction: column; gap: 0; }
.map-row {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 10px;
    border-bottom: 1px solid var(--re-border-light);
    border-radius: 6px;
    transition: background .1s;
}
.map-row:hover { background: var(--re-surface2); }
.map-row-code {
    font-size: 12px; font-weight: 700; font-family: ui-monospace, monospace;
    color: #6366f1; flex-shrink: 0; min-width: 90px;
}
body.app-theme-dark .map-row-code { color: #818cf8; }
.map-row-name { font-size: 13px; color: var(--re-text); flex: 1; }
.map-row-combo {
    font-size: 11px; color: var(--re-text-muted); flex-shrink: 0; min-width: 110px;
    text-align: right;
}
.maps-section-header {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 8px;
}
.maps-section-label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .6px; color: var(--re-text-muted);
}

/* Layout sıfırlamaları */
.page-routing-edit .integrator-dashboard {
    height: 100% !important; min-height: 0 !important;
    padding: 0 !important; max-width: none !important;
    background: transparent !important; box-shadow: none !important;
    border: none !important; border-radius: 0 !important;
}
.page-routing-edit .integrator-dashboard__content {
    display: flex !important; flex-direction: column !important;
    width: 100% !important; max-width: none !important;
    min-height: 0 !important; padding: 0 !important;
    margin: 0 !important; overflow: hidden !important;
    height: 100% !important;
}
</style>

<div class="ux-edit-shell">
    @await Html.PartialAsync("_CalibraActionBar", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["Title"]       = isNew ? "Yeni Rota" : ((Model!.Name ?? Model.Code ?? "Rota") + (Model!.IsActive ? "" : " (Pasif)")),
        ["ListUrl"]     = Url.Action("Routings"),
        ["NewUrl"]      = Url.Action("RoutingEdit"),
        ["SaveBtnId"]   = "btn-save",
        ["DeleteBtnId"] = "btn-delete",
        ["NewBtnId"]    = "btn-new",
        ["ShowDelete"]  = !isNew,
    })

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content" style="flex:1; min-height:0; display:flex; flex-direction:column; overflow:hidden;">
<div class="re-page" style="height:100%;">


    <div class="re-tabbed">
        <nav class="re-nav">
            <div class="re-nav-grouptitle">Rota</div>
            <button type="button" class="re-nav-btn is-active" data-tab="genel">
                <svg class="re-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <span>Genel Bilgiler</span>
                <span class="re-nav-count" id="nav-count-ops">@operations.Count</span>
            </button>
            <div class="re-nav-grouptitle">Ek Sahalar</div>
            <button type="button" class="re-nav-btn" data-tab="widgets">
                <svg class="re-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm0 10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10-10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zm0 10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                <span>Widget Sahaları</span>
            </button>
            <div class="re-nav-grouptitle">Mamul</div>
            <button type="button" class="re-nav-btn" data-tab="mamul" @(isNew ? "disabled" : "")>
                <svg class="re-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
                <span>Mamul Eşleştirme</span>
                <span class="re-nav-count" id="nav-count-maps">0</span>
            </button>
        </nav>

        <div class="re-pane">
            <!-- Tab: Genel Bilgiler (+ Operasyonlar inline) -->
            <section class="re-pane-section is-active" data-pane="genel">
                <h2>Genel Bilgiler</h2>
                <div class="pane-hint">Rotanın kimlik ve mamul bağı. Boş Item = şablon rota (herhangi bir mamul için temel).</div>

                <input type="hidden" id="f-id" value="@(Model?.Id ?? 0)" />

                <div class="re-row">
                    <label>Ad *</label>
                    <input type="text" id="f-name" value="@Model?.Name" placeholder="Standart Üretim Rotası" maxlength="200" />
                </div>
                <div class="re-row">
                    <label>Mamul Kodu</label>
                    <div class="inline-pair">
                        <input type="text" id="f-itemCode" value="@Model?.ItemCode" placeholder="Items.Code (boş = şablon)" maxlength="50" autocomplete="off" />
                        <input type="hidden" id="f-itemId" value="@(Model?.ItemId?.ToString() ?? "")" />
                        <span class="read-label" id="f-itemName">@Model?.ItemName</span>
                    </div>
                </div>
                <div class="re-row" style="align-items: start;">
                    <label>Açıklama</label>
                    <textarea id="f-description" maxlength="500" placeholder="İsteğe bağlı detay...">@Model?.Description</textarea>
                </div>
                <div class="re-row">
                    <label>Aktif</label>
                    <label style="display:inline-flex; gap:8px; align-items:center;">
                        <input type="checkbox" id="f-active" @(Model is null || Model.IsActive ? "checked" : "") />
                        <span style="font-size:12px;color:var(--re-text-muted);" id="f-active-label">@((Model is null || Model.IsActive) ? "Etkin" : "Pasif")</span>
                    </label>
                </div>

                @if (!isNew)
                {
                    <div class="re-meta">
                        <span>Oluşturma: @Model!.Created.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        @if (Model.Updated.HasValue)
                        {
                            <span>Güncelleme: @Model.Updated.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        }
                    </div>
                }

                <!-- Operasyon Adımları (inline) -->
                <div class="re-ops-section">
                    <div class="re-ops-section-header">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--re-text-muted);"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/></svg>
                        <span class="re-ops-section-label">Operasyon Adımları</span>
                    </div>
                    <table class="re-ops-table">
                        <thead>
                            <tr>
                                <th class="col-seq">Sıra</th>
                                <th>Operasyon *</th>
                                <th>Notlar</th>
                                <th class="col-action"></th>
                            </tr>
                        </thead>
                        <tbody id="ops-tbody">
                            @if (operations.Count == 0)
                            {
                                <tr id="ops-empty-row"><td colspan="4" class="row-empty">Henüz operasyon eklenmemiş. Aşağıdaki formdan ekleyin.</td></tr>
                            }
                            else
                            {
                                foreach (var op in operations)
                                {
                                    <tr data-row-id="@op.Id">
                                        <td>
                                            <input type="number" class="op-seq" min="0" step="1" value="@op.Sequence" />
                                        </td>
                                        <td>
                                            <div style="display:flex;gap:4px;align-items:center;">
                                                <input type="text" class="op-code" readonly value="@op.OperationCode" data-id="@op.OperationId"
                                                       placeholder="Operasyon seç..." style="flex:1;cursor:pointer;" title="Operasyon seçmek için tıklayın" />
                                                <button type="button" class="re-icon-btn op-guide-btn" title="Operasyon rehberi">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                                                </button>
                                            </div>
                                        </td>
                                        <td>
                                            <input type="text" class="op-notes" value="@op.Notes" placeholder="(opsiyonel)" maxlength="500" />
                                        </td>
                                        <td class="col-action">
                                            <button type="button" class="re-icon-btn re-icon-btn--up" data-action="up" title="Yukarı">↑</button>
                                            <button type="button" class="re-icon-btn re-icon-btn--down" data-action="down" title="Aşağı">↓</button>
                                            <button type="button" class="re-icon-btn re-icon-btn--del" data-action="del" title="Sil">×</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <div class="re-add-row">
                        <div class="grid">
                            <div class="field">
                                <label>Sıra</label>
                                <input type="number" id="add-seq" min="0" step="1" value="@(operations.Count > 0 ? (operations.Max(o => o.Sequence) + 10).ToString() : "10")" />
                            </div>
                            <div class="field">
                                <label>Operasyon *</label>
                                <div style="display:flex;gap:4px;align-items:center;">
                                    <input type="text" id="add-op-code" readonly placeholder="Seçilmedi" style="flex:1;cursor:pointer;" title="Operasyon seçmek için tıklayın" />
                                    <input type="hidden" id="add-op-id" value="" />
                                    <button type="button" class="re-btn" id="btn-add-op-guide" style="padding:5px 10px;white-space:nowrap;">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle;margin-right:3px;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>Seç
                                    </button>
                                </div>
                            </div>
                            <div class="field">
                                <label>Notlar</label>
                                <input type="text" id="add-notes" placeholder="(opsiyonel)" maxlength="500" />
                            </div>
                            <div class="field">
                                <label>&nbsp;</label>
                                <button type="button" class="re-btn re-btn--primary" id="btn-add-op">+ Ekle</button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Tab: Widget Sahaları -->
            <section class="re-pane-section" data-pane="widgets">
                <div id="reDynamicWidgets"
                     data-form-code="ROUTING_EDIT"
                     data-record-id="@(Model?.Id.ToString() ?? "")">
                    <div class="re-placeholder">
                        Bu form için tanımlı widget yok. <a href="@Url.Action("FormManagement", "Admin")">Form Tasarım Ayarları</a>'ndan ekleyebilirsin.
                    </div>
                </div>
            </section>

            <!-- Tab: Mamul Eşleştirme -->
            <section class="re-pane-section" data-pane="mamul">
                <h2>Mamul Eşleştirme</h2>
                <div class="pane-hint">Bu rotanın uygulandığı mamulleri ve kombinasyonları tanımlayın. Eşleştirme yoksa rota tüm mamuller için şablon olarak geçerlidir.</div>
                @if (isNew)
                {
                    <div class="re-placeholder">Önce rotayı kaydedin, ardından mamul eşleştirebilirsiniz.</div>
                }
                else
                {
                    <div style="margin-bottom:16px;">
                        <button type="button" class="re-btn re-btn--primary" id="btn-open-map-guide" style="gap:6px;display:inline-flex;align-items:center;">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Mamul Ekle
                        </button>
                    </div>

                    <div class="maps-section-header">
                        <span class="maps-section-label">Eşleşmeler</span>
                        <span class="re-nav-count" id="nav-count-maps-inline">0</span>
                    </div>
                    <div class="map-rows-list" id="map-rows-container">
                        <div class="re-placeholder" id="map-empty-placeholder">Yükleniyor...</div>
                    </div>
                }
            </section>
        </div>
    </div>

    <!-- ── Operasyon Rehber Popup (Stok Rehberi style) ── -->
    <div id="op-guide-backdrop" class="cg-modal-backdrop">
        <div class="cg-modal">
            <div class="cg-modal-header">
                <div class="cg-modal-header-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                </div>
                <span class="cg-modal-title">Operasyon Seç</span>
                <button type="button" class="cg-modal-header-close" id="op-guide-close">×</button>
            </div>
            <div class="cg-modal-search-wrap">
                <span class="cg-modal-search-icon">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </span>
                <input type="text" id="op-guide-search" class="cg-modal-search" placeholder="Kod veya ad ile ara..." autocomplete="off" />
            </div>
            <div class="cg-section-label" id="op-guide-section-label">OPERASYONLAR (0)</div>
            <div class="cg-modal-list" id="op-guide-list"></div>
            <div class="cg-modal-footer">
                <span class="cg-modal-footer-count" id="op-guide-footer-count">0 operasyon</span>
                <button type="button" class="cg-modal-footer-close" id="op-guide-close-btn">Kapat</button>
            </div>
        </div>
    </div>

    <!-- ── Mamul (Stok) Rehber Popup ── -->
    <div id="map-guide-backdrop" class="cg-modal-backdrop">
        <div class="cg-modal">
            <!-- Step A: Stok seçimi -->
            <div id="map-guide-step-a" style="display:flex;flex-direction:column;flex:1;min-height:0;overflow:hidden;">
                <div class="cg-modal-header">
                    <div class="cg-modal-header-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#818cf8" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
                    </div>
                    <span class="cg-modal-title">Mamul Seç</span>
                    <button type="button" class="cg-modal-header-close" id="map-guide-close">×</button>
                </div>
                <div class="cg-modal-search-wrap">
                    <span class="cg-modal-search-icon">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </span>
                    <input type="text" id="map-guide-search" class="cg-modal-search" placeholder="Stok kodu veya adı..." autocomplete="off" />
                </div>
                <div class="cg-section-label" id="map-guide-section-label">STOKLAR (0)</div>
                <div class="cg-modal-list" id="map-guide-list"></div>
                <div class="cg-modal-footer">
                    <span class="cg-modal-footer-count" id="map-guide-footer-count">0 stok</span>
                    <button type="button" class="cg-modal-footer-close" id="map-guide-close-btn">Kapat</button>
                </div>
            </div>
            <!-- Step B: Kombinasyon seçimi -->
            <div id="map-guide-step-b" style="display:none;flex-direction:column;flex:1;min-height:0;overflow:hidden;">
                <div class="cg-modal-header">
                    <button type="button" class="cg-modal-back-btn" id="map-guide-back">← Geri</button>
                    <span class="cg-modal-title" id="map-guide-b-title">Kombinasyon Seç</span>
                    <button type="button" class="cg-modal-header-close" id="map-guide-b-close">×</button>
                </div>
                <div class="cg-section-label" id="map-guide-b-label">KOMBİNASYONLAR (0)</div>
                <div class="cg-modal-list" id="map-guide-b-list"></div>
                <div class="cg-modal-footer">
                    <button type="button" class="cg-modal-add-btn" id="map-guide-b-nocombo">+ Kombinasyonsuz Ekle</button>
                    <button type="button" class="cg-modal-footer-close" id="map-guide-b-close-btn">Kapat</button>
                </div>
            </div>
        </div>
    </div>
</div>
</section>
</div>

<div id="re-flash"></div>
@Html.AntiForgeryToken()

<script>
(function () {
    const isNew = @(isNew ? "true" : "false");
    const id    = @(Model?.Id ?? 0);

    function token() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function flash(msg, ok) {
        const el = document.getElementById('re-flash');
        el.textContent = msg;
        el.className = ok ? 'ok' : 'err';
        el.style.display = 'block';
        clearTimeout(window.__reFlashTm);
        window.__reFlashTm = setTimeout(() => el.style.display = 'none', 3000);
    }

    /* ── Tab switch ── */
    const navBtns = document.querySelectorAll('.re-nav-btn');
    const panes   = document.querySelectorAll('.re-pane-section');
    function activate(tabKey) {
        navBtns.forEach(b => b.classList.toggle('is-active', b.dataset.tab === tabKey));
        panes.forEach(p => p.classList.toggle('is-active', p.dataset.pane === tabKey));
    }
    navBtns.forEach(btn => btn.addEventListener('click', () => {
        if (btn.disabled) return;
        activate(btn.dataset.tab);
    }));

    /* ── Active switch label ── */
    const activeChk = document.getElementById('f-active');
    const activeLbl = document.getElementById('f-active-label');
    activeChk?.addEventListener('change', () => {
        if (activeLbl) activeLbl.textContent = activeChk.checked ? 'Etkin' : 'Pasif';
    });

    /* ── Item lookup ── */
    let itemLookupTm = null;
    const itemCodeEl = document.getElementById('f-itemCode');
    const itemIdEl   = document.getElementById('f-itemId');
    const itemNameEl = document.getElementById('f-itemName');
    async function resolveItem(code, opts) {
        opts = opts || {};
        const q = (code || '').trim();
        if (!q) {
            if (itemIdEl) itemIdEl.value = '';
            if (itemNameEl) itemNameEl.textContent = '';
            return null;
        }
        try {
            const r = await fetch('/Logistics/StockLookup?q=' + encodeURIComponent(q), { credentials: 'same-origin' });
            const list = await r.json();
            const arr = Array.isArray(list) ? list : [];
            const match = arr.find(s => (s.code || '').toLowerCase() === q.toLowerCase());
            if (match) {
                if (itemIdEl) itemIdEl.value = String(match.id);
                if (itemNameEl) itemNameEl.textContent = match.name || '';
                return match;
            } else {
                if (itemIdEl) itemIdEl.value = '';
                if (itemNameEl) itemNameEl.textContent = opts.silent ? '' : 'Bulunamadı';
                return null;
            }
        } catch (e) { return null; }
    }
    itemCodeEl?.addEventListener('input', function () {
        clearTimeout(itemLookupTm);
        itemLookupTm = setTimeout(() => resolveItem(this.value, { silent: true }), 250);
    });
    itemCodeEl?.addEventListener('blur', function () { resolveItem(this.value); });

    /* ── Operasyon rehber ── */
    let opOptionsCache = null;
    async function getOperationOptions() {
        if (opOptionsCache) return opOptionsCache;
        try {
            const r = await fetch('/Production/OperationsList?includeInactive=false', { credentials: 'same-origin' });
            const list = await r.json();
            opOptionsCache = Array.isArray(list) ? list : [];
        } catch (e) { opOptionsCache = []; }
        return opOptionsCache;
    }
    function escapeHtml(s) {
        return (s == null ? '' : String(s)).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    let opGuideCallback = null;

    function openOpGuide(callback) {
        opGuideCallback = callback;
        const backdrop = document.getElementById('op-guide-backdrop');
        backdrop.classList.add('is-open');
        const searchEl = document.getElementById('op-guide-search');
        searchEl.value = '';
        renderOpGuide('');
        setTimeout(() => searchEl.focus(), 50);
    }

    function closeOpGuide() {
        document.getElementById('op-guide-backdrop').classList.remove('is-open');
        opGuideCallback = null;
    }

    async function renderOpGuide(filter) {
        const opts = await getOperationOptions();
        const listEl = document.getElementById('op-guide-list');
        const labelEl = document.getElementById('op-guide-section-label');
        const countEl = document.getElementById('op-guide-footer-count');
        if (!listEl) return;
        const q = (filter || '').toLowerCase().trim();
        const filtered = q
            ? opts.filter(o => (o.code || '').toLowerCase().includes(q) || (o.name || '').toLowerCase().includes(q))
            : opts;
        if (labelEl) labelEl.textContent = 'OPERASYONLAR (' + filtered.length + ')';
        if (countEl) countEl.textContent = filtered.length + ' operasyon';
        if (!filtered.length) {
            listEl.innerHTML = '<div class="cg-modal-empty">' + (q ? 'Sonuç bulunamadı.' : 'Operasyon tanımlanmamış.') + '</div>';
            return;
        }
        listEl.innerHTML = filtered.map(o =>
            `<div class="cg-modal-row" data-op-id="${o.id}" data-op-code="${escapeHtml(o.code)}" data-op-name="${escapeHtml(o.name || '')}">
                <span class="cg-modal-row-code">${escapeHtml(o.code)}</span>
                <span class="cg-modal-row-name">${escapeHtml(o.name || '')}</span>
            </div>`
        ).join('');
        listEl.querySelectorAll('.cg-modal-row').forEach(row => {
            row.addEventListener('click', () => {
                const op = { id: parseInt(row.dataset.opId), code: row.dataset.opCode, name: row.dataset.opName };
                closeOpGuide();
                if (opGuideCallback) opGuideCallback(op);
            });
        });
    }

    document.getElementById('op-guide-search')?.addEventListener('input', function() { renderOpGuide(this.value); });
    document.getElementById('op-guide-close')?.addEventListener('click', closeOpGuide);
    document.getElementById('op-guide-close-btn')?.addEventListener('click', closeOpGuide);
    document.getElementById('op-guide-backdrop')?.addEventListener('click', function(e) {
        if (e.target === this) closeOpGuide();
    });

    /* Add-row guide triggers */
    document.getElementById('add-op-code')?.addEventListener('click', () => openOpGuide(op => {
        document.getElementById('add-op-code').value = op.code;
        document.getElementById('add-op-id').value = String(op.id);
    }));
    document.getElementById('btn-add-op-guide')?.addEventListener('click', () => openOpGuide(op => {
        document.getElementById('add-op-code').value = op.code;
        document.getElementById('add-op-id').value = String(op.id);
    }));

    function tbody() { return document.getElementById('ops-tbody'); }
    function rebuildEmptyState() {
        const rows = tbody().querySelectorAll('tr[data-row-id]');
        const empty = document.getElementById('ops-empty-row');
        if (rows.length === 0) {
            if (!empty) {
                tbody().innerHTML = '<tr id="ops-empty-row"><td colspan="4" class="row-empty">Henüz operasyon eklenmemiş. Aşağıdaki formdan ekleyin.</td></tr>';
            }
        } else if (empty) {
            empty.remove();
        }
        document.getElementById('nav-count-ops').textContent = String(rows.length);
    }

    function bindRowActions(tr) {
        tr.querySelector('[data-action="del"]')?.addEventListener('click', () => {
            tr.remove(); rebuildEmptyState();
        });
        tr.querySelector('[data-action="up"]')?.addEventListener('click', () => {
            const prev = tr.previousElementSibling;
            if (prev && prev.dataset && prev.dataset.rowId) tr.parentNode.insertBefore(tr, prev);
        });
        tr.querySelector('[data-action="down"]')?.addEventListener('click', () => {
            const next = tr.nextElementSibling;
            if (next && next.dataset && next.dataset.rowId) tr.parentNode.insertBefore(next, tr);
        });
        const opCodeInput = tr.querySelector('.op-code');
        function openGuideForRow() {
            openOpGuide(op => {
                if (opCodeInput) { opCodeInput.value = op.code; opCodeInput.dataset.id = String(op.id); }
            });
        }
        tr.querySelector('.op-guide-btn')?.addEventListener('click', openGuideForRow);
        opCodeInput?.addEventListener('click', openGuideForRow);
    }

    tbody().querySelectorAll('tr[data-row-id]').forEach(tr => bindRowActions(tr));

    document.getElementById('btn-add-op')?.addEventListener('click', () => {
        const seq = Number(document.getElementById('add-seq').value || 0);
        const opCode = document.getElementById('add-op-code').value.trim();
        const opId = parseInt(document.getElementById('add-op-id').value || '0');
        if (!opId) { flash('Önce operasyon seçin.', false); return; }
        const notes = document.getElementById('add-notes').value.trim();

        const tr = document.createElement('tr');
        tr.dataset.rowId = 'new-' + Date.now();
        tr.innerHTML = `
            <td><input type="number" class="op-seq" min="0" step="1" value="${seq}" /></td>
            <td>
                <div style="display:flex;gap:4px;align-items:center;">
                    <input type="text" class="op-code" readonly value="${escapeHtml(opCode)}" data-id="${opId}"
                           placeholder="Operasyon seç..." style="flex:1;cursor:pointer;" />
                    <button type="button" class="re-icon-btn op-guide-btn" title="Operasyon rehberi">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </button>
                </div>
            </td>
            <td><input type="text" class="op-notes" value="${escapeHtml(notes)}" placeholder="(opsiyonel)" maxlength="500" /></td>
            <td class="col-action">
                <button type="button" class="re-icon-btn re-icon-btn--up" data-action="up" title="Yukarı">↑</button>
                <button type="button" class="re-icon-btn re-icon-btn--down" data-action="down" title="Aşağı">↓</button>
                <button type="button" class="re-icon-btn re-icon-btn--del" data-action="del" title="Sil">×</button>
            </td>`;
        tbody().appendChild(tr);
        bindRowActions(tr);
        rebuildEmptyState();

        document.getElementById('add-seq').value = String(seq + 10);
        document.getElementById('add-op-code').value = '';
        document.getElementById('add-op-id').value = '';
        document.getElementById('add-notes').value = '';
    });

    /* ── Save ── */
    document.getElementById('btn-save')?.addEventListener('click', async () => {
        const name = document.getElementById('f-name').value.trim();
        if (!name) { flash('Ad zorunlu.', false); return; }
        // K6: Kod alanı UI'dan kaldırıldı; backend name'den auto-derive eder.
        // Payload'da code = name göndererek mevcut DTO contract'ını korur (server zaten override eder).
        const code = name;

        const itemCodeVal = (itemCodeEl?.value || '').trim();
        if (itemCodeVal) {
            await resolveItem(itemCodeVal);
            if (!itemIdEl.value) {
                flash('Mamul kodu çözümlenemedi. Boş bırakın veya geçerli kod seçin.', false);
                return;
            }
        }
        const itemId = itemIdEl.value ? Number(itemIdEl.value) : null;

        const rows = Array.from(tbody().querySelectorAll('tr[data-row-id]'));
        const operationList = [];
        for (const tr of rows) {
            const opCodeInput = tr.querySelector('.op-code');
            const opId = opCodeInput?.dataset.id ? Number(opCodeInput.dataset.id) : 0;
            if (!opId) { flash('Operasyon seçilmemiş satır var.', false); return; }
            const seq = Number(tr.querySelector('.op-seq').value || 0);
            const notes = tr.querySelector('.op-notes').value.trim() || null;
            operationList.push({ sequence: seq, operationId: opId, machineId: null, overrideDuration: null, durationUnit: 1, notes });
        }

        const body = {
            id: Number(document.getElementById('f-id').value || 0),
            code, name, itemId,
            configId: null,
            description: document.getElementById('f-description').value.trim() || null,
            isActive: activeChk.checked,
            operations: operationList
        };

        try {
            const r = await fetch('/Production/SaveRouting', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                credentials: 'same-origin',
                body: JSON.stringify(body)
            });
            const data = await r.json();
            if (data.ok) {
                flash('Kaydedildi.', true);
                if (isNew && data.id) {
                    // PJAX swap Edit?id=... için unstable → liste sayfasına dön
                    setTimeout(() => location.href = '/Production/Routings', 500);
                } else {
                    setTimeout(() => location.reload(), 500);
                }
            } else flash(data.error || 'Hata.', false);
        } catch (e) { flash('İstek hatası: ' + e.message, false); }
    });

    /* ── Delete ── Rapor §2.1: showConfirm global helper (wwwroot/js/confirm-modal.js) */

    document.getElementById('btn-delete')?.addEventListener('click', async () => {
        const ok = await showConfirm({
            title: 'Rota Sil',
            message: 'Bu rota ve içindeki tüm operasyon adımları kalıcı olarak silinecek. Devam edilsin mi?',
            okLabel: 'Sil'
        });
        if (!ok) return;
        try {
            const r = await fetch('/Production/DeleteRouting/' + id, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token() },
                credentials: 'same-origin'
            });
            const data = await r.json();
            if (data.ok) location.href = '/Production/Routings';
            else flash(data.error || 'Hata.', false);
        } catch (e) { flash('İstek hatası: ' + e.message, false); }
    });

    /* ── Mamul Eşleştirme ── */
    @if (!isNew)
    {
        <text>
    let mapLoaded = false;

    async function loadCurrentMaps() {
        const container = document.getElementById('map-rows-container');
        const placeholder = document.getElementById('map-empty-placeholder');
        if (placeholder) placeholder.style.display = '';
        if (placeholder) placeholder.textContent = 'Yükleniyor...';
        try {
            const r = await fetch('/Production/RoutingItemMaps?routingId=' + id, { credentials: 'same-origin' });
            const maps = await r.json();
            renderCurrentMaps(maps);
        } catch(e) {
            if (placeholder) { placeholder.style.display = ''; placeholder.textContent = 'Yükleme hatası.'; }
        }
    }

    function renderCurrentMaps(maps) {
        const container = document.getElementById('map-rows-container');
        const countEl = document.getElementById('nav-count-maps');
        const countEl2 = document.getElementById('nav-count-maps-inline');
        if (!container) return;
        if (countEl) countEl.textContent = String(maps.length);
        if (countEl2) countEl2.textContent = String(maps.length);
        if (!maps.length) {
            container.innerHTML = '<div class="re-placeholder" id="map-empty-placeholder">Henüz eşleştirme yok. Mamul Ekle butonu ile başlayın.</div>';
            return;
        }
        container.innerHTML = maps.map(m => `
            <div class="map-row" data-map-id="${m.id}">
                <span class="map-row-code">${escapeHtml(m.itemCode || '')}</span>
                <span class="map-row-name">${escapeHtml(m.itemName || '')}</span>
                <span class="map-row-combo">${m.configId
                    ? escapeHtml(m.combinationCode || '') + (m.combinationName ? ' — ' + escapeHtml(m.combinationName) : '')
                    : '<span style="opacity:.45;">—</span>'}</span>
                <button type="button" class="re-icon-btn re-icon-btn--del" data-map-del="${m.id}" title="Çıkar">×</button>
            </div>`).join('');
        container.querySelectorAll('[data-map-del]').forEach(btn => {
            btn.addEventListener('click', () => deleteMap(parseInt(btn.dataset.mapDel)));
        });
    }

    async function deleteMap(mapId) {
        try {
            const r = await fetch('/Production/DeleteRoutingItemMap?id=' + mapId, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token() },
                credentials: 'same-origin'
            });
            const data = await r.json();
            if (data.ok) loadCurrentMaps();
            else flash(data.error || 'Silinemedi.', false);
        } catch(e) { flash('İstek hatası: ' + e.message, false); }
    }

    async function addMap(itemId, configId) {
        let url = '/Production/AddRoutingItemMap?routingId=' + id + '&itemId=' + itemId;
        if (configId != null) url += '&configId=' + configId;
        try {
            const r = await fetch(url, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token() },
                credentials: 'same-origin'
            });
            const data = await r.json();
            if (data.ok) { flash('Eklendi.', true); loadCurrentMaps(); }
            else flash(data.error || 'Eklenemedi.', false);
        } catch(e) { flash('İstek hatası: ' + e.message, false); }
    }

    /* ── Mamul guide popup ── */
    let mapGuideStockCache = null;
    let mapGuideSelectedItem = null;

    async function getStockOptions(q) {
        try {
            const r = await fetch('/Logistics/StockLookup?q=' + encodeURIComponent(q || ''), { credentials: 'same-origin' });
            const list = await r.json();
            return Array.isArray(list) ? list : [];
        } catch(e) { return []; }
    }

    function openMapGuide() {
        mapGuideSelectedItem = null;
        showMapStepA();
        document.getElementById('map-guide-backdrop').classList.add('is-open');
        const searchEl = document.getElementById('map-guide-search');
        searchEl.value = '';
        renderMapStepA('');
        setTimeout(() => searchEl.focus(), 50);
    }

    function closeMapGuide() {
        document.getElementById('map-guide-backdrop').classList.remove('is-open');
        mapGuideSelectedItem = null;
    }

    function showMapStepA() {
        document.getElementById('map-guide-step-a').style.display = 'flex';
        document.getElementById('map-guide-step-b').style.display = 'none';
    }

    function showMapStepB() {
        document.getElementById('map-guide-step-a').style.display = 'none';
        document.getElementById('map-guide-step-b').style.display = 'flex';
    }

    let mapGuideSearchTm = null;
    async function renderMapStepA(q) {
        const listEl = document.getElementById('map-guide-list');
        const labelEl = document.getElementById('map-guide-section-label');
        const countEl = document.getElementById('map-guide-footer-count');
        if (!listEl) return;
        listEl.innerHTML = '<div class="cg-modal-empty">Aranıyor...</div>';
        const items = await getStockOptions(q);
        if (labelEl) labelEl.textContent = 'STOKLAR (' + items.length + ')';
        if (countEl) countEl.textContent = items.length + ' stok';
        if (!items.length) {
            listEl.innerHTML = '<div class="cg-modal-empty">' + (q ? 'Sonuç bulunamadı.' : 'Stok bulunamadı.') + '</div>';
            return;
        }
        listEl.innerHTML = items.map(s =>
            `<div class="cg-modal-row" data-item-id="${s.id}" data-item-code="${escapeHtml(s.code)}" data-item-name="${escapeHtml(s.name || '')}">
                <span class="cg-modal-row-code">${escapeHtml(s.code)}</span>
                <span class="cg-modal-row-name">${escapeHtml(s.name || '')}</span>
            </div>`
        ).join('');
        listEl.querySelectorAll('.cg-modal-row').forEach(row => {
            row.addEventListener('click', async () => {
                mapGuideSelectedItem = { id: parseInt(row.dataset.itemId), code: row.dataset.itemCode, name: row.dataset.itemName };
                await loadMapStepB(mapGuideSelectedItem);
            });
        });
    }

    async function loadMapStepB(item) {
        const bLabel = document.getElementById('map-guide-b-label');
        const bList  = document.getElementById('map-guide-b-list');
        const bTitle = document.getElementById('map-guide-b-title');
        if (bTitle) bTitle.textContent = escapeHtml(item.code) + ' — Kombinasyon Seç';
        if (bList) bList.innerHTML = '<div class="cg-modal-empty">Yükleniyor...</div>';
        showMapStepB();
        try {
            const r = await fetch('/Logistics/CombinationLookup?materialCode=' + encodeURIComponent(item.code), { credentials: 'same-origin' });
            const combos = await r.json();
            if (!Array.isArray(combos) || !combos.length) {
                // Kombinasyon yoksa direkt ekle
                closeMapGuide();
                addMap(item.id, null);
                return;
            }
            if (bLabel) bLabel.textContent = 'KOMBİNASYONLAR (' + combos.length + ')';
            bList.innerHTML = combos.map(c => `
                <div class="cg-modal-row" data-combo-id="${c.configId}">
                    <span class="cg-modal-row-code">${escapeHtml(c.code || '')}</span>
                    <span class="cg-modal-row-name cg-modal-row-sub">${
                        (c.features || []).map(f => escapeHtml(f.feature + ': ' + f.value)).join(' · ')
                    }</span>
                </div>`).join('');
            bList.querySelectorAll('.cg-modal-row').forEach(row => {
                row.addEventListener('click', () => {
                    const comboId = parseInt(row.dataset.comboId);
                    closeMapGuide();
                    addMap(item.id, comboId);
                });
            });
        } catch(e) {
            closeMapGuide();
            addMap(item.id, null);
        }
    }

    document.getElementById('map-guide-search')?.addEventListener('input', function() {
        clearTimeout(mapGuideSearchTm);
        mapGuideSearchTm = setTimeout(() => renderMapStepA(this.value), 220);
    });
    document.getElementById('map-guide-close')?.addEventListener('click', closeMapGuide);
    document.getElementById('map-guide-close-btn')?.addEventListener('click', closeMapGuide);
    document.getElementById('map-guide-b-close')?.addEventListener('click', closeMapGuide);
    document.getElementById('map-guide-b-close-btn')?.addEventListener('click', closeMapGuide);
    document.getElementById('map-guide-back')?.addEventListener('click', () => {
        mapGuideSelectedItem = null;
        showMapStepA();
    });
    document.getElementById('map-guide-b-nocombo')?.addEventListener('click', () => {
        if (!mapGuideSelectedItem) return;
        closeMapGuide();
        addMap(mapGuideSelectedItem.id, null);
    });
    document.getElementById('map-guide-backdrop')?.addEventListener('click', function(e) {
        if (e.target === this) closeMapGuide();
    });
    document.getElementById('btn-open-map-guide')?.addEventListener('click', openMapGuide);

    document.querySelector('.re-nav-btn[data-tab="mamul"]')?.addEventListener('click', () => {
        if (!mapLoaded) { mapLoaded = true; loadCurrentMaps(); }
    });
        </text>
    }

    /* Escape closes guide modals */
    document.addEventListener('keydown', function(e) {
        if (e.key !== 'Escape') return;
        if (document.getElementById('op-guide-backdrop')?.classList.contains('is-open')) closeOpGuide();
        @if (!isNew) { <text>
        if (document.getElementById('map-guide-backdrop')?.classList.contains('is-open')) closeMapGuide();
        </text> }
    });

    /* Hash deep-link */
    function applyHash() {
        const h = (location.hash || '').replace('#', '').trim();
        if (!h) return;
        const ok = Array.from(navBtns).some(b => b.dataset.tab === h && !b.disabled);
        if (ok) activate(h);
    }
    window.addEventListener('hashchange', applyHash);
    applyHash();

    /* DynamicWidgetRenderer mount */
    function mountWidgets() {
        var el = document.getElementById('reDynamicWidgets');
        if (!el) return;
        function tryMount() {
            if (!window.CalibraHub || !window.CalibraHub.mountDynamicWidgetRenderer) return;
            try {
                window._reDynRenderer = window.CalibraHub.mountDynamicWidgetRenderer(el, {
                    formCode: 'ROUTING_EDIT',
                    recordId: el.dataset.recordId || '',
                    layout:   'sidetabs'
                });
            } catch (e) { console.warn('[RE] mountDynamicWidgetRenderer hatasi:', e); }
        }
        if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
            tryMount();
        } else {
            var retries = 30;
            var iv = setInterval(function () {
                if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
                    clearInterval(iv); tryMount();
                } else if (--retries <= 0) { clearInterval(iv); }
            }, 200);
        }
    }
    mountWidgets();
})();
</script>

</div>
@* /pdt-tab-content *@
