@model CalibraHub.Application.Contracts.WorkOrderDto
@using CalibraHub.Domain.Enums
@{
    var isNew = Model is null;
    ViewData["Title"] = isNew ? "Yeni İş Emri" : $"İş Emri: {Model!.OrderNumber}";
    ViewData["FormCode"] = "WORK_ORDER";
    ViewData["BodyClass"] = "page-work-order-edit";

    string Iso(DateTime? d) => d?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm") ?? "";

    var status = Model?.Status ?? WorkOrderStatus.Planned;
    var canEditPlan = status == WorkOrderStatus.Planned;
    var canRelease  = status == WorkOrderStatus.Planned;
    var canStart    = status == WorkOrderStatus.Released;
    var canComplete = status == WorkOrderStatus.InProgress;
    var canClose    = status == WorkOrderStatus.Completed;
    var canCancel   = status is WorkOrderStatus.Planned or WorkOrderStatus.Released or WorkOrderStatus.InProgress or WorkOrderStatus.Completed;
    var canRevise   = !isNew && status is not WorkOrderStatus.Planned and not WorkOrderStatus.Closed and not WorkOrderStatus.Cancelled;
}

@section Styles {
<style>
/* ── Tema değişkenleri (light default) ── */
.woe-page {
    --woe-bg:           #f8fafc;
    --woe-surface:      #ffffff;
    --woe-surface2:     #f1f5f9;
    --woe-border:       #e2e8f0;
    --woe-border-light: #f1f5f9;
    --woe-text:         #0f172a;
    --woe-text-muted:   #64748b;
    --woe-input-bg:     #ffffff;
    --woe-input-disabled:#f8fafc;
    --woe-accent:       var(--theme-accent, #2563eb);
    --woe-toast-ok-bg:  #d1fae5;
    --woe-toast-ok-tx:  #065f46;
    --woe-toast-er-bg:  #fee2e2;
    --woe-toast-er-tx:  #991b1b;
}
/* ── Tema değişkenleri (dark override) ── */
body.app-theme-dark .woe-page {
    --woe-bg:           #080c17;
    --woe-surface:      #0d1323;
    --woe-surface2:     #111827;
    --woe-border:       rgba(255,255,255,.09);
    --woe-border-light: rgba(255,255,255,.04);
    --woe-text:         #e2e8f0;
    --woe-text-muted:   #94a3b8;
    --woe-input-bg:     rgba(255,255,255,.06);
    --woe-input-disabled:rgba(255,255,255,.03);
    --woe-accent:       var(--theme-accent, #6366f1);
    --woe-toast-ok-bg:  rgba(34,197,94,.18);
    --woe-toast-ok-tx:  #4ade80;
    --woe-toast-er-bg:  rgba(239,68,68,.18);
    --woe-toast-er-tx:  #f87171;
}

.woe-page {
    padding: 16px 24px; height: 100%;
    display: flex; flex-direction: column; min-height: 0; gap: 12px;
    overflow: auto;
    background: var(--woe-bg); color: var(--woe-text);
}

.woe-toolbar {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--woe-border);
}
.woe-toolbar h1 { font-size: 18px; margin: 0; color: var(--woe-text); }
.woe-toolbar .spacer { flex: 1; }
.woe-back { color: var(--woe-text-muted); text-decoration: none; font-size: 13px; }
.woe-back:hover { color: var(--woe-text); }

.woe-btn {
    padding: 7px 14px; border-radius: 7px;
    border: 1px solid var(--woe-border);
    background: var(--woe-surface); color: var(--woe-text);
    cursor: pointer; font-size: 13px; font-weight: 500;
    transition: background .12s, border-color .12s;
}
.woe-btn:hover:not(:disabled) { background: var(--woe-surface2); border-color: var(--woe-accent); }
.woe-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.woe-btn--primary { background: linear-gradient(135deg, #6366f1, #4f46e5); color: #fff; border-color: #4f46e5; }
.woe-btn--primary:hover:not(:disabled) { filter: brightness(1.07); border-color: #4f46e5; }
.woe-btn--success { background: linear-gradient(135deg, #10b981, #059669); color: #fff; border-color: #059669; }
.woe-btn--success:hover:not(:disabled) { filter: brightness(1.07); border-color: #059669; }
.woe-btn--danger  { background: #fef2f2; color: #991b1b; border-color: #fecaca; }
.woe-btn--warn    { background: #fffbeb; color: #92400e; border-color: #fde68a; }
body.app-theme-dark .woe-btn--danger  { background: rgba(239,68,68,.12); color: #fca5a5; border-color: rgba(239,68,68,.32); }
body.app-theme-dark .woe-btn--danger:hover:not(:disabled)  { background: rgba(239,68,68,.20); border-color: rgba(239,68,68,.45); }
body.app-theme-dark .woe-btn--warn    { background: rgba(245,158,11,.12); color: #fcd34d; border-color: rgba(245,158,11,.32); }
body.app-theme-dark .woe-btn--warn:hover:not(:disabled)    { background: rgba(245,158,11,.20); border-color: rgba(245,158,11,.45); }

.woe-status { padding: 4px 12px; border-radius: 14px; font-size: 12px; font-weight: 700; }
.woe-status-0 { background: #e0e7ff; color: #4338ca; }
.woe-status-1 { background: #fef3c7; color: #92400e; }
.woe-status-2 { background: #ddd6fe; color: #6d28d9; }
.woe-status-3 { background: #d1fae5; color: #065f46; }
.woe-status-4 { background: #f3f4f6; color: #6b7280; }
.woe-status-5 { background: #fee2e2; color: #991b1b; }
body.app-theme-dark .woe-status-0 { background: rgba(99,102,241,.18); color: #a5b4fc; }
body.app-theme-dark .woe-status-1 { background: rgba(245,158,11,.18); color: #fcd34d; }
body.app-theme-dark .woe-status-2 { background: rgba(168,85,247,.18); color: #d8b4fe; }
body.app-theme-dark .woe-status-3 { background: rgba(34,197,94,.18); color: #86efac; }
body.app-theme-dark .woe-status-4 { background: rgba(148,163,184,.18); color: #cbd5e1; }
body.app-theme-dark .woe-status-5 { background: rgba(239,68,68,.18); color: #fca5a5; }

.woe-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; min-height: 0; }
@@media (max-width: 1024px) { .woe-grid { grid-template-columns: 1fr; } }

/* ── Sol-tab + sağ-pane yapısı ── */
.woe-tabbed {
    display: flex; min-height: 380px; gap: 0;
    background: var(--woe-surface);
    border: 1px solid var(--woe-border); border-radius: 10px;
    overflow: hidden;
}
.woe-nav {
    width: 220px; flex-shrink: 0;
    background: var(--woe-surface2);
    border-right: 1px solid var(--woe-border);
    padding: 10px 0; overflow-y: auto;
    display: flex; flex-direction: column;
}
.woe-nav-grouptitle {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px;
    color: var(--woe-text-muted);
    padding: 10px 14px 4px; margin: 0;
}
.woe-nav-btn {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 9px 14px;
    border: none; background: transparent;
    text-align: left; cursor: pointer;
    color: var(--woe-text); font-size: 13px; font-weight: 500;
    border-left: 3px solid transparent;
    transition: background .12s, color .12s;
}
.woe-nav-btn:hover { background: rgba(99,102,241,.08); }
.woe-nav-btn.is-active {
    border-left-color: var(--woe-accent);
    background: rgba(99,102,241,.14);
    font-weight: 600;
}
.woe-nav-icon {
    width: 14px; height: 14px; flex-shrink: 0; opacity: .7;
}
.woe-nav-btn.is-active .woe-nav-icon { opacity: 1; }
.woe-nav-count {
    margin-left: auto; padding: 1px 7px; border-radius: 999px;
    font-size: 10px; font-weight: 700; font-family: ui-monospace, monospace;
    background: rgba(99,102,241,.14); color: #4f46e5;
    border: 1px solid rgba(99,102,241,.28);
}
body.app-theme-dark .woe-nav-count { color: #a5b4fc; }

.woe-pane {
    flex: 1 1 auto; min-width: 0;
    padding: 18px 22px; overflow-y: auto;
}
.woe-pane-section { display: none; }
.woe-pane-section.is-active { display: block; }
.woe-pane h2 {
    margin: 0 0 4px; font-size: 15px; color: var(--woe-text); font-weight: 700;
}
.woe-pane .pane-hint {
    font-size: 12px; color: var(--woe-text-muted); margin-bottom: 14px;
}
.woe-placeholder {
    padding: 32px 16px; border: 1px dashed var(--woe-border); border-radius: 8px;
    text-align: center; color: var(--woe-text-muted); font-size: 13px;
}

/* ── Widget pane: grup başlığı sağ panelde gözükmesin (sol nav'da zaten var) ──
   DynamicWidgetRenderer her grup için <details> + <summary>{grupAdı}</summary>
   render ediyor. Summary'yi gizliyoruz, details'in card chrome'unu düzleştirip
   sadece widget alanları gözüksün. ÖNEMLİ: modern (floating) label widget'ın
   üst kenarına -8/-10px ile yapışıyor — kart padding-top:0 yapılırsa label
   üstten kesiliyor. Bu yüzden padding-top:12 + overflow:visible. */
#woeDynamicWidgets details > summary {
    display: none !important;
}
#woeDynamicWidgets details[data-dyn-group-id] {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 12px 4px 0 4px !important;
    margin: 0 0 12px 0 !important;
    border-radius: 0 !important;
    overflow: visible !important;
}
.woe-placeholder strong { color: var(--woe-text); display: block; margin-bottom: 6px; font-size: 14px; }

.woe-card {
    background: var(--woe-surface);
    border: 1px solid var(--woe-border);
    border-radius: 10px; padding: 16px;
}
.woe-card h3 {
    margin: 0 0 12px; font-size: 13px;
    text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--woe-text-muted);
}

.woe-row {
    display: grid; grid-template-columns: 140px 1fr;
    gap: 10px; align-items: center; margin-bottom: 10px;
}
.woe-row label { font-size: 12px; color: var(--woe-text-muted); font-weight: 500; }
/* Tıklanabilir başlık — Mamul Kodu *'a tıklayınca Malzeme Kartı'na navigate eder.
   Cursor + indigo hover + alttan kesik çizgi (link davranışını ima eder). */
.woe-row__label--link {
    cursor: pointer;
    transition: color .12s, text-decoration-color .12s;
    text-decoration: underline dotted transparent;
    text-underline-offset: 3px;
}
.woe-row__label--link:hover {
    color: var(--woe-accent);
    text-decoration-color: var(--woe-accent);
}
.woe-row input, .woe-row select, .woe-row textarea {
    padding: 7px 10px; border-radius: 6px;
    border: 1px solid var(--woe-border);
    background: var(--woe-input-bg); color: var(--woe-text);
    font-size: 13px; font-family: inherit;
    outline: none; transition: border-color .12s, box-shadow .12s;
}
.woe-row input::placeholder, .woe-row textarea::placeholder { color: var(--woe-text-muted); opacity: .65; }
.woe-row input:focus, .woe-row select:focus, .woe-row textarea:focus {
    border-color: var(--woe-accent);
    box-shadow: 0 0 0 2px rgba(99,102,241,.18);
}
.woe-row input[readonly], .woe-row input:disabled,
.woe-row select:disabled, .woe-row textarea[readonly] {
    background: var(--woe-input-disabled);
    color: var(--woe-text-muted);
}
body.app-theme-dark .woe-row select,
html.dark .woe-row select { color-scheme: dark; }
body.app-theme-dark .woe-row input[type="datetime-local"],
html.dark .woe-row input[type="datetime-local"] { color-scheme: dark; }
/* select > * = option/optgroup (Razor parser "option" kelimesini OptionTagHelper
   olarak yorumladığı için universal child selector kullanılıyor). */
.woe-row select > * {
    background: var(--woe-surface);
    color: var(--woe-text);
}
body.app-theme-dark .woe-row select > *,
html.dark .woe-row select > * {
    background-color: #0d1323;
    color: #e2e8f0;
}
.woe-row textarea { min-height: 60px; resize: vertical; }
/* 2026-05-22: split eski 140 1fr 60 100 idi (sag input dar kaliyordu); esit 1fr/1fr yapildi.
   split3: 3 sutun esit (plan baslangic | bitis | oncelik). */
.woe-row.split  { grid-template-columns: 130px 1fr 100px 1fr; }
.woe-row.split3 {
    grid-template-columns: 110px 1fr 90px 1fr 80px 1fr;
}
/* Inline fields (input + lookup + clear) artik dar input ile kalmasin, kolon icinde yayilsin */
.woe-row.split  .woe-inline-fields,
.woe-row.split3 .woe-inline-fields { width: 100%; }
.woe-row.split  .woe-inline-fields .woe-input--code,
.woe-row.split3 .woe-inline-fields .woe-input--code { max-width: none; flex: 1 1 auto; min-width: 0; }
/* 2026-05-22 Standart rehber pattern A — Code input yaninda Name "side-label".
   Code dar (sabit), Name geni s alir (ellipsis ile kesilir). Kullanici Code'u gorur + Name'i
   referans olarak yaninda okur. Pick sonrasi JS span'i guncel ler. */
.wo-guide-name {
    flex: 1 1 auto; min-width: 0;
    color: var(--woe-text-muted); font-size: 12px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    padding: 4px 6px;
}
.wo-guide-name:empty::before { content: '—'; color: var(--woe-border); }
/* Code input bu pattern'de daha dar — yanindaki Name'e yer birak */
.woe-row .woe-inline-fields .wo-guide-input { max-width: 200px; flex: 0 0 200px; }

.woe-source-list { font-size: 13px; }
.woe-source-list .src-item {
    padding: 8px 0;
    border-bottom: 1px dashed var(--woe-border);
    display: flex; justify-content: space-between;
    color: var(--woe-text);
}
.woe-source-list .src-item:last-child { border-bottom: none; }
.woe-source-list .src-item a { color: var(--woe-accent); text-decoration: none; }
.woe-source-list .src-item a:hover { text-decoration: underline; }
.woe-source-list .src-empty { color: var(--woe-text-muted); padding: 12px 0; text-align: center; font-size: 12px; }

.woe-meta {
    font-size: 12px; color: var(--woe-text-muted);
    display: flex; gap: 16px; flex-wrap: wrap;
    padding-top: 8px; border-top: 1px dashed var(--woe-border); margin-top: 8px;
}
.woe-meta a { color: var(--woe-accent); text-decoration: none; }
.woe-meta a:hover { text-decoration: underline; }

/* ── Inline fields (kod + okur etiket / qty + birim) ── */
.woe-inline-fields {
    display: flex; align-items: center; gap: 8px;
    min-width: 0;
}
.woe-input--code { max-width: 240px; flex: 0 0 240px; }
.woe-input--qty  {
    max-width: 130px; flex: 0 0 130px;
    text-align: right;
    /* Number input spinner (yukarı/aşağı oklar) — Firefox + Webkit tarafından gizle */
    -moz-appearance: textfield;
    appearance: textfield;
}
.woe-input--qty::-webkit-outer-spin-button,
.woe-input--qty::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}
.woe-readonly-text {
    font-size: 13px; font-weight: 500;
    color: var(--woe-text);
    padding: 7px 10px;
    background: var(--woe-input-disabled);
    border: 1px solid var(--woe-border-light);
    border-radius: 6px;
    flex: 1 1 auto; min-width: 0;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.woe-readonly-text:empty::before {
    content: '—';
    opacity: .4;
}
/* Birim dropdown — readonly text alanıyla benzer görünüm, ama tıklanabilir.
   Stok kartındaki "miktar + birim" deseninin üretim emrindeki karşılığı. */
.woe-unit-select {
    flex: 0 0 auto; min-width: 110px;
    padding: 7px 10px; border-radius: 6px;
    border: 1px solid var(--woe-border);
    background: var(--woe-input-bg); color: var(--woe-text);
    font-size: 13px; font-weight: 500;
    outline: none; cursor: pointer;
    transition: border-color .12s, box-shadow .12s;
}
.woe-unit-select:hover:not(:disabled) { border-color: var(--woe-accent); }
.woe-unit-select:focus { border-color: var(--woe-accent); box-shadow: 0 0 0 2px rgba(99,102,241,.18); }
.woe-unit-select:disabled { opacity: .65; cursor: not-allowed; }
body.app-theme-dark .woe-unit-select,
html.dark .woe-unit-select { color-scheme: dark; }
.woe-unit-select > * { background: var(--woe-surface); color: var(--woe-text); }
body.app-theme-dark .woe-unit-select > *,
html.dark .woe-unit-select > * { background-color: #0d1323; color: #e2e8f0; }

/* ── Toast (sag alt) — auto-dismiss + manuel close ── */
#woe-toast-host {
    position: fixed; bottom: 24px; right: 24px; z-index: 9999;
    display: flex; flex-direction: column-reverse; gap: 10px;
    pointer-events: none;        /* host clickleri yutmaz; sadece toast'lar interaktif */
    max-width: 380px;
}
.woe-toast {
    pointer-events: auto;
    display: flex; align-items: flex-start; gap: 10px;
    min-width: 240px; max-width: 380px;
    padding: 11px 14px; border-radius: 10px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.32);
    font-size: 13px; line-height: 1.4;
    animation: woe-toast-slide .22s ease-out;
    position: relative;
}
.woe-toast--ok  { background: var(--woe-toast-ok-bg); color: var(--woe-toast-ok-tx); border: 1px solid rgba(16,185,129,.32); }
.woe-toast--err { background: var(--woe-toast-er-bg); color: var(--woe-toast-er-tx); border: 1px solid rgba(239,68,68,.32); }
.woe-toast.is-leaving { animation: woe-toast-fade .25s ease-in forwards; }
.woe-toast-msg  { flex: 1 1 auto; min-width: 0; word-break: break-word; }
.woe-toast-close {
    flex-shrink: 0;
    background: transparent; border: none; cursor: pointer;
    color: inherit; opacity: .7;
    width: 22px; height: 22px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 4px;
    font-size: 16px; line-height: 1; padding: 0;
}
.woe-toast-close:hover { opacity: 1; background: rgba(0,0,0,.08); }
@@keyframes woe-toast-slide {
    from { transform: translateY(12px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
}
@@keyframes woe-toast-fade {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(8px); }
}

/* ── Ek Alanlar (DynamicWidgetRenderer) — Material Card ile ayni pattern ── */
#woeDynamicWidgetsCard {
    background: var(--woe-surface);
    border: 1px solid var(--woe-border);
    border-radius: 12px;
    padding: 14px 16px;
    margin-top: 12px;
}
#woeDynamicWidgetsCard h3 {
    margin: 0 0 12px; font-size: 14px; font-weight: 600;
    color: var(--woe-text);
    padding-bottom: 8px;
    border-bottom: 1px solid var(--woe-border-light);
}
#woeDynamicWidgets { width: 100%; }

/* ── Layout wrapper resetleri (diger admin sayfalariyla ayni pattern) ── */
.page-work-order-edit .integrator-dashboard {
    height: 100% !important; min-height: 0 !important;
    padding: 0 !important; max-width: none !important;
    background: transparent !important; box-shadow: none !important;
    border: none !important; border-radius: 0 !important;
}
.page-work-order-edit .integrator-dashboard__content {
    display: flex !important; flex-direction: column !important;
    width: 100% !important; max-width: none !important;
    min-height: 0 !important; padding: 0 !important;
    margin: 0 !important; overflow: hidden !important;
    height: 100% !important;
}

/* ── Rota / Operasyonlar tab (Faz 3a-5) ────────────────────────────── */
.woe-rota-table {
    display: flex; flex-direction: column; gap: 1px;
    background: var(--woe-border-light);
    border: 1px solid var(--woe-border);
    border-radius: 6px; overflow: hidden;
    margin-top: 8px;
}
.woe-rota-row {
    display: grid;
    /* 2026-05-22: + drag handle (24px) ilk kolon */
    grid-template-columns: 24px 60px 1.6fr 1.4fr 110px 130px 110px 56px;
    gap: 8px; padding: 8px 12px; align-items: center;
    background: var(--woe-surface);
    font-size: 13px;
}
/* Drag durumu — surulen satir yariseffaf */
.woe-rota-row.is-dragging { opacity: 0.4; }
.woe-rota-row.is-drop-target { box-shadow: inset 0 2px 0 0 #6366f1; }
/* Drag handle — sadece düzenlenebilir + bekliyor satirlarda gosterilir */
.woe-rota-drag {
    cursor: grab; color: var(--woe-text-muted); font-size: 14px;
    user-select: none; text-align: center; line-height: 1;
    opacity: 0.4; transition: opacity .12s, color .12s;
}
.woe-rota-drag:hover { opacity: 1; color: var(--woe-text); }
.woe-rota-drag:active { cursor: grabbing; }
.woe-rota-row.woe-rota-head {
    background: var(--woe-surface2);
    font-weight: 600; font-size: 12px; color: var(--woe-text-muted);
    text-transform: uppercase; letter-spacing: 0.4px;
}
.woe-rota-row input,
.woe-rota-row select {
    width: 100%; box-sizing: border-box;
    padding: 4px 6px; font-size: 13px;
    background: var(--woe-input-bg, var(--woe-surface));
    border: 1px solid var(--woe-border);
    border-radius: 4px; color: var(--woe-text);
}
.woe-rota-row input:read-only,
.woe-rota-row input[readonly] { opacity: 0.7; cursor: default; }
.woe-rota-status {
    display: inline-block; padding: 2px 8px; border-radius: 10px;
    font-size: 11px; font-weight: 600; text-align: center;
}
.woe-rota-status-0 { background: rgba(148,163,184,.16); color: #94a3b8; }
.woe-rota-status-1 { background: rgba(59,130,246,.18); color: #60a5fa; }
.woe-rota-status-2 { background: rgba(34,197,94,.18); color: #4ade80; }
.woe-rota-status-3 { background: rgba(239,68,68,.18); color: #f87171; }
.woe-rota-row .rota-del {
    background: transparent;
    border: 1px solid rgba(239,68,68,.3);
    color: #f87171;
    cursor: pointer; font-size: 14px;
    padding: 2px 8px;
    border-radius: 4px;
    line-height: 1;
    transition: background .12s, border-color .12s;
}
.woe-rota-row .rota-del:hover {
    background: rgba(239,68,68,.18);
    border-color: rgba(239,68,68,.6);
    color: #fca5a5;
}
.woe-rota-empty { padding: 14px; text-align: center; }

/* ── Inline edit satırı (yeni operasyon ekleme) ──────────────────────── */
.woe-rota-row--edit {
    background: rgba(99,102,241,.05);
    border: 1px dashed rgba(99,102,241,.35);
    border-radius: 7px;
    margin-bottom: 2px;
}
.woe-edit-inp {
    width: 100%; box-sizing: border-box;
    padding: 5px 7px; border-radius: 5px;
    border: 1px solid var(--woe-border);
    background: var(--woe-input-bg); color: var(--woe-text);
    font-size: 12.5px;
}
.woe-edit-inp:focus { outline: none; border-color: var(--woe-accent); }
.woe-edit-pick {
    display: flex; align-items: center; gap: 6px;
    min-width: 0;
}
.woe-edit-pick-btn {
    flex: 0 0 auto;
    width: 26px; height: 26px;
    border: 1px solid var(--woe-border);
    background: var(--woe-input-bg); color: var(--woe-text-muted);
    border-radius: 5px; cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background .12s, border-color .12s, color .12s;
}
.woe-edit-pick-btn:hover { background: rgba(99,102,241,.1); border-color: var(--woe-accent); color: var(--woe-accent); }
.woe-edit-pick-btn.is-invalid { border-color: #ef4444; background: rgba(239,68,68,.08); animation: rotaShake .3s; }
.woe-edit-pick-name {
    font-size: 12.5px; color: var(--woe-text);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    flex: 1; min-width: 0;
}
.woe-edit-pick-name--empty { color: var(--woe-text-muted); font-style: italic; }
.rota-save-btn {
    background: transparent;
    border: 1px solid rgba(34,197,94,.4);
    border-radius: 5px; padding: 2px 7px;
    color: #4ade80; font-size: 14px; font-weight: 700;
    cursor: pointer; line-height: 1;
    transition: background .12s, border-color .12s;
}
.rota-save-btn:hover { background: rgba(34,197,94,.15); border-color: #4ade80; }
.rota-save-btn:disabled { opacity: .5; cursor: default; }
@@keyframes rotaShake {
    0%,100% { transform: translateX(0); }
    25%      { transform: translateX(-4px); }
    75%      { transform: translateX(4px); }
}

.wo-mach-btn {
    background: var(--woe-input-disabled);
    border: 1px dashed var(--woe-border);
    color: var(--woe-text); font-size: 12px;
    padding: 4px 9px; border-radius: 5px;
    cursor: pointer; text-align: left;
    transition: background .12s, border-color .12s, color .12s;
}
.wo-mach-btn:hover {
    background: rgba(99,102,241,.08);
    border-color: var(--woe-accent);
    border-style: solid;
    color: var(--woe-accent);
}

/* ── Rehber pick butonlari (Sorumlu / Lokasyon / Rota) ─────────────── */
.woe-pick-btn {
    flex: 0 0 auto;
    width: 32px; height: 32px;
    border: 1px solid var(--woe-border);
    background: var(--woe-input-bg); color: var(--woe-text-muted);
    border-radius: 6px; cursor: pointer;
    font-size: 14px; line-height: 1;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background .12s, color .12s, border-color .12s;
}
.woe-pick-btn:hover:not(:disabled) {
    background: rgba(99,102,241,.1); border-color: var(--woe-accent);
    color: var(--woe-accent);
}
.woe-pick-btn:disabled { opacity: .5; cursor: not-allowed; }
.woe-pick-btn--clear:hover:not(:disabled) {
    background: rgba(239,68,68,.1); border-color: #ef4444; color: #ef4444;
}
input[id$="Display"][readonly] { cursor: default; opacity: .92; }

/* ── Generic picker modal ─────────────────────────────────────────── */
/* CSS degiskenleri .woe-page'de tanimli; modal document.body'ye mount edilince
   parent context'i bulamayip light defaultlara dusuyordu. Backdrop'a kendi
   tema-aware fallbacklarini koyuyoruz (light + dark) — boylece modal nereye
   mount edilirse edilsin tema sayfa ile tutarli kalir. */
.wpicker-backdrop {
    /* Light theme defaultlari (.woe-page ile birebir) */
    --woe-bg:           #f8fafc;
    --woe-surface:      #ffffff;
    --woe-surface2:     #f1f5f9;
    --woe-border:       #e2e8f0;
    --woe-border-light: #f1f5f9;
    --woe-text:         #0f172a;
    --woe-text-muted:   #64748b;
    --woe-input-bg:     #ffffff;
    --woe-accent:       var(--theme-accent, #2563eb);

    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.55); backdrop-filter: blur(3px);
    display: flex; align-items: center; justify-content: center;
}
/* Dark theme override — body.app-theme-dark sayfa ile ayni anda gecer. */
body.app-theme-dark .wpicker-backdrop {
    --woe-bg:           #080c17;
    --woe-surface:      #0d1323;
    --woe-surface2:     #111827;
    --woe-border:       rgba(255,255,255,.09);
    --woe-border-light: rgba(255,255,255,.04);
    --woe-text:         #e2e8f0;
    --woe-text-muted:   #94a3b8;
    --woe-input-bg:     rgba(255,255,255,.06);
    --woe-accent:       var(--theme-accent, #6366f1);
}
.wpicker {
    width: min(640px, 92vw);
    max-height: 78vh;
    background: var(--woe-surface); color: var(--woe-text);
    border: 1px solid var(--woe-border); border-radius: 12px;
    display: flex; flex-direction: column; overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,.4);
}
.wpicker__head {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--woe-border);
}
.wpicker__title {
    font-size: 14px; font-weight: 600; color: var(--woe-text);
    flex: 0 0 auto;
}
.wpicker__search {
    flex: 1 1 auto; min-width: 0;
    padding: 7px 10px; border-radius: 6px;
    border: 1px solid var(--woe-border);
    background: var(--woe-input-bg); color: var(--woe-text);
    outline: none; font-size: 13px;
}
.wpicker__search:focus { border-color: var(--woe-accent); }
.wpicker__close {
    flex: 0 0 auto; width: 28px; height: 28px;
    background: none; border: none; color: var(--woe-text-muted);
    cursor: pointer; border-radius: 6px;
    font-size: 18px; display: inline-flex; align-items: center; justify-content: center;
}
.wpicker__close:hover { background: rgba(255,255,255,.06); color: var(--woe-text); }
.wpicker__list {
    flex: 1 1 auto; overflow-y: auto; min-height: 0;
}
.wpicker__row {
    display: grid; grid-template-columns: 130px 1fr auto;
    align-items: center; gap: 10px;
    padding: 9px 14px; cursor: pointer;
    border-bottom: 1px solid var(--woe-border-light);
    transition: background .1s;
}
.wpicker__row:hover { background: rgba(99,102,241,.08); }
.wpicker__code {
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 12px; font-weight: 600; color: var(--woe-accent);
    letter-spacing: .03em;
}
.wpicker__name {
    font-size: 13px; color: var(--woe-text);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.wpicker__meta {
    font-size: 11px; color: var(--woe-text-muted);
    flex: 0 0 auto;
}
.wpicker__badge {
    display: inline-block; padding: 1px 7px; border-radius: 8px;
    font-size: 10px; font-weight: 600;
    background: rgba(245,158,11,.18); color: #f59e0b;
    margin-left: 6px;
}
.wpicker__empty, .wpicker__loading {
    padding: 24px; text-align: center; color: var(--woe-text-muted);
    font-size: 13px;
}

/* ── BOM (Reçete) tablosu — Faz 2 ──────────────────────────────── */
.woe-bom-table {
    background: var(--woe-input-disabled);
    border: 1px solid var(--woe-border-light);
    border-radius: 8px; overflow: hidden;
    margin-top: 10px;
}
.woe-bom-row {
    display: grid;
    grid-template-columns: 2fr 1fr 110px 110px 80px 80px 1fr;
    align-items: center; gap: 10px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--woe-border-light);
    font-size: 13px;
}
.woe-bom-row:last-child { border-bottom: none; }
.woe-bom-row.woe-bom-head {
    background: rgba(99,102,241,.06);
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: .04em; color: var(--woe-text-muted);
}
.woe-bom-empty { padding: 18px 14px; text-align: center; line-height: 1.6; }
.woe-bom-design-note {
    margin-top: 14px; padding: 12px 14px;
    background: rgba(99,102,241,.06);
    border: 1px dashed rgba(99,102,241,.35);
    border-radius: 8px;
    font-size: 12.5px; color: var(--woe-text-muted); line-height: 1.55;
}
.woe-bom-design-note code {
    background: rgba(99,102,241,.12); color: var(--woe-accent);
    padding: 1px 6px; border-radius: 4px;
    font-size: 11.5px;
}

/* ── Toolbar inline switch ("Üretime Planla") ─────────────────────── */
.woe-switch-inline {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 12px; border-radius: 8px;
    background: rgba(34,197,94,.08);
    border: 1px solid rgba(34,197,94,.25);
    cursor: pointer; user-select: none;
    transition: background .12s, border-color .12s;
}
.woe-switch-inline:hover { background: rgba(34,197,94,.14); border-color: rgba(34,197,94,.4); }
.woe-switch-inline input[type="checkbox"] {
    position: absolute; opacity: 0; width: 0; height: 0;
}
.woe-switch-inline .woe-switch-track {
    position: relative; display: inline-block;
    width: 32px; height: 18px;
    background: rgba(15,23,42,.25);
    border-radius: 999px;
    transition: background .18s;
    flex-shrink: 0;
}
.woe-switch-inline .woe-switch-track::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 14px; height: 14px; border-radius: 50%;
    background: #fff;
    transition: left .18s, background .18s;
    box-shadow: 0 1px 3px rgba(0,0,0,.3);
}
.woe-switch-inline input:checked ~ .woe-switch-track { background: #16a34a; }
.woe-switch-inline input:checked ~ .woe-switch-track::after { left: 16px; }
.woe-switch-inline .woe-switch-text {
    font-size: 12.5px; font-weight: 600;
    color: #16a34a;
    white-space: nowrap;
}
body.app-theme-dark .woe-switch-inline .woe-switch-text { color: #4ade80; }
.woe-switch-inline input:not(:checked) ~ .woe-switch-text { color: var(--woe-text-muted); opacity: .7; }
</style>
}

@{
    var _colId = !isNew ? Model!.Id.ToString() : $"new-{Guid.NewGuid():N}";
    var _colTitle = isNew ? "Yeni İş Emri" : $"İş Emri: {Model!.OrderNumber}";
}
<form class="integrator-form" style="display:none" aria-hidden="true"
      data-collaboration-record-type="WORK_ORDER_EDIT"
      data-collaboration-record-id="@_colId"
      data-collaboration-record-title="@_colTitle"></form>

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">
<div class="woe-page">
    <div class="woe-toolbar">
        <a class="woe-back" href="@Url.Action("WorkOrders")" title="Listeye dön">←</a>
        <a class="woe-btn" href="@Url.Action("WorkOrderEdit")" id="btn-new" title="Yeni iş emri">+ Yeni</a>
        <button class="woe-btn woe-btn--primary" id="btn-save" @(isNew || canEditPlan ? "" : "disabled")>Kaydet</button>
        @* "Üretime Planla" switch — sadece YENİ iş emrinde göster. Default ON; kapatırsa
           WO Taslak (Planned) statüsünde kaydedilir, sonradan toolbar'daki "Yayımla" ile
           üretime açılabilir. ON ise Save sırasında autoRelease=true gönderilir,
           backend operasyonları otomatik patlatır + Released (Yayımlandı) statüsüne yazar. *@
        @if (isNew)
        {
            <label class="woe-switch-inline" title="Açıkken: kaydet sonrası iş emri Yayımlandı statüsüne geçer ve üretim sahasına açılır. Kapatırsan: Taslak kalır, sonra Yayımla butonuyla açarsın.">
                <input type="checkbox" id="f-autoRelease" checked />
                <span class="woe-switch-track"></span>
                <span class="woe-switch-text">Üretime Planla</span>
            </label>
        }
        @if (!isNew)
        {
            @* Yayımla / Kapat / İptal butonları toolbar'dan kaldırıldı:
                 - Yayımla: artık YENİ iş emrinde "Üretime Planla" switch'i ile yapılır
                 - Kapat / İptal: nadir kullanım — gerekirse ayrı bir "Yönetim" menüsünden açılır
               Revize: hâlâ yöneticilik aksiyonu olarak kalir. *@
            <button class="woe-btn woe-btn--warn" id="btn-revise" @(canRevise ? "" : "disabled")>Revize</button>
        }
        <span class="spacer"></span>
        <h1>@(isNew ? "Yeni İş Emri" : Model!.OrderNumber)@(Model is { RevisionNo: > 0 } ? $" • Rev {Model.RevisionNo}" : "")</h1>
        @if (!isNew)
        {
            <span class="woe-status woe-status-@((byte)status)">@StatusLabel(status)</span>
        }
    </div>

    <div class="woe-tabbed">
        <nav class="woe-nav">
            <div class="woe-nav-grouptitle">İş Emri</div>
            <button type="button" class="woe-nav-btn is-active" data-tab="genel">
                <svg class="woe-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <span>Genel Bilgiler</span>
            </button>
            <button type="button" class="woe-nav-btn" data-tab="makine">
                <svg class="woe-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span>Makine</span>
            </button>
            <button type="button" class="woe-nav-btn" data-tab="rota">
                <svg class="woe-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                <span>Rota / Operasyonlar</span>
            </button>
            <button type="button" class="woe-nav-btn" data-tab="recete">
                <svg class="woe-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20v-6h4v6a2 2 0 002 2h3a2 2 0 002-2v-3a2 2 0 00-2-2h-3v-4h3a2 2 0 002-2V6a2 2 0 00-2-2h-3a2 2 0 00-2 2v3a2 2 0 002 2h1v4h-3a2 2 0 01-2-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v3a2 2 0 002 2h3a2 2 0 002-2v-3"/></svg>
                <span>Reçete</span>
            </button>
            <button type="button" class="woe-nav-btn" data-tab="kaynak">
                <svg class="woe-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2a4 4 0 00-4-4H3m18 6v-2a4 4 0 00-4-4h-2m-4-4a4 4 0 100-8 4 4 0 000 8zm-2 4a4 4 0 100-8 4 4 0 000 8z"/></svg>
                <span>Kaynak Sipariş</span>
                @if (!isNew && Model!.Sources.Count > 0)
                {
                    <span class="woe-nav-count">@Model.Sources.Count</span>
                }
            </button>
            @if (!isNew && (Model!.RevisionNo > 0 || Model.RevisedFromId.HasValue))
            {
                <button type="button" class="woe-nav-btn" data-tab="revize">
                    <svg class="woe-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    <span>Revizyon</span>
                </button>
            }

            <div class="woe-nav-grouptitle">Ek Sahalar</div>
            <button type="button" class="woe-nav-btn" data-tab="widgets">
                <svg class="woe-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm0 10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10-10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zm0 10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                <span>Widget Sahaları</span>
            </button>
        </nav>

        <div class="woe-pane">
            <!-- Tab: Genel Bilgiler -->
            <section class="woe-pane-section is-active" data-pane="genel">
                <h2>Genel Bilgiler</h2>
                <div class="pane-hint">İş emri kimlik, plan, mamul ve sorumlu bilgileri.</div>

                @* 2026-05-22: Numara + İş Emri Tarihi alanları Mamul Kodu input genişliği ile
                   uyumlu (max-width:240px → woe-input--code ile aynı). Numara'ya WORK_ORDER
                   rehberi baglandi — kullanici mevcut bir is emrini secip hizli navigate yapabilir.
                   Tarih artik saat olmadan (dd.MM.yyyy). *@
                <div class="woe-row">
                    <label>Numara</label>
                    <div class="woe-inline-fields">
                        <input type="text" id="f-orderNumber" class="woe-input--code wo-orderno-input"
                               data-guide-code="WORKORDERS"
                               value="@(Model?.OrderNumber ?? "(otomatik)")"
                               placeholder="Yeni iş emri için otomatik" autocomplete="off"
                               readonly />
                    </div>
                </div>
                <div class="woe-row">
                    <label>İş Emri Tarihi</label>
                    <div class="woe-inline-fields">
                        <input type="text" id="f-orderDate" class="woe-input--code"
                               value="@(Model?.OrderDate.ToLocalTime().ToString("dd.MM.yyyy") ?? DateTime.Now.ToString("dd.MM.yyyy"))"
                               readonly />
                    </div>
                </div>

                @* Mamul Kodu — Tip 1 (Mamul) standart rehberi (ITEMS_FINISHED guide).
                   Mamul Adi okunur etiket olarak gosterilir; rehberden secince ya da
                   kod yazip Tab/blur sonrasi resolveItem() doldurur.
                   "Mamul Kodu *" başlığına tek tıklayınca seçilmiş mamulün
                   Malzeme Kartı edit ekranına navigate olur (link davranışı). *@
                <div class="woe-row">
                    <label id="lbl-itemCode" class="woe-row__label--link" title="Mamulün malzeme kartını aç">Mamul Kodu *</label>
                    <div class="woe-inline-fields">
                        <input type="text" id="f-itemCode" class="woe-input--code" value="@Model?.ItemCode" placeholder="Mamul kodu seçiniz..." @(canEditPlan || isNew ? "" : "readonly") />
                        <input type="hidden" id="f-itemId" value="@Model?.ItemId" />
                        <span class="woe-readonly-text" id="f-itemName">@Model?.ItemName</span>
                    </div>
                </div>

                <div class="woe-row" id="f-configWrapper" style="display:none;">
                    <label>Konfigürasyon Kodu *</label>
                    <div class="woe-inline-fields">
                        @* 🔍 / × butonları kod input'unun hemen yanında — Mamul Kodu satırı
                           ile aynı dizilim (kullanıcı talebi 2026-05-20). Açıklama sağa kayar. *@
                        <input type="text" id="f-configCode" class="woe-input--code" placeholder="Kombinasyon kodu..." @(canEditPlan || isNew ? "" : "readonly") />
                        <button type="button" class="woe-pick-btn" data-pick="config"
                                @(canEditPlan || isNew ? "" : "disabled")
                                title="Kombinasyon rehberinden seç">🔍</button>
                        @if (canEditPlan || isNew)
                        {
                            <button type="button" class="woe-pick-btn woe-pick-btn--clear"
                                    data-clear="config" title="Temizle">×</button>
                        }
                        <input type="hidden" id="f-configId" value="@Model?.ConfigId" />
                        <input type="text" id="f-configDesc" class="woe-readonly-text" readonly placeholder="Konfigürasyon açıklaması" />
                    </div>
                </div>

                <div class="woe-row">
                    <label>Planlanan Miktar *</label>
                    <div class="woe-inline-fields">
                        @* 2026-05-22: Yeni IE default planlanan miktar 1 (Model null veya 0 ise).
                           Edit modunda mevcut deger korunur. *@
                        <input type="number" step="0.0001" id="f-plannedQty" class="woe-input--qty"
                               value="@((Model?.PlannedQuantity ?? 0m) > 0m
                                       ? Model!.PlannedQuantity.ToString(System.Globalization.CultureInfo.InvariantCulture)
                                       : "1")"
                               min="0" @(canEditPlan || isNew ? "" : "readonly") />
                        @* Birim: stok kartındaki default + tüm tanımlı birimler arasında seçim.
                           Dropdown sayfa yüklenirken /Logistics/GetAllMeasureUnits ile doldurulur. *@
                        <select id="f-unitId" class="woe-unit-select"
                                data-preselect="@(Model?.UnitId?.ToString() ?? "")"
                                @(canEditPlan || isNew ? "" : "disabled")
                                title="Ölçü birimi">
                            <option value="">— Birim —</option>
                            @if (Model?.UnitId.HasValue == true)
                            {
                                <option value="@Model.UnitId" selected>@(Model.UnitCode ?? $"#{Model.UnitId}")</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="woe-row" style="align-items: start;">
                    <label>Notlar</label>
                    <textarea id="f-notes" @(canEditPlan || isNew ? "" : "readonly")>@Model?.Notes</textarea>
                </div>

                @if (!isNew)
                {
                    <div class="woe-meta">
                        <span>Üretilen: <strong>@Model!.ProducedQuantity.ToString("N2")</strong></span>
                        <span>Fire: <strong>@Model.ScrapQuantity.ToString("N2")</strong></span>
                        @if (Model.ActualStartDate.HasValue)
                        {
                            <span>Gerçek Başlangıç: @Model.ActualStartDate.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        }
                        @if (Model.ActualEndDate.HasValue)
                        {
                            <span>Gerçek Bitiş: @Model.ActualEndDate.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        }
                    </div>
                }
            </section>

            <!-- Tab: Makine / Planlama -->
            <section class="woe-pane-section" data-pane="makine">
                <h2>Planlama &amp; Makine</h2>
                <div class="pane-hint">Üretim takvimi, sorumlu, öncelik, üretim konumu ve default makine. Default Makine, operasyon patlatmasında satır makinesizse fallback olur — operasyon satırında ayrıca override edilebilir.</div>

                @* 2026-05-22: Single-column stack — Oncelik / Plan Baslangic / Plan Bitis /
                   Sorumlu / Makine / Rota / Konum sirayla alt alta. Inputlar form genisliginin
                   bir kismini kaplar (max-width ile asiri uzamaz). Tip 1 rehber: 4 rehber alani
                   (Personel/Makine/Konum/Rota) wo-guide-input class'iyla mountLookupForInput'a
                   baglanir. *@
                <div class="woe-row">
                    <label>Öncelik</label>
                    <select id="f-priority" style="max-width:220px;" @(canEditPlan || isNew ? "" : "disabled")>
                        @foreach (var p in Enum.GetValues<WorkOrderPriority>())
                        {
                            var sel = (Model?.Priority ?? WorkOrderPriority.Medium) == p;
                            if (sel) { <option value="@((byte)p)" selected>@PriorityLabel(p)</option> }
                            else     { <option value="@((byte)p)">@PriorityLabel(p)</option> }
                        }
                    </select>
                </div>

                <div class="woe-row">
                    <label>Plan Başlangıç</label>
                    <input type="datetime-local" id="f-plannedStart" style="max-width:220px;"
                           value="@Iso(Model?.PlannedStartDate)" @(canEditPlan || isNew ? "" : "readonly") />
                </div>

                <div class="woe-row">
                    <label>Plan Bitiş</label>
                    <input type="datetime-local" id="f-plannedEnd" style="max-width:220px;"
                           value="@Iso(Model?.PlannedEndDate)" @(canEditPlan || isNew ? "" : "readonly") />
                </div>

                @* 2026-05-22: Standart rehber pattern (A) — ValueColumn (Code) input'a yazilir,
                   DisplayColumn (Name) input yaninda etiket olarak gosterilir. Hidden ID alani
                   FK olarak DB'ye yazilir. Pick sonrasi label JS tarafindan (FixedFieldLookupBridge
                   record event'i) guncellenir. *@
                <div class="woe-row">
                    <label>Sorumlu Personel</label>
                    <div class="woe-inline-fields" style="max-width:600px;">
                        <input type="hidden" id="f-assignedPersonnelId" value="@Model?.AssignedPersonnelId" />
                        <input type="text" id="f-personnelDisplay" class="woe-input--code wo-guide-input"
                               data-guide-code="PERSONNEL" data-guide-id-target="f-assignedPersonnelId"
                               data-guide-name-target="f-personnelName"
                               value="@(Model?.AssignedPersonnelCode ?? "")"
                               placeholder="Personel kodu..." autocomplete="off"
                               @(canEditPlan || isNew ? "" : "readonly") />
                        <span id="f-personnelName" class="wo-guide-name">@(Model?.AssignedPersonnelName ?? Model?.AssignedUserName)</span>
                    </div>
                </div>

                <div class="woe-row">
                    <label>Makine</label>
                    <div class="woe-inline-fields" style="max-width:600px;">
                        <input type="hidden" id="f-defaultMachineId" value="@Model?.DefaultMachineId" />
                        <input type="text" id="f-defaultMachineDisplay" class="woe-input--code wo-guide-input"
                               data-guide-code="MACHINES" data-guide-id-target="f-defaultMachineId"
                               data-guide-name-target="f-defaultMachineName"
                               value="@(Model?.DefaultMachineCode ?? "")"
                               placeholder="Makine kodu..." autocomplete="off"
                               @(canEditPlan || isNew ? "" : "readonly") />
                        <span id="f-defaultMachineName" class="wo-guide-name">@Model?.DefaultMachineName</span>
                    </div>
                </div>

                <div class="woe-row">
                    <label>Rota</label>
                    <div class="woe-inline-fields" style="max-width:600px;">
                        <input type="hidden" id="f-routingId" value="@Model?.RoutingId" />
                        <input type="text" id="f-routingCode" class="woe-input--code wo-guide-input"
                               data-guide-code="ROUTING" data-guide-id-target="f-routingId"
                               data-guide-name-target="f-routingName"
                               value="@(Model?.RoutingCode ?? "")"
                               placeholder="Boş = Mamul'e göre otomatik" autocomplete="off"
                               @(canEditPlan || isNew ? "" : "readonly") />
                        <span id="f-routingName" class="wo-guide-name">@Model?.RoutingName</span>
                    </div>
                </div>

                <div class="woe-row">
                    <label>Üretim Konumu</label>
                    <div class="woe-inline-fields" style="max-width:600px;">
                        <input type="hidden" id="f-locationId" value="@Model?.WarehouseLocationId" />
                        <input type="text" id="f-locationDisplay" class="woe-input--code wo-guide-input"
                               data-guide-code="LOCATIONS" data-guide-id-target="f-locationId"
                               data-guide-name-target="f-locationName"
                               value="@(Model?.WarehouseLocationCode ?? "")"
                               placeholder="Lokasyon kodu..." autocomplete="off"
                               @(canEditPlan || isNew ? "" : "readonly") />
                        <span id="f-locationName" class="wo-guide-name">@Model?.WarehouseLocationName</span>
                    </div>
                </div>

                <div class="woe-row">
                    <label>AR-GE/ÜR-GE Projesi</label>
                    <div class="woe-inline-fields" style="max-width:600px;">
                        <select id="f-argeProject" class="woe-unit-select" style="max-width:440px;"
                                data-current="@Model?.ArgeProjectId" @(canEditPlan || isNew ? "" : "disabled")>
                            <option value="">— Proje yok (AR-GE mamulüyse otomatik bağlanır) —</option>
                        </select>
                    </div>
                </div>
            </section>

            @* ── Tab: Rota / Operasyonlar (Faz 3a-5) ─────────────────────
               WorkOrderOperation listesi: sequence sıralı, satır içi düzenlenebilir.
               Released öncesi serbest düzenleme; Released+ aşamalarında salt-okur
               (Faz 3b'de shop-floor tablet aksiyonları üretilen miktarı ilerletecek).
               Patlat butonu: Routing'i seçilmiş emirde RoutingOperation'ı temizleyip
               yeniden kopyalar (idempotent re-explode). *@
            <section class="woe-pane-section" data-pane="rota">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:6px;">
                    <h2 style="margin:0; flex:1;">Rota / Operasyonlar</h2>
                    @if (!isNew)
                    {
                        <button type="button" class="woe-btn" id="btn-rota-explode" title="Rota'daki operasyonları kopyala (mevcutları siler)">
                            ⚙ Rota'dan Patlat
                        </button>
                        @if (canEditPlan)
                        {
                            <button type="button" class="woe-btn woe-btn--primary" id="btn-rota-add">+ Operasyon Ekle</button>
                        }
                    }
                </div>
                <div class="pane-hint">
                    İş emrinin operasyon adımları. <strong>Released</strong> aşamasında rota'daki operasyonlar otomatik kopyalanır;
                    burada manuel ekleme/düzenleme de yapılabilir. Shop-floor tablet ekranından Başlat / Kısmi Bitir / Bitir aksiyonları
                    bu listeye işlenir.
                </div>
                @if (isNew)
                {
                    <div class="src-empty">İş emri kaydedildikten sonra operasyon ekleyebilirsin.</div>
                }
                else
                {
                    <div id="woe-rota-list" class="woe-rota-table" data-workorder-id="@Model!.Id" data-can-edit="@(canEditPlan ? "1" : "0")">
                        <div class="woe-rota-row woe-rota-head">
                            <span></span>
                            <span>Sıra</span>
                            <span>Operasyon</span>
                            <span>Makine</span>
                            <span>Süre</span>
                            <span>Üretilen / Fire</span>
                            <span>Durum</span>
                            <span></span>
                        </div>
                        <div class="woe-rota-empty src-empty">Yükleniyor…</div>
                    </div>
                }
            </section>

            <!-- Tab: Reçete (Faz 2 — BOM Patlatma) -->
            <section class="woe-pane-section" data-pane="recete">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:6px;">
                    <h2 style="margin:0; flex:1;">Reçete (Bill of Materials)</h2>
                    @if (!isNew)
                    {
                        <button type="button" class="woe-btn" id="btn-bom-explode"
                                title="Ürün ağacındaki bileşenleri planlanan miktara çarp ve listele (mevcut listeyi siler)">
                            ⚙ Reçeteyi Patlat
                        </button>
                    }
                </div>
                <div class="pane-hint">
                    Mamul reçetesinden patlatılacak bileşen ve fire bilgisi.
                    <strong>Patlat</strong> butonu aktif Ürün Ağacı'ndaki bileşenleri
                    (kombinasyon dahil) planlanan miktara orantılı olarak yansıtır.
                </div>

                @if (isNew)
                {
                    <div class="src-empty">İş emri kaydedildikten sonra reçeteyi patlatabilirsin.</div>
                }
                else
                {
                    <div id="woe-bom-list" class="woe-bom-table" data-workorder-id="@Model!.Id">
                        <div class="woe-bom-row woe-bom-head">
                            <span>Bileşen</span>
                            <span>Konfig</span>
                            <span style="text-align:right;">Net İhtiyaç</span>
                            <span style="text-align:right;">Çıkış Yapılan</span>
                            <span style="text-align:right;">Fire %</span>
                            <span>Birim</span>
                            <span>Notlar</span>
                        </div>
                        <div class="woe-bom-empty src-empty">Yükleniyor…</div>
                    </div>
                }
            </section>

            <!-- Tab: Kaynak Siparişler -->
            <section class="woe-pane-section" data-pane="kaynak">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:6px;">
                    <h2 style="margin:0; flex:1;">Kaynak Siparişler</h2>
                    @if (!isNew)
                    {
                        <button type="button" class="woe-btn woe-btn--primary" id="btn-add-source" title="Bu iş emrine satış siparişi kalemi bağla">+ Sipariş Ekle</button>
                    }
                </div>
                <div class="pane-hint">Bu iş emri hangi satış siparişi kalem(ler)inden tetiklendi. Yeni kaynak ekleyince planlanan miktar otomatik artar.</div>
                <div class="woe-source-list">
                    @if (isNew)
                    {
                        <div class="src-empty">İş emri kaydedildikten sonra kaynak sipariş bağlayabilirsin.</div>
                    }
                    else if (Model!.Sources.Count == 0)
                    {
                        <div class="src-empty">Kaynak sipariş yok — manuel açılmış iş emri. Yukarıdaki butonla sipariş bağlayabilirsin.</div>
                    }
                    else
                    {
                        foreach (var src in Model.Sources)
                        {
                            <div class="src-item">
                                <a href="@Url.Action("DocumentEdit", "Sales", new { id = src.SourceDocumentId })">
                                    @(src.SourceDocumentNumber ?? $"#{src.SourceDocumentId}") · satır #@src.SourceLineId
                                </a>
                                <strong>@src.AllocatedQuantity.ToString("N2")</strong>
                            </div>
                        }
                    }
                </div>
            </section>

            @* ── Kaynak Sipariş Ekleme Modalı (Faz 1.5) ────────────────────────
               1. Açık siparişleri listele (status filter: Approved/Sent — backend'in
                  GetDocuments endpoint'i kullanılır)
               2. Sipariş seçilince satırları getir (Sales/GetQuote?id=)
               3. Mamul/config eşleşen satırlar vurgulanır (eşleşmeyenler de seçilebilir
                  — kullanıcı sorumluluğunda)
               4. Satır + miktar gir → /Production/CreateFromSalesLine POST
                  targetWorkOrderId=mevcutId ile mevcut emire allocation eklenir,
                  PlannedQuantity otomatik artar (servis tarafında zaten yapılıyor). *@
            @if (!isNew)
            {
                <div id="addSourceModal" style="display:none; position:fixed; inset:0; background:rgba(8,12,24,.55); backdrop-filter:blur(4px); z-index:5000; align-items:center; justify-content:center;">
                    <div style="background:var(--woe-surface); border:1px solid var(--woe-border); border-radius:12px; width:min(640px,94vw); max-height:85vh; overflow:auto; box-shadow:0 12px 48px rgba(0,0,0,.35); color:var(--woe-text);">
                        <div style="display:flex; align-items:center; padding:14px 18px; border-bottom:1px solid var(--woe-border);">
                            <h3 style="margin:0; flex:1; font-size:15px;">Kaynak Sipariş Ekle</h3>
                            <button type="button" id="btn-add-source-close" style="background:transparent; border:none; color:var(--woe-text-muted); font-size:20px; cursor:pointer; padding:0 6px;">×</button>
                        </div>
                        <div style="padding:14px 18px;">
                            <div class="pane-hint" style="margin-bottom:10px;">
                                Satış siparişinden seç → satır seç → miktar gir → "Ekle".
                                Satır listesi yalnızca iş emrindeki <strong>Mamul + Konfigürasyon</strong>'la eşleşen kalemlerle gösterilir.
                            </div>

                            <div style="margin-bottom:12px;">
                                <label style="font-size:12px; color:var(--woe-text-muted); display:block; margin-bottom:4px;">Sipariş</label>
                                <select id="add-src-doc" class="woe-unit-select" style="width:100%; min-width:0;">
                                    <option value="">Yükleniyor…</option>
                                </select>
                            </div>

                            <div style="margin-bottom:12px;">
                                <label style="font-size:12px; color:var(--woe-text-muted); display:block; margin-bottom:4px;">Satır (eşleşen)</label>
                                <select id="add-src-line" class="woe-unit-select" style="width:100%; min-width:0;" disabled>
                                    <option value="">Önce sipariş seç</option>
                                </select>
                                <div id="add-src-line-info" style="font-size:11px; color:var(--woe-text-muted); margin-top:4px;"></div>
                            </div>

                            <div style="margin-bottom:14px;">
                                <label style="font-size:12px; color:var(--woe-text-muted); display:block; margin-bottom:4px;">Eklenecek Miktar</label>
                                <input type="number" step="0.0001" min="0" id="add-src-qty" class="woe-input--qty" style="width:160px; max-width:160px; flex:0 0 160px;" />
                            </div>
                        </div>
                        <div style="display:flex; justify-content:flex-end; gap:8px; padding:12px 18px; border-top:1px solid var(--woe-border); background:var(--woe-surface2);">
                            <button type="button" class="woe-btn" id="btn-add-source-cancel">Vazgeç</button>
                            <button type="button" class="woe-btn woe-btn--primary" id="btn-add-source-submit" disabled>Ekle</button>
                        </div>
                    </div>
                </div>
            }

            <!-- Tab: Revizyon -->
            @if (!isNew && (Model!.RevisionNo > 0 || Model.RevisedFromId.HasValue))
            {
                <section class="woe-pane-section" data-pane="revize">
                    <h2>Revizyon</h2>
                    <div class="pane-hint">Bu iş emrinin revizyon zinciri.</div>
                    <div class="woe-meta" style="border-top:none;padding-top:0;margin-top:0;">
                        <span>Revizyon No: <strong>@Model.RevisionNo</strong></span>
                        @if (Model.RevisedFromId.HasValue)
                        {
                            <span><a href="@Url.Action("WorkOrderEdit", new { id = Model.RevisedFromId.Value })">← Önceki revizyon</a></span>
                        }
                    </div>
                </section>
            }

            <!-- Tab: Widget Sahaları —
                 Sol nav butonu admin tanımlı ilk grubun adıyla guncellenir;
                 sag pane'de tekrar baslik/hint yok — DynamicWidgetRenderer
                 grup baslıklarını kendi icinde render ediyor. -->
            <section class="woe-pane-section" data-pane="widgets">
                <div id="woeDynamicWidgets"
                     data-form-code="WORK_ORDER_EDIT"
                     data-record-id="@(Model?.Id.ToString() ?? "")">
                    <div class="woe-placeholder" id="woeDynamicWidgetsEmpty">
                        Bu form için tanımlı widget yok. <a href="@Url.Action("FormManagement", "Admin")">Form Tasarım Ayarları</a>'ndan ekleyebilirsin.
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>
</section>

@* Toast container — sag alt kose, otomatik kapanan + manuel close butonlu *@
<div id="woe-toast-host"></div>
@Html.AntiForgeryToken()

@functions {
    static string StatusLabel(WorkOrderStatus s) => s switch
    {
        WorkOrderStatus.Planned => "Taslak",
        WorkOrderStatus.Released => "Yayımlandı",
        WorkOrderStatus.InProgress => "Devam ediyor",
        WorkOrderStatus.Completed => "Tamamlandı",
        WorkOrderStatus.Closed => "Kapatıldı",
        WorkOrderStatus.Cancelled => "İptal",
        _ => s.ToString()
    };
    static string PriorityLabel(WorkOrderPriority p) => p switch
    {
        WorkOrderPriority.Low => "Düşük",
        WorkOrderPriority.Medium => "Normal",
        WorkOrderPriority.High => "Yüksek",
        _ => p.ToString()
    };
}

@section Scripts {
<script>
(function () {
    const isNew = @(isNew ? "true" : "false");
    const id = @(Model?.Id ?? 0);

    function token() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    // ── Toast — sag alt kose, 4 sn auto-dismiss + manuel close ──
    function flash(msg, ok) {
        const host = document.getElementById('woe-toast-host');
        if (!host) return;

        const el = document.createElement('div');
        el.className = 'woe-toast ' + (ok ? 'woe-toast--ok' : 'woe-toast--err');
        el.setAttribute('role', ok ? 'status' : 'alert');

        const msgEl = document.createElement('div');
        msgEl.className = 'woe-toast-msg';
        msgEl.textContent = msg;

        const closeBtn = document.createElement('button');
        closeBtn.type = 'button';
        closeBtn.className = 'woe-toast-close';
        closeBtn.setAttribute('aria-label', 'Kapat');
        closeBtn.textContent = '×';

        function dismiss() {
            if (el.classList.contains('is-leaving')) return;
            el.classList.add('is-leaving');
            clearTimeout(autoTm);
            setTimeout(() => { if (el.parentNode) el.parentNode.removeChild(el); }, 260);
        }
        closeBtn.addEventListener('click', dismiss);

        el.appendChild(msgEl);
        el.appendChild(closeBtn);
        host.appendChild(el);

        // 4 saniye sonra otomatik kapat
        const autoTm = setTimeout(dismiss, 4000);
    }
    function num(id) {
        const v = document.getElementById(id).value;
        return v === '' ? null : Number(v);
    }
    function txt(id) {
        const v = document.getElementById(id).value;
        return v === '' ? null : v;
    }

    function payload() {
        return {
            // f-itemId hidden input — itemCode resolve edildikten sonra dolar
            itemId: num('f-itemId') || 0,
            // f-configId hidden — configCode resolve edildikten sonra dolar
            configId: num('f-configId'),
            plannedQuantity: num('f-plannedQty') || 0,
            unitId: num('f-unitId'),
            plannedStartDate: txt('f-plannedStart'),
            plannedEndDate: txt('f-plannedEnd'),
            priority: num('f-priority') ?? 1,
            // assignedUserId artık kullanılmıyor (legacy column) — null gönderiyoruz
            assignedUserId: null,
            // Sorumlu Personel: Personnel.Id (User hesabı gerekmez)
            assignedPersonnelId: num('f-assignedPersonnelId'),
            warehouseLocationId: num('f-locationId'),
            // Rota: Genel tab'taki rehber alanından (boşsa server tarafı item bazlı arar)
            routingId: num('f-routingId'),
            // Default Makine: header tercihi — patlatmada operasyon bazli fallback
            defaultMachineId: num('f-defaultMachineId'),
            // AR-GE/ÜR-GE proje (boşsa server ItemId'den otomatik türetir)
            argeProjectId: num('f-argeProject'),
            notes: txt('f-notes'),
            // "Üretime Planla" switch — sadece yeni iş emrinde anlamli (toolbar'da
            // hidden değilse). Açık ise WO Released statüsünde acilir + operasyonlar
            // patlatilir; kapali ise Taslak (Planned) kalir.
            autoRelease: (function(){
                var sw = document.getElementById('f-autoRelease');
                return sw ? !!sw.checked : null;
            })()
        };
    }

    // ── AR-GE/ÜR-GE proje dropdown'u doldur (Faz 3) ──
    (function () {
        var sel = document.getElementById('f-argeProject');
        if (!sel) return;
        var current = sel.getAttribute('data-current') || '';
        fetch('/Arge/ProjectsLookup', { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (list) {
                (list || []).forEach(function (p) {
                    var o = document.createElement('option');
                    o.value = p.id; o.textContent = p.label;
                    if (String(p.id) === String(current)) o.selected = true;
                    sel.appendChild(o);
                });
            })
            .catch(function () { });
    })();

    // ── Birim dropdown'u — sectilen stok kartinda tanimli birimlere kisitlama (2026-05-20).
    // /Logistics/GetItemUnits?itemId=X cevabi: { conversions: [{lineNo,unitId,multiplier}],
    // availableUnits: [{id, unitCode, unitName, isActive}] }. Birlestirilmis liste:
    //   1) Master birim (Items.UnitId — endpoint'in conversions'inda LineNo=0 olur, yoksa
    //      caller'in passlediği masterUnitId/masterUnitCode kullanilir).
    //   2) Alternatif birimler (LineNo >= 1, multiplier ile).
    // availableUnits sozlugu code/name aciklamasi icin lookup tablosu olarak kullanilir.
    async function loadItemUnitsToDropdown(itemId, masterUnitId, masterUnitCode, preselectId) {
        const sel = document.getElementById('f-unitId');
        if (!sel) return;
        if (!itemId || itemId <= 0) {
            // Item secilmemis — bos placeholder
            sel.innerHTML = '<option value="">— Birim —</option>';
            return;
        }
        try {
            const r = await fetch('/Logistics/GetItemUnits?itemId=' + encodeURIComponent(itemId),
                                   { credentials: 'same-origin' });
            if (!r.ok) { console.warn('[WOE] GetItemUnits ' + r.status); return; }
            const data = await r.json();
            const unitDict = new Map();
            (data.availableUnits || []).forEach(u => unitDict.set(String(u.id), u));

            // Bu mamul icin izinli birim ID set'i: master + alternatlar
            const allowed = new Map(); // id -> { code, name, isMaster }
            if (masterUnitId != null) {
                const master = unitDict.get(String(masterUnitId));
                allowed.set(String(masterUnitId), {
                    code: (master && master.unitCode) || masterUnitCode || ('#' + masterUnitId),
                    name: master ? master.unitName : '',
                    isMaster: true,
                });
            }
            (data.conversions || []).forEach(c => {
                if (c.unitId == null) return;
                const key = String(c.unitId);
                if (allowed.has(key)) return; // master tekrari
                const u = unitDict.get(key);
                allowed.set(key, {
                    code: (u && u.unitCode) || ('#' + c.unitId),
                    name: u ? u.unitName : '',
                    isMaster: false,
                });
            });

            // Dropdown'i yeniden kur. Mevcut secimi (preselect veya edit mode kalintisi) koru.
            const prevSelected = preselectId || sel.value || '';
            const prevValid = allowed.has(String(prevSelected));
            sel.innerHTML = '';
            // Tek izinli birim varsa placeholder gostermeye gerek yok; cok varsa "— Birim —" iste
            if (allowed.size === 0) {
                const opt = document.createElement('option');
                opt.value = ''; opt.textContent = '— Birim tanimsiz —';
                sel.appendChild(opt);
                return;
            }
            allowed.forEach((info, id) => {
                const opt = document.createElement('option');
                opt.value = id;
                // 2026-05-22: "(ana)" suffix kaldirildi — kullanici sadece kod + ad gorur.
                // Master birim zaten preselect mantiginda otomatik secilir.
                opt.textContent = info.code + (info.name ? ' — ' + info.name : '');
                sel.appendChild(opt);
            });
            // Secim mantigi:
            //   - Edit mode'da gelen preselect izinli birimde ise onu koru.
            //   - Aksi halde master birimi default sec.
            if (prevValid) {
                sel.value = String(prevSelected);
            } else if (masterUnitId != null) {
                sel.value = String(masterUnitId);
            }
        } catch (e) {
            console.error('[WOE loadItemUnits]', e);
        }
    }

    // ── Mamul kodu resolve (itemCode → itemId, itemName, hasConfig) ─────
    async function resolveItem() {
        const codeEl = document.getElementById('f-itemCode');
        const nameEl = document.getElementById('f-itemName');
        const idEl   = document.getElementById('f-itemId');
        const cfgWrap = document.getElementById('f-configWrapper');
        if (!codeEl) return null;

        // Yardimci — span/input ayrimi yapmadan yaz (textContent vs value)
        function setText(el, val) {
            if (!el) return;
            if ('value' in el && el.tagName === 'INPUT') el.value = val || '';
            else el.textContent = val || '';
        }

        const code = (codeEl.value || '').trim();
        if (!code) {
            setText(nameEl, '');
            idEl.value = '';
            // Birim de temizlensin
            const unitDispClr = document.getElementById('f-unitDisplay');
            const unitIdClr   = document.getElementById('f-unitId');
            setText(unitDispClr, '');
            if (unitIdClr) unitIdClr.value = '';
            cfgWrap.style.display = 'none';
            document.getElementById('f-configCode').value = '';
            document.getElementById('f-configId').value = '';
            document.getElementById('f-configDesc').value = '';
            return null;
        }

        try {
            const resp = await fetch('/Logistics/StockLookup?q=' + encodeURIComponent(code), { credentials: 'same-origin' });
            const list = await resp.json();
            const match = (list || []).find(s => (s.code || '').toLowerCase() === code.toLowerCase());
            if (!match) {
                setText(nameEl, '');
                idEl.value = '';
                cfgWrap.style.display = 'none';
                return null;
            }
            // StockLookup artik id, unitId, unitCode dondur (LogisticsController ext'i)
            codeEl.value = match.code;
            setText(nameEl, match.name || '');
            // ItemId direkt StockLookup'tan
            if (match.id != null) idEl.value = String(match.id);

            // Birim — 2026-05-20: stok kartında tanımlı birimlerle (master + alternat)
            // sınırlı dropdown. /Logistics/GetItemUnits?itemId=X endpoint'i conversions
            // listesi + tüm birim sözlüğü döner; ikisini join'leyip select'i yeniden kurarız.
            // Önceki davranış: tüm sistem birimleri listeleniyordu — kullanıcı talebi
            // doğrultusunda kartta seçili olmayan birimler artık görünmez.
            if (match.id != null) {
                await loadItemUnitsToDropdown(
                    /* itemId */       match.id,
                    /* masterUnitId */  match.unitId,
                    /* masterUnitCode */ match.unitCode || '',
                    /* preselect */    document.getElementById('f-unitId')?.dataset.preselect || ''
                );
            }

            const hasCfg = match.hasConfig === true || match.hasConfig === 'true';
            cfgWrap.style.display = hasCfg ? '' : 'none';
            if (!hasCfg) {
                document.getElementById('f-configCode').value = '';
                document.getElementById('f-configId').value = '';
                document.getElementById('f-configDesc').value = '';
            } else {
                // hasConfig=true ve mevcut configId var ise (edit modu) → kombinasyon
                // bilgilerini fetch et ve f-configCode + f-configDesc doldur.
                const existingCfgId = (document.getElementById('f-configId').value || '').trim();
                const cfgCodeEl = document.getElementById('f-configCode');
                if (existingCfgId && !cfgCodeEl.value) {
                    try {
                        const cfgResp = await fetch('/Logistics/CombinationLookup?materialCode=' + encodeURIComponent(match.code), { credentials: 'same-origin' });
                        const cfgList = await cfgResp.json();
                        const cfgMatch = (cfgList || []).find(c => String(c.configId) === existingCfgId);
                        if (cfgMatch) {
                            cfgCodeEl.value = cfgMatch.code;
                            const descEl = document.getElementById('f-configDesc');
                            if (descEl) {
                                descEl.value = cfgMatch.name ||
                                    (cfgMatch.features || []).map(f => `${f.feature}: ${f.value || f.valueCode || ''}`).join(' | ');
                            }
                        }
                    } catch (_) { /* sessiz */ }
                }
            }
            return match;
        } catch (err) {
            console.error('[WOE resolveItem]', err);
            return null;
        }
    }

    // ── Konfigurasyon kodu resolve (configCode → configId + features desc) ─
    async function resolveConfig() {
        const matCode = (document.getElementById('f-itemCode')?.value || '').trim();
        const cfgCodeEl = document.getElementById('f-configCode');
        const cfgIdEl   = document.getElementById('f-configId');
        const descEl    = document.getElementById('f-configDesc');
        const cfgCode   = (cfgCodeEl?.value || '').trim();

        if (!matCode || !cfgCode) {
            if (cfgIdEl) cfgIdEl.value = '';
            if (descEl) descEl.value = '';
            return null;
        }
        try {
            const resp = await fetch('/Logistics/CombinationLookup?materialCode=' + encodeURIComponent(matCode), { credentials: 'same-origin' });
            const list = await resp.json();
            const match = (list || []).find(c => (c.code || '').toLowerCase() === cfgCode.toLowerCase());
            if (!match) {
                if (cfgIdEl) cfgIdEl.value = '';
                if (descEl) descEl.value = '';
                return null;
            }
            cfgCodeEl.value = match.code;
            if (cfgIdEl) cfgIdEl.value = (match.configId ?? '').toString();
            if (descEl) {
                descEl.value = match.name ||
                    (match.features || []).map(f => `${f.feature}: ${f.value || f.valueCode || ''}`).join(' | ');
            }
            return match;
        } catch (err) {
            console.error('[WOE resolveConfig]', err);
            return null;
        }
    }

    // Initial: edit modunda yuklenince itemCode dolu ise resolve et
    if (document.getElementById('f-itemCode').value) { resolveItem(); }

    async function call(url, body) {
        const headers = { 'Content-Type': 'application/json', 'RequestVerificationToken': token() };
        const res = await fetch(url, { method: 'POST', headers, body: body ? JSON.stringify(body) : null, credentials: 'same-origin' });
        const data = await res.json().catch(() => ({ ok: false, error: 'Yanit JSON degil' }));
        return data;
    }

    document.getElementById('btn-save')?.addEventListener('click', async () => {
        // Save'den once mamul kodu + konfigurasyon kodunu yeniden cozumle —
        // kullanici yazdiktan sonra blur etmeden direkt save tikladiysa
        // hidden id'ler dolmamis olabilir.
        await resolveItem();
        if ((document.getElementById('f-configCode')?.value || '').trim()) {
            await resolveConfig();
        }
        const body = payload();
        if (!body.itemId) { flash('Mamul kodu seçilmedi veya geçersiz.', false); return; }
        if (document.getElementById('f-configWrapper').style.display !== 'none' && !body.configId) {
            flash('Kombinasyonlu mamulde konfigürasyon seçimi zorunludur.', false); return;
        }
        if (!body.plannedQuantity || body.plannedQuantity <= 0) { flash('Planlanan miktar 0\'dan büyük olmalı.', false); return; }

        // Ek alan (widget) zorunlu + kisitlama validasyonu — entity save'den ONCE kontrol et
        if (window._woeDynRenderer && window._woeDynRenderer.validate) {
            const dynValidation = window._woeDynRenderer.validate();
            if (!dynValidation.valid) {
                flash(dynValidation.message || 'Ek alanlarda eksik/hatali veri var.', false);
                return;
            }
        }

        const url = isNew ? '@Url.Action("Create")' : '@Url.Action("Update")/' + id;
        // Update payload: tum alanlari gonder — backend UpdateWorkOrderRequest record'u bekliyor.
        const r = await call(url, isNew ? body : {
            plannedQuantity: body.plannedQuantity, unitId: body.unitId,
            plannedStartDate: body.plannedStartDate, plannedEndDate: body.plannedEndDate,
            priority: body.priority,
            assignedUserId: body.assignedUserId,
            assignedPersonnelId: body.assignedPersonnelId,
            warehouseLocationId: body.warehouseLocationId,
            routingId: body.routingId,
            defaultMachineId: body.defaultMachineId,
            notes: body.notes
        });
        if (!r.ok) { flash(r.error || 'Hata.', false); return; }

        // Entity basarili — simdi widget degerlerini de kaydet (WidgetTra)
        const newId = (r.id && r.id > 0) ? r.id : id;
        if (window._woeDynRenderer && newId > 0) {
            try {
                const dynResult = await window._woeDynRenderer.save({ recordId: String(newId) });
                if (dynResult && dynResult.success === false) {
                    console.warn('[WOE] widget save basarisiz:', dynResult.message);
                }
            } catch (e) { console.warn('[WOE] widget save hatasi:', e); }
        }

        flash(isNew ? 'İş emri oluşturuldu.' : 'Kaydedildi.', true);
        if (isNew && r.id) location.href = '@Url.Action("WorkOrderEdit")?id=' + r.id;
        else setTimeout(() => location.reload(), 600);
    });

    async function changeStatus(newStatus) {
        const r = await call('@Url.Action("ChangeStatus")/' + id, { workOrderId: id, newStatus });
        if (r.ok) { flash('Durum değişti.', true); setTimeout(() => location.reload(), 500); }
        else flash(r.error || 'Hata.', false);
    }

    document.getElementById('btn-release')?.addEventListener('click', () => changeStatus(1));
    /* Başlat (Status=2 InProgress) ve Tamamla (Status=3 Completed) iş emri toolbar'ından
       kaldırıldı — bu geçişler Faz 3'te makine ataması üzerinden tetiklenecek
       (Üretim → Makine → İş Emrini Başlat / Bitir / Kısmi Bitir). */
    document.getElementById('btn-close')?.addEventListener('click', async () => {
        var ok = await CalibraAlert.confirm('İş emrini kalıcı kapatıyorsun. Devam edilsin mi?',
            { title: 'İş Emrini Kapat', okText: 'Evet, Kapat', cancelText: 'Vazgeç', danger: true });
        if (ok) changeStatus(4);
    });
    document.getElementById('btn-cancel')?.addEventListener('click', async () => {
        var ok = await CalibraAlert.confirm('İş emrini iptal etmek istediğine emin misin?',
            { title: 'İş Emrini İptal', okText: 'Evet, İptal Et', cancelText: 'Vazgeç', danger: true });
        if (ok) changeStatus(5);
    });

    document.getElementById('btn-revise')?.addEventListener('click', async () => {
        var ok = await CalibraAlert.confirm('Yeni revizyon emri oluşturulsun mu? Mevcut emir iptal edilecek.',
            { title: 'Yeni Revizyon', okText: 'Evet, Oluştur', cancelText: 'Vazgeç', danger: false });
        if (!ok) return;
        const r = await call('@Url.Action("Revise")/' + id);
        if (r.ok && r.id) location.href = '@Url.Action("WorkOrderEdit")?id=' + r.id;
        else flash(r.error || 'Hata.', false);
    });

    // ── Mamul + Konfigurasyon lookup mount ──────────────────────────────
    // Mamul kodu icin Tip 1 (Mamul) standart rehberi (ITEMS_FINISHED).
    // Pick sonrasi 'change' event tetiklenir → resolveItem() id+hasConfig'i cozer.
    // Tab tusu / focus loss / paste durumlarinda da resolveItem calissin diye
    // change + blur + keydown(Enter) dinleniyor.
    document.getElementById('f-itemCode')?.addEventListener('change', resolveItem);
    document.getElementById('f-itemCode')?.addEventListener('blur', resolveItem);
    document.getElementById('f-itemCode')?.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === 'Tab') {
            // setTimeout ile blur'dan once resolveItem cagrilmasin diye event loop'a birak
            setTimeout(resolveItem, 0);
        }
    });
    document.getElementById('f-configCode')?.addEventListener('blur', resolveConfig);

    // ── "Mamul Kodu *" başlığına tıklama → Malzeme Kartı edit ekranı ─────
    // Workspace iframe içindeysek window.top.CalibraHub.openWorkspaceTab ile
    // YENİ "Malzeme Kartları" tab'ı açılır. Açık bir Malzeme Kartı tab'ı varsa
    // (matchPath ile yakalanır), o tab URL'i yeni id ile güncellenip aktive edilir.
    // iframe dışındaysak (rare) düz navigate.
    (function bindItemLabelClick() {
        var lbl = document.getElementById('lbl-itemCode');
        if (!lbl) return;
        lbl.addEventListener('click', function () {
            var idEl = document.getElementById('f-itemId');
            var itemId = parseInt((idEl && idEl.value) || '0', 10) || 0;
            if (itemId <= 0) {
                flash('Mamul önce seçilmeli — kod yazıp Tab\'a basın veya rehberden seçin.', false);
                return;
            }
            var url = '/Logistics/MaterialCardEdit?id=' + encodeURIComponent(itemId);
            try {
                if (window.top && window.top.CalibraHub && typeof window.top.CalibraHub.openWorkspaceTab === 'function') {
                    window.top.CalibraHub.openWorkspaceTab({
                        url: url,
                        title: 'Malzeme Kartları',
                        // matchPath: aynı /Logistics/MaterialCard prefix'ine sahip
                        // mevcut tab varsa (list ya da başka edit) URL'ini güncelle + aktive et.
                        matchPath: '/Logistics/MaterialCard',
                    });
                    return;
                }
            } catch (e) { /* cross-origin vs — fallback'a düş */ }
            // Fallback: aynı pencerede navigate
            window.location.href = url;
        });
    })();

    function ensureLookupsMounted() {
        if (!window.CalibraHub || !window.CalibraHub.mountLookupForInput) return;
        const itemEl = document.getElementById('f-itemCode');
        if (itemEl && !itemEl.dataset.lookupMounted) {
            try {
                window.CalibraHub.mountLookupForInput({
                    inputElement: itemEl,
                    // formCode + fieldKey verilince LookupCard header'inda
                    // "Alan Ayarlari" (gear/Settings) butonu gorunur. Boylece
                    // admin bu rehberin gosterim kolonlarini, kisitlarini vs
                    // form bazinda override edebilir.
                    formCode: 'WORK_ORDER_EDIT',
                    fieldKey: 'itemCode',
                    guideCode: 'ITEMS_FINISHED',
                    isRequired: true
                });
                itemEl.dataset.lookupMounted = '1';
            } catch (e) { console.warn('[WOE] item lookup mount hatasi:', e); }
        }

        // 2026-05-22: Planlama & Makine tab'indaki 4 rehber alani Tip 1 standart rehber.
        // Markup'taki .wo-guide-input class'li input'lara mountLookupForInput baglanir;
        // veri data-* attribute'larindan okunur. Custom wpicker (4 ayri picker fonksiyonu)
        // artik kullanilmiyor — standart rehber UI/UX birlik saglar (Cari/Stok ile ayni).
        // 2026-05-22: Order Number alanı için ayri rehber + navigate davranisi.
        // Kullanici mevcut bir is emrini secince o IE'nin edit sayfasina yonlendirir.
        var orderInput = document.querySelector('.wo-orderno-input');
        if (orderInput && !orderInput.dataset.lookupMounted) {
            try {
                // Readonly attribute'u kaldir ki rehber popup acilabilsin (FixedFieldLookupBridge
                // readonly'yi kendi mantiginda yonetir). Manuel yazim yine engellenir.
                orderInput.removeAttribute('readonly');
                window.CalibraHub.mountLookupForInput({
                    inputElement: orderInput,
                    formCode: 'WORK_ORDER_EDIT',
                    fieldKey: 'orderNumber',
                    guideCode: 'WORKORDERS',
                });
                orderInput.dataset.lookupMounted = '1';
                orderInput.addEventListener('change', function () {
                    var pickedId = orderInput.dataset.recordId || orderInput.getAttribute('data-record-id') || '';
                    if (pickedId && Number(pickedId) > 0) {
                        // URL'den mevcut id'yi al; farkliysa navigate (ayni ise reload anlamsiz)
                        var curId = new URLSearchParams(window.location.search).get('id') || '0';
                        if (parseInt(pickedId, 10) !== parseInt(curId, 10)) {
                            window.location.href = '/Production/WorkOrderEdit?id=' + encodeURIComponent(pickedId);
                        }
                    }
                });
            } catch (e) { console.warn('[WOE] WORKORDERS rehber mount hatasi:', e); }
        }

        document.querySelectorAll('.wo-guide-input').forEach(function (input) {
            if (input.dataset.lookupMounted) return;
            var guideCode = input.dataset.guideCode;
            var idTargetId = input.dataset.guideIdTarget;
            var nameTargetId = input.dataset.guideNameTarget;
            if (!guideCode) return;
            try {
                window.CalibraHub.mountLookupForInput({
                    inputElement: input,
                    formCode: 'WORK_ORDER_EDIT',
                    fieldKey: input.id,
                    guideCode: guideCode,
                });
                input.dataset.lookupMounted = '1';

                // 2026-05-22 Standart rehber pattern A:
                //   • Input value     = Code (ValueColumn)             → DB icin display
                //   • Hidden ID target = Record.Id                     → DB FK
                //   • Name span target = DisplayColumn (Name)          → kullanici yaninda gorur
                // FixedFieldLookupBridge pick sonrasi 'change' event firlatir + input'a
                // data-record-id (Id) ve data-display (Name) attribute'larini set eder.
                if (idTargetId || nameTargetId) {
                    input.addEventListener('change', function () {
                        if (idTargetId) {
                            var idEl = document.getElementById(idTargetId);
                            if (idEl) {
                                var recId = input.dataset.recordId || input.getAttribute('data-record-id') || '';
                                idEl.value = recId || '';
                            }
                        }
                        if (nameTargetId) {
                            var nameEl = document.getElementById(nameTargetId);
                            if (nameEl) {
                                var display = input.dataset.display || input.getAttribute('data-display') || '';
                                nameEl.textContent = display || '';
                            }
                        }
                    });
                    // ffl-clear event ile temizlenince ID + Name'i de sifirla
                    input.addEventListener('ffl-clear', function () {
                        if (idTargetId) {
                            var idEl = document.getElementById(idTargetId);
                            if (idEl) idEl.value = '';
                        }
                        if (nameTargetId) {
                            var nameEl = document.getElementById(nameTargetId);
                            if (nameEl) nameEl.textContent = '';
                        }
                    });
                }
            } catch (e) { console.warn('[WOE] guide lookup mount hatasi (' + guideCode + '):', e); }
        });
    }

    if (window.CalibraHub && window.CalibraHub.mountLookupForInput) {
        ensureLookupsMounted();
    } else {
        // Bundle henuz yuklenmedi — DynamicWidgetRenderer init'i bundle yukleyince retry et
        var lookupTries = 0;
        var lookupTimer = setInterval(() => {
            lookupTries++;
            if (window.CalibraHub && window.CalibraHub.mountLookupForInput) {
                clearInterval(lookupTimer); ensureLookupsMounted();
            } else if (lookupTries >= 50) clearInterval(lookupTimer);
        }, 100);
    }

    // ── Generic picker (rehber) — Sorumlu / Lokasyon / Rota / Operasyon / Makine ─
    // Modal patterm RoutingTree.PickerModal ile ayni gorsel dilde ama vanilla.
    // window.wpicker olarak expose ediliyor — diger IIFE'lerden de cagrilabilir.
    // opts: { title, url, codeOf, nameOf, metaOf?, badgeOf?, filter?, onSelect }
    window.wpicker = wpicker;
    function wpicker(opts) {
        var bd = document.createElement('div');
        bd.className = 'wpicker-backdrop';
        bd.innerHTML =
            '<div class="wpicker">' +
              '<div class="wpicker__head">' +
                '<span class="wpicker__title">' + (opts.title || 'Seç') + '</span>' +
                '<input type="text" class="wpicker__search" placeholder="Ara... (kod, ad)" autofocus />' +
                '<button type="button" class="wpicker__close" title="Kapat (Esc)">×</button>' +
              '</div>' +
              '<div class="wpicker__list"><div class="wpicker__loading">Yükleniyor…</div></div>' +
            '</div>';

        function close() {
            document.removeEventListener('keydown', onKey);
            if (bd.parentNode) bd.parentNode.removeChild(bd);
        }
        function onKey(e) { if (e.key === 'Escape') close(); }
        document.addEventListener('keydown', onKey);
        bd.addEventListener('click', function (e) { if (e.target === bd) close(); });
        bd.querySelector('.wpicker__close').addEventListener('click', close);

        var list   = bd.querySelector('.wpicker__list');
        var search = bd.querySelector('.wpicker__search');
        var allItems = [];

        function render(items) {
            if (!items || items.length === 0) {
                list.innerHTML = '<div class="wpicker__empty">Kayıt bulunamadı.</div>';
                return;
            }
            // Inline picker satiri — kolon sayisina gore esnek olabilir; basit tutuyoruz:
            // [code] [name + meta] [badge?]
            list.innerHTML = items.map(function (it, i) {
                var code = (opts.codeOf ? opts.codeOf(it) : (it.code || it.machineCode || it.locationCode || '')) || '';
                var name = (opts.nameOf ? opts.nameOf(it) : (it.name || it.fullName || it.machineName || it.locationName || '')) || '';
                var meta = opts.metaOf ? (opts.metaOf(it) || '') : '';
                var badge = opts.badgeOf ? (opts.badgeOf(it) || '') : '';
                return '<div class="wpicker__row" data-idx="' + i + '">' +
                       '<span class="wpicker__code">' + escHtml(code) + '</span>' +
                       '<span class="wpicker__name">' + escHtml(name) +
                            (meta ? ' <span class="wpicker__meta">· ' + escHtml(meta) + '</span>' : '') +
                       '</span>' +
                       '<span>' + (badge ? '<span class="wpicker__badge">' + escHtml(badge) + '</span>' : '') + '</span>' +
                       '</div>';
            }).join('');
            list.querySelectorAll('.wpicker__row').forEach(function (row) {
                row.addEventListener('click', function () {
                    var idx = parseInt(row.getAttribute('data-idx'), 10);
                    var item = items[idx];
                    if (typeof opts.onSelect === 'function') opts.onSelect(item);
                    close();
                });
            });
        }

        function applyFilter() {
            var q = (search.value || '').trim().toLowerCase();
            if (!q) { render(allItems); return; }
            var fil = allItems.filter(function (it) {
                return Object.keys(it).some(function (k) {
                    var v = it[k];
                    return v != null && String(v).toLowerCase().indexOf(q) !== -1;
                });
            });
            render(fil);
        }
        search.addEventListener('input', applyFilter);

        document.body.appendChild(bd);
        setTimeout(function () { search.focus(); }, 30);

        // Veri cek
        fetch(opts.url, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                allItems = Array.isArray(data) ? data : (data && Array.isArray(data.items) ? data.items : []);
                if (typeof opts.filter === 'function') allItems = allItems.filter(opts.filter);
                render(allItems);
            })
            .catch(function (e) {
                list.innerHTML = '<div class="wpicker__empty">Yükleme hatası: ' + escHtml(String(e.message || e)) + '</div>';
            });

        function escHtml(s) {
            return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }
    }

    // ── Pick handler'lari ────────────────────────────────────────────────
    function pickPersonnel() {
        wpicker({
            title: 'Personel Rehberi',
            url: '/Production/PersonnelList?includeInactive=false&onlyOperators=false',
            codeOf: function (p) { return p.code || ''; },
            nameOf: function (p) { return p.fullName || ''; },
            metaOf: function (p) {
                var bits = [];
                if (p.title) bits.push(p.title);
                if (p.department) bits.push(p.department);
                return bits.join(' · ');
            },
            // Personel atamasi artik dogrudan Personnel.Id'ye yapiliyor — User hesabi gerekmez.
            onSelect: function (p) {
                document.getElementById('f-assignedPersonnelId').value = p.id || '';
                document.getElementById('f-personnelDisplay').value = p.fullName || '';
            },
        });
    }
    function pickLocation() {
        wpicker({
            title: 'Üretim Lokasyonu Rehberi',
            url: '/Logistics/GetAllLocations',
            codeOf: function (l) { return l.locationCode || ''; },
            nameOf: function (l) { return l.locationName || ''; },
            metaOf: function (l) { return l.locationTypeDisplayName || l.locationTypeCode || ''; },
            // Sadece AKTIF + ÜRETIM HATTI (IsMachinePark=true) lokasyonlar listelenir.
            // Stok/depo lokasyonlari hariç tutulur — iş emrinin üretim konumu makine parkurudur.
            filter: function (l) {
                return l.isActive !== false && l.isMachinePark === true;
            },
            onSelect: function (l) {
                document.getElementById('f-locationId').value = l.id || '';
                document.getElementById('f-locationDisplay').value =
                    (l.locationCode || '') + (l.locationName ? ' · ' + l.locationName : '');
            },
        });
    }
    function pickMachine() {
        wpicker({
            title: 'Makine Rehberi (Default)',
            url: '/Logistics/GetAllMachines',
            codeOf:  function (m) { return m.machineCode || ''; },
            nameOf:  function (m) { return m.machineName || ''; },
            metaOf:  function (m) { return m.locationName || m.locationCode || ''; },
            badgeOf: function (m) { return m.isActive === false ? 'Pasif' : ''; },
            filter:  function (m) { return m.isActive !== false; },
            onSelect: function (m) {
                document.getElementById('f-defaultMachineId').value = m.id || '';
                // 2026-05-22: Single-field display — NAME oncelik (Personnel pattern).
                // Hidden id zaten gerçek FK; display sadece insan için.
                document.getElementById('f-defaultMachineDisplay').value =
                    m.machineName || m.machineCode || '';
            },
        });
    }
    function pickRouting() {
        // Mamul seciliyse o item icin filtreli liste; degilse tum aktif rotalar.
        var itemId = parseInt(document.getElementById('f-itemId')?.value || '0', 10) || 0;
        var url = '/Production/RoutingsList' + (itemId > 0 ? ('?itemId=' + itemId) : '');
        wpicker({
            title: 'Rota Rehberi' + (itemId ? ' (Mamul filtreli)' : ''),
            url: url,
            codeOf: function (r) { return r.code || ''; },
            nameOf: function (r) { return r.name || ''; },
            metaOf: function (r) { return r.itemCode ? ('Mamul: ' + r.itemCode) : (r.description || ''); },
            badgeOf: function (r) { return r.isActive ? '' : 'Pasif'; },
            filter: function (r) { return r.isActive !== false; },
            onSelect: function (r) {
                document.getElementById('f-routingId').value = r.id || '';
                // 2026-05-22: Single-field display — NAME oncelik (Personnel pattern).
                document.getElementById('f-routingCode').value = r.name || r.code || '';
            },
        });
    }
    // 2026-05-20: Konfigürasyon rehberi BOMEdit ile birebir aynı standart pattern'e
    // geçirildi — CalibraHub.openCombinationPicker (React CombinationPickerModal).
    // Mevcut/Yeni iki tab: kullanıcı mevcut kombinasyon seçebilir veya yeni üretebilir.
    // Bundle (calibrahub-widgets.js) henüz yüklenmediyse kısa retry; süresinde gelmezse
    // diag mesajıyla bilgilendirir.
    function woBuildComboDesc(details) {
        return (details || []).map(function (d) {
            var label = (d.featureName || d.feature || '') +
                        ' (' + (d.valueName || d.valueCode || d.value || '') + ')';
            return d.description ? (label + ' — ' + d.description) : label;
        }).join(', ');
    }
    function woOpenComboPicker(materialCode, opts, retriesLeft) {
        if (retriesLeft === undefined) retriesLeft = 10;
        if (!window.CalibraHub || typeof CalibraHub.openCombinationPicker !== 'function') {
            if (retriesLeft > 0) {
                setTimeout(function () { woOpenComboPicker(materialCode, opts, retriesLeft - 1); }, 200);
                return true;
            }
            var diag = !window.CalibraHub
                ? 'window.CalibraHub tanımsız — React bundle yüklenmemiş'
                : 'window.CalibraHub.openCombinationPicker yok — bundle eski: tarayıcı cache silin veya Ctrl+Shift+R';
            flash(diag, false);
            console.error('[WOE]', diag, { CalibraHub: window.CalibraHub });
            return false;
        }
        CalibraHub.openCombinationPicker(materialCode, opts);
        return true;
    }
    function pickConfig() {
        var matCode = (document.getElementById('f-itemCode')?.value || '').trim();
        if (!matCode) { flash('Önce mamul kodu seçiniz.', false); return; }
        var matNameEl  = document.getElementById('f-itemName');
        var cfgCodeEl  = document.getElementById('f-configCode');
        var cfgIdEl    = document.getElementById('f-configId');
        var cfgDescEl  = document.getElementById('f-configDesc');
        woOpenComboPicker(matCode, {
            materialName: matNameEl ? (matNameEl.value || matNameEl.textContent || '').trim() : '',
            currentCode:  cfgCodeEl ? (cfgCodeEl.value || '').trim() : null,
            // onApply: kullanıcı mevcut bir kombinasyon seçti veya "Yeni" tabından üretti.
            // configId, code ve details (feature/value listesi) geri döner.
            onApply: function (configId, code, details) {
                if (cfgCodeEl) cfgCodeEl.value = code || '';
                if (cfgIdEl)   cfgIdEl.value   = (configId != null ? String(configId) : '');
                if (cfgDescEl) cfgDescEl.value = woBuildComboDesc(details);
            },
        });
    }
    function clearPick(kind) {
        if (kind === 'personnel') {
            document.getElementById('f-assignedPersonnelId').value = '';
            document.getElementById('f-personnelDisplay').value = '';
        } else if (kind === 'location') {
            document.getElementById('f-locationId').value = '';
            document.getElementById('f-locationDisplay').value = '';
        } else if (kind === 'routing') {
            document.getElementById('f-routingId').value = '';
            document.getElementById('f-routingCode').value = '';
            // 2026-05-22: f-routingName span'i kaldirildi — ek temizleme gerekmez.
        } else if (kind === 'machine') {
            document.getElementById('f-defaultMachineId').value = '';
            document.getElementById('f-defaultMachineDisplay').value = '';
            // 2026-05-22: f-defaultMachineName span'i kaldirildi — ek temizleme gerekmez.
        } else if (kind === 'config') {
            document.getElementById('f-configCode').value = '';
            document.getElementById('f-configId').value = '';
            document.getElementById('f-configDesc').value = '';
        }
    }
    var _pickBtns = document.querySelectorAll('button[data-pick]');
    console.log('[WOE] Picker butonlari bulundu:', _pickBtns.length,
        Array.from(_pickBtns).map(function (b) { return b.getAttribute('data-pick'); }));
    _pickBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
            var kind = btn.getAttribute('data-pick');
            console.log('[WOE] Picker click:', kind);
            if (kind === 'personnel') pickPersonnel();
            else if (kind === 'location') pickLocation();
            else if (kind === 'routing') pickRouting();
            else if (kind === 'machine') pickMachine();
            else if (kind === 'config') pickConfig();
            else console.warn('[WOE] Bilinmeyen pick kind:', kind);
        });
    });
    document.querySelectorAll('button[data-clear]').forEach(function (btn) {
        btn.addEventListener('click', function () { clearPick(btn.getAttribute('data-clear')); });
    });

    // ── BOM Patlatma (Faz 2) — load + render + explode ──────────────────
    var bomList = document.getElementById('woe-bom-list');
    if (bomList) {
        var bomWoId = parseInt(bomList.getAttribute('data-workorder-id'), 10);

        function fmt(n, d) {
            d = d == null ? 4 : d;
            if (n == null || isNaN(n)) return '—';
            return Number(n).toLocaleString('tr-TR', { minimumFractionDigits: d, maximumFractionDigits: d });
        }
        function escHtml(s) {
            return String(s == null ? '' : s)
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        function renderBomList(items) {
            // Header'ı koru, satırları replace et
            var head = bomList.querySelector('.woe-bom-head');
            bomList.innerHTML = '';
            if (head) bomList.appendChild(head);

            if (!items || items.length === 0) {
                var empty = document.createElement('div');
                empty.className = 'woe-bom-empty src-empty';
                empty.innerHTML = 'Henüz patlatma yapılmadı. <strong>"⚙ Reçeteyi Patlat"</strong> butonuna basarak ürün ağacından bileşen listesini oluştur.';
                bomList.appendChild(empty);
                return;
            }

            items.forEach(function (c) {
                var row = document.createElement('div');
                row.className = 'woe-bom-row';
                var firePct = (Number(c.scrapRate) || 0) * 100;
                row.innerHTML =
                    '<span><strong style="color:var(--woe-accent);">' + escHtml(c.itemCode || ('#' + c.itemId)) + '</strong>' +
                        (c.itemName ? ' · <span style="color:var(--woe-text-muted);">' + escHtml(c.itemName) + '</span>' : '') + '</span>' +
                    '<span style="color:var(--woe-text-muted); font-size:12px;">' + escHtml(c.configCode || '—') + '</span>' +
                    '<span style="text-align:right; font-weight:600;">' + fmt(c.requiredQuantity, 2) + '</span>' +
                    '<span style="text-align:right;">' + fmt(c.issuedQuantity, 2) + '</span>' +
                    '<span style="text-align:right; color:' + (firePct > 0 ? '#f59e0b' : 'var(--woe-text-muted)') + ';">' +
                        (firePct > 0 ? firePct.toFixed(2) + ' %' : '—') + '</span>' +
                    '<span style="color:var(--woe-text-muted);">' + escHtml(c.unitCode || '—') + '</span>' +
                    '<span style="color:var(--woe-text-muted); font-size:12px;">' + escHtml(c.notes || '') + '</span>';
                bomList.appendChild(row);
            });
        }

        async function loadBom() {
            try {
                var r = await fetch('/Production/WorkOrderComponents?workOrderId=' + bomWoId, { credentials: 'same-origin' });
                var list = await r.json();
                renderBomList(Array.isArray(list) ? list : []);
            } catch (ex) {
                flash('Bileşen listesi yüklenemedi: ' + ex.message, false);
            }
        }

        async function explodeBom() {
            var ok = await CalibraAlert.confirm('Reçete patlatılacak. Mevcut bileşen listesi silinecek ve ürün ağacından yeniden oluşturulacak. Devam edilsin mi?',
            { title: 'Reçeteyi Patlat', okText: 'Evet, Patlat', cancelText: 'Vazgeç', danger: true });
        if (!ok) return;
            var btn = document.getElementById('btn-bom-explode');
            if (btn) btn.disabled = true;
            try {
                var token = (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value || '';
                var r = await fetch('/Production/ExplodeBom?workOrderId=' + bomWoId, {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'RequestVerificationToken': token },
                });
                var j = await r.json();
                if (!j.ok) {
                    flash(j.error || 'Patlatma başarısız', false);
                    return;
                }
                flash('Reçete patlatıldı: ' + (j.result?.componentCount || 0) + ' bileşen yazıldı.', true);
                await loadBom();
            } catch (ex) {
                flash('Hata: ' + ex.message, false);
            } finally {
                if (btn) btn.disabled = false;
            }
        }

        document.getElementById('btn-bom-explode')?.addEventListener('click', explodeBom);

        // Reçete tabı açılınca lazy-load
        var bomLoaded = false;
        function maybeLoadBom() {
            if (bomLoaded) return;
            var sec = document.querySelector('.woe-pane-section[data-pane="recete"]');
            if (sec && sec.classList.contains('is-active')) {
                bomLoaded = true;
                loadBom();
            }
        }
        document.querySelectorAll('.woe-nav-btn').forEach(function (b) {
            b.addEventListener('click', function () { setTimeout(maybeLoadBom, 50); });
        });
        setTimeout(maybeLoadBom, 100);
    }

    // ── Sol nav "Widget Sahaları" butonunu admin tanimli ilk grup adiyla guncelle.
    //   Form schema'sini /api/widgets/forms/{code}/schema'dan cek; group widget
    //   varsa nav buton label'ini onun title'i ile degistir (yoksa "Ek Sahalar" kalsin).
    async function updateWidgetNavLabel() {
        try {
            const resp = await fetch('/api/widgets/forms/WORK_ORDER_EDIT/schema', { credentials: 'same-origin' });
            if (!resp.ok) return;
            const data = await resp.json();
            const widgets = (data && (data.widgets || data.items || data)) || [];
            const arr = Array.isArray(widgets) ? widgets : [];
            const groups = arr.filter(w =>
                String((w.dataType || w.DataType) || '').toLowerCase() === 'group');
            if (groups.length === 0) return;
            // Ilk grubun label/title'i (sortOrder ile siralanmis ilk eleman)
            groups.sort((a, b) => ((a.sortOrder || a.SortOrder || 0) - (b.sortOrder || b.SortOrder || 0)));
            const first = groups[0];
            const label = first.label || first.Label || first.title || first.Title || null;
            if (!label) return;
            const navBtn = document.querySelector('.woe-nav-btn[data-tab="widgets"] span');
            if (navBtn) navBtn.textContent = label;
        } catch (_) { /* sessiz */ }
    }
    updateWidgetNavLabel();

    // ── DynamicWidgetRenderer mount (Material Card ile ayni pattern) ──
    // Bundle React Shell modunda hazir, workspace iframe modunda dinamik yuklenir.
    (function initDynRenderer() {
        var el = document.getElementById('woeDynamicWidgets');
        if (!el) return;

        function doMount() {
            if (!window.CalibraHub || !window.CalibraHub.mountDynamicWidgetRenderer) {
                console.warn('[WOE] mountDynamicWidgetRenderer bulunamadi');
                return;
            }
            try {
                window._woeDynRenderer = window.CalibraHub.mountDynamicWidgetRenderer(el, {
                    formCode: el.getAttribute('data-form-code') || 'WORK_ORDER_EDIT',
                    recordId: el.getAttribute('data-record-id') || '',
                    classPrefix: 'woe',
                    containerId: 'woeDynamicWidgetsCard'
                });
            } catch (e) { console.warn('[WOE] mountDynamicWidgetRenderer hatasi:', e); }
        }

        if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
            // Bundle zaten yuklu (React Shell)
            doMount();
        } else {
            // Workspace iframe — bundle dinamik yukle
            var cssUrl = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
            var jsUrl  = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';

            if (!document.querySelector('link[data-woe-bundle]')) {
                var link = document.createElement('link');
                link.rel = 'stylesheet'; link.href = cssUrl;
                link.setAttribute('data-woe-bundle', '1');
                document.head.appendChild(link);
            }
            if (!document.querySelector('script[data-woe-bundle]')) {
                var script = document.createElement('script');
                script.src = jsUrl;
                script.setAttribute('data-woe-bundle', '1');
                script.onload = doMount;
                script.onerror = function () { console.warn('[WOE] bundle yuklenemedi'); };
                document.head.appendChild(script);
            } else {
                // Diger script tag'i yuklenmis olabilir, tekrar dene
                var tries = 0;
                var tm = setInterval(function () {
                    tries++;
                    if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
                        clearInterval(tm); doMount();
                    } else if (tries >= 50) { clearInterval(tm); }
                }, 100);
            }
        }
    })();
})();

/* ── Tab switch — sol nav + sağ pane ── */
(function () {
    const navBtns = document.querySelectorAll('.woe-nav-btn');
    const panes   = document.querySelectorAll('.woe-pane-section');
    if (!navBtns.length || !panes.length) return;

    function activate(tabKey) {
        navBtns.forEach(b => b.classList.toggle('is-active', b.dataset.tab === tabKey));
        panes.forEach(p => p.classList.toggle('is-active', p.dataset.pane === tabKey));
    }

    navBtns.forEach(btn => {
        btn.addEventListener('click', () => activate(btn.dataset.tab));
    });

    /* Hash deep-link: #genel | #makine | #recete | #kaynak | #revize | #widgets */
    function applyHash() {
        const h = (location.hash || '').replace('#', '').trim();
        if (!h) return;
        const exists = Array.from(navBtns).some(b => b.dataset.tab === h);
        if (exists) activate(h);
    }
    window.addEventListener('hashchange', applyHash);
    applyHash();
})();

/* ── Birim dropdown'u (2026-05-20 sonrasi) ────────────────────────────────────
   Eski davranış: tüm sistem birimleri page-load'da yüklenirdi.
   Yeni davranış: yalnız seçili mamulün kartında tanımlı birimler — master + alternat.
   loadItemUnitsToDropdown (resolveItem icinde) cagrilir. Edit mode'da Model.UnitId
   data-preselect attribute'unde tutulur; resolveItem ilk render'da bunu honor eder.
   Mamul kodu henuz secilmemis ise placeholder "— Birim —" gosterilir. */

/* ── Kaynak Sipariş Ekleme — modal akışı ──────────────────────────────────────
   Mevcut iş emrine sales order kalemini bağlar. Backend
   /Production/CreateFromSalesLine endpoint'i targetWorkOrderId parametresi ile
   AddSourceAsync + PlannedQuantity güncellemesini birlikte yapar (toplama). */
(function () {
    const modal      = document.getElementById('addSourceModal');
    const btnOpen    = document.getElementById('btn-add-source');
    const btnClose   = document.getElementById('btn-add-source-close');
    const btnCancel  = document.getElementById('btn-add-source-cancel');
    const btnSubmit  = document.getElementById('btn-add-source-submit');
    const docSel     = document.getElementById('add-src-doc');
    const lineSel    = document.getElementById('add-src-line');
    const lineInfo   = document.getElementById('add-src-line-info');
    const qtyInput   = document.getElementById('add-src-qty');
    if (!modal || !btnOpen) return;

    const workOrderId = @(Model?.Id ?? 0);
    let docsLoaded = false;
    let currentLines = [];

    function open() {
        modal.style.display = 'flex';
        if (!docsLoaded) loadDocs();
    }
    function close() {
        modal.style.display = 'none';
        docSel.value = '';
        lineSel.innerHTML = '<option value="">Önce sipariş seç</option>';
        lineSel.disabled = true;
        lineInfo.textContent = '';
        qtyInput.value = '';
        btnSubmit.disabled = true;
    }

    async function loadDocs() {
        try {
            // SADECE satış SIPARIŞLERİ (Document.type = satis_siparisi) — teklifler hariç.
            // Cancelled/Rejected statüsündekiler client-side filtre ile haricte tutulur.
            const r = await fetch('/Sales/GetOrdersList', { credentials: 'same-origin' });
            const list = await r.json();
            docSel.innerHTML = '<option value="">— Sipariş seç —</option>';
            (Array.isArray(list) ? list : []).forEach(function (d) {
                const status = String(d.status || d.Status || '').toLowerCase();
                if (status === 'cancelled' || status === 'rejected') return;
                const opt = document.createElement('option');
                opt.value = String(d.id || d.Id);
                const num = d.documentNumber || d.DocumentNumber || ('#' + opt.value);
                const cust = d.contactName || d.ContactName || '';
                opt.textContent = num + (cust ? ' · ' + cust : '');
                docSel.appendChild(opt);
            });
            docsLoaded = true;
        } catch (e) {
            console.error('[WOE-AddSrc] Sipariş listesi yüklenemedi:', e);
            docSel.innerHTML = '<option value="">(Yüklenemedi — yenileyin)</option>';
        }
    }

    async function loadLines(docId) {
        lineSel.disabled = true;
        lineSel.innerHTML = '<option value="">Yükleniyor…</option>';
        lineInfo.textContent = '';
        currentLines = [];
        if (!docId) {
            lineSel.innerHTML = '<option value="">Önce sipariş seç</option>';
            return;
        }
        try {
            const r = await fetch('/Sales/GetQuote?id=' + encodeURIComponent(docId), { credentials: 'same-origin' });
            const data = await r.json();
            currentLines = Array.isArray(data?.lines) ? data.lines : (Array.isArray(data?.Lines) ? data.Lines : []);
            renderLines();
        } catch (e) {
            console.error('[WOE-AddSrc] Sipariş satırları yüklenemedi:', e);
            lineSel.innerHTML = '<option value="">(Hata — yenileyin)</option>';
        }
    }

    // İş emrinin mamul + konfigürasyon kimliklerini oku — satır filtresi için.
    function woMatchKey() {
        var itemId = parseInt(document.getElementById('f-itemId')?.value || '0', 10) || 0;
        var configIdRaw = document.getElementById('f-configId')?.value;
        var configId = (configIdRaw && configIdRaw !== '') ? (parseInt(configIdRaw, 10) || null) : null;
        return { itemId: itemId, configId: configId };
    }

    // Bir satırın WO ile eşleşip eşleşmediği — itemId zorunlu, configId tam eşleşme
    // (WO config'siz ise satır da config'siz olmalı; WO config'li ise aynı configId).
    function lineMatchesWo(l, wo) {
        var lItemId   = Number(l.itemId       || l.ItemId       || 0);
        var lConfigId = Number(l.combinationId || l.CombinationId || 0) || null;
        if (!wo.itemId || lItemId !== wo.itemId) return false;
        // Config eşleşmesi: ikisi de boş VEYA ikisi de aynı id
        if (wo.configId == null && lConfigId == null) return true;
        return wo.configId === lConfigId;
    }

    // Satır listesini render et — DAİMA mamul + konfigürasyon ile eşleşen satırları gösterir.
    // Eşleşme zorunlu: WO'nun mamulü çözülmemişse hiç satır listelenmez.
    function renderLines() {
        lineSel.innerHTML = '';
        lineInfo.textContent = '';
        if (!currentLines || currentLines.length === 0) {
            lineSel.innerHTML = '<option value="">Bu siparişte kalem yok</option>';
            lineSel.disabled = true;
            return;
        }
        var wo = woMatchKey();
        if (!wo.itemId) {
            lineSel.innerHTML = '<option value="">Önce iş emri Mamul Kodu doldurulmalı</option>';
            lineSel.disabled = true;
            lineInfo.innerHTML = '<span style="color:#f59e0b;">⚠ Eşleşme için Genel sekmesinden Mamul Kodu seçin.</span>';
            return;
        }
        var visible = currentLines.filter(function (l) { return lineMatchesWo(l, wo); });

        if (visible.length === 0) {
            lineSel.innerHTML = '<option value="">Mamul/konfigürasyon ile eşleşen satır yok</option>';
            lineSel.disabled = true;
            lineInfo.textContent = currentLines.length + ' satır var, hiçbiri iş emrinin mamulü ile eşleşmiyor.';
            return;
        }

        lineSel.innerHTML = '<option value="">— Satır seç —</option>';
        visible.forEach(function (l) {
            var id    = l.id || l.Id;
            var code  = l.materialCode || l.MaterialCode || '';
            var name  = l.materialName || l.MaterialName || '';
            var qty   = Number(l.quantity || l.Quantity || 0);
            var combo = l.combinationCode || l.CombinationCode || '';
            var opt   = document.createElement('option');
            opt.value = String(id);
            opt.dataset.qty = String(qty);
            opt.dataset.code = code;
            opt.dataset.name = name;
            var label = '#' + id + ' — ' + (code || '?');
            if (combo) label += ' [' + combo + ']';
            if (name)  label += ' / ' + name;
            label += ' (' + qty.toFixed(2) + ')';
            opt.textContent = label;
            lineSel.appendChild(opt);
        });
        lineSel.disabled = false;
        lineInfo.textContent = visible.length + ' / ' + currentLines.length + ' satır eşleşti.';
    }

    async function onLineChange() {
        const opt = lineSel.options[lineSel.selectedIndex];
        if (!opt || !opt.value) {
            lineInfo.textContent = '';
            qtyInput.value = '';
            btnSubmit.disabled = true;
            return;
        }
        const lineId = Number(opt.value);
        const totalQty = Number(opt.dataset.qty || 0);
        // Allocated qty (zaten başka iş emirlerine atanmış miktar) — kalan açık
        let allocated = 0;
        try {
            const r = await fetch('/Production/AllocatedQuantity?sourceLineId=' + lineId, { credentials: 'same-origin' });
            const data = await r.json();
            allocated = Number(data?.allocated || 0);
        } catch (e) { /* ignore */ }
        const remaining = totalQty - allocated;
        lineInfo.textContent = 'Toplam: ' + totalQty.toFixed(2) + ' · Atanmış: ' + allocated.toFixed(2) + ' · Kalan: ' + remaining.toFixed(2);
        qtyInput.value = remaining > 0 ? remaining.toFixed(4) : '';
        btnSubmit.disabled = remaining <= 0;
    }

    // Rapor §6.6 — native alert → CalibraAlert/toast fallback
    function _woNotify(msg, kind) {
        if (window.CalibraAlert && CalibraAlert[kind]) { CalibraAlert[kind](msg); return; }
        if (window.CalibraHub && CalibraHub.toast) { CalibraHub.toast(msg, kind === 'error' ? 'err' : (kind === 'warn' ? 'warn' : 'ok')); return; }
        alert(msg);
    }

    async function submit() {
        const docId  = Number(docSel.value);
        const lineId = Number(lineSel.value);
        const qty    = Number(qtyInput.value);
        if (!docId || !lineId) { _woNotify('Sipariş ve satır seçin.', 'warn'); return; }
        if (!qty || qty <= 0) { _woNotify('Geçerli miktar girin.', 'warn'); return; }

        btnSubmit.disabled = true;
        btnSubmit.textContent = 'Ekleniyor…';
        try {
            const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            const token = tokenEl ? tokenEl.value : '';
            const body = {
                sourceDocumentId: docId,
                sourceLineId: lineId,
                quantity: qty,
                targetWorkOrderId: workOrderId  // Mevcut emire ekle (toplama)
            };
            const r = await fetch('/Production/CreateFromSalesLine', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                credentials: 'same-origin',
                body: JSON.stringify(body)
            });
            const data = await r.json();
            if (data?.ok) {
                // Sayfayı yenile — yeni source list ve PlannedQuantity gözüksün
                location.reload();
            } else {
                _woNotify('Hata: ' + (data?.error || 'Bilinmeyen.'), 'error');
                btnSubmit.disabled = false;
                btnSubmit.textContent = 'Ekle';
            }
        } catch (e) {
            _woNotify('İstek hatası: ' + e.message, 'error');
            btnSubmit.disabled = false;
            btnSubmit.textContent = 'Ekle';
        }
    }

    btnOpen.addEventListener('click', open);
    btnClose.addEventListener('click', close);
    btnCancel.addEventListener('click', close);
    modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.style.display === 'flex') close();
    });
    docSel.addEventListener('change', function () { loadLines(docSel.value); });
    lineSel.addEventListener('change', onLineChange);
    btnSubmit.addEventListener('click', submit);
})();

// ── Rota / Operasyonlar tab — WorkOrderOperation listesi ──────────────
(function () {
    const rotaList = document.getElementById('woe-rota-list');
    if (!rotaList) return; // isNew durumunda render olmuyor

    const woId = parseInt(rotaList.getAttribute('data-workorder-id'), 10);
    const canEdit = rotaList.getAttribute('data-can-edit') === '1';

    function token() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function flashRota(msg, ok) {
        // Use existing flash if present
        if (typeof window.calibraToast === 'function') return window.calibraToast(msg, ok ? 'ok' : 'err');
        const host = document.getElementById('woe-toast-host');
        if (!host) { console[ok ? 'log' : 'error'](msg); return; }
        const el = document.createElement('div');
        el.className = 'woe-toast ' + (ok ? 'woe-toast--ok' : 'woe-toast--err');
        el.textContent = msg;
        host.appendChild(el);
        setTimeout(() => el.remove(), 4000);
    }

    function statusLabel(s) {
        switch (Number(s) || 0) {
            case 0: return 'Bekliyor';
            case 1: return 'Devam';
            case 2: return 'Tamam';
            case 3: return 'Atlandı';
            default: return '?';
        }
    }

    function fmtDuration(d, unit) {
        if (d == null) return '—';
        const u = (Number(unit) === 2) ? 'sa' : 'dk';
        return Number(d).toFixed(2) + ' ' + u;
    }

    function fmtQty(produced, scrap) {
        const p = Number(produced || 0).toFixed(2);
        const s = Number(scrap || 0).toFixed(2);
        return p + ' / ' + s;
    }

    async function loadRota() {
        try {
            const r = await fetch('/Production/WorkOrderOperations?workOrderId=' + woId, { credentials: 'same-origin' });
            const list = await r.json();
            renderRota(list || []);
        } catch (ex) {
            flashRota('Rota yüklenemedi: ' + ex.message, false);
        }
    }

    function renderRota(items) {
        // Header'ı koru, satırları replace et
        const head = rotaList.querySelector('.woe-rota-head');
        rotaList.innerHTML = '';
        if (head) rotaList.appendChild(head);

        if (!items || items.length === 0) {
            const empty = document.createElement('div');
            empty.className = 'woe-rota-empty src-empty';
            empty.textContent = 'Operasyon yok. "Rota\'dan Patlat" ile rota şablonundan kopyalayın veya manuel ekleyin.';
            rotaList.appendChild(empty);
            return;
        }

        for (const op of items) {
            const row = document.createElement('div');
            row.className = 'woe-rota-row';
            row.dataset.id = op.id;
            row.dataset.status = String(op.status || 0);
            row.dataset.opData = JSON.stringify(op);   // drag-drop save için snapshot

            // 2026-05-22: Drag handle — sadece düzenlenebilir + Bekliyor (status=0) için aktif.
            // Diğer durumlarda boş div (sıra korunsun, layout kaymasın).
            const dragCell = document.createElement('div');
            if (canEdit && (op.status || 0) === 0) {
                dragCell.className = 'woe-rota-drag';
                dragCell.draggable = true;
                dragCell.title = 'Sürükle-bırak ile sıralamayı değiştir';
                dragCell.textContent = '⋮⋮';
                attachDragHandlers(dragCell, row);
            }
            row.appendChild(dragCell);

            // Sıra
            const seq = document.createElement('input');
            seq.type = 'number'; seq.min = '0'; seq.step = '1';
            seq.value = op.sequence ?? 0;
            seq.readOnly = !canEdit || (op.status > 0);
            row.appendChild(seq);

            // Operasyon (kod + ad — şimdilik salt-okur display, değiştirme için silip yeniden eklemek)
            const opCell = document.createElement('span');
            opCell.textContent = (op.operationCode ? op.operationCode + ' · ' : '') + (op.operationName || '#' + op.operationId);
            row.appendChild(opCell);

            // Makine — düzenlenebilirse pickerli buton, değilse salt-okur span
            const machCell = document.createElement('span');
            const machText = op.machineCode
                ? (op.machineCode + (op.machineName ? ' · ' + op.machineName : ''))
                : '— atanmadı';
            const opStatus = op.status || 0;
            if (canEdit && opStatus === 0) {
                // Tıklanabilir buton — picker ile değiştir
                const machBtn = document.createElement('button');
                machBtn.type = 'button';
                machBtn.className = 'wo-mach-btn';
                machBtn.title = 'Makine atamak/değiştirmek için tıklayın';
                machBtn.textContent = machText;
                machBtn.addEventListener('click', function () { pickMachineForOp(op); });
                machCell.appendChild(machBtn);
            } else {
                machCell.textContent = machText;
            }
            row.appendChild(machCell);

            // Süre
            const durCell = document.createElement('span');
            durCell.textContent = fmtDuration(op.plannedDuration, op.durationUnit);
            row.appendChild(durCell);

            // Üretilen / Fire
            const qtyCell = document.createElement('span');
            qtyCell.textContent = fmtQty(op.producedQuantity, op.scrapQuantity);
            row.appendChild(qtyCell);

            // Durum
            const stCell = document.createElement('span');
            const stBadge = document.createElement('span');
            stBadge.className = 'woe-rota-status woe-rota-status-' + (op.status ?? 0);
            stBadge.textContent = statusLabel(op.status);
            stCell.appendChild(stBadge);
            row.appendChild(stCell);

            // Sil
            const delWrap = document.createElement('span');
            if (canEdit && (op.status || 0) === 0) {
                const del = document.createElement('button');
                del.type = 'button'; del.className = 'rota-del'; del.title = 'Sil';
                del.textContent = '×';
                del.addEventListener('click', () => removeOp(op.id));
                delWrap.appendChild(del);
            }
            row.appendChild(delWrap);

            rotaList.appendChild(row);
        }
    }

    async function removeOp(opId) {
        var ok = await CalibraAlert.confirm('Bu operasyonu silmek istediğinize emin misiniz?',
            { title: 'Operasyonu Sil', okText: 'Evet, Sil', cancelText: 'Vazgeç', danger: true });
        if (!ok) return;
        try {
            const r = await fetch('/Production/DeleteWorkOrderOperation/' + opId, {
                method: 'POST', credentials: 'same-origin',
                headers: { 'RequestVerificationToken': token() }
            });
            const j = await r.json();
            if (!j.ok) { flashRota(j.error || 'Silme başarısız', false); return; }
            flashRota('Silindi', true);
            await loadRota();
        } catch (ex) {
            flashRota('Hata: ' + ex.message, false);
        }
    }

    // ── 2026-05-22 Drag-drop reorder ──────────────────────────────────────
    // HTML5 native drag: handle elementi (⋮⋮) draggable. Drop sirasinda satir
    // DOM'da tasinir; sonra her satirin sequence'i (10/20/30...) yeniden hesaplanip
    // backend'e SaveWorkOrderOperation cagrisiyla persist edilir. Sadece Bekliyor
    // (status=0) satirlar arasinda yer degisikligi olabilir — baslamis operasyonlar
    // (status>0) handle'a sahip degil, drop target da degil.
    let _draggingRow = null;

    function attachDragHandlers(handle, row) {
        handle.addEventListener('dragstart', function (e) {
            _draggingRow = row;
            row.classList.add('is-dragging');
            try { e.dataTransfer.effectAllowed = 'move'; e.dataTransfer.setData('text/plain', row.dataset.id); } catch {}
        });
        handle.addEventListener('dragend', function () {
            row.classList.remove('is-dragging');
            _draggingRow = null;
            // Tüm drop-target göstergelerini temizle
            rotaList.querySelectorAll('.is-drop-target').forEach(function (r) { r.classList.remove('is-drop-target'); });
        });
        // Row üzerinde dragover/drop — handle dışından da bırakılabilsin
        row.addEventListener('dragover', function (e) {
            if (!_draggingRow || _draggingRow === row) return;
            // Yalnızca status=0 satırlar üzerine bırakılabilir (canEdit + Bekliyor)
            if ((row.dataset.status || '0') !== '0') return;
            e.preventDefault();
            try { e.dataTransfer.dropEffect = 'move'; } catch {}
            row.classList.add('is-drop-target');
        });
        row.addEventListener('dragleave', function () {
            row.classList.remove('is-drop-target');
        });
        row.addEventListener('drop', async function (e) {
            if (!_draggingRow || _draggingRow === row) return;
            if ((row.dataset.status || '0') !== '0') return;
            e.preventDefault();
            row.classList.remove('is-drop-target');
            // DOM'da yerini değiştir — drop edilen satır _draggingRow'un ÜSTÜNE konur
            // (klasik liste sıralama davranışı). Bottom drop için ekstra hesap yapmıyoruz —
            // kullanıcı hedef satırın üstüne bırakıyor olarak yorumlanır.
            rotaList.insertBefore(_draggingRow, row);
            await persistRotaOrder();
        });
    }

    async function persistRotaOrder() {
        // Yeni DOM sırasına göre sequence'leri 10, 20, 30… yeniden hesapla ve persist et.
        // SaveWorkOrderOperation tüm alanları korur, sadece sequence değişir.
        const rows = Array.from(rotaList.querySelectorAll('.woe-rota-row:not(.woe-rota-head)'));
        let seq = 10;
        const updates = [];
        for (const r of rows) {
            const raw = r.dataset.opData;
            if (!raw) continue;
            const op = JSON.parse(raw);
            const newSeq = seq;
            seq += 10;
            if (op.sequence === newSeq) continue;   // değişmemiş, skip
            updates.push({ op, newSeq });
        }
        if (updates.length === 0) return;
        try {
            // Sıralı çağrı — paralel save sırasız tamamlanabilir (race) ama API zaten
            // her satırı bağımsız update ediyor, fark etmez. Yine de sıralı daha güvenli.
            for (const u of updates) {
                await fetch('/Production/SaveWorkOrderOperation', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                    body: JSON.stringify({
                        id: u.op.id, workOrderId: woId,
                        sequence: u.newSeq,
                        operationId: u.op.operationId,
                        machineId: u.op.machineId ?? null,
                        plannedDuration: u.op.plannedDuration ?? null,
                        durationUnit: u.op.durationUnit ?? 1,
                        notes: u.op.notes ?? null,
                    }),
                });
            }
            flashRota('Sıralama güncellendi.', true);
            await loadRota();   // backend'den temiz reload
        } catch (ex) {
            flashRota('Sıralama kaydedilemedi: ' + ex.message, false);
            await loadRota();   // mevcut state'e dön
        }
    }

    async function explodeFromRouting() {
        const routingIdEl = document.getElementById('f-routingId');
        const routingId = routingIdEl ? parseInt(routingIdEl.value || '0', 10) : 0;
        if (!routingId) {
            flashRota('Önce Genel sekmesinden Rota seçin (veya emir Released aşamasına gelince otomatik patlatılır).', false);
            return;
        }
        var ok = await CalibraAlert.confirm('Rota şablonundaki operasyonlar bu iş emrine kopyalanacak. Mevcut operasyonlar silinecek. Devam edilsin mi?',
            { title: 'Rotadan Patlat', okText: 'Evet, Patlat', cancelText: 'Vazgeç', danger: true });
        if (!ok) return;
        try {
            const r = await fetch('/Production/ExplodeFromRouting', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                body: JSON.stringify({ workOrderId: woId, routingId })
            });
            const j = await r.json();
            if (!j.ok) { flashRota(j.error || 'Patlatma başarısız', false); return; }
            flashRota('Operasyonlar kopyalandı.', true);
            await loadRota();
        } catch (ex) {
            flashRota('Hata: ' + ex.message, false);
        }
    }

    // Operasyon satırına makine ata/değiştir — rehber picker + SaveWorkOrderOperation
    // (mevcut tüm alanları korur, sadece machineId değişir).
    function pickMachineForOp(op) {
        if (typeof window.wpicker !== 'function') {
            flashRota('Picker hazır değil — sayfayı yenileyin.', false);
            return;
        }
        window.wpicker({
            title: 'Makine Rehberi (Op: ' + (op.operationCode || '#' + op.operationId) + ')',
            url: '/Logistics/GetAllMachines',
            codeOf:  function (m) { return m.machineCode || ''; },
            nameOf:  function (m) { return m.machineName || ''; },
            metaOf:  function (m) { return m.locationName || m.locationCode || ''; },
            badgeOf: function (m) { return m.isActive === false ? 'Pasif' : ''; },
            filter:  function (m) { return m.isActive !== false; },
            onSelect: async function (m) {
                try {
                    const r = await fetch('/Production/SaveWorkOrderOperation', {
                        method: 'POST', credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                        body: JSON.stringify({
                            id: op.id, workOrderId: woId,
                            sequence: op.sequence, operationId: op.operationId,
                            machineId: m.id || null,
                            plannedDuration: op.plannedDuration ?? null,
                            durationUnit: op.durationUnit ?? 1,
                            notes: op.notes ?? null,
                        }),
                    });
                    const j = await r.json();
                    if (!j.ok) { flashRota(j.error || 'Makine atama başarısız', false); return; }
                    flashRota('Makine atandı: ' + (m.machineCode || ''), true);
                    await loadRota();
                } catch (ex) {
                    flashRota('Hata: ' + ex.message, false);
                }
            },
        });
    }

    // Manuel operasyon ekleme — satır doğrudan tabloya eklenir (modal yok).
    // Akış: + buton → boş editör satırı → hücre üzerinden rehber seç → ✓ kaydet.
    function addBlankRow() {
        // Zaten açık bir edit satırı varsa ona odaklan, yeni ekleme
        var existing = rotaList.querySelector('.woe-rota-row--edit');
        if (existing) {
            existing.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            var firstInp = existing.querySelector('.woe-edit-pick-btn');
            if (firstInp) firstInp.focus();
            return;
        }

        // Sonraki sıra numarası (mevcut satırlardan hesapla)
        var savedRows = rotaList.querySelectorAll('.woe-rota-row:not(.woe-rota-head):not(.woe-rota-row--edit)');
        var nextSeq = (savedRows.length + 1) * 10;

        // Seçili operasyon ve makine durumu
        var pendingOp = null;   // { id, code, name }
        var pendingMach = null; // { id, code, name }

        var row = document.createElement('div');
        row.className = 'woe-rota-row woe-rota-row--edit';

        // 1. Drag placeholder (kaydedilmemiş satırda drag yok)
        row.appendChild(document.createElement('div'));

        // 2. Sıra inputu
        var seqInp = document.createElement('input');
        seqInp.type = 'number'; seqInp.min = '1'; seqInp.step = '1'; seqInp.value = nextSeq;
        seqInp.className = 'woe-edit-inp';
        seqInp.title = 'Sıra';
        row.appendChild(seqInp);

        // Yardımcı: pick cell oluştur (🔍 buton + ad etiketi)
        function makePick(placeholder, onPick) {
            var wrap = document.createElement('div');
            wrap.className = 'woe-edit-pick';

            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'woe-edit-pick-btn';
            btn.title = 'Seçmek için tıklayın';
            btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>';

            var lbl = document.createElement('span');
            lbl.className = 'woe-edit-pick-name woe-edit-pick-name--empty';
            lbl.textContent = placeholder;

            btn.addEventListener('click', function () { onPick(btn, lbl); });

            wrap.appendChild(btn);
            wrap.appendChild(lbl);
            return { wrap, btn, lbl };
        }

        // 3. Operasyon pick cell
        var opPick = makePick('Operasyon seçin…', function (btn, lbl) {
            if (typeof window.wpicker !== 'function') { flashRota('Picker hazır değil.', false); return; }
            window.wpicker({
                title: 'Operasyon Seç',
                url: '/Production/OperationsList?includeInactive=false',
                codeOf:  function (o) { return o.code || ''; },
                nameOf:  function (o) { return o.name || ''; },
                metaOf:  function (o) { return o.description || ''; },
                badgeOf: function (o) { return o.isActive === false ? 'Pasif' : ''; },
                filter:  function (o) { return o.isActive !== false; },
                onSelect: function (o) {
                    pendingOp = { id: o.id, code: o.code, name: o.name };
                    lbl.textContent = o.code + ' · ' + o.name;
                    lbl.classList.remove('woe-edit-pick-name--empty');
                    btn.classList.remove('is-invalid');
                },
            });
        });
        row.appendChild(opPick.wrap);

        // 4. Makine pick cell (opsiyonel)
        var machPick = makePick('— opsiyonel', function (btn, lbl) {
            if (typeof window.wpicker !== 'function') { flashRota('Picker hazır değil.', false); return; }
            window.wpicker({
                title: 'Makine Seç',
                url: '/Logistics/GetAllMachines',
                codeOf:  function (m) { return m.machineCode || ''; },
                nameOf:  function (m) { return m.machineName || ''; },
                metaOf:  function (m) { return m.locationName || m.locationCode || ''; },
                badgeOf: function (m) { return m.isActive === false ? 'Pasif' : ''; },
                filter:  function (m) { return m.isActive !== false; },
                onSelect: function (m) {
                    pendingMach = { id: m.id, code: m.machineCode, name: m.machineName };
                    lbl.textContent = m.machineCode + (m.machineName ? ' · ' + m.machineName : '');
                    lbl.classList.remove('woe-edit-pick-name--empty');
                },
            });
        });
        row.appendChild(machPick.wrap);

        // 5. Süre inputu
        var durInp = document.createElement('input');
        durInp.type = 'number'; durInp.min = '0'; durInp.step = '0.01'; durInp.placeholder = 'dk';
        durInp.className = 'woe-edit-inp';
        durInp.title = 'Planlanan süre (dk)';
        row.appendChild(durInp);

        // 6-7. Üretilen / Durum (boş — kaydedilmemiş satırda yok)
        row.appendChild(document.createElement('span'));
        row.appendChild(document.createElement('span'));

        // 8. ✓ Kaydet + × İptal butonları
        var actCell = document.createElement('div');
        actCell.style.cssText = 'display:flex; gap:4px; align-items:center; justify-content:center;';

        var saveBtn = document.createElement('button');
        saveBtn.type = 'button'; saveBtn.className = 'rota-save-btn'; saveBtn.title = 'Kaydet (Enter)';
        saveBtn.textContent = '✓';

        var cancelBtn = document.createElement('button');
        cancelBtn.type = 'button'; cancelBtn.className = 'rota-del'; cancelBtn.title = 'İptal (Esc)';
        cancelBtn.textContent = '×';

        actCell.appendChild(saveBtn);
        actCell.appendChild(cancelBtn);
        row.appendChild(actCell);

        // Boş mesajı kaldır, satırı ekle
        var emptyEl = rotaList.querySelector('.woe-rota-empty');
        if (emptyEl) emptyEl.remove();
        rotaList.appendChild(row);
        row.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        // Enter ile kaydet, Esc ile iptal
        row.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); saveBtn.click(); }
            if (e.key === 'Escape') { cancelBtn.click(); }
        });

        cancelBtn.addEventListener('click', function () {
            row.remove();
            if (!rotaList.querySelector('.woe-rota-row:not(.woe-rota-head)')) {
                var empty = document.createElement('div');
                empty.className = 'woe-rota-empty src-empty';
                empty.textContent = 'Operasyon yok. "Rota\'dan Patlat" ile rota şablonundan kopyalayın veya manuel ekleyin.';
                rotaList.appendChild(empty);
            }
        });

        saveBtn.addEventListener('click', async function () {
            if (!pendingOp) {
                flashRota('Önce bir operasyon seçin.', false);
                opPick.btn.classList.add('is-invalid');
                setTimeout(function () { opPick.btn.classList.remove('is-invalid'); }, 1800);
                return;
            }
            var seq = parseInt(seqInp.value, 10);
            if (Number.isNaN(seq) || seq < 1) { flashRota('Geçersiz sıra numarası.', false); seqInp.focus(); return; }
            var durRaw = durInp.value;
            var plannedDuration = (durRaw === '' || durRaw == null) ? null : Number(durRaw);

            saveBtn.disabled = true;
            try {
                var r = await fetch('/Production/SaveWorkOrderOperation', {
                    method: 'POST', credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token() },
                    body: JSON.stringify({
                        id: 0, workOrderId: woId,
                        sequence: seq, operationId: pendingOp.id,
                        machineId: pendingMach ? pendingMach.id : null,
                        plannedDuration: plannedDuration,
                        durationUnit: 1,
                        notes: null,
                    }),
                });
                var j = await r.json();
                if (!j.ok) { flashRota(j.error || 'Kayıt başarısız', false); saveBtn.disabled = false; return; }
                flashRota('Operasyon eklendi.', true);
                await loadRota();
            } catch (ex) {
                flashRota('Hata: ' + ex.message, false);
                saveBtn.disabled = false;
            }
        });
    }

    const explBtn = document.getElementById('btn-rota-explode');
    if (explBtn) explBtn.addEventListener('click', explodeFromRouting);
    const addBtn = document.getElementById('btn-rota-add');
    if (addBtn) addBtn.addEventListener('click', addBlankRow);

    // Tab açılınca lazy-load: data attribute ile tek seferlik flag
    let loaded = false;
    function maybeLoad() {
        if (loaded) return;
        const rotaSection = document.querySelector('.woe-pane-section[data-pane="rota"]');
        if (rotaSection && rotaSection.classList.contains('is-active')) {
            loaded = true;
            loadRota();
        }
    }
    document.querySelectorAll('.woe-nav-btn').forEach(btn => {
        btn.addEventListener('click', () => setTimeout(maybeLoad, 50));
    });
    // Eğer rota tabı açık başlıyorsa direkt yükle
    setTimeout(maybeLoad, 100);
})();
</script>
}
