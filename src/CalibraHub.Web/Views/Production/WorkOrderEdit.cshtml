@model CalibraHub.Application.Contracts.WorkOrderDto
@using CalibraHub.Domain.Enums
@{
    var isNew = Model is null;
    ViewData["Title"] = isNew ? "Yeni İş Emri" : $"İş Emri: {Model!.OrderNumber}";
    ViewData["FormCode"] = "WORK_ORDER";
    ViewData["BodyClass"] = "page-work-order-edit";

    string Iso(DateTime? d) => d?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm") ?? "";

    var status = Model?.Status ?? WorkOrderStatus.Planned;
    var canEditPlan = status == WorkOrderStatus.Planned;
    var canRelease  = status == WorkOrderStatus.Planned;
    var canStart    = status == WorkOrderStatus.Released;
    var canComplete = status == WorkOrderStatus.InProgress;
    var canClose    = status == WorkOrderStatus.Completed;
    var canCancel   = status is WorkOrderStatus.Planned or WorkOrderStatus.Released or WorkOrderStatus.InProgress or WorkOrderStatus.Completed;
    var canRevise   = !isNew && status is not WorkOrderStatus.Planned and not WorkOrderStatus.Closed and not WorkOrderStatus.Cancelled;
}

@section Styles {
<style>
/* ── Tema değişkenleri (light default) ── */
.woe-page {
    --woe-bg:           #f8fafc;
    --woe-surface:      #ffffff;
    --woe-surface2:     #f1f5f9;
    --woe-border:       #e2e8f0;
    --woe-border-light: #f1f5f9;
    --woe-text:         #0f172a;
    --woe-text-muted:   #64748b;
    --woe-input-bg:     #ffffff;
    --woe-input-disabled:#f8fafc;
    --woe-accent:       var(--theme-accent, #2563eb);
    --woe-toast-ok-bg:  #d1fae5;
    --woe-toast-ok-tx:  #065f46;
    --woe-toast-er-bg:  #fee2e2;
    --woe-toast-er-tx:  #991b1b;
}
/* ── Tema değişkenleri (dark override) ── */
body.app-theme-dark .woe-page {
    --woe-bg:           #080c17;
    --woe-surface:      #0d1323;
    --woe-surface2:     #111827;
    --woe-border:       rgba(255,255,255,.09);
    --woe-border-light: rgba(255,255,255,.04);
    --woe-text:         #e2e8f0;
    --woe-text-muted:   #94a3b8;
    --woe-input-bg:     rgba(255,255,255,.06);
    --woe-input-disabled:rgba(255,255,255,.03);
    --woe-accent:       var(--theme-accent, #6366f1);
    --woe-toast-ok-bg:  rgba(34,197,94,.18);
    --woe-toast-ok-tx:  #4ade80;
    --woe-toast-er-bg:  rgba(239,68,68,.18);
    --woe-toast-er-tx:  #f87171;
}

.woe-page {
    padding: 16px 24px; height: 100%;
    display: flex; flex-direction: column; min-height: 0; gap: 12px;
    overflow: auto;
    background: var(--woe-bg); color: var(--woe-text);
}

.woe-toolbar {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--woe-border);
}
.woe-toolbar h1 { font-size: 18px; margin: 0; color: var(--woe-text); }
.woe-toolbar .spacer { flex: 1; }
.woe-back { color: var(--woe-text-muted); text-decoration: none; font-size: 13px; }
.woe-back:hover { color: var(--woe-text); }

.woe-btn {
    padding: 7px 14px; border-radius: 7px;
    border: 1px solid var(--woe-border);
    background: var(--woe-surface); color: var(--woe-text);
    cursor: pointer; font-size: 13px; font-weight: 500;
    transition: background .12s, border-color .12s;
}
.woe-btn:hover:not(:disabled) { background: var(--woe-surface2); border-color: var(--woe-accent); }
.woe-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.woe-btn--primary { background: linear-gradient(135deg, #6366f1, #4f46e5); color: #fff; border-color: #4f46e5; }
.woe-btn--primary:hover:not(:disabled) { filter: brightness(1.07); border-color: #4f46e5; }
.woe-btn--success { background: linear-gradient(135deg, #10b981, #059669); color: #fff; border-color: #059669; }
.woe-btn--success:hover:not(:disabled) { filter: brightness(1.07); border-color: #059669; }
.woe-btn--danger  { background: #fef2f2; color: #991b1b; border-color: #fecaca; }
.woe-btn--warn    { background: #fffbeb; color: #92400e; border-color: #fde68a; }
body.app-theme-dark .woe-btn--danger  { background: rgba(239,68,68,.12); color: #fca5a5; border-color: rgba(239,68,68,.32); }
body.app-theme-dark .woe-btn--danger:hover:not(:disabled)  { background: rgba(239,68,68,.20); border-color: rgba(239,68,68,.45); }
body.app-theme-dark .woe-btn--warn    { background: rgba(245,158,11,.12); color: #fcd34d; border-color: rgba(245,158,11,.32); }
body.app-theme-dark .woe-btn--warn:hover:not(:disabled)    { background: rgba(245,158,11,.20); border-color: rgba(245,158,11,.45); }

.woe-status { padding: 4px 12px; border-radius: 14px; font-size: 12px; font-weight: 700; }
.woe-status-0 { background: #e0e7ff; color: #4338ca; }
.woe-status-1 { background: #fef3c7; color: #92400e; }
.woe-status-2 { background: #ddd6fe; color: #6d28d9; }
.woe-status-3 { background: #d1fae5; color: #065f46; }
.woe-status-4 { background: #f3f4f6; color: #6b7280; }
.woe-status-5 { background: #fee2e2; color: #991b1b; }
body.app-theme-dark .woe-status-0 { background: rgba(99,102,241,.18); color: #a5b4fc; }
body.app-theme-dark .woe-status-1 { background: rgba(245,158,11,.18); color: #fcd34d; }
body.app-theme-dark .woe-status-2 { background: rgba(168,85,247,.18); color: #d8b4fe; }
body.app-theme-dark .woe-status-3 { background: rgba(34,197,94,.18); color: #86efac; }
body.app-theme-dark .woe-status-4 { background: rgba(148,163,184,.18); color: #cbd5e1; }
body.app-theme-dark .woe-status-5 { background: rgba(239,68,68,.18); color: #fca5a5; }

.woe-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; min-height: 0; }
@@media (max-width: 1024px) { .woe-grid { grid-template-columns: 1fr; } }

/* ── Sol-tab + sağ-pane yapısı ── */
.woe-tabbed {
    display: flex; min-height: 380px; gap: 0;
    background: var(--woe-surface);
    border: 1px solid var(--woe-border); border-radius: 10px;
    overflow: hidden;
}
.woe-nav {
    width: 220px; flex-shrink: 0;
    background: var(--woe-surface2);
    border-right: 1px solid var(--woe-border);
    padding: 10px 0; overflow-y: auto;
    display: flex; flex-direction: column;
}
.woe-nav-grouptitle {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px;
    color: var(--woe-text-muted);
    padding: 10px 14px 4px; margin: 0;
}
.woe-nav-btn {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 9px 14px;
    border: none; background: transparent;
    text-align: left; cursor: pointer;
    color: var(--woe-text); font-size: 13px; font-weight: 500;
    border-left: 3px solid transparent;
    transition: background .12s, color .12s;
}
.woe-nav-btn:hover { background: rgba(99,102,241,.08); }
.woe-nav-btn.is-active {
    border-left-color: var(--woe-accent);
    background: rgba(99,102,241,.14);
    font-weight: 600;
}
.woe-nav-icon {
    width: 14px; height: 14px; flex-shrink: 0; opacity: .7;
}
.woe-nav-btn.is-active .woe-nav-icon { opacity: 1; }
.woe-nav-count {
    margin-left: auto; padding: 1px 7px; border-radius: 999px;
    font-size: 10px; font-weight: 700; font-family: ui-monospace, monospace;
    background: rgba(99,102,241,.14); color: #4f46e5;
    border: 1px solid rgba(99,102,241,.28);
}
body.app-theme-dark .woe-nav-count { color: #a5b4fc; }

.woe-pane {
    flex: 1 1 auto; min-width: 0;
    padding: 18px 22px; overflow-y: auto;
}
.woe-pane-section { display: none; }
.woe-pane-section.is-active { display: block; }
.woe-pane h2 {
    margin: 0 0 4px; font-size: 15px; color: var(--woe-text); font-weight: 700;
}
.woe-pane .pane-hint {
    font-size: 12px; color: var(--woe-text-muted); margin-bottom: 14px;
}
.woe-placeholder {
    padding: 32px 16px; border: 1px dashed var(--woe-border); border-radius: 8px;
    text-align: center; color: var(--woe-text-muted); font-size: 13px;
}

/* ── Widget pane: grup başlığı sağ panelde gözükmesin (sol nav'da zaten var) ──
   DynamicWidgetRenderer her grup için <details> + <summary>{grupAdı}</summary>
   render ediyor. Summary'yi gizliyoruz, details'in card chrome'unu düzleştirip
   sadece widget alanları gözüksün. ÖNEMLİ: modern (floating) label widget'ın
   üst kenarına -8/-10px ile yapışıyor — kart padding-top:0 yapılırsa label
   üstten kesiliyor. Bu yüzden padding-top:12 + overflow:visible. */
#woeDynamicWidgets details > summary {
    display: none !important;
}
#woeDynamicWidgets details[data-dyn-group-id] {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 12px 4px 0 4px !important;
    margin: 0 0 12px 0 !important;
    border-radius: 0 !important;
    overflow: visible !important;
}
.woe-placeholder strong { color: var(--woe-text); display: block; margin-bottom: 6px; font-size: 14px; }

.woe-card {
    background: var(--woe-surface);
    border: 1px solid var(--woe-border);
    border-radius: 10px; padding: 16px;
}
.woe-card h3 {
    margin: 0 0 12px; font-size: 13px;
    text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--woe-text-muted);
}

.woe-row {
    display: grid; grid-template-columns: 140px 1fr;
    gap: 10px; align-items: center; margin-bottom: 10px;
}
.woe-row label { font-size: 12px; color: var(--woe-text-muted); font-weight: 500; }
.woe-row input, .woe-row select, .woe-row textarea {
    padding: 7px 10px; border-radius: 6px;
    border: 1px solid var(--woe-border);
    background: var(--woe-input-bg); color: var(--woe-text);
    font-size: 13px; font-family: inherit;
    outline: none; transition: border-color .12s, box-shadow .12s;
}
.woe-row input::placeholder, .woe-row textarea::placeholder { color: var(--woe-text-muted); opacity: .65; }
.woe-row input:focus, .woe-row select:focus, .woe-row textarea:focus {
    border-color: var(--woe-accent);
    box-shadow: 0 0 0 2px rgba(99,102,241,.18);
}
.woe-row input[readonly], .woe-row input:disabled,
.woe-row select:disabled, .woe-row textarea[readonly] {
    background: var(--woe-input-disabled);
    color: var(--woe-text-muted);
}
body.app-theme-dark .woe-row select,
html.dark .woe-row select { color-scheme: dark; }
body.app-theme-dark .woe-row input[type="datetime-local"],
html.dark .woe-row input[type="datetime-local"] { color-scheme: dark; }
/* select > * = option/optgroup (Razor parser "option" kelimesini OptionTagHelper
   olarak yorumladığı için universal child selector kullanılıyor). */
.woe-row select > * {
    background: var(--woe-surface);
    color: var(--woe-text);
}
body.app-theme-dark .woe-row select > *,
html.dark .woe-row select > * {
    background-color: #0d1323;
    color: #e2e8f0;
}
.woe-row textarea { min-height: 60px; resize: vertical; }
.woe-row.split { grid-template-columns: 140px 1fr 60px 100px; }

.woe-source-list { font-size: 13px; }
.woe-source-list .src-item {
    padding: 8px 0;
    border-bottom: 1px dashed var(--woe-border);
    display: flex; justify-content: space-between;
    color: var(--woe-text);
}
.woe-source-list .src-item:last-child { border-bottom: none; }
.woe-source-list .src-item a { color: var(--woe-accent); text-decoration: none; }
.woe-source-list .src-item a:hover { text-decoration: underline; }
.woe-source-list .src-empty { color: var(--woe-text-muted); padding: 12px 0; text-align: center; font-size: 12px; }

.woe-meta {
    font-size: 12px; color: var(--woe-text-muted);
    display: flex; gap: 16px; flex-wrap: wrap;
    padding-top: 8px; border-top: 1px dashed var(--woe-border); margin-top: 8px;
}
.woe-meta a { color: var(--woe-accent); text-decoration: none; }
.woe-meta a:hover { text-decoration: underline; }

/* ── Inline fields (kod + okur etiket / qty + birim) ── */
.woe-inline-fields {
    display: flex; align-items: center; gap: 8px;
    min-width: 0;
}
.woe-input--code { max-width: 240px; flex: 0 0 240px; }
.woe-input--qty  {
    max-width: 130px; flex: 0 0 130px;
    text-align: right;
    /* Number input spinner (yukarı/aşağı oklar) — Firefox + Webkit tarafından gizle */
    -moz-appearance: textfield;
    appearance: textfield;
}
.woe-input--qty::-webkit-outer-spin-button,
.woe-input--qty::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}
.woe-readonly-text {
    font-size: 13px; font-weight: 500;
    color: var(--woe-text);
    padding: 7px 10px;
    background: var(--woe-input-disabled);
    border: 1px solid var(--woe-border-light);
    border-radius: 6px;
    flex: 1 1 auto; min-width: 0;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.woe-readonly-text:empty::before {
    content: '—';
    opacity: .4;
}
/* Birim dropdown — readonly text alanıyla benzer görünüm, ama tıklanabilir.
   Stok kartındaki "miktar + birim" deseninin üretim emrindeki karşılığı. */
.woe-unit-select {
    flex: 0 0 auto; min-width: 110px;
    padding: 7px 10px; border-radius: 6px;
    border: 1px solid var(--woe-border);
    background: var(--woe-input-bg); color: var(--woe-text);
    font-size: 13px; font-weight: 500;
    outline: none; cursor: pointer;
    transition: border-color .12s, box-shadow .12s;
}
.woe-unit-select:hover:not(:disabled) { border-color: var(--woe-accent); }
.woe-unit-select:focus { border-color: var(--woe-accent); box-shadow: 0 0 0 2px rgba(99,102,241,.18); }
.woe-unit-select:disabled { opacity: .65; cursor: not-allowed; }
body.app-theme-dark .woe-unit-select,
html.dark .woe-unit-select { color-scheme: dark; }
.woe-unit-select > * { background: var(--woe-surface); color: var(--woe-text); }
body.app-theme-dark .woe-unit-select > *,
html.dark .woe-unit-select > * { background-color: #0d1323; color: #e2e8f0; }

/* ── Toast (sag alt) — auto-dismiss + manuel close ── */
#woe-toast-host {
    position: fixed; bottom: 24px; right: 24px; z-index: 9999;
    display: flex; flex-direction: column-reverse; gap: 10px;
    pointer-events: none;        /* host clickleri yutmaz; sadece toast'lar interaktif */
    max-width: 380px;
}
.woe-toast {
    pointer-events: auto;
    display: flex; align-items: flex-start; gap: 10px;
    min-width: 240px; max-width: 380px;
    padding: 11px 14px; border-radius: 10px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.32);
    font-size: 13px; line-height: 1.4;
    animation: woe-toast-slide .22s ease-out;
    position: relative;
}
.woe-toast--ok  { background: var(--woe-toast-ok-bg); color: var(--woe-toast-ok-tx); border: 1px solid rgba(16,185,129,.32); }
.woe-toast--err { background: var(--woe-toast-er-bg); color: var(--woe-toast-er-tx); border: 1px solid rgba(239,68,68,.32); }
.woe-toast.is-leaving { animation: woe-toast-fade .25s ease-in forwards; }
.woe-toast-msg  { flex: 1 1 auto; min-width: 0; word-break: break-word; }
.woe-toast-close {
    flex-shrink: 0;
    background: transparent; border: none; cursor: pointer;
    color: inherit; opacity: .7;
    width: 22px; height: 22px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 4px;
    font-size: 16px; line-height: 1; padding: 0;
}
.woe-toast-close:hover { opacity: 1; background: rgba(0,0,0,.08); }
@@keyframes woe-toast-slide {
    from { transform: translateY(12px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
}
@@keyframes woe-toast-fade {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(8px); }
}

/* ── Ek Alanlar (DynamicWidgetRenderer) — Material Card ile ayni pattern ── */
#woeDynamicWidgetsCard {
    background: var(--woe-surface);
    border: 1px solid var(--woe-border);
    border-radius: 12px;
    padding: 14px 16px;
    margin-top: 12px;
}
#woeDynamicWidgetsCard h3 {
    margin: 0 0 12px; font-size: 14px; font-weight: 600;
    color: var(--woe-text);
    padding-bottom: 8px;
    border-bottom: 1px solid var(--woe-border-light);
}
#woeDynamicWidgets { width: 100%; }

/* ── Layout wrapper resetleri (diger admin sayfalariyla ayni pattern) ── */
.page-work-order-edit .integrator-dashboard {
    height: 100% !important; min-height: 0 !important;
    padding: 0 !important; max-width: none !important;
    background: transparent !important; box-shadow: none !important;
    border: none !important; border-radius: 0 !important;
}
.page-work-order-edit .integrator-dashboard__content {
    display: flex !important; flex-direction: column !important;
    width: 100% !important; max-width: none !important;
    min-height: 0 !important; padding: 0 !important;
    margin: 0 !important; overflow: hidden !important;
    height: 100% !important;
}

/* ── Rota / Operasyonlar tab (Faz 3a-5) ────────────────────────────── */
.woe-rota-table {
    display: flex; flex-direction: column; gap: 1px;
    background: var(--woe-border-light);
    border: 1px solid var(--woe-border);
    border-radius: 6px; overflow: hidden;
    margin-top: 8px;
}
.woe-rota-row {
    display: grid;
    grid-template-columns: 60px 1.6fr 1.4fr 110px 130px 110px 56px;
    gap: 8px; padding: 8px 12px; align-items: center;
    background: var(--woe-surface);
    font-size: 13px;
}
.woe-rota-row.woe-rota-head {
    background: var(--woe-surface2);
    font-weight: 600; font-size: 12px; color: var(--woe-text-muted);
    text-transform: uppercase; letter-spacing: 0.4px;
}
.woe-rota-row input,
.woe-rota-row select {
    width: 100%; box-sizing: border-box;
    padding: 4px 6px; font-size: 13px;
    background: var(--woe-input-bg, var(--woe-surface));
    border: 1px solid var(--woe-border);
    border-radius: 4px; color: var(--woe-text);
}
.woe-rota-row input:read-only,
.woe-rota-row input[readonly] { opacity: 0.7; cursor: default; }
.woe-rota-status {
    display: inline-block; padding: 2px 8px; border-radius: 10px;
    font-size: 11px; font-weight: 600; text-align: center;
}
.woe-rota-status-0 { background: rgba(148,163,184,.16); color: #94a3b8; }
.woe-rota-status-1 { background: rgba(59,130,246,.18); color: #60a5fa; }
.woe-rota-status-2 { background: rgba(34,197,94,.18); color: #4ade80; }
.woe-rota-status-3 { background: rgba(239,68,68,.18); color: #f87171; }
.woe-rota-row .rota-del {
    background: transparent; border: none; color: var(--woe-text-muted);
    cursor: pointer; font-size: 18px; padding: 4px;
    border-radius: 4px;
}
.woe-rota-row .rota-del:hover { background: rgba(239,68,68,.15); color: #f87171; }
.woe-rota-empty { padding: 14px; text-align: center; }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">
<div class="woe-page">
    <div class="woe-toolbar">
        <a class="woe-back" href="@Url.Action("WorkOrders")" title="Listeye dön">←</a>
        <a class="woe-btn" href="@Url.Action("WorkOrderEdit")" id="btn-new" title="Yeni iş emri">+ Yeni</a>
        <button class="woe-btn woe-btn--primary" id="btn-save" @(isNew || canEditPlan ? "" : "disabled")>Kaydet</button>
        @if (!isNew)
        {
            @* Başlat / Tamamla butonları kaldırıldı — bu işlemler Faz 3'te
               makine ataması üzerinden (Makine → İş Emrini Başlat / Bitir / Kısmi Bitir)
               yapılacak. Salına/Kapat/Revize/İptal yöneticilik aksiyonları olarak kalır. *@
            <button class="woe-btn woe-btn--success" id="btn-release" @(canRelease ? "" : "disabled")>Salına ▶</button>
            <button class="woe-btn" id="btn-close" @(canClose ? "" : "disabled")>Kapat</button>
            <button class="woe-btn woe-btn--warn" id="btn-revise" @(canRevise ? "" : "disabled")>Revize</button>
            <button class="woe-btn woe-btn--danger" id="btn-cancel" @(canCancel ? "" : "disabled")>İptal</button>
        }
        <span class="spacer"></span>
        <h1>@(isNew ? "Yeni İş Emri" : Model!.OrderNumber)@(Model is { RevisionNo: > 0 } ? $" • Rev {Model.RevisionNo}" : "")</h1>
        @if (!isNew)
        {
            <span class="woe-status woe-status-@((byte)status)">@StatusLabel(status)</span>
        }
    </div>

    <div class="woe-tabbed">
        <nav class="woe-nav">
            <div class="woe-nav-grouptitle">İş Emri</div>
            <button type="button" class="woe-nav-btn is-active" data-tab="genel">
                <svg class="woe-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
