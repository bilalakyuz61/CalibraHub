@model CalibraHub.Application.Contracts.OperationDto
@{
    var isNew = Model is null;
    ViewData["Title"] = isNew ? "Yeni Operasyon" : $"Operasyon: {Model!.Name ?? Model.Code}";
    ViewData["FormCode"] = "OPERATION_EDIT";
    ViewData["BodyClass"] = "page-operation-edit workspace-frame-body";
}

<partial name="_ProductionDefsTabs" model='"operations"' />

@* PJAX wrapper *@
<div id="pdt-tab-content" data-pdt-key="operations" data-pdt-body-class="page-operation-edit">

<div class="ux-edit-shell">
  <header class="ux-edit-bar">
    <div class="ux-edit-bar__left">
      <a class="ux-edit-bar__back" href="/Production/Operations">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Listeye Dön
      </a>
      <h1 class="ux-edit-bar__title">@(isNew ? "Yeni Operasyon" : (Model!.Name ?? "Operasyonu Düzenle"))</h1>
      @if (!isNew)
      {
        var pillCls = Model!.IsActive ? "ux-edit-bar__status" : "ux-edit-bar__status ux-edit-bar__status--off";
        <span class="@pillCls">@(Model.IsActive ? "Aktif" : "Pasif")</span>
      }
    </div>
    <div class="ux-edit-bar__right">
      <a class="ux-edit-bar__btn" href="/Production/Operations">İptal</a>
      <button class="ux-edit-bar__btn ux-edit-bar__btn--primary" id="oe-save">Kaydet</button>
      @if (!isNew)
      {
        <button class="ux-edit-bar__btn ux-edit-bar__btn--danger" id="oe-delete">Sil</button>
      }
    </div>
  </header>

  <div class="ux-edit-body">
    <aside class="ux-edit-nav" id="oeNav">
      <button type="button" class="ux-edit-nav__tab is-active" data-tab="general">
        <svg class="ux-edit-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <span>Genel Bilgiler</span>
      </button>
      <button type="button" class="ux-edit-nav__tab" data-tab="widgets" id="oeNavWidgets" style="display:none;">
        <svg class="ux-edit-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm0 10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10-10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zm0 10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        <span>Ek Alanlar</span>
      </button>
    </aside>

    <section class="ux-edit-content">
      <div class="ux-edit-pane is-active" data-tab="general">
        <h2>Genel Bilgiler</h2>
        <div class="ux-edit-hint">Operasyonun temel kimlik bilgileri.</div>

        <input type="hidden" id="oe-id" value="@(Model?.Id.ToString() ?? "")" />

        <div class="ux-field">
          <label for="oe-name">Ad *</label>
          <input id="oe-name" type="text" maxlength="200"
                 value="@(Model?.Name ?? "")" placeholder="Kesim, Kaynak, Boya" />
        </div>

        <div class="ux-field ux-field--wide">
          <label for="oe-desc">Açıklama</label>
          <textarea id="oe-desc" maxlength="500"
                    placeholder="İsteğe bağlı detay...">@(Model?.Description ?? "")</textarea>
        </div>

        <div class="ux-row2">
          <div class="ux-field">
            <label for="oe-sort">Sıralama</label>
            <input id="oe-sort" type="number" min="0" value="@(Model?.SortOrder ?? 0)" />
          </div>
          <div class="ux-field">
            <label>Durum</label>
            <div class="ux-switch-row">
              <label class="ux-switch">
                <input type="checkbox" id="oe-active" @(Model is null || Model.IsActive ? "checked" : "") />
                <span class="ux-switch-track"></span>
              </label>
              <span class="ux-switch-label" id="oe-active-label">@((Model is null || Model.IsActive) ? "Aktif" : "Pasif")</span>
            </div>
          </div>
        </div>

        <div id="oe-err" style="display:none;" class="ux-err"></div>
      </div>

      <div class="ux-edit-pane" data-tab="widgets">
        <h2>Ek Alanlar</h2>
        <div class="ux-edit-hint">Admin → Widget Tanımları → OPERATION_EDIT'te tanımlanan ek alanlar.</div>
        <div class="ux-dyn-widgets">
          <div id="oeDynamicWidgets"
               data-form-code="OPERATION_EDIT"
               data-record-id="@(Model?.Id.ToString() ?? "")">
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

@if (!isNew)
{
  <div id="oe-modal" class="ux-modal-backdrop" style="display:none;" onclick="oeCloseModal()">
    <div class="ux-modal" onclick="event.stopPropagation()">
      <div class="ux-modal-icon">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <div class="ux-modal-title">Operasyonu Sil</div>
      <div class="ux-modal-msg" id="oe-modal-msg"></div>
      <div class="ux-modal-actions">
        <button class="ux-modal-cancel" onclick="oeCloseModal()">Vazgeç</button>
        <button class="ux-modal-del" id="oe-modal-del">Sil</button>
      </div>
    </div>
  </div>
}

@Html.AntiForgeryToken()

<script>
(function () {
    var idVal = (document.getElementById('oe-id')?.value || '').trim();

    function csrf() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function setErr(msg) {
        var el = document.getElementById('oe-err');
        if (!el) return;
        if (msg) { el.textContent = msg; el.style.display = ''; activateTab('general'); }
        else el.style.display = 'none';
    }
    function shake(id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.classList.remove('is-invalid'); void el.offsetWidth;
        el.classList.add('is-invalid');
        setTimeout(function () { el.classList.remove('is-invalid'); }, 1200);
    }

    // ── Tab switching ──
    function activateTab(key) {
        document.querySelectorAll('#oeNav .ux-edit-nav__tab').forEach(function (b) {
            b.classList.toggle('is-active', b.dataset.tab === key);
        });
        document.querySelectorAll('.ux-edit-pane').forEach(function (p) {
            p.classList.toggle('is-active', p.dataset.tab === key);
        });
    }
    document.querySelectorAll('#oeNav .ux-edit-nav__tab').forEach(function (b) {
        b.addEventListener('click', function () {
            if (b.disabled) return;
            activateTab(b.dataset.tab);
        });
    });

    // Active label sync
    var activeEl = document.getElementById('oe-active');
    var activeLabel = document.getElementById('oe-active-label');
    if (activeEl && activeLabel) {
        activeEl.addEventListener('change', function () {
            activeLabel.textContent = activeEl.checked ? 'Aktif' : 'Pasif';
        });
    }

    // ── Save ──
    var saveBtn = document.getElementById('oe-save');
    if (saveBtn) {
        saveBtn.addEventListener('click', function () {
            var name = (document.getElementById('oe-name').value || '').trim();
            if (!name) { activateTab('general'); shake('oe-name'); return; }
            var code = name;

            var payload = {
                id:               idVal ? parseInt(idVal) : 0,
                code:             code,
                name:             name,
                description:      (document.getElementById('oe-desc').value || '').trim() || null,
                standardDuration: null,
                durationUnit:     1,
                hourlyRate:       null,
                sortOrder:        parseInt(document.getElementById('oe-sort').value) || 0,
                isActive:         activeEl.checked,
            };
            saveBtn.disabled = true;
            setErr('');
            fetch('/Production/SaveOperation', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrf() },
                credentials: 'same-origin',
                body: JSON.stringify(payload)
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d && d.ok) {
                    if (!idVal && d.id) {
                        location.href = '/Production/OperationEdit?id=' + d.id;
                    } else {
                        location.href = '/Production/Operations';
                    }
                } else {
                    setErr((d && d.error) || 'Kayıt başarısız.');
                    saveBtn.disabled = false;
                }
            })
            .catch(function () { setErr('Bağlantı hatası.'); saveBtn.disabled = false; });
        });
    }

    // ── Delete modal ──
    var deleteBtn = document.getElementById('oe-delete');
    if (deleteBtn) {
        deleteBtn.addEventListener('click', function () {
            var name = (document.getElementById('oe-name').value || '').trim();
            var msgEl = document.getElementById('oe-modal-msg');
            if (msgEl) msgEl.innerHTML = '<strong>' + name + '</strong> operasyonunu silmek istediğinize emin misiniz?';
            document.getElementById('oe-modal').style.display = 'flex';
            document.getElementById('oe-modal-del').focus();
        });

        var modalDel = document.getElementById('oe-modal-del');
        if (modalDel) {
            modalDel.addEventListener('click', function () {
                modalDel.disabled = true;
                modalDel.textContent = 'Siliniyor…';
                fetch('/Production/DeleteOperation/' + idVal, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrf() },
                    credentials: 'same-origin'
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d && d.ok) {
                        location.href = '/Production/Operations';
                    } else {
                        oeCloseModal();
                        setErr((d && d.error) || 'Silinemedi.');
                    }
                })
                .catch(function () { oeCloseModal(); setErr('Bağlantı hatası.'); });
            });
        }
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') oeCloseModal();
    });
})();

function oeCloseModal() {
    var m = document.getElementById('oe-modal');
    if (m) m.style.display = 'none';
    var btn = document.getElementById('oe-modal-del');
    if (btn) { btn.disabled = false; btn.textContent = 'Sil'; }
}

// ── DynamicWidgetRenderer mount (stacked) ──
(function () {
    var el = document.getElementById('oeDynamicWidgets');
    if (!el) return;
    function doMount() {
        if (!window.CalibraHub || !window.CalibraHub.mountDynamicWidgetRenderer) return;
        try {
            window._oeDynRenderer = window.CalibraHub.mountDynamicWidgetRenderer(el, {
                formCode:    el.getAttribute('data-form-code') || 'OPERATION_EDIT',
                recordId:    el.getAttribute('data-record-id') || '',
                classPrefix: 'oe',
                layout:      'stacked',
                onMounted:   function (handle) {
                    // Polling — load tamamlanınca widget sayisini ogren, tab'i goster
                    var attempts = 0;
                    var iv = setInterval(function () {
                        attempts++;
                        try {
                            if (handle && typeof handle.getHasWidgets === 'function') {
                                if (handle.getHasWidgets()) {
                                    var nav = document.getElementById('oeNavWidgets');
                                    if (nav) nav.style.display = '';
                                    clearInterval(iv);
                                    return;
                                }
                            }
                        } catch (_) { /* swallow */ }
                        if (attempts > 25) clearInterval(iv);
                    }, 200);
                }
            });
        } catch (e) { console.warn('[OE] mountDynamicWidgetRenderer hatasi:', e); }
    }
    if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
        doMount();
    } else {
        var cssUrl = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
        var jsUrl  = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
        if (!document.querySelector('link[data-oe-bundle]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet'; link.href = cssUrl;
            link.setAttribute('data-oe-bundle', '1');
            document.head.appendChild(link);
        }
        if (!document.querySelector('script[data-oe-bundle]')) {
            var script = document.createElement('script');
            script.src = jsUrl;
            script.setAttribute('data-oe-bundle', '1');
            script.onload  = function () { setTimeout(doMount, 0); };
            script.onerror = function () { console.error('[OE] Bundle yuklenemedi'); };
            document.head.appendChild(script);
        }
    }
})();
</script>

</div>
@* /pdt-tab-content *@
