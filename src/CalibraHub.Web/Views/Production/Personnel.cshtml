@model CalibraHub.Web.Models.Production.PersonnelViewModel
@using System.Text.Json
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@{
    ViewData["Title"] = "Personel Tanımlamaları";
    ViewData["FormCode"] = "PERSONNEL_EDIT";
    ViewData["BodyClass"] = "page-personnel";
    ViewData["DbInfo"] =
        "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>Personnel</td><td style='padding:6px 8px;'>Üretim personeli (PIN/NFC kart, ünvan, departman, operatör flag)</td></tr>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>WorkOrderOperation</td><td style='padding:6px 8px;'>StartedByPersonnelId / CompletedByPersonnelId FK</td></tr>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>User</td><td style='padding:6px 8px;'>Personnel.UserId opsiyonel link (sistem login varsa)</td></tr>"
        + "</table>";

    var jsonOpts = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        WriteIndented = false,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };
    var boardConfigJson = Model.BoardConfig != null
        ? JsonSerializer.Serialize(Model.BoardConfig, jsonOpts)
        : "null";
}

<partial name="_ProductionDefsTabs" model='"personnel"' />

@* PJAX wrapper — production-defs-pjax.js sadece bu div'i swap eder.
   Style/script blogu wrapper icinde, partial ise disinda kalir. *@
<div id="pdt-tab-content" data-pdt-key="personnel" data-pdt-body-class="page-personnel">
<style>
    .page-personnel .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-personnel .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important;
        margin: 0 !important; overflow: hidden !important;
    }
    .workspace-frame-body.page-personnel .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-personnel .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }
</style>

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">
    <div id="reactSmartBoard" style="flex:1 1 auto;min-height:0;overflow:hidden;"></div>
</section>

<script>
(function() {
    var BOARD_CONFIG = @Html.Raw(boardConfigJson);
    var BUNDLE_URL = '@FileVersionProvider.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js")';
    var CSS_URL = '@FileVersionProvider.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css")';

    var el = document.getElementById('reactSmartBoard');
    if (!el) { console.error('[Personnel] Mount element yok'); return; }

    function showError(msg) {
        el.innerHTML = '<div class="cb-mount-error">'
            + '<div>' + msg + '</div>'
            + '<button onclick="location.reload()">Sayfayı Yenile</button>'
            + '</div>';
    }

    function doMount() {
        if (!BOARD_CONFIG) { showError('Board config bulunamadı'); return; }
        if (!window.CalibraHub || !window.CalibraHub.mountSmartBoard) {
            showError('SmartBoard mount fonksiyonu bulunamadı');
            return;
        }
        try {
            window.CalibraHub.mountSmartBoard(el, BOARD_CONFIG);
            console.log('[Personnel] SmartBoard mounted,', (BOARD_CONFIG.entities || []).length, 'personel');
        } catch (ex) {
            console.error('[Personnel] Mount exception:', ex);
            showError('Mount hatası: ' + (ex.message || ex));
        }
    }

    function loadCss() {
        if (document.querySelector('link[data-personnel-smartboard]')) return;
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = CSS_URL;
        link.setAttribute('data-personnel-smartboard', '1');
        document.head.appendChild(link);
    }

    function loadScript(cb) {
        // PJAX swap sirasinda bundle zaten yuklu olabilir — sadece yoksa ekle
        if (document.querySelector('script[data-personnel-smartboard]')) { cb(); return; }
        var script = document.createElement('script');
        script.src = BUNDLE_URL;
        script.setAttribute('data-personnel-smartboard', '1');
        script.onload = function() { setTimeout(cb, 0); };
        script.onerror = function() {
            console.error('[Personnel] Bundle script failed');
            showError('Bundle yüklenemedi (network hatası)');
        };
        document.head.appendChild(script);
    }

    loadCss();
    if (window.CalibraHub && window.CalibraHub.mountSmartBoard) {
        doMount();
    } else {
        loadScript(doMount);
    }
})();
</script>
</div>
