@model CalibraHub.Application.Contracts.PersonnelDto
@{
    var isNew = Model is null;
    ViewData["Title"] = isNew ? "Yeni Personel" : $"Personel: {Model!.FullName}";
    ViewData["FormCode"] = "PERSONNEL_EDIT";
    ViewData["BodyClass"] = "page-personnel-edit workspace-frame-body";
}

<partial name="_ProductionDefsTabs" model='"personnel"' />

@{
    var _colId = !isNew ? Model!.Id.ToString() : $"new-{Guid.NewGuid():N}";
    var _colTitle = isNew ? "Yeni Personel" : $"Personel: {Model!.FullName}";
}

@* PJAX wrapper — production-defs-pjax.js bu div'i swap eder; üst tab bar dışarıda kalır. *@
<div id="pdt-tab-content" data-pdt-key="personnel" data-pdt-body-class="page-personnel-edit">

<form class="integrator-form" style="display:none" aria-hidden="true"
      data-collaboration-record-type="PERSONNEL_EDIT"
      data-collaboration-record-id="@_colId"
      data-collaboration-record-title="@_colTitle"></form>

<div class="ux-edit-shell">
  @await Html.PartialAsync("_CalibraActionBar", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
  {
      ["Title"]       = isNew ? "Yeni Personel" : ((Model!.FullName ?? "Personeli Düzenle") + (Model!.IsActive ? "" : " (Pasif)")),
      ["ListUrl"]     = "/Production/Personnel",
      ["NewUrl"]      = "/Production/PersonnelEdit",
      ["SaveBtnId"]   = "pe-save",
      ["DeleteBtnId"] = "pe-delete",
      ["ListBtnId"]   = "pe-cancel",
      ["ShowDelete"]  = !isNew,
  })

  <div class="ux-edit-body">
    <aside class="ux-edit-nav" id="peNav">
      <button type="button" class="ux-edit-nav__tab is-active" data-tab="general">
        <svg class="ux-edit-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/></svg>
        <span>Genel Bilgiler</span>
      </button>
      <button type="button" class="ux-edit-nav__tab" data-tab="widgets" id="peNavWidgets" style="display:none;">
        <svg class="ux-edit-nav__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm0 10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10-10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zm0 10a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        <span>Ek Alanlar</span>
      </button>
    </aside>

    <section class="ux-edit-content">
      <div class="ux-edit-pane is-active" data-tab="general">
        <h2>Genel Bilgiler</h2>
        <div class="ux-edit-hint">Personel kimlik, iletişim ve sistem bilgileri.</div>

        <input type="hidden" id="pe-id" value="@(Model?.Id.ToString() ?? "")" />

        <div class="ux-field ux-field--wide">
          <label for="pe-name">Ad Soyad *</label>
          <input id="pe-name" type="text" maxlength="150"
                 value="@(Model?.FullName ?? "")" placeholder="Örn: Ahmet Yılmaz" />
        </div>

        <div class="ux-row2">
          <div class="ux-field">
            <label for="pe-title">Ünvan</label>
            <input id="pe-title" type="text" maxlength="100"
                   value="@(Model?.Title ?? "")" placeholder="Örn: Operatör" />
          </div>
          <div class="ux-field">
            <label for="pe-dept">Departman</label>
            <select id="pe-dept" data-current="@(Model?.Department ?? "")">
              <option value="">— Departman seçiniz —</option>
            </select>
          </div>
        </div>

        <div class="ux-row2">
          <div class="ux-field">
            <label for="pe-phone">Telefon</label>
            <input id="pe-phone" type="text" maxlength="40"
                   value="@(Model?.Phone ?? "")" placeholder="Örn: 0532 ..." />
          </div>
          <div class="ux-field">
            <label for="pe-email">E-posta</label>
            <input id="pe-email" type="email" maxlength="150"
                   value="@(Model?.Email ?? "")" placeholder="ornek@firma.com" />
          </div>
        </div>

        <div class="ux-row2">
          <div class="ux-field">
            <label for="pe-birthdate">Doğum Tarihi</label>
            <input id="pe-birthdate" type="date"
                   value="@(Model?.BirthDate?.ToString("yyyy-MM-dd") ?? "")" />
          </div>
          <div class="ux-field"></div>
        </div>

        <div class="ux-row2">
          <div class="ux-field">
            <label for="pe-pin">PIN Kodu</label>
            <input id="pe-pin" type="text" maxlength="20"
                   value="@(Model?.PinCode ?? "")" placeholder="Vardiya/terminal girişi" />
          </div>
          <div class="ux-field">
            <label for="pe-card">Kart No</label>
            <input id="pe-card" type="text" maxlength="50"
                   value="@(Model?.CardNo ?? "")" placeholder="RFID / barkod" />
          </div>
        </div>

        <div class="ux-field ux-field--wide">
          <label for="pe-user">Sistem Kullanıcısı</label>
          <select id="pe-user" data-current="@(Model?.UserId?.ToString() ?? "")">
            <option value="">— Sistem girişi yok —</option>
          </select>
          <span class="ux-hint">Bu personelin web/masaüstü giriş hesabı varsa eşleştirin. Boş bırakılırsa yalnızca terminalde PIN/kart ile çalışır.</span>
        </div>

        <div class="ux-field ux-field--wide">
          <label for="pe-notes">Notlar</label>
          <textarea id="pe-notes" maxlength="2000"
                    placeholder="Vardiya bilgileri, ekstra notlar...">@(Model?.Notes ?? "")</textarea>
        </div>

        <div class="ux-row2">
          <div class="ux-field">
            <label>Üretim Operatörü</label>
            <div class="ux-switch-row">
              <label class="ux-switch">
                <input type="checkbox" id="pe-operator" @(Model?.IsProductionOperator == true ? "checked" : "") />
                <span class="ux-switch-track"></span>
              </label>
              <span class="ux-switch-label" id="pe-operator-label">@(Model?.IsProductionOperator == true ? "Evet" : "Hayır")</span>
            </div>
          </div>
          <div class="ux-field">
            <label>Durum</label>
            <div class="ux-switch-row">
              <label class="ux-switch">
                <input type="checkbox" id="pe-active" @(Model is null || Model.IsActive ? "checked" : "") />
                <span class="ux-switch-track"></span>
              </label>
              <span class="ux-switch-label" id="pe-active-label">@(Model is null || Model.IsActive ? "Aktif" : "Pasif")</span>
            </div>
          </div>
        </div>

        <div id="pe-err" style="display:none;" class="ux-err"></div>
      </div>

      <div class="ux-edit-pane" data-tab="widgets">
        <h2>Ek Alanlar</h2>
        <div class="ux-edit-hint">Admin → Widget Tanımları → PERSONNEL_EDIT'te tanımlanan ek alanlar.</div>
        <div class="ux-dyn-widgets">
          <div id="peDynamicWidgets"
               data-form-code="PERSONNEL_EDIT"
               data-record-id="@(Model?.Id.ToString() ?? "")">
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

@if (!isNew)
{
  <div id="pe-modal" class="ux-modal-backdrop" style="display:none;" onclick="peCloseModal()">
    <div class="ux-modal" onclick="event.stopPropagation()">
      <div class="ux-modal-icon">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <div class="ux-modal-title">Personeli Sil</div>
      <div class="ux-modal-msg" id="pe-modal-msg"></div>
      <div class="ux-modal-actions">
        <button class="ux-modal-cancel" onclick="peCloseModal()">Vazgeç</button>
        <button class="ux-modal-del" id="pe-modal-del">Sil</button>
      </div>
    </div>
  </div>
}

@Html.AntiForgeryToken()

<script>
(function () {
    var idVal = document.getElementById('pe-id')?.value || '';

    function csrf() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function setErr(msg) {
        var el = document.getElementById('pe-err');
        if (!el) return;
        if (msg) { el.textContent = msg; el.style.display = ''; activateTab('general'); }
        else el.style.display = 'none';
    }
    function shake(id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.classList.remove('is-invalid'); void el.offsetWidth;
        el.classList.add('is-invalid');
        setTimeout(function () { el.classList.remove('is-invalid'); }, 1200);
    }

    // ── Tab switching ──
    function activateTab(key) {
        document.querySelectorAll('#peNav .ux-edit-nav__tab').forEach(function (b) {
            b.classList.toggle('is-active', b.dataset.tab === key);
        });
        document.querySelectorAll('.ux-edit-pane').forEach(function (p) {
            p.classList.toggle('is-active', p.dataset.tab === key);
        });
    }
    document.querySelectorAll('#peNav .ux-edit-nav__tab').forEach(function (b) {
        b.addEventListener('click', function () {
            if (b.disabled) return;
            activateTab(b.dataset.tab);
        });
    });

    // ── Toggle label sync ──
    function bindLabel(inputId, labelId, onText, offText) {
        var inp = document.getElementById(inputId);
        var lab = document.getElementById(labelId);
        if (!inp || !lab) return;
        inp.addEventListener('change', function () {
            lab.textContent = inp.checked ? onText : offText;
        });
    }
    bindLabel('pe-active',   'pe-active-label',   'Aktif', 'Pasif');
    bindLabel('pe-operator', 'pe-operator-label', 'Evet',  'Hayır');

    // ── Departman dropdown ──
    (function loadDepartments() {
        var sel = document.getElementById('pe-dept');
        if (!sel) return;
        var current = sel.getAttribute('data-current') || '';
        fetch('/Admin/GetDepartmentsLookup', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (list) {
                var opts = ['<option value="">— Departman seçiniz —</option>'];
                (list || []).forEach(function (d) {
                    var s = (current && d.name === current) ? ' selected' : '';
                    opts.push('<option value="' + escapeAttr(d.name) + '"' + s + '>' + escapeHtml(d.name) + '</option>');
                });
                sel.innerHTML = opts.join('');
            })
            .catch(function () { /* sessiz */ });

        function escapeHtml(s) {
            return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
        function escapeAttr(s) {
            return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;');
        }
    })();

    // ── Sistem Kullanıcısı dropdown ──
    (function loadUsers() {
        var sel = document.getElementById('pe-user');
        if (!sel) return;
        var current = sel.getAttribute('data-current') || '';
        fetch('/CompanyUser/UsersLookup', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (list) {
                var opts = ['<option value="">— Sistem girişi yok —</option>'];
                (list || []).forEach(function (u) {
                    var s = (current && String(u.id) === String(current)) ? ' selected' : '';
                    var label = u.name + (u.email ? ' (' + u.email + ')' : '');
                    opts.push('<option value="' + u.id + '"' + s + '>' + escUser(label) + '</option>');
                });
                sel.innerHTML = opts.join('');
            })
            .catch(function () { /* sessiz */ });
        function escUser(s) {
            return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
    })();

    // ── Save ──
    var saveBtn = document.getElementById('pe-save');
    if (saveBtn) {
        saveBtn.addEventListener('click', function () {
            var name = (document.getElementById('pe-name').value || '').trim();
            if (!name) { activateTab('general'); shake('pe-name'); return; }

            var payload = {
                id:                   idVal ? parseInt(idVal) : 0,
                code:                 '',
                fullName:             name,
                title:                document.getElementById('pe-title').value.trim() || null,
                department:           document.getElementById('pe-dept').value.trim() || null,
                pinCode:              document.getElementById('pe-pin').value.trim() || null,
                cardNo:               document.getElementById('pe-card').value.trim() || null,
                isProductionOperator: document.getElementById('pe-operator').checked,
                isActive:             document.getElementById('pe-active').checked,
                userId:               (function () { var v = document.getElementById('pe-user').value; return v ? parseInt(v, 10) : null; })(),
                phone:                document.getElementById('pe-phone').value.trim() || null,
                email:                document.getElementById('pe-email').value.trim() || null,
                notes:                document.getElementById('pe-notes').value.trim() || null,
                birthDate:            document.getElementById('pe-birthdate').value || null
            };
            saveBtn.disabled = true;
            setErr('');
            fetch('/Production/SavePersonnel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrf() },
                body: JSON.stringify(payload)
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d && d.ok) {
                    window.location.href = '/Production/Personnel';
                } else {
                    setErr((d && d.error) || 'Kayıt başarısız.');
                    saveBtn.disabled = false;
                }
            })
            .catch(function (e) { setErr('Bağlantı hatası: ' + (e.message || e)); saveBtn.disabled = false; });
        });
    }

    // ── Delete modal ──
    var deleteBtn = document.getElementById('pe-delete');
    if (deleteBtn) {
        deleteBtn.addEventListener('click', function () {
            var name = document.getElementById('pe-name').value;
            var msgEl = document.getElementById('pe-modal-msg');
            if (msgEl) msgEl.innerHTML = '<strong>' + name + '</strong> personelini silmek istediğinize emin misiniz?';
            document.getElementById('pe-modal').style.display = 'flex';
            document.getElementById('pe-modal-del').focus();
        });

        var modalDel = document.getElementById('pe-modal-del');
        if (modalDel) {
            modalDel.addEventListener('click', function () {
                modalDel.disabled = true;
                modalDel.textContent = 'Siliniyor…';
                fetch('/Production/DeletePersonnel/' + idVal, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrf() }
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d && d.ok) {
                        window.location.href = '/Production/Personnel';
                    } else {
                        peCloseModal();
                        setErr((d && d.error) || 'Silinemedi.');
                    }
                })
                .catch(function (e) { peCloseModal(); setErr('Bağlantı hatası: ' + (e.message || e)); });
            });
        }
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') peCloseModal();
    });
})();

function peCloseModal() {
    var m = document.getElementById('pe-modal');
    if (m) m.style.display = 'none';
    var btn = document.getElementById('pe-modal-del');
    if (btn) { btn.disabled = false; btn.textContent = 'Sil'; }
}

// ── DynamicWidgetRenderer mount (stacked layout) ──
(function () {
    var el = document.getElementById('peDynamicWidgets');
    if (!el) return;
    function doMount() {
        if (!window.CalibraHub || !window.CalibraHub.mountDynamicWidgetRenderer) return;
        try {
            window._peDynRenderer = window.CalibraHub.mountDynamicWidgetRenderer(el, {
                formCode:    el.getAttribute('data-form-code') || 'PERSONNEL_EDIT',
                recordId:    el.getAttribute('data-record-id') || '',
                classPrefix: 'pe',
                layout:      'stacked',
                onMounted:   function (handle) {
                    var attempts = 0;
                    var iv = setInterval(function () {
                        attempts++;
                        try {
                            if (handle && typeof handle.getHasWidgets === 'function' && handle.getHasWidgets()) {
                                var nav = document.getElementById('peNavWidgets');
                                if (nav) nav.style.display = '';
                                clearInterval(iv);
                                return;
                            }
                        } catch (_) {}
                        if (attempts > 25) clearInterval(iv);
                    }, 200);
                }
            });
        } catch (e) { console.warn('[PE] mountDynamicWidgetRenderer hatasi:', e); }
    }
    if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
        doMount();
    } else {
        var cssUrl = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
        var jsUrl  = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
        if (!document.querySelector('link[data-pe-bundle]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet'; link.href = cssUrl;
            link.setAttribute('data-pe-bundle', '1');
            document.head.appendChild(link);
        }
        if (!document.querySelector('script[data-pe-bundle]')) {
            var script = document.createElement('script');
            script.src = jsUrl;
            script.setAttribute('data-pe-bundle', '1');
            script.onload  = function () { setTimeout(doMount, 0); };
            script.onerror = function () { console.error('[PE] Bundle yuklenemedi'); };
            document.head.appendChild(script);
        }
    }
})();
</script>

</div>
@* /pdt-tab-content *@
