@model CalibraHub.Application.Contracts.PersonnelDto
@{
    var isNew = Model is null;
    ViewData["Title"] = isNew ? "Yeni Personel" : $"Personel: {Model!.FullName}";
    ViewData["FormCode"] = "PERSONNEL_EDIT";
    ViewData["BodyClass"] = "page-personnel-edit";
}

@section Styles {
<style>
    .pe-root {
        --pe-bg:      #f1f5f9;
        --pe-surface: #ffffff;
        --pe-border:  #e2e8f0;
        --pe-text:    #0f172a;
        --pe-muted:   #64748b;
        --pe-accent:  #6366f1;
        display: flex; align-items: flex-start; justify-content: center;
        min-height: 100%; padding: 32px 16px;
        background: var(--pe-bg);
    }
    body.app-theme-dark .pe-root {
        --pe-bg:      #080c17;
        --pe-surface: #0d1323;
        --pe-border:  rgba(255,255,255,.09);
        --pe-text:    #e2e8f0;
        --pe-muted:   #94a3b8;
    }
    .pe-card {
        width: 100%; max-width: 640px;
        background: var(--pe-surface); border: 1px solid var(--pe-border);
        border-radius: 14px; padding: 28px 28px 24px;
        box-shadow: 0 4px 24px rgba(0,0,0,.08);
    }
    .pe-header {
        display: flex; align-items: center; gap: 10px;
        margin-bottom: 24px; padding-bottom: 16px;
        border-bottom: 1px solid var(--pe-border);
    }
    .pe-header h1 { font-size: 17px; font-weight: 700; margin: 0; color: var(--pe-text); }
    .pe-back {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 12px; border-radius: 8px;
        border: 1px solid var(--pe-border); background: none;
        color: var(--pe-muted); font-size: 13px; cursor: pointer;
        text-decoration: none; transition: background .12s;
    }
    .pe-back:hover { background: var(--pe-bg); color: var(--pe-text); }
    .pe-spacer { flex: 1; }

    .pe-field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 14px; }
    .pe-label { font-size: 12px; font-weight: 600; color: var(--pe-muted); }
    .pe-input, .pe-select, .pe-textarea {
        padding: 9px 12px; border-radius: 8px;
        border: 1px solid var(--pe-border);
        background: var(--pe-bg); color: var(--pe-text);
        font-size: 14px; outline: none;
        font-family: inherit;
        transition: border-color .15s, box-shadow .15s;
    }
    .pe-textarea { resize: vertical; min-height: 70px; }
    .pe-input:focus, .pe-select:focus, .pe-textarea:focus {
        border-color: var(--pe-accent);
        box-shadow: 0 0 0 3px rgba(99,102,241,.12);
    }
    .pe-input.is-invalid, .pe-select.is-invalid {
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 3px rgba(239,68,68,.12) !important;
    }
    body.app-theme-dark .pe-select { color-scheme: dark; }

    .pe-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .pe-switch-row { display: flex; align-items: center; gap: 10px; }
    .pe-switch { position: relative; width: 42px; height: 24px; display: inline-block; flex-shrink: 0; }
    .pe-switch input { opacity: 0; width: 0; height: 0; position: absolute; }
    .pe-switch-track {
        position: absolute; inset: 0; border-radius: 24px; cursor: pointer;
        background: #e2e8f0; transition: background .2s;
    }
    .pe-switch input:checked + .pe-switch-track { background: #10b981; }
    body.app-theme-dark .pe-switch-track { background: rgba(255,255,255,.12); }
    body.app-theme-dark .pe-switch input:checked + .pe-switch-track { background: #059669; }
    .pe-switch-track::before {
        content: ''; position: absolute; height: 18px; width: 18px;
        left: 3px; top: 3px; border-radius: 50%;
        background: #fff; transition: transform .2s;
        box-shadow: 0 1px 3px rgba(0,0,0,.25);
    }
    .pe-switch input:checked + .pe-switch-track::before { transform: translateX(18px); }
    .pe-switch-label { font-size: 13px; font-weight: 600; color: var(--pe-muted); }

    .pe-actions {
        display: flex; gap: 8px; margin-top: 24px;
        padding-top: 16px; border-top: 1px solid var(--pe-border);
    }
    .pe-btn {
        padding: 9px 20px; border-radius: 8px; font-size: 13px; font-weight: 600;
        border: 1px solid transparent; cursor: pointer; transition: all .12s;
        text-decoration: none; display: inline-flex; align-items: center; justify-content: center;
    }
    .pe-btn--primary { background: var(--pe-accent); color: #fff; border-color: #4f46e5; }
    .pe-btn--primary:hover { filter: brightness(1.1); }
    .pe-btn--primary:disabled { opacity: .55; cursor: not-allowed; }
    .pe-btn--ghost { background: none; border-color: var(--pe-border); color: var(--pe-text); }
    .pe-btn--ghost:hover { background: var(--pe-bg); }
    .pe-btn--danger { background: none; border-color: #fecaca; color: #dc2626; margin-left: auto; }
    body.app-theme-dark .pe-btn--danger { border-color: rgba(239,68,68,.35); color: #f87171; }
    .pe-btn--danger:hover { background: rgba(239,68,68,.08); }
    .pe-btn--danger:disabled { opacity: .4; cursor: not-allowed; }

    .pe-err {
        margin-top: 10px; padding: 8px 12px; border-radius: 8px; font-size: 13px;
        background: rgba(239,68,68,.08); color: #dc2626; border: 1px solid rgba(239,68,68,.2);
    }
    body.app-theme-dark .pe-err { color: #f87171; }

    /* Delete modal */
    .pe-modal-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,.48); backdrop-filter: blur(3px);
        display: flex; align-items: center; justify-content: center;
    }
    .pe-modal {
        background: var(--pe-surface); border: 1px solid var(--pe-border);
        border-radius: 14px; padding: 24px; width: 360px; max-width: 90vw;
        display: flex; flex-direction: column; gap: 14px;
        box-shadow: 0 24px 64px rgba(0,0,0,.35);
    }
    .pe-modal-icon { display: flex; justify-content: center; color: #ef4444; }
    .pe-modal-title { font-size: 16px; font-weight: 600; text-align: center; color: var(--pe-text); }
    .pe-modal-msg { font-size: 13px; color: var(--pe-muted); text-align: center; line-height: 1.55; }
    .pe-modal-actions { display: flex; gap: 8px; justify-content: center; margin-top: 4px; }
    .pe-modal-cancel {
        padding: 8px 22px; border-radius: 8px; font-size: 13px; font-weight: 500;
        border: 1px solid var(--pe-border); background: var(--pe-surface);
        color: var(--pe-text); cursor: pointer; transition: background .12s;
    }
    .pe-modal-cancel:hover { background: var(--pe-bg); }
    .pe-modal-del {
        padding: 8px 22px; border-radius: 8px; font-size: 13px; font-weight: 500;
        border: none; background: #ef4444; color: #fff; cursor: pointer; transition: filter .12s;
    }
    .pe-modal-del:hover:not(:disabled) { filter: brightness(1.1); }
    .pe-modal-del:disabled { opacity: .5; cursor: not-allowed; }
</style>
}

@{
    var _colId = !isNew ? Model!.Id.ToString() : $"new-{Guid.NewGuid():N}";
    var _colTitle = isNew ? "Yeni Personel" : $"Personel: {Model!.FullName}";
}
<form class="integrator-form" style="display:none" aria-hidden="true"
      data-collaboration-record-type="PERSONNEL_EDIT"
      data-collaboration-record-id="@_colId"
      data-collaboration-record-title="@_colTitle"></form>

<div class="pe-root">
  <div class="pe-card">
    <div class="pe-header">
      <a class="pe-back" href="/Production/Personnel">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Listeye Dön
      </a>
      <span class="pe-spacer"></span>
      <h1>@(isNew ? "Yeni Personel" : "Personeli Düzenle")</h1>
    </div>

    <input type="hidden" id="pe-id" value="@(Model?.Id.ToString() ?? "")" />

    <div class="pe-field">
      <label class="pe-label" for="pe-name">Ad Soyad *</label>
      <input id="pe-name" class="pe-input" maxlength="150"
             value="@(Model?.FullName ?? "")" placeholder="Örn: Ahmet Yılmaz" />
    </div>

    <div class="pe-row2">
      <div class="pe-field">
        <label class="pe-label" for="pe-title">Ünvan</label>
        <input id="pe-title" class="pe-input" maxlength="100"
               value="@(Model?.Title ?? "")" placeholder="Örn: Operatör" />
      </div>
      <div class="pe-field">
        <label class="pe-label" for="pe-dept">Departman</label>
        <select id="pe-dept" class="pe-input" data-current="@(Model?.Department ?? "")">
          <option value="">— Departman seçiniz —</option>
        </select>
      </div>
    </div>

    <div class="pe-row2">
      <div class="pe-field">
        <label class="pe-label" for="pe-phone">Telefon</label>
        <input id="pe-phone" class="pe-input" maxlength="40"
               value="@(Model?.Phone ?? "")" placeholder="Örn: 0532 ..." />
      </div>
      <div class="pe-field">
        <label class="pe-label" for="pe-email">E-posta</label>
        <input id="pe-email" class="pe-input" type="email" maxlength="150"
               value="@(Model?.Email ?? "")" placeholder="ornek@firma.com" />
      </div>
    </div>

    <div class="pe-row2">
      <div class="pe-field">
        <label class="pe-label" for="pe-pin">PIN Kodu</label>
        <input id="pe-pin" class="pe-input" maxlength="20"
               value="@(Model?.PinCode ?? "")" placeholder="Vardiya/terminal girişi" />
      </div>
      <div class="pe-field">
        <label class="pe-label" for="pe-card">Kart No</label>
        <input id="pe-card" class="pe-input" maxlength="50"
               value="@(Model?.CardNo ?? "")" placeholder="RFID / barkod" />
      </div>
    </div>

    <div class="pe-field">
      <label class="pe-label" for="pe-notes">Notlar</label>
      <textarea id="pe-notes" class="pe-textarea" maxlength="2000"
                placeholder="Vardiya bilgileri, ekstra notlar...">@(Model?.Notes ?? "")</textarea>
    </div>

    <div class="pe-row2">
      <div class="pe-field">
        <label class="pe-label">Üretim Operatörü</label>
        <div class="pe-switch-row">
          <label class="pe-switch">
            <input type="checkbox" id="pe-operator" @(Model?.IsProductionOperator == true ? "checked" : "") />
            <span class="pe-switch-track"></span>
          </label>
          <span class="pe-switch-label" id="pe-operator-label">@(Model?.IsProductionOperator == true ? "Evet" : "Hayır")</span>
        </div>
      </div>
      <div class="pe-field">
        <label class="pe-label">Durum</label>
        <div class="pe-switch-row">
          <label class="pe-switch">
            <input type="checkbox" id="pe-active" @(Model is null || Model.IsActive ? "checked" : "") />
            <span class="pe-switch-track"></span>
          </label>
          <span class="pe-switch-label" id="pe-active-label">@(Model is null || Model.IsActive ? "Aktif" : "Pasif")</span>
        </div>
      </div>
    </div>

    <div id="pe-err" style="display:none;" class="pe-err"></div>

    <!-- Dinamik widget alanları (Admin → Widget Tanımları → PERSONNEL_EDIT) -->
    <div id="peDynamicWidgetsCard" style="display:none; margin-top:16px; padding-top:16px; border-top:1px solid var(--pe-border);">
      <div id="peDynamicWidgets"
           data-form-code="PERSONNEL_EDIT"
           data-record-id="@(Model?.Id.ToString() ?? "")">
      </div>
    </div>

    <div class="pe-actions">
      <button class="pe-btn pe-btn--primary" id="pe-save">Kaydet</button>
      <a class="pe-btn pe-btn--ghost" href="/Production/Personnel">İptal</a>
      @if (!isNew)
      {
        <button class="pe-btn pe-btn--danger" id="pe-delete">Sil</button>
      }
    </div>
  </div>
</div>

@if (!isNew)
{
  <div id="pe-modal" class="pe-modal-backdrop" style="display:none;" onclick="peCloseModal()">
    <div class="pe-modal" onclick="event.stopPropagation()">
      <div class="pe-modal-icon">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <div class="pe-modal-title">Personeli Sil</div>
      <div class="pe-modal-msg" id="pe-modal-msg"></div>
      <div class="pe-modal-actions">
        <button class="pe-modal-cancel" onclick="peCloseModal()">Vazgeç</button>
        <button class="pe-modal-del" id="pe-modal-del">Sil</button>
      </div>
    </div>
  </div>
}

@Html.AntiForgeryToken()

@section Scripts {
<script>
(function () {
    var idVal = document.getElementById('pe-id')?.value || '';

    function csrf() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function setErr(msg) {
        var el = document.getElementById('pe-err');
        if (!el) return;
        if (msg) { el.textContent = msg; el.style.display = ''; }
        else el.style.display = 'none';
    }
    function shake(id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.classList.remove('is-invalid'); void el.offsetWidth;
        el.classList.add('is-invalid');
        setTimeout(function () { el.classList.remove('is-invalid'); }, 1200);
    }

    // ── Toggle label sync ─────────────────────────────────────
    function bindLabel(inputId, labelId, onText, offText) {
        var inp = document.getElementById(inputId);
        var lab = document.getElementById(labelId);
        if (!inp || !lab) return;
        inp.addEventListener('change', function () {
            lab.textContent = inp.checked ? onText : offText;
        });
    }
    bindLabel('pe-active',   'pe-active-label',   'Aktif', 'Pasif');
    bindLabel('pe-operator', 'pe-operator-label', 'Evet',  'Hayır');

    // ── Departman dropdown — Admin/GetDepartmentsLookup ──────────
    // Sadece AKTIF + sirkete tanimli departmanlar listelenir. Mevcut personel
    // free-text degeri (data-current) listede yoksa secim bos kalir
    // (kullanici listeden secmek zorunda — pasif/silinmis kayit korunmaz).
    (function loadDepartments() {
        var sel = document.getElementById('pe-dept');
        if (!sel) return;
        var current = sel.getAttribute('data-current') || '';
        fetch('/Admin/GetDepartmentsLookup', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (list) {
                var opts = ['<option value="">— Departman seçiniz —</option>'];
                (list || []).forEach(function (d) {
                    var s = (current && d.name === current) ? ' selected' : '';
                    opts.push('<option value="' + escapeAttr(d.name) + '"' + s + '>' + escapeHtml(d.name) + '</option>');
                });
                sel.innerHTML = opts.join('');
            })
            .catch(function () { /* sessiz: select bos kalir, save sirasinda sorun yok */ });

        function escapeHtml(s) {
            return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }
        function escapeAttr(s) {
            return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;');
        }
    })();

    // ── Save ──────────────────────────────────────────────────
    var saveBtn = document.getElementById('pe-save');
    if (saveBtn) {
        saveBtn.addEventListener('click', function () {
            var name = (document.getElementById('pe-name').value || '').trim();
            if (!name) { shake('pe-name'); return; }

            var payload = {
                id:                   idVal ? parseInt(idVal) : 0,
                code:                 '',
                fullName:             name,
                title:                document.getElementById('pe-title').value.trim() || null,
                department:           document.getElementById('pe-dept').value.trim() || null,
                pinCode:              document.getElementById('pe-pin').value.trim() || null,
                cardNo:               document.getElementById('pe-card').value.trim() || null,
                isProductionOperator: document.getElementById('pe-operator').checked,
                isActive:             document.getElementById('pe-active').checked,
                userId:               null,
                phone:                document.getElementById('pe-phone').value.trim() || null,
                email:                document.getElementById('pe-email').value.trim() || null,
                notes:                document.getElementById('pe-notes').value.trim() || null
            };
            saveBtn.disabled = true;
            setErr('');
            fetch('/Production/SavePersonnel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrf() },
                body: JSON.stringify(payload)
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d && d.ok) {
                    window.location.href = '/Production/Personnel';
                } else {
                    setErr((d && d.error) || 'Kayıt başarısız.');
                    saveBtn.disabled = false;
                }
            })
            .catch(function (e) { setErr('Bağlantı hatası: ' + (e.message || e)); saveBtn.disabled = false; });
        });
    }

    // ── Delete modal ──────────────────────────────────────────
    var deleteBtn = document.getElementById('pe-delete');
    if (deleteBtn) {
        deleteBtn.addEventListener('click', function () {
            var name = document.getElementById('pe-name').value;
            var msgEl = document.getElementById('pe-modal-msg');
            if (msgEl) msgEl.innerHTML = '<strong>' + name + '</strong> personelini silmek istediğinize emin misiniz?';
            document.getElementById('pe-modal').style.display = 'flex';
            document.getElementById('pe-modal-del').focus();
        });

        var modalDel = document.getElementById('pe-modal-del');
        if (modalDel) {
            modalDel.addEventListener('click', function () {
                modalDel.disabled = true;
                modalDel.textContent = 'Siliniyor…';
                fetch('/Production/DeletePersonnel/' + idVal, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrf() }
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d && d.ok) {
                        window.location.href = '/Production/Personnel';
                    } else {
                        peCloseModal();
                        setErr((d && d.error) || 'Silinemedi.');
                    }
                })
                .catch(function (e) { peCloseModal(); setErr('Bağlantı hatası: ' + (e.message || e)); });
            });
        }
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') peCloseModal();
    });
})();

function peCloseModal() {
    var m = document.getElementById('pe-modal');
    if (m) m.style.display = 'none';
    var btn = document.getElementById('pe-modal-del');
    if (btn) { btn.disabled = false; btn.textContent = 'Sil'; }
}
</script>
}
