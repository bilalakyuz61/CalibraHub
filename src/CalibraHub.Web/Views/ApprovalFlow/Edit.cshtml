@using CalibraHub.Application.Contracts
@using CalibraHub.Domain.Enums
@using System.Text.Json
@model CalibraHub.Application.Contracts.ApprovalFlowDto?
@{
    ViewData["Title"] = Model is null ? "Yeni Onay Akışı" : $"Akış Düzenle — {Model.Name}";
    ViewData["BodyClass"] = "page-approval-flow-edit workspace-frame-body";
    var isNew = Model is null;
    var flowId = Model?.Id ?? 0;
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var initData = JsonSerializer.Serialize(new {
        id               = flowId,
        name             = Model?.Name ?? "",
        description      = Model?.Description ?? "",
        // Yeni akışta documentKind boş bırakılır — JS ilk spesifik belge türünü seçer.
        // "Document" (Tüm Belgeler) default'u kaldırıldı: wildcard yalnızca eski kayıtlı
        // akışlarda (legacy) görünür, yeni akışta seçenek olarak sunulmaz.
        documentKind     = Model?.DocumentKind ?? "",
        isActive         = Model?.IsActive ?? true,
        rules       = (Model?.Rules ?? Array.Empty<ApprovalFlowRuleDto>()).Select(r => new {
            id        = r.Id,
            ruleType  = r.RuleType.ToString(),
            ruleValue = r.RuleValue,
            isActive  = r.IsActive,
        }),
        steps       = (Model?.Steps ?? Array.Empty<ApprovalFlowStepDto>()).Select(s => new {
            id            = s.Id,
            stepOrder     = s.StepOrder,
            stepName      = s.StepName,
            approverType  = s.ApproverType.ToString(),
            approverId    = s.ApproverId,
            approverLabel = s.ApproverLabel,
            isActive      = s.IsActive,
        }),
        variables   = (Model?.Variables ?? Array.Empty<ApprovalFlowVariableDto>()).Select(v => new {
            id           = v.Id,
            name         = v.Name,
            typeCode     = v.TypeCode,
            defaultValue = v.DefaultValue,
            description  = v.Description,
            valueSource  = v.ValueSource,
            sqlQuery     = v.SqlQuery,
            sortOrder    = v.SortOrder,
        }),
    }, jsonOpts);
    var usersJson = JsonSerializer.Serialize(ViewData["Users"] ?? Array.Empty<object>(), jsonOpts);
    var departmentsJson = JsonSerializer.Serialize(ViewData["Departments"] ?? Array.Empty<object>(), jsonOpts);
    var initialNodesEdgesJson = JsonSerializer.Serialize(
        ViewData["InitialNodesEdges"] ?? new { nodes = Array.Empty<object>(), edges = Array.Empty<object>() },
        jsonOpts);
}

@section Styles {
<style>
/* ── wrapper ───────────────────────────────────────────────── */
.afe-wrapper {
    --afe-bg:        #f8fafc;
    --afe-surface:   #ffffff;
    --afe-border:    #e2e8f0;
    --afe-text:      #1e293b;
    --afe-muted:     #64748b;
    --afe-accent:    #6366f1;
    --afe-accent-s:  rgba(99,102,241,.12);
    --afe-danger:    #ef4444;
    --afe-ok:        #10b981;
    display: flex; flex-direction: column;
    flex: 1 1 auto; min-height: 0;
    background: var(--afe-bg); color: var(--afe-text);
}
body.app-theme-dark .afe-wrapper {
    --afe-bg:        #080c17;
    --afe-surface:   #0d1323;
    --afe-border:    rgba(255,255,255,.09);
    --afe-text:      #e2e8f0;
    --afe-muted:     #94a3b8;
    --afe-accent:    #818cf8;
    --afe-accent-s:  rgba(129,140,248,.15);
}

/* ── Genel Bilgiler sağ panel ──────────────────────────────── */
.afp-overlay {
    position: fixed; inset: 0; z-index: 9890;
    background: rgba(0,0,0,.3); backdrop-filter: blur(2px);
    display: none;
}
.afp-overlay.show { display: block; }
.afp-panel {
    position: fixed; top: 0; right: -380px; width: 360px; height: 100vh;
    z-index: 9900;
    background: #ffffff;
    border-left: 1px solid #e2e8f0;
    color: #1e293b;
    box-shadow: -12px 0 40px rgba(0,0,0,.22);
    display: flex; flex-direction: column;
    transition: right .25s cubic-bezier(.4,0,.2,1);
    overflow: hidden;
}
body.app-theme-dark .afp-panel {
    background: #0d1323;
    border-left-color: rgba(255,255,255,.09);
    color: #e2e8f0;
    box-shadow: -12px 0 40px rgba(0,0,0,.55);
}
.afp-panel.open { right: 0; }
.afp-panel-header {
    display: flex; align-items: center; gap: 10px;
    padding: 16px 20px 14px;
    border-bottom: 1px solid #e2e8f0; flex-shrink: 0;
}
body.app-theme-dark .afp-panel-header { border-bottom-color: rgba(255,255,255,.09); }
.afp-panel-title { font-size: .95rem; font-weight: 700; margin: 0; flex: 1; }
.afp-panel-close {
    background: none; border: none; cursor: pointer; padding: 4px;
    color: #64748b; border-radius: 6px; line-height: 1; flex-shrink: 0;
}
.afp-panel-close:hover { background: rgba(99,102,241,.1); color: #6366f1; }
body.app-theme-dark .afp-panel-close { color: #94a3b8; }
body.app-theme-dark .afp-panel-close:hover { background: rgba(129,140,248,.15); color: #818cf8; }
.afp-panel-body { flex: 1; overflow-y: auto; padding: 20px; }
.afp-field { margin-bottom: 18px; }
.afp-field-row { display: flex; gap: 12px; margin-bottom: 18px; }
.afp-field-row .afp-field { flex: 1; margin-bottom: 0; }
.afp-label {
    display: block; font-size: .75rem; font-weight: 600;
    color: #64748b; margin-bottom: 5px; letter-spacing: .02em;
}
body.app-theme-dark .afp-label { color: #94a3b8; }
.afp-input,
.afp-select {
    width: 100%; padding: 8px 12px;
    border: 1px solid #e2e8f0; border-radius: 7px;
    background: #f8fafc; color: #1e293b;
    font-size: .875rem; font-family: inherit;
    transition: border-color .15s, box-shadow .15s;
    box-sizing: border-box;
}
body.app-theme-dark .afp-input,
body.app-theme-dark .afp-select {
    background: #080c17; color: #e2e8f0;
    border-color: rgba(255,255,255,.09);
}
.afp-input:focus,
.afp-select:focus {
    outline: none; border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,.12);
}
body.app-theme-dark .afp-input:focus,
body.app-theme-dark .afp-select:focus {
    border-color: #818cf8;
    box-shadow: 0 0 0 3px rgba(129,140,248,.15);
}
.afp-input--name { font-weight: 600; }
.afp-meta {
    margin-top: 24px; padding-top: 16px;
    border-top: 1px solid #e2e8f0;
    font-size: .78rem; color: #64748b;
    display: flex; flex-direction: column; gap: 4px;
}
body.app-theme-dark .afp-meta { border-top-color: rgba(255,255,255,.09); color: #94a3b8; }
.afp-meta strong { color: #1e293b; }
body.app-theme-dark .afp-meta strong { color: #e2e8f0; }

/* ── Center confirm modal (silme onay standardı muadili) ────
   .afe-wrapper'in DIŞINDA mount edildiği için kendi self-contained
   teması var (--afe-* değişkenlerine dayanmaz). */
.afe-confirm-backdrop {
    position: fixed; inset: 0; z-index: 10000;
    background: rgba(2, 6, 23, .72); backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: none; align-items: center; justify-content: center;
    opacity: 0; transition: opacity .15s;
}
.afe-confirm-backdrop.show { display: flex; opacity: 1; }
.afe-confirm-card {
    background: #ffffff; color: #1e293b;
    border: 1px solid #e2e8f0; border-radius: 14px;
    box-shadow: 0 32px 96px rgba(0,0,0,.45), 0 0 0 1px rgba(0,0,0,.04);
    width: min(440px, calc(100vw - 32px));
    padding: 24px 24px 20px;
    transform: scale(.96); transition: transform .15s;
}
body.app-theme-dark .afe-confirm-card {
    background: #0f172a; color: #e2e8f0;
    border-color: rgba(255,255,255,.1);
    box-shadow: 0 32px 96px rgba(0,0,0,.7), 0 0 0 1px rgba(255,255,255,.04);
}
.afe-confirm-backdrop.show .afe-confirm-card { transform: scale(1); }
.afe-confirm-icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: rgba(245, 158, 11, .14); color: #f59e0b;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 14px;
}
.afe-confirm-title {
    text-align: center; font-size: 1.08rem; font-weight: 600;
    margin: 0 0 8px;
}
.afe-confirm-msg {
    text-align: center; font-size: .88rem; color: #64748b;
    line-height: 1.55; margin: 0 0 20px;
}
body.app-theme-dark .afe-confirm-msg { color: #94a3b8; }
.afe-confirm-actions {
    display: flex; gap: 10px; justify-content: flex-end;
}
.afe-confirm-actions button {
    padding: 8px 20px; border-radius: 8px; font-size: .85rem;
    font-weight: 600; cursor: pointer; transition: all .15s;
    font-family: inherit;
}
.afe-confirm-btn-cancel {
    background: transparent; color: #1e293b;
    border: 1px solid #e2e8f0;
}
.afe-confirm-btn-cancel:hover { background: #f1f5f9; }
body.app-theme-dark .afe-confirm-btn-cancel {
    color: #e2e8f0; border-color: rgba(255,255,255,.12);
}
body.app-theme-dark .afe-confirm-btn-cancel:hover { background: rgba(255,255,255,.04); }
.afe-confirm-btn-ok {
    background: #6366f1; color: #fff; border: 1px solid #6366f1;
}
.afe-confirm-btn-ok:hover { background: #4f46e5; border-color: #4f46e5; }
body.app-theme-dark .afe-confirm-btn-ok {
    background: #818cf8; border-color: #818cf8;
}
body.app-theme-dark .afe-confirm-btn-ok:hover { background: #6366f1; border-color: #6366f1; }

/* switch */
.afe-switch { display: inline-flex; align-items: center; gap: 7px; font-size: .82rem; cursor: pointer; }
.afe-switch input[type=checkbox] { display: none; }
.afe-switch__track {
    width: 36px; height: 20px; border-radius: 10px;
    background: #ef4444; transition: background .2s;
    position: relative; flex-shrink: 0;
}
.afe-switch input:checked + .afe-switch__track { background: #10b981; }
.afe-switch__track::after {
    content: ''; position: absolute; top: 3px; left: 3px;
    width: 14px; height: 14px; border-radius: 50%; background: #fff;
    transition: left .2s;
}
.afe-switch input:checked + .afe-switch__track::after { left: 19px; }

/* ── Body (full height designer) ───────────────────────────── */
.afe-body-designer {
    flex: 1 1 auto; min-height: 0;
    padding: 12px 16px;
    display: flex; flex-direction: column;
}
#approval-flow-designer-root {
    flex: 1 1 auto;
    min-height: 0;
}

/* ── toast ─── */
.afe-toast {
    position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%);
    padding: 12px 24px; border-radius: 10px; font-size: .875rem; font-weight: 600;
    z-index: 9999; box-shadow: 0 8px 32px rgba(0,0,0,.2);
    opacity: 0; transition: opacity .25s;
}
.afe-toast.show { opacity: 1; }
.afe-toast--ok  { background: #d1fae5; color: #065f46; }
.afe-toast--err { background: #fee2e2; color: #991b1b; }
body.app-theme-dark .afe-toast--ok  { background: rgba(34,197,94,.2);  color: #4ade80; }
body.app-theme-dark .afe-toast--err { background: rgba(239,68,68,.2);  color: #f87171; }

/* ── Revizyon geçmişi modal ─────────────────────────────────── */
.afh-backdrop {
    position: fixed; inset: 0; z-index: 10500;
    background: rgba(2,6,23,.72); backdrop-filter: blur(6px);
    display: none; align-items: flex-start; justify-content: center;
    padding-top: 48px;
}
.afh-backdrop.show { display: flex; }
.afh-card {
    background: #ffffff; color: #1e293b;
    border: 1px solid #e2e8f0; border-radius: 14px;
    box-shadow: 0 32px 96px rgba(0,0,0,.38);
    width: min(880px, calc(100vw - 32px));
    max-height: calc(100vh - 80px);
    display: flex; flex-direction: column;
    overflow: hidden;
}
body.app-theme-dark .afh-card {
    background: #0f172a; color: #e2e8f0;
    border-color: rgba(255,255,255,.1);
    box-shadow: 0 32px 96px rgba(0,0,0,.7);
}
.afh-header {
    display: flex; align-items: center; gap: 10px;
    padding: 16px 20px 14px;
    border-bottom: 1px solid #e2e8f0; flex-shrink: 0;
}
body.app-theme-dark .afh-header { border-color: rgba(255,255,255,.09); }
.afh-title { font-size: 1rem; font-weight: 700; margin: 0; flex: 1; }
.afh-close {
    background: none; border: none; cursor: pointer; padding: 4px;
    color: #64748b; border-radius: 6px; line-height: 1;
}
.afh-close:hover { background: #f1f5f9; color: #1e293b; }
body.app-theme-dark .afh-close:hover { background: rgba(255,255,255,.08); color: #e2e8f0; }
.afh-body {
    display: flex; flex: 1; min-height: 0; overflow: hidden;
}
.afh-left {
    width: 300px; flex-shrink: 0; border-right: 1px solid #e2e8f0;
    overflow-y: auto; padding: 12px 0;
}
body.app-theme-dark .afh-left { border-color: rgba(255,255,255,.09); }
.afh-right {
    flex: 1; min-width: 0; overflow-y: auto; padding: 16px 20px;
}
.afh-rev-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 16px; cursor: pointer; transition: background .12s;
    border-left: 3px solid transparent;
}
.afh-rev-item:hover { background: #f8fafc; }
.afh-rev-item.active { border-left-color: #6366f1; background: #f0f1ff; }
body.app-theme-dark .afh-rev-item:hover { background: rgba(255,255,255,.04); }
body.app-theme-dark .afh-rev-item.active { background: rgba(99,102,241,.14); }
.afh-rev-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 32px; height: 24px; padding: 0 8px;
    border-radius: 12px; font-size: .75rem; font-weight: 700;
    background: #e0e7ff; color: #3730a3;
}
body.app-theme-dark .afh-rev-badge { background: rgba(99,102,241,.25); color: #a5b4fc; }
.afh-rev-info { flex: 1; min-width: 0; }
.afh-rev-date { font-size: .78rem; color: #64748b; }
body.app-theme-dark .afh-rev-date { color: #94a3b8; }
.afh-pending-badge {
    display: inline-flex; align-items: center; gap: 3px;
    padding: 2px 8px; border-radius: 10px; font-size: .72rem; font-weight: 600;
    background: #fef3c7; color: #92400e;
}
body.app-theme-dark .afh-pending-badge { background: rgba(245,158,11,.2); color: #fcd34d; }
.afh-section-title {
    font-size: .78rem; font-weight: 700;
    letter-spacing: .06em; color: #64748b; margin: 0 0 10px;
}
body.app-theme-dark .afh-section-title { color: #94a3b8; }
.afh-empty { font-size: .85rem; color: #94a3b8; text-align: center; padding: 24px 0; }
.afh-steps-list { list-style: none; margin: 0 0 20px; padding: 0; display: flex; flex-direction: column; gap: 6px; }
.afh-step {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 10px 12px; border-radius: 8px;
    background: #f8fafc; border: 1px solid #e2e8f0;
    font-size: .84rem;
}
body.app-theme-dark .afh-step { background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.09); }
.afh-step-num {
    min-width: 22px; height: 22px; border-radius: 50%;
    background: #e0e7ff; color: #3730a3;
    display: flex; align-items: center; justify-content: center;
    font-size: .72rem; font-weight: 700; flex-shrink: 0; margin-top: 1px;
}
body.app-theme-dark .afh-step-num { background: rgba(99,102,241,.25); color: #a5b4fc; }
.afh-step-name { font-weight: 600; }
.afh-step-who  { font-size: .78rem; color: #64748b; }
body.app-theme-dark .afh-step-who { color: #94a3b8; }
.afh-pending-table { width: 100%; border-collapse: collapse; font-size: .83rem; }
.afh-pending-table th {
    text-align: left; padding: 6px 10px; font-size: .73rem; font-weight: 700;
    color: #64748b; border-bottom: 2px solid #e2e8f0;
}
body.app-theme-dark .afh-pending-table th { color: #94a3b8; border-color: rgba(255,255,255,.09); }
.afh-pending-table td {
    padding: 8px 10px; border-bottom: 1px solid #f1f5f9;
}
body.app-theme-dark .afh-pending-table td { border-color: rgba(255,255,255,.06); }
.afh-loading { text-align: center; color: #94a3b8; padding: 32px 0; font-size: .88rem; }
</style>
}

<div class="ux-edit-shell">
@await Html.PartialAsync("_CalibraActionBar", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
{
    ["Title"]      = isNew ? "Yeni Onay Akışı" : $"Akış: {Model!.Name}",
    ["ListUrl"]    = "/ApprovalFlow",
    ["SaveBtnId"]  = "afe-save",
    ["ShowDelete"] = false,
    ["ShowNew"]    = false,
})
<div class="afe-wrapper">
    <!-- Body: tam ekran designer -->
    <div class="afe-body-designer">
        <div id="approval-flow-designer-root"></div>
    </div>

</div>
</div>

<div class="afe-toast" id="toast"></div>

<!-- Revizyon geçmişi modal -->
<div class="afh-backdrop" id="afh-backdrop" role="dialog" aria-modal="true">
    <div class="afh-card">
        <div class="afh-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#6366f1;flex-shrink:0">
                <path d="M12 8v4l3 3"/><path d="M3.05 11a9 9 0 1 1 .5 4m-.5 5v-5h5"/>
            </svg>
            <p class="afh-title">Revizyon Geçmişi</p>
            <button type="button" class="afh-close" id="afh-close" aria-label="Kapat">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="afh-body">
            <div class="afh-left" id="afh-rev-list">
                <div class="afh-loading">Yükleniyor…</div>
            </div>
            <div class="afh-right" id="afh-detail">
                <div class="afh-empty">Listedeki bir revizyonu seçin.</div>
            </div>
        </div>
    </div>
</div>

<!-- Genel Bilgiler sağ panel -->
<div class="afp-overlay" id="afpOverlay"></div>
<div class="afp-panel" id="afpPanel" role="dialog" aria-modal="true" aria-labelledby="afpPanelTitle">
    <div class="afp-panel-header">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#6366f1;flex-shrink:0">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p class="afp-panel-title" id="afpPanelTitle">Genel Bilgiler</p>
        <button type="button" class="afp-panel-close" id="afpClose" aria-label="Kapat">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
    </div>
    <div class="afp-panel-body">
        <div class="afp-field">
            <label class="afp-label" for="fName">Akış Adı</label>
            <input type="text" id="fName" class="afp-input afp-input--name" placeholder="Akış Adı *" autocomplete="off" />
        </div>
        <div class="afp-field">
            <label class="afp-label" for="fKind">Belge / Entity Türü</label>
            <select id="fKind" class="afp-select" title="Entity Tipi">
                @* Dinamik seçenekler script tarafından doldurulur (ENTITY_TYPES). *@
            </select>
        </div>
        <div class="afp-field" style="display:flex;align-items:center;padding-top:4px">
            <label class="afe-switch">
                <input type="checkbox" id="fActive" checked />
                <span class="afe-switch__track"></span>
                <span>Aktif</span>
            </label>
        </div>
        @if (!isNew)
        {
            <div class="afp-meta">
                <span>Akış ID: <strong>@flowId</strong></span>
            </div>
        }
    </div>
</div>

<!-- Center confirm modal (entity tipi değişimi gibi onay-gerektiren akışlar için) -->
<div class="afe-confirm-backdrop" id="afeConfirmBackdrop" role="dialog" aria-modal="true" aria-labelledby="afeConfirmTitle">
    <div class="afe-confirm-card">
        <div class="afe-confirm-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>
        <h3 class="afe-confirm-title" id="afeConfirmTitle">Entity Tipi Değişiyor</h3>
        <p class="afe-confirm-msg" id="afeConfirmMsg"></p>
        <div class="afe-confirm-actions">
            <button type="button" class="afe-confirm-btn-cancel" id="afeConfirmCancel">Vazgeç</button>
            <button type="button" class="afe-confirm-btn-ok" id="afeConfirmOk">Devam Et</button>
        </div>
    </div>
</div>

@section Scripts {
<link rel="stylesheet" href="~/react/calibrahub-widgets.css" asp-append-version="true" />
<script src="~/react/calibrahub-widgets.js" asp-append-version="true"></script>
<script>
(function () {
    // ── başlangıç verisi ──────────────────────────────────────────────────────
    var INIT = @Html.Raw(initData);
    var USERS = @Html.Raw(usersJson);
    var DEPARTMENTS = @Html.Raw(departmentsJson);
    var CARI_GROUPS = @Html.Raw(JsonSerializer.Serialize(ViewData["CariGroups"] ?? Array.Empty<object>(), jsonOpts));
    var MATERIAL_GROUPS = @Html.Raw(JsonSerializer.Serialize(ViewData["MaterialGroups"] ?? new Dictionary<string,object>(), jsonOpts));
    var SQL_QUERIES = @Html.Raw(JsonSerializer.Serialize(ViewData["SqlQueries"] ?? Array.Empty<object>(), jsonOpts));
    var INTEGRATIONS = @Html.Raw(JsonSerializer.Serialize(ViewData["Integrations"] ?? Array.Empty<object>(), jsonOpts));
    // Entity-agnostic plugin: backend registry'den entity tipleri kataloğu.
    var ENTITY_TYPES = @Html.Raw(JsonSerializer.Serialize(ViewData["EntityTypes"] ?? Array.Empty<object>(), jsonOpts));
    if (!Array.isArray(ENTITY_TYPES)) ENTITY_TYPES = [];
    var INITIAL_NODES_EDGES = (function () {
        try { return @Html.Raw(initialNodesEdgesJson); }
        catch (e) { return { nodes: [], edges: [] }; }
    })();
    if (!INITIAL_NODES_EDGES || typeof INITIAL_NODES_EDGES !== 'object') {
        INITIAL_NODES_EDGES = { nodes: [], edges: [] };
    }

    // ── DOM bağlantıları ──────────────────────────────────────────────────────
    var fName      = document.getElementById('fName');
    var fKind      = document.getElementById('fKind');
    var fActive    = document.getElementById('fActive');

    // Action bar title'a status dot + name span enjekte et
    (function() {
        var titleEl = document.querySelector('.pte-action-bar__title');
        if (!titleEl) return;
        titleEl.style.cssText += 'display:inline-flex;align-items:center;gap:7px;';
        titleEl.innerHTML = '';
        var dotEl = document.createElement('span');
        dotEl.id = 'hbStatusDot';
        dotEl.style.cssText = 'width:8px;height:8px;border-radius:50%;flex-shrink:0;background:#10b981;box-shadow:0 0 0 2px rgba(16,185,129,.2);transition:background .2s,box-shadow .2s;';
        var nameEl = document.createElement('span');
        nameEl.id = 'hbFlowName';
        titleEl.appendChild(dotEl);
        titleEl.appendChild(nameEl);
    })();

    // Action bar'a sağ taraf araç butonlarını ekle (pte-meta sonrasına = sağ taraf)
    (function() {
        var bar = document.querySelector('.pte-action-bar');
        if (!bar) return;
        var toolBtns = [
            { id: 'btnVars',    title: 'Değişkenler',
              svg: '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1"/><path d="M16 3h1a2 2 0 0 1 2 2v5c0 1.1.9 2 2 2a2 2 0 0 1-2 2v5a2 2 0 0 1-2 2h-1"/></svg>' },
            { id: 'btnMiniMap', title: 'Mini Harita',
              svg: '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 6 6-3 6 3 6-3v14l-6 3-6-3-6 3V6z"/><path d="M9 3v14M15 6v14"/></svg>' },
            { id: 'btnInfo',    title: 'Genel Bilgiler',
              svg: '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>' },
        ];
        if (!@(isNew ? "true" : "false")) {
            toolBtns.push({ id: 'btnHistory', title: 'Revizyon Geçmişi',
                svg: '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"/><path d="M3.05 11a9 9 0 1 1 .5 4m-.5 5v-5h5"/></svg>' });
        }
        toolBtns.forEach(function(b) {
            var el = document.createElement('button');
            el.type = 'button'; el.id = b.id;
            el.className = 'pte-btn pte-btn--secondary pte-btn--icon';
            el.title = b.title; el.setAttribute('aria-label', b.title);
            el.innerHTML = b.svg;
            bar.appendChild(el);
        });
    })();

    var hbName     = document.getElementById('hbFlowName');
    var hbDot      = document.getElementById('hbStatusDot');

    // ── Center confirm modal helper (Promise tabanlı) ──────────────────────────
    function afeConfirm(message, opts) {
        opts = opts || {};
        return new Promise(function (resolve) {
            var back = document.getElementById('afeConfirmBackdrop');
            var msgEl = document.getElementById('afeConfirmMsg');
            var titleEl = document.getElementById('afeConfirmTitle');
            var okBtn = document.getElementById('afeConfirmOk');
            var cancelBtn = document.getElementById('afeConfirmCancel');
            msgEl.textContent = message || '';
            if (opts.title) titleEl.textContent = opts.title;
            if (opts.okLabel) okBtn.textContent = opts.okLabel;
            back.classList.add('show');
            setTimeout(function () { okBtn.focus(); }, 30);

            function cleanup(result) {
                back.classList.remove('show');
                okBtn.removeEventListener('click', onOk);
                cancelBtn.removeEventListener('click', onCancel);
                back.removeEventListener('click', onBackdrop);
                document.removeEventListener('keydown', onKey);
                resolve(result);
            }
            function onOk() { cleanup(true); }
            function onCancel() { cleanup(false); }
            function onBackdrop(e) { if (e.target === back) cleanup(false); }
            function onKey(e) {
                if (e.key === 'Escape') cleanup(false);
                else if (e.key === 'Enter') cleanup(true);
            }
            okBtn.addEventListener('click', onOk);
            cancelBtn.addEventListener('click', onCancel);
            back.addEventListener('click', onBackdrop);
            document.addEventListener('keydown', onKey);
        });
    }

    // ── başlangıç değerleri ───────────────────────────────────────────────────
    // Entity tipi select'i dinamik doldur (ENTITY_TYPES backend'den geldi).
    // Boş fallback: hep "Document" var sayalım — backend tarafı zaten Document'i kayıt eder.
    fKind.innerHTML = '';
    if (ENTITY_TYPES.length === 0) {
        var opt0 = document.createElement('option');
        opt0.value = 'Document'; opt0.textContent = 'Tüm Belgeler';
        fKind.appendChild(opt0);
    } else {
        // optgroup ile grupla: groupCategory'ye göre (Belgeler / Üretim / Tanımlar / Diğer)
        // Grup sırası: ilk karşılaşma sırasında deterministik kalsın.
        var groups = {};
        var groupOrder = [];
        ENTITY_TYPES.forEach(function (et) {
            var g = et.groupCategory || 'Diğer';
            if (!groups[g]) { groups[g] = []; groupOrder.push(g); }
            groups[g].push(et);
        });
        groupOrder.forEach(function (g) {
            var og = document.createElement('optgroup');
            og.label = g;
            groups[g].forEach(function (et) {
                var opt = document.createElement('option');
                opt.value = et.code; opt.textContent = et.label || et.code;
                og.appendChild(opt);
            });
            fKind.appendChild(og);
        });
    }

    fName.value = INIT.name || '';
    hbName.textContent = INIT.name || 'Yeni Akış';
    fActive.checked = INIT.isActive !== false;
    var initKind = INIT.documentKind || '';
    // Geriye uyumluluk: "All" enum değeri yeni sistemde "Document" (wildcard) ile eş anlamlı.
    if (initKind === 'All') initKind = 'Document';

    // "Document" wildcard yeni akışlarda kullanılmaz (kullanıcı belge bazlı spesifik akış
    // tasarlar, "tüm belgeler" gerekirse Kopyala ile çoğaltır). Ama mevcut bir akışın
    // değeri Document ise kayıt değerinin korunması için option olarak ekleriz (en üste,
    // legacy uyarısıyla). Kullanıcı dilerse spesifik bir belge türüne taşır.
    if (initKind === 'Document') {
        var legacyOpt = document.createElement('option');
        legacyOpt.value = 'Document';
        legacyOpt.textContent = '⚠ Tüm Belgeler (eski tip)';
        fKind.insertBefore(legacyOpt, fKind.firstChild);
    }

    fKind.value = initKind;
    if (!fKind.value && fKind.options.length > 0) fKind.value = fKind.options[0].value;

    // Entity tipi değişti mi? — Save sonrası designer'ı yeni field setiyle yeniden
    // mount edebilmek için sayfayı reload ederiz. (Reload-before-save eski davranıştı
    // ama controller URL param'i ignore ediyordu → kayıt görünmüyor sanılıyordu.)
    var entityChanged = false;
    fKind.addEventListener('change', function () {
        var newCode = fKind.value;
        if (!newCode || newCode === initKind) return;
        var msg = 'Entity tipini değiştirmek karar koşullarındaki alanları sıfırlayabilir. ' +
                  'Devam etmek istiyor musunuz? (Kaydet butonuna basana kadar değişiklik DB\'ye yazılmaz.)';
        afeConfirm(msg, { title: 'Entity Tipi Değiştiriliyor', okLabel: 'Devam Et' }).then(function (ok) {
            if (!ok) { fKind.value = initKind; return; }
            entityChanged = true;
            showToast('Yeni entity tipi seçildi — kaydedildikten sonra alanlar yenilenecek.', true);
        });
    });

    // ── Designer payload cache (rules artık designer'dan gelir) ───────────────
    var designerPayload = null;

    // ── React Flow designer mount ─────────────────────────────────────────────
    function mountDesignerWhenReady() {
        var root = document.getElementById('approval-flow-designer-root');
        if (!root) return;
        if (window.CalibraHub && typeof window.CalibraHub.mountApprovalFlowDesigner === 'function') {
            window.CalibraHub.mountApprovalFlowDesigner(root, {
                apiBase:      '/ApprovalFlow',
                flowId:       INIT.id || 0,
                initialNodes: Array.isArray(INITIAL_NODES_EDGES.nodes) ? INITIAL_NODES_EDGES.nodes : [],
                initialEdges: Array.isArray(INITIAL_NODES_EDGES.edges) ? INITIAL_NODES_EDGES.edges : [],
                initialRules: Array.isArray(INIT.rules) ? INIT.rules : [],
                initialVariables: Array.isArray(INIT.variables) ? INIT.variables : [],
                users:        USERS,
                departments:  DEPARTMENTS,
                cariGroups:   CARI_GROUPS,
                materialGroups: MATERIAL_GROUPS,
                sqlQueries:   SQL_QUERIES,
                integrations: INTEGRATIONS,
                entityTypes:  ENTITY_TYPES,
                currentEntityType: fKind.value || 'Document',
                canUseAdhoc:  true,
                onSave: function (payload) {
                    designerPayload = payload;
                    window._afDesignerPayload = payload;
                }
            });
        } else {
            setTimeout(mountDesignerWhenReady, 80);
        }
    }
    mountDesignerWhenReady();

    // ── Kaydet ────────────────────────────────────────────────────────────────
    function showToast(msg, ok) {
        var t = document.getElementById('toast');
        t.textContent = msg;
        t.className = 'afe-toast ' + (ok ? 'afe-toast--ok' : 'afe-toast--err') + ' show';
        setTimeout(function() { t.classList.remove('show'); }, 3000);
    }

    async function doSave() {
        var name = fName.value.trim();
        if (!name) { showToast('Akış adı zorunludur.', false); fName.focus(); return; }

        // Designer payload — rules + nodes + edges hepsi designer'dan gelir.
        var dp = window._afDesignerPayload || designerPayload || null;
        if (!dp && typeof window._afDesignerGetPayload === 'function') {
            try { dp = window._afDesignerGetPayload(); } catch (e) { dp = null; }
        }
        var dpNodes = (dp && Array.isArray(dp.nodes)) ? dp.nodes : [];
        var dpEdges = (dp && Array.isArray(dp.edges)) ? dp.edges : [];
        var dpRules = (dp && Array.isArray(dp.rules)) ? dp.rules : (INIT.rules || []);

        // En az bir adım (step tipi) düğümü zorunlu
        var stepNodes = dpNodes.filter(function (n) { return n.nodeType === 'step'; });
        if (stepNodes.length === 0) {
            showToast('En az bir onay adımı (step düğümü) tanımlanmalıdır.', false);
            return;
        }

        // 3. kol (Gecikme/timeout) tutarlılık kontrolü:
        //   - Timeout edge varsa slaHours > 0 zorunlu (SLA toggle kaldırıldı —
        //     edge'in varlığı SLA'nın aktif olması demek)
        for (var si = 0; si < stepNodes.length; si++) {
            var sn = stepNodes[si];
            var nd = null;
            try { nd = sn.nodeDataJson ? JSON.parse(sn.nodeDataJson) : null; } catch (e) { nd = null; }
            nd = nd || {};
            var hasTimeoutEdge = dpEdges.some(function (e) {
                return e.sourceClientId === sn.clientId && e.edgeKind === 'timeout';
            });
            if (hasTimeoutEdge) {
                var sh = parseInt(nd.slaHours, 10);
                if (!sh || sh <= 0) {
                    showToast('"' + (sn.stepName || 'Adım') + '" Gecikme kolu bağlı ama süre girilmemiş — edge\'i seçip Süre alanına değer girin.', false);
                    return;
                }
            }
        }

        function extractDbId(clientId) {
            if (typeof clientId !== 'string') return 0;
            var m = clientId.match(/^step_(\d+)$/);
            return m ? parseInt(m[1], 10) : 0;
        }
        var stepsPayload = dpNodes.map(function (n, i) {
            var label = n.stepName
                || (n.nodeType === 'start'    ? 'Başla'
                  : n.nodeType === 'end'      ? 'Bitir'
                  : n.nodeType === 'decision' ? 'Karar'
                  : 'Adım ' + (i + 1));
            return {
                id:            extractDbId(n.clientId),
                stepOrder:     i + 1,
                stepName:      label,
                approverType:  n.approverType || 'AnyUser',
                approverId:    n.approverId || null,
                approverLabel: n.approverLabel || null,
                isActive:      true,
                nodeType:      n.nodeType || 'step',
                posX:          Math.round(n.posX || 0),
                posY:          Math.round(n.posY || 0),
                nodeData:      n.nodeDataJson || null,
            };
        });

        var edgesPayload = dpEdges.map(function (e, i) {
            var srcIdx = dpNodes.findIndex(function (x) { return x.clientId === e.sourceClientId; });
            var tgtIdx = dpNodes.findIndex(function (x) { return x.clientId === e.targetClientId; });
            if (srcIdx < 0 || tgtIdx < 0) return null;
            return {
                id:                 0,
                sourceStepClientId: srcIdx,
                targetStepClientId: tgtIdx,
                label:              e.label || null,
                edgeKind:           e.edgeKind || 'default',
                condition:          e.condition || null,
                sortOrder:          (typeof e.sortOrder === 'number' ? e.sortOrder : i),
                sourceHandle:       e.sourceHandle || null,
                targetHandle:       e.targetHandle || null,
            };
        }).filter(Boolean);

        var payload = {
            id:           INIT.id,
            name:         name,
            description:  INIT.description || null,
            documentKind: fKind.value,
            isActive:     fActive.checked,
            rules: dpRules.map(function(r) {
                return {
                    id: r.id || 0,
                    ruleType: r.ruleType,
                    ruleValue: r.ruleValue || null,
                    isActive: r.isActive !== false,
                };
            }),
            steps: stepsPayload,
            edges: edgesPayload,
            variables: (dp && Array.isArray(dp.variables) ? dp.variables : (INIT.variables || [])).map(function (v, vi) {
                return {
                    id:           v.id || 0,
                    name:         (v.name || '').trim(),
                    typeCode:     v.typeCode || 'int',
                    defaultValue: v.defaultValue || null,
                    description:  v.description || null,
                    valueSource:  v.valueSource || 'manual',
                    sqlQuery:     v.sqlQuery || null,
                    sortOrder:    (typeof v.sortOrder === 'number' ? v.sortOrder : vi),
                };
            }).filter(function (v) { return v.name; }),
        };

        var btn = document.getElementById('afe-save');
        if (btn) btn.disabled = true;

        try {
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            var res = await fetch('/ApprovalFlow/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(payload),
            });
            var data = await res.json();
            if (data.ok) {
                showToast('Kaydedildi.', true);
                INIT.id = data.id;
                // Yeni kayıt VEYA entity tipi değişti → sayfayı reload et ki designer
                // yeni entity'nin field setiyle taze mount olsun.
                if (payload.id === 0) {
                    setTimeout(function() { window.location.href = '/ApprovalFlow/Edit?id=' + data.id; }, 800);
                } else if (entityChanged) {
                    setTimeout(function() { window.location.reload(); }, 800);
                }
            } else {
                showToast('Hata: ' + (data.error || 'Bilinmeyen hata'), false);
            }
        } catch(e) {
            showToast('Bağlantı hatası: ' + e.message, false);
        } finally {
            if (btn) btn.disabled = false;
        }
    }

    document.getElementById('afe-save').addEventListener('click', doSave);

    // ── Toolbar: ad + durum noktası senkronizasyonu ──────────────────────────
    fName.addEventListener('input', function () {
        hbName.textContent = fName.value.trim() || 'Yeni Akış';
    });

    function updateStatusDot() {
        if (!hbDot) return;
        if (fActive.checked) {
            hbDot.style.background = '#10b981';
            hbDot.style.boxShadow = '0 0 0 2px rgba(16,185,129,.2)';
        } else {
            hbDot.style.background = '#ef4444';
            hbDot.style.boxShadow = '0 0 0 2px rgba(239,68,68,.2)';
        }
    }
    fActive.addEventListener('change', updateStatusDot);
    updateStatusDot();

    // ── Değişkenler butonu ───────────────────────────────────────────────────
    document.getElementById('btnVars').addEventListener('click', function () {
        if (typeof window._afdOpenVariables === 'function') window._afdOpenVariables();
    });

    // ── Mini Harita butonu ───────────────────────────────────────────────────
    (function () {
        var btn = document.getElementById('btnMiniMap');
        var MMKEY = 'cb-afd-minimap-on';
        function syncBtn() {
            var on = localStorage.getItem(MMKEY) === '1';
            btn.classList.toggle('active', on);
            btn.style.background = on ? 'var(--bs-primary, #6366f1)' : '';
            btn.style.color      = on ? '#fff' : '';
            btn.style.borderColor = on ? 'var(--bs-primary, #6366f1)' : '';
        }
        syncBtn();
        btn.addEventListener('click', function () {
            if (typeof window._afdToggleMinimap === 'function') {
                window._afdToggleMinimap();
                setTimeout(syncBtn, 50);
            }
        });
    })();

    // ── Genel Bilgiler sağ panel ──────────────────────────────────────────────
    (function () {
        var panel   = document.getElementById('afpPanel');
        var overlay = document.getElementById('afpOverlay');
        var btnInfo = document.getElementById('btnInfo');
        var closeBtn = document.getElementById('afpClose');

        function openPanel() {
            panel.classList.add('open');
            overlay.classList.add('show');
            document.addEventListener('keydown', onEscPanel);
            setTimeout(function () { fName.focus(); fName.select(); }, 60);
        }

        function closePanel() {
            panel.classList.remove('open');
            overlay.classList.remove('show');
            document.removeEventListener('keydown', onEscPanel);
        }

        function onEscPanel(e) { if (e.key === 'Escape') closePanel(); }

        btnInfo.addEventListener('click', openPanel);
        closeBtn.addEventListener('click', closePanel);
        overlay.addEventListener('click', closePanel);

        // Yeni akışta paneli otomatik aç
        if (@(isNew ? "true" : "false")) {
            setTimeout(openPanel, 120);
        }
    })();

    // ── Revizyon geçmişi modal ────────────────────────────────────────────────
    (function () {
        var FLOW_ID = @(isNew ? "0" : flowId.ToString());
        if (!FLOW_ID) return; // yeni akış — geçmiş yok

        var backdrop  = document.getElementById('afh-backdrop');
        var closeBtn  = document.getElementById('afh-close');
        var revList   = document.getElementById('afh-rev-list');
        var detailEl  = document.getElementById('afh-detail');
        var histBtn   = document.getElementById('btnHistory');
        if (!histBtn) return;

        function fmtDate(s) {
            if (!s) return '-';
            var d = new Date(s);
            return d.toLocaleDateString('tr-TR', { day:'2-digit', month:'2-digit', year:'numeric' })
                 + ' ' + d.toLocaleTimeString('tr-TR', { hour:'2-digit', minute:'2-digit' });
        }

        function openModal() {
            backdrop.classList.add('show');
            document.addEventListener('keydown', onEsc);
            revList.innerHTML = '<div class="afh-loading">Yükleniyor…</div>';
            detailEl.innerHTML = '<div class="afh-empty">Listedeki bir revizyonu seçin.</div>';

            fetch('/ApprovalFlow/Revisions?flowId=' + FLOW_ID)
                .then(function (r) { return r.json(); })
                .then(renderList)
                .catch(function () { revList.innerHTML = '<div class="afh-empty">Yüklenemedi.</div>'; });
        }

        function closeModal() {
            backdrop.classList.remove('show');
            document.removeEventListener('keydown', onEsc);
        }

        function onEsc(e) { if (e.key === 'Escape') closeModal(); }

        function renderList(revs) {
            if (!revs || !revs.length) {
                revList.innerHTML = '<div class="afh-empty">Henüz revizyon kaydı yok.</div>';
                return;
            }
            var html = '';
            revs.forEach(function (r) {
                var pendHtml = r.pendingCount > 0
                    ? '<span class="afh-pending-badge"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>' + r.pendingCount + ' bekleyen</span>'
                    : '';
                html += '<div class="afh-rev-item" data-id="' + r.id + '" tabindex="0" role="button">'
                      +   '<span class="afh-rev-badge">Rev ' + r.revisionNo + '</span>'
                      +   '<div class="afh-rev-info">'
                      +     '<div style="font-size:.82rem;font-weight:600">' + fmtDate(r.createdAt) + '</div>'
                      +     '<div class="afh-rev-date">' + (r.createdBy || '-') + '</div>'
                      +     pendHtml
                      +   '</div>'
                      + '</div>';
            });
            revList.innerHTML = html;
            revList.querySelectorAll('.afh-rev-item').forEach(function (el) {
                el.addEventListener('click', function () {
                    revList.querySelectorAll('.afh-rev-item').forEach(function (x) { x.classList.remove('active'); });
                    el.classList.add('active');
                    loadDetail(el.dataset.id);
                });
                el.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') el.click(); });
            });
            // İlk revizyonu otomatik seç
            var first = revList.querySelector('.afh-rev-item');
            if (first) first.click();
        }

        function loadDetail(revId) {
            detailEl.innerHTML = '<div class="afh-loading">Yükleniyor…</div>';
            fetch('/ApprovalFlow/RevisionDetail?id=' + revId)
                .then(function (r) { return r.json(); })
                .then(renderDetail)
                .catch(function () { detailEl.innerHTML = '<div class="afh-empty">Yüklenemedi.</div>'; });
        }

        function renderDetail(d) {
            var snap = {};
            try { snap = JSON.parse(d.snapshot); } catch (e) {}

            var steps = (snap.steps || []).filter(function (s) {
                var nt = (s.nodeType || 'step').toLowerCase();
                return nt === 'step';
            });

            // Adımlar
            var stepsHtml = '<p class="afh-section-title">Onay Adımları</p>';
            if (!steps.length) {
                stepsHtml += '<div class="afh-empty" style="padding:8px 0">Adım bilgisi bulunamadı.</div>';
            } else {
                stepsHtml += '<ul class="afh-steps-list">';
                steps.forEach(function (s, i) {
                    stepsHtml += '<li class="afh-step">'
                               + '<span class="afh-step-num">' + (i + 1) + '</span>'
                               + '<div><div class="afh-step-name">' + esc(s.stepName || 'Adım') + '</div>'
                               + '<div class="afh-step-who">' + esc(s.approverLabel || s.approverId || '') + '</div></div>'
                               + '</li>';
                });
                stepsHtml += '</ul>';
            }

            // Bekleyen belgeler
            var pendHtml = '<p class="afh-section-title" style="margin-top:16px">Bekleyen Belgeler</p>';
            if (!d.pendingInstances || !d.pendingInstances.length) {
                pendHtml += '<div class="afh-empty" style="padding:8px 0">Bu revizyona ait bekleyen belge yok.</div>';
            } else {
                pendHtml += '<table class="afh-pending-table"><thead><tr>'
                          + '<th>Belge No</th><th>Adım</th><th>Onaylayıcı</th><th>Başlangıç</th>'
                          + '</tr></thead><tbody>';
                d.pendingInstances.forEach(function (p) {
                    pendHtml += '<tr>'
                              + '<td>' + esc(p.documentNumber || '#' + p.instanceId) + '</td>'
                              + '<td>' + esc(p.currentStepName || '-') + '</td>'
                              + '<td>' + esc(p.approverName || '-') + '</td>'
                              + '<td>' + fmtDate(p.startedAt) + '</td>'
                              + '</tr>';
                });
                pendHtml += '</tbody></table>';
            }

            detailEl.innerHTML = stepsHtml + pendHtml;
        }

        function esc(s) {
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        histBtn.addEventListener('click', openModal);
        closeBtn.addEventListener('click', closeModal);
        backdrop.addEventListener('click', function (e) { if (e.target === backdrop) closeModal(); });
    })();
})();
</script>
@Html.AntiForgeryToken()
}
