@model CalibraHub.Web.Controllers.IntegrationDocCatalogEnumEditViewModel
@{
    var isNew = Model.Enum == null;
    ViewData["Title"]    = isNew ? "Yeni Enum Tanımı" : $"Enum: {Model.Enum!.Code}";
    ViewData["FormCode"] = "INTEGRATION_DOC_ENUM_EDIT";
    ViewData["BodyClass"] = "page-ide workspace-frame-body";
}

@section Styles {
<style>
    .ide-wrap {
        --ide-bg: var(--app-bg, #f1f5f9);
        --ide-surface: var(--app-surface, #ffffff);
        --ide-surface-2: var(--app-surface-alt, #fafbfc);
        --ide-border: var(--app-border, #e2e8f0);
        --ide-text: var(--app-text, #0f172a);
        --ide-muted: var(--app-text-muted, #64748b);
        --ide-accent: #6366f1;
        display: flex; align-items: flex-start; justify-content: center;
        padding: 24px 16px; background: var(--ide-bg);
        color: var(--ide-text);
    }
    body.app-theme-dark .ide-wrap, body.app-theme-midnight .ide-wrap {
        --ide-bg: #080c17; --ide-surface: #0d1323; --ide-surface-2: #0a1020;
        --ide-border: rgba(255,255,255,.09); --ide-text: #e2e8f0; --ide-muted: #94a3b8;
    }
    /* 2026-05-21: Tam ekran flex layout — header sabit, body scroll'lu, değerler listesi
       kalan alanı dolduran iç-scroll. Sayfa hiç dış scroll açmaz, Kaydet hep görünür. */
    .ide-wrap {
        flex: 1 1 auto; min-height: 0;
        padding: 16px;
        display: flex; align-items: stretch; justify-content: center;
        overflow: hidden;
    }
    .ide-card { width: 100%; max-width: 980px; background: var(--ide-surface);
        border: 1px solid var(--ide-border); border-radius: 14px;
        display: flex; flex-direction: column;
        height: 100%; min-height: 0;
        overflow: hidden; }
    /* ide-body iç scroll açmaz — Değerler bölümü kalan alanı kapar (flex:1)
       ve içeride scroll yapar. Böylece form alanları + usage hep görünür. */
    .ide-body   { flex: 1 1 auto; min-height: 0; overflow: hidden;
                  display: flex; flex-direction: column; gap: 0; }
    .ide-btn { display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 12px; border-radius: 8px; border: 1px solid var(--ide-border);
        background: none; color: var(--ide-muted); font-size: 13px; cursor: pointer;
        text-decoration: none; }
    .ide-body { padding: 20px 24px; }
    .ide-row { display: grid; grid-template-columns: 160px 1fr; gap: 10px 14px;
        align-items: center; margin-bottom: 12px; }
    .ide-row label { font-size: 12.5px; color: var(--ide-muted); font-weight: 600; }
    .ide-row .hint { color: var(--ide-muted); font-size: 11px; margin-top: 2px; }
    .ide-input { padding: 8px 12px; border-radius: 8px; background: var(--ide-surface-2);
        border: 1px solid var(--ide-border); color: var(--ide-text); font-size: 13px;
        width: 100%; box-sizing: border-box; font-family: inherit; outline: none; }
    .ide-input:focus { border-color: var(--ide-accent); box-shadow: 0 0 0 3px rgba(99,102,241,.18); }
    .ide-section { margin-top: 18px; padding: 14px;
        background: var(--ide-surface-2); border: 1px solid var(--ide-border); border-radius: 10px; }
    .ide-section-title { display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 10px; font-size: 13px; font-weight: 700; color: var(--ide-text); }
    /* Değerler tablosu — dar ekranda yatay scroll + uzun listede iç dikey scroll.
       2026-05-21: Tam ekran flex layout ile değerler bölümü .ide-body altında
       kalan tüm alanı doldurur; iç scroll sadece liste uzunsa devreye girer.
       Sayfa hiç dış scroll açmaz — Kaydet hep görünür. */
    .ide-section--values { flex: 1 1 auto; min-height: 0; display: flex; flex-direction: column; }
    .ide-section--values > .ide-values-scroll { flex: 1 1 auto; min-height: 0; }
    .ide-values-scroll {
        overflow-x: auto;
        overflow-y: auto;
        scrollbar-width: thin;
        scrollbar-color: rgba(148,163,184,.35) transparent;
        position: relative;
    }
    .ide-values-scroll::-webkit-scrollbar { width: 8px; height: 8px; }
    .ide-values-scroll::-webkit-scrollbar-thumb { background: rgba(148,163,184,.35); border-radius: 999px; }
    .ide-values-scroll::-webkit-scrollbar-thumb:hover { background: rgba(148,163,184,.55); }

    /* Değerler başlık satırı (Value/Label/Technical Code/Sıra) scroll'da yapışsın */
    .ide-values-scroll > .ide-vrow:first-child {
        position: sticky; top: 0; z-index: 2;
        background: var(--ide-surface-2);
        margin-bottom: 4px; padding-bottom: 4px;
        border-bottom: 1px solid var(--ide-border);
    }
    .ide-vrow { display: grid; grid-template-columns: 90px minmax(160px, 1fr) 160px 60px 36px;
        gap: 6px; align-items: center; margin-bottom: 6px; min-width: 520px; }
    .ide-vrow input { padding: 6px 10px; border-radius: 6px; background: var(--ide-surface);
        border: 1px solid var(--ide-border); color: var(--ide-text); font-size: 12px;
        font-family: ui-monospace, Menlo, Consolas, monospace; width: 100%; min-width: 0; box-sizing: border-box; }
    .ide-vrow input:focus { outline: none; border-color: var(--ide-accent); }
    .ide-del { width: 32px; height: 30px; border-radius: 6px;
        border: 1px solid transparent; background: transparent;
        color: var(--ide-muted); cursor: pointer;
        display: inline-flex; align-items: center; justify-content: center; }
    .ide-del:hover { background: rgba(239,68,68,.10); color: #ef4444; }
    .ide-msg { margin-top: 14px; padding: 8px 14px; border-radius: 8px; font-size: 13px; }
    .ide-msg.ok  { background: rgba(16,185,129,.1); color: #059669; border: 1px solid rgba(16,185,129,.25); }
    .ide-msg.err { background: rgba(239,68,68,.1);  color: #dc2626; border: 1px solid rgba(239,68,68,.25); }

    /* Inline Provider modal */
    .ide-prov-bd { position: fixed; inset: 0; z-index: 9990;
        background: rgba(0,0,0,.55); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center; }
    .ide-prov-modal { width: 92%; max-width: 460px;
        background: var(--ide-surface); border: 1px solid var(--ide-border);
        border-radius: 14px; padding: 22px 24px;
        box-shadow: 0 20px 60px rgba(0,0,0,.3); }
    .ide-prov-modal h2 { margin: 0 0 4px; font-size: 16px; font-weight: 700; color: var(--ide-text); }
    .ide-prov-modal .hint { font-size: 11.5px; color: var(--ide-muted); margin-bottom: 16px; display: block; }
    .ide-prov-row { display: grid; grid-template-columns: 110px 1fr; gap: 8px 12px; align-items: center; margin-bottom: 10px; }
    .ide-prov-row label { font-size: 12px; color: var(--ide-muted); font-weight: 600; }
    .ide-prov-row input, .ide-prov-row select { padding: 7px 10px; border-radius: 6px;
        background: var(--ide-surface-2); border: 1px solid var(--ide-border);
        color: var(--ide-text); font-size: 12.5px; outline: none; font-family: inherit; }
    .ide-prov-row input:focus, .ide-prov-row select:focus { border-color: var(--ide-accent); }
    .ide-prov-btns { display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px; }
    .ide-prov-btn { padding: 7px 16px; border-radius: 7px; font-size: 12.5px; font-weight: 600;
        cursor: pointer; border: 1px solid var(--ide-border); }
    .ide-prov-btn--ghost { background: transparent; color: var(--ide-muted); }
    .ide-prov-btn--primary { background: #6366f1; border-color: #4f46e5; color: #fff; }
</style>
}

<div class="ux-edit-shell">
  @await Html.PartialAsync("_CalibraActionBar", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
  {
      ["Title"]       = isNew ? "Yeni Enum Tanımı" : "Enum Düzenle",
      ["ListUrl"]     = "/Integrations#enums",
      ["SaveBtnId"]   = "ide-save",
      ["DeleteBtnId"] = "ide-delete",
      ["ShowDelete"]  = !isNew,
      ["ShowNew"]     = false,
  })
  <div class="ide-wrap">
    <div class="ide-card">
        <div class="ide-body">
            <input type="hidden" id="ideId" value="@(Model.Enum?.Id ?? 0)" />

            @{
                var code = Model.Enum?.Code ?? "";
                // Yeni sıralama (2026-05-21 kullanıcı geri bildirimi):
                //   1) Provider  2) Endpoint  3) Alan adı  4) Kod  5) Açıklama  6) Durum  7) Değerler
                // Eski multi-row "Hangi Alanlarda Kullanılıyor" tek endpoint + tek path'e indirildi.
                // Save payload'da hala UsedInFields = [{ endpointId, path }] formatında gönderiyoruz
                // (geriye uyum — backend değişmedi). Bu form sadece [0]'ı yönetir.
            }

            <!-- 1) Provider -->
            <div class="ide-row">
                <label for="ideProvider">Provider *</label>
                <div style="display:flex;gap:6px;align-items:stretch;">
                    <select id="ideProvider" class="ide-input" style="flex:1 1 auto;">
                        @foreach (var p in Model.Providers)
                        {
                            var selected = Model.Enum?.ProviderId == p.Id ? "selected" : "";
                            <option value="@p.Id" selected="@(selected == "selected")">@p.Label (@p.Code)</option>
                        }
                    </select>
                    <button type="button" id="ideAddProviderBtn" class="ide-btn"
                            title="Yeni Provider Ekle (ör. SAP, Logo)"
                            style="padding:0 14px;font-size:18px;line-height:1;flex:0 0 auto;color:var(--ide-accent);border:1px dashed var(--ide-border);background:transparent;cursor:pointer;border-radius:8px;font-weight:300;">
                        +
                    </button>
                </div>
            </div>

            <!-- 2) Endpoint (tek seçim) -->
            <div class="ide-row">
                <label for="ideEndpoint">Endpoint</label>
                <div>
                    <select id="ideEndpoint" class="ide-input">
                        <option value="">— Tüm Endpointler (kapsam yok) —</option>
                        @* JS sayfa yüklendiğinde /Integrations/api/endpoints'ten doldurur *@
                    </select>
                    <div class="hint">Bu enum hangi endpoint için geçerli? Boş bırakırsanız tüm endpointler için path-bazlı eşleşme yapılır.</div>
                </div>
            </div>

            <!-- 3) Alan adı (Field Path) — tek path, autocomplete'li -->
            <div class="ide-row">
                <label for="ideFieldPath">Alan Adı</label>
                <div style="position:relative;">
                    <input id="ideFieldPath" class="ide-input"
                           placeholder="Örn: FatUst.Tip · Kalemler[].StokKodu"
                           autocomplete="off"
                           style="font-family: ui-monospace, Menlo, Consolas, monospace;" />
                    <div id="ideFieldPathSugs"
                         style="display:none;position:absolute;top:100%;left:0;right:0;margin-top:2px;
                                background:var(--ide-surface);border:1px solid var(--ide-accent);
                                border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.25);
                                max-height:220px;overflow-y:auto;z-index:200;"></div>
                    <div class="hint">Endpoint body şemasındaki tam yol. Yazmaya başlayın → öneriler gelir. <code>FatUst.Tip</code>, <code>Kalemler[].Tip</code> gibi.</div>
                </div>
            </div>

            <!-- 4) Kod -->
            <div class="ide-row">
                <label for="ideCode">Kod *</label>
                <input id="ideCode" class="ide-input" value="@code"
                       maxlength="80" placeholder="Örn: TFaturaTip"
                       style="font-family: ui-monospace, Menlo, Consolas, monospace;" />
            </div>

            <!-- Etiket hidden — Save akisinda Label = Code kullanilir -->
            <input type="hidden" id="ideLabel" value="@code" />

            <!-- 5) Açıklama -->
            <div class="ide-row">
                <label for="ideDesc">Açıklama</label>
                <input id="ideDesc" class="ide-input" value="@(Model.Enum?.Description ?? "")"
                       maxlength="1000" placeholder="Kısa açıklama" />
            </div>

            <!-- 6) Durum -->
            <div class="ide-row">
                <label>Durum</label>
                <div class="form-check form-switch" style="margin:0;">
                    <input id="ideIsActive" class="form-check-input" type="checkbox" role="switch"
                           @(Model.Enum?.IsActive ?? true ? "checked" : "") />
                </div>
            </div>

            <div class="ide-section ide-section--values">
                <div class="ide-section-title">
                    <span>Değerler <span class="hint" style="font-weight:400;font-size:11px;color:var(--ide-muted);">en az 1 değer</span></span>
                    <button type="button" class="ide-btn" onclick="ideAddValue()">+ Değer Ekle</button>
                </div>
                <div class="ide-values-scroll">
                    <div class="ide-vrow" style="font-size:10px;font-weight:600;color:var(--ide-muted);text-transform:uppercase;">
                        <div>Value</div><div>Label</div><div>Technical Code</div><div>Sıra</div><div></div>
                    </div>
                    <div id="ideValues"></div>
                </div>
            </div>

            <div id="ideMsg"></div>
        </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function () {
    var initialValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Enum?.Values.Select(v => new { value = v.Value, label = v.Label, technicalCode = v.TechnicalCode, sortOrder = v.SortOrder }).ToArray()
        ?? Array.Empty<object>()));
    var values = (initialValues && initialValues.length > 0) ? initialValues.slice() : [{ value: '0', label: '', technicalCode: '', sortOrder: 10 }];

    // 2026-05-21 — Tek endpoint + tek path UI'sine indirildi (kullanici geri bildirimi).
    // Backend hala UsedInFields = [{ endpointId, path }] formatinda bekliyor (geriye uyum);
    // bu yuzden initial listenin sadece ilk elemanini kullanıyoruz, save'de tekrar [0]'a sariyoruz.
    var initialUsages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Enum?.UsedInFields.Select(u => new { endpointId = u.EndpointId, path = u.Path }).ToArray()
        ?? Array.Empty<object>()));
    // İlk satırı seç (varsa) — diger satirlar oldugu yerde DB'de kalir ama UI gostermez;
    // save'de yalniz ilk satir overwrite eder (tek-endpoint mantigi).
    var initialUsage = (initialUsages && initialUsages.length > 0) ? initialUsages[0] : { endpointId: null, path: '' };

    // Öneri listesi: [{ path, endpointId, endpointLabel }]
    var pathSuggestions = [];

    // Endpoint listesi: [{ id, label }] — page load'da fetch edilir, dropdown'u besler.
    var endpointList = [];

    // 2026-05-21: Tek endpoint dropdown + tek path input (yeni sıralama: Provider →
    // Endpoint → Alan adı → Kod → ... → Değerler). Önceki multi-row UI kaldırıldı.
    var epSelectEl   = document.getElementById('ideEndpoint');
    var pathInputEl  = document.getElementById('ideFieldPath');
    var pathSugsEl   = document.getElementById('ideFieldPathSugs');

    // İlk değerleri input'lara bas (DB'de [0] olarak duruyordu)
    pathInputEl.value = initialUsage.path || '';
    // Endpoint select dropdown henüz boş — endpoint listesi fetch edilince doldurulur.

    function populateEndpointSelect(currentEndpointId) {
        // Mevcut value'yu koru, sadece option'ları yeniden ekle
        var preserved = (currentEndpointId != null && currentEndpointId !== '')
            ? String(currentEndpointId)
            : '';
        // İlk option ("Tüm Endpointler") kalır, sonra temizle
        for (var i = epSelectEl.options.length - 1; i >= 1; i--) epSelectEl.remove(i);
        endpointList.forEach(function(ep) {
            var o = document.createElement('option');
            o.value = String(ep.id);
            o.textContent = ep.label || ('#' + ep.id);
            epSelectEl.appendChild(o);
        });
        // Endpoint listesi henüz yuklenmediyse fallback option ekle
        if (preserved && !endpointList.some(function(ep) { return String(ep.id) === preserved; })) {
            var oFb = document.createElement('option');
            oFb.value = preserved;
            oFb.textContent = 'Endpoint #' + preserved;
            epSelectEl.appendChild(oFb);
        }
        if (preserved) epSelectEl.value = preserved;
    }
    // İlk render — endpointList henüz boş; sadece preserved id'yi fallback ile ekler.
    populateEndpointSelect(initialUsage.endpointId);

    // Path autocomplete — pathSuggestions üzerinde filter, seçim yapılınca endpoint de doldurulur.
    function showPathSugs(q) {
        q = (q || '').toLowerCase();
        var matches = pathSuggestions.filter(function(s) {
            return s.path.toLowerCase().includes(q) ||
                (s.endpointLabel && s.endpointLabel.toLowerCase().includes(q));
        });
        if (matches.length === 0) { pathSugsEl.style.display = 'none'; return; }
        pathSugsEl.innerHTML = '';
        matches.slice(0, 30).forEach(function(s) {
            var item = document.createElement('div');
            item.style.cssText = 'display:flex;align-items:baseline;justify-content:space-between;' +
                'gap:10px;padding:6px 10px;cursor:pointer;border-bottom:1px solid var(--ide-border);';
            item.innerHTML =
                '<span style="font-family:ui-monospace,Menlo,Consolas,monospace;font-size:12px;color:var(--ide-text);white-space:nowrap;">' + esc(s.path) + '</span>' +
                (s.endpointLabel
                    ? '<span style="font-size:10px;color:var(--ide-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex-shrink:1;min-width:0;">' + esc(s.endpointLabel) + '</span>'
                    : '');
            item.addEventListener('mouseenter', function() { item.style.background = 'rgba(99,102,241,.12)'; });
            item.addEventListener('mouseleave', function() { item.style.background = ''; });
            item.addEventListener('mousedown', function(e) {
                e.preventDefault();
                pathInputEl.value = s.path;
                // Suggestion endpoint bilgisi taşıyorsa endpoint dropdown'unu da set et
                if (s.endpointId != null) {
                    populateEndpointSelect(s.endpointId);
                    epSelectEl.value = String(s.endpointId);
                }
                pathSugsEl.style.display = 'none';
            });
            pathSugsEl.appendChild(item);
        });
        pathSugsEl.style.display = '';
    }
    pathInputEl.addEventListener('input', function() { showPathSugs(pathInputEl.value); });
    pathInputEl.addEventListener('focus', function() { showPathSugs(pathInputEl.value); });
    pathInputEl.addEventListener('blur', function() {
        setTimeout(function() { pathSugsEl.style.display = 'none'; }, 160);
    });

    // Öneri listesini + endpoint listesini paralel yükle.
    Promise.all([
        fetch('/Integrations/api/doc-catalog/field-path-suggestions', { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .catch(function() { return null; }),
        fetch('/Integrations/api/endpoints?includeInactive=false', { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .catch(function() { return null; }),
    ]).then(function(results) {
        var sugRes = results[0], epRes = results[1];
        if (sugRes && sugRes.success && Array.isArray(sugRes.suggestions)) pathSuggestions = sugRes.suggestions;
        if (epRes && epRes.success && Array.isArray(epRes.endpoints)) {
            endpointList = epRes.endpoints.map(function(e) {
                var lbl = e.name || ('#' + e.id);
                if (e.apiProfileName) lbl = e.apiProfileName + ' — ' + lbl;
                if (e.httpMethod) lbl = '[' + e.httpMethod + '] ' + lbl;
                return { id: e.id, label: lbl };
            });
        }
        // Endpoint listesi yuklendi — dropdown'u guncelle (mevcut seçimi koru)
        populateEndpointSelect(epSelectEl.value || initialUsage.endpointId);
    });

    // ── Kod → Etiket otomatik mirror ──────────────────────────────────────
    // Etiket alani kullanici geribildirimi ile kaldirildi (2026-05-20). Save
    // payload'unda Label hala bekleniyor — hidden ideLabel input'una Kod degeri
    // surekli yansitilir.
    (function setupCodeMirror() {
        var codeEl = document.getElementById('ideCode');
        var labelEl = document.getElementById('ideLabel');
        if (!codeEl || !labelEl) return;
        function sync() { labelEl.value = codeEl.value || ''; }
        codeEl.addEventListener('input', sync);
        sync();
    })();

    // ── Inline Provider Create modal ──────────────────────────────────────
    document.getElementById('ideAddProviderBtn').addEventListener('click', function() {
        showProviderModal();
    });

    function showProviderModal() {
        var bd = document.createElement('div');
        bd.className = 'ide-prov-bd';
        bd.innerHTML =
            '<div class="ide-prov-modal" role="dialog" aria-modal="true">' +
              '<h2 id="pmTitle">Yeni Provider Ekle</h2>' +
              '<span class="hint" id="pmHint">Yeni ERP / API kaynağı (ör. SAP, Logo, Custom REST) — kayıt sonrası Provider dropdown güncellenir. Mevcut bir Kod yazarsanız düzenleme moduna geçer.</span>' +
              '<div class="ide-prov-row"><label for="pmCode">Kod *</label>' +
                '<input id="pmCode" placeholder="SAP" maxlength="50" style="font-family:ui-monospace,Menlo,Consolas,monospace;" /></div>' +
              '<div class="ide-prov-row"><label for="pmLabel">Etiket *</label>' +
                '<input id="pmLabel" placeholder="SAP S/4HANA" maxlength="120" /></div>' +
              '<div class="ide-prov-row"><label for="pmColor">İkon Rengi</label>' +
                '<select id="pmColor">' +
                  '<option value="indigo">indigo (mor)</option>' +
                  '<option value="emerald">emerald (yeşil)</option>' +
                  '<option value="blue">blue (mavi)</option>' +
                  '<option value="amber">amber (turuncu)</option>' +
                  '<option value="rose">rose (kırmızı)</option>' +
                  '<option value="violet">violet (mor)</option>' +
                  '<option value="slate">slate (gri)</option>' +
                '</select></div>' +
              '<div class="ide-prov-row"><label for="pmDesc">Açıklama</label>' +
                '<input id="pmDesc" placeholder="SAP REST entegrasyonu" maxlength="500" /></div>' +
              '<div id="pmMsg"></div>' +
              '<div class="ide-prov-btns" style="justify-content:space-between;">' +
                '<button type="button" class="ide-prov-btn" id="pmDelete" ' +
                  'style="display:none;color:#ef4444;border-color:rgba(239,68,68,.35);background:transparent;">Sil</button>' +
                '<div style="display:flex;gap:8px;">' +
                  '<button type="button" class="ide-prov-btn ide-prov-btn--ghost" id="pmCancel">Vazgeç</button>' +
                  '<button type="button" class="ide-prov-btn ide-prov-btn--primary" id="pmSave">Kaydet</button>' +
                '</div>' +
              '</div>' +
            '</div>';
        document.body.appendChild(bd);

        var providersList = [];     // [{id, code, label, description, iconColor, ...}]
        var matchedId = null;        // mevcut provider'a eslesince set edilir
        var titleEl  = bd.querySelector('#pmTitle');
        var hintEl   = bd.querySelector('#pmHint');
        var codeEl   = bd.querySelector('#pmCode');
        var labelEl  = bd.querySelector('#pmLabel');
        var colorEl  = bd.querySelector('#pmColor');
        var descEl   = bd.querySelector('#pmDesc');
        var saveEl   = bd.querySelector('#pmSave');
        var delEl    = bd.querySelector('#pmDelete');
        var msgEl    = bd.querySelector('#pmMsg');

        function close() { document.body.removeChild(bd); document.removeEventListener('keydown', onKey); }
        function onKey(e) { if (e.key === 'Escape') close(); }
        document.addEventListener('keydown', onKey);
        bd.addEventListener('click', function(e) { if (e.target === bd) close(); });
        bd.querySelector('#pmCancel').onclick = close;
        codeEl.focus();

        // Provider listesini cek (modal acilinca taze veri)
        fetch('/Integrations/api/doc-catalog/providers?includeInactive=true', { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(d) { if (d && d.success && Array.isArray(d.items)) providersList = d.items; });

        // Kod input'unda detection (input + blur)
        function syncMode() {
            var typed = (codeEl.value || '').trim().toLowerCase();
            if (!typed) { setMode(null); return; }
            var match = providersList.find(function(p) { return (p.code || '').toLowerCase() === typed; });
            setMode(match || null);
        }
        function setMode(match) {
            if (match) {
                matchedId = match.id;
                titleEl.textContent  = 'Provider Düzenle — ' + match.label;
                hintEl.textContent   = '"' + match.code + '" mevcut. Etiket / İkon Rengi / Açıklama değiştirilebilir. "Sil" ile pasife alınır.';
                // Sadece bos alanlari doldur (kullanici override yapmissa silmeyelim)
                if (!labelEl.value.trim()) labelEl.value = match.label || '';
                if (!descEl.value.trim())  descEl.value  = match.description || '';
                colorEl.value = match.iconColor || 'indigo';
                saveEl.textContent = 'Güncelle';
                delEl.style.display = '';
            } else {
                matchedId = null;
                titleEl.textContent  = 'Yeni Provider Ekle';
                hintEl.textContent   = 'Yeni ERP / API kaynağı (ör. SAP, Logo, Custom REST). Mevcut bir Kod yazarsanız düzenleme moduna geçer.';
                saveEl.textContent = 'Kaydet';
                delEl.style.display = 'none';
            }
        }
        codeEl.addEventListener('input', syncMode);
        codeEl.addEventListener('blur', syncMode);

        saveEl.onclick = function() {
            var code  = codeEl.value.trim();
            var label = labelEl.value.trim();
            var color = colorEl.value;
            var desc  = descEl.value.trim();
            if (!code)  { showPmMsg(msgEl, 'Kod zorunlu', 'err'); return; }
            if (!label) { showPmMsg(msgEl, 'Etiket zorunlu', 'err'); return; }

            // matchedId varsa update, yoksa insert (endpoint ayni; id farkli)
            var payload = {
                id: matchedId,            // null => INSERT, dolu => UPDATE
                code: code,
                label: label,
                description: desc || null,
                iconColor: color,
                sortOrder: 100,
                isActive: true,
            };
            fetch('/Integrations/api/doc-catalog/providers/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
                credentials: 'same-origin',
            })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (!d || !d.success) { showPmMsg(msgEl, d?.error || 'Kayit basarisiz', 'err'); return; }
                var pid = d.id || matchedId;
                if (!pid) { showPmMsg(msgEl, 'Sunucu id donmedi', 'err'); return; }
                refreshProviderDropdown(pid, code, label);
                close();
            })
            .catch(function(ex) { showPmMsg(msgEl, 'Sunucu hatasi: ' + ex.message, 'err'); });
        };

        delEl.onclick = async function() {
            if (!matchedId) return;
            // Native confirm yerine global CalibraAlert.confirm helper (Layout'tan yuklenir).
            var pCode = codeEl.value.trim();
            var ok = await CalibraAlert.confirm(
                '"' + pCode + '" pasife alinacak. Buna bagli enum/field-doc kayitlari etkilenmez.',
                { title: 'Provider Silinsin Mi?', okText: 'Evet, Sil', cancelText: 'Vazgec', danger: true });
            if (!ok) return;
            fetch('/Integrations/api/doc-catalog/providers/delete/' + matchedId, {
                method: 'POST', credentials: 'same-origin',
            })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (!d || !d.success) { showPmMsg(msgEl, d?.error || 'Silinemedi', 'err'); return; }
                // Mevcut dropdown'dan opsiyonu kaldir + ilk kalani sec
                var sel = document.getElementById('ideProvider');
                var opt = sel.querySelector('option[value="' + matchedId + '"]');
                if (opt) opt.remove();
                if (sel.options.length > 0) sel.value = sel.options[0].value;
                close();
            })
            .catch(function(ex) { showPmMsg(msgEl, 'Sunucu hatasi: ' + ex.message, 'err'); });
        };
    }

    function refreshProviderDropdown(pid, code, label) {
        var sel = document.getElementById('ideProvider');
        var existing = sel.querySelector('option[value="' + pid + '"]');
        if (existing) {
            existing.textContent = label + ' (' + code + ')';
        } else {
            var opt = document.createElement('option');
            opt.value = String(pid);
            opt.textContent = label + ' (' + code + ')';
            sel.appendChild(opt);
        }
        sel.value = String(pid);
    }

    function showPmMsg(el, msg, type) {
        el.innerHTML = '<div class="ide-msg ' + type + '" style="margin-top:10px;">' + esc(msg) + '</div>';
    }

    function renderValues() {
        var host = document.getElementById('ideValues');
        host.innerHTML = '';
        values.forEach(function(v, idx) {
            var row = document.createElement('div');
            row.className = 'ide-vrow';
            row.innerHTML =
                '<input data-val placeholder="0" value="' + esc(v.value) + '" />' +
                '<input data-lbl placeholder="Etiket" value="' + esc(v.label) + '" />' +
                '<input data-tc placeholder="ftSFat" value="' + esc(v.technicalCode || '') + '" style="font-family:ui-monospace,Menlo,Consolas,monospace;" />' +
                '<input data-so type="number" min="0" value="' + (v.sortOrder || (idx+1)*10) + '" />' +
                '<button type="button" class="ide-del" title="Sil">×</button>';
            row.querySelector('[data-val]').oninput = e => values[idx].value = e.target.value;
            row.querySelector('[data-lbl]').oninput = e => values[idx].label = e.target.value;
            row.querySelector('[data-tc]').oninput  = e => values[idx].technicalCode = e.target.value;
            row.querySelector('[data-so]').oninput  = e => values[idx].sortOrder = parseInt(e.target.value, 10) || 0;
            row.querySelector('.ide-del').onclick   = () => { if (values.length <= 1) { ideMsg('En az 1 deger olmali','err'); return; } values.splice(idx,1); renderValues(); };
            host.appendChild(row);
        });
    }
    renderValues();

    window.ideAddValue = function() { values.push({ value:'', label:'', technicalCode:'', sortOrder: (values.length+1)*10 }); renderValues(); };

    window.ideSave = function() {
        var providerId = parseInt(document.getElementById('ideProvider').value, 10);
        var code  = document.getElementById('ideCode').value.trim();
        // Etiket alani kaldirildi (2026-05-20) — Label = Code mirror (hidden input).
        var label = (document.getElementById('ideLabel').value || '').trim() || code;
        if (!providerId) { ideMsg('Provider zorunlu','err'); return; }
        if (!code)  { ideMsg('Kod zorunlu','err'); return; }
        var idVal = parseInt(document.getElementById('ideId').value, 10) || null;

        // 2026-05-21: Tek endpoint + tek path UI. Backend hala usedInFields = array bekliyor,
        // bu yüzden tek girişi [{...}] dizisine sarıp gönderiyoruz. Path boşsa array boş gönderilir.
        var singleEndpointId = epSelectEl.value ? Number(epSelectEl.value) : null;
        var singlePath = (pathInputEl.value || '').trim();
        var usages = singlePath
            ? [{ endpointId: singleEndpointId, path: singlePath }]
            : [];

        var payload = {
            id: idVal,
            providerId: providerId,
            code: code,
            label: label,
            description: document.getElementById('ideDesc').value || null,
            sourceInfo: null,
            isActive: document.getElementById('ideIsActive').checked,
            values: values.filter(v => v.value !== ''),
            usedInFields: usages,
        };
        fetch('/Integrations/api/doc-catalog/enums/save', {
            method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload), credentials:'same-origin'
        }).then(r => r.json()).then(d => {
            if (d.success) window.location.href = '/Integrations#enums';
            else ideMsg(d.error || 'Hata','err');
        }).catch(e => ideMsg('Sunucu hatası: ' + e.message, 'err'));
    };

    window.ideDelete = async function() {
        var id = parseInt(document.getElementById('ideId').value, 10);
        if (!id) return;
        var ok = await CalibraAlert.confirm('Bu enum tanimini pasife alalim mi?',
            { title: 'Enum Silinsin Mi?', okText: 'Evet, Sil', cancelText: 'Vazgec', danger: true });
        if (!ok) return;
        fetch('/Integrations/api/doc-catalog/enums/delete/' + id, { method:'POST', credentials:'same-origin' })
            .then(r => r.json()).then(d => {
                if (d.success) window.location.href = '/Integrations#enums';
                else ideMsg(d.error || 'Silinemedi','err');
            });
    };

    function ideMsg(msg, type) {
        var el = document.getElementById('ideMsg');
        if (!msg) { el.innerHTML = ''; return; }
        el.innerHTML = '<div class="ide-msg ' + type + '">' + esc(msg) + '</div>';
        if (type === 'ok') setTimeout(() => { el.innerHTML = ''; }, 3000);
    }
    function esc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    var _idesSave = document.getElementById('ide-save');
    if (_idesSave) _idesSave.addEventListener('click', window.ideSave);
    var _idesDel = document.getElementById('ide-delete');
    if (_idesDel) _idesDel.addEventListener('click', window.ideDelete);
})();
</script>
}
