@{
    ViewData["Title"] = "Onayda Bekleyenler";
    var scopes = ViewBag.AvailableScopes as IReadOnlyList<string> ?? new[] { "mine" };
    var defaultScope = (string)(ViewBag.DefaultScope ?? "mine");
}

@section Styles {
<style>
    .pa-wrap {
        padding: 18px;
        height: calc(100vh - var(--app-header-height, 64px) - var(--app-tabs-height, 48px));
        display: flex; flex-direction: column; min-height: 0;
        max-width: 100%;
    }
    .pa-header {
        display: flex; align-items: center; gap: 14px; margin-bottom: 14px;
        flex: 0 0 auto;
    }
    .pa-title { font-size: 20px; font-weight: 700; margin: 0; }
    .pa-subtitle { font-size: 12px; color: #64748b; }
    .pa-scope-picker {
        margin-left: auto; display: flex; align-items: center; gap: 8px;
    }
    .pa-scope-picker label { font-size: 12px; color: #64748b; font-weight: 500; }
    .pa-scope-picker select {
        padding: 5px 28px 5px 10px; border-radius: 6px;
        border: 1px solid rgba(148,163,184,.3);
        background: var(--surface, #fff); font-size: 13px;
        appearance: none;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><polyline points='1,1 5,5 9,1' fill='none' stroke='%2364748b' stroke-width='1.5'/></svg>");
        background-repeat: no-repeat;
        background-position: right 10px center;
    }
    body.app-theme-dark .pa-scope-picker select,
    html.dark .pa-scope-picker select {
        background-color: rgba(15,23,42,.5); color: #e2e8f0;
        border-color: rgba(255,255,255,.1);
    }

    .pa-body { display: flex; flex-direction: row; gap: 14px; flex: 1 1 auto; min-height: 0; }

    .pa-groups {
        flex: 0 0 260px;
        background: var(--surface, #fff);
        border: 1px solid rgba(148,163,184,.18);
        border-radius: 10px; padding: 8px;
        overflow-y: auto; min-height: 0;
    }
    body.app-theme-dark .pa-groups,
    html.dark .pa-groups {
        background: rgba(15,23,42,.4);
        border-color: rgba(255,255,255,.08);
    }
    .pa-group {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 12px; margin: 4px 0;
        border-radius: 8px; cursor: pointer;
        transition: background 0.15s;
        font-size: 13px;
    }
    .pa-group:hover { background: rgba(99,102,241,.06); }
    .pa-group.active {
        background: linear-gradient(135deg, rgba(99,102,241,.14), rgba(139,92,246,.10));
        border: 1px solid rgba(99,102,241,.3);
    }
    .pa-group-name { flex: 1 1 auto; font-weight: 500; color: #1e293b; }
    body.app-theme-dark .pa-group-name,
    html.dark .pa-group-name { color: #f1f5f9; }
    .pa-group-count {
        flex: 0 0 auto;
        background: rgba(99,102,241,.18); color: #6366f1;
        font-size: 11px; font-weight: 700;
        padding: 2px 8px; border-radius: 10px; min-width: 24px; text-align: center;
    }
    .pa-group.empty { opacity: 0.5; padding: 14px; text-align: center; font-size: 12px; color: #94a3b8; }

    .pa-list-wrap {
        flex: 1 1 auto;
        background: var(--surface, #fff);
        border: 1px solid rgba(148,163,184,.18);
        border-radius: 10px; overflow: hidden;
        display: flex; flex-direction: column; min-height: 0;
    }
    body.app-theme-dark .pa-list-wrap,
    html.dark .pa-list-wrap {
        background: rgba(15,23,42,.4);
        border-color: rgba(255,255,255,.08);
    }
    .pa-list-header {
        padding: 10px 16px;
        border-bottom: 1px solid rgba(148,163,184,.12);
        display: flex; align-items: center; gap: 10px;
        flex: 0 0 auto;
    }
    .pa-list-title { font-size: 14px; font-weight: 600; }
    .pa-list-count { font-size: 11px; color: #94a3b8; }

    .pa-list-scroll { flex: 1 1 auto; min-height: 0; overflow: auto; }
    .pa-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 12.5px; }
    .pa-table th {
        position: sticky; top: 0;
        background: rgba(241,245,249,1); color: #64748b;
        font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em;
        padding: 7px 12px; text-align: left;
        border-bottom: 1px solid rgba(148,163,184,.15);
    }
    body.app-theme-dark .pa-table th,
    html.dark .pa-table th { background: rgba(30,41,59,1); }
    .pa-table td {
        padding: 6px 12px; border-bottom: 1px solid rgba(148,163,184,.08);
        vertical-align: middle;
    }
    .pa-table tr { cursor: pointer; transition: background 0.12s; }
    .pa-table tr:hover td { background: rgba(99,102,241,.05); }
    body.app-theme-dark .pa-table tr:hover td,
    html.dark .pa-table tr:hover td { background: rgba(99,102,241,.10); }

    .pa-empty {
        padding: 50px 20px; text-align: center; color: #94a3b8; font-size: 13px;
    }
    .pa-step-pill {
        display: inline-flex; align-items: center; gap: 4px;
        background: rgba(99,102,241,.12); color: #6366f1;
        font-size: 11px; font-weight: 600;
        padding: 2px 8px; border-radius: 10px;
    }
    .pa-overdue { color: #ef4444; font-weight: 600; }

    /* ── Sütunlar butonu ─────────────────────────────────── */
    .pa-col-btn {
        margin-left: auto;
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 12px; border-radius: 7px;
        border: 1px solid rgba(148,163,184,.25);
        background: transparent; cursor: pointer;
        font-size: 12px; font-weight: 500; color: #64748b;
        transition: background 0.15s, border-color 0.15s;
    }
    .pa-col-btn:hover { background: rgba(99,102,241,.07); border-color: rgba(99,102,241,.35); color: #6366f1; }
    body.app-theme-dark .pa-col-btn { color: #94a3b8; border-color: rgba(255,255,255,.12); }
    body.app-theme-dark .pa-col-btn:hover { background: rgba(99,102,241,.15); color: #818cf8; }

    /* ── Sütun seçim paneli ──────────────────────────────── */
    .pa-col-panel {
        display: none; position: fixed; z-index: 1100;
        background: var(--app-surface, #fff);
        border: 1px solid rgba(148,163,184,.2);
        border-radius: 10px;
        box-shadow: 0 8px 32px rgba(15,23,42,.18);
        padding: 12px 0; min-width: 200px;
    }
    .pa-col-panel.open { display: block; }
    body.app-theme-dark .pa-col-panel {
        background: #1e293b; border-color: rgba(255,255,255,.1);
        box-shadow: 0 8px 32px rgba(0,0,0,.5);
    }
    .pa-col-panel-title {
        padding: 2px 14px 10px;
        font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em;
        color: #94a3b8; border-bottom: 1px solid rgba(148,163,184,.12); margin-bottom: 6px;
    }
    .pa-col-row {
        padding: 5px 14px; display: flex; align-items: center; gap: 8px;
        cursor: pointer; font-size: 13px; transition: background 0.12s;
    }
    .pa-col-row:hover { background: rgba(99,102,241,.07); }
    body.app-theme-dark .pa-col-row:hover { background: rgba(99,102,241,.12); }
    .pa-col-row input[type="checkbox"] { cursor: pointer; accent-color: #6366f1; }
    .pa-col-row label { cursor: pointer; flex: 1; user-select: none; }

    /* ── Sütun gizleme (CSS class toggle on .pa-list-wrap) ── */
    .pa-list-wrap.pa-hide-flow .pa-col-flow { display: none !important; }
    .pa-list-wrap.pa-hide-typ  .pa-col-typ  { display: none !important; }
    .pa-list-wrap.pa-hide-cari .pa-col-cari { display: none !important; }
    .pa-list-wrap.pa-hide-amt  .pa-col-amt  { display: none !important; }
    .pa-list-wrap.pa-hide-step .pa-col-step { display: none !important; }
    .pa-list-wrap.pa-hide-apvr .pa-col-apvr { display: none !important; }
    .pa-list-wrap.pa-hide-dt   .pa-col-dt   { display: none !important; }

    /* Modal */
    .pa-modal-backdrop {
        position: fixed; inset: 0; background: rgba(15,23,42,.55);
        backdrop-filter: blur(3px);
        display: none; align-items: center; justify-content: center;
        z-index: 1050;
    }
    .pa-modal-backdrop.show { display: flex; }
    .pa-modal {
        background: #fff; border-radius: 12px;
        width: min(720px, 92vw); max-height: 88vh;
        display: flex; flex-direction: column;
        box-shadow: 0 20px 60px rgba(15,23,42,.30);
        animation: pa-modal-in 0.18s ease-out;
    }
    body.app-theme-dark .pa-modal,
    html.dark .pa-modal { background: #1e293b; color: #e2e8f0; }
    @@keyframes pa-modal-in {
        from { opacity: 0; transform: translateY(20px) scale(.98); }
        to   { opacity: 1; transform: translateY(0)     scale(1); }
    }
    .pa-modal-header {
        padding: 16px 20px;
        border-bottom: 1px solid rgba(148,163,184,.18);
        display: flex; align-items: flex-start; gap: 14px;
    }
    .pa-modal-title { font-size: 16px; font-weight: 700; margin: 0 0 4px; }
    .pa-modal-sub { font-size: 12px; color: #64748b; }
    .pa-modal-close {
        margin-left: auto; background: transparent; border: 0; font-size: 22px;
        color: #94a3b8; cursor: pointer; line-height: 1;
    }
    .pa-modal-body { padding: 18px 20px; overflow-y: auto; flex: 1 1 auto; }
    .pa-modal-footer {
        padding: 14px 20px; border-top: 1px solid rgba(148,163,184,.18);
        display: flex; gap: 8px; justify-content: flex-end;
        flex: 0 0 auto;
    }
    .pa-btn {
        padding: 8px 16px; border-radius: 8px; border: 0;
        font-size: 13px; font-weight: 600; cursor: pointer;
        transition: opacity 0.15s, transform 0.12s;
    }
    .pa-btn:hover { transform: translateY(-1px); }
    .pa-btn-primary { background: linear-gradient(135deg, #10b981, #059669); color: #fff; }
    .pa-btn-danger  { background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff; }
    .pa-btn-ghost   { background: rgba(148,163,184,.15); color: #64748b; }

    .pa-detail-grid {
        display: grid; grid-template-columns: 110px 1fr; gap: 8px 14px;
        font-size: 13px; margin-bottom: 18px;
    }
    .pa-detail-grid dt { color: #94a3b8; font-weight: 500; }
    .pa-detail-grid dd { margin: 0; font-weight: 500; }

    .pa-steps {
        list-style: none; padding: 0; margin: 0;
    }
    .pa-steps li {
        position: relative; padding: 10px 14px 10px 32px; margin: 6px 0;
        border-radius: 8px;
        background: rgba(148,163,184,.06);
    }
    .pa-steps li::before {
        content: ''; position: absolute; left: 10px; top: 14px;
        width: 12px; height: 12px; border-radius: 50%;
        background: #cbd5e1;
    }
    .pa-steps li.status-Approved::before { background: #10b981; }
    .pa-steps li.status-Pending::before  { background: #f59e0b; }
    .pa-steps li.status-Rejected::before { background: #ef4444; }
    .pa-step-title { font-weight: 600; font-size: 13px; }
    .pa-step-meta { font-size: 11px; color: #64748b; margin-top: 2px; }
</style>
}

<div class="pa-wrap">
    <div class="pa-header">
        <div>
            <h1 class="pa-title">Onayda Bekleyenler</h1>
            <div class="pa-subtitle">Sizden onay bekleyen kayıtlar (sol panel: belge türü)</div>
        </div>
        <div class="pa-scope-picker">
            <label for="paScope">Görünüm</label>
            <select id="paScope">
                @foreach (var s in scopes)
                {
                    var label = s switch
                    {
                        "mine" => "Sadece benim",
                        "department" => "Departmanım",
                        "all" => "Tümü",
                        _ => s
                    };
                    if (string.Equals(s, defaultScope, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@s" selected>@label</option>
                    }
                    else
                    {
                        <option value="@s">@label</option>
                    }
                }
            </select>
        </div>
    </div>

    <div class="pa-body">
        <div class="pa-groups" id="paGroups">
            <div class="pa-group empty">Yükleniyor…</div>
        </div>
        <div class="pa-list-wrap">
            <div class="pa-list-header">
                <div>
                    <div class="pa-list-title" id="paListTitle">Tüm belge türleri</div>
                    <div class="pa-list-count" id="paListCount"></div>
                </div>
                <button type="button" class="pa-col-btn" id="paColBtn" onclick="paToggleColPanel(event)">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v1m0 16v1M4.22 4.22l.71.71m14.14 14.14.71.71M3 12h1m16 0h1M4.93 19.07l.71-.71M18.36 5.64l.71-.71"/><circle cx="12" cy="12" r="4"/></svg>
                    Sütunlar
                </button>
            </div>
            <!-- Sütun seçim paneli -->
            <div class="pa-col-panel" id="paColPanel">
                <div class="pa-col-panel-title">Sütun Görünürlüğü</div>
                <div class="pa-col-row"><input type="checkbox" id="paColFlow" onchange="paColToggle('flow',this.checked)"><label for="paColFlow">Akış Adı</label></div>
                <div class="pa-col-row"><input type="checkbox" id="paColTyp"  onchange="paColToggle('typ', this.checked)"><label for="paColTyp">Tür</label></div>
                <div class="pa-col-row"><input type="checkbox" id="paColCari" onchange="paColToggle('cari',this.checked)"><label for="paColCari">Cari</label></div>
                <div class="pa-col-row"><input type="checkbox" id="paColAmt"  onchange="paColToggle('amt', this.checked)"><label for="paColAmt">Tutar</label></div>
                <div class="pa-col-row"><input type="checkbox" id="paColStep" onchange="paColToggle('step',this.checked)"><label for="paColStep">Adım</label></div>
                <div class="pa-col-row"><input type="checkbox" id="paColApvr" onchange="paColToggle('apvr',this.checked)"><label for="paColApvr">Onaylayıcı</label></div>
                <div class="pa-col-row"><input type="checkbox" id="paColDt"   onchange="paColToggle('dt',  this.checked)"><label for="paColDt">Bekliyor (Tarih)</label></div>
            </div>
            <div class="pa-list-scroll" id="paListScroll">
                <div class="pa-empty">Sol panelden bir belge türü seçin…</div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="pa-modal-backdrop" id="paModalBackdrop">
    <div class="pa-modal" role="dialog" aria-modal="true">
        <div class="pa-modal-header">
            <div>
                <div class="pa-modal-title" id="paModalTitle">Belge Detayı</div>
                <div class="pa-modal-sub" id="paModalSub"></div>
            </div>
            <button type="button" class="pa-modal-close" id="paModalClose" aria-label="Kapat">×</button>
        </div>
        <div class="pa-modal-body" id="paModalBody">
            <div style="text-align:center;padding:30px;color:#94a3b8;">Yükleniyor…</div>
        </div>
        <div class="pa-modal-footer">
            <button type="button" class="pa-btn pa-btn-danger"  id="paBtnReject">Reddet</button>
            <button type="button" class="pa-btn pa-btn-primary" id="paBtnApprove">Onayla</button>
            <button type="button" class="pa-btn pa-btn-ghost"   id="paBtnCancel">Kapat</button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
(function() {
    const scopeEl = document.getElementById('paScope');
    const groupsEl = document.getElementById('paGroups');
    const listScrollEl = document.getElementById('paListScroll');
    const listTitleEl = document.getElementById('paListTitle');
    const listCountEl = document.getElementById('paListCount');
    const backdropEl = document.getElementById('paModalBackdrop');
    const modalCloseEl = document.getElementById('paModalClose');
    const modalCancelEl = document.getElementById('paBtnCancel');
    const modalApproveEl = document.getElementById('paBtnApprove');
    const modalRejectEl = document.getElementById('paBtnReject');
    const modalBodyEl = document.getElementById('paModalBody');
    const modalTitleEl = document.getElementById('paModalTitle');
    const modalSubEl = document.getElementById('paModalSub');

    let activeDocTypeId = null;  // null = tüm türler
    let currentInstanceId = null;
    let _extraCols = [];          // [{key, label, dataType}] — aktif extra kolon defs
    let _extraData = {};          // {instanceId: {colName: strValue}} — aktif extra kolon verileri

    function csrf() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function escapeHtml(s) {
        if (s == null) return '';
        return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }
    function fmtDate(iso) {
        if (!iso) return '—';
        const d = new Date(iso);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleDateString('tr-TR') + ' ' + d.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
    }
    function fmtMoney(v, code) {
        if (v == null) return '—';
        const n = Number(v);
        return n.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ' + (code || '');
    }

    async function loadGroups() {
        const scope = scopeEl.value;
        groupsEl.innerHTML = '<div class="pa-group empty">Yükleniyor…</div>';
        try {
            const resp = await fetch('/PendingApproval/Groups?scope=' + encodeURIComponent(scope), { credentials: 'same-origin' });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            renderGroups(data.groups);
        } catch (err) {
            groupsEl.innerHTML = '<div class="pa-group empty">Hata: ' + escapeHtml(err.message) + '</div>';
        }
    }

    function renderGroups(groups) {
        if (!groups || groups.length === 0) {
            groupsEl.innerHTML = '<div class="pa-group empty">Onayda bekleyen kayıt yok 🎉</div>';
            listScrollEl.innerHTML = '<div class="pa-empty">Bu görünümde bekleyen kayıt bulunmuyor.</div>';
            listTitleEl.textContent = '—';
            listCountEl.textContent = '';
            return;
        }
        const total = groups.reduce((s, g) => s + g.count, 0);
        let html = '<div class="pa-group ' + (activeDocTypeId === null ? 'active' : '') + '" data-doctype="">' +
                   '<span class="pa-group-name">Tüm türler</span>' +
                   '<span class="pa-group-count">' + total + '</span>' +
                   '</div>';
        groups.forEach(g => {
            const id = g.documentTypeId == null ? '' : g.documentTypeId;
            const active = (g.documentTypeId === activeDocTypeId) ? 'active' : '';
            html += '<div class="pa-group ' + active + '" data-doctype="' + id + '">' +
                    '<span class="pa-group-name">' + escapeHtml(g.documentTypeName) + '</span>' +
                    '<span class="pa-group-count">' + g.count + '</span>' +
                    '</div>';
        });
        groupsEl.innerHTML = html;
        groupsEl.querySelectorAll('.pa-group[data-doctype]').forEach(el => {
            el.addEventListener('click', () => {
                const raw = el.getAttribute('data-doctype');
                activeDocTypeId = raw === '' ? null : Number(raw);
                groupsEl.querySelectorAll('.pa-group').forEach(g => g.classList.remove('active'));
                el.classList.add('active');
                listTitleEl.textContent = el.querySelector('.pa-group-name').textContent;
                loadList();
            });
        });
        // İlk yüklemede otomatik tüm türleri göster
        loadList();
    }

    async function loadList() {
        const scope = scopeEl.value;
        listScrollEl.innerHTML = '<div class="pa-empty">Yükleniyor…</div>';
        try {
            let url = '/PendingApproval/List?scope=' + encodeURIComponent(scope);
            if (activeDocTypeId != null) url += '&documentTypeId=' + activeDocTypeId;
            const resp = await fetch(url, { credentials: 'same-origin' });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            renderList(data.items);
            // noinspection ES6MissingAwait — arka planda extra kolon meta+veri yükle, hazır olunca yeniden render
            loadExtraColumnsAndData(data.items);
        } catch (err) {
            listScrollEl.innerHTML = '<div class="pa-empty" style="color:#ef4444;">Hata: ' + escapeHtml(err.message) + '</div>';
        }
    }

    async function loadExtraColumnsAndData(items) {
        const views = [...new Set(items.map(i => i.extraColumnsViewName).filter(Boolean))];
        if (views.length !== 1) {
            _extraCols = []; _extraData = {};
            updateExtraColPanel();
            return;
        }
        const viewName = views[0];
        const idList   = items.map(i => i.instanceId).join(',');
        try {
            const [metaR, dataR] = await Promise.all([
                fetch('/PendingApproval/FlowExtraColumns?viewName=' + encodeURIComponent(viewName), { credentials: 'same-origin' }),
                fetch('/PendingApproval/FlowExtraData?viewName=' + encodeURIComponent(viewName) + '&ids=' + idList, { credentials: 'same-origin' })
            ]);
            const [metaJ, dataJ] = await Promise.all([metaR.json(), dataR.json()]);
            _extraCols = (metaJ.ok && metaJ.columns) ? metaJ.columns : [];
            _extraData = (dataJ.ok && dataJ.data)    ? dataJ.data    : {};
        } catch(e) { _extraCols = []; _extraData = {}; }
        renderList(items);
        updateExtraColPanel();
    }

    function updateExtraColPanel() {
        const panel = document.getElementById('paColPanel');
        if (!panel) return;
        panel.querySelectorAll('.pa-col-row-extra').forEach(el => el.remove());
        if (!_extraCols.length) return;
        let localCfg = {};
        try { localCfg = JSON.parse(localStorage.getItem('pa-col-cfg') || '{}'); } catch(e) {}
        const sep = document.createElement('div');
        sep.style.cssText = 'padding:4px 14px 2px;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:#94a3b8;border-top:1px solid rgba(148,163,184,.12);margin-top:4px;';
        sep.textContent = 'Akış Alanları';
        sep.className = 'pa-col-row-extra';
        panel.appendChild(sep);
        _extraCols.forEach(col => {
            const row = document.createElement('div');
            row.className = 'pa-col-row pa-col-row-extra';
            const cbId    = 'paColExt_' + col.key;
            const checked = localCfg['ext_' + col.key] !== false;
            row.innerHTML = '<input type="checkbox" id="' + cbId + '" ' + (checked ? 'checked' : '') +
                            ' onchange="paColToggle(\'ext_' + col.key + '\',this.checked)">' +
                            '<label for="' + cbId + '">' + escapeHtml(col.label) + '</label>';
            panel.appendChild(row);
        });
    }

    function renderList(items) {
        if (!items || items.length === 0) {
            listScrollEl.innerHTML = '<div class="pa-empty">Bu türde bekleyen kayıt yok.</div>';
            listCountEl.textContent = '';
            _extraCols = []; _extraData = {};
            updateExtraColPanel();
            return;
        }
        listCountEl.textContent = items.length + ' kayıt';
        // Extra kolon header'ları
        const extraHeaders = _extraCols.map(c =>
            '<th class="pa-col-ext pa-col-ext-' + c.key + '">' + escapeHtml(c.label) + '</th>'
        ).join('');
        let html = '<table class="pa-table"><thead><tr>' +
                   '<th>Belge No</th>' +
                   '<th class="pa-col-flow">Akış</th>' +
                   '<th class="pa-col-typ">Tür</th>' +
                   '<th class="pa-col-cari">Cari</th>' +
                   '<th class="pa-col-amt">Tutar</th>' +
                   '<th class="pa-col-step">Adım</th>' +
                   '<th class="pa-col-apvr">Onaylayıcı</th>' +
                   extraHeaders +
                   '<th class="pa-col-dt">Bekliyor</th>' +
                   '</tr></thead><tbody>';
        const now = Date.now();
        items.forEach(it => {
            const overdue = it.dueDate && new Date(it.dueDate).getTime() < now;
            html += '<tr data-instance-id="' + it.instanceId + '">' +
                    '<td><strong>' + escapeHtml(it.documentNumber) + '</strong></td>' +
                    '<td class="pa-col-flow" style="font-size:11px;color:#94a3b8;">' + escapeHtml(it.flowName) + '</td>' +
                    '<td class="pa-col-typ">' + escapeHtml(it.documentTypeName || 'Belirsiz') + '</td>' +
                    '<td class="pa-col-cari">' + escapeHtml(it.contactName || '—') + '</td>' +
                    '<td class="pa-col-amt">' + fmtMoney(it.grandTotal, it.currencyCode) + '</td>' +
                    '<td class="pa-col-step"><span class="pa-step-pill">' + it.stepPosition + ' / ' + it.totalSteps + '</span>' +
                    '<span style="font-size:11px;color:#94a3b8;margin-left:6px;">' + escapeHtml(it.stepName) + '</span></td>' +
                    '<td class="pa-col-apvr">' + escapeHtml(it.approverName || '—') + '</td>' +
                    _extraCols.map(function(c) {
                        const extRow = _extraData[it.instanceId] || _extraData[String(it.instanceId)] || {};
                        return '<td class="pa-col-ext pa-col-ext-' + c.key + '">' + escapeHtml(extRow[c.key] || '—') + '</td>';
                    }).join('') +
                    '<td class="pa-col-dt ' + (overdue ? 'pa-overdue' : '') + '">' + fmtDate(it.stepCreated) + '</td>' +
                    '</tr>';
        });
        html += '</tbody></table>';
        listScrollEl.innerHTML = html;
        listScrollEl.querySelectorAll('tr[data-instance-id]').forEach(row => {
            row.addEventListener('click', () => {
                openDetail(Number(row.getAttribute('data-instance-id')));
            });
        });
    }

    async function openDetail(instanceId) {
        currentInstanceId = instanceId;
        backdropEl.classList.add('show');
        modalBodyEl.innerHTML = '<div style="text-align:center;padding:30px;color:#94a3b8;">Yükleniyor…</div>';
        modalTitleEl.textContent = 'Belge Detayı';
        modalSubEl.textContent = '';
        try {
            const scope = scopeEl.value;
            const resp = await fetch('/PendingApproval/Detail?instanceId=' + instanceId + '&scope=' + encodeURIComponent(scope), { credentials: 'same-origin' });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            renderDetail(data.detail);
        } catch (err) {
            modalBodyEl.innerHTML = '<div style="color:#ef4444;padding:20px;">Hata: ' + escapeHtml(err.message) + '</div>';
        }
    }

    function renderDetail(d) {
        const h = d.header;
        modalTitleEl.textContent = 'Belge: ' + (h.documentNumber || '—');
        modalSubEl.textContent = h.flowName + ' • Adım ' + h.stepPosition + ' / ' + h.totalSteps;

        let html = '<dl class="pa-detail-grid">' +
                   '<dt>Belge No</dt><dd>' + escapeHtml(h.documentNumber || '—') + '</dd>' +
                   '<dt>Tür</dt><dd>' + escapeHtml(h.documentTypeName || 'Belirsiz') + '</dd>' +
                   '<dt>Cari</dt><dd>' + escapeHtml(h.contactName || '—') + '</dd>' +
                   '<dt>Tutar</dt><dd>' + fmtMoney(h.grandTotal, h.currencyCode) + '</dd>' +
                   '<dt>Adım Adı</dt><dd>' + escapeHtml(h.stepName || '—') + '</dd>' +
                   '<dt>Onaycı</dt><dd>' + escapeHtml(h.approverName || h.approverId || '—') + '</dd>' +
                   '<dt>Bekliyor</dt><dd>' + fmtDate(h.stepCreated) + '</dd>' +
                   '</dl>';

        if (d.steps && d.steps.length > 0) {
            html += '<div style="font-size:11px;color:#64748b;font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:8px;">Akış Geçmişi</div>';
            html += '<ul class="pa-steps">';
            d.steps.forEach(s => {
                html += '<li class="status-' + escapeHtml(s.status) + '">' +
                        '<div class="pa-step-title">' + s.stepOrder + '. ' + escapeHtml(s.stepName) + ' — ' + escapeHtml(s.status) + '</div>' +
                        '<div class="pa-step-meta">' +
                        (s.approverName ? escapeHtml(s.approverName) : '—') +
                        (s.actionDate ? ' • ' + fmtDate(s.actionDate) : '') +
                        (s.note ? ' • ' + escapeHtml(s.note) : '') +
                        '</div></li>';
            });
            html += '</ul>';
        }

        modalBodyEl.innerHTML = html;
    }

    function closeModal() {
        backdropEl.classList.remove('show');
        currentInstanceId = null;
    }

    async function approveCurrent() {
        if (!currentInstanceId) return;
        const note = prompt('İsterseniz onay notu girin (opsiyonel):', '');
        if (note === null) return; // cancel
        modalApproveEl.disabled = true;
        try {
            const fd = new FormData();
            fd.set('instanceId', currentInstanceId);
            if (note) fd.set('note', note);
            const resp = await fetch('/Approval/ApproveStep', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'RequestVerificationToken': csrf() },
                body: fd,
            });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            closeModal();
            await loadGroups();  // sayım yenilensin
        } catch (err) {
            alert('Onaylama hatası: ' + err.message);
        } finally {
            modalApproveEl.disabled = false;
        }
    }

    async function rejectCurrent() {
        if (!currentInstanceId) return;
        const note = prompt('Lütfen ret gerekçesini girin:', '');
        if (!note || !note.trim()) return;
        modalRejectEl.disabled = true;
        try {
            const fd = new FormData();
            fd.set('instanceId', currentInstanceId);
            fd.set('note', note);
            const resp = await fetch('/Approval/RejectApproval', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'RequestVerificationToken': csrf() },
                body: fd,
            });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            closeModal();
            await loadGroups();
        } catch (err) {
            alert('Reddetme hatası: ' + err.message);
        } finally {
            modalRejectEl.disabled = false;
        }
    }

    scopeEl.addEventListener('change', () => { activeDocTypeId = null; loadGroups(); });
    modalCloseEl.addEventListener('click', closeModal);
    modalCancelEl.addEventListener('click', closeModal);
    backdropEl.addEventListener('click', e => { if (e.target === backdropEl) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && backdropEl.classList.contains('show')) closeModal(); });
    modalApproveEl.addEventListener('click', approveCurrent);
    modalRejectEl.addEventListener('click', rejectCurrent);

    // İlk yüklemede grupları çek
    loadGroups();
})();

// ── Sütun görünürlüğü (localStorage: pa-col-cfg) ─────────────────────────
(function() {
    const STORAGE_KEY = 'pa-col-cfg';
    const COL_KEYS    = ['flow','typ','cari','amt','step','apvr','dt'];
    const COL_CB_IDS  = { flow:'paColFlow', typ:'paColTyp', cari:'paColCari', amt:'paColAmt', step:'paColStep', apvr:'paColApvr', dt:'paColDt' };

    let _cfg = {};
    try { _cfg = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch(e) {}

    function getListWrap() { return document.querySelector('.pa-list-wrap'); }

    function applyExtColStyle(colKey, hidden) {
        const styleId = 'pa-ext-hide-' + colKey;
        if (hidden) {
            if (!document.getElementById(styleId)) {
                const s = document.createElement('style');
                s.id = styleId;
                s.textContent = '.pa-col-ext-' + colKey + ' { display: none !important; }';
                document.head.appendChild(s);
            }
        } else {
            const s = document.getElementById(styleId);
            if (s) s.remove();
        }
    }

    function applyAll() {
        const wrap = getListWrap();
        if (!wrap) return;
        COL_KEYS.forEach(k => {
            const hidden = _cfg[k] === false;
            wrap.classList.toggle('pa-hide-' + k, hidden);
            const cb = document.getElementById(COL_CB_IDS[k]);
            if (cb) cb.checked = !hidden;
        });
        // Kaydedilmiş ext kolon gizliliklerini uygula
        Object.entries(_cfg).forEach(([k, v]) => {
            if (k.startsWith('ext_')) applyExtColStyle(k.slice(4), v === false);
        });
    }

    window.paColToggle = function(key, visible) {
        _cfg[key] = visible;
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(_cfg)); } catch(e) {}
        if (key.startsWith('ext_')) {
            applyExtColStyle(key.slice(4), !visible);
        } else {
            const wrap = getListWrap();
            if (wrap) wrap.classList.toggle('pa-hide-' + key, !visible);
        }
    };

    window.paToggleColPanel = function(e) {
        e.stopPropagation();
        const panel = document.getElementById('paColPanel');
        if (!panel) return;
        const isOpen = panel.classList.contains('open');
        panel.classList.toggle('open', !isOpen);
        if (!isOpen) {
            applyAll(); // checkbox state'lerini sync et
            const btn  = document.getElementById('paColBtn');
            const rect = btn ? btn.getBoundingClientRect() : { left: 0, bottom: 0, width: 0 };
            panel.style.top  = (rect.bottom + 4) + 'px';
            panel.style.left = Math.max(4, rect.right - panel.offsetWidth) + 'px';
        }
    };

    document.addEventListener('click', function(e) {
        const panel = document.getElementById('paColPanel');
        if (panel && panel.classList.contains('open') && !panel.contains(e.target)) {
            panel.classList.remove('open');
        }
    });

    // Sayfa açıldığında hemen uygula
    applyAll();
})();
</script>
}
