@{
    ViewData["Title"] = "Onayda Bekleyenler";
    var scopes = ViewBag.AvailableScopes as IReadOnlyList<string> ?? new[] { "mine" };
    var defaultScope = (string)(ViewBag.DefaultScope ?? "mine");
}

@section Styles {
<style>
    .pa-wrap {
        padding: 18px;
        flex: 1 1 0;
        min-height: 0;
        overflow: hidden;
        display: flex; flex-direction: column;
        max-width: 100%;
    }
    .pa-header {
        display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
        flex: 0 0 auto;
    }
    .pa-header-sep {
        width: 1px; height: 20px; background: rgba(148,163,184,.25); flex-shrink: 0;
    }
    body.app-theme-dark .pa-header-sep { background: rgba(255,255,255,.12); }
    .pa-title { font-size: 20px; font-weight: 700; margin: 0; }
    /* Kapsam radio-pill grubu (üst başlık satırı) */
    .pa-scope-radio {
        display: flex; align-items: center;
        background: rgba(148,163,184,.12); border-radius: 8px; padding: 2px; gap: 1px;
        flex-shrink: 0;
    }
    body.app-theme-dark .pa-scope-radio { background: rgba(255,255,255,.07); }
    .pa-scope-opt { display: flex; align-items: center; cursor: pointer; }
    .pa-scope-opt input[type="radio"] { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
    .pa-scope-opt span {
        padding: 5px 13px; border-radius: 6px;
        font-size: 12px; font-weight: 500; color: #64748b;
        cursor: pointer; white-space: nowrap; user-select: none;
        transition: background .12s, color .12s;
    }
    .pa-scope-opt input[type="radio"]:checked + span { background: #6366f1; color: #fff; }
    body.app-theme-dark .pa-scope-opt span { color: #94a3b8; }
    body.app-theme-dark .pa-scope-opt input[type="radio"]:checked + span { background: #6366f1; color: #fff; }

    /* ── Liste başlık üç sütun ── */
    .pa-list-header-left  { flex: 1 1 auto; min-width: 0; }
    .pa-list-header-mid   { flex: 0 0 auto; display: flex; align-items: center; }
    .pa-list-header-right { flex: 1 1 auto; display: flex; justify-content: flex-end; align-items: center; gap: 6px; }

    /* Arama kutusu — ortada sabit genişlik */
    .pa-search-wrap {
        width: 280px; position: relative; display: flex; align-items: center;
    }
    .pa-search-input {
        width: 100%; height: 30px; padding: 0 8px 0 30px;
        border: 1px solid rgba(148,163,184,.22); border-radius: 7px;
        background: transparent; font-size: 12px;
        color: var(--app-text, #0f172a); outline: none;
        transition: border-color .1s;
    }
    .pa-search-input:focus { border-color: rgba(99,102,241,.5); }
    .pa-search-input::placeholder { color: #94a3b8; }
    .pa-search-wrap svg { position: absolute; left: 8px; color: #94a3b8; pointer-events: none; flex-shrink: 0; }
    body.app-theme-dark .pa-search-input { color: #e2e8f0; border-color: rgba(255,255,255,.1); }
    body.app-theme-dark .pa-search-input:focus { border-color: rgba(99,102,241,.5); }
    body.app-theme-dark .pa-search-input::placeholder { color: #475569; }

    .pa-body { display: flex; flex-direction: row; gap: 0; flex: 1 1 auto; min-height: 0; }

    /* ── Sol kenar çubuğu (belge türleri + kapsam) ── */
    .pa-sidebar {
        width: 260px; flex: 0 0 auto;
        display: flex; flex-direction: column;
        background: var(--surface, #fff);
        border: 1px solid rgba(148,163,184,.18);
        border-radius: 10px;
        overflow: hidden;
        margin-right: 14px;
        transition: width .22s ease, margin-right .22s ease, opacity .18s;
    }
    .pa-sidebar.collapsed { width: 0; margin-right: 0; opacity: 0; pointer-events: none; }
    body.app-theme-dark .pa-sidebar {
        background: rgba(15,23,42,.4);
        border-color: rgba(255,255,255,.08);
    }
    .pa-groups {
        flex: 1 1 auto;
        padding: 8px;
        overflow-y: auto; min-height: 0;
    }

    /* ── Kenar çubuğu aç/kapat butonu ── */
    .pa-sidebar-toggle-btn {
        width: 28px; height: 28px; flex-shrink: 0;
        border-radius: 7px;
        border: 1px solid rgba(148,163,184,.22);
        background: transparent; cursor: pointer;
        color: #64748b;
        display: flex; align-items: center; justify-content: center;
        transition: background .12s, color .12s, border-color .12s;
    }
    .pa-sidebar-toggle-btn svg { transition: transform .22s ease; }
    .pa-sidebar-toggle-btn.collapsed svg { transform: rotate(180deg); }
    .pa-sidebar-toggle-btn:hover { background: rgba(99,102,241,.08); border-color: rgba(99,102,241,.35); color: #6366f1; }
    body.app-theme-dark .pa-sidebar-toggle-btn { color: #94a3b8; border-color: rgba(255,255,255,.1); }
    body.app-theme-dark .pa-sidebar-toggle-btn:hover { background: rgba(99,102,241,.15); border-color: rgba(99,102,241,.4); color: #818cf8; }
    .pa-group {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 12px; margin: 4px 0;
        border-radius: 8px; cursor: pointer;
        transition: background 0.15s;
        font-size: 13px;
    }
    .pa-group:hover { background: rgba(99,102,241,.06); }
    .pa-group.active {
        background: linear-gradient(135deg, rgba(99,102,241,.14), rgba(139,92,246,.10));
        border: 1px solid rgba(99,102,241,.3);
    }
    .pa-group-name { flex: 1 1 auto; font-weight: 500; color: #1e293b; }
    body.app-theme-dark .pa-group-name { color: #f1f5f9; }
    .pa-group-count {
        flex: 0 0 auto;
        background: rgba(99,102,241,.18); color: #6366f1;
        font-size: 11px; font-weight: 700;
        padding: 2px 8px; border-radius: 10px; min-width: 24px; text-align: center;
    }
    .pa-group.empty { opacity: 0.5; padding: 14px; text-align: center; font-size: 12px; color: #94a3b8; }

    .pa-list-wrap {
        flex: 1 1 auto;
        background: var(--surface, #fff);
        border: 1px solid rgba(148,163,184,.18);
        border-radius: 10px; overflow: hidden;
        display: flex; flex-direction: column; min-height: 0;
    }
    body.app-theme-dark .pa-list-wrap {
        background: rgba(15,23,42,.4);
        border-color: rgba(255,255,255,.08);
    }
    .pa-list-header {
        padding: 0 14px;
        height: 44px;
        border-bottom: 1px solid rgba(148,163,184,.12);
        display: flex; align-items: center; gap: 10px;
        flex: 0 0 auto;
    }
    body.app-theme-dark .pa-list-header { border-bottom-color: rgba(255,255,255,.07); }
    .pa-list-title { font-size: 13.5px; font-weight: 600; }
    .pa-list-count { font-size: 11px; color: #94a3b8; }

    .pa-list-scroll { flex: 1 1 auto; min-height: 0; overflow: auto; }
    .pa-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 12.5px; }
    .pa-table th {
        position: sticky; top: 0;
        background: rgba(241,245,249,1); color: #64748b;
        font-size: 11px; font-weight: 600; letter-spacing: .02em;
        padding: 7px 12px; text-align: left;
        border-bottom: 1px solid rgba(148,163,184,.15);
    }
    body.app-theme-dark .pa-table th { background: rgba(30,41,59,1); }
    .pa-table td {
        padding: 6px 12px; border-bottom: 1px solid rgba(148,163,184,.08);
        vertical-align: middle;
    }
    .pa-table tr { cursor: pointer; transition: background 0.12s; }
    .pa-table tr:hover td { background: rgba(99,102,241,.05); }
    body.app-theme-dark .pa-table tr:hover td { background: rgba(99,102,241,.10); }

    .pa-empty {
        padding: 50px 20px; text-align: center; color: #94a3b8; font-size: 13px;
    }
    .pa-step-pill {
        display: inline-flex; align-items: center; gap: 4px;
        background: rgba(99,102,241,.12); color: #6366f1;
        font-size: 11px; font-weight: 600;
        padding: 2px 8px; border-radius: 10px;
    }
    .pa-overdue { color: #ef4444; font-weight: 600; }

    /* ── Sütunlar butonu ─────────────────────────────────── */
    .pa-col-btn {
        margin-left: auto;
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px; padding: 0;
        border-radius: 7px;
        border: 1px solid rgba(148,163,184,.22);
        background: transparent; cursor: pointer;
        color: #64748b;
        transition: color .12s, background .12s, border-color .12s;
        flex-shrink: 0;
    }
    .pa-col-btn svg { width: 14px; height: 14px; }
    .pa-col-btn:hover { background: rgba(99,102,241,.08); border-color: rgba(99,102,241,.35); color: #6366f1; }
    .pa-col-btn.active { background: rgba(99,102,241,.12); border-color: rgba(99,102,241,.4); color: #6366f1; }
    body.app-theme-dark .pa-col-btn { color: #94a3b8; border-color: rgba(255,255,255,.1); background: rgba(255,255,255,.03); }
    body.app-theme-dark .pa-col-btn:hover { background: rgba(99,102,241,.15); border-color: rgba(99,102,241,.4); color: #818cf8; }
    body.app-theme-dark .pa-col-btn.active { background: rgba(99,102,241,.18); border-color: rgba(99,102,241,.45); color: #818cf8; }

    /* ── Sütun ayarları paneli ──────────────────────────────── */
    .pa-col-panel {
        display: none; position: fixed; z-index: 1100;
        background: var(--app-surface, #fff);
        border: 1px solid rgba(148,163,184,.2);
        border-radius: 10px;
        box-shadow: 0 8px 32px rgba(15,23,42,.18);
        width: 320px; max-height: 520px;
        flex-direction: column; overflow: hidden;
    }
    .pa-col-panel.open { display: flex; }
    body.app-theme-dark .pa-col-panel {
        background: #1e293b; border-color: rgba(255,255,255,.1);
        box-shadow: 0 8px 32px rgba(0,0,0,.5);
    }
    .pa-col-panel-title {
        padding: 10px 12px 9px;
        font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .05em;
        color: #94a3b8; border-bottom: 1px solid rgba(148,163,184,.12); flex-shrink: 0;
    }
    .pa-col-panel-rows { overflow-y: auto; flex: 1; padding: 4px 0; }
    .pa-cfg-row {
        display: flex; align-items: center; gap: 5px;
        padding: 4px 8px; user-select: none;
        border-top: 2px solid transparent;
        transition: border-color 0.1s;
    }
    .pa-cfg-row:not(.pa-cfg-fixed):hover { background: rgba(99,102,241,.06); }
    body.app-theme-dark .pa-cfg-row:not(.pa-cfg-fixed):hover { background: rgba(99,102,241,.10); }
    .pa-cfg-row.pa-cfg-dragging { opacity: .35; }
    .pa-cfg-row.pa-cfg-dragover { border-top-color: #6366f1; }
    .pa-cfg-grip {
        width: 14px; height: 20px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        cursor: grab; color: #94a3b8;
    }
    .pa-cfg-grip:active { cursor: grabbing; }
    .pa-cfg-fixed .pa-cfg-grip { visibility: hidden; }
    .pa-cfg-eye {
        width: 22px; height: 22px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        border-radius: 5px; cursor: pointer; border: none; background: transparent;
        color: #6366f1; transition: background 0.1s; padding: 0;
    }
    .pa-cfg-eye:hover { background: rgba(99,102,241,.12); }
    .pa-cfg-eye.pa-eye-off { color: #94a3b8; }
    .pa-cfg-fixed .pa-cfg-eye { visibility: hidden; pointer-events: none; }
    .pa-cfg-label {
        flex: 1; font-size: 12px;
        color: var(--app-text, #0f172a);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    body.app-theme-dark .pa-cfg-label { color: #e2e8f0; }
    .pa-cfg-row.pa-cfg-hidden .pa-cfg-label { color: #94a3b8; }
    .pa-cfg-align { display: flex; gap: 2px; flex: 1; }
    .pa-cfg-align-btn {
        flex: 1; height: 28px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 5px; border: 1px solid rgba(148,163,184,.2);
        cursor: pointer; color: #94a3b8; background: transparent; padding: 0;
        transition: all 0.1s;
    }
    .pa-cfg-align-btn svg { width: 14px; height: 14px; }
    .pa-cfg-align-btn:hover { background: rgba(99,102,241,.1); color: #6366f1; }
    .pa-cfg-align-btn.pa-align-active {
        background: rgba(99,102,241,.15); color: #6366f1;
        border-color: rgba(99,102,241,.3);
    }
    body.app-theme-dark .pa-cfg-align-btn.pa-align-active {
        background: rgba(99,102,241,.25); color: #818cf8;
    }
    /* Genişlet butonu */
    .pa-cfg-exp {
        width: 20px; height: 20px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        border-radius: 4px; border: none; background: transparent;
        color: #94a3b8; cursor: pointer; padding: 0;
        transition: transform 0.15s, color 0.1s;
    }
    .pa-cfg-exp:hover { color: #6366f1; }
    .pa-cfg-exp.open { transform: rotate(180deg); }
    /* Detay alt paneli */
    .pa-cfg-detail {
        display: none; flex-direction: column; gap: 7px;
        padding: 8px 10px 10px 36px;
        background: rgba(99,102,241,.03);
        border-bottom: 1px solid rgba(148,163,184,.1);
    }
    body.app-theme-dark .pa-cfg-detail {
        background: rgba(99,102,241,.05);
        border-bottom-color: rgba(255,255,255,.06);
    }
    .pa-cfg-detail.open { display: flex; }
    .pa-cfg-field-row {
        display: flex; align-items: center; gap: 6px;
    }
    .pa-cfg-field-label {
        font-size: 11px; color: #94a3b8; font-weight: 500;
        flex: 0 0 54px;
    }
    .pa-cfg-field-input {
        flex: 1; height: 26px; padding: 0 8px;
        font-size: 12px;
        border: 1px solid rgba(148,163,184,.25);
        border-radius: 5px;
        background: var(--app-surface, #fff);
        color: var(--app-text, #0f172a);
        outline: none;
        transition: border-color .1s;
    }
    .pa-cfg-field-input:focus { border-color: rgba(99,102,241,.5); }
    body.app-theme-dark .pa-cfg-field-input {
        background: rgba(255,255,255,.05);
        color: #e2e8f0;
        border-color: rgba(255,255,255,.12);
    }
    body.app-theme-dark .pa-cfg-field-input:focus { border-color: rgba(99,102,241,.5); }
    .pa-cfg-width-input { flex: none; width: 72px; }
    .pa-cfg-field-unit { font-size: 11px; color: #94a3b8; flex-shrink: 0; }

    /* Modal */
    .pa-modal-backdrop {
        position: fixed; inset: 0; background: rgba(15,23,42,.55);
        backdrop-filter: blur(3px);
        display: none; align-items: center; justify-content: center;
        z-index: 1050;
    }
    .pa-modal-backdrop.show { display: flex; }
    .pa-modal {
        background: #fff; border-radius: 12px;
        width: min(720px, 92vw); max-height: 88vh;
        display: flex; flex-direction: column;
        box-shadow: 0 20px 60px rgba(15,23,42,.30);
        animation: pa-modal-in 0.18s ease-out;
    }
    body.app-theme-dark .pa-modal { background: #1e293b; color: #e2e8f0; }
    @@keyframes pa-modal-in {
        from { opacity: 0; transform: translateY(20px) scale(.98); }
        to   { opacity: 1; transform: translateY(0)     scale(1); }
    }
    .pa-modal-header {
        padding: 16px 20px;
        border-bottom: 1px solid rgba(148,163,184,.18);
        display: flex; align-items: flex-start; gap: 14px;
    }
    .pa-modal-title { font-size: 16px; font-weight: 700; margin: 0 0 4px; }
    .pa-modal-sub { font-size: 12px; color: #64748b; }
    .pa-modal-close {
        margin-left: auto; background: transparent; border: 0; font-size: 22px;
        color: #94a3b8; cursor: pointer; line-height: 1;
    }
    .pa-modal-body { padding: 18px 20px; overflow-y: auto; flex: 1 1 auto; }
    .pa-modal-footer {
        padding: 14px 20px; border-top: 1px solid rgba(148,163,184,.18);
        display: flex; gap: 8px; justify-content: flex-end;
        flex: 0 0 auto;
    }
    .pa-btn {
        padding: 8px 16px; border-radius: 8px; border: 0;
        font-size: 13px; font-weight: 600; cursor: pointer;
        transition: opacity 0.15s, transform 0.12s;
    }
    .pa-btn:hover { transform: translateY(-1px); }
    .pa-btn-primary { background: linear-gradient(135deg, #10b981, #059669); color: #fff; }
    .pa-btn-danger  { background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff; }
    .pa-btn-ghost   { background: rgba(148,163,184,.15); color: #64748b; }
    .pa-btn-route   { background: linear-gradient(135deg, #6366f1, #4f46e5); color: #fff; }
    /* Not girişi paneli */
    .pa-note-panel {
        padding: 12px 20px 14px;
        border-top: 1px solid rgba(148,163,184,.18);
        flex: 0 0 auto;
    }
    .pa-note-label {
        font-size: 12px; font-weight: 600; margin-bottom: 6px;
        color: var(--app-text, #0f172a);
    }
    .pa-note-textarea {
        width: 100%; box-sizing: border-box; resize: vertical;
        border: 1px solid rgba(148,163,184,.3); border-radius: 8px;
        padding: 7px 10px; font-size: 13px; line-height: 1.4;
        background: transparent; color: var(--app-text, #0f172a);
        font-family: inherit; outline: none;
        transition: border-color .12s;
    }
    .pa-note-textarea:focus { border-color: rgba(99,102,241,.55); }
    body.app-theme-dark .pa-note-textarea { border-color: rgba(255,255,255,.15); color: #e2e8f0; }
    .pa-note-actions { display: flex; justify-content: flex-end; gap: 8px; margin-top: 8px; }
    .pa-note-panel--approve { background: rgba(16,185,129,.05); }
    .pa-note-panel--reject  { background: rgba(239,68,68,.05); }
    .pa-note-panel--approve .pa-note-label { color: #059669; }
    .pa-note-panel--reject  .pa-note-label { color: #dc2626; }

    .pa-detail-grid {
        display: grid; grid-template-columns: 110px 1fr; gap: 6px 14px;
        font-size: 13px; margin-bottom: 20px;
    }
    .pa-detail-grid dt { color: #94a3b8; font-weight: 500; }
    .pa-detail-grid dd { margin: 0; font-weight: 500; }

    /* ─── Süreç zaman çizelgesi ─── */
    .pa-flow-section-title {
        font-size: 11px; font-weight: 700; letter-spacing: .06em;
        color: #94a3b8; text-transform: uppercase;
        margin-bottom: 14px;
    }
    /* ── Yatay onay süreci zaman çizelgesi ── */
    .pa-htl {
        display: flex; flex-direction: row;
        overflow-x: auto; padding: 4px 4px 12px;
    }
    .pa-htl::-webkit-scrollbar { height: 4px; }
    .pa-htl::-webkit-scrollbar-thumb { background: rgba(148,163,184,.3); border-radius: 2px; }

    .pa-htl-node {
        display: flex; flex-direction: column; align-items: center;
        flex: 1; min-width: 130px; max-width: 210px;
    }

    .pa-htl-spine {
        display: flex; align-items: center; width: 100%; height: 36px;
    }

    .pa-htl-line {
        flex: 1; height: 2px; background: #e2e8f0;
    }
    body.app-theme-dark .pa-htl-line { background: rgba(255,255,255,.12); }
    .pa-htl-line.htl-done { background: #10b981; }
    .pa-htl-node:first-child .pa-htl-spine .pa-htl-line:first-child { visibility: hidden; }
    .pa-htl-node:last-child  .pa-htl-spine .pa-htl-line:last-child  { visibility: hidden; }

    .pa-htl-dot {
        width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        font-size: 15px; font-weight: 700;
        border: 2px solid #e2e8f0;
        background: var(--app-surface, #fff); color: #94a3b8;
        position: relative; z-index: 1;
    }
    body.app-theme-dark .pa-htl-dot { background: #1e293b; border-color: rgba(255,255,255,.15); color: #64748b; }
    .pa-htl-node.sf-approved .pa-htl-dot { border-color: #10b981; background: #ecfdf5; color: #059669; }
    .pa-htl-node.sf-pending  .pa-htl-dot { border-color: #f59e0b; background: #fffbeb; color: #b45309; }
    .pa-htl-node.sf-rejected .pa-htl-dot { border-color: #ef4444; background: #fef2f2; color: #dc2626; }
    body.app-theme-dark .pa-htl-node.sf-approved .pa-htl-dot { background: rgba(16,185,129,.15); }
    body.app-theme-dark .pa-htl-node.sf-pending  .pa-htl-dot { background: rgba(245,158,11,.12); }
    body.app-theme-dark .pa-htl-node.sf-rejected .pa-htl-dot { background: rgba(239,68,68,.12); }

    .pa-htl-card {
        margin-top: 10px; width: 100%; padding: 6px 8px; text-align: center;
    }
    /* Aktif adım (sf-current) — daha canlı görünüm */
    .pa-htl-node.sf-current .pa-htl-dot {
        box-shadow: 0 0 0 4px rgba(245,158,11,.22), 0 0 12px rgba(245,158,11,.18);
    }
    body.app-theme-dark .pa-htl-node.sf-current .pa-htl-dot {
        box-shadow: 0 0 0 4px rgba(245,158,11,.3), 0 0 14px rgba(245,158,11,.22);
    }
    .pa-htl-node.sf-current .pa-htl-card {
        background: rgba(245,158,11,.07); border: 1.5px solid rgba(245,158,11,.28);
        border-radius: 10px;
    }
    body.app-theme-dark .pa-htl-node.sf-current .pa-htl-card {
        background: rgba(245,158,11,.12); border-color: rgba(245,158,11,.38);
    }
    /* Sırada (queued) adım — soluk */
    .pa-htl-node.sf-queued { opacity: .55; }

    .pa-htl-name {
        font-size: 12px; font-weight: 600; color: var(--app-text, #0f172a); margin-bottom: 3px;
    }
    body.app-theme-dark .pa-htl-name { color: #e2e8f0; }

    .pa-htl-badge {
        display: inline-block; font-size: 10px; font-weight: 700;
        padding: 2px 8px; border-radius: 20px;
        letter-spacing: .03em; white-space: nowrap; margin-bottom: 4px;
    }
    .badge-approved { background: #d1fae5; color: #065f46; }
    .badge-pending  { background: #fef3c7; color: #92400e; }
    .badge-rejected { background: #fee2e2; color: #991b1b; }
    .badge-waiting  { background: #f1f5f9; color: #64748b; }
    body.app-theme-dark .badge-approved { background: rgba(16,185,129,.18); color: #6ee7b7; }
    body.app-theme-dark .badge-pending  { background: rgba(245,158,11,.18); color: #fcd34d; }
    body.app-theme-dark .badge-rejected { background: rgba(239,68,68,.18); color: #fca5a5; }
    body.app-theme-dark .badge-waiting  { background: rgba(148,163,184,.1); color: #94a3b8; }

    .pa-htl-approver { font-size: 11px; color: #64748b; margin-bottom: 3px; }

    .pa-htl-times {
        display: flex; flex-direction: column; align-items: center;
        gap: 1px; font-size: 10px; color: #94a3b8;
    }
    .pa-htl-time-lbl { font-weight: 600; color: #94a3b8; }

    .pa-htl-note {
        margin-top: 5px; font-size: 11px; padding: 4px 8px; text-align: left;
        border-left: 3px solid #e2e8f0; color: #64748b; border-radius: 0 4px 4px 0;
        background: rgba(148,163,184,.06);
    }
    body.app-theme-dark .pa-htl-note { border-color: rgba(255,255,255,.12); background: rgba(255,255,255,.04); }

    /* ── Bekleyen / Tamamlanan tab ── */
    .pa-mode-tabs {
        display: flex; align-items: center; gap: 2px;
        background: rgba(148,163,184,.12); border-radius: 8px; padding: 2px;
        flex-shrink: 0;
    }
    body.app-theme-dark .pa-mode-tabs { background: rgba(255,255,255,.07); }
    .pa-mode-tab {
        padding: 5px 14px; border-radius: 6px;
        font-size: 12px; font-weight: 500; color: #64748b;
        cursor: pointer; white-space: nowrap; user-select: none;
        transition: background .12s, color .12s;
        border: none; background: transparent;
    }
    .pa-mode-tab.active { background: #6366f1; color: #fff; }
    body.app-theme-dark .pa-mode-tab { color: #94a3b8; }
    body.app-theme-dark .pa-mode-tab.active { background: #6366f1; color: #fff; }

    /* Tamamlanmış listede durum rozeti sütunu */
    .pa-status-badge {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 11px; font-weight: 600;
        padding: 2px 8px; border-radius: 10px;
    }
</style>
}

<div class="pa-wrap">
    <div class="pa-header">
        <button type="button" class="pa-sidebar-toggle-btn" id="paSidebarToggle" onclick="paToggleSidebar()" title="Menüyü Gizle / Göster">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
        </button>
        <h1 class="pa-title">Onay Takibi</h1>
        <div class="pa-mode-tabs" id="paModeTabsGroup">
            <button type="button" class="pa-mode-tab active" data-mode="pending" onclick="paSetMode('pending')">Bekleyenler</button>
            <button type="button" class="pa-mode-tab" data-mode="completed" onclick="paSetMode('completed')">Tamamlananlar</button>
        </div>
        @if (scopes.Count > 1)
        {
        <div class="pa-header-sep"></div>
        <div class="pa-scope-radio" id="paScopeGroup">
            @foreach (var s in scopes)
            {
                var label = s switch
                {
                    "mine" => "Sadece Benim",
                    "department" => "Departmanım",
                    "all" => "Tümü",
                    _ => s
                };
                var isDefault = string.Equals(s, defaultScope, StringComparison.OrdinalIgnoreCase);
                <label class="pa-scope-opt">
                    <input type="radio" name="paScope" value="@s" @(isDefault ? "checked" : "")>
                    <span>@label</span>
                </label>
            }
        </div>
        }
        else
        {
        <div style="display:none;" id="paScopeGroup">
            @foreach (var s in scopes)
            {
                var isDefault = string.Equals(s, defaultScope, StringComparison.OrdinalIgnoreCase);
                <label class="pa-scope-opt">
                    <input type="radio" name="paScope" value="@s" @(isDefault ? "checked" : "")>
                    <span>@s</span>
                </label>
            }
        </div>
        }
    </div>

    <div class="pa-body">
        <div class="pa-sidebar" id="paSidebar">
            <div class="pa-groups" id="paGroups">
                <div class="pa-group empty">Yükleniyor…</div>
            </div>
        </div>
        <div class="pa-list-wrap">
            <div class="pa-list-header">
                <div class="pa-list-header-left">
                    <div class="pa-list-title" id="paListTitle">Tüm belge türleri</div>
                    <div class="pa-list-count" id="paListCount"></div>
                </div>
                <div class="pa-list-header-mid">
                    <div class="pa-search-wrap" data-nodirty>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <input type="text" id="paSearch" class="pa-search-input" placeholder="Hızlı ara…" autocomplete="off">
                    </div>
                </div>
                <div class="pa-list-header-right">
                    <button type="button" class="pa-col-btn" id="paColBtn" onclick="paToggleColPanel(event)" title="Sütun Ayarları">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="21" y1="4"  x2="14" y2="4"/><line x1="10" y1="4" x2="3" y2="4"/>
                            <line x1="21" y1="12" x2="12" y2="12"/><line x1="8" y1="12" x2="3" y2="12"/>
                            <line x1="21" y1="20" x2="16" y2="20"/><line x1="12" y1="20" x2="3" y2="20"/>
                            <line x1="14" y1="2"  x2="14" y2="6"/>
                            <line x1="8"  y1="10" x2="8"  y2="14"/>
                            <line x1="16" y1="18" x2="16" y2="22"/>
                        </svg>
                    </button>
                </div>
            </div>
            <!-- Sütun ayarları paneli (JS tarafından doldurulur) -->
            <div class="pa-col-panel" id="paColPanel" data-nodirty>
                <div class="pa-col-panel-title">Sütun Ayarları</div>
                <div class="pa-col-panel-rows" id="paColRows"></div>
            </div>
            <div class="pa-list-scroll" id="paListScroll">
                <div class="pa-empty">Sol panelden bir belge türü seçin…</div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="pa-modal-backdrop" id="paModalBackdrop">
    <div class="pa-modal" role="dialog" aria-modal="true">
        <div class="pa-modal-header">
            <div>
                <div class="pa-modal-title" id="paModalTitle">Belge Detayı</div>
                <div class="pa-modal-sub" id="paModalSub"></div>
            </div>
            <button type="button" class="pa-modal-close" id="paModalClose" aria-label="Kapat">×</button>
        </div>
        <div class="pa-modal-body" id="paModalBody">
            <div style="text-align:center;padding:30px;color:#94a3b8;">Yükleniyor…</div>
        </div>
        <!-- Not girişi — Onayla/Reddet tıklandığında açılır, native prompt() yerine -->
        <div class="pa-note-panel" id="paNotePanel" style="display:none;">
            <div class="pa-note-label" id="paNoteLabel">Onay Notu</div>
            <textarea id="paNoteText" class="pa-note-textarea" rows="2" placeholder="Not girin…"></textarea>
            <div class="pa-note-actions">
                <button type="button" class="pa-btn pa-btn-ghost" id="paNoteCancel">Vazgeç</button>
                <button type="button" class="pa-btn" id="paNoteSubmit">Gönder</button>
            </div>
        </div>
        <div class="pa-modal-footer" id="paModalFooter">
            <button type="button" class="pa-btn pa-btn-danger"  id="paBtnReject">Reddet</button>
            <span id="paChoiceArms" style="display:contents;"></span>
            <button type="button" class="pa-btn pa-btn-primary" id="paBtnApprove">Onayla</button>
            <button type="button" class="pa-btn pa-btn-ghost"   id="paBtnCancel">Kapat</button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
(async function() {
    const groupsEl = document.getElementById('paGroups');
    function getScope() {
        var c = document.querySelector('input[name="paScope"]:checked');
        return c ? c.value : 'mine';
    }
    const listScrollEl = document.getElementById('paListScroll');
    const listTitleEl = document.getElementById('paListTitle');
    const listCountEl = document.getElementById('paListCount');
    const backdropEl = document.getElementById('paModalBackdrop');
    const modalCloseEl = document.getElementById('paModalClose');
    const modalCancelEl = document.getElementById('paBtnCancel');
    const modalApproveEl = document.getElementById('paBtnApprove');
    const modalRejectEl = document.getElementById('paBtnReject');
    const modalBodyEl = document.getElementById('paModalBody');
    const modalTitleEl = document.getElementById('paModalTitle');
    const modalSubEl = document.getElementById('paModalSub');
    const modalFooterEl = document.getElementById('paModalFooter');
    const choiceArmsEl  = document.getElementById('paChoiceArms');
    const notePanelEl = document.getElementById('paNotePanel');
    const noteLabelEl = document.getElementById('paNoteLabel');
    const noteTextEl = document.getElementById('paNoteText');
    const noteSubmitEl = document.getElementById('paNoteSubmit');
    const noteCancelEl = document.getElementById('paNoteCancel');
    let _noteAction = null; // 'approve' | 'reject'
    let _currentChoiceArmId = null; // seçim kolu ile onayda set edilir
    let _currentMode = 'pending'; // 'pending' | 'completed'

    // ── Sütun yapılandırması ─────────────────────────────────────────────────
    const COL_STORAGE_KEY = 'pa-col-cfg-v2';
    const DEFAULT_DEFS = [
        { key: 'docno', label: 'Belge No',    visible: true, align: 'left',   fixed: true },
        { key: 'flow',  label: 'Akış',        visible: true, align: 'left'   },
        { key: 'typ',   label: 'Tür',         visible: true, align: 'left'   },
        { key: 'cari',  label: 'Cari',        visible: true, align: 'left'   },
        { key: 'amt',   label: 'Tutar',       visible: true, align: 'right'  },
        { key: 'step',  label: 'Adım',        visible: true, align: 'center' },
        { key: 'apvr',  label: 'Onaylayıcı',  visible: true, align: 'left'   },
        { key: 'dt',    label: 'Bekliyor',    visible: true, align: 'left'   },
    ];

    function _loadColDefs() {
        try {
            var saved = JSON.parse(localStorage.getItem(COL_STORAGE_KEY) || 'null');
            if (!Array.isArray(saved)) return DEFAULT_DEFS.map(function(d) { return Object.assign({}, d); });
            var result = [];
            saved.forEach(function(s) {
                var def = DEFAULT_DEFS.find(function(d) { return d.key === s.key; });
                if (def) result.push(Object.assign({}, def, {
                    visible: s.visible !== false,
                    align:   s.align || def.align,
                    label:   s.label || def.label,
                    width:   s.width || null
                }));
            });
            DEFAULT_DEFS.forEach(function(d) {
                if (!result.find(function(r) { return r.key === d.key; }))
                    result.push(Object.assign({}, d));
            });
            return result;
        } catch(e) { return DEFAULT_DEFS.map(function(d) { return Object.assign({}, d); }); }
    }

    function _serializeColDefs() {
        return JSON.stringify(_colDefs.map(function(c) {
            return { key: c.key, visible: c.visible, align: c.align, label: c.label, width: c.width || null };
        }));
    }

    function _saveColDefs() {
        var serialized = _serializeColDefs();
        try { localStorage.setItem(COL_STORAGE_KEY, serialized); } catch(e) {}
        // Kullanıcı bazlı server-side saklama (fire-and-forget)
        fetch('/PendingApproval/SaveColConfig', {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': csrf()
            },
            body: JSON.stringify({ config: serialized })
        }).catch(function() {});
    }

    function _applyServerConfig(json) {
        try {
            var saved = JSON.parse(json || 'null');
            if (!Array.isArray(saved)) return;
            var result = [];
            saved.forEach(function(s) {
                var def = DEFAULT_DEFS.find(function(d) { return d.key === s.key; });
                if (def) result.push(Object.assign({}, def, {
                    visible: s.visible !== false,
                    align:   s.align || def.align,
                    label:   s.label || def.label,
                    width:   s.width || null
                }));
            });
            DEFAULT_DEFS.forEach(function(d) {
                if (!result.find(function(r) { return r.key === d.key; }))
                    result.push(Object.assign({}, d));
            });
            _colDefs = result;
        } catch(e) {}
    }

    function _renderCell(key, it, now) {
        switch (key) {
            case 'docno': return '<strong>' + escapeHtml(it.documentNumber) + '</strong>';
            case 'flow':  return '<span style="font-size:11px;color:#94a3b8;">' + escapeHtml(it.flowName) + '</span>';
            case 'typ':   return escapeHtml(it.documentTypeName || 'Belirsiz');
            case 'cari':  return escapeHtml(it.contactName || '—');
            case 'amt':   return fmtMoney(it.grandTotal, it.currencyCode);
            case 'step':  return '<span class="pa-step-pill">' + it.stepPosition + ' / ' + it.totalSteps + '</span>' +
                                 '<span style="font-size:11px;color:#94a3b8;margin-left:6px;">' + escapeHtml(it.stepName) + '</span>';
            case 'apvr':  return escapeHtml(it.approverName || '—');
            case 'dt': {
                if (_currentMode === 'completed') {
                    const statusTr  = STATUS_TR[it.instanceStatus]   || it.instanceStatus || '—';
                    const badgeCls  = it.instanceStatus === 'Approved' ? 'badge-approved' : 'badge-rejected';
                    return '<span class="pa-status-badge ' + badgeCls + '">' + statusTr + '</span>' +
                           '<span style="font-size:11px;color:#94a3b8;margin-left:6px;">' + fmtDate(it.stepCreated) + '</span>';
                }
                const od = it.dueDate && new Date(it.dueDate).getTime() < now;
                return '<span class="' + (od ? 'pa-overdue' : '') + '">' + fmtDate(it.stepCreated) + '</span>';
            }
            default: return '';
        }
    }

    let _colDefs = _loadColDefs();
    let _lastItems = null;
    let _expandedKeys = new Set();

    var ALIGN_ICONS = {
        left:   '<svg viewBox="0 0 16 14" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="16" height="2" rx="1"/><rect x="0" y="4" width="10" height="2" rx="1"/><rect x="0" y="8" width="13" height="2" rx="1"/><rect x="0" y="12" width="8" height="2" rx="1"/></svg>',
        center: '<svg viewBox="0 0 16 14" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="16" height="2" rx="1"/><rect x="3" y="4" width="10" height="2" rx="1"/><rect x="1.5" y="8" width="13" height="2" rx="1"/><rect x="4" y="12" width="8" height="2" rx="1"/></svg>',
        right:  '<svg viewBox="0 0 16 14" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="16" height="2" rx="1"/><rect x="6" y="4" width="10" height="2" rx="1"/><rect x="2.5" y="8" width="13" height="2" rx="1"/><rect x="8" y="12" width="8" height="2" rx="1"/></svg>',
    };

    // ── Sütun ayarları paneli renderer ───────────────────────────────────────
    function _renderColPanel() {
        var rowsEl = document.getElementById('paColRows');
        if (!rowsEl) return;
        var GRIP   = '<svg width="10" height="14" viewBox="0 0 10 14" fill="currentColor" style="opacity:.45"><circle cx="2" cy="2" r="1.5"/><circle cx="8" cy="2" r="1.5"/><circle cx="2" cy="7" r="1.5"/><circle cx="8" cy="7" r="1.5"/><circle cx="2" cy="12" r="1.5"/><circle cx="8" cy="12" r="1.5"/></svg>';
        var EYE    = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
        var EYEOFF = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
        var CHEV   = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6,9 12,15 18,9"/></svg>';

        var html = '';
        _colDefs.forEach(function(c, i) {
            var fc   = c.fixed ? ' pa-cfg-fixed' : '';
            var hc   = !c.visible ? ' pa-cfg-hidden' : '';
            var isOpen = _expandedKeys.has(c.key);
            var oc   = isOpen ? ' open' : '';
            html +=
                '<div class="pa-cfg-row' + fc + hc + '" data-idx="' + i + '" data-key="' + c.key + '" draggable="' + (c.fixed ? 'false' : 'true') + '">' +
                    '<span class="pa-cfg-grip">' + GRIP + '</span>' +
                    '<button type="button" class="pa-cfg-eye' + (!c.visible ? ' pa-eye-off' : '') + '" data-key="' + c.key + '">' + (c.visible ? EYE : EYEOFF) + '</button>' +
                    '<span class="pa-cfg-label">' + escapeHtml(c.label) + '</span>' +
                    '<button type="button" class="pa-cfg-exp' + oc + '" data-key="' + c.key + '" title="Detay ayarları">' + CHEV + '</button>' +
                '</div>' +
                '<div class="pa-cfg-detail' + oc + '" data-key="' + c.key + '">' +
                    '<div class="pa-cfg-field-row">' +
                        '<span class="pa-cfg-field-label">Başlık</span>' +
                        '<input type="text" class="pa-cfg-field-input" data-key="' + c.key + '" data-field="label" value="' + escapeHtml(c.label) + '">' +
                    '</div>' +
                    '<div class="pa-cfg-field-row">' +
                        '<span class="pa-cfg-field-label">Genişlik</span>' +
                        '<input type="number" class="pa-cfg-field-input pa-cfg-width-input" data-key="' + c.key + '" data-field="width" value="' + (c.width || '') + '" placeholder="Otomatik" min="40" max="600">' +
                        '<span class="pa-cfg-field-unit">px</span>' +
                    '</div>' +
                    '<div class="pa-cfg-field-row">' +
                        '<span class="pa-cfg-field-label">Hizalama</span>' +
                        '<span class="pa-cfg-align">' +
                            '<button type="button" class="pa-cfg-align-btn' + (c.align === 'left'   ? ' pa-align-active' : '') + '" data-key="' + c.key + '" data-align="left"   title="Sola hizala">'   + ALIGN_ICONS.left   + '</button>' +
                            '<button type="button" class="pa-cfg-align-btn' + (c.align === 'center' ? ' pa-align-active' : '') + '" data-key="' + c.key + '" data-align="center" title="Ortala">'         + ALIGN_ICONS.center + '</button>' +
                            '<button type="button" class="pa-cfg-align-btn' + (c.align === 'right'  ? ' pa-align-active' : '') + '" data-key="' + c.key + '" data-align="right"  title="Sağa hizala">'   + ALIGN_ICONS.right  + '</button>' +
                        '</span>' +
                    '</div>' +
                '</div>';
        });
        rowsEl.innerHTML = html;

        // Panel genelinde dragover → yasak simgesi gözükmesin
        var panelEl = document.getElementById('paColPanel');
        if (panelEl) panelEl.ondragover = function(e) { e.preventDefault(); };

        // Eye toggle
        rowsEl.querySelectorAll('.pa-cfg-eye').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key = btn.getAttribute('data-key');
                var def = _colDefs.find(function(c) { return c.key === key; });
                if (!def || def.fixed) return;
                def.visible = !def.visible;
                _saveColDefs();
                _renderColPanel();
                if (_lastItems) renderList(_lastItems);
            });
        });

        // Hizalama
        rowsEl.querySelectorAll('.pa-cfg-align-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key = btn.getAttribute('data-key');
                var align = btn.getAttribute('data-align');
                var def = _colDefs.find(function(c) { return c.key === key; });
                if (!def) return;
                def.align = align;
                _saveColDefs();
                _renderColPanel();
                if (_lastItems) renderList(_lastItems);
            });
        });

        // Genişlet/daralt
        rowsEl.querySelectorAll('.pa-cfg-exp').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key = btn.getAttribute('data-key');
                if (_expandedKeys.has(key)) _expandedKeys.delete(key);
                else _expandedKeys.add(key);
                _renderColPanel();
            });
        });

        // Başlık değiştirme (input event → sadece listeyi güncelle, paneli değil)
        rowsEl.querySelectorAll('.pa-cfg-field-input[data-field="label"]').forEach(function(inp) {
            inp.addEventListener('input', function() {
                var key = inp.getAttribute('data-key');
                var def = _colDefs.find(function(c) { return c.key === key; });
                if (!def) return;
                def.label = inp.value;
                _saveColDefs();
                var span = rowsEl.querySelector('.pa-cfg-row[data-key="' + key + '"] .pa-cfg-label');
                if (span) span.textContent = def.label;
                if (_lastItems) renderList(_lastItems);
            });
        });

        // Genişlik değiştirme (change event — blur/Enter tetikler)
        rowsEl.querySelectorAll('.pa-cfg-field-input[data-field="width"]').forEach(function(inp) {
            inp.addEventListener('change', function() {
                var key = inp.getAttribute('data-key');
                var def = _colDefs.find(function(c) { return c.key === key; });
                if (!def) return;
                def.width = parseInt(inp.value) || null;
                _saveColDefs();
                if (_lastItems) renderList(_lastItems);
            });
        });

        // Drag-and-drop sıralama
        var dragSrcIdx = null;
        rowsEl.querySelectorAll('.pa-cfg-row:not(.pa-cfg-fixed)').forEach(function(row) {
            row.addEventListener('dragstart', function(e) {
                dragSrcIdx = parseInt(row.getAttribute('data-idx'));
                e.dataTransfer.effectAllowed = 'move';
                setTimeout(function() { row.classList.add('pa-cfg-dragging'); }, 0);
            });
            row.addEventListener('dragend', function() {
                dragSrcIdx = null;
                rowsEl.querySelectorAll('.pa-cfg-row').forEach(function(r) {
                    r.classList.remove('pa-cfg-dragging', 'pa-cfg-dragover');
                });
            });
            row.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                rowsEl.querySelectorAll('.pa-cfg-row').forEach(function(r) { r.classList.remove('pa-cfg-dragover'); });
                row.classList.add('pa-cfg-dragover');
            });
            row.addEventListener('dragleave', function() { row.classList.remove('pa-cfg-dragover'); });
            row.addEventListener('drop', function(e) {
                e.preventDefault();
                var targetIdx = parseInt(row.getAttribute('data-idx'));
                if (dragSrcIdx !== null && dragSrcIdx !== targetIdx) {
                    var moved = _colDefs.splice(dragSrcIdx, 1)[0];
                    _colDefs.splice(targetIdx, 0, moved);
                    _saveColDefs();
                    _renderColPanel();
                    if (_lastItems) renderList(_lastItems);
                }
            });
        });
    }

    // ── /Sütun yapılandırması ────────────────────────────────────────────────

    let activeDocTypeId = null;  // ilk yüklemede ilk gruba otomatik set edilir
    let currentInstanceId = null;

    function csrf() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    function escapeHtml(s) {
        if (s == null) return '';
        return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }
    function fmtDate(iso) {
        if (!iso) return '—';
        const d = new Date(iso);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleDateString('tr-TR') + ' ' + d.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
    }
    function fmtMoney(v, code) {
        if (v == null) return '—';
        const n = Number(v);
        return n.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ' + (code || '');
    }

    async function loadGroups() {
        const scope = getScope();
        groupsEl.innerHTML = '<div class="pa-group empty">Yükleniyor…</div>';
        try {
            const ep = _currentMode === 'completed' ? '/PendingApproval/CompletedGroups' : '/PendingApproval/Groups';
            const resp = await fetch(ep + '?scope=' + encodeURIComponent(scope), { credentials: 'same-origin' });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            renderGroups(data.groups);
        } catch (err) {
            groupsEl.innerHTML = '<div class="pa-group empty">Hata: ' + escapeHtml(err.message) + '</div>';
        }
    }

    function renderGroups(groups) {
        const emptyMsg = _currentMode === 'completed'
            ? 'Tamamlanmış akış bulunamadı.'
            : 'Onayda bekleyen kayıt yok.';
        if (!groups || groups.length === 0) {
            groupsEl.innerHTML = '<div class="pa-group empty">' + emptyMsg + '</div>';
            listScrollEl.innerHTML = '<div class="pa-empty">Bu görünümde kayıt bulunmuyor.</div>';
            listTitleEl.textContent = '—';
            listCountEl.textContent = '';
            return;
        }
        let html = '';
        groups.forEach(g => {
            const id = g.documentTypeId == null ? '' : g.documentTypeId;
            html += '<div class="pa-group" data-doctype="' + id + '">' +
                    '<span class="pa-group-name">' + escapeHtml(g.documentTypeName) + '</span>' +
                    '<span class="pa-group-count">' + g.count + '</span>' +
                    '</div>';
        });
        groupsEl.innerHTML = html;
        groupsEl.querySelectorAll('.pa-group[data-doctype]').forEach(el => {
            el.addEventListener('click', () => {
                const raw = el.getAttribute('data-doctype');
                activeDocTypeId = raw === '' ? null : Number(raw);
                groupsEl.querySelectorAll('.pa-group').forEach(g => g.classList.remove('active'));
                el.classList.add('active');
                listTitleEl.textContent = el.querySelector('.pa-group-name').textContent;
                loadList();
            });
        });
        // İlk yüklemede ilk grubu otomatik seç
        const firstEl = groupsEl.querySelector('.pa-group[data-doctype]');
        if (firstEl) {
            const raw = firstEl.getAttribute('data-doctype');
            activeDocTypeId = raw === '' ? null : Number(raw);
            firstEl.classList.add('active');
            listTitleEl.textContent = firstEl.querySelector('.pa-group-name').textContent;
        }
        loadList();
    }

    async function loadList() {
        const scope = getScope();
        listScrollEl.innerHTML = '<div class="pa-empty">Yükleniyor…</div>';
        try {
            const ep = _currentMode === 'completed' ? '/PendingApproval/CompletedList' : '/PendingApproval/List';
            let url = ep + '?scope=' + encodeURIComponent(scope);
            if (activeDocTypeId != null) url += '&documentTypeId=' + activeDocTypeId;
            const resp = await fetch(url, { credentials: 'same-origin' });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            renderList(data.items);
        } catch (err) {
            listScrollEl.innerHTML = '<div class="pa-empty" style="color:#ef4444;">Hata: ' + escapeHtml(err.message) + '</div>';
        }
    }

    function renderList(items) {
        _lastItems = items;
        var filtered = _filterItems(items);
        if (!filtered || filtered.length === 0) {
            listScrollEl.innerHTML = '<div class="pa-empty">' +
                (_searchQuery ? 'Arama sonucu bulunamadı.' : 'Bu türde bekleyen kayıt yok.') + '</div>';
            listCountEl.textContent = _searchQuery ? (filtered.length + ' / ' + (items||[]).length) : '';
            return;
        }
        listCountEl.textContent = _searchQuery
            ? (filtered.length + ' / ' + items.length + ' kayıt')
            : (filtered.length + ' kayıt');
        items = filtered;
        var vis = _colDefs.filter(function(c) { return c.visible; });
        // colgroup: genişlik tanımlı sütunlar için kesin width
        var html = '<table class="pa-table"><colgroup>';
        vis.forEach(function(c) {
            html += c.width ? '<col style="width:' + c.width + 'px;min-width:' + c.width + 'px">' : '<col>';
        });
        html += '</colgroup><thead><tr>';
        vis.forEach(function(c) {
            var styleArr = [];
            if (c.align && c.align !== 'left') styleArr.push('text-align:' + c.align);
            if (c.width) styleArr.push('min-width:' + c.width + 'px');
            var as = styleArr.length ? ' style="' + styleArr.join(';') + '"' : '';
            html += '<th class="pa-col-' + c.key + '"' + as + '>' + escapeHtml(c.label) + '</th>';
        });
        html += '</tr></thead><tbody>';
        var now = Date.now();
        items.forEach(function(it) {
            html += '<tr data-instance-id="' + it.instanceId + '">';
            vis.forEach(function(c) {
                var styleArr = [];
                if (c.align && c.align !== 'left') styleArr.push('text-align:' + c.align);
                if (c.width) styleArr.push('min-width:' + c.width + 'px');
                var as = styleArr.length ? ' style="' + styleArr.join(';') + '"' : '';
                html += '<td class="pa-col-' + c.key + '"' + as + '>' + _renderCell(c.key, it, now) + '</td>';
            });
            html += '</tr>';
        });
        html += '</tbody></table>';
        listScrollEl.innerHTML = html;
        listScrollEl.querySelectorAll('tr[data-instance-id]').forEach(function(row) {
            row.addEventListener('click', function() {
                openDetail(Number(row.getAttribute('data-instance-id')));
            });
        });
    }

    async function openDetail(instanceId) {
        currentInstanceId = instanceId;
        backdropEl.classList.add('show');
        modalBodyEl.innerHTML = '<div style="text-align:center;padding:30px;color:#94a3b8;">Yükleniyor…</div>';
        modalTitleEl.textContent = 'Belge Detayı';
        modalSubEl.textContent = '';
        // Tamamlananlar modunda aksiyon butonlarını gizle
        if (_currentMode === 'completed') {
            modalApproveEl.style.display = 'none';
            modalRejectEl.style.display  = 'none';
        } else {
            modalApproveEl.style.display = '';
            modalRejectEl.style.display  = '';
        }
        try {
            const scope = getScope();
            const ep = _currentMode === 'completed' ? '/PendingApproval/CompletedDetail' : '/PendingApproval/Detail';
            const resp = await fetch(ep + '?instanceId=' + instanceId + '&scope=' + encodeURIComponent(scope), { credentials: 'same-origin' });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            renderDetail(data.detail);
            renderChoiceArms(data.detail.choiceArms);
        } catch (err) {
            modalBodyEl.innerHTML = '<div style="color:#ef4444;padding:20px;">Hata: ' + escapeHtml(err.message) + '</div>';
        }
    }

    const STATUS_TR = {
        'Approved':  'Onaylandı',
        'Pending':   'Bekliyor',
        'Rejected':  'Reddedildi',
        'Waiting':   'Beklemede',
        'Skipped':   'Atlandı',
        'Cancelled': 'İptal Edildi',
    };
    const STATUS_CSS = {
        'Approved':  'sf-approved',
        'Pending':   'sf-pending',
        'Rejected':  'sf-rejected',
        'Waiting':   'sf-waiting',
        'Skipped':   'sf-waiting',
        'Cancelled': 'sf-rejected',
    };
    const STATUS_BADGE = {
        'Approved':  'badge-approved',
        'Pending':   'badge-pending',
        'Rejected':  'badge-rejected',
        'Waiting':   'badge-waiting',
        'Skipped':   'badge-waiting',
        'Cancelled': 'badge-rejected',
    };
    const STATUS_ICON = {
        'Approved':  '✓',
        'Pending':   '…',
        'Rejected':  '✕',
        'Waiting':   '○',
        'Skipped':   '–',
        'Cancelled': '✕',
    };

    function renderDetail(d) {
        const h = d.header;
        modalTitleEl.textContent = 'Belge: ' + (h.documentNumber || '—');
        modalSubEl.textContent = h.flowName + ' • Adım ' + h.stepPosition + ' / ' + h.totalSteps;

        let html = '<dl class="pa-detail-grid">' +
                   '<dt>Belge No</dt><dd>' + escapeHtml(h.documentNumber || '—') + '</dd>' +
                   '<dt>Tür</dt><dd>' + escapeHtml(h.documentTypeName || 'Belirsiz') + '</dd>' +
                   '<dt>Cari</dt><dd>' + escapeHtml(h.contactName || '—') + '</dd>' +
                   '<dt>Tutar</dt><dd>' + fmtMoney(h.grandTotal, h.currencyCode) + '</dd>' +
                   '</dl>';

        if (d.steps && d.steps.length > 0) {
            html += '<div class="pa-flow-section-title">Onay Süreci</div>';
            html += '<div class="pa-htl">';

            // İlk düğüm: belge oluşturma (daima tamamlanmış)
            html += '<div class="pa-htl-node sf-approved">' +
                    '<div class="pa-htl-spine">' +
                    '<div class="pa-htl-line"></div>' +
                    '<div class="pa-htl-dot">✓</div>' +
                    '<div class="pa-htl-line htl-done"></div>' +
                    '</div>' +
                    '<div class="pa-htl-card">' +
                    '<div class="pa-htl-name">Belge Oluşturma</div>' +
                    '<span class="pa-htl-badge badge-approved">Tamamlandı</span>' +
                    '<div class="pa-htl-times">' +
                    '<span><span class="pa-htl-time-lbl">Tarih:</span> ' + fmtDate(h.documentDate) + '</span>' +
                    '</div>' +
                    '</div>' +
                    '</div>';

            const instanceDone = h.instanceStatus === 'Approved' || h.instanceStatus === 'Rejected';
            const visibleSteps = d.steps.filter(s =>
                !instanceDone || s.status !== 'Pending' || s.actionDate != null
            );
            // Sıradaki aktif adım: visibleSteps içinde Pending durumundaki ilk adım
            const firstPendingIdx = visibleSteps.findIndex(s => (s.status || 'Waiting') === 'Pending');
            visibleSteps.forEach((s, idx) => {
                const status = s.status || 'Waiting';

                // Sırası gelmeyen Pending adımlar (birden fazla Pending varsa 2. ve sonrası)
                const isQueued  = status === 'Pending' && idx !== firstPendingIdx;
                const isCurrent = status === 'Pending' && idx === firstPendingIdx;

                // Görsel sınıf: sıradakiler için sf-waiting
                const cssClass = isQueued ? 'sf-waiting sf-queued' : (STATUS_CSS[status] || 'sf-waiting');
                const badge    = isQueued ? 'badge-waiting'        : (STATUS_BADGE[status] || 'badge-waiting');
                const icon     = isQueued ? '○'                    : (STATUS_ICON[status]  || '○');
                const labelTr  = isQueued ? 'Sırada'               : (STATUS_TR[status]    || status);

                // Giriş zamanı: yalnızca aktif veya tamamlanan adımlarda göster
                const hasStarted = status === 'Approved' || status === 'Rejected' || isCurrent;
                const entryTime = hasStarted
                    ? (idx === 0
                        ? (h.instanceStarted || s.enteredAt)
                        : (visibleSteps[idx - 1].actionDate || h.instanceStarted))
                    : null;

                // Sol bağlantı çizgisi: önceki düğüm tamamlandıysa yeşil
                const lineBeforeDone = idx === 0 || visibleSteps[idx - 1].status === 'Approved';
                // Sağ bağlantı çizgisi: bu adım tamamlandıysa yeşil
                const lineAfterDone  = status === 'Approved';

                html += '<div class="pa-htl-node ' + cssClass + (isCurrent ? ' sf-current' : '') + '">' +
                        '<div class="pa-htl-spine">' +
                        '<div class="pa-htl-line' + (lineBeforeDone ? ' htl-done' : '') + '"></div>' +
                        '<div class="pa-htl-dot">' + icon + '</div>' +
                        '<div class="pa-htl-line' + (lineAfterDone ? ' htl-done' : '') + '"></div>' +
                        '</div>' +
                        '<div class="pa-htl-card">' +
                        '<div class="pa-htl-name">' + escapeHtml(s.stepName || ('Adım ' + (idx + 1))) + '</div>' +
                        '<span class="pa-htl-badge ' + badge + '">' + labelTr + '</span>' +
                        (s.approverName ? '<div class="pa-htl-approver">' + escapeHtml(s.approverName) + '</div>' : '') +
                        (entryTime || s.actionDate
                            ? '<div class="pa-htl-times">' +
                              (entryTime ? '<span><span class="pa-htl-time-lbl">G:</span> ' + fmtDate(entryTime) + '</span>' : '') +
                              (s.actionDate ? '<span><span class="pa-htl-time-lbl">Ç:</span> ' + fmtDate(s.actionDate) + '</span>' : '') +
                              '</div>'
                            : '') +
                        (s.note ? '<div class="pa-htl-note">' + escapeHtml(s.note) + '</div>' : '') +
                        '</div>' +
                        '</div>';
            });
            html += '</div>';
        }

        modalBodyEl.innerHTML = html;
    }

    function renderChoiceArms(arms) {
        _currentChoiceArmId = null;
        if (!choiceArmsEl) return;
        choiceArmsEl.innerHTML = '';
        if (_currentMode === 'completed' || !arms || arms.length === 0) {
            modalApproveEl.style.display = _currentMode === 'completed' ? 'none' : '';
            modalRejectEl.style.display  = _currentMode === 'completed' ? 'none' : '';
            return;
        }
        // Çoklu seçim: Onayla + Reddet korunur, özel kollar ek seçenek olarak eklenir
        modalRejectEl.style.display = '';
        modalApproveEl.style.display = '';
        arms.forEach(function (a) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'pa-btn pa-btn-route';
            btn.textContent = a.label;
            btn.addEventListener('click', function () {
                _currentChoiceArmId = a.armId;
                showNotePanel('approve', a.label);
            });
            choiceArmsEl.appendChild(btn);
        });
    }

    function closeModal() {
        backdropEl.classList.remove('show');
        currentInstanceId = null;
        hideNotePanel();
    }

    function showNotePanel(action, actionLabel) {
        _noteAction = action;
        notePanelEl.className = 'pa-note-panel pa-note-panel--' + action;
        noteTextEl.value = '';
        if (action === 'approve') {
            var lbl = actionLabel || 'Onayla';
            noteLabelEl.textContent = lbl + ' — Not (opsiyonel)';
            noteTextEl.placeholder = 'Onay notu eklemek isterseniz girin…';
            noteSubmitEl.className = 'pa-btn pa-btn-primary';
            noteSubmitEl.textContent = lbl;
        } else {
            noteLabelEl.textContent = 'Ret Gerekçesi';
            noteTextEl.placeholder = 'Ret gerekçesini girin…';
            noteSubmitEl.className = 'pa-btn pa-btn-danger';
            noteSubmitEl.textContent = 'Reddet';
        }
        notePanelEl.style.display = '';
        modalFooterEl.style.display = 'none';
        noteTextEl.focus();
    }

    function hideNotePanel() {
        notePanelEl.style.display = 'none';
        modalFooterEl.style.display = '';
        _noteAction = null;
        _currentChoiceArmId = null;
    }

    async function submitNote() {
        if (!currentInstanceId || !_noteAction) return;
        const note = noteTextEl.value.trim();
        if (_noteAction === 'reject' && !note) {
            noteTextEl.focus();
            noteTextEl.style.borderColor = '#ef4444';
            setTimeout(() => { noteTextEl.style.borderColor = ''; }, 1500);
            return;
        }
        noteSubmitEl.disabled = true;
        try {
            const fd = new FormData();
            fd.set('instanceId', currentInstanceId);
            if (note) fd.set('note', note);
            if (_noteAction === 'approve' && _currentChoiceArmId) fd.set('choiceArmId', _currentChoiceArmId);
            const url = _noteAction === 'approve' ? '/Approval/ApproveStep' : '/Approval/RejectApproval';
            const resp = await fetch(url, {
                method: 'POST', credentials: 'same-origin',
                headers: { 'RequestVerificationToken': csrf() },
                body: fd,
            });
            const data = await resp.json();
            if (!data.ok) throw new Error(data.error || 'Hata');
            closeModal();
            await loadGroups();
        } catch (err) {
            const prefix = _noteAction === 'approve' ? 'Onaylama' : 'Reddetme';
            // inline hata — note label altında kırmızı metin
            noteLabelEl.innerHTML = noteLabelEl.textContent
                + `<span style="color:#ef4444;font-weight:400;margin-left:8px;">${prefix} hatası: ${err.message}</span>`;
        } finally {
            noteSubmitEl.disabled = false;
        }
    }

    function approveCurrent() { if (currentInstanceId) showNotePanel('approve'); }
    function rejectCurrent()  { if (currentInstanceId) showNotePanel('reject');  }

    document.getElementById('paScopeGroup')?.addEventListener('change', function() {
        activeDocTypeId = null; loadGroups();
    });

    // Arama
    let _searchQuery = '';
    const searchEl = document.getElementById('paSearch');
    if (searchEl) {
        searchEl.addEventListener('input', function() {
            _searchQuery = searchEl.value.trim().toLowerCase();
            if (_lastItems) renderList(_lastItems);
        });
    }

    function _filterItems(items) {
        if (!_searchQuery) return items;
        return items.filter(function(it) {
            return (it.documentNumber  || '').toLowerCase().includes(_searchQuery) ||
                   (it.flowName        || '').toLowerCase().includes(_searchQuery) ||
                   (it.documentTypeName|| '').toLowerCase().includes(_searchQuery) ||
                   (it.contactName     || '').toLowerCase().includes(_searchQuery) ||
                   (it.approverName    || '').toLowerCase().includes(_searchQuery) ||
                   (it.stepName        || '').toLowerCase().includes(_searchQuery);
        });
    }
    if (modalCloseEl)  modalCloseEl.addEventListener('click', closeModal);
    if (modalCancelEl) modalCancelEl.addEventListener('click', closeModal);
    if (backdropEl)    backdropEl.addEventListener('click', e => { if (e.target === backdropEl) closeModal(); });
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && backdropEl?.classList.contains('show')) {
            if (_noteAction) hideNotePanel(); else closeModal();
        }
        if (e.key === 'Enter' && e.ctrlKey && _noteAction) submitNote();
    });
    if (modalApproveEl) modalApproveEl.addEventListener('click', approveCurrent);
    if (modalRejectEl)  modalRejectEl.addEventListener('click', rejectCurrent);
    if (noteSubmitEl)   noteSubmitEl.addEventListener('click', submitNote);
    if (noteCancelEl)   noteCancelEl.addEventListener('click', hideNotePanel);

    // ── Kenar çubuğu toggle ─────────────────────────────────────────────────
    (function() {
        var sidebar = document.getElementById('paSidebar');
        var toggleBtn = document.getElementById('paSidebarToggle');
        var SIDEBAR_KEY = 'pa-sidebar-collapsed';
        if (sidebar && localStorage.getItem(SIDEBAR_KEY) === '1') {
            sidebar.classList.add('collapsed');
            if (toggleBtn) toggleBtn.classList.add('collapsed');
        }
    })();

    window.paSetMode = function(mode) {
        if (_currentMode === mode) return;
        _currentMode = mode;
        document.querySelectorAll('.pa-mode-tab').forEach(function(btn) {
            btn.classList.toggle('active', btn.getAttribute('data-mode') === mode);
        });
        // Başlık sütununu mode'a göre güncelle
        var dtDef = DEFAULT_DEFS.find(function(d) { return d.key === 'dt'; });
        if (dtDef) dtDef.label = mode === 'completed' ? 'Tamamlanma' : 'Bekliyor';
        activeDocTypeId = null;
        listTitleEl.textContent = 'Tüm belge türleri';
        listCountEl.textContent = '';
        loadGroups();
    };

    window.paToggleSidebar = function() {
        var sidebar = document.getElementById('paSidebar');
        var toggleBtn = document.getElementById('paSidebarToggle');
        if (!sidebar) return;
        var isCollapsed = sidebar.classList.toggle('collapsed');
        if (toggleBtn) toggleBtn.classList.toggle('collapsed', isCollapsed);
        try { localStorage.setItem('pa-sidebar-collapsed', isCollapsed ? '1' : '0'); } catch(e) {}
    };

    window.paToggleColPanel = function(e) {
        e.stopPropagation();
        var panel = document.getElementById('paColPanel');
        var btn   = document.getElementById('paColBtn');
        if (!panel) return;
        var isOpen = panel.classList.contains('open');
        if (!isOpen) {
            _renderColPanel();
            var rect = btn ? btn.getBoundingClientRect() : { right: 0, bottom: 0 };
            panel.style.top  = (rect.bottom + 4) + 'px';
            panel.style.left = Math.max(4, rect.right - 300) + 'px';
        }
        panel.classList.toggle('open', !isOpen);
        if (btn) btn.classList.toggle('active', !isOpen);
    };

    document.addEventListener('click', function(e) {
        var panel = document.getElementById('paColPanel');
        if (panel && panel.classList.contains('open') && !panel.contains(e.target)) {
            panel.classList.remove('open');
            var btn = document.getElementById('paColBtn');
            if (btn) btn.classList.remove('active');
        }
    });

    // Kullanıcı bazlı sütun config'ini sunucudan yükle, ardından grupları çek
    try {
        const cfgResp = await fetch('/PendingApproval/GetColConfig', { credentials: 'same-origin' });
        const cfgData = await cfgResp.json();
        if (cfgData && cfgData.config) {
            _applyServerConfig(cfgData.config);
            // Sunucu config'i localStorage'a da yaz (soğuk yükleme için cache)
            try { localStorage.setItem(COL_STORAGE_KEY, cfgData.config); } catch(e) {}
        }
    } catch(e) { /* sunucuya ulaşılamazsa localStorage ile devam */ }

    loadGroups();
})();
</script>
}
