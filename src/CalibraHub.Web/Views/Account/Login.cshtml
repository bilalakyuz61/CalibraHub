@using System.Text.Json
@model CalibraHub.Web.Models.Account.LoginInputModel
@inject CalibraHub.Web.Infrastructure.Ui.IUiTextService UiText
@{
    Layout = null;
    var runtime = await UiText.GetRuntimeAsync();
    var ui = await UiText.GetFormAsync("account.login");
}
<!DOCTYPE html>
<html lang="@runtime.LanguageCode">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ui.Text("title") - CalibraHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ── Login sayfasi tema toggle butonu (sag ust) ─────────────── */
        .login-theme-toggle {
            position: fixed; top: 16px; right: 18px; z-index: 1050;
            width: 38px; height: 38px;
            border: 1px solid rgba(148, 163, 184, 0.32);
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.85);
            color: #475569;
            cursor: pointer;
            display: inline-flex; align-items: center; justify-content: center;
            transition: background-color .18s, color .18s, border-color .18s, transform .18s;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        .login-theme-toggle:hover { transform: scale(1.08); background: rgba(241, 245, 249, 0.95); }
        .login-theme-toggle .icon-sun  { display: none;  }
        .login-theme-toggle .icon-moon { display: block; }
        body.app-theme-dark .login-theme-toggle {
            background: rgba(15, 23, 42, 0.72);
            border-color: rgba(148, 163, 184, 0.30);
            color: #e2e8f0;
        }
        body.app-theme-dark .login-theme-toggle:hover { background: rgba(30, 41, 59, 0.95); }
        body.app-theme-dark .login-theme-toggle .icon-sun  { display: block; }
        body.app-theme-dark .login-theme-toggle .icon-moon { display: none;  }

        /* ── Dark tema overrides — login sayfasi icin ───────────────── */
        body.app-theme-dark.login-page {
            background: #0a0d17 !important;
        }
        body.app-theme-dark .login-panel {
            background: linear-gradient(145deg, #0f172a, #0a0d17) !important;
        }
        body.app-theme-dark .login-hero {
            background: #0a0d17;
        }
        body.app-theme-dark .login-hero img {
            filter: saturate(1.05) brightness(0.92);
        }
        body.app-theme-dark .login-card {
            background: rgba(15, 23, 42, 0.88) !important;
            border: 1px solid rgba(148, 163, 184, 0.14) !important;
            box-shadow: 0 18px 48px rgba(0, 0, 0, 0.55) !important;
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card h1 { color: #f1f5f9 !important; }
        body.app-theme-dark .login-card .form-label,
        body.app-theme-dark .login-card label,
        body.app-theme-dark .login-field > label {
            color: #94a3b8 !important;
        }
        body.app-theme-dark .login-card .form-control,
        body.app-theme-dark .login-card .form-select,
        body.app-theme-dark .login-field .form-control,
        body.app-theme-dark .login-field .form-select {
            background-color: rgba(30, 41, 59, 0.65) !important;
            border-color: rgba(148, 163, 184, 0.22) !important;
            color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card .form-control:focus,
        body.app-theme-dark .login-card .form-select:focus {
            border-color: #6366f1 !important;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.18) !important;
        }
        body.app-theme-dark .login-card .form-select option {
            background: #0c0f1a; color: #e2e8f0;
        }
        body.app-theme-dark .login-card .btn-primary {
            background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
            border: none !important;
        }
        body.app-theme-dark .login-remember-label { color: #cbd5e1 !important; }
        body.app-theme-dark .login-card .text-muted { color: #94a3b8 !important; }
        body.app-theme-dark .login-card .border-top { border-color: rgba(148, 163, 184, 0.18) !important; }

        .login-error-msg {
            min-height: 46px;
            margin-bottom: 12px;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: .875rem;
            font-weight: 500;
            background: rgba(239,68,68,.10);
            border: 1px solid rgba(239,68,68,.35);
            color: #dc2626;
            display: flex;
            align-items: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .18s;
        }
        .login-error-msg.is-visible {
            opacity: 1;
            pointer-events: auto;
        }
        body.app-theme-dark .login-error-msg {
            background: rgba(239,68,68,.14);
            border-color: rgba(248,113,113,.35);
            color: #f87171;
        }

        @@keyframes loginShake {
            0%, 100% { transform: translateX(0); }
            15%  { transform: translateX(-7px); }
            30%  { transform: translateX(7px); }
            45%  { transform: translateX(-5px); }
            60%  { transform: translateX(5px); }
            75%  { transform: translateX(-2px); }
        }
        .login-pw-error .form-control {
            border-color: #ef4444 !important;
            box-shadow: 0 0 0 3px rgba(239,68,68,.18) !important;
        }
        body.app-theme-dark .login-pw-error .form-control {
            border-color: #f87171 !important;
            box-shadow: 0 0 0 3px rgba(248,113,113,.18) !important;
        }
        .login-pw-shake {
            animation: loginShake .42s cubic-bezier(.36,.07,.19,.97) both;
        }

        /* ── Kimlik kalibrasyon kadranı v2 — 3 katmanlı harf-bulmacalı kilit ──
           CALIBRAHUB'ın 10 harfi (decoy YOK) üç yarı-saydam katmanda AYNI merkez +
           AYNI yarıçapta üst üste (superimposed, konsantrik DEĞİL) çizilir. Katmanlar
           hizasızken 12°'lik adımlarla örülü/serpiştirilmiş durur — üç renk (indigo/
           cyan/violet) açıkça ayrı katmanlar olarak okunur, harfler tam üst üste
           binmez (bkz. LAYERS residue yorumu). Şifre karakteri yazıldıkça bir
           katman bir adım döner (döngüsel: 1.→L1, 2.→L2, 3.→L3, 4.→L1…), silme geri
           sarar. Çözülme YALNIZ sunucu login onayında (server-truth) tetiklenir —
           client parola doğrulamaz; matematiksel olarak yazarak hizalanmak imkansızdır
           (bkz. Login.cshtml script yorumu). Renk paleti v1 ibre-kadranından (indigo/
           cyan/violet + emerald/rose) bilinçli olarak korundu; mobil (Compose Canvas)
           ile birebir aynı kanonik tasarım. */
        .cald-wrap {
            width: 148px; margin: 2px auto 20px; position: relative;
            color-scheme: light;
            --cald-glass-a: rgba(255,255,255,.95);
            --cald-glass-b: rgba(148,163,184,.18);
            --cald-ring: rgba(148,163,184,.30);
            --cald-l1: #4f46e5;   /* indigo — 1. katman */
            --cald-l2: #0891b2;   /* cyan   — 2. katman */
            --cald-l3: #7c3aed;   /* violet — 3. katman */
            --cald-hub: #4f46e5;
            --cald-success: #059669;
            --cald-danger: #e11d48;
            --cald-status: #64748b;
        }
        body.app-theme-dark .cald-wrap {
            color-scheme: dark;
            --cald-glass-a: rgba(148,163,184,.16);
            --cald-glass-b: rgba(2,6,23,.35);
            --cald-ring: rgba(148,163,184,.22);
            --cald-l1: #818cf8;
            --cald-l2: #22d3ee;
            --cald-l3: #a78bfa;
            --cald-hub: #818cf8;
            --cald-success: #34d399;
            --cald-danger: #fb7185;
            --cald-status: #94a3b8;
        }
        .cald-stage {
            position: relative; width: 148px; height: 148px; margin: 0 auto; border-radius: 50%; overflow: hidden;
            background:
                radial-gradient(118% 118% at 30% 22%, var(--cald-glass-a), rgba(226,232,240,.06) 56%, var(--cald-glass-b) 100%),
                radial-gradient(90% 90% at 50% 128%, rgba(99,102,241,.14), transparent 62%);
            box-shadow:
                inset 0 2px 6px rgba(255,255,255,.9),
                inset 0 -12px 24px rgba(79,70,229,.12),
                inset 0 0 0 1px var(--cald-ring),
                0 14px 28px -12px rgba(30,41,59,.36),
                0 4px 12px -6px rgba(99,102,241,.3);
            transition: box-shadow .5s ease;
        }
        body.app-theme-dark .cald-stage {
            box-shadow:
                inset 0 2px 6px rgba(226,232,240,.24),
                inset 0 -12px 26px rgba(2,6,23,.58),
                inset 0 0 0 1px var(--cald-ring),
                0 18px 34px -14px rgba(0,0,0,.66),
                0 4px 14px -6px rgba(139,92,246,.36);
        }
        .cald-wrap.is-solved .cald-stage {
            box-shadow:
                inset 0 2px 6px rgba(255,255,255,.9), inset 0 -12px 24px rgba(16,185,129,.16),
                inset 0 0 0 1px rgba(52,211,153,.5),
                0 14px 28px -12px rgba(30,41,59,.36), 0 0 0 4px rgba(52,211,153,.16), 0 0 22px rgba(52,211,153,.42);
        }
        body.app-theme-dark .cald-wrap.is-solved .cald-stage {
            box-shadow:
                inset 0 2px 6px rgba(226,232,240,.24), inset 0 -12px 26px rgba(2,6,23,.58),
                inset 0 0 0 1px rgba(52,211,153,.5),
                0 18px 34px -14px rgba(0,0,0,.66), 0 0 0 4px rgba(16,185,129,.2), 0 0 24px rgba(16,185,129,.5);
        }
        .cald-wrap.is-fail .cald-stage {
            box-shadow:
                inset 0 2px 6px rgba(255,255,255,.9), inset 0 -12px 24px rgba(244,63,94,.16),
                inset 0 0 0 1px rgba(251,113,133,.5),
                0 14px 28px -12px rgba(30,41,59,.36), 0 0 0 4px rgba(251,113,133,.16), 0 0 22px rgba(244,63,94,.42);
        }
        body.app-theme-dark .cald-wrap.is-fail .cald-stage {
            box-shadow:
                inset 0 2px 6px rgba(226,232,240,.24), inset 0 -12px 26px rgba(2,6,23,.58),
                inset 0 0 0 1px rgba(251,113,133,.5),
                0 18px 34px -14px rgba(0,0,0,.66), 0 0 0 4px rgba(244,63,94,.2), 0 0 24px rgba(244,63,94,.5);
        }
        .cald-wrap.is-measuring .cald-stage { animation: caldPulse 1.1s ease-in-out infinite; }
        .cald-svg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; display: block; }
        .cald-track { fill: none; stroke: var(--cald-ring); stroke-width: 1.4; }
        /* Harf katmanları — üçü de AYNI 10 harfi (CALIBRAHUB, decoy yok) AYNI yarıçapta
           çizer; fill/opacity katman <g>'sinde tanımlı, <text> çocukları miras alır. */
        .cald-letter {
            font-family: ui-monospace, Menlo, Consolas, monospace;
            font-size: 16px; font-weight: 700;
        }
        .cald-layer-1, .cald-layer-2, .cald-layer-3 { transition: fill .35s ease, opacity .35s ease; }
        .cald-layer-1 { fill: var(--cald-l1); opacity: .60; }
        .cald-layer-2 { fill: var(--cald-l2); opacity: .60; }
        .cald-layer-3 { fill: var(--cald-l3); opacity: .60; }
        .cald-wrap.is-solved .cald-layer-1,
        .cald-wrap.is-solved .cald-layer-2,
        .cald-wrap.is-solved .cald-layer-3 { fill: var(--cald-success); opacity: 1; }
        .cald-wrap.is-fail .cald-layer-1,
        .cald-wrap.is-fail .cald-layer-2,
        .cald-wrap.is-fail .cald-layer-3 { fill: var(--cald-danger); opacity: .82; }
        .cald-hub { fill: var(--cald-hub); transition: fill .3s ease; }
        .cald-wrap.is-solved .cald-hub { fill: var(--cald-success); }
        .cald-wrap.is-fail .cald-hub { fill: var(--cald-danger); }
        .cald-check {
            fill: none; stroke: var(--cald-success); stroke-width: 3.4; stroke-linecap: round; stroke-linejoin: round;
            opacity: 0; transform: scale(.4); transform-origin: 100px 100px;
            transition: opacity .3s, transform .35s cubic-bezier(.34,1.56,.5,1);
        }
        .cald-wrap.is-solved .cald-check { opacity: 1; transform: scale(1); }
        .cald-status {
            margin-top: 16px; text-align: center; font-size: .86rem; font-weight: 600;
            min-height: 1.2em; white-space: nowrap; color: var(--cald-status); transition: color .3s;
        }
        .cald-wrap.is-measuring .cald-status { color: var(--cald-l1); }
        .cald-wrap.is-solved .cald-status { color: var(--cald-success); }
        .cald-wrap.is-fail .cald-status { color: var(--cald-danger); }
        @@keyframes caldPulse { 0%, 100% { filter: brightness(1); } 50% { filter: brightness(1.14); } }
        @@keyframes caldShake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-7px)} 40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(3px)} }
        .cald-wrap.cald-shake .cald-stage { animation: caldShake .5s ease; }
        @@media (prefers-reduced-motion: reduce) {
            .cald-check, .cald-layer-1, .cald-layer-2, .cald-layer-3, .cald-stage { transition: none; }
            .cald-wrap.cald-shake .cald-stage { animation: none; }
            .cald-wrap.is-measuring .cald-stage { animation: none; }
        }
    </style>
</head>
<body class="login-page app-theme-@runtime.ThemeCode"
      data-reset-workspace-tabs="1">
<!-- Tema toggle — sag ust kose -->
<button type="button" id="btnThemeToggle" class="login-theme-toggle" title="Tema değiştir" aria-label="Tema değiştir">
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
    </svg>
</button>
<script>
    (function () {
        var TK = 'calibra_theme';
        var body = document.body;
        var btn  = document.getElementById('btnThemeToggle');
        var themeInput = document.getElementById('loginThemeInput');
        var form = document.getElementById('loginForm');

        // localStorage tercihini hem UI'a hem hidden input'a uygula
        function applyTheme(t) {
            body.classList.remove('app-theme-light', 'app-theme-dark');
            body.classList.add('app-theme-' + t);
            if (themeInput) themeInput.value = t;
            try { localStorage.setItem(TK, t); } catch (e) {}
        }

        var saved = null;
        try { saved = localStorage.getItem(TK); } catch (e) {}
        if (saved === 'dark' || saved === 'light') { applyTheme(saved); }
        else if (themeInput) { themeInput.value = body.classList.contains('app-theme-dark') ? 'dark' : 'light'; }

        function currentTheme() {
            return body.classList.contains('app-theme-dark') ? 'dark' : 'light';
        }
        btn.addEventListener('click', function () {
            applyTheme(currentTheme() === 'dark' ? 'light' : 'dark');
        });
    })();
</script>
<div class="login-shell">
    <section class="login-hero" aria-hidden="true">
        @* CalibraHub Software marka görseli. Frame overflow:hidden + img object-fit:cover
           ile panel tamamen kaplanır, sağ-alt sparkle filigranı doğal olarak kırpılır. *@
        <div class="login-hero-frame">
            <img src="~/Document/CalibraHubLoginLogo.png" alt="CalibraHub Software" />
        </div>
    </section>

    <section class="login-panel">
        <div class="login-card">
            <h1>CalibraHub</h1>

            @* Kimlik kalibrasyon kadranı v2 — 3 katmanlı harf-bulmacalı kilit (CALIBRAHUB,
               decoy yok). Şifre karakterine bağlı katman rotasyonu + sunucu onayına bağlı
               çözülme mantığı sayfa sonundaki script'te (window.CalibraLoginDial). *@
            <div class="cald-wrap" id="caldDial">
                <div class="cald-stage" id="caldStage" aria-hidden="true">
                    <svg class="cald-svg" viewBox="0 0 200 200">
                        <circle class="cald-track" cx="100" cy="100" r="90" />
                        <g class="cald-layer-1" id="caldLayer1"></g>
                        <g class="cald-layer-2" id="caldLayer2"></g>
                        <g class="cald-layer-3" id="caldLayer3"></g>
                        <path class="cald-check" d="M91 101 l6 6 12 -13" />
                        <circle class="cald-hub" cx="100" cy="100" r="4" />
                    </svg>
                </div>
                <div class="cald-status" id="caldStatus">Giriş yapmaya hazır</div>
            </div>

            <form asp-action="Login" method="post" autocomplete="off" id="loginForm">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />
                <input type="hidden" name="ThemeCode" id="loginThemeInput" value="" />

                <div class="form-floating login-field mb-3">
                    @* a11y (rapor §6.6): autofocus + required + aria-required + class="cb-field-error" *@
                    <input asp-for="Email" class="form-control" autocomplete="email"
                           placeholder=" " autofocus required aria-required="true" />
                    <label asp-for="Email" class="cb-field-required">@ui.Text("email")</label>
                    <span asp-validation-for="Email" class="cb-field-error"></span>
                </div>

                <div class="form-floating login-field mb-3">
                    <select asp-for="CompanyId" asp-items="Model.CompanyOptions" class="form-select">
                        <option value="">@ui.Text("company_placeholder")</option>
                    </select>
                    <label asp-for="CompanyId">@ui.Text("company")</label>
                    <span asp-validation-for="CompanyId"></span>
                </div>

                <div class="form-floating login-field mb-3">
                    <input asp-for="Password" type="password" class="form-control"
                           autocomplete="current-password" placeholder=" " required aria-required="true" />
                    <label asp-for="Password" class="cb-field-required">@ui.Text("password")</label>
                    <span asp-validation-for="Password" class="cb-field-error"></span>
                </div>

                <div class="login-remember-row mb-3">
                    <label class="login-switch" for="rememberToggle">
                        <input type="checkbox" id="rememberToggle" />
                        <span class="login-switch-track"></span>
                    </label>
                    <span class="login-remember-label">Beni hatırla</span>
                </div>

                <button type="submit" class="btn btn-primary w-100">@ui.Text("submit")</button>

                <div class="text-center mt-3">
                    <a href="@Url.Action("ForgotPassword", "Account")" class="text-muted small"
                       style="text-decoration:none;opacity:.75;transition:opacity .15s"
                       onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='.75'">
                        Şifremi Unuttum
                    </a>
                </div>
            </form>

            @if (ViewBag.ShowSetupLink == true)
            {
                <div class="mt-4 pt-3 border-top text-center">
                    <p class="text-muted small mb-2">Sistemde henüz şirket tanımlanmamış.</p>
                    <a href="/Gate" class="btn btn-outline-secondary btn-sm">
                        İlk Kurulumu Yap
                    </a>
                </div>
            }


        </div>
    </section>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (function () {
        const companyPlaceholderText = @Html.Raw(JsonSerializer.Serialize(ui.Text("company_placeholder")));
        const emailInput = document.getElementById("Email");
        const companySelect = document.getElementById("CompanyId");
        if (!emailInput || !companySelect) {
            return;
        }

        const endpoint = '@Url.Action("CompaniesForUser", "Account")';

        function renderCompanies(items) {
            const currentValue = companySelect.value;
            companySelect.innerHTML = "";

            const placeholder = document.createElement("option");
            placeholder.value = "";
            placeholder.textContent = companyPlaceholderText;
            companySelect.appendChild(placeholder);

            let hasCurrent = false;
            items.forEach(function (item) {
                const option = document.createElement("option");
                option.value = item.id;
                option.textContent = item.name;
                if (item.id === currentValue) {
                    option.selected = true;
                    hasCurrent = true;
                }

                companySelect.appendChild(option);
            });

            if (!hasCurrent) {
                companySelect.value = "";
            }
        }

        async function loadCompanies() {
            const email = emailInput.value.trim();
            if (!email) {
                renderCompanies([]);
                return;
            }

            try {
                const response = await fetch(endpoint + "?email=" + encodeURIComponent(email), {
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                if (!response.ok) {
                    renderCompanies([]);
                    return;
                }

                const data = await response.json();
                renderCompanies(Array.isArray(data) ? data : []);
            } catch {
                renderCompanies([]);
            }
        }

        emailInput.addEventListener("blur", loadCompanies);
        emailInput.addEventListener("change", loadCompanies);

        if (emailInput.value.trim().length > 0) {
            loadCompanies();
        }

        // Beni hatırla switch
        var rememberToggle = document.getElementById("rememberToggle");
        var rememberLabel = document.querySelector(".login-remember-label");
        var remembered = localStorage.getItem("calibra_login_remember") === "1";

        if (rememberToggle) {
            rememberToggle.checked = remembered;

            // Önceki oturumdan hatırlanan bilgileri yükle
            if (remembered && !emailInput.value) {
                var savedEmail = localStorage.getItem("calibra_login_email");
                var savedCompany = localStorage.getItem("calibra_login_company");
                if (savedEmail) {
                    emailInput.value = savedEmail;
                    loadCompanies().then(function () {
                        if (savedCompany && companySelect) {
                            companySelect.value = savedCompany;
                        }
                    });
                }
            }

            if (rememberLabel) {
                rememberLabel.addEventListener("click", function () {
                    rememberToggle.checked = !rememberToggle.checked;
                });
            }
        }

        var loginForm = emailInput.closest("form");
        if (loginForm) {
            var pwInput = document.getElementById("Password");
            var pwWrap  = pwInput ? pwInput.closest(".login-field") : null;

            loginForm.addEventListener("submit", async function (e) {
                e.preventDefault();

                // Tema hidden input'u güncelle
                var themeInput = document.getElementById("loginThemeInput");
                if (themeInput) themeInput.value = document.body.classList.contains("app-theme-dark") ? "dark" : "light";

                // Beni hatırla
                if (rememberToggle && rememberToggle.checked) {
                    localStorage.setItem("calibra_login_remember", "1");
                    localStorage.setItem("calibra_login_email", emailInput.value.trim());
                    if (companySelect.value) localStorage.setItem("calibra_login_company", companySelect.value);
                } else {
                    localStorage.removeItem("calibra_login_remember");
                    localStorage.removeItem("calibra_login_email");
                    localStorage.removeItem("calibra_login_company");
                }

                // Kilit bulmacası: sunucu doğrulaması başladı
                if (window.CalibraLoginDial) window.CalibraLoginDial.begin();

                // AJAX submit
                try {
                    var resp = await fetch(loginForm.action || window.location.href, {
                        method: "POST",
                        body: new FormData(loginForm),
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });
                    var json = await resp.json();

                    if (json.ok) {
                        // Doğru giriş — katmanlar ortak faza oturup CALIBRAHUB'ı hizalar (yeşil), sonra login
                        if (window.CalibraLoginDial) window.CalibraLoginDial.success(function () { window.location.href = json.redirect; });
                        else window.location.href = json.redirect;
                        return;
                    }

                    // Giriş başarısız — kadran hizasız kalır + shake + kırmızı flaş (kanonik v2 spec)
                    if (json.error === "locked") {
                        if (window.CalibraLoginDial) window.CalibraLoginDial.fail('Hesap kilitli');
                        if (pwInput) {
                            pwInput.value = "";
                            pwInput.disabled = true;
                            setTimeout(function () { pwInput.disabled = false; }, 5000);
                        }
                    } else if (json.error === "validation") {
                        if (window.CalibraLoginDial) window.CalibraLoginDial.fail('Alanları doldurun');
                    } else {   // credentials
                        var rem = (typeof json.remaining === "number") ? json.remaining : -1;
                        var det = rem > 0 ? ("Şifreniz hatalı, " + rem + " deneme kaldı") : "Şifreniz hatalı";
                        if (window.CalibraLoginDial) window.CalibraLoginDial.fail("Giriş başarısız", det);
                        if (pwInput) { pwInput.value = ""; pwInput.focus(); }
                    }
                } catch {
                    // Network hatası: normal submit
                    loginForm.submit();
                }
            });
        }
    })();
</script>
<script>
    /* ── Kimlik kalibrasyon kadranı v2 — 3 katmanlı harf-bulmacalı kilit ──
       CALIBRAHUB'ın 10 harfi (decoy YOK) üç yarı-saydam katmanda AYNI merkez + AYNI
       yarıçapta üst üste (superimposed) döner. Hizasızken üç katman 12°'lik adımlarla
       ÖRÜLÜ (braided) durur — her katmanın harfi kendi rengiyle ayrı bir açısal
       noktada görünür, üç kopya birbirinin TAM üzerine binmez (bkz. LAYERS residue
       yorumu altta). Şifre her karakterinde bir katman bir adım döner (döngüsel:
       1.→L1, 2.→L2, 3.→L3, 4.→L1…), silme geri sarar (adım sayısı doğrudan parola
       uzunluğundan türetilir, tuş yönünden bağımsızdır).

       Matematiksel imkansızlık garantisi: her katmanın taban ofseti (base) 36°'nin
       (SLOT_DEG) TAM katı DEĞİLDİR ve üç katmanın da 36'ya göre kalanı (residue)
       BİRBİRİNDEN FARKLIDIR. Yazma adımları hep TAM slot (36°) eklediğinden bir
       katmanın "mod 36" kalanı yazarak asla değişmez — dolayısıyla iki katman
       ASLA aynı mutlak açıya (mod 360) gelemez (aynı açı için aynı "mod 36" kalanı
       şart, üçü de farklı olduğundan bu yapısal olarak imkansızdır). Hizalanma
       yalnız Solved animasyonuyla (her katman kendi en yakın 360° katına
       programatik "snap" eder — 360° her zaman ≡0 mod 36 olduğundan üç katman da
       AYNI görünüme oturur) gerçekleşir. Yani doğru şifre yazarak CALIBRAHUB'ı
       hizalamak yapısal olarak imkansızdır; çözülme YALNIZ sunucu login onayıyla
       (window.CalibraLoginDial.success) tetiklenir. */
    (function () {
        var dial = document.getElementById('caldDial');
        if (!dial) return;
        var statusEl = document.getElementById('caldStatus');
        var NS = 'http://www.w3.org/2000/svg';
        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        var LETTERS  = 'CALIBRAHUB'.split('');   // 10 harf, decoy YOK — üç katman da aynı dizilim
        var SLOTS    = LETTERS.length;
        var SLOT_DEG = 360 / SLOTS;              // 36°
        var RADIUS   = 68;

        // 3 katman: base'lerin 36'ya göre kalanı (residue) KASITLI olarak hem sıfırdan
        // hem birbirinden farklı: 6°, 18°, 30° — 36°'lik slot bandını 3'e eşit böler
        // (12°'lik adımlarla "örülü" görünüm — matematiksel olarak ulaşılabilecek en
        // geniş eşit ayrım). Kullanıcı geri bildirimi (2026-07-16): eski değerler
        // (18/-90/162) hepsi AYNI 18°'lik kalana sahipti → üç katman aynı 10 açısal
        // slotta tam üst üste biniyordu (yalnız hangi harfin göründüğü değişiyordu).
        // Farklı kalan hem daha güçlü bir "yazarak çözülemez" ispatı verir (üstteki
        // yorum) hem de idle'da üç katmanın açıkça ayrı/serpiştirilmiş durmasını
        // sağlar. dir yalnız kozmetik (hangi yöne "karıştığını" belirler).
        var LAYERS = [
            { base: 6,  dir: +1, id: 'caldLayer1' },
            { base: 18, dir: -1, id: 'caldLayer2' },
            { base: 30, dir: +1, id: 'caldLayer3' }
        ];

        var groups  = LAYERS.map(function (l) { return document.getElementById(l.id); });
        var ringDeg = LAYERS.map(function (l) { return l.base; });   // sürekli (unwrap) açı — hiç mod alınmaz
        var ringRaf = [null, null, null];

        // ── Katman inşası: her katmana aynı 10 harf (CALIBRAHUB) yerleştirilir ──
        groups.forEach(function (g) {
            LETTERS.forEach(function (ch) {
                var t = document.createElementNS(NS, 'text');
                t.setAttribute('text-anchor', 'middle');
                t.setAttribute('dominant-baseline', 'central');
                t.setAttribute('class', 'cald-letter');
                t.textContent = ch;
                g.appendChild(t);
            });
        });

        // Bir katmanın 10 harfini verilen mutlak açıda (deg) konumlandırır; her harf
        // kadran-numarası gibi teğetsel döner (mobil Compose Canvas ile aynı ilke).
        function placeLayer(r, deg) {
            var kids = groups[r].children;
            for (var i = 0; i < SLOTS; i++) {
                var a = -90 + i * SLOT_DEG + deg;
                var rad = a * Math.PI / 180;
                var x = 100 + RADIUS * Math.cos(rad);
                var y = 100 + RADIUS * Math.sin(rad);
                var el = kids[i];
                el.setAttribute('x', x.toFixed(2));
                el.setAttribute('y', y.toFixed(2));
                el.setAttribute('transform', 'rotate(' + (a + 90).toFixed(2) + ' ' + x.toFixed(2) + ' ' + y.toFixed(2) + ')');
            }
        }

        function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
        function easeOutBack(t) { var c1 = 1.70158, c3 = c1 + 1; return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2); }

        function cancelLayer(r) { if (ringRaf[r]) { cancelAnimationFrame(ringRaf[r]); ringRaf[r] = null; } }
        function animateLayer(r, target, durationMs, ease, onDone) {
            cancelLayer(r);
            if (reduce) { ringDeg[r] = target; placeLayer(r, target); if (onDone) onDone(); return; }
            var start = ringDeg[r], delta = target - start, t0 = null;
            function step(ts) {
                if (t0 === null) t0 = ts;
                var t = Math.min(1, (ts - t0) / durationMs);
                ringDeg[r] = start + delta * (ease ? ease(t) : t);
                placeLayer(r, ringDeg[r]);
                if (t < 1) { ringRaf[r] = requestAnimationFrame(step); }
                else { ringDeg[r] = target; placeLayer(r, target); ringRaf[r] = null; if (onDone) onDone(); }
            }
            ringRaf[r] = requestAnimationFrame(step);
        }

        // n. tuş vuruşu katmanları döngüsel gezer (1.→L1, 2.→L2, 3.→L3, 4.→L1…): [r]
        // katmanının parola [len] uzunluğundayken almış olduğu toplam adım sayısı.
        // Uzunluktan türetildiği için silme otomatik olarak aynı adımları geri sarar.
        function ringSteps(len, r) {
            if (len <= 0) return 0;
            var c = 0;
            for (var k = 1; k <= len; k++) { if ((k - 1) % 3 === r) c++; }
            return c;
        }
        function typingTarget(len, r) {
            var L = LAYERS[r];
            return L.base + L.dir * SLOT_DEG * ringSteps(len, r);
        }

        var mode = 'idle';   // idle | typing | measuring | solved | fail
        function setStatus(t) { if (statusEl) statusEl.textContent = t; }
        function setMode(m, cls) {
            mode = m;
            dial.classList.remove('is-measuring', 'is-solved', 'is-fail');
            if (cls) dial.classList.add(cls);
        }
        function toTyping(len) {
            for (var r = 0; r < 3; r++) animateLayer(r, typingTarget(len, r), 220, easeOutCubic);
        }

        // ── Şifre alanı: her karakter bir katmanı bir adım döndürür, silme geri sarar ──
        var pwEl = document.getElementById('Password');
        if (pwEl) {
            pwEl.addEventListener('input', function () {
                if (mode === 'measuring' || mode === 'solved') return;   // aktif akışla çakışma
                var len = pwEl.value.length;
                setMode(len > 0 ? 'typing' : 'idle');
                setStatus(len > 0 ? 'Şifre giriliyor…' : 'Giriş yapmaya hazır');
                toTyping(len);
            });
        }

        // ── Dış API — submit handler çağırır (bkz. loginForm AJAX submit script'i) ──
        window.CalibraLoginDial = {
            begin: function () {
                setMode('measuring', 'is-measuring');
                setStatus('Doğrulanıyor…');
                // Katmanlar mevcut (karışık) konumunda kalır — client parola doğrulamaz;
                // yalnız CSS nabzı (caldPulse) "işleniyor" hissi verir.
            },
            success: function (done) {
                setMode('solved', 'is-solved');
                setStatus('Giriş başarılı');
                // Kilit çözülüşü: katmanlar SIRAYLA en yakın ORTAK faza (360°'nin tam katı,
                // yani mod 360 ≡ 0) "klik" diye oturur — üçü de aynı faza geldiği için tam
                // örtüşür → tek net CALIBRAHUB + yeşil.
                LAYERS.forEach(function (l, r) {
                    setTimeout(function () {
                        var target = Math.round(ringDeg[r] / 360) * 360;
                        animateLayer(r, target, 560, easeOutBack);
                    }, r * 150);
                });
                setTimeout(function () { if (done) done(); }, 1300);
            },
            fail: function (label, detail) {
                setMode('fail', 'is-fail');
                setStatus(label || 'Giriş başarısız');
                dial.classList.remove('cald-shake');
                void dial.offsetWidth;   // reflow — animasyonu yeniden tetikler
                dial.classList.add('cald-shake');
                // Katmanlar kasıtlı olarak hareket ETTİRİLMEZ — "hizasız kalır" (spec).
                if (detail) setTimeout(function () { if (mode === 'fail') setStatus(detail); }, 900);
            }
        };

        // ── İlk render ──
        LAYERS.forEach(function (l, r) { placeLayer(r, ringDeg[r]); });

        // Tam-sayfa POST fallback'i (fetch/network istisnası) sunucu tarafında ModelState
        // hatasıyla yeniden render edildiyse kadran ilk açılışta hizasız/kırmızı başlar.
        var serverHadError = @(ViewData.ModelState.IsValid ? "false" : "true");
        if (serverHadError) window.CalibraLoginDial.fail('Giriş başarısız');
    })();
</script>
</body>
</html>

