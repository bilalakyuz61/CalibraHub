@using System.Text.Json
@model CalibraHub.Web.Models.Account.LoginInputModel
@inject CalibraHub.Web.Infrastructure.Ui.IUiTextService UiText
@{
    Layout = null;
    var runtime = await UiText.GetRuntimeAsync();
    var ui = await UiText.GetFormAsync("account.login");
}
<!DOCTYPE html>
<html lang="@runtime.LanguageCode">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ui.Text("title") - CalibraHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ── Login sayfasi tema toggle butonu (sag ust) ─────────────── */
        .login-theme-toggle {
            position: fixed; top: 16px; right: 18px; z-index: 1050;
            width: 38px; height: 38px;
            border: 1px solid rgba(148, 163, 184, 0.32);
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.85);
            color: #475569;
            cursor: pointer;
            display: inline-flex; align-items: center; justify-content: center;
            transition: background-color .18s, color .18s, border-color .18s, transform .18s;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        .login-theme-toggle:hover { transform: scale(1.08); background: rgba(241, 245, 249, 0.95); }
        .login-theme-toggle .icon-sun  { display: none;  }
        .login-theme-toggle .icon-moon { display: block; }
        body.app-theme-dark .login-theme-toggle {
            background: rgba(15, 23, 42, 0.72);
            border-color: rgba(148, 163, 184, 0.30);
            color: #e2e8f0;
        }
        body.app-theme-dark .login-theme-toggle:hover { background: rgba(30, 41, 59, 0.95); }
        body.app-theme-dark .login-theme-toggle .icon-sun  { display: block; }
        body.app-theme-dark .login-theme-toggle .icon-moon { display: none;  }

        /* ── Dark tema overrides — login sayfasi icin ───────────────── */
        body.app-theme-dark.login-page {
            background: #0a0d17 !important;
        }
        body.app-theme-dark .login-panel {
            background: linear-gradient(145deg, #0f172a, #0a0d17) !important;
        }
        body.app-theme-dark .login-hero {
            background: #0a0d17;
        }
        body.app-theme-dark .login-hero img {
            filter: saturate(1.05) brightness(0.92);
        }
        body.app-theme-dark .login-card {
            background: rgba(15, 23, 42, 0.88) !important;
            border: 1px solid rgba(148, 163, 184, 0.14) !important;
            box-shadow: 0 18px 48px rgba(0, 0, 0, 0.55) !important;
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card h1 { color: #f1f5f9 !important; }
        body.app-theme-dark .login-card .form-label,
        body.app-theme-dark .login-card label,
        body.app-theme-dark .login-field > label {
            color: #94a3b8 !important;
        }
        body.app-theme-dark .login-card .form-control,
        body.app-theme-dark .login-card .form-select,
        body.app-theme-dark .login-field .form-control,
        body.app-theme-dark .login-field .form-select {
            background-color: rgba(30, 41, 59, 0.65) !important;
            border-color: rgba(148, 163, 184, 0.22) !important;
            color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card .form-control:focus,
        body.app-theme-dark .login-card .form-select:focus {
            border-color: #6366f1 !important;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.18) !important;
        }
        body.app-theme-dark .login-card .form-select option {
            background: #0c0f1a; color: #e2e8f0;
        }
        body.app-theme-dark .login-card .btn-primary {
            background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
            border: none !important;
        }
        body.app-theme-dark .login-remember-label { color: #cbd5e1 !important; }
        body.app-theme-dark .login-card .text-muted { color: #94a3b8 !important; }
        body.app-theme-dark .login-card .border-top { border-color: rgba(148, 163, 184, 0.18) !important; }

        .login-error-msg {
            min-height: 46px;
            margin-bottom: 12px;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: .875rem;
            font-weight: 500;
            background: rgba(239,68,68,.10);
            border: 1px solid rgba(239,68,68,.35);
            color: #dc2626;
            display: flex;
            align-items: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .18s;
        }
        .login-error-msg.is-visible {
            opacity: 1;
            pointer-events: auto;
        }
        body.app-theme-dark .login-error-msg {
            background: rgba(239,68,68,.14);
            border-color: rgba(248,113,113,.35);
            color: #f87171;
        }

        @@keyframes loginShake {
            0%, 100% { transform: translateX(0); }
            15%  { transform: translateX(-7px); }
            30%  { transform: translateX(7px); }
            45%  { transform: translateX(-5px); }
            60%  { transform: translateX(5px); }
            75%  { transform: translateX(-2px); }
        }
        .login-pw-error .form-control {
            border-color: #ef4444 !important;
            box-shadow: 0 0 0 3px rgba(239,68,68,.18) !important;
        }
        body.app-theme-dark .login-pw-error .form-control {
            border-color: #f87171 !important;
            box-shadow: 0 0 0 3px rgba(248,113,113,.18) !important;
        }
        .login-pw-shake {
            animation: loginShake .42s cubic-bezier(.36,.07,.19,.97) both;
        }

        /* ── Kimlik kalibrasyon kadranı — girişe bağlı 3 ibreli enstrüman ──
           Alanları doldurdukça 3 ibre merkeze yaklaşır; doğru girişte kilitlenir
           (yeşil ✓), yanlışta saçılır (kırmızı). Kart temasına uyumlu. */
        .cal-dial { width: 148px; margin: 2px auto 20px; position: relative; }
        .cal-dial-glass {
            position: relative; width: 148px; height: 148px; margin: 0 auto; border-radius: 50%; overflow: hidden;
            background:
                radial-gradient(118% 118% at 30% 22%, #ffffff, rgba(255,255,255,.3) 30%, rgba(226,232,240,.06) 56%, rgba(148,163,184,.18) 100%),
                radial-gradient(90% 90% at 50% 128%, rgba(99,102,241,.16), transparent 62%);
            box-shadow:
                inset 0 2px 6px rgba(255,255,255,.9),
                inset 0 -12px 24px rgba(79,70,229,.12),
                inset 0 0 0 1px rgba(148,163,184,.26),
                0 14px 28px -12px rgba(30,41,59,.36),
                0 4px 12px -6px rgba(99,102,241,.3);
            transition: box-shadow .5s ease;
        }
        body.app-theme-dark .cal-dial-glass {
            background:
                radial-gradient(118% 118% at 30% 22%, rgba(148,163,184,.5), rgba(148,163,184,.12) 32%, rgba(15,23,42,.24) 60%, rgba(2,6,23,.52) 100%),
                radial-gradient(90% 90% at 50% 128%, rgba(139,92,246,.28), transparent 62%);
            box-shadow:
                inset 0 2px 6px rgba(226,232,240,.24),
                inset 0 -12px 26px rgba(2,6,23,.58),
                inset 0 0 0 1px rgba(148,163,184,.18),
                0 18px 34px -14px rgba(0,0,0,.66),
                0 4px 14px -6px rgba(139,92,246,.36);
        }
        .cal-dial.is-cal .cal-dial-glass {
            box-shadow:
                inset 0 2px 6px rgba(255,255,255,.9), inset 0 -12px 24px rgba(16,185,129,.16),
                inset 0 0 0 1px rgba(52,211,153,.5),
                0 14px 28px -12px rgba(30,41,59,.36), 0 0 0 4px rgba(52,211,153,.16), 0 0 22px rgba(52,211,153,.42);
        }
        body.app-theme-dark .cal-dial.is-cal .cal-dial-glass {
            box-shadow:
                inset 0 2px 6px rgba(226,232,240,.24), inset 0 -12px 26px rgba(2,6,23,.58),
                inset 0 0 0 1px rgba(52,211,153,.5),
                0 18px 34px -14px rgba(0,0,0,.66), 0 0 0 4px rgba(16,185,129,.2), 0 0 24px rgba(16,185,129,.5);
        }
        .cal-dial.is-fail .cal-dial-glass {
            box-shadow:
                inset 0 2px 6px rgba(255,255,255,.9), inset 0 -12px 24px rgba(244,63,94,.16),
                inset 0 0 0 1px rgba(251,113,133,.5),
                0 14px 28px -12px rgba(30,41,59,.36), 0 0 0 4px rgba(251,113,133,.16), 0 0 22px rgba(244,63,94,.42);
        }
        body.app-theme-dark .cal-dial.is-fail .cal-dial-glass {
            box-shadow:
                inset 0 2px 6px rgba(226,232,240,.24), inset 0 -12px 26px rgba(2,6,23,.58),
                inset 0 0 0 1px rgba(251,113,133,.5),
                0 18px 34px -14px rgba(0,0,0,.66), 0 0 0 4px rgba(244,63,94,.2), 0 0 24px rgba(244,63,94,.5);
        }
        .cal-dial-svg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; display: block; }
        .cal-track { fill: none; stroke: rgba(148,163,184,.3); stroke-width: 4.5; stroke-linecap: round; }
        body.app-theme-dark .cal-track { stroke: rgba(148,163,184,.22); }
        .cal-err { fill: none; stroke: url(#calGrad); stroke-width: 4.5; stroke-linecap: round; transition: stroke .3s; }
        .cal-dial.is-cal  .cal-err { stroke: url(#calGradOk); }
        .cal-dial.is-fail .cal-err { stroke: url(#calGradFail); }
        .cal-tick { stroke: rgba(100,116,139,.48); stroke-width: 1.4; }
        .cal-tick.maj { stroke: rgba(71,85,105,.7); stroke-width: 2.2; }
        .cal-tick.zero { stroke: #6366f1; stroke-width: 2.6; }
        body.app-theme-dark .cal-tick { stroke: rgba(148,163,184,.4); }
        body.app-theme-dark .cal-tick.maj { stroke: rgba(203,213,225,.58); }
        body.app-theme-dark .cal-tick.zero { stroke: #818cf8; }
        /* 3 ibre — farklı uzunluk/renk/kalınlık (saat ibresi hiyerarşisi) */
        .cal-needle { stroke-linecap: round; transition: stroke .3s, filter .3s; }
        .cal-needle.n1 { stroke: #4f46e5; stroke-width: 2.6; filter: drop-shadow(0 0 2.5px rgba(79,70,229,.5)); }
        .cal-needle.n2 { stroke: #0891b2; stroke-width: 2.0; }
        .cal-needle.n3 { stroke: #7c3aed; stroke-width: 1.7; opacity: .92; }
        body.app-theme-dark .cal-needle.n1 { stroke: #818cf8; filter: drop-shadow(0 0 3px rgba(129,140,248,.7)); }
        body.app-theme-dark .cal-needle.n2 { stroke: #22d3ee; }
        body.app-theme-dark .cal-needle.n3 { stroke: #a78bfa; }
        .cal-dial.is-cal  .cal-needle { stroke: #059669 !important; filter: drop-shadow(0 0 3px rgba(16,185,129,.55)); }
        .cal-dial.is-fail .cal-needle { stroke: #e11d48 !important; filter: drop-shadow(0 0 3px rgba(244,63,94,.5)); }
        body.app-theme-dark .cal-dial.is-cal  .cal-needle { stroke: #34d399 !important; }
        body.app-theme-dark .cal-dial.is-fail .cal-needle { stroke: #fb7185 !important; }
        .cal-hub { fill: #4f46e5; } .cal-hub-in { fill: #fff; }
        body.app-theme-dark .cal-hub { fill: #818cf8; } body.app-theme-dark .cal-hub-in { fill: #0a0d17; }
        .cal-dial.is-cal  .cal-hub { fill: #059669; } body.app-theme-dark .cal-dial.is-cal  .cal-hub { fill: #34d399; }
        .cal-dial.is-fail .cal-hub { fill: #e11d48; } body.app-theme-dark .cal-dial.is-fail .cal-hub { fill: #fb7185; }
        .cal-check { opacity: 0; transform: scale(.4); transform-origin: 100px 128px; transition: opacity .3s, transform .35s cubic-bezier(.34,1.56,.5,1); }
        .cal-dial.is-cal .cal-check { opacity: 1; transform: scale(1); }
        .cal-dial-readout {
            position: absolute; left: 0; right: 0; bottom: 20%; text-align: center; z-index: 3;
            font-family: ui-monospace, Menlo, Consolas, monospace; font-size: .74rem; font-weight: 700;
            color: #4f46e5; pointer-events: none; font-variant-numeric: tabular-nums;
        }
        body.app-theme-dark .cal-dial-readout { color: #a5b4fc; }
        .cal-dial.is-cal  .cal-dial-readout { color: #059669; } body.app-theme-dark .cal-dial.is-cal  .cal-dial-readout { color: #34d399; }
        .cal-dial.is-fail .cal-dial-readout { color: #e11d48; } body.app-theme-dark .cal-dial.is-fail .cal-dial-readout { color: #fb7185; }
        .cal-dial-status {
            margin-top: 16px; text-align: center; font-size: .86rem; font-weight: 600;
            min-height: 1.2em; white-space: nowrap; color: #64748b; transition: color .3s;
        }
        body.app-theme-dark .cal-dial-status { color: #94a3b8; }
        .cal-dial.is-calibrating .cal-dial-status { color: #4f46e5; } body.app-theme-dark .cal-dial.is-calibrating .cal-dial-status { color: #a5b4fc; }
        .cal-dial.is-cal  .cal-dial-status { color: #059669; } body.app-theme-dark .cal-dial.is-cal  .cal-dial-status { color: #34d399; }
        .cal-dial.is-fail .cal-dial-status { color: #e11d48; } body.app-theme-dark .cal-dial.is-fail .cal-dial-status { color: #fb7185; }
        @@keyframes calShake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-7px)} 40%{transform:translateX(6px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(3px)} }
        .cal-dial.cal-shake .cal-dial-glass { animation: calShake .5s ease; }
        @@media (prefers-reduced-motion: reduce) {
            .cal-check, .cal-needle, .cal-err { transition: none; }
            .cal-dial.cal-shake .cal-dial-glass { animation: none; }
        }
    </style>
</head>
<body class="login-page app-theme-@runtime.ThemeCode"
      data-reset-workspace-tabs="1">
<!-- Tema toggle — sag ust kose -->
<button type="button" id="btnThemeToggle" class="login-theme-toggle" title="Tema değiştir" aria-label="Tema değiştir">
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
    </svg>
</button>
<script>
    (function () {
        var TK = 'calibra_theme';
        var body = document.body;
        var btn  = document.getElementById('btnThemeToggle');
        var themeInput = document.getElementById('loginThemeInput');
        var form = document.getElementById('loginForm');

        // localStorage tercihini hem UI'a hem hidden input'a uygula
        function applyTheme(t) {
            body.classList.remove('app-theme-light', 'app-theme-dark');
            body.classList.add('app-theme-' + t);
            if (themeInput) themeInput.value = t;
            try { localStorage.setItem(TK, t); } catch (e) {}
        }

        var saved = null;
        try { saved = localStorage.getItem(TK); } catch (e) {}
        if (saved === 'dark' || saved === 'light') { applyTheme(saved); }
        else if (themeInput) { themeInput.value = body.classList.contains('app-theme-dark') ? 'dark' : 'light'; }

        function currentTheme() {
            return body.classList.contains('app-theme-dark') ? 'dark' : 'light';
        }
        btn.addEventListener('click', function () {
            applyTheme(currentTheme() === 'dark' ? 'light' : 'dark');
        });
    })();
</script>
<div class="login-shell">
    <section class="login-hero" aria-hidden="true">
        @* CalibraHub Software marka görseli. Frame overflow:hidden + img object-fit:cover
           ile panel tamamen kaplanır, sağ-alt sparkle filigranı doğal olarak kırpılır. *@
        <div class="login-hero-frame">
            <img src="~/Document/CalibraHubLoginLogo.png" alt="CalibraHub Software" />
        </div>
    </section>

    <section class="login-panel">
        <div class="login-card">
            <h1>CalibraHub</h1>

            @* Kimlik kalibrasyon kadranı — kullanıcı adı/şirket/şifre girişine bağlı 3 ibre.
               Doldururken "kalibre ediliyor", doğru girişte "kalibrasyon tamam", yanlışta "edilemedi". *@
            <div class="cal-dial" id="calDial">
                <div class="cal-dial-glass" id="calGlass" aria-hidden="true">
                    <svg class="cal-dial-svg" viewBox="0 0 200 200">
                        <defs>
                            <linearGradient id="calGrad" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0" stop-color="#6366f1" /><stop offset="1" stop-color="#22d3ee" />
                            </linearGradient>
                            <linearGradient id="calGradOk" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0" stop-color="#22d3ee" /><stop offset="1" stop-color="#34d399" />
                            </linearGradient>
                            <linearGradient id="calGradFail" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0" stop-color="#fb7185" /><stop offset="1" stop-color="#e11d48" />
                            </linearGradient>
                        </defs>
                        <path class="cal-track" pathLength="100" d="M47.72 152.28 A74 74 0 1 1 152.28 152.28" />
                        <path class="cal-err" id="calErr" pathLength="100" d="M47.72 152.28 A74 74 0 1 1 152.28 152.28" stroke-dasharray="0 100" />
                        <g id="calTicks"></g>
                        <g class="cal-check" fill="none" stroke="#34d399" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M90 128 l6.5 7 14 -15" />
                        </g>
                        @* İbre sırası: kısa→uzun (ana ibre en üstte çizilir) *@
                        <g id="calNeedle3"><line class="cal-needle n3" x1="100" y1="100" x2="100" y2="62" /></g>
                        <g id="calNeedle2"><line class="cal-needle n2" x1="100" y1="100" x2="100" y2="54" /></g>
                        <g id="calNeedle"><line class="cal-needle n1" x1="100" y1="104" x2="100" y2="44" /></g>
                        <circle class="cal-hub" cx="100" cy="100" r="6.5" />
                        <circle class="cal-hub-in" cx="100" cy="100" r="2.4" />
                    </svg>
                    <div class="cal-dial-readout"><span id="calVal">+0.00</span></div>
                </div>
                <div class="cal-dial-status" id="calStatus">Kalibrasyon bekleniyor</div>
            </div>

            <form asp-action="Login" method="post" autocomplete="off" id="loginForm">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />
                <input type="hidden" name="ThemeCode" id="loginThemeInput" value="" />

                <div class="form-floating login-field mb-3">
                    @* a11y (rapor §6.6): autofocus + required + aria-required + class="cb-field-error" *@
                    <input asp-for="Email" class="form-control" autocomplete="email"
                           placeholder=" " autofocus required aria-required="true" />
                    <label asp-for="Email" class="cb-field-required">@ui.Text("email")</label>
                    <span asp-validation-for="Email" class="cb-field-error"></span>
                </div>

                <div class="form-floating login-field mb-3">
                    <select asp-for="CompanyId" asp-items="Model.CompanyOptions" class="form-select">
                        <option value="">@ui.Text("company_placeholder")</option>
                    </select>
                    <label asp-for="CompanyId">@ui.Text("company")</label>
                    <span asp-validation-for="CompanyId"></span>
                </div>

                <div class="form-floating login-field mb-3">
                    <input asp-for="Password" type="password" class="form-control"
                           autocomplete="current-password" placeholder=" " required aria-required="true" />
                    <label asp-for="Password" class="cb-field-required">@ui.Text("password")</label>
                    <span asp-validation-for="Password" class="cb-field-error"></span>
                </div>

                <div class="login-remember-row mb-3">
                    <label class="login-switch" for="rememberToggle">
                        <input type="checkbox" id="rememberToggle" />
                        <span class="login-switch-track"></span>
                    </label>
                    <span class="login-remember-label">Beni hatırla</span>
                </div>

                <button type="submit" class="btn btn-primary w-100">@ui.Text("submit")</button>

                <div class="text-center mt-3">
                    <a href="@Url.Action("ForgotPassword", "Account")" class="text-muted small"
                       style="text-decoration:none;opacity:.75;transition:opacity .15s"
                       onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='.75'">
                        Şifremi Unuttum
                    </a>
                </div>
            </form>

            @if (ViewBag.ShowSetupLink == true)
            {
                <div class="mt-4 pt-3 border-top text-center">
                    <p class="text-muted small mb-2">Sistemde henüz şirket tanımlanmamış.</p>
                    <a href="/Gate" class="btn btn-outline-secondary btn-sm">
                        İlk Kurulumu Yap
                    </a>
                </div>
            }


        </div>
    </section>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (function () {
        const companyPlaceholderText = @Html.Raw(JsonSerializer.Serialize(ui.Text("company_placeholder")));
        const emailInput = document.getElementById("Email");
        const companySelect = document.getElementById("CompanyId");
        if (!emailInput || !companySelect) {
            return;
        }

        const endpoint = '@Url.Action("CompaniesForUser", "Account")';

        function renderCompanies(items) {
            const currentValue = companySelect.value;
            companySelect.innerHTML = "";

            const placeholder = document.createElement("option");
            placeholder.value = "";
            placeholder.textContent = companyPlaceholderText;
            companySelect.appendChild(placeholder);

            let hasCurrent = false;
            items.forEach(function (item) {
                const option = document.createElement("option");
                option.value = item.id;
                option.textContent = item.name;
                if (item.id === currentValue) {
                    option.selected = true;
                    hasCurrent = true;
                }

                companySelect.appendChild(option);
            });

            if (!hasCurrent) {
                companySelect.value = "";
            }
        }

        async function loadCompanies() {
            const email = emailInput.value.trim();
            if (!email) {
                renderCompanies([]);
                return;
            }

            try {
                const response = await fetch(endpoint + "?email=" + encodeURIComponent(email), {
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                if (!response.ok) {
                    renderCompanies([]);
                    return;
                }

                const data = await response.json();
                renderCompanies(Array.isArray(data) ? data : []);
            } catch {
                renderCompanies([]);
            }
        }

        emailInput.addEventListener("blur", loadCompanies);
        emailInput.addEventListener("change", loadCompanies);

        if (emailInput.value.trim().length > 0) {
            loadCompanies();
        }

        // Beni hatırla switch
        var rememberToggle = document.getElementById("rememberToggle");
        var rememberLabel = document.querySelector(".login-remember-label");
        var remembered = localStorage.getItem("calibra_login_remember") === "1";

        if (rememberToggle) {
            rememberToggle.checked = remembered;

            // Önceki oturumdan hatırlanan bilgileri yükle
            if (remembered && !emailInput.value) {
                var savedEmail = localStorage.getItem("calibra_login_email");
                var savedCompany = localStorage.getItem("calibra_login_company");
                if (savedEmail) {
                    emailInput.value = savedEmail;
                    loadCompanies().then(function () {
                        if (savedCompany && companySelect) {
                            companySelect.value = savedCompany;
                        }
                    });
                }
            }

            if (rememberLabel) {
                rememberLabel.addEventListener("click", function () {
                    rememberToggle.checked = !rememberToggle.checked;
                });
            }
        }

        var loginForm = emailInput.closest("form");
        if (loginForm) {
            var pwInput = document.getElementById("Password");
            var pwWrap  = pwInput ? pwInput.closest(".login-field") : null;

            loginForm.addEventListener("submit", async function (e) {
                e.preventDefault();

                // Tema hidden input'u güncelle
                var themeInput = document.getElementById("loginThemeInput");
                if (themeInput) themeInput.value = document.body.classList.contains("app-theme-dark") ? "dark" : "light";

                // Beni hatırla
                if (rememberToggle && rememberToggle.checked) {
                    localStorage.setItem("calibra_login_remember", "1");
                    localStorage.setItem("calibra_login_email", emailInput.value.trim());
                    if (companySelect.value) localStorage.setItem("calibra_login_company", companySelect.value);
                } else {
                    localStorage.removeItem("calibra_login_remember");
                    localStorage.removeItem("calibra_login_email");
                    localStorage.removeItem("calibra_login_company");
                }

                // Kalibrasyon ölçümü başladı
                if (window.CalibraLoginDial) window.CalibraLoginDial.begin();

                // AJAX submit
                try {
                    var resp = await fetch(loginForm.action || window.location.href, {
                        method: "POST",
                        body: new FormData(loginForm),
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });
                    var json = await resp.json();

                    if (json.ok) {
                        // Doğru giriş — hemen yönlenme; önce "kalibrasyon tamam" hissi, sonra login
                        if (window.CalibraLoginDial) window.CalibraLoginDial.success(function () { window.location.href = json.redirect; });
                        else window.location.href = json.redirect;
                        return;
                    }

                    // Kalibre edilemedi — kırmızı kadran yeterli uyarı; kadran/alan titremesi YOK
                    if (json.error === "locked") {
                        if (window.CalibraLoginDial) window.CalibraLoginDial.fail('Hesap kilitli');
                        if (pwInput) {
                            pwInput.value = "";
                            pwInput.disabled = true;
                            setTimeout(function () { pwInput.disabled = false; }, 5000);
                        }
                    } else if (json.error === "validation") {
                        if (window.CalibraLoginDial) window.CalibraLoginDial.fail('Alanları doldurun');
                    } else {   // credentials
                        var rem = (typeof json.remaining === "number") ? json.remaining : -1;
                        var det = rem > 0 ? ("Şifreniz hatalı, " + rem + " deneme kaldı") : "Şifreniz hatalı";
                        if (window.CalibraLoginDial) window.CalibraLoginDial.fail("Kalibre edilemedi", det);
                        if (pwInput) { pwInput.value = ""; pwInput.focus(); }
                    }
                } catch {
                    // Network hatası: normal submit
                    loginForm.submit();
                }
            });
        }
    })();
</script>
<script>
    /* ── Kimlik kalibrasyon kadranı — 3 ibre, mekanik tik-tik ──
       Yazdıkça ibreler rastgele dağılır ("kalibre ediliyor"); Giriş'te rastgele dolaşır,
       doğru girişte 12'de (merkez) toplanıp kilitlenir (yeşil ✓), yanlışta dağınık kalır (kırmızı). */
    (function () {
        var dial = document.getElementById('calDial');
        if (!dial) return;
        var errArc   = document.getElementById('calErr');
        var valEl    = document.getElementById('calVal');
        var statusEl = document.getElementById('calStatus');
        var ticksG   = document.getElementById('calTicks');
        var NS = 'http://www.w3.org/2000/svg';
        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var CENTER = 50;

        var emailEl = document.getElementById('Email');
        var pwEl    = document.getElementById('Password');
        var coEl    = document.getElementById('CompanyId');

        // n1 = şifre (ana ibre), n2 = kullanıcı adı, n3 = şirket
        var needles = [
            { el: document.getElementById('calNeedle'),  cur: 12, tgt: 12, seek: 3.4 },
            { el: document.getElementById('calNeedle2'), cur: 88, tgt: 88, seek: 2.6 },
            { el: document.getElementById('calNeedle3'), cur: 30, tgt: 30, seek: 2.0 }
        ];

        // ── Tick'ler: 0..100 her 5'te bir; 25'lik major; 50 (merkez) vurgulu ──
        for (var i = 0; i <= 20; i++) {
            var v = i * 5, a = (-135 + v / 100 * 270) * Math.PI / 180;
            var sn = Math.sin(a), cs = Math.cos(a);
            var r1 = (v === 50) ? 60 : 66, r2 = (v % 25 === 0) ? 84 : 80;
            var ln = document.createElementNS(NS, 'line');
            ln.setAttribute('x1', (100 + sn * r1).toFixed(2)); ln.setAttribute('y1', (100 - cs * r1).toFixed(2));
            ln.setAttribute('x2', (100 + sn * r2).toFixed(2)); ln.setAttribute('y2', (100 - cs * r2).toFixed(2));
            ln.setAttribute('class', 'cal-tick' + (v === 50 ? ' zero' : (v % 25 === 0 ? ' maj' : '')));
            ticksG.appendChild(ln);
        }

        function place(n) { n.el.setAttribute('transform', 'rotate(' + (-135 + n.cur / 100 * 270).toFixed(2) + ' 100 100)'); }
        function renderArc() {
            var avg = (needles[0].cur + needles[1].cur + needles[2].cur) / 3;
            if (avg >= 50) errArc.setAttribute('stroke-dasharray', '0 50 ' + (avg - 50).toFixed(2) + ' 100');
            else           errArc.setAttribute('stroke-dasharray', '0 ' + avg.toFixed(2) + ' ' + (50 - avg).toFixed(2) + ' 100');
            var dev = (avg - 50) / 50; if (Math.abs(dev) < 0.01) dev = 0;
            valEl.textContent = (dev >= 0 ? '+' : '') + dev.toFixed(2);
        }

        var mode = 'idle';        // idle | calibrating | success | fail
        var raf = 0, running = false, busyStart = 0, lastTick = 0;
        var STEP = 2.6;           // her tik'te ilerlenen açı adımı
        var TICK_MS = 55;         // tik aralığı — mekanik "tik tik" hissi
        function quant(v) { return Math.round(v / STEP) * STEP; }
        // Mekanik kadran: ibre hedefe düz kaymaz/dalgalanmaz — sabit adımlarla tik tik ilerler
        function frame(ts) {
            if (reduce) {
                for (var r = 0; r < 3; r++) { needles[r].cur = needles[r].tgt; place(needles[r]); }
                renderArc(); running = false; return;
            }
            if (ts - lastTick >= TICK_MS) {
                lastTick = ts;
                var moved = false;
                for (var k = 0; k < 3; k++) {
                    var n = needles[k], target = quant(n.tgt);
                    if (Math.abs(n.cur - target) >= STEP * 0.5) {
                        n.cur = quant(n.cur + (target > n.cur ? STEP : -STEP));   // bir tik ilerle
                        moved = true;
                    } else if (n.cur !== target) { n.cur = target; moved = true; }
                    place(n);
                }
                if (moved) renderArc();
                if (!moved) { running = false; return; }
            }
            raf = requestAnimationFrame(frame);
        }
        function kick() { if (!running) { running = true; lastTick = 0; raf = requestAnimationFrame(frame); } }
        function setStatus(t) { if (statusEl) statusEl.textContent = t; }

        // ── Rastgele dağılım: ibreler kadran boyunca serbestçe dağılır (mekanik arama) ──
        var roamId = 0;
        function randTargets() { for (var k = 0; k < 3; k++) needles[k].tgt = Math.random() * 100; }   // tam aralik: alt-sol/alt-sag uclara (±135°) kadar
        function startRoam(ms) { stopRoam(); randTargets(); kick(); if (!reduce) roamId = setInterval(function () { randTargets(); kick(); }, ms); }
        function stopRoam() { if (roamId) { clearInterval(roamId); roamId = 0; } }

        // Yalnizca ŞIFRE yazilirken ibreler rastgele dagilir; sifre bosken notr dinlenme.
        // (Kullanici adi / sirket alanlari ibreleri oynatmaz.)
        // Her tuşta SIRAYLA tek bir ibre oynar: 1. tuş→ibre1, 2. tuş→ibre2, 3. tuş→ibre3, 4. tuş→ibre1…
        var keyIdx = 0;
        function evalFields() {
            if (mode === 'fail' || mode === 'success') { mode = 'idle'; dial.classList.remove('is-fail', 'is-cal'); }
            if (mode === 'success' || mode === 'measuring') return;
            var pw = pwEl ? pwEl.value : '';
            if (pw) {
                mode = 'calibrating';
                dial.classList.add('is-calibrating');
                setStatus('Kalibre ediliyor…');
                // Sadece sıradaki ibreye yeni hedef ver → o ibre mekanik tik ile oynar,
                // diğer ikisi olduğu yerde durur. Her tuşta bir sonraki ibreye geçilir.
                needles[keyIdx % 3].tgt = Math.random() * 100;
                keyIdx++;
                kick();
            } else {
                mode = 'idle';
                keyIdx = 0;                                // şifre boşaldı → döngü baştan (ibre1)
                dial.classList.remove('is-calibrating');
                setStatus('Kalibrasyon bekleniyor');
                needles[0].tgt = 26; needles[1].tgt = 54; needles[2].tgt = 78;   // nötr dinlenme
                kick();
            }
        }
        if (pwEl) pwEl.addEventListener('input', evalFields);

        // ── Dış API — submit handler çağırır ──
        window.CalibraLoginDial = {
            begin: function () {
                mode = 'measuring'; busyStart = performance.now();
                dial.classList.remove('is-cal', 'is-fail'); dial.classList.add('is-calibrating');
                setStatus('Kalibre ediliyor…');
                startRoam(300);                              // ölçüm: ibreler rastgele dolaşır
            },
            success: function (done) {
                var wait = Math.max(0, 700 - (performance.now() - busyStart));
                setTimeout(function () {
                    mode = 'success'; stopRoam();
                    dial.classList.remove('is-calibrating', 'is-fail');
                    needles[0].tgt = 50; needles[1].tgt = 50; needles[2].tgt = 50; kick();   // 12'de topla
                    // Kilitlenme: üç ibre tam merkeze oturur — yazı YOK, sadece yeşil + ✓
                    setTimeout(function () {
                        cancelAnimationFrame(raf); running = false;
                        needles[0].cur = needles[1].cur = needles[2].cur = 50;
                        needles.forEach(place); renderArc();
                        dial.classList.add('is-cal'); setStatus('');
                    }, reduce ? 0 : 520);
                    setTimeout(function () { if (done) done(); }, reduce ? 500 : 1300);
                }, wait);
            },
            fail: function (label, detail) {
                var msg = label || 'Kalibre edilemedi';
                var wait = Math.max(0, 700 - (performance.now() - busyStart));
                setTimeout(function () {
                    mode = 'fail';
                    dial.classList.remove('is-calibrating', 'is-cal'); dial.classList.add('is-fail');
                    setStatus(msg);                          // önce: Kalibre edilemedi
                    startRoam(300);                          // yine rastgele dolaşır…
                    setTimeout(function () { stopRoam(); randTargets(); kick(); }, 1000);   // …dağınık kalır (titreme YOK)
                    if (detail) setTimeout(function () { if (mode === 'fail') setStatus(detail); }, 1300);   // sonra: Şifreniz hatalı, N deneme kaldı
                }, wait);
            }
        };

        // ── İlk render ──
        needles.forEach(place); renderArc();
        evalFields();   // ilk durum: şifre boş → nötr dinlenme
    })();
</script>
</body>
</html>

