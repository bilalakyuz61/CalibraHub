@using System.Text.Json
@model CalibraHub.Web.Models.Account.LoginInputModel
@inject CalibraHub.Web.Infrastructure.Ui.IUiTextService UiText
@{
    Layout = null;
    var runtime = await UiText.GetRuntimeAsync();
    var ui = await UiText.GetFormAsync("account.login");
}
<!DOCTYPE html>
<html lang="@runtime.LanguageCode">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ui.Text("title") - CalibraHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ── Login sayfasi tema toggle butonu (sag ust) ─────────────── */
        .login-theme-toggle {
            position: fixed; top: 16px; right: 18px; z-index: 1050;
            width: 38px; height: 38px;
            border: 1px solid rgba(148, 163, 184, 0.32);
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.85);
            color: #475569;
            cursor: pointer;
            display: inline-flex; align-items: center; justify-content: center;
            transition: background-color .18s, color .18s, border-color .18s, transform .18s;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        .login-theme-toggle:hover { transform: scale(1.08); background: rgba(241, 245, 249, 0.95); }
        .login-theme-toggle .icon-sun  { display: none;  }
        .login-theme-toggle .icon-moon { display: block; }
        body.app-theme-dark .login-theme-toggle {
            background: rgba(15, 23, 42, 0.72);
            border-color: rgba(148, 163, 184, 0.30);
            color: #e2e8f0;
        }
        body.app-theme-dark .login-theme-toggle:hover { background: rgba(30, 41, 59, 0.95); }
        body.app-theme-dark .login-theme-toggle .icon-sun  { display: block; }
        body.app-theme-dark .login-theme-toggle .icon-moon { display: none;  }

        /* ── Dark tema overrides — login sayfasi icin ───────────────── */
        body.app-theme-dark.login-page {
            background: #0a0d17 !important;
        }
        body.app-theme-dark .login-panel {
            background: linear-gradient(145deg, #0f172a, #0a0d17) !important;
        }
        body.app-theme-dark .login-hero {
            background: #0a0d17;
        }
        body.app-theme-dark .login-hero img {
            filter: saturate(1.05) brightness(0.92);
        }
        body.app-theme-dark .login-card {
            background: rgba(15, 23, 42, 0.88) !important;
            border: 1px solid rgba(148, 163, 184, 0.14) !important;
            box-shadow: 0 18px 48px rgba(0, 0, 0, 0.55) !important;
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card h1 { color: #f1f5f9 !important; }
        body.app-theme-dark .login-card .form-label,
        body.app-theme-dark .login-card label,
        body.app-theme-dark .login-field > label {
            color: #94a3b8 !important;
        }
        body.app-theme-dark .login-card .form-control,
        body.app-theme-dark .login-card .form-select,
        body.app-theme-dark .login-field .form-control,
        body.app-theme-dark .login-field .form-select {
            background-color: rgba(30, 41, 59, 0.65) !important;
            border-color: rgba(148, 163, 184, 0.22) !important;
            color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card .form-control:focus,
        body.app-theme-dark .login-card .form-select:focus {
            border-color: #6366f1 !important;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.18) !important;
        }
        body.app-theme-dark .login-card .form-select option {
            background: #0c0f1a; color: #e2e8f0;
        }
        body.app-theme-dark .login-card .btn-primary {
            background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
            border: none !important;
        }
        body.app-theme-dark .login-remember-label { color: #cbd5e1 !important; }
        body.app-theme-dark .login-card .text-muted { color: #94a3b8 !important; }
        body.app-theme-dark .login-card .border-top { border-color: rgba(148, 163, 184, 0.18) !important; }
    </style>
</head>
<body class="login-page app-theme-@runtime.ThemeCode"
      data-reset-workspace-tabs="1">
<!-- Tema toggle — sag ust kose -->
<button type="button" id="btnThemeToggle" class="login-theme-toggle" title="Tema değiştir" aria-label="Tema değiştir">
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
    </svg>
</button>
<script>
    (function () {
        var TK = 'calibra_theme';
        var body = document.body;
        var btn = document.getElementById('btnThemeToggle');
        // Kullanici tercihi varsa uygula
        var saved = null;
        try { saved = localStorage.getItem(TK); } catch (e) {}
        if (saved === 'dark' || saved === 'light') {
            body.classList.remove('app-theme-light', 'app-theme-dark');
            body.classList.add('app-theme-' + saved);
        }
        function currentTheme() {
            return body.classList.contains('app-theme-dark') ? 'dark' : 'light';
        }
        btn.addEventListener('click', function () {
            var next = currentTheme() === 'dark' ? 'light' : 'dark';
            body.classList.remove('app-theme-light', 'app-theme-dark');
            body.classList.add('app-theme-' + next);
            try { localStorage.setItem(TK, next); } catch (e) {}
        });
    })();
</script>
<div class="login-shell">
    <section class="login-hero" aria-hidden="true">
        <img src="~/Document/2026-02-21_13-51-14.jpg" alt="Calibra Login" />
    </section>

    <section class="login-panel">
        <div class="login-card">
            <h1>CalibraHub</h1>

            <form asp-action="Login" method="post" autocomplete="off">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div class="form-floating login-field mb-3">
                    <input asp-for="Email" class="form-control" autocomplete="off" placeholder=" " />
                    <label asp-for="Email">@ui.Text("email")</label>
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="form-floating login-field mb-3">
                    <select asp-for="CompanyId" asp-items="Model.CompanyOptions" class="form-select">
                        <option value="">@ui.Text("company_placeholder")</option>
                    </select>
                    <label asp-for="CompanyId">@ui.Text("company")</label>
                    <span asp-validation-for="CompanyId"></span>
                </div>

                <div class="form-floating login-field mb-3">
                    <input asp-for="Password" class="form-control" autocomplete="off" placeholder=" " />
                    <label asp-for="Password">@ui.Text("password")</label>
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="login-remember-row mb-3">
                    <label class="login-switch" for="rememberToggle">
                        <input type="checkbox" id="rememberToggle" />
                        <span class="login-switch-track"></span>
                    </label>
                    <span class="login-remember-label">Beni hatırla</span>
                </div>

                <button type="submit" class="btn btn-primary w-100">@ui.Text("submit")</button>
            </form>

            @if (ViewBag.ShowSetupLink == true)
            {
                <div class="mt-4 pt-3 border-top text-center">
                    <p class="text-muted small mb-2">Sistemde henüz şirket tanımlanmamış.</p>
                    <a asp-controller="Setup" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        İlk Kurulumu Yap
                    </a>
                </div>
            }

        </div>
    </section>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (function () {
        const companyPlaceholderText = @Html.Raw(JsonSerializer.Serialize(ui.Text("company_placeholder")));
        const emailInput = document.getElementById("Email");
        const companySelect = document.getElementById("CompanyId");
        if (!emailInput || !companySelect) {
            return;
        }

        const endpoint = '@Url.Action("CompaniesForUser", "Account")';

        function renderCompanies(items) {
            const currentValue = companySelect.value;
            companySelect.innerHTML = "";

            const placeholder = document.createElement("option");
            placeholder.value = "";
            placeholder.textContent = companyPlaceholderText;
            companySelect.appendChild(placeholder);

            let hasCurrent = false;
            items.forEach(function (item) {
                const option = document.createElement("option");
                option.value = item.id;
                option.textContent = item.name;
                if (item.id === currentValue) {
                    option.selected = true;
                    hasCurrent = true;
                }

                companySelect.appendChild(option);
            });

            if (!hasCurrent) {
                companySelect.value = "";
            }
        }

        async function loadCompanies() {
            const email = emailInput.value.trim();
            if (!email) {
                renderCompanies([]);
                return;
            }

            try {
                const response = await fetch(endpoint + "?email=" + encodeURIComponent(email), {
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                if (!response.ok) {
                    renderCompanies([]);
                    return;
                }

                const data = await response.json();
                renderCompanies(Array.isArray(data) ? data : []);
            } catch {
                renderCompanies([]);
            }
        }

        emailInput.addEventListener("blur", loadCompanies);
        emailInput.addEventListener("change", loadCompanies);

        if (emailInput.value.trim().length > 0) {
            loadCompanies();
        }

        // Beni hatırla switch
        var rememberToggle = document.getElementById("rememberToggle");
        var rememberLabel = document.querySelector(".login-remember-label");
        var remembered = localStorage.getItem("calibra_login_remember") === "1";

        if (rememberToggle) {
            rememberToggle.checked = remembered;

            // Önceki oturumdan hatırlanan bilgileri yükle
            if (remembered && !emailInput.value) {
                var savedEmail = localStorage.getItem("calibra_login_email");
                var savedCompany = localStorage.getItem("calibra_login_company");
                if (savedEmail) {
                    emailInput.value = savedEmail;
                    loadCompanies().then(function () {
                        if (savedCompany && companySelect) {
                            companySelect.value = savedCompany;
                        }
                    });
                }
            }

            if (rememberLabel) {
                rememberLabel.addEventListener("click", function () {
                    rememberToggle.checked = !rememberToggle.checked;
                });
            }
        }

        var loginForm = emailInput.closest("form");
        if (loginForm) {
            loginForm.addEventListener("submit", function () {
                if (rememberToggle && rememberToggle.checked) {
                    localStorage.setItem("calibra_login_remember", "1");
                    localStorage.setItem("calibra_login_email", emailInput.value.trim());
                    if (companySelect.value) {
                        localStorage.setItem("calibra_login_company", companySelect.value);
                    }
                } else {
                    localStorage.removeItem("calibra_login_remember");
                    localStorage.removeItem("calibra_login_email");
                    localStorage.removeItem("calibra_login_company");
                }
            });
        }
    })();
</script>
<!-- ⚙ Veritabanı Ayarları Butonu -->
<button type="button" id="btnDbSettings" title="Veritabani Baglanti Ayarlari"
        style="position:fixed;bottom:18px;right:18px;z-index:1000;
               width:40px;height:40px;border-radius:50%;border:none;cursor:pointer;
               background:rgba(100,116,139,0.18);color:#64748b;
               display:flex;align-items:center;justify-content:center;
               transition:background .2s,color .2s;"
        onmouseover="this.style.background='rgba(37,99,235,0.12)';this.style.color='#2563eb';"
        onmouseout="this.style.background='rgba(100,116,139,0.18)';this.style.color='#64748b';">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/>
        <path d="M12 2v2M12 20v2M2 12h2M20 12h2"/>
    </svg>
</button>

<!-- DB Ayarları Modal -->
<div id="dbSettingsModal"
     style="display:none;position:fixed;inset:0;z-index:2000;
            background:rgba(0,0,0,.45);backdrop-filter:blur(3px);
            align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:14px;padding:28px 32px;width:420px;max-width:96vw;
                box-shadow:0 12px 48px rgba(0,0,0,.22);position:relative;">
        <h5 style="margin:0 0 20px;font-size:1rem;font-weight:700;color:#1e293b;display:flex;align-items:center;gap:8px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>
            Veritabani Baglanti Ayarlari
        </h5>

        <div style="display:grid;gap:10px;margin-bottom:16px;">
            <div>
                <label style="font-size:0.78rem;font-weight:600;color:#475569;display:block;margin-bottom:3px;">Sunucu Adi</label>
                <input id="dbServer" type="text" placeholder="localhost veya 192.168.1.1\SQLEXPRESS"
                       style="width:100%;box-sizing:border-box;border:1px solid #cbd5e1;border-radius:7px;padding:7px 10px;font-size:0.82rem;" />
            </div>
            <div>
                <label style="font-size:0.78rem;font-weight:600;color:#475569;display:block;margin-bottom:3px;">Veritabani Adi</label>
                <input id="dbDatabase" type="text" placeholder="CalibraHub"
                       style="width:100%;box-sizing:border-box;border:1px solid #cbd5e1;border-radius:7px;padding:7px 10px;font-size:0.82rem;" />
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div>
                    <label style="font-size:0.78rem;font-weight:600;color:#475569;display:block;margin-bottom:3px;">Kullanici Adi</label>
                    <input id="dbUser" type="text" placeholder="sa"
                           style="width:100%;box-sizing:border-box;border:1px solid #cbd5e1;border-radius:7px;padding:7px 10px;font-size:0.82rem;" />
                </div>
                <div>
                    <label style="font-size:0.78rem;font-weight:600;color:#475569;display:block;margin-bottom:3px;">Sifre</label>
                    <input id="dbPassword" type="password" placeholder="Degistirmek icin girin"
                           style="width:100%;box-sizing:border-box;border:1px solid #cbd5e1;border-radius:7px;padding:7px 10px;font-size:0.82rem;" />
                </div>
            </div>
        </div>

        <div id="dbSettingsMsg" style="margin-bottom:12px;min-height:24px;font-size:0.78rem;"></div>

        <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button type="button" onclick="dbSettingsTest()"
                    style="padding:7px 16px;border-radius:7px;border:1px solid #cbd5e1;background:#f8fafc;
                           font-size:0.82rem;cursor:pointer;font-weight:500;color:#475569;">
                Baglanti Test Et
            </button>
            <button type="button" onclick="dbSettingsSave()"
                    style="padding:7px 16px;border-radius:7px;border:none;background:#2563eb;
                           color:#fff;font-size:0.82rem;cursor:pointer;font-weight:600;">
                Kaydet
            </button>
            <button type="button" onclick="dbSettingsClose()"
                    style="padding:7px 16px;border-radius:7px;border:1px solid #cbd5e1;background:#fff;
                           font-size:0.82rem;cursor:pointer;color:#64748b;margin-left:auto;">
                Kapat
            </button>
        </div>

        <p style="margin:14px 0 0;font-size:0.72rem;color:#94a3b8;">
            Kaydedilen bağlantı bilgileri DPAPI ile şifrelenerek saklanır. Kayıt sonrası uygulamayı yeniden başlatın.
        </p>
    </div>
</div>

<script>
(function () {
    var modal = document.getElementById('dbSettingsModal');
    var msgEl = document.getElementById('dbSettingsMsg');

    document.getElementById('btnDbSettings').addEventListener('click', function () {
        modal.style.display = 'flex';
        msgEl.innerHTML = '';
        fetch('/Account/GetDbSettings')
            .then(safeJson)
            .then(function (d) {
                document.getElementById('dbServer').value = d.server || '';
                document.getElementById('dbDatabase').value = d.database || '';
                document.getElementById('dbUser').value = d.user || '';
                document.getElementById('dbPassword').value = '';
            })
            .catch(function () {
                dbMsg('Mevcut ayarlar okunamadi.', false);
            });
    });

    modal.addEventListener('click', function (e) {
        if (e.target === modal) dbSettingsClose();
    });

    window.dbSettingsClose = function () { modal.style.display = 'none'; };

    function getPayload() {
        return {
            server: document.getElementById('dbServer').value.trim(),
            database: document.getElementById('dbDatabase').value.trim(),
            user: document.getElementById('dbUser').value.trim(),
            password: document.getElementById('dbPassword').value
        };
    }

    function safeJson(r) {
        return r.text().then(function (text) {
            if (!text || !text.trim()) {
                console.error('[DbSettings] Bos yanit. URL:', r.url, 'HTTP:', r.status);
                return { success: false, message: 'Sunucu bos yanit gonderdi (HTTP ' + r.status + '). URL: ' + r.url };
            }
            try { return JSON.parse(text); }
            catch (e) {
                console.error('[DbSettings] JSON parse hatasi. HTTP:', r.status, 'Body:', text.substring(0, 200));
                return { success: false, message: 'Sunucu gecersiz yanit gonderdi (HTTP ' + r.status + '): ' + text.substring(0, 80) };
            }
        });
    }

    function setBusy(busy) {
        var btns = modal.querySelectorAll('button[type="button"]');
        btns.forEach(function(b) { b.disabled = busy; });
    }

    window.dbSettingsTest = function () {
        dbMsg('Baglanti test ediliyor...', null);
        setBusy(true);
        fetch('/Account/TestDbSettings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(getPayload())
        })
        .then(safeJson)
        .then(function (d) { dbMsg(d.message, d.success); })
        .catch(function (e) { dbMsg('Hata: ' + e.message, false); })
        .finally(function () { setBusy(false); });
    };

    window.dbSettingsSave = function () {
        dbMsg('Baglanti test ediliyor, basarili ise kaydedilecek...', null);
        setBusy(true);
        fetch('/Account/SaveDbSettings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(getPayload())
        })
        .then(safeJson)
        .then(function (d) { dbMsg(d.message, d.success); })
        .catch(function (e) { dbMsg('Hata: ' + e.message, false); })
        .finally(function () { setBusy(false); });
    };

    function dbMsg(msg, ok) {
        if (!msg) { msgEl.innerHTML = ''; return; }
        var bg = ok === null ? '#f1f5f9' : (ok ? '#dcfce7' : '#fef2f2');
        var cl = ok === null ? '#475569' : (ok ? '#15803d' : '#dc2626');
        var br = ok === null ? '#cbd5e1' : (ok ? '#bbf7d0' : '#fecaca');
        msgEl.innerHTML = '<span style="display:inline-block;padding:4px 10px;border-radius:6px;background:'
            + bg + ';color:' + cl + ';border:1px solid ' + br + ';">' + msg + '</span>';
    }
})();
</script>
</body>
</html>

