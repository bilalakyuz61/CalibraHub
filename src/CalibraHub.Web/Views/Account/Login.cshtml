@using System.Text.Json
@model CalibraHub.Web.Models.Account.LoginInputModel
@inject CalibraHub.Web.Infrastructure.Ui.IUiTextService UiText
@{
    Layout = null;
    var runtime = await UiText.GetRuntimeAsync();
    var ui = await UiText.GetFormAsync("account.login");
}
<!DOCTYPE html>
<html lang="@runtime.LanguageCode">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ui.Text("title") - CalibraHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* ── Login sayfasi tema toggle butonu (sag ust) ─────────────── */
        .login-theme-toggle {
            position: fixed; top: 16px; right: 18px; z-index: 1050;
            width: 38px; height: 38px;
            border: 1px solid rgba(148, 163, 184, 0.32);
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.85);
            color: #475569;
            cursor: pointer;
            display: inline-flex; align-items: center; justify-content: center;
            transition: background-color .18s, color .18s, border-color .18s, transform .18s;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        .login-theme-toggle:hover { transform: scale(1.08); background: rgba(241, 245, 249, 0.95); }
        .login-theme-toggle .icon-sun  { display: none;  }
        .login-theme-toggle .icon-moon { display: block; }
        body.app-theme-dark .login-theme-toggle {
            background: rgba(15, 23, 42, 0.72);
            border-color: rgba(148, 163, 184, 0.30);
            color: #e2e8f0;
        }
        body.app-theme-dark .login-theme-toggle:hover { background: rgba(30, 41, 59, 0.95); }
        body.app-theme-dark .login-theme-toggle .icon-sun  { display: block; }
        body.app-theme-dark .login-theme-toggle .icon-moon { display: none;  }

        /* ── Dark tema overrides — login sayfasi icin ───────────────── */
        body.app-theme-dark.login-page {
            background: #0a0d17 !important;
        }
        body.app-theme-dark .login-panel {
            background: linear-gradient(145deg, #0f172a, #0a0d17) !important;
        }
        body.app-theme-dark .login-hero {
            background: #0a0d17;
        }
        body.app-theme-dark .login-hero img {
            filter: saturate(1.05) brightness(0.92);
        }
        body.app-theme-dark .login-card {
            background: rgba(15, 23, 42, 0.88) !important;
            border: 1px solid rgba(148, 163, 184, 0.14) !important;
            box-shadow: 0 18px 48px rgba(0, 0, 0, 0.55) !important;
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card h1 { color: #f1f5f9 !important; }
        body.app-theme-dark .login-card .form-label,
        body.app-theme-dark .login-card label,
        body.app-theme-dark .login-field > label {
            color: #94a3b8 !important;
        }
        body.app-theme-dark .login-card .form-control,
        body.app-theme-dark .login-card .form-select,
        body.app-theme-dark .login-field .form-control,
        body.app-theme-dark .login-field .form-select {
            background-color: rgba(30, 41, 59, 0.65) !important;
            border-color: rgba(148, 163, 184, 0.22) !important;
            color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card .form-control:focus,
        body.app-theme-dark .login-card .form-select:focus {
            border-color: #6366f1 !important;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.18) !important;
        }
        body.app-theme-dark .login-card .form-select option {
            background: #0c0f1a; color: #e2e8f0;
        }
        body.app-theme-dark .login-card .btn-primary {
            background: linear-gradient(135deg, #6366f1, #8b5cf6) !important;
            border: none !important;
        }
        body.app-theme-dark .login-remember-label { color: #cbd5e1 !important; }
        body.app-theme-dark .login-card .text-muted { color: #94a3b8 !important; }
        body.app-theme-dark .login-card .border-top { border-color: rgba(148, 163, 184, 0.18) !important; }

        .login-error-msg {
            min-height: 46px;
            margin-bottom: 12px;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: .875rem;
            font-weight: 500;
            background: rgba(239,68,68,.10);
            border: 1px solid rgba(239,68,68,.35);
            color: #dc2626;
            display: flex;
            align-items: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .18s;
        }
        .login-error-msg.is-visible {
            opacity: 1;
            pointer-events: auto;
        }
        body.app-theme-dark .login-error-msg {
            background: rgba(239,68,68,.14);
            border-color: rgba(248,113,113,.35);
            color: #f87171;
        }

        @@keyframes loginShake {
            0%, 100% { transform: translateX(0); }
            15%  { transform: translateX(-7px); }
            30%  { transform: translateX(7px); }
            45%  { transform: translateX(-5px); }
            60%  { transform: translateX(5px); }
            75%  { transform: translateX(-2px); }
        }
        .login-pw-error .form-control {
            border-color: #ef4444 !important;
            box-shadow: 0 0 0 3px rgba(239,68,68,.18) !important;
        }
        body.app-theme-dark .login-pw-error .form-control {
            border-color: #f87171 !important;
            box-shadow: 0 0 0 3px rgba(248,113,113,.18) !important;
        }
        .login-pw-shake {
            animation: loginShake .42s cubic-bezier(.36,.07,.19,.97) both;
        }

        /* ── Sol hero: kalibrasyon sahnesi (cam küre + hareketli kadran) ─── */
        .cal-hero {
            position: relative; width: 100%; height: 100%;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            gap: clamp(22px, 4.5vh, 46px); overflow: hidden;
        }
        .calh-bg { position: absolute; inset: 0; pointer-events: none;
            background:
                radial-gradient(58% 46% at 50% 40%, rgba(99,102,241,.22), transparent 62%),
                radial-gradient(42% 34% at 63% 64%, rgba(34,211,238,.13), transparent 60%);
        }
        .calh-bg::before { content: ''; position: absolute; left: 50%; top: 40%; transform: translate(-50%, -50%);
            width: min(680px, 86vh); height: min(680px, 86vh); border-radius: 50%;
            background: repeating-radial-gradient(circle, rgba(148,163,184,.09) 0 1px, transparent 1px 48px);
            -webkit-mask: radial-gradient(circle, #000 44%, transparent 72%);
                    mask: radial-gradient(circle, #000 44%, transparent 72%);
            opacity: .7;
        }

        .cal-orb { position: relative; z-index: 1; width: min(330px, 42vh); height: min(330px, 42vh); }
        .cal-orb-glass {
            position: absolute; inset: 0; border-radius: 50%; overflow: hidden;
            cursor: grab; touch-action: none;
            background:
                radial-gradient(120% 120% at 32% 24%, rgba(226,232,240,.52), rgba(148,163,184,.14) 30%, rgba(30,41,59,.3) 58%, rgba(2,6,23,.62) 100%),
                radial-gradient(100% 100% at 50% 132%, rgba(99,102,241,.34), transparent 60%),
                radial-gradient(80% 80% at 72% 80%, rgba(34,211,238,.16), transparent 55%);
            box-shadow:
                inset 0 3px 10px rgba(226,232,240,.34),
                inset 0 -22px 46px rgba(2,6,23,.66),
                inset 0 0 0 1px rgba(148,163,184,.28),
                inset 0 0 42px rgba(99,102,241,.14),
                0 40px 80px -24px rgba(0,0,0,.72),
                0 0 60px -10px rgba(99,102,241,.4);
            transition: box-shadow .55s ease;
        }
        .cal-orb-glass:active { cursor: grabbing; }
        .cal-orb.is-cal .cal-orb-glass {
            box-shadow:
                inset 0 3px 10px rgba(226,232,240,.34),
                inset 0 -22px 46px rgba(2,6,23,.66),
                inset 0 0 0 1px rgba(52,211,153,.5),
                inset 0 0 44px rgba(16,185,129,.2),
                0 40px 80px -24px rgba(0,0,0,.72),
                0 0 66px -8px rgba(16,185,129,.5);
        }
        .cal-orb-shine {
            position: absolute; top: 6%; left: 12%; width: 48%; height: 34%; border-radius: 50%;
            background: radial-gradient(closest-side, rgba(255,255,255,.82), rgba(255,255,255,0));
            transform: rotate(-18deg); filter: blur(2px); pointer-events: none; z-index: 3;
        }
        .cal-orb-svg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 2; display: block; }
        .cal-track { fill: none; stroke: rgba(148,163,184,.26); stroke-width: 4.5; stroke-linecap: round; }
        .cal-err { fill: none; stroke: url(#calGrad); stroke-width: 4.5; stroke-linecap: round; }
        .cal-orb.is-cal .cal-err { stroke: url(#calGradOk); }
        .cal-tick { stroke: rgba(148,163,184,.42); stroke-width: 1.4; }
        .cal-tick.maj { stroke: rgba(203,213,225,.62); stroke-width: 2.3; }
        .cal-tick.zero { stroke: #818cf8; stroke-width: 2.8; }
        .cal-needle { stroke: #c7d2fe; stroke-width: 2.4; stroke-linecap: round; filter: drop-shadow(0 0 3px rgba(129,140,248,.75)); }
        .cal-hub { fill: #a5b4fc; } .cal-hub-in { fill: #0a0d17; }
        .cal-check { opacity: 0; transform: scale(.4); transform-origin: 100px 66px; transition: opacity .3s, transform .3s cubic-bezier(.34,1.56,.5,1); }
        .cal-orb.is-cal .cal-check { opacity: 1; transform: scale(1); }
        .cal-orb-readout {
            position: absolute; left: 0; right: 0; bottom: 22%; text-align: center; z-index: 3;
            font-family: ui-monospace, Consolas, monospace; font-size: clamp(.82rem, 1.7vh, 1.06rem); font-weight: 700;
            letter-spacing: .02em; color: #c7d2fe; pointer-events: none; font-variant-numeric: tabular-nums;
            text-shadow: 0 0 12px rgba(99,102,241,.5);
        }
        .cal-orb.is-cal .cal-orb-readout { color: #6ee7b7; text-shadow: 0 0 12px rgba(16,185,129,.5); }
        .cal-orb-hint {
            position: absolute; left: 50%; bottom: -32px; transform: translateX(-50%);
            font-size: .72rem; letter-spacing: .05em; color: rgba(203,213,225,.5); white-space: nowrap;
            opacity: 0; transition: opacity .25s; pointer-events: none;
        }
        .cal-orb:hover .cal-orb-hint { opacity: .9; }

        .calh-brand { position: relative; z-index: 1; text-align: center; }
        .calh-word {
            font-size: clamp(1.9rem, 4.6vh, 2.8rem); font-weight: 800; letter-spacing: -.02em; line-height: 1;
            background: linear-gradient(115deg, #e0e7ff 0%, #a5b4fc 46%, #67e8f9 100%);
            -webkit-background-clip: text; background-clip: text; color: transparent;
        }
        .calh-tag {
            margin-top: 11px; font-size: clamp(.6rem, 1.2vh, .74rem); letter-spacing: .32em;
            font-weight: 600; color: rgba(165,180,252,.62);
        }

        @@media (max-width: 860px) {
            .cal-hero { gap: 10px; flex-direction: row; }
            .cal-orb { width: 96px; height: 96px; }
            .calh-bg::before { width: 320px; height: 320px; }
            .calh-word { font-size: 1.5rem; } .calh-tag { display: none; }
            .cal-orb-hint { display: none; }
        }
        @@media (prefers-reduced-motion: reduce) { .cal-check { transition: none; } }
    </style>
</head>
<body class="login-page app-theme-@runtime.ThemeCode"
      data-reset-workspace-tabs="1">
<!-- Tema toggle — sag ust kose -->
<button type="button" id="btnThemeToggle" class="login-theme-toggle" title="Tema değiştir" aria-label="Tema değiştir">
    <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
    </svg>
    <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
    </svg>
</button>
<script>
    (function () {
        var TK = 'calibra_theme';
        var body = document.body;
        var btn  = document.getElementById('btnThemeToggle');
        var themeInput = document.getElementById('loginThemeInput');
        var form = document.getElementById('loginForm');

        // localStorage tercihini hem UI'a hem hidden input'a uygula
        function applyTheme(t) {
            body.classList.remove('app-theme-light', 'app-theme-dark');
            body.classList.add('app-theme-' + t);
            if (themeInput) themeInput.value = t;
            try { localStorage.setItem(TK, t); } catch (e) {}
        }

        var saved = null;
        try { saved = localStorage.getItem(TK); } catch (e) {}
        if (saved === 'dark' || saved === 'light') { applyTheme(saved); }
        else if (themeInput) { themeInput.value = body.classList.contains('app-theme-dark') ? 'dark' : 'light'; }

        function currentTheme() {
            return body.classList.contains('app-theme-dark') ? 'dark' : 'light';
        }
        btn.addEventListener('click', function () {
            applyTheme(currentTheme() === 'dark' ? 'light' : 'dark');
        });
    })();
</script>
<div class="login-shell">
    <section class="login-hero" aria-hidden="true">
        @* 2026-07-11: Statik marka görseli yerine interaktif kalibrasyon sahnesi —
           cam küre içinde hareketli kadran (açılışta oto-kalibrasyon + sürükleyerek
           yeniden kalibre). Eski görsel ~/Document/CalibraHubLoginLogo.png korunuyor. *@
        <div class="cal-hero">
            <div class="calh-bg"></div>
            <div class="cal-orb" id="calOrb" title="Sürükleyerek kalibre edin" aria-label="CalibraHub kalibrasyon amblemi">
                <div class="cal-orb-glass" id="calGlass">
                    <svg class="cal-orb-svg" viewBox="0 0 200 200" aria-hidden="true">
                        <defs>
                            <linearGradient id="calGrad" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0" stop-color="#6366f1" /><stop offset="1" stop-color="#22d3ee" />
                            </linearGradient>
                            <linearGradient id="calGradOk" x1="0" y1="0" x2="1" y2="1">
                                <stop offset="0" stop-color="#22d3ee" /><stop offset="1" stop-color="#34d399" />
                            </linearGradient>
                        </defs>
                        <path class="cal-track" pathLength="100" d="M47.72 152.28 A74 74 0 1 1 152.28 152.28" />
                        <path class="cal-err" id="calErr" pathLength="100" d="M47.72 152.28 A74 74 0 1 1 152.28 152.28" stroke-dasharray="0 100" />
                        <g id="calTicks"></g>
                        <g class="cal-check" fill="none" stroke="#34d399" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M90 66 l6.5 7 14 -15" />
                        </g>
                        <g id="calNeedle">
                            <line class="cal-needle" x1="100" y1="107" x2="100" y2="47" />
                        </g>
                        <circle class="cal-hub" cx="100" cy="100" r="7" />
                        <circle class="cal-hub-in" cx="100" cy="100" r="2.6" />
                    </svg>
                    <div class="cal-orb-shine"></div>
                    <div class="cal-orb-readout"><span id="calVal">+0.00</span></div>
                </div>
                <span class="cal-orb-hint">sürükleyerek kalibre et</span>
            </div>
            <div class="calh-brand">
                <div class="calh-word">CalibraHub</div>
                <div class="calh-tag">Hassasiyet · Ölçüm · Kontrol</div>
            </div>
        </div>
    </section>

    <section class="login-panel">
        <div class="login-card">
            <h1>CalibraHub</h1>

            <form asp-action="Login" method="post" autocomplete="off" id="loginForm">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />
                <input type="hidden" name="ThemeCode" id="loginThemeInput" value="" />

                <div class="form-floating login-field mb-3">
                    @* a11y (rapor §6.6): autofocus + required + aria-required + class="cb-field-error" *@
                    <input asp-for="Email" class="form-control" autocomplete="email"
                           placeholder=" " autofocus required aria-required="true" />
                    <label asp-for="Email" class="cb-field-required">@ui.Text("email")</label>
                    <span asp-validation-for="Email" class="cb-field-error"></span>
                </div>

                <div class="form-floating login-field mb-3">
                    <select asp-for="CompanyId" asp-items="Model.CompanyOptions" class="form-select">
                        <option value="">@ui.Text("company_placeholder")</option>
                    </select>
                    <label asp-for="CompanyId">@ui.Text("company")</label>
                    <span asp-validation-for="CompanyId"></span>
                </div>

                <div class="form-floating login-field mb-3">
                    <input asp-for="Password" type="password" class="form-control"
                           autocomplete="current-password" placeholder=" " required aria-required="true" />
                    <label asp-for="Password" class="cb-field-required">@ui.Text("password")</label>
                    <span asp-validation-for="Password" class="cb-field-error"></span>
                </div>

                <div class="login-remember-row mb-3">
                    <label class="login-switch" for="rememberToggle">
                        <input type="checkbox" id="rememberToggle" />
                        <span class="login-switch-track"></span>
                    </label>
                    <span class="login-remember-label">Beni hatırla</span>
                </div>

                <div id="loginError" class="login-error-msg"></div>

                <button type="submit" class="btn btn-primary w-100">@ui.Text("submit")</button>

                <div class="text-center mt-3">
                    <a href="@Url.Action("ForgotPassword", "Account")" class="text-muted small"
                       style="text-decoration:none;opacity:.75;transition:opacity .15s"
                       onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='.75'">
                        Şifremi Unuttum
                    </a>
                </div>
            </form>

            @if (ViewBag.ShowSetupLink == true)
            {
                <div class="mt-4 pt-3 border-top text-center">
                    <p class="text-muted small mb-2">Sistemde henüz şirket tanımlanmamış.</p>
                    <a href="/Gate" class="btn btn-outline-secondary btn-sm">
                        İlk Kurulumu Yap
                    </a>
                </div>
            }


        </div>
    </section>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    (function () {
        const companyPlaceholderText = @Html.Raw(JsonSerializer.Serialize(ui.Text("company_placeholder")));
        const emailInput = document.getElementById("Email");
        const companySelect = document.getElementById("CompanyId");
        if (!emailInput || !companySelect) {
            return;
        }

        const endpoint = '@Url.Action("CompaniesForUser", "Account")';

        function renderCompanies(items) {
            const currentValue = companySelect.value;
            companySelect.innerHTML = "";

            const placeholder = document.createElement("option");
            placeholder.value = "";
            placeholder.textContent = companyPlaceholderText;
            companySelect.appendChild(placeholder);

            let hasCurrent = false;
            items.forEach(function (item) {
                const option = document.createElement("option");
                option.value = item.id;
                option.textContent = item.name;
                if (item.id === currentValue) {
                    option.selected = true;
                    hasCurrent = true;
                }

                companySelect.appendChild(option);
            });

            if (!hasCurrent) {
                companySelect.value = "";
            }
        }

        async function loadCompanies() {
            const email = emailInput.value.trim();
            if (!email) {
                renderCompanies([]);
                return;
            }

            try {
                const response = await fetch(endpoint + "?email=" + encodeURIComponent(email), {
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                if (!response.ok) {
                    renderCompanies([]);
                    return;
                }

                const data = await response.json();
                renderCompanies(Array.isArray(data) ? data : []);
            } catch {
                renderCompanies([]);
            }
        }

        emailInput.addEventListener("blur", loadCompanies);
        emailInput.addEventListener("change", loadCompanies);

        if (emailInput.value.trim().length > 0) {
            loadCompanies();
        }

        // Beni hatırla switch
        var rememberToggle = document.getElementById("rememberToggle");
        var rememberLabel = document.querySelector(".login-remember-label");
        var remembered = localStorage.getItem("calibra_login_remember") === "1";

        if (rememberToggle) {
            rememberToggle.checked = remembered;

            // Önceki oturumdan hatırlanan bilgileri yükle
            if (remembered && !emailInput.value) {
                var savedEmail = localStorage.getItem("calibra_login_email");
                var savedCompany = localStorage.getItem("calibra_login_company");
                if (savedEmail) {
                    emailInput.value = savedEmail;
                    loadCompanies().then(function () {
                        if (savedCompany && companySelect) {
                            companySelect.value = savedCompany;
                        }
                    });
                }
            }

            if (rememberLabel) {
                rememberLabel.addEventListener("click", function () {
                    rememberToggle.checked = !rememberToggle.checked;
                });
            }
        }

        var loginForm = emailInput.closest("form");
        if (loginForm) {
            var pwInput = document.getElementById("Password");
            var pwWrap  = pwInput ? pwInput.closest(".login-field") : null;

            loginForm.addEventListener("submit", async function (e) {
                e.preventDefault();

                // Tema hidden input'u güncelle
                var themeInput = document.getElementById("loginThemeInput");
                if (themeInput) themeInput.value = document.body.classList.contains("app-theme-dark") ? "dark" : "light";

                // Beni hatırla
                if (rememberToggle && rememberToggle.checked) {
                    localStorage.setItem("calibra_login_remember", "1");
                    localStorage.setItem("calibra_login_email", emailInput.value.trim());
                    if (companySelect.value) localStorage.setItem("calibra_login_company", companySelect.value);
                } else {
                    localStorage.removeItem("calibra_login_remember");
                    localStorage.removeItem("calibra_login_email");
                    localStorage.removeItem("calibra_login_company");
                }

                // AJAX submit
                try {
                    var resp = await fetch(loginForm.action || window.location.href, {
                        method: "POST",
                        body: new FormData(loginForm),
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });
                    var json = await resp.json();

                    if (json.ok) {
                        window.location.href = json.redirect;
                        return;
                    }

                    var errorDiv = document.getElementById("loginError");
                    function showError(msg) {
                        if (errorDiv) { errorDiv.textContent = msg; errorDiv.classList.add("is-visible"); }
                    }
                    function clearError() {
                        if (errorDiv) { errorDiv.classList.remove("is-visible"); errorDiv.textContent = ""; }
                    }

                    if (json.error === "credentials") {
                        showError(json.message || "E-posta, şirket veya şifre hatalı.");
                        if (pwWrap && pwInput) {
                            pwInput.value = "";
                            pwWrap.classList.add("login-pw-error");
                            pwWrap.classList.remove("login-pw-shake");
                            void pwWrap.offsetWidth;
                            pwWrap.classList.add("login-pw-shake");
                            pwWrap.addEventListener("animationend", function () {
                                pwWrap.classList.remove("login-pw-shake");
                            }, { once: true });
                            pwInput.focus();
                            pwInput.addEventListener("input", function () {
                                pwWrap.classList.remove("login-pw-error");
                                clearError();
                            }, { once: true });
                        }
                    } else if (json.error === "locked") {
                        showError(json.message || "Hesap geçici olarak kilitlendi. Lütfen daha sonra tekrar deneyin.");
                        if (pwWrap && pwInput) {
                            pwInput.value = "";
                            pwInput.disabled = true;
                            setTimeout(function () { pwInput.disabled = false; }, 5000);
                        }
                    } else if (json.error === "validation") {
                        showError("Lütfen tüm alanları doldurun.");
                    }
                } catch {
                    // Network hatası: normal submit
                    loginForm.submit();
                }
            });
        }
    })();
</script>
<script>
    /* Kalibrasyon amblemi — cam küre içindeki kadran (sürükle-kalibre + açılış sıfırlama) */
    (function () {
        var orb    = document.getElementById('calOrb');
        if (!orb) return;
        var glass  = document.getElementById('calGlass');
        var needle = document.getElementById('calNeedle');
        var errArc = document.getElementById('calErr');
        var valEl  = document.getElementById('calVal');
        var ticksG = document.getElementById('calTicks');
        var NS = 'http://www.w3.org/2000/svg';
        var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        var CENTER = 50, SNAP = 3.2, BAND = 4;   // merkeze (kalibre) yakınlık eşikleri
        var cur = 0, dragging = false, raf = 0, idleRaf = 0;

        // ── Tick'ler: 0..100 her 5'te bir; 25'lik major; 50 (merkez) vurgulu ──
        for (var i = 0; i <= 20; i++) {
            var v = i * 5, a = (-135 + v / 100 * 270) * Math.PI / 180;
            var sn = Math.sin(a), cs = Math.cos(a);
            var r1 = (v === 50) ? 60 : 66, r2 = (v % 25 === 0) ? 84 : 80;
            var ln = document.createElementNS(NS, 'line');
            ln.setAttribute('x1', (100 + sn * r1).toFixed(2)); ln.setAttribute('y1', (100 - cs * r1).toFixed(2));
            ln.setAttribute('x2', (100 + sn * r2).toFixed(2)); ln.setAttribute('y2', (100 - cs * r2).toFixed(2));
            ln.setAttribute('class', 'cal-tick' + (v === 50 ? ' zero' : (v % 25 === 0 ? ' maj' : '')));
            ticksG.appendChild(ln);
        }

        function render(v) {
            cur = v;
            needle.setAttribute('transform', 'rotate(' + (-135 + v / 100 * 270).toFixed(2) + ' 100 100)');
            // Hata yayı: merkezden (50) iğneye kadar dolar
            if (v >= 50) errArc.setAttribute('stroke-dasharray', '0 50 ' + (v - 50).toFixed(2) + ' 100');
            else         errArc.setAttribute('stroke-dasharray', '0 ' + v.toFixed(2) + ' ' + (50 - v).toFixed(2) + ' 100');
            orb.classList.toggle('is-cal', Math.abs(v - 50) <= BAND);
            var dev = (v - 50) / 50;                 // -1.00 .. +1.00
            if (Math.abs(dev) < 0.01) dev = 0;
            valEl.textContent = (dev >= 0 ? '+' : '') + dev.toFixed(2);
        }

        function tween(to, dur, done) {
            cancelAnimationFrame(raf);
            var from = cur, t0 = null;
            orb.classList.add('cal-busy');
            (function step(ts) {
                if (t0 === null) t0 = ts;
                var k = Math.min(1, (ts - t0) / dur);
                render(from + (to - from) * (1 - Math.pow(1 - k, 3)));  // easeOutCubic
                if (k < 1) raf = requestAnimationFrame(step);
                else { orb.classList.remove('cal-busy'); if (done) done(); }
            })(performance.now());
        }

        // ── Boşta hafif titreşim — canlı enstrüman hissi ──
        function startIdle() {
            if (reduce) { render(CENTER); return; }
            var t0 = performance.now();
            (function loop(ts) {
                if (dragging) return;
                render(CENTER + Math.sin((ts - t0) / 950) * 0.5);
                idleRaf = requestAnimationFrame(loop);
            })(performance.now());
        }
        function stopIdle() { cancelAnimationFrame(idleRaf); }

        // ── Açılış: enstrüman kendini sıfırlar (sönümlü salınım → merkez) ──
        function calibrateSweep() {
            if (reduce) { render(CENTER); startIdle(); return; }
            cancelAnimationFrame(raf);
            var dur = 1950, t0 = null;
            (function step(ts) {
                if (t0 === null) t0 = ts;
                var t = (ts - t0) / dur;
                if (t >= 1) { render(CENTER); startIdle(); return; }
                render(CENTER + 50 * Math.cos(t * Math.PI * 3.1) * Math.exp(-t * 3.2));
                raf = requestAnimationFrame(step);
            })(performance.now());
        }

        // ── Sürükleyerek kalibrasyon ──
        function valFromEvent(e) {
            var rect = glass.getBoundingClientRect();
            var pt = e.touches ? e.touches[0] : e;
            var px = pt.clientX - (rect.left + rect.width / 2);
            var py = pt.clientY - (rect.top + rect.height / 2);
            var deg = Math.atan2(px, -py) * 180 / Math.PI;   // yukarı=0, saat yönü +
            if (deg < -135) deg = -135; if (deg > 135) deg = 135;
            var v = (deg + 135) / 270 * 100;
            if (Math.abs(v - CENTER) <= SNAP) v = CENTER;    // merkeze snap
            return v;
        }
        function onDown(e) {
            dragging = true; stopIdle(); cancelAnimationFrame(raf);
            render(valFromEvent(e)); e.preventDefault();
        }
        function onMove(e) { if (!dragging) return; render(valFromEvent(e)); e.preventDefault(); }
        function onUp() {
            if (!dragging) return; dragging = false;
            tween(CENTER, 700, startIdle);                   // bırakınca merkeze otur (kalibre)
        }
        glass.addEventListener('mousedown', onDown);
        window.addEventListener('mousemove', onMove);
        window.addEventListener('mouseup', onUp);
        glass.addEventListener('touchstart', onDown, { passive: false });
        window.addEventListener('touchmove', onMove, { passive: false });
        window.addEventListener('touchend', onUp);

        render(0);
        setTimeout(calibrateSweep, 260);
    })();
</script>
</body>
