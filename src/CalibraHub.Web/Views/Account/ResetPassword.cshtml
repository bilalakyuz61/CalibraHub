@model CalibraHub.Web.Models.Account.ResetPasswordInputModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifre Sıfırlama - CalibraHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body.app-theme-dark.login-page { background: #0a0d17 !important; }
        body.app-theme-dark .login-panel { background: linear-gradient(145deg, #0f172a, #0a0d17) !important; }
        body.app-theme-dark .login-hero { background: #0a0d17; }
        body.app-theme-dark .login-card {
            background: rgba(15,23,42,.88) !important;
            border: 1px solid rgba(148,163,184,.14) !important;
            box-shadow: 0 18px 48px rgba(0,0,0,.55) !important;
            backdrop-filter: blur(18px); color: #e2e8f0 !important;
        }
        body.app-theme-dark .login-card h1 { color: #f1f5f9 !important; }
        body.app-theme-dark .login-card .form-label,
        body.app-theme-dark .login-card label,
        body.app-theme-dark .login-field > label { color: #94a3b8 !important; }
        body.app-theme-dark .login-card .form-control { background-color: rgba(30,41,59,.65) !important; border-color: rgba(148,163,184,.22) !important; color: #e2e8f0 !important; }
        body.app-theme-dark .login-card .form-control:focus { border-color: #6366f1 !important; box-shadow: 0 0 0 3px rgba(99,102,241,.18) !important; }
        body.app-theme-dark .login-card .btn-primary { background: linear-gradient(135deg, #6366f1, #8b5cf6) !important; border: none !important; }
        body.app-theme-dark .login-card .text-muted { color: #94a3b8 !important; }
        .rp-success {
            background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.3);
            border-radius: 8px; padding: 16px; color: #065f46; text-align: center;
        }
        body.app-theme-dark .rp-success { color: #34d399; background: rgba(16,185,129,.08); }
        .pw-hint { font-size: 12px; color: #64748b; margin-top: 4px; }
        body.app-theme-dark .pw-hint { color: #94a3b8; }
    </style>
</head>
<body class="login-page app-theme-light" data-reset-workspace-tabs="1">
<div class="login-shell">
    <section class="login-hero" aria-hidden="true">
        <div class="login-hero-frame">
            <img src="~/Document/CalibraHubLoginLogo.png" alt="CalibraHub Software" />
        </div>
    </section>

    <section class="login-panel">
        <div class="login-card">
            <h1>Yeni Şifre</h1>

            @if (ViewBag.Success == true)
            {
                <div class="rp-success">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:block;margin:0 auto 8px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <strong>Şifreniz güncellendi.</strong><br />
                    <span class="text-muted small">Yeni şifrenizle giriş yapabilirsiniz.</span>
                </div>
                <div class="mt-4 text-center">
                    <a asp-action="Login" class="btn btn-primary w-100">Giriş Yap</a>
                </div>
            }
            else
            {
                <p class="text-muted small mb-4">Yeni şifrenizi belirleyin.</p>

                <form asp-action="ResetPassword" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Token" />

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating login-field mb-1">
                        <input asp-for="NewPassword" type="password" class="form-control"
                               placeholder=" " required autofocus />
                        <label asp-for="NewPassword">Yeni Şifre</label>
                        <span asp-validation-for="NewPassword" class="cb-field-error"></span>
                    </div>
                    <div class="pw-hint mb-3">En az 10 karakter, büyük/küçük harf, rakam ve özel karakter içermeli.</div>

                    <div class="form-floating login-field mb-4">
                        <input asp-for="ConfirmPassword" type="password" class="form-control"
                               placeholder=" " required />
                        <label asp-for="ConfirmPassword">Şifre Tekrar</label>
                        <span asp-validation-for="ConfirmPassword" class="cb-field-error"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Şifremi Güncelle</button>
                </form>
            }
        </div>
    </section>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
try {
    var t = localStorage.getItem('calibra_theme');
    if (t === 'dark') document.body.classList.replace('app-theme-light', 'app-theme-dark');
} catch {}
</script>
</body>
</html>
