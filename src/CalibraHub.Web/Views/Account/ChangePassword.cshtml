@model CalibraHub.Web.Models.Account.ChangePasswordInputModel
@{
    ViewData["Title"] = "Şifre Değiştir";
    var inWorkspace = string.Equals(Context.Request.Query["workspace"], "1", StringComparison.Ordinal)
                      || string.Equals(Context.Request.Headers["Sec-Fetch-Dest"], "iframe", StringComparison.OrdinalIgnoreCase);
}

@section Styles {
<style>
    .cp-wrap {
        max-width: 480px; margin: 32px auto; padding: 0 16px;
        font-family: inherit;
    }
    .cp-card {
        background: #ffffff; color: #0f172a;
        border: 1px solid #e2e8f0; border-radius: 14px;
        padding: 24px; box-shadow: 0 8px 24px rgba(15,23,42,.06);
    }
    body.app-theme-dark .cp-card {
        background: #0f172a; color: #e2e8f0;
        border-color: rgba(255,255,255,.1);
        box-shadow: 0 12px 36px rgba(0,0,0,.4);
    }

    .cp-head { display:flex; align-items:center; gap:14px; margin-bottom:20px; padding-bottom:18px; border-bottom: 1px solid rgba(148,163,184,.18); }
    .cp-icon {
        width:44px; height:44px; border-radius:12px;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color:#fff; display:flex; align-items:center; justify-content:center;
        box-shadow: 0 4px 12px rgba(99,102,241,.3);
    }
    .cp-icon svg { stroke: currentColor; }
    .cp-title { margin:0; font-size:1.05rem; font-weight:600; }
    .cp-subtitle { margin:3px 0 0 0; font-size:.78rem; color:#64748b; }
    body.app-theme-dark .cp-subtitle { color: #94a3b8; }

    .cp-row { display:flex; flex-direction:column; gap:6px; margin-bottom:14px; }
    .cp-label { font-size:.75rem; font-weight:600; color:#475569; letter-spacing:.04em; }
    body.app-theme-dark .cp-label { color: #94a3b8; }

    .cp-input-wrap { position: relative; display:flex; align-items:center; }
    .cp-input {
        flex: 1; padding:9px 38px 9px 12px; font-size:.88rem; font-family: inherit;
        border: 1px solid rgba(148,163,184,.4); border-radius: 8px;
        background:#fff; color:#0f172a; outline:none;
        transition: border-color .15s, box-shadow .15s;
        width: 100%;
    }
    body.app-theme-dark .cp-input {
        background:#020617; color:#e2e8f0; border-color: rgba(148,163,184,.3);
    }
    .cp-input:focus { border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,.18); }

    /* Göz ikonu — şifre göster/gizle toggle */
    .cp-eye {
        position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
        background: transparent; border: none; cursor: pointer;
        color: #94a3b8; padding: 4px; border-radius: 5px;
        display:flex; align-items:center; justify-content:center;
        transition: color .12s, background .12s;
    }
    .cp-eye:hover { color: #6366f1; background: rgba(99,102,241,.08); }
    body.app-theme-dark .cp-eye { color: #64748b; }
    body.app-theme-dark .cp-eye:hover { color: #a5b4fc; background: rgba(129,140,248,.12); }

    /* Şifre güç meter */
    .cp-strength { height: 4px; border-radius: 2px; background: rgba(148,163,184,.2); overflow:hidden; margin-top:6px; }
    .cp-strength-bar { height: 100%; width: 0%; transition: width .25s, background .25s; }
    .cp-strength-text { font-size: .72rem; color:#64748b; margin-top:4px; min-height: 16px; }
    body.app-theme-dark .cp-strength-text { color: #94a3b8; }

    .cp-actions { display:flex; justify-content:space-between; align-items:center; gap:10px; margin-top:18px; padding-top:16px; border-top: 1px solid rgba(148,163,184,.18); }
    .cp-btn {
        padding:9px 22px; border-radius:8px; font-size:.88rem; font-weight:600;
        border:1px solid transparent; cursor:pointer; font-family: inherit;
        transition: all .15s;
    }
    .cp-btn--primary { background:#6366f1; color:#fff; border-color:#6366f1; }
    .cp-btn--primary:hover { background:#4f46e5; border-color:#4f46e5; }
    .cp-btn--ghost { background:transparent; color:#475569; border-color: rgba(148,163,184,.4); }
    .cp-btn--ghost:hover { background: rgba(148,163,184,.1); }
    body.app-theme-dark .cp-btn--ghost { color:#cbd5e1; border-color: rgba(148,163,184,.3); }
    .cp-btn--link { color:#6366f1; text-decoration:none; font-size:.82rem; font-weight:600; }
    .cp-btn--link:hover { text-decoration: underline; }

    .cp-alert { padding:10px 14px; border-radius:8px; font-size:.85rem; margin-bottom:16px; }
    .cp-alert--ok  { background: rgba(16,185,129,.1); color:#047857; border: 1px solid rgba(16,185,129,.3); }
    .cp-alert--err { background: rgba(239,68,68,.1); color:#dc2626; border: 1px solid rgba(239,68,68,.3); }
    body.app-theme-dark .cp-alert--ok  { color:#34d399; }
    body.app-theme-dark .cp-alert--err { color:#fca5a5; }

    .cp-hint { font-size:.72rem; color:#64748b; margin-top:6px; }
    body.app-theme-dark .cp-hint { color: #94a3b8; }

    .field-validation-error { color:#dc2626; font-size:.78rem; margin-top:4px; }
    body.app-theme-dark .field-validation-error { color:#fca5a5; }
</style>
}

<div class="cp-wrap">
    <div class="cp-card">
        <div class="cp-head">
            <div class="cp-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            </div>
            <div>
                <h2 class="cp-title">Şifre Değiştir</h2>
                <p class="cp-subtitle">Güvenlik için yeni şifreniz en az 8 karakter olmalı.</p>
            </div>
        </div>

        @if (TempData["PasswordSuccess"] is string okMsg)
        {
            <div class="cp-alert cp-alert--ok">@okMsg</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="cp-alert cp-alert--err">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="ChangePassword" method="post" autocomplete="off">
            @Html.AntiForgeryToken()

            <div class="cp-row">
                <label class="cp-label" for="CurrentPassword">Mevcut Şifre</label>
                <div class="cp-input-wrap">
                    <input asp-for="CurrentPassword" class="cp-input" type="password" autocomplete="off" required />
                    <button type="button" class="cp-eye" data-toggle="CurrentPassword" title="Şifreyi göster/gizle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
            </div>

            <div class="cp-row">
                <label class="cp-label" for="NewPassword">Yeni Şifre</label>
                <div class="cp-input-wrap">
                    <input asp-for="NewPassword" id="NewPassword" class="cp-input" type="password" autocomplete="off" minlength="8" required />
                    <button type="button" class="cp-eye" data-toggle="NewPassword" title="Şifreyi göster/gizle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div class="cp-strength"><div class="cp-strength-bar" id="cpStrengthBar"></div></div>
                <div class="cp-strength-text" id="cpStrengthText">En az 8 karakter</div>
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>

            <div class="cp-row">
                <label class="cp-label" for="ConfirmNewPassword">Yeni Şifre (Tekrar)</label>
                <div class="cp-input-wrap">
                    <input asp-for="ConfirmNewPassword" id="ConfirmNewPassword" class="cp-input" type="password" autocomplete="off" minlength="8" required />
                    <button type="button" class="cp-eye" data-toggle="ConfirmNewPassword" title="Şifreyi göster/gizle">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div class="cp-hint" id="cpMatchHint"></div>
                <span asp-validation-for="ConfirmNewPassword" class="field-validation-error"></span>
            </div>

            <div class="cp-actions">
                <a class="cp-btn--link" asp-action="Profile">← Profil bilgileri</a>
                <div style="display:flex;gap:10px;">
                    @if (!inWorkspace)
                    {
                        <a class="cp-btn cp-btn--ghost" href="/">Vazgeç</a>
                    }
                    <button type="submit" class="cp-btn cp-btn--primary">Kaydet</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        // Göz ikonu — şifre göster/gizle
        document.querySelectorAll('.cp-eye').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var targetId = btn.getAttribute('data-toggle');
                var inp = document.getElementById(targetId) || document.querySelector('[name="' + targetId + '"]');
                if (!inp) return;
                inp.type = inp.type === 'password' ? 'text' : 'password';
            });
        });

        // Şifre güç meter
        var newPwd = document.getElementById('NewPassword');
        var confirmPwd = document.getElementById('ConfirmNewPassword');
        var bar = document.getElementById('cpStrengthBar');
        var txt = document.getElementById('cpStrengthText');
        var matchHint = document.getElementById('cpMatchHint');

        function scorePassword(p) {
            if (!p) return 0;
            var score = 0;
            if (p.length >= 8)  score += 1;
            if (p.length >= 12) score += 1;
            if (/[a-z]/.test(p) && /[A-Z]/.test(p)) score += 1;
            if (/\d/.test(p)) score += 1;
            if (/[^A-Za-z0-9]/.test(p)) score += 1;
            return Math.min(score, 5);
        }
        var levels = [
            { w: 0,   c: 'rgba(148,163,184,.3)', t: 'En az 8 karakter' },
            { w: 20,  c: '#ef4444',              t: 'Çok zayıf' },
            { w: 40,  c: '#f97316',              t: 'Zayıf' },
            { w: 60,  c: '#eab308',              t: 'Orta' },
            { w: 80,  c: '#22c55e',              t: 'Güçlü' },
            { w: 100, c: '#10b981',              t: 'Çok güçlü' },
        ];

        function updateStrength() {
            var s = scorePassword(newPwd.value);
            var lv = levels[s];
            bar.style.width = lv.w + '%';
            bar.style.background = lv.c;
            txt.textContent = lv.t;
            txt.style.color = s >= 3 ? lv.c : '';
        }
        function updateMatch() {
            if (!confirmPwd.value) { matchHint.textContent = ''; return; }
            if (confirmPwd.value === newPwd.value) {
                matchHint.textContent = '✓ Şifreler uyuşuyor';
                matchHint.style.color = '#10b981';
            } else {
                matchHint.textContent = '✗ Şifreler uyuşmuyor';
                matchHint.style.color = '#ef4444';
            }
        }
        if (newPwd) newPwd.addEventListener('input', function () { updateStrength(); updateMatch(); });
        if (confirmPwd) confirmPwd.addEventListener('input', updateMatch);
    })();
    </script>
}
