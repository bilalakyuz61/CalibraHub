@model CalibraHub.Web.Models.Account.ChangePasswordInputModel
@inject CalibraHub.Web.Infrastructure.Ui.IUiTextService UiText
@{
    var ui = await UiText.GetFormAsync("account.change_password");
    ViewData["Title"] = ui.Text("title");
}

<section class="panel auth-panel">
    <h1>@ui.Text("title")</h1>
    <p class="text-muted">@ui.Text("subtitle")</p>

    <form asp-action="ChangePassword" method="post" class="mt-3" autocomplete="off">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="CurrentPassword" class="form-label">@ui.Text("current_password")</label>
            <input asp-for="CurrentPassword" class="form-control" autocomplete="off" />
            <span asp-validation-for="CurrentPassword"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">@ui.Text("new_password")</label>
            <input asp-for="NewPassword" class="form-control" autocomplete="off" />
            <span asp-validation-for="NewPassword"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmNewPassword" class="form-label">@ui.Text("confirm_password")</label>
            <input asp-for="ConfirmNewPassword" class="form-control" autocomplete="off" />
            <span asp-validation-for="ConfirmNewPassword"></span>
        </div>

        <button type="submit" class="btn btn-primary">@ui.Text("submit")</button>
    </form>
</section>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}

