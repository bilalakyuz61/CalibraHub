@model CalibraHub.Web.Models.Arge.ArgeProjectsViewModel
@using System.Text.Json
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@{
    ViewData["Title"] = "AR-GE Projeleri";
    ViewData["FormCode"] = "ARGE_PROJECT_EDIT";
    ViewData["BodyClass"] = "page-arge-projects";

    var jsonOpts = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        WriteIndented = false,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };
    var boardConfigJson = Model.BoardConfig != null
        ? JsonSerializer.Serialize(Model.BoardConfig, jsonOpts)
        : "null";
}

<style>
    .page-arge-projects .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .workspace-frame-body.page-arge-projects .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-arge-projects .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }
</style>

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">
    <div id="reactSmartBoard" style="flex:1 1 auto;min-height:0;overflow:hidden;"></div>
</section>

<script>
(function () {
    var BOARD_CONFIG = @Html.Raw(boardConfigJson);
    var BUNDLE_URL = '@FileVersionProvider.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js")';
    var CSS_URL = '@FileVersionProvider.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css")';

    var el = document.getElementById('reactSmartBoard');
    if (!el) { return; }

    function showError(msg) {
        el.innerHTML = '<div style="display:flex;align-items:center;justify-content:center;height:100%;min-height:300px;color:#ef4444;font-size:14px;">' + msg + '</div>';
    }

    function doMount() {
        if (!BOARD_CONFIG) { showError('Board config bulunamadı'); return; }
        if (!window.CalibraHub || !window.CalibraHub.mountSmartBoard) { showError('SmartBoard mount fonksiyonu bulunamadı'); return; }
        try { window.CalibraHub.mountSmartBoard(el, BOARD_CONFIG); }
        catch (ex) { console.error('[Arge] Mount exception:', ex); showError('Mount hatası: ' + (ex.message || ex)); }
    }

    function loadCss() {
        if (document.querySelector('link[data-arge-smartboard]')) return;
        var link = document.createElement('link');
        link.rel = 'stylesheet'; link.href = CSS_URL;
        link.setAttribute('data-arge-smartboard', '1');
        document.head.appendChild(link);
    }

    function loadScript(cb) {
        if (document.querySelector('script[data-arge-smartboard]')) { cb(); return; }
        var script = document.createElement('script');
        script.src = BUNDLE_URL;
        script.setAttribute('data-arge-smartboard', '1');
        script.onload = function () { setTimeout(cb, 0); };
        script.onerror = function () { showError('Bundle yüklenemedi'); };
        document.head.appendChild(script);
    }

    loadCss();
    if (window.CalibraHub && window.CalibraHub.mountSmartBoard) doMount();
    else loadScript(doMount);
})();
</script>
