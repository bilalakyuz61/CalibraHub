@using CalibraHub.Application.Contracts
@model CalibraHub.Web.Models.Approval.ApprovalPanelViewModel
@{
    var inst = Model.Instance;
    var hasInstance = inst is not null;
    var isPending = hasInstance && inst!.Status == "Pending";
    var isApproved = hasInstance && inst!.Status == "Approved";
    var isRejected = hasInstance && inst!.Status == "Rejected";
    var isCancelled = hasInstance && inst!.Status == "Cancelled";
    var antiforgery = Html.AntiForgeryToken().ToString() ?? "";

    // DueDate pill — Pending adimlarda gosterilir. Gecmis = kirmizi, 24sa icinde = sari.
    Func<ApprovalStepRecordDto, Microsoft.AspNetCore.Html.IHtmlContent> renderDuePill = step =>
    {
        var html = "";
        if (step.Status == "Pending" && step.DueDate.HasValue)
        {
            var dueLocal = step.DueDate.Value.ToLocalTime();
            var nowLocal = DateTime.Now;
            var hoursLeft = (dueLocal - nowLocal).TotalHours;
            string cls = hoursLeft < 0 ? "ap-due--overdue" : hoursLeft < 24 ? "ap-due--warning" : "ap-due--normal";
            string label = hoursLeft < 0
                ? $"Suresi asildi — {dueLocal:dd.MM.yyyy HH:mm}"
                : $"Son: {dueLocal:dd.MM.yyyy HH:mm}";
            html += $"<span class=\"ap-due {cls}\" title=\"SLA bitis tarihi\"><svg width=\"10\" height=\"10\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg>{System.Net.WebUtility.HtmlEncode(label)}</span>";
        }
        if (!string.IsNullOrWhiteSpace(step.SlaActionType))
        {
            var lbl = step.SlaActionType switch
            {
                "reminder"    => "SLA: hatirlatma gonderildi",
                "escalate"    => "SLA: eskale edildi",
                "autoApprove" => "SLA: otomatik onaylandi",
                "autoReject"  => "SLA: otomatik reddedildi",
                _ => "SLA aksiyonu"
            };
            html += $"<span class=\"ap-sla-action\" title=\"{System.Net.WebUtility.HtmlEncode(step.SlaActionAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "")}\">{System.Net.WebUtility.HtmlEncode(lbl)}</span>";
        }
        return new Microsoft.AspNetCore.Html.HtmlString(html);
    };
}

<style>
.ap-panel { font-size: .875rem; color: var(--bs-body-color); }
.ap-status-bar {
    display: flex; align-items: center; gap: 10px; padding: 12px 16px;
    border-radius: 10px; margin-bottom: 16px; font-weight: 600;
}
.ap-status-bar--pending  { background: rgba(99,102,241,.1);  color: #6366f1; }
.ap-status-bar--approved { background: rgba(16,185,129,.1);  color: #10b981; }
.ap-status-bar--rejected { background: rgba(239,68,68,.1);   color: #ef4444; }
.ap-status-bar--none     { background: rgba(100,116,139,.1); color: #64748b; }
.ap-step-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
.ap-step { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px;
    border: 1px solid rgba(0,0,0,.07); }
body.app-theme-dark .ap-step { border-color: rgba(255,255,255,.07); }
.ap-step__badge {
    width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: .75rem; font-weight: 700; flex-shrink: 0;
}
.ap-step__badge--pending  { background: rgba(99,102,241,.12); color: #6366f1; }
.ap-step__badge--approved { background: rgba(16,185,129,.12); color: #10b981; }
.ap-step__badge--rejected { background: rgba(239,68,68,.12);  color: #ef4444; }
.ap-step__info { flex: 1 1 auto; }
.ap-step__name { font-weight: 600; }
.ap-step__meta { font-size: .78rem; color: #64748b; }
.ap-select { width: 100%; padding: 8px 10px; border: 1px solid rgba(0,0,0,.15);
    border-radius: 8px; font-size: .85rem; background: var(--bs-body-bg); color: var(--bs-body-color); }
.ap-textarea { width: 100%; padding: 8px 10px; border: 1px solid rgba(0,0,0,.15);
    border-radius: 8px; font-size: .85rem; resize: vertical; min-height: 64px;
    background: var(--bs-body-bg); color: var(--bs-body-color); }
.ap-btn { padding: 8px 18px; border-radius: 8px; border: none; cursor: pointer; font-size: .85rem; font-weight: 600; }
.ap-btn--approve { background: #10b981; color: #fff; }
.ap-btn--reject  { background: #ef4444; color: #fff; }
.ap-btn--start   { background: #6366f1; color: #fff; }
.ap-btn--cancel  { background: transparent; border: 1px solid rgba(0,0,0,.15); color: #64748b; }
.ap-btn:disabled { opacity: .5; pointer-events: none; }
.ap-msg { font-size: .82rem; margin-top: 6px; }
.ap-msg--ok  { color: #10b981; }
.ap-msg--err { color: #ef4444; }
.ap-due {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 2px 8px; border-radius: 999px; font-size: .72rem; font-weight: 600;
    margin-left: 6px;
}
.ap-due--normal   { background: rgba(99,102,241,.10); color: #6366f1; }
.ap-due--warning  { background: rgba(245,158,11,.15); color: #d97706; }
.ap-due--overdue  { background: rgba(239,68,68,.15);  color: #dc2626; }
.ap-sla-action {
    display: inline-flex; align-items: center;
    padding: 1px 6px; border-radius: 4px; font-size: .68rem; font-weight: 600;
    margin-left: 4px; background: rgba(100,116,139,.15); color: #475569;
}
</style>

<div class="ap-panel" id="apPanel_@(Model.DocumentId.ToString("N"))">

    @if (!hasInstance)
    {
        <!-- Henüz akış başlatılmamış -->
        <div class="ap-status-bar ap-status-bar--none">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            Henüz onay akışı başlatılmamış
        </div>

        @if (Model.AvailableFlows.Count == 0)
        {
            <p style="color:#64748b; font-size:.85rem;">Bu belge türü (@Model.DocumentKind) için tanımlı onay akışı bulunmuyor.
                <a href="/ApprovalFlow/Edit?id=0" target="_blank">Yeni akış oluştur →</a>
            </p>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:10px;">
                <div>
                    <label style="font-size:.78rem;font-weight:600;color:#64748b;">Onay Akışı Seçin</label>
                    <select class="ap-select mt-1" id="apFlowSelect_@(Model.DocumentId.ToString("N"))">
                        @foreach (var f in Model.AvailableFlows)
                        {
                            <option value="@f.Id">@f.Name (@f.StepCount adım)</option>
                        }
                    </select>
                </div>
                <div>
                    <button class="ap-btn ap-btn--start" onclick="apStartFlow('@Model.DocumentId.ToString("N")')">
                        İşleme Al — Onay Başlat
                    </button>
                    <span class="ap-msg" id="apMsg_@(Model.DocumentId.ToString("N"))"></span>
                </div>
            </div>
        }
    }
    else if (isPending)
    {
        var currentRecord = inst!.StepRecords.FirstOrDefault(s => s.StepOrder == inst.CurrentStep);
        var pendingOrderedSteps = inst.StepRecords.OrderBy(s => s.StepOrder).ToList();
        var currentSeqStep = pendingOrderedSteps.Select((s, i) => new { s, i })
            .FirstOrDefault(x => x.s.StepOrder == inst.CurrentStep)?.i + 1 ?? 1;
        <!-- Bekleyen onay -->
        <div class="ap-status-bar ap-status-bar--pending">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            Onay Bekliyor — @inst.FlowName
        </div>

        <ul class="ap-step-list mb-3">
            @for (int psi = 0; psi < pendingOrderedSteps.Count; psi++)
            {
                var step = pendingOrderedSteps[psi];
                var seqNo = psi + 1;
                var isCurrent = step.StepOrder == inst.CurrentStep;
                var stepClass = step.Status == "Approved" ? "ap-step__badge--approved"
                              : step.Status == "Rejected" ? "ap-step__badge--rejected"
                              : "ap-step__badge--pending";
                var stepIcon = step.Status == "Approved" ? "✓"
                             : step.Status == "Rejected" ? "✕"
                             : seqNo.ToString();
                <li class="ap-step" style="@(isCurrent ? "border-color:#6366f1;" : "")">
                    <span class="ap-step__badge @stepClass">@stepIcon</span>
                    <div class="ap-step__info">
                        <div class="ap-step__name">@step.StepName @(isCurrent ? "← mevcut adım" : "") @renderDuePill(step)</div>
                        @if (step.Status != "Pending" && step.ApproverName is not null)
                        {
                            <div class="ap-step__meta">@step.ApproverName · @step.ActionDate?.ToString("dd.MM.yyyy HH:mm") @(step.Note is not null ? "· \"" + step.Note + "\"" : "")</div>
                        }
                    </div>
                    <span style="font-size:.75rem;color:#94a3b8;">@step.Status</span>
                </li>
            }
        </ul>

        <!-- Onay / Red alanı -->
        <div style="border-top:1px solid rgba(0,0,0,.07);padding-top:14px;display:flex;flex-direction:column;gap:10px;">
            <div>
                <label style="font-size:.78rem;font-weight:600;color:#64748b;">Not (opsiyonel)</label>
                <textarea class="ap-textarea mt-1" id="apNote_@(Model.DocumentId.ToString("N"))" placeholder="Onay/red notu..."></textarea>
            </div>
            <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
                <button class="ap-btn ap-btn--approve" onclick="apApprove('@Model.DocumentId.ToString("N")', @inst.Id)">
                    ✓ Onayla (@currentSeqStep/@inst.TotalSteps. Adım)
                </button>
                <button class="ap-btn ap-btn--reject" onclick="apReject('@Model.DocumentId.ToString("N")', @inst.Id)">
                    ✕ Reddet
                </button>
                <button class="ap-btn ap-btn--cancel" onclick="apCancel('@Model.DocumentId.ToString("N")', @inst.Id)">
                    İptal
                </button>
                <span class="ap-msg" id="apMsg_@(Model.DocumentId.ToString("N"))"></span>
            </div>
        </div>
    }
    else if (isApproved)
    {
        <div class="ap-status-bar ap-status-bar--approved">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            Onaylandı — @inst!.FlowName
        </div>
        <ul class="ap-step-list">
            @foreach (var step in inst!.StepRecords.OrderBy(s => s.StepOrder))
            {
                <li class="ap-step">
                    <span class="ap-step__badge ap-step__badge--approved">✓</span>
                    <div class="ap-step__info">
                        <div class="ap-step__name">@step.StepName @renderDuePill(step)</div>
                        <div class="ap-step__meta">@step.ApproverName · @step.ActionDate?.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                </li>
            }
        </ul>
    }
    else if (isRejected)
    {
        <div class="ap-status-bar ap-status-bar--rejected">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
            Reddedildi — @inst!.FlowName
        </div>
        @if (!string.IsNullOrWhiteSpace(inst!.RejectNote))
        {
            <p style="background:rgba(239,68,68,.08);border-radius:8px;padding:10px 14px;color:#ef4444;font-size:.85rem;">
                Red notu: @inst.RejectNote
            </p>
        }
        <ul class="ap-step-list">
            @{ var rejectedOrderedSteps = inst.StepRecords.OrderBy(s => s.StepOrder).ToList(); }
            @for (int rsi = 0; rsi < rejectedOrderedSteps.Count; rsi++)
            {
                var step = rejectedOrderedSteps[rsi];
                var cls = step.Status == "Approved" ? "ap-step__badge--approved"
                        : step.Status == "Rejected" ? "ap-step__badge--rejected"
                        : "ap-step__badge--pending";
                var ico = step.Status == "Approved" ? "✓" : step.Status == "Rejected" ? "✕" : (rsi + 1).ToString();
                <li class="ap-step">
                    <span class="ap-step__badge @cls">@ico</span>
                    <div class="ap-step__info">
                        <div class="ap-step__name">@step.StepName @renderDuePill(step)</div>
                        @if (step.ApproverName is not null)
                        {
                            <div class="ap-step__meta">@step.ApproverName · @step.ActionDate?.ToString("dd.MM.yyyy HH:mm") @(step.Note is not null ? $"· \"{step.Note}\"" : "")</div>
                        }
                    </div>
                </li>
            }
        </ul>
    }
    else
    {
        <div class="ap-status-bar ap-status-bar--none">İptal Edildi</div>
    }

</div>

<script>
(function () {
    var CSRF = '@Html.AntiForgeryToken()'.replace(/<[^>]+>/g,'').replace(/value="([^"]+)".*/, '$1').trim();
    // CSRF token'ı input[name="__RequestVerificationToken"]'dan al
    CSRF = (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value || '';

    async function post(url, params) {
        var body = new URLSearchParams(params);
        var r = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': CSRF },
            body: body.toString(),
        });
        return r.json();
    }

    function setMsg(key, text, ok) {
        var el = document.getElementById('apMsg_' + key);
        if (!el) return;
        el.textContent = text;
        el.className = 'ap-msg ' + (ok ? 'ap-msg--ok' : 'ap-msg--err');
    }

    window.apStartFlow = async function(key) {
        var sel = document.getElementById('apFlowSelect_' + key);
        var flowId = sel ? parseInt(sel.value) : 0;
        var docId = '@Model.DocumentId';
        setMsg(key, 'İşleme alınıyor…', true);
        var d = await post('/Approval/StartApproval', { documentId: docId, flowId: flowId });
        if (d.ok) {
            setMsg(key, 'Onay akışı başlatıldı.', true);
            setTimeout(function() { location.reload(); }, 800);
        } else {
            setMsg(key, 'Hata: ' + (d.error || ''), false);
        }
    };

    window.apApprove = async function(key, instanceId) {
        var note = (document.getElementById('apNote_' + key) || {}).value || '';
        setMsg(key, 'Onaylanıyor…', true);
        var d = await post('/Approval/ApproveStep', { instanceId: instanceId, note: note });
        if (d.ok) {
            setMsg(key, d.status === 'Approved' ? 'Tüm adımlar onaylandı!' : 'Adım onaylandı, sonraki adım bekleniyor.', true);
            setTimeout(function() { location.reload(); }, 800);
        } else {
            setMsg(key, 'Hata: ' + (d.error || ''), false);
        }
    };

    window.apReject = async function(key, instanceId) {
        var note = (document.getElementById('apNote_' + key) || {}).value || '';
        if (!note.trim()) { setMsg(key, 'Red için not zorunludur.', false); return; }
        setMsg(key, 'Reddediliyor…', true);
        var d = await post('/Approval/RejectApproval', { instanceId: instanceId, note: note });
        if (d.ok) {
            setMsg(key, 'Reddedildi.', false);
            setTimeout(function() { location.reload(); }, 800);
        } else {
            setMsg(key, 'Hata: ' + (d.error || ''), false);
        }
    };

    window.apCancel = async function(key, instanceId) {
        setMsg(key, 'İptal ediliyor…', true);
        var d = await post('/Approval/CancelApproval', { instanceId: instanceId });
        if (d.ok) {
            setMsg(key, 'İptal edildi.', true);
            setTimeout(function() { location.reload(); }, 800);
        } else {
            setMsg(key, 'Hata: ' + (d.error || ''), false);
        }
    };
})();
</script>
