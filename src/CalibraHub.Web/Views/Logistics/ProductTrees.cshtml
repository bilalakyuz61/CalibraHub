@{
    ViewData["Title"] = ViewBag.Title;
    ViewData["BodyClass"] = "page-product-trees";
}

@section Styles {
<style>
    /* ── Page-level overrides ── */
    .page-product-trees { --workspace-action-bar-height: 0px; }
    .page-product-trees .workspace-tabs { position:relative;top:unset;flex:0 0 auto;border-bottom:1px solid var(--app-border,#dde3ee);z-index:2; }
    .page-product-trees .workspace-tabs[hidden] { display:block !important;min-height:42px;visibility:hidden;pointer-events:none; }
    .page-product-trees .workspace-action-bar { display:none !important; }
    .page-product-trees .app-content-area { display:flex;flex-direction:column;overflow:hidden; }
    .page-product-trees .integrator-dashboard { flex:1 1 0;min-height:0;display:flex;flex-direction:column; }
    .page-product-trees .integrator-dashboard__content {
        flex:1 1 0;min-height:0;width:auto !important;max-width:none !important;
        padding:0 !important;margin:0 !important;
        display:flex !important;flex-direction:column !important;overflow:hidden;
    }

    /* ── Action bar ── */
    .pte-action-bar {
        display:flex;align-items:center;gap:8px;padding:8px 16px;flex-shrink:0;
        background:rgba(15,15,26,0.85);border-bottom:1px solid rgba(255,255,255,0.06);
        backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
    }
    body.app-theme-light .pte-action-bar {
        background:rgba(248,250,252,0.92);border-bottom-color:#e2e8f0;
    }
    .pte-action-bar .pte-meta {
        margin-left:auto;font-size:0.72rem;color:rgba(255,255,255,0.55);font-weight:500;
    }
    body.app-theme-light .pte-action-bar .pte-meta { color:#94a3b8; }

    /* ── Buttons ── */
    .pte-btn {
        display:inline-flex;align-items:center;gap:6px;
        padding:7px 14px;border-radius:8px;border:1px solid;
        font-size:0.78rem;font-weight:600;cursor:pointer;
        transition:all 0.12s ease;background:transparent;
    }
    .pte-btn:disabled { opacity:0.5;cursor:not-allowed; }
    .pte-btn--primary { background:#6366f1;border-color:#4f46e5;color:#fff; }
    .pte-btn--primary:hover:not(:disabled) { background:#4f46e5; }
    .pte-btn--secondary {
        background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.65);
    }
    body.app-theme-light .pte-btn--secondary { background:#fff;border-color:#e2e8f0;color:#475569; }
    .pte-btn--secondary:hover:not(:disabled) { background:rgba(255,255,255,0.1);color:#fff; }
    body.app-theme-light .pte-btn--secondary:hover:not(:disabled) { background:#f1f5f9;color:#1e293b; }
    .pte-btn--danger {
        background:rgba(239,68,68,0.08);border-color:rgba(239,68,68,0.25);color:#f87171;
    }
    .pte-btn--danger:hover:not(:disabled) { background:rgba(239,68,68,0.18); }
    .pte-btn--sm { padding:5px 10px;font-size:0.72rem;border-radius:6px; }

    /* ── Body: sidenav + content ── */
    .pte-body { flex:1 1 0;min-height:0;display:flex;flex-direction:row;overflow:hidden; }

    /* ── Sidebar navigation ── */
    .pte-sidenav {
        width:192px;flex-shrink:0;display:flex;flex-direction:column;gap:2px;
        padding:12px 8px;
        background:rgba(255,255,255,0.02);border-right:1px solid rgba(255,255,255,0.07);
        overflow-y:auto;
    }
    body.app-theme-light .pte-sidenav {
        background:#f8fafc;border-right-color:#e2e8f0;
    }
    .pte-sidenav-label {
        font-size:0.7rem;font-weight:700;
        color:rgba(255,255,255,0.55);padding:8px 10px 4px;
    }
    body.app-theme-light .pte-sidenav-label { color:#94a3b8; }
    .pte-nav-btn {
        display:flex;align-items:center;gap:8px;width:100%;
        padding:9px 12px;border:none;background:transparent;cursor:pointer;
        font-size:0.78rem;font-weight:500;color:rgba(255,255,255,0.55);
        border-radius:8px;border-left:3px solid transparent;
        transition:all 0.12s;text-align:left;
    }
    body.app-theme-light .pte-nav-btn { color:#64748b; }
    .pte-nav-btn:hover { background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.8); }
    body.app-theme-light .pte-nav-btn:hover { background:rgba(99,102,241,0.05);color:#475569; }
    .pte-nav-btn.is-active {
        border-left-color:#6366f1;background:rgba(99,102,241,0.09);color:#a5b4fc;font-weight:600;
    }
    body.app-theme-light .pte-nav-btn.is-active {
        background:rgba(99,102,241,0.07);color:#4f46e5;
    }
    .pte-nav-dot {
        width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0;opacity:0.5;
    }
    .pte-nav-btn.is-active .pte-nav-dot { opacity:1; }
    .pte-nav-count {
        margin-left:auto;padding:1px 6px;border-radius:999px;
        font-size:0.6rem;font-weight:700;font-family:monospace;
        background:rgba(99,102,241,0.12);color:#a5b4fc;
        border:1px solid rgba(99,102,241,0.25);flex-shrink:0;
    }
    body.app-theme-light .pte-nav-count { background:rgba(99,102,241,0.08);color:#4f46e5; }

    /* ── Content area ── */
    .pte-content {
        flex:1 1 auto;min-width:0;overflow-y:auto;padding:20px 24px;background:transparent;
    }
    body.app-theme-dark .pte-content,
    html.dark .pte-content {
        background:#0c0f1a;
        background-image:radial-gradient(at 20% 30%,rgba(99,102,241,0.12) 0px,transparent 50%),
                         radial-gradient(at 80% 20%,rgba(14,165,233,0.08) 0px,transparent 50%),
                         radial-gradient(at 50% 80%,rgba(168,85,247,0.08) 0px,transparent 50%);
    }
    body.app-theme-light .pte-content { background:#f8fafc; }

    /* ── Cards ── */
    .pte-card {
        background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);
        border-radius:14px;padding:22px;
        backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
        margin-bottom:16px;
    }
    body.app-theme-light .pte-card {
        background:rgba(255,255,255,0.8);border-color:rgba(15,23,42,0.08);
        box-shadow:0 2px 6px rgba(15,23,42,0.04);
    }
    .pte-card-title {
        font-size:0.85rem;font-weight:700;
        color:rgba(255,255,255,0.85);
        margin:0 0 14px 0;display:flex;align-items:center;gap:8px;
    }
    body.app-theme-light .pte-card-title { color:#64748b; }
    .pte-card-title::before {
        content:'';width:6px;height:6px;border-radius:50%;background:#6366f1;
    }

    /* ── Form grid ── */
    .pte-grid { display:flex;flex-direction:column;gap:12px; }
    .pte-row { display:flex;align-items:center;gap:10px;flex-wrap:wrap; }
    .pte-field { display:flex;flex-direction:column;gap:5px; }
    .pte-label {
        font-size:0.72rem;font-weight:600;color:rgba(255,255,255,0.65);
        letter-spacing:0.02em;white-space:nowrap;flex-shrink:0;
    }
    body.app-theme-light .pte-label { color:#64748b; }
    .pte-label--req::after { content:' *';color:#f87171; }

    /* ── Inputs ── */
    .pte-input {
        padding:9px 12px;border-radius:9px;
        background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);
        color:rgba(255,255,255,0.85);font-size:0.85rem;
        transition:border-color 0.15s,background 0.15s;
        outline:none;
    }
    body.app-theme-light .pte-input { background:#fff;border-color:#e2e8f0;color:#1e293b; }
    .pte-input:focus {
        border-color:#6366f1;background:rgba(255,255,255,0.06);
        box-shadow:0 0 0 3px rgba(99,102,241,0.12);
    }
    body.app-theme-light .pte-input:focus { background:#fff; }
    .pte-input::placeholder { color:rgba(255,255,255,0.4); }
    body.app-theme-light .pte-input::placeholder { color:#94a3b8; }
    .pte-input[readonly] { opacity:0.7;cursor:default; }
    .pte-input.is-invalid {
        border-color:#ef4444;background:rgba(239,68,68,0.06);
        animation:pteShake 0.4s cubic-bezier(.36,.07,.19,.97) both;
    }
    .pte-input[type="number"] { text-align:right;-moz-appearance:textfield; }
    .pte-input[type="number"]::-webkit-outer-spin-button,
    .pte-input[type="number"]::-webkit-inner-spin-button { -webkit-appearance:none;margin:0; }

    /* ── Lookup ── */
    .pte-lookup {
        display:inline-flex;align-items:stretch;border-radius:9px;overflow:hidden;
    }
    .pte-lookup .pte-input { border-radius:9px 0 0 9px;border-right:0; }
    .pte-lookup-btn {
        display:flex;align-items:center;justify-content:center;width:36px;
        background:rgba(99,102,241,0.08);border:1px solid rgba(255,255,255,0.1);
        border-left:0;border-radius:0 9px 9px 0;cursor:pointer;
        color:#a5b4fc;transition:all 0.12s;
    }
    body.app-theme-light .pte-lookup-btn {
        background:rgba(99,102,241,0.06);border-color:#e2e8f0;color:#6366f1;
    }
    .pte-lookup-btn:hover { background:rgba(99,102,241,0.18); }

    /* ── Image area ── */
    .pte-image-area {
        display:flex;align-items:stretch;gap:10px;
        margin-top:16px;padding:14px;border-radius:12px;
        background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);
    }
    body.app-theme-light .pte-image-area {
        background:#fafbfd;border-color:rgba(15,23,42,0.06);
    }
    .pte-img-actions {
        display:flex;flex-direction:column;gap:6px;flex-shrink:0;
    }
    .pte-img-btn {
        width:32px;height:32px;border-radius:50%;border:1px solid;display:flex;
        align-items:center;justify-content:center;cursor:pointer;transition:all 0.12s;
    }
    .pte-img-btn--upload { background:#6366f1;border-color:#4f46e5;color:#fff; }
    .pte-img-btn--upload:hover { background:#4f46e5; }
    .pte-img-btn--mode {
        background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.12);color:rgba(255,255,255,0.5);
    }
    body.app-theme-light .pte-img-btn--mode { background:#fff;border-color:#e2e8f0;color:#94a3b8; }
    .pte-img-btn--mode.is-active { background:#6366f1;border-color:#4f46e5;color:#fff; }
    .pte-img-btn--clear { background:rgba(239,68,68,0.08);border-color:rgba(239,68,68,0.25);color:#f87171; }
    .pte-img-btn--clear:hover { background:rgba(239,68,68,0.18); }
    .pte-img-preview {
        flex:1 1 0;min-height:140px;border-radius:10px;
        border:2px dashed rgba(255,255,255,0.12);overflow:hidden;position:relative;
        display:flex;align-items:center;justify-content:center;flex-direction:column;
        background:rgba(255,255,255,0.02);
    }
    body.app-theme-light .pte-img-preview {
        border-color:#cbd5e1;background:#f1f5f9;
    }

    /* ── Component grid (Bilesen tab) ── */
    .pte-comp-grid {
        margin-top:16px;border-radius:12px;overflow:hidden;
        background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);
    }
    body.app-theme-light .pte-comp-grid {
        background:#fafbfd;border-color:rgba(15,23,42,0.06);
    }
    .pte-comp-header {
        display:flex;align-items:center;gap:8px;padding:10px 14px;
        border-bottom:1px solid rgba(255,255,255,0.06);
    }
    body.app-theme-light .pte-comp-header { border-bottom-color:#e2e8f0; }
    .pte-comp-title {
        font-size:0.85rem;font-weight:700;color:rgba(255,255,255,0.85);
    }
    body.app-theme-light .pte-comp-title { color:#94a3b8; }
    .pte-comp-badge {
        padding:1px 8px;border-radius:999px;font-size:0.62rem;font-weight:700;
        background:rgba(99,102,241,0.12);color:#a5b4fc;
        border:1px solid rgba(99,102,241,0.25);
    }
    body.app-theme-light .pte-comp-badge { background:rgba(99,102,241,0.08);color:#4f46e5; }
    .pte-comp-body { max-height:320px;overflow-y:auto;overflow-x:auto; }
    .pte-comp-table { width:100%;border-collapse:collapse;font-size:0.82rem; }
    .pte-comp-th {
        padding:8px 10px;text-align:left;font-size:0.78rem;font-weight:600;
        color:rgba(255,255,255,0.7);border-bottom:1px solid rgba(255,255,255,0.08);
        position:sticky;top:0;z-index:3;
        background:rgba(15,15,26,0.6);backdrop-filter:blur(8px);
    }
    body.app-theme-light .pte-comp-th {
        color:#64748b;border-bottom-color:#e2e8f0;background:rgba(248,250,252,0.95);
    }
    .pte-comp-td {
        padding:7px 10px;border-bottom:1px solid rgba(255,255,255,0.04);
        color:rgba(255,255,255,0.75);
    }
    body.app-theme-light .pte-comp-td { color:#334155;border-bottom-color:#f0f2f6; }
    .pte-comp-table tbody tr { cursor:pointer;transition:background 0.1s; }
    .pte-comp-table tbody tr:hover .pte-comp-td { background:rgba(99,102,241,0.06); }
    body.app-theme-light .pte-comp-table tbody tr:hover .pte-comp-td { background:rgba(99,102,241,0.04); }
    .pte-comp-table tbody tr.selected .pte-comp-td {
        background:rgba(99,102,241,0.12);
    }
    body.app-theme-light .pte-comp-table tbody tr.selected .pte-comp-td {
        background:rgba(99,102,241,0.08);
    }
    .pte-comp-table tbody tr.selected {
        outline:2px solid rgba(99,102,241,0.4);outline-offset:-1px;border-radius:4px;
    }
    .pte-row-badge {
        display:inline-flex;align-items:center;padding:1px 7px;border-radius:4px;
        font-size:0.7rem;font-weight:600;
        background:rgba(99,102,241,0.12);color:#a5b4fc;
    }
    body.app-theme-light .pte-row-badge { background:rgba(99,102,241,0.08);color:#4f46e5; }
    .pte-icon-btn {
        background:transparent;border:none;cursor:pointer;padding:3px;
        border-radius:4px;transition:all 0.1s;color:rgba(255,255,255,0.45);
    }
    .pte-icon-btn:hover { background:rgba(255,255,255,0.08); }
    .pte-icon-btn--edit:hover { color:#6366f1; }
    .pte-icon-btn--del:hover { color:#f87171; }
    body.app-theme-light .pte-icon-btn { color:#94a3b8; }
    body.app-theme-light .pte-icon-btn--edit:hover { color:#4f46e5; }
    body.app-theme-light .pte-icon-btn--del:hover { color:#ef4444; }

    /* ── Empty state ── */
    .pte-empty {
        text-align:center;padding:32px 16px;color:rgba(255,255,255,0.35);font-size:0.82rem;
    }
    body.app-theme-light .pte-empty { color:rgba(71,85,105,0.5); }

    /* ── Toast message ── */
    .pte-message {
        padding:0;margin:0 0 12px;border-radius:10px;font-size:0.82rem;font-weight:500;
        overflow:hidden;max-height:0;opacity:0;transition:all 0.3s ease;
    }
    .pte-message.ok {
        max-height:60px;opacity:1;padding:10px 16px;
        background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.25);color:#34d399;
    }
    .pte-message.err {
        max-height:60px;opacity:1;padding:10px 16px;
        background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.22);color:#f87171;
    }

    /* ── Dropdown (glassmorphic) ── */
    .pte-dd {
        position:fixed !important;z-index:99999 !important;
        background:rgba(15,23,42,0.95);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
        border:1px solid rgba(255,255,255,0.12);border-radius:10px;
        box-shadow:0 8px 32px rgba(0,0,0,0.35);min-width:360px;overflow:hidden;
    }
    body.app-theme-light .pte-dd {
        background:rgba(255,255,255,0.97);border-color:#e2e8f0;
        box-shadow:0 8px 24px rgba(0,0,0,0.12);
    }
    .pte-dd-search {
        padding:8px;border-bottom:1px solid rgba(255,255,255,0.08);
    }
    body.app-theme-light .pte-dd-search { border-bottom-color:#f0f2f6; }
    .pte-dd-list { max-height:240px;overflow-y:auto; }
    .pte-dd-item {
        padding:8px 14px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,0.04);
        font-size:0.82rem;color:rgba(255,255,255,0.8);transition:background 0.1s;
    }
    body.app-theme-light .pte-dd-item { color:#334155;border-bottom-color:#f5f7fb; }
    .pte-dd-item:hover { background:rgba(99,102,241,0.08); }
    body.app-theme-light .pte-dd-item:hover { background:#f0f4ff; }
    .pte-dd-item strong { color:#a5b4fc; }
    body.app-theme-light .pte-dd-item strong { color:#1e293b; }
    .pte-dd-muted { color:rgba(255,255,255,0.45);font-size:0.78rem; }
    body.app-theme-light .pte-dd-muted { color:#64748b; }
    .pte-dd-empty { padding:12px 14px;color:rgba(255,255,255,0.4);font-size:0.82rem; }
    body.app-theme-light .pte-dd-empty { color:#94a3b8; }
    .pte-badge-cfg {
        display:inline-block;padding:1px 6px;border-radius:4px;font-size:0.65rem;font-weight:600;
        background:rgba(99,102,241,0.15);color:#a5b4fc;margin-left:6px;
    }
    body.app-theme-light .pte-badge-cfg { background:rgba(99,102,241,0.1);color:#4f46e5; }
    .pte-chip {
        display:inline-flex;align-items:center;gap:3px;
        background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.25);
        border-radius:4px;padding:0 6px;font-size:0.7rem;margin:2px 2px 0 0;white-space:nowrap;
    }
    body.app-theme-light .pte-chip { background:#f0f4ff;border-color:#c7d2fe; }
    .pte-chip-feat { color:#a5b4fc;font-weight:600; }
    body.app-theme-light .pte-chip-feat { color:#4f46e5; }
    .pte-chip-val { color:rgba(255,255,255,0.7); }
    body.app-theme-light .pte-chip-val { color:#1e293b; }

    /* ── Animations ── */
    @@keyframes pteShake {
        10%,90% { transform:translateX(-1px); }
        20%,80% { transform:translateX(2px); }
        30%,50%,70% { transform:translateX(-4px); }
        40%,60% { transform:translateX(4px); }
    }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide page-product-trees">
  <div class="integrator-dashboard__content">

    <!-- Action Bar -->
    <div class="pte-action-bar">
        <button type="button" class="pte-btn pte-btn--primary" id="ptBtnSave">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
            Kaydet
        </button>
        <button type="button" class="pte-btn pte-btn--danger" id="ptBtnDelete">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
            Sil
        </button>
        <button type="button" class="pte-btn pte-btn--secondary" id="ptBtnNew">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14m-7-7h14"/></svg>
            Yeni Recete
        </button>
        <span class="pte-meta" id="pteMeta"></span>
    </div>

    <!-- Body: sidenav + content -->
    <div class="pte-body">

        <!-- Sidebar Navigation -->
        <nav class="pte-sidenav" id="pteSideNav">
            <button type="button" class="pte-nav-btn is-active" data-tab="genel">
                <span class="pte-nav-dot"></span>
                Genel Bilgiler
            </button>
            <button type="button" class="pte-nav-btn" data-tab="bilesen">
                <span class="pte-nav-dot"></span>
                Bilesen Bilgileri
                <span class="pte-nav-count" id="ptCompCount">0</span>
            </button>
        </nav>

        <!-- Content Area -->
        <div class="pte-content" id="pteContent">
            <div class="pte-message" id="pteMsg"></div>

            <!-- ── Genel Bilgiler ── -->
            <div id="pteTab-genel">
                <div class="pte-card">
                    <p class="pte-card-title">Mamul Bilgileri</p>
                    <div class="pte-grid">

                        <!-- Mamul Kodu + Adi -->
                        <div class="pte-row">
                            <label class="pte-label pte-label--req" style="width:130px;">Mamul Kodu</label>
                            <div class="pte-lookup" style="width:180px;flex-shrink:0;">
                                <input type="text" id="ptParentCode" class="pte-input" style="width:130px;" placeholder="Kod..." autocomplete="off" readonly />
                                <button type="button" class="pte-lookup-btn" id="btnParentLookup" title="Malzeme Rehberi">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
                                </button>
                            </div>
                            <input type="text" id="ptParentName" class="pte-input" readonly placeholder="Mamul adi..." style="flex:1 1 0;min-width:0;" />
                        </div>

                        <!-- Kombinasyon Kodu -->
                        <div class="pte-row" style="display:none;" id="ptConfigRow">
                            <label class="pte-label pte-label--req" style="width:130px;color:#a5b4fc;">Kombinasyon Kodu</label>
                            <div class="pte-lookup" style="width:180px;flex-shrink:0;">
                                <input type="text" id="ptConfigCode" class="pte-input" style="width:130px;border-color:rgba(99,102,241,0.3);" placeholder="Kombinasyon secin..." readonly />
                                <button type="button" class="pte-lookup-btn" id="btnConfigLookup" title="Kombinasyon Rehberi">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
                                </button>
                            </div>
                            <div id="ptConfigDescRow" style="display:none;flex:1 1 0;min-width:0;">
                                <input type="text" id="ptConfigDesc" class="pte-input" readonly placeholder="Kombinasyon aciklamasi..." style="width:100%;" />
                            </div>
                        </div>

                        <!-- Recete Aciklamasi -->
                        <div class="pte-field" style="max-width:500px;">
                            <label class="pte-label" for="ptRecipeNote">Recete Aciklamasi</label>
                            <input type="text" id="ptRecipeNote" class="pte-input" placeholder="Istege bagli..." />
                        </div>

                    </div>
                </div>

                <!-- Gorsel Alani -->
                <div class="pte-card">
                    <p class="pte-card-title">Urun Gorseli</p>
                    <div class="pte-image-area" id="ptBottomPanel-genel">
                        <div class="pte-img-actions">
                            <label for="ptImageInput" class="pte-img-btn pte-img-btn--upload" title="Gorsel Yukle">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1M16 8l-4-4m0 0L8 8m4-4v12"/></svg>
                            </label>
                            <button type="button" class="pte-img-btn pte-img-btn--mode is-active" data-mode="square" onclick="event.preventDefault();ptSetImageMode('square')" title="Kare">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                            </button>
                            <button type="button" class="pte-img-btn pte-img-btn--mode" data-mode="free" onclick="event.preventDefault();ptSetImageMode('free')" title="Serbest">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg>
                            </button>
                            <button type="button" class="pte-img-btn pte-img-btn--clear" onclick="event.preventDefault();ptClearImage()" title="Temizle">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                            </button>
                        </div>
                        <div class="pte-img-preview" id="ptImagePreviewContainer">
                            <svg fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" style="width:36px;height:36px;opacity:.4;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"/>
                            </svg>
                            <span style="font-size:0.75rem;opacity:0.4;padding:0 8px;text-align:center;">Gorsel yukle</span>
                        </div>
                        <input type="file" style="display:none;" id="ptImageInput" accept="image/*" onchange="ptPreviewImage(this)">
                        <input type="hidden" id="ptImageBase64" />
                        <input type="hidden" id="ptImageFitMode" value="square" />
                    </div>
                </div>
            </div><!-- /pteTab-genel -->

            <!-- ── Bilesen Bilgileri ── -->
            <div id="pteTab-bilesen" style="display:none;">
                <div class="pte-card">
                    <p class="pte-card-title">Bilesen Ekle</p>
                    <div class="pte-grid">

                        <!-- Bilesen Kodu + Adi -->
                        <div class="pte-row">
                            <label class="pte-label pte-label--req" style="width:130px;">Bilesen Kodu</label>
                            <div class="pte-lookup" style="width:180px;flex-shrink:0;">
                                <input type="text" id="cfCompCode" class="pte-input" style="width:130px;" placeholder="Kod..." autocomplete="off" readonly />
                                <button type="button" class="pte-lookup-btn" id="btnCompLookup" title="Malzeme Rehberi">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
                                </button>
                            </div>
                            <input type="text" id="cfCompName" class="pte-input" readonly placeholder="Bilesen adi..." style="flex:1 1 0;min-width:0;" />
                        </div>

                        <!-- Miktar + Fire + Butonlar -->
                        <div class="pte-row">
                            <label class="pte-label pte-label--req" style="width:130px;">Miktar</label>
                            <input type="number" id="cfCompQty" class="pte-input" value="1" min="0" step="any" style="width:100px;" />
                            <label class="pte-label" style="margin-left:8px;">Fire Miktari</label>
                            <input type="number" id="cfCompScrap" class="pte-input" value="0" min="0" step="any" style="width:100px;" />
                            <button type="button" class="pte-btn pte-btn--primary pte-btn--sm" id="ptCompFormSubmit" style="margin-left:8px;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14"/></svg>
                                Ekle
                            </button>
                            <button type="button" class="pte-btn pte-btn--secondary pte-btn--sm" id="ptCompFormCancel" style="display:none;">Iptal</button>
                        </div>

                        <!-- Bilesen Kombinasyonu -->
                        <div class="pte-row" style="display:none;" id="cfCompCfgWrap">
                            <label class="pte-label pte-label--req" style="width:130px;color:#a5b4fc;">Kombinasyon</label>
                            <div class="pte-lookup" style="width:180px;flex-shrink:0;">
                                <input type="text" id="cfCompCfgCode" class="pte-input" style="width:130px;border-color:rgba(99,102,241,0.3);" placeholder="Kombinasyon secin..." readonly />
                                <button type="button" class="pte-lookup-btn" id="btnCompCfgLookup" title="Kombinasyon Rehberi">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
                                </button>
                            </div>
                            <div id="cfCompCfgDescWrap" style="display:none;flex:1 1 0;min-width:0;">
                                <input type="text" id="cfCompCfgDesc" class="pte-input" readonly placeholder="Kombinasyon aciklamasi..." style="width:100%;" />
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Bilesen Listesi -->
                <div class="pte-comp-grid" id="ptBottomPanel-bilesen">
                    <div class="pte-comp-header">
                        <span class="pte-comp-title">Bilesen Listesi</span>
                        <span class="pte-comp-badge" id="ptCompCountBadge">0 bilesen</span>
                    </div>
                    <div id="ptEmptyState" class="pte-empty">
                        <svg fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" style="width:32px;height:32px;opacity:.35;margin-bottom:6px;display:inline-block;">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                        </svg>
                        <div>Henuz bilesen eklenmedi</div>
                    </div>
                    <div class="pte-comp-body">
                        <table class="pte-comp-table" id="ptCompTable">
                            <thead>
                                <tr>
                                    <th class="pte-comp-th" style="width:56px;"></th>
                                    <th class="pte-comp-th" style="width:32px;">#</th>
                                    <th class="pte-comp-th">Kod</th>
                                    <th class="pte-comp-th">Ad</th>
                                    <th class="pte-comp-th" style="width:80px;">Miktar</th>
                                    <th class="pte-comp-th" style="width:80px;">Fire</th>
                                    <th class="pte-comp-th" style="width:120px;">Kombinasyon</th>
                                </tr>
                            </thead>
                            <tbody id="ptLinesBody"></tbody>
                        </table>
                    </div>
                </div>
            </div><!-- /pteTab-bilesen -->

        </div><!-- /pte-content -->

    </div><!-- /pte-body -->

  </div><!-- /integrator-dashboard__content -->
</section>


@section Scripts {
<script>
(function () {

    /* ===== TOAST ===== */
    function showMsg(text, ok) {
        var m = document.getElementById('pteMsg');
        if (!m) return;
        m.textContent = text;
        m.className = 'pte-message ' + (ok ? 'ok' : 'err');
        setTimeout(function() { m.className = 'pte-message'; m.textContent = ''; }, 4000);
    }

    /* ===== IMAGE PROCESSING (Canvas-based) ===== */
    let ptCurrentImageMode = 'square';
    let ptCurrentLoadedImg = null;

    /* ===== COMBINATION LOOKUP STATE ===== */
    let ptCurrentMaterialCode = null;
    let ptCachedCombos = [];

    function ptProcessImageToCanvas() {
        if (!ptCurrentLoadedImg) return;
        const img = ptCurrentLoadedImg;
        const container = document.getElementById('ptImagePreviewContainer');
        const base64Input = document.getElementById('ptImageBase64');
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        let tx, ty;
        if (ptCurrentImageMode === 'square') {
            const size = Math.min(img.width, img.height);
            const x = (img.width - size) / 2, y = (img.height - size) / 2;
            tx = ty = Math.min(size, 800);
            canvas.width = tx; canvas.height = ty;
            ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, 0, tx, ty);
            ctx.drawImage(img, x, y, size, size, 0, 0, tx, ty);
        } else {
            let scale = Math.min(800 / img.width, 800 / img.height);
            if (scale > 1) scale = 1;
            tx = img.width * scale; ty = img.height * scale;
            canvas.width = tx; canvas.height = ty;
            ctx.fillStyle = '#FFFFFF'; ctx.fillRect(0, 0, tx, ty);
            ctx.drawImage(img, 0, 0, img.width, img.height, 0, 0, tx, ty);
        }
        const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
        base64Input.value = dataUrl;
        const fitMode = ptCurrentImageMode === 'square' ? 'cover' : 'contain';
        container.innerHTML = '<img id="ptPreviewImgEl" src="' + dataUrl + '" style="width:100%;height:100%;object-fit:' + fitMode + ';border-radius:10px;position:absolute;top:0;left:0;" />';
        container.style.borderStyle = 'solid';
    }

    window.ptSetImageMode = function(mode) {
        ptCurrentImageMode = mode;
        document.getElementById('ptImageFitMode').value = mode;
        document.querySelectorAll('.pte-img-btn--mode').forEach(function(b) {
            b.classList.toggle('is-active', b.dataset.mode === mode);
        });
        if (ptCurrentLoadedImg) {
            ptProcessImageToCanvas();
        } else {
            var el = document.getElementById('ptPreviewImgEl');
            if (el) el.style.objectFit = mode === 'square' ? 'cover' : 'contain';
        }
    };

    window.ptClearImage = function() {
        ptCurrentLoadedImg = null;
        document.getElementById('ptImageInput').value = '';
        document.getElementById('ptImageBase64').value = 'CLEAR';
        var container = document.getElementById('ptImagePreviewContainer');
        container.innerHTML = '<svg fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" style="width:36px;height:36px;opacity:.4;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"></path></svg><span style="font-size:0.75rem;opacity:0.4;padding:0 8px;text-align:center;">Gorsel yukle</span>';
        container.style.borderStyle = 'dashed';
    };

    window.ptPreviewImage = function(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var img = new Image();
                img.onload = function() { ptCurrentLoadedImg = img; ptProcessImageToCanvas(); };
                img.src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        } else {
            ptClearImage();
        }
    };

    /* ===== TAB NAVIGATION ===== */
    function ptShowTabWarning(msg) {
        showMsg(msg, false);
    }

    function ptCanSwitchToBilesen() {
        var mamulKodu = document.getElementById('ptParentCode')?.value.trim();
        if (!mamulKodu) {
            ptShowTabWarning('Once Mamul Kodu secilmelidir.');
            return false;
        }
        var cfgRow  = document.getElementById('ptConfigRow');
        var cfgCode = document.getElementById('ptConfigCode')?.value.trim();
        if (cfgRow && cfgRow.style.display !== 'none' && !cfgCode) {
            ptShowTabWarning('Kombinasyonlu mamul icin Kombinasyon Kodu secilmelidir.');
            return false;
        }
        return true;
    }

    document.querySelectorAll('.pte-nav-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var tab = btn.dataset.tab;
            if (tab === 'bilesen' && !ptCanSwitchToBilesen()) return;

            document.querySelectorAll('.pte-nav-btn').forEach(function(b) { b.classList.remove('is-active'); });
            btn.classList.add('is-active');

            // Tab panels
            document.getElementById('pteTab-genel').style.display = (tab === 'genel') ? '' : 'none';
            document.getElementById('pteTab-bilesen').style.display = (tab === 'bilesen') ? '' : 'none';

            if (tab === 'bilesen') renderGrid();
        });
    });

    /* ===== DROPDOWN HELPER ===== */
    function positionDropdown(dd, anchor) {
        var r = anchor.getBoundingClientRect();
        dd.style.top  = (r.bottom + 2) + 'px';
        dd.style.left = r.left + 'px';
        var ddW = dd.offsetWidth || parseInt(dd.style.minWidth) || 360;
        if (r.left + ddW > window.innerWidth - 8) {
            dd.style.left = Math.max(4, window.innerWidth - ddW - 8) + 'px';
        }
        var ddH = dd.offsetHeight || 300;
        if (r.bottom + ddH > window.innerHeight - 10) {
            dd.style.top = Math.max(4, r.top - ddH - 2) + 'px';
        }
    }

    function escHtml(s) {
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(s));
        return d.innerHTML;
    }

    /* ===== MAMUL KODU LOOKUP ===== */
    var btnLookup = document.getElementById('btnParentLookup');
    var codeInput = document.getElementById('ptParentCode');
    var nameInput = document.getElementById('ptParentName');

    var dd = document.createElement('div');
    dd.className = 'pte-dd';
    dd.style.display = 'none';
    dd.innerHTML = '<div class="pte-dd-search"><input type="text" id="ptStockSearch" class="pte-input" style="width:100%;" placeholder="Kod veya urun adi ile ara..." autocomplete="off" /></div><div class="pte-dd-list" id="ptStockList"></div>';
    document.body.appendChild(dd);

    function showLoading() {
        var list = document.getElementById('ptStockList');
        if (list) list.innerHTML = '<div class="pte-dd-empty"><span style="opacity:.6;">Araniyor...</span></div>';
    }

    function renderStockList(items) {
        var list = document.getElementById('ptStockList');
        if (!list) return;
        if (!items || !items.length) {
            list.innerHTML = '<div class="pte-dd-empty">Sonuc bulunamadi</div>';
            return;
        }
        list.innerHTML = items.map(function(s) {
            return '<div class="pte-dd-item" data-code="' + escHtml(s.code) + '" data-name="' + escHtml(s.name ?? '') + '" data-config="' + s.hasConfig + '">' +
                '<strong>' + escHtml(s.code) + '</strong> ' +
                '<span class="pte-dd-muted">' + escHtml(s.name ?? '') + '</span>' +
                (s.hasConfig ? '<span class="pte-badge-cfg">Kombinasyonlu</span>' : '') +
                '</div>';
        }).join('');
        list.querySelectorAll('.pte-dd-item').forEach(function(el) {
            el.addEventListener('click', function() {
                codeInput.value = el.dataset.code;
                nameInput.value = el.dataset.name;
                var cfgRow = document.getElementById('ptConfigRow');
                var cfgInput = document.getElementById('ptConfigCode');
                var cfgDescEl = document.getElementById('ptConfigDesc');
                var cfgDescRow = document.getElementById('ptConfigDescRow');
                var isConfigurable = el.dataset.config === 'true';
                if (cfgRow) cfgRow.style.display = isConfigurable ? 'flex' : 'none';
                if (cfgInput) { cfgInput.value = ''; cfgInput.placeholder = isConfigurable ? 'Buyutec ile kombinasyon secin...' : ''; }
                if (cfgDescEl) cfgDescEl.value = '';
                if (cfgDescRow) cfgDescRow.style.display = 'none';
                ptCurrentMaterialCode = isConfigurable ? el.dataset.code : null;
                ptCachedCombos = [];
                dd.style.display = 'none';
                if (!isConfigurable) ptLoadExistingTree(el.dataset.code, null);
            });
        });
    }

    var debounceTimer;
    async function fetchStocks(q) {
        showLoading();
        try {
            var resp = await fetch('/Logistics/StockLookup?q=' + encodeURIComponent(q ?? ''));
            var data = await resp.json();
            renderStockList(data);
        } catch {
            var list = document.getElementById('ptStockList');
            if (list) list.innerHTML = '<div class="pte-dd-empty" style="color:#f87171;">Yuklenemedi</div>';
        }
    }

    btnLookup?.addEventListener('click', function() {
        var isOpen = dd.style.display !== 'none';
        if (isOpen) { dd.style.display = 'none'; return; }
        dd.style.display = '';
        positionDropdown(dd, btnLookup);
        var searchInput = document.getElementById('ptStockSearch');
        if (searchInput) searchInput.value = '';
        fetchStocks('');
        setTimeout(function() { document.getElementById('ptStockSearch')?.focus(); }, 50);
    });

    window.addEventListener('scroll', function() { if (dd.style.display !== 'none') positionDropdown(dd, btnLookup); }, true);
    window.addEventListener('resize', function() { if (dd.style.display !== 'none') positionDropdown(dd, btnLookup); });

    document.getElementById('ptStockSearch')?.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        var self = this;
        debounceTimer = setTimeout(function() { fetchStocks(self.value); }, 250);
    });

    /* ===== BILESEN KODU LOOKUP ===== */
    var btnCompLookup = document.getElementById('btnCompLookup');
    var compCodeInput = document.getElementById('cfCompCode');
    var compNameInput = document.getElementById('cfCompName');

    var compDd = document.createElement('div');
    compDd.className = 'pte-dd';
    compDd.style.display = 'none';
    compDd.innerHTML = '<div class="pte-dd-search"><input type="text" id="ptCompSearch" class="pte-input" style="width:100%;" placeholder="Kod veya urun adi ile ara..." autocomplete="off" /></div><div class="pte-dd-list" id="ptCompList"></div>';
    document.body.appendChild(compDd);

    function renderCompStockList(items) {
        var list = document.getElementById('ptCompList');
        if (!list) return;
        if (!items || !items.length) {
            list.innerHTML = '<div class="pte-dd-empty">Sonuc bulunamadi</div>';
            return;
        }
        list.innerHTML = items.map(function(s) {
            return '<div class="pte-dd-item" data-code="' + escHtml(s.code) + '" data-name="' + escHtml(s.name ?? '') + '" data-config="' + s.hasConfig + '">' +
                '<strong>' + escHtml(s.code) + '</strong> ' +
                '<span class="pte-dd-muted">' + escHtml(s.name ?? '') + '</span>' +
                (s.hasConfig ? '<span class="pte-badge-cfg">Kombinasyonlu</span>' : '') +
                '</div>';
        }).join('');
        list.querySelectorAll('.pte-dd-item').forEach(function(el) {
            el.addEventListener('click', function() {
                compCodeInput.value = el.dataset.code;
                compNameInput.value = el.dataset.name;
                var isConfigurable = el.dataset.config === 'true';
                var cfgWrap = document.getElementById('cfCompCfgWrap');
                var cfgCodeEl = document.getElementById('cfCompCfgCode');
                var cfgDescEl = document.getElementById('cfCompCfgDesc');
                var cfgDescWrap = document.getElementById('cfCompCfgDescWrap');
                if (cfgWrap) cfgWrap.style.display = isConfigurable ? 'flex' : 'none';
                if (cfgCodeEl) { cfgCodeEl.value = ''; cfgCodeEl.placeholder = isConfigurable ? 'Buyutec ile kombinasyon secin...' : ''; }
                if (cfgDescEl) cfgDescEl.value = '';
                if (cfgDescWrap) cfgDescWrap.style.display = 'none';
                ptCompMaterialCode = isConfigurable ? el.dataset.code : null;
                ptCompCachedCombos = [];
                compDd.style.display = 'none';
                document.getElementById('cfCompQty')?.focus();
            });
        });
    }

    var compDebounceTimer;
    async function fetchCompStocks(q) {
        var list = document.getElementById('ptCompList');
        if (list) list.innerHTML = '<div class="pte-dd-empty"><span style="opacity:.6;">Araniyor...</span></div>';
        try {
            var resp = await fetch('/Logistics/StockLookup?q=' + encodeURIComponent(q ?? ''));
            var data = await resp.json();
            renderCompStockList(data);
        } catch {
            var list = document.getElementById('ptCompList');
            if (list) list.innerHTML = '<div class="pte-dd-empty" style="color:#f87171;">Yuklenemedi</div>';
        }
    }

    btnCompLookup?.addEventListener('click', function() {
        var isOpen = compDd.style.display !== 'none';
        if (isOpen) { compDd.style.display = 'none'; return; }
        compDd.style.display = '';
        positionDropdown(compDd, btnCompLookup);
        var searchInput = document.getElementById('ptCompSearch');
        if (searchInput) searchInput.value = '';
        fetchCompStocks('');
        setTimeout(function() { document.getElementById('ptCompSearch')?.focus(); }, 50);
    });

    window.addEventListener('scroll', function() { if (compDd.style.display !== 'none') positionDropdown(compDd, btnCompLookup); }, true);
    window.addEventListener('resize', function() { if (compDd.style.display !== 'none') positionDropdown(compDd, btnCompLookup); });

    document.getElementById('ptCompSearch')?.addEventListener('input', function() {
        clearTimeout(compDebounceTimer);
        var self = this;
        compDebounceTimer = setTimeout(function() { fetchCompStocks(self.value); }, 250);
    });

    /* ===== KOMBINASYON LOOKUP (Mamul) ===== */
    var btnConfigLookup = document.getElementById('btnConfigLookup');
    var cfgCodeInput = document.getElementById('ptConfigCode');

    var comboDd = document.createElement('div');
    comboDd.className = 'pte-dd';
    comboDd.style.display = 'none';
    comboDd.innerHTML = '<div class="pte-dd-search"><input type="text" id="ptComboSearch" class="pte-input" style="width:100%;" placeholder="Kod, aciklama veya ozellik/deger ile ara..." autocomplete="off" /></div><div class="pte-dd-list" id="ptComboList"></div>';
    document.body.appendChild(comboDd);

    function renderComboList(items, query) {
        var q = (query || '').toLowerCase();
        var matchFeature = function(c) { return (c.features || []).some(function(fv) {
            return (fv.feature || '').toLowerCase().includes(q) || (fv.value || '').toLowerCase().includes(q);
        }); };
        var filtered = q
            ? items.filter(function(c) { return c.code.toLowerCase().includes(q) || (c.name || '').toLowerCase().includes(q) || matchFeature(c); })
            : items;
        var list = document.getElementById('ptComboList');
        if (!list) return;
        if (!filtered.length) {
            list.innerHTML = '<div class="pte-dd-empty">Sonuc bulunamadi</div>';
            return;
        }
        list.innerHTML = filtered.map(function(c) {
            var chips = (c.features || []).map(function(fv) {
                return '<span class="pte-chip"><span class="pte-chip-feat">' + escHtml(fv.feature) + '</span><span style="opacity:.4;">:</span><span class="pte-chip-val">' + escHtml(fv.value) + '</span></span>';
            }).join('');
            return '<div class="pte-dd-item" data-code="' + escHtml(c.code) + '" data-name="' + escHtml(c.name ?? '') + '" data-features="' + encodeURIComponent(JSON.stringify(c.features || [])) + '">' +
                '<div><strong>' + escHtml(c.code) + '</strong>' +
                (c.name && c.name !== c.code ? ' <span class="pte-dd-muted">' + escHtml(c.name) + '</span>' : '') +
                '</div>' +
                (chips ? '<div style="margin-top:4px;line-height:1.6;">' + chips + '</div>' : '') +
                '</div>';
        }).join('');
        list.querySelectorAll('.pte-dd-item').forEach(function(el) {
            el.addEventListener('click', function() {
                if (cfgCodeInput) cfgCodeInput.value = el.dataset.code;
                var features = JSON.parse(decodeURIComponent(el.dataset.features || '%5B%5D'));
                var descText = features.length
                    ? features.map(function(fv) { return fv.feature + ' (' + fv.value + ')'; }).join(', ')
                    : (el.dataset.name || '');
                var descEl = document.getElementById('ptConfigDesc');
                var descRowEl = document.getElementById('ptConfigDescRow');
                if (descEl) descEl.value = descText;
                if (descRowEl) descRowEl.style.display = descText ? 'flex' : 'none';
                comboDd.style.display = 'none';
                ptLoadExistingTree(ptCurrentMaterialCode, el.dataset.code);
            });
        });
    }

    async function openComboDd() {
        comboDd.style.display = '';
        positionDropdown(comboDd, btnConfigLookup);
        var searchEl = document.getElementById('ptComboSearch');
        if (searchEl) { searchEl.value = ''; setTimeout(function() { searchEl.focus(); }, 50); }
        if (!ptCurrentMaterialCode) {
            var list = document.getElementById('ptComboList');
            if (list) list.innerHTML = '<div class="pte-dd-empty" style="color:#fbbf24;">Lutfen once mamul kodu secin</div>';
            return;
        }
        if (!ptCachedCombos.length) {
            var list = document.getElementById('ptComboList');
            if (list) list.innerHTML = '<div class="pte-dd-empty"><span style="opacity:.6;">Yukleniyor...</span></div>';
            try {
                var resp = await fetch('/Logistics/CombinationLookup?materialCode=' + encodeURIComponent(ptCurrentMaterialCode));
                ptCachedCombos = await resp.json();
            } catch {
                if (list) list.innerHTML = '<div class="pte-dd-empty" style="color:#f87171;">Yukleme hatasi</div>';
                return;
            }
        }
        renderComboList(ptCachedCombos, '');
    }

    btnConfigLookup?.addEventListener('click', function() {
        if (comboDd.style.display !== 'none') { comboDd.style.display = 'none'; return; }
        openComboDd();
    });

    window.addEventListener('scroll', function() { if (comboDd.style.display !== 'none') positionDropdown(comboDd, btnConfigLookup); }, true);
    window.addEventListener('resize', function() { if (comboDd.style.display !== 'none') positionDropdown(comboDd, btnConfigLookup); });

    document.getElementById('ptComboSearch')?.addEventListener('input', function() {
        renderComboList(ptCachedCombos, this.value);
    });

    /* ===== BILESEN KOMBINASYON LOOKUP ===== */
    var btnCompCfgLookup = document.getElementById('btnCompCfgLookup');
    let ptCompMaterialCode = null;
    let ptCompCachedCombos = [];

    var cfCfgDd = document.createElement('div');
    cfCfgDd.className = 'pte-dd';
    cfCfgDd.style.display = 'none';
    cfCfgDd.innerHTML = '<div class="pte-dd-search"><input type="text" id="cfCfgSearch" class="pte-input" style="width:100%;" placeholder="Kombinasyon ara..." autocomplete="off" /></div><div class="pte-dd-list" id="cfCfgList"></div>';
    document.body.appendChild(cfCfgDd);

    btnCompCfgLookup?.addEventListener('click', async function() {
        if (cfCfgDd.style.display !== 'none') { cfCfgDd.style.display = 'none'; return; }
        cfCfgDd.style.display = '';
        positionDropdown(cfCfgDd, btnCompCfgLookup);
        document.getElementById('cfCfgSearch').value = '';
        document.getElementById('cfCfgSearch')?.focus();
        await loadCfCfgList('');
        requestAnimationFrame(function() { positionDropdown(cfCfgDd, btnCompCfgLookup); });
    });

    document.getElementById('cfCfgSearch')?.addEventListener('input', function() {
        renderCfCfgList(ptCompCachedCombos, this.value);
    });

    async function loadCfCfgList(q) {
        var listEl = document.getElementById('cfCfgList');
        if (!listEl) return;
        if (!ptCompMaterialCode) {
            listEl.innerHTML = '<div class="pte-dd-empty" style="color:#fbbf24;">Lutfen once bilesen secin</div>';
            return;
        }
        if (!ptCompCachedCombos.length) {
            listEl.innerHTML = '<div class="pte-dd-empty"><span style="opacity:.6;">Yukleniyor...</span></div>';
            try {
                var resp = await fetch('/Logistics/CombinationLookup?materialCode=' + encodeURIComponent(ptCompMaterialCode));
                ptCompCachedCombos = await resp.json();
            } catch {
                listEl.innerHTML = '<div class="pte-dd-empty" style="color:#f87171;">Yukleme hatasi</div>';
                return;
            }
        }
        renderCfCfgList(ptCompCachedCombos, q);
    }

    function renderCfCfgList(items, query) {
        var q = (query || '').toLowerCase();
        var filtered = q ? items.filter(function(c) {
            return c.code.toLowerCase().includes(q) || (c.name || '').toLowerCase().includes(q) ||
                (c.features || []).some(function(fv) { return (fv.feature + fv.value).toLowerCase().includes(q); });
        }) : items;
        var listEl = document.getElementById('cfCfgList');
        if (!listEl) return;
        if (!filtered.length) { listEl.innerHTML = '<div class="pte-dd-empty">Sonuc bulunamadi</div>'; return; }
        listEl.innerHTML = filtered.map(function(c) {
            var chips = (c.features || []).map(function(fv) {
                return '<span class="pte-chip"><span class="pte-chip-feat">' + escHtml(fv.feature) + '</span><span style="opacity:.4;">:</span><span class="pte-chip-val">' + escHtml(fv.value) + '</span></span>';
            }).join('');
            return '<div class="pte-dd-item" data-code="' + escHtml(c.code) + '" data-name="' + escHtml(c.name ?? '') + '">' +
                '<div><strong>' + escHtml(c.code) + '</strong>' +
                (c.name && c.name !== c.code ? ' <span class="pte-dd-muted">' + escHtml(c.name) + '</span>' : '') +
                '</div>' +
                (chips ? '<div style="margin-top:3px;">' + chips + '</div>' : '') +
                '</div>';
        }).join('');
        listEl.querySelectorAll('.pte-dd-item').forEach(function(item) {
            item.addEventListener('click', function() {
                document.getElementById('cfCompCfgCode').value = item.dataset.code;
                var cfgName = item.dataset.name || '';
                document.getElementById('cfCompCfgDesc').value = cfgName;
                document.getElementById('cfCompCfgDescWrap').style.display = cfgName ? '' : 'none';
                cfCfgDd.style.display = 'none';
            });
        });
    }

    /* ===== BILESEN VERI MODELI ===== */
    let ptComponents = [];
    let ptEditIndex = -1;
    let ptSelIndex = -1;

    /* ===== GRID RENDER ===== */
    function renderGrid() {
        var tbody = document.getElementById('ptLinesBody');
        var empty = document.getElementById('ptEmptyState');
        var badge = document.getElementById('ptCompCountBadge');
        var navCount = document.getElementById('ptCompCount');
        if (!tbody) return;
        var countText = ptComponents.length + ' bilesen';
        if (badge) badge.textContent = countText;
        if (navCount) navCount.textContent = String(ptComponents.length);
        if (!ptComponents.length) {
            empty.style.display = '';
            tbody.innerHTML = '';
            return;
        }
        empty.style.display = 'none';
        tbody.innerHTML = ptComponents.map(function(c, i) {
            var sel = i === ptSelIndex ? 'selected' : '';
            var cfgBadge = c.hasConfig
                ? '<span class="pte-row-badge">' + escHtml(c.cfgCode || 'Secilmedi') + '</span>'
                : '<span style="opacity:0.3;">-</span>';
            return '<tr class="' + sel + '" data-idx="' + i + '">' +
                '<td class="pte-comp-td" style="white-space:nowrap;">' +
                    '<button class="pte-icon-btn pte-icon-btn--edit pt-edit-row" data-idx="' + i + '" title="Duzelt">' +
                        '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>' +
                    '</button>' +
                    '<button class="pte-icon-btn pte-icon-btn--del pt-delete-row" data-idx="' + i + '" title="Sil">' +
                        '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>' +
                    '</button>' +
                '</td>' +
                '<td class="pte-comp-td" style="opacity:0.4;">' + (i + 1) + '</td>' +
                '<td class="pte-comp-td"><strong>' + escHtml(c.code) + '</strong></td>' +
                '<td class="pte-comp-td">' + escHtml(c.name || '-') + '</td>' +
                '<td class="pte-comp-td">' + c.qty + '</td>' +
                '<td class="pte-comp-td">' + c.scrap + '</td>' +
                '<td class="pte-comp-td">' + cfgBadge + '</td>' +
                '</tr>';
        }).join('');
    }

    /* ===== COMP FORM LOAD/CLEAR ===== */
    function loadCompForm(idx) {
        var btn = document.getElementById('ptCompFormSubmit');
        var cancelBtn = document.getElementById('ptCompFormCancel');
        ptEditIndex = idx;
        if (idx >= 0) {
            var c = ptComponents[idx];
            if (btn) { btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Guncelle'; }
            if (cancelBtn) cancelBtn.style.display = '';
            var f = function(id, val) { var el = document.getElementById(id); if (el) el.value = val; };
            f('cfCompCode', c.code); f('cfCompName', c.name);
            f('cfCompQty', c.qty); f('cfCompScrap', c.scrap);
            f('cfCompCfgCode', c.cfgCode || ''); f('cfCompCfgDesc', c.cfgDesc || '');
            var cfgWrap = document.getElementById('cfCompCfgWrap');
            var cfgDescWrap = document.getElementById('cfCompCfgDescWrap');
            if (cfgWrap) cfgWrap.style.display = c.hasConfig ? 'flex' : 'none';
            if (cfgDescWrap) cfgDescWrap.style.display = (c.hasConfig && c.cfgDesc) ? 'flex' : 'none';
            ptCompMaterialCode = c.hasConfig ? c.code : null;
            ptCompCachedCombos = [];
        } else {
            clearCompForm();
        }
    }

    function clearCompForm() {
        var btn = document.getElementById('ptCompFormSubmit');
        var cancelBtn = document.getElementById('ptCompFormCancel');
        if (btn) btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14"/></svg> Ekle';
        if (cancelBtn) cancelBtn.style.display = 'none';
        var f = function(id, val) { var el = document.getElementById(id); if (el) el.value = val; };
        f('cfCompCode', ''); f('cfCompName', ''); f('cfCompQty', '1'); f('cfCompScrap', '0');
        f('cfCompCfgCode', ''); f('cfCompCfgDesc', '');
        var cfgWrap = document.getElementById('cfCompCfgWrap');
        var cfgDescWrap = document.getElementById('cfCompCfgDescWrap');
        if (cfgWrap) cfgWrap.style.display = 'none';
        if (cfgDescWrap) cfgDescWrap.style.display = 'none';
        ptEditIndex = -1; ptSelIndex = -1;
        ptCompMaterialCode = null; ptCompCachedCombos = [];
        document.querySelectorAll('#ptLinesBody tr').forEach(function(r) { r.classList.remove('selected'); });
        renderGrid();
    }

    document.getElementById('ptCompFormCancel')?.addEventListener('click', clearCompForm);

    /* ===== COMP ADD/UPDATE ===== */
    document.getElementById('ptCompFormSubmit')?.addEventListener('click', function() {
        var codeEl = document.getElementById('cfCompCode');
        var code = codeEl.value.trim();
        var name = document.getElementById('cfCompName')?.value.trim() || '';
        var qty = parseFloat(document.getElementById('cfCompQty').value);
        var scrap = parseFloat(document.getElementById('cfCompScrap').value) || 0;
        var hasConfig = document.getElementById('cfCompCfgWrap').style.display !== 'none';
        var cfgCode = document.getElementById('cfCompCfgCode').value.trim();
        var cfgDesc = document.getElementById('cfCompCfgDesc').value.trim();

        if (!code) { codeEl.classList.add('is-invalid'); setTimeout(function() { codeEl.classList.remove('is-invalid'); }, 2000); return; }
        if (!qty || qty <= 0) {
            var qtyEl = document.getElementById('cfCompQty');
            qtyEl.classList.add('is-invalid'); qtyEl.focus();
            setTimeout(function() { qtyEl.classList.remove('is-invalid'); }, 2000); return;
        }
        if (hasConfig && !cfgCode) {
            var cfgEl = document.getElementById('cfCompCfgCode');
            cfgEl.classList.add('is-invalid');
            setTimeout(function() { cfgEl.classList.remove('is-invalid'); }, 2000); return;
        }

        var component = { code: code, name: name, qty: qty, scrap: scrap, hasConfig: hasConfig, cfgCode: cfgCode, cfgDesc: cfgDesc };
        if (ptEditIndex >= 0) { ptComponents[ptEditIndex] = component; }
        else { ptComponents.push(component); }
        clearCompForm();
        renderGrid();
    });

    /* ===== GRID ROW CLICK ===== */
    document.getElementById('ptLinesBody')?.addEventListener('click', function(e) {
        var delBtn = e.target.closest('.pt-delete-row');
        var editBtn = e.target.closest('.pt-edit-row');
        if (delBtn) {
            var idx = parseInt(delBtn.dataset.idx);
            ptComponents.splice(idx, 1);
            if (ptEditIndex === idx) clearCompForm();
            else if (ptEditIndex > idx) ptEditIndex--;
            ptSelIndex = -1;
            renderGrid(); return;
        }
        if (editBtn) {
            var idx = parseInt(editBtn.dataset.idx);
            ptSelIndex = idx;
            renderGrid();
            loadCompForm(idx); return;
        }
    });

    /* ===== LOAD EXISTING TREE ===== */
    let ptCurrentId = null;

    async function ptLoadExistingTree(materialCode, configCode, switchTab) {
        if (switchTab === undefined) switchTab = true;
        try {
            var url = '/Logistics/GetBOM?materialCode=' + encodeURIComponent(materialCode)
                + (configCode ? '&configCode=' + encodeURIComponent(configCode) : '');
            var resp = await fetch(url, { credentials: 'include' });
            if (!resp.ok) return;
            var data = await resp.json();

            ptComponents = []; ptCurrentId = null; ptSelIndex = -1; ptEditIndex = -1;

            if (data.found) {
                ptCurrentId = data.id;
                ptComponents = (data.lines || []).map(function(l) { return {
                    code: l.componentMaterialCode,
                    name: l.componentMaterialName || l.componentMaterialCode,
                    qty: l.quantity, scrap: l.scrapRatio,
                    hasConfig: !!l.componentConfigCode,
                    cfgCode: l.componentConfigCode || null
                }; });

                var savedFitMode = data.imageFitMode || 'square';
                ptCurrentImageMode = savedFitMode;
                document.getElementById('ptImageFitMode').value = savedFitMode;
                document.querySelectorAll('.pte-img-btn--mode').forEach(function(b) {
                    b.classList.toggle('is-active', b.dataset.mode === savedFitMode);
                });

                var imgBase64 = data.imageBase64;
                var imgMimeType = data.imageMimeType || 'image/png';
                if (imgBase64) {
                    var dataUrl = 'data:' + imgMimeType + ';base64,' + imgBase64;
                    document.getElementById('ptImageBase64').value = dataUrl;
                    var img = new Image();
                    img.onload = function() { ptCurrentLoadedImg = img; ptProcessImageToCanvas(); };
                    img.src = dataUrl;
                } else {
                    if (typeof ptClearImage === 'function') ptClearImage();
                }

                if (switchTab)
                    document.querySelector('.pte-nav-btn[data-tab="bilesen"]')?.click();
            }
            renderGrid();
        } catch { /* connection error */ }
    }

    /* ===== RESET FORM ===== */
    function ptResetMainForm() {
        ptCurrentId = null;
        ['ptParentCode','ptParentName','ptConfigCode'].forEach(function(id) {
            var el = document.getElementById(id); if (el) el.value = '';
        });
        var descRow = document.getElementById('ptConfigDescRow');
        if (descRow) descRow.style.display = 'none';
        var cfgRow = document.getElementById('ptConfigRow');
        if (cfgRow) cfgRow.style.display = 'none';
        if (typeof ptClearImage === 'function') ptClearImage();
        ptSetImageMode('square');
        ptComponents = []; ptSelIndex = -1; ptEditIndex = -1;
        renderGrid(); clearCompForm();
        var genel = document.querySelector('.pte-nav-btn[data-tab="genel"]');
        if (genel) genel.click();
    }

    document.getElementById('ptBtnNew')?.addEventListener('click', ptResetMainForm);

    /* ===== SAVE ===== */
    document.getElementById('ptBtnSave')?.addEventListener('click', async function() {
        var parentCode = document.getElementById('ptParentCode')?.value?.trim();
        if (!parentCode) { showMsg('Lutfen once mamul kodunu seciniz.', false); return; }
        if (ptComponents.length === 0) { showMsg('Recetede en az bir bilesen olmalidir.', false); return; }

        var btn = document.getElementById('ptBtnSave');
        btn.disabled = true;

        var imageBase64 = null, imageMimeType = null;
        var rawImg = document.getElementById('ptImageBase64')?.value || '';
        if (rawImg && rawImg !== 'CLEAR') {
            if (rawImg.startsWith('data:')) {
                var parts = rawImg.split(',');
                imageBase64 = parts[1] || null;
                imageMimeType = parts[0].split(':')[1]?.split(';')[0] || 'image/png';
            } else {
                imageBase64 = rawImg;
            }
        }

        var payload = {
            id: ptCurrentId || null,
            parentMaterialCode: parentCode,
            configurationCode: document.getElementById('ptConfigCode')?.value?.trim() || null,
            description: null,
            imageBase64: imageBase64,
            imageMimeType: imageMimeType,
            imageFitMode: document.getElementById('ptImageFitMode')?.value || 'square',
            lines: ptComponents.map(function(c) { return {
                componentMaterialCode: c.code,
                componentConfigCode: c.cfgCode || null,
                quantity: c.qty,
                scrapRatio: c.scrap
            }; })
        };

        try {
            var resp = await fetch('@Url.Action("SaveBOM","Logistics")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify(payload)
            });
            var data = await resp.json();
            if (data.success) {
                showMsg('Recete basariyla kaydedildi.', true);
                ptResetMainForm();
            } else {
                showMsg('Kayit hatasi: ' + (data.message || 'Bilinmeyen hata'), false);
            }
        } catch (err) {
            showMsg('Baglanti hatasi: ' + err.message, false);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg> Kaydet';
        }
    });

    /* ===== URL PRELOAD ===== */
    (async function preloadFromUrl() {
        var p = new URLSearchParams(window.location.search);
        var mat = p.get('mat');
        var cfg = p.get('cfg');
        if (!mat) return;

        try {
            var r = await fetch('/Logistics/StockLookup?q=' + encodeURIComponent(mat), { credentials: 'include' });
            var cards = await r.json();
            var card = cards.find(function(c) { return c.code.toUpperCase() === mat.toUpperCase(); });
            if (!card) return;

            document.getElementById('ptParentCode').value = card.code;
            document.getElementById('ptParentName').value = card.name || '';
            ptCurrentMaterialCode = card.hasConfig ? card.code : null;
            ptCachedCombos = [];

            var cfgRow = document.getElementById('ptConfigRow');
            var cfgInput = document.getElementById('ptConfigCode');
            var cfgDescRow = document.getElementById('ptConfigDescRow');

            if (card.hasConfig && cfg) {
                if (cfgRow) cfgRow.style.display = 'flex';
                if (cfgInput) cfgInput.value = cfg;
                if (cfgDescRow) cfgDescRow.style.display = 'none';
                ptLoadExistingTree(card.code, cfg, false);
            } else {
                if (cfgRow) cfgRow.style.display = card.hasConfig ? 'flex' : 'none';
                ptLoadExistingTree(card.code, null, false);
            }
        } catch { /* silent */ }
    })();

    /* ===== CLOSE ALL DROPDOWNS ON OUTSIDE CLICK ===== */
    document.addEventListener('click', function(e) {
        if (!dd.contains(e.target) && e.target !== btnLookup && !btnLookup?.contains(e.target))
            dd.style.display = 'none';
        if (!compDd.contains(e.target) && e.target !== btnCompLookup && !btnCompLookup?.contains(e.target))
            compDd.style.display = 'none';
        if (!comboDd.contains(e.target) && e.target !== btnConfigLookup && !btnConfigLookup?.contains(e.target))
            comboDd.style.display = 'none';
        if (!cfCfgDd.contains(e.target) && e.target !== btnCompCfgLookup && !btnCompCfgLookup?.contains(e.target))
            cfCfgDd.style.display = 'none';
    }, true);

})();
</script>
}
