@{
    ViewData["Title"] = ViewBag.Title;
    ViewData["BodyClass"] = "page-product-trees";
}

@section Styles {
<style>
    /* ── Page-level overrides ── */
    .page-product-trees { --workspace-action-bar-height: 0px; }
    .page-product-trees .workspace-tabs { position:relative;top:unset;flex:0 0 auto;border-bottom:1px solid var(--app-border,#dde3ee);z-index:2; }
    .page-product-trees .workspace-tabs[hidden] { display:block !important;min-height:42px;visibility:hidden;pointer-events:none; }
    .page-product-trees .workspace-action-bar { display:none !important; }
    .page-product-trees .app-content-area { display:flex;flex-direction:column;overflow:hidden; }
    .page-product-trees .integrator-dashboard { flex:1 1 0;min-height:0;display:flex;flex-direction:column; }
    .page-product-trees .integrator-dashboard__content {
        flex:1 1 0;min-height:0;width:auto !important;max-width:none !important;
        padding:0 !important;margin:0 !important;
        display:flex !important;flex-direction:column !important;overflow:hidden;
    }

    /* ── Action bar ── */
    .pte-action-bar {
        display:flex;align-items:center;gap:8px;padding:8px 16px;flex-shrink:0;
        background:rgba(15,15,26,0.85);border-bottom:1px solid rgba(255,255,255,0.06);
        backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
        position:relative;
    }
    body.app-theme-light .pte-action-bar {
        background:rgba(248,250,252,0.92);border-bottom-color:#e2e8f0;
    }
    .pte-action-bar .pte-meta {
        margin-left:auto;font-size:0.72rem;color:rgba(255,255,255,0.55);font-weight:500;
    }
    body.app-theme-light .pte-action-bar .pte-meta { color:#94a3b8; }

    /* ── KITT (Knight Rider) save flash — MaterialCardEdit ile ayni desen ──
       Aksiyon seridinin alt kenarinda yesil sweep bg + glow nokta scanner.
       NOT: pte-action-bar'da overflow:hidden YOK — dropdown menu (.pte-actions-menu)
       action bar'in disinda asagi dogru acilir. KITT scanner zaten action bar
       sinirlari icinde kalacak sekilde konumlandirildi (bottom:0). */
    .pte-action-bar::before {
        content:'';position:absolute;left:0;right:0;bottom:0;
        height:2px;pointer-events:none;opacity:0;
        background:linear-gradient(90deg,
            rgba(0,60,20,0) 0%,
            rgba(10,120,40,.55) 50%,
            rgba(0,60,20,0) 100%);
    }
    .pte-action-bar::after {
        content:'';position:absolute;left:0;bottom:0;
        width:18%;height:4px;pointer-events:none;opacity:0;
        background:linear-gradient(90deg,
            transparent 0%,
            rgba(34,197,94,.35) 18%,
            rgba(74,255,140,1) 50%,
            rgba(34,197,94,.35) 82%,
            transparent 100%);
        box-shadow:
            0 0 10px 2px rgba(34,197,94,.95),
            0 0 22px 6px rgba(34,197,94,.55),
            0 0 40px 12px rgba(34,197,94,.22);
        border-radius:50%;
    }
    .pte-action-bar.is-save-flash::before { animation:pteKittBg   1800ms ease-out forwards; }
    .pte-action-bar.is-save-flash::after  { animation:pteKittScan 1800ms cubic-bezier(.45,.05,.55,.95) forwards; }
    @@keyframes pteKittBg {
        0%, 100% { opacity:0; }
        10%, 90% { opacity:1; }
    }
    @@keyframes pteKittScan {
        0%   { opacity:0; left:0; }
        8%   { opacity:1; }
        48%  { opacity:1; left:82%; }
        52%  { opacity:1; left:82%; }
        92%  { opacity:1; left:0; }
        100% { opacity:0; left:0; }
    }

    /* ── Buttons ── */
    .pte-btn {
        display:inline-flex;align-items:center;gap:6px;
        padding:7px 14px;border-radius:8px;border:1px solid;
        font-size:0.78rem;font-weight:600;cursor:pointer;
        transition:all 0.12s ease;background:transparent;
    }
    .pte-btn:disabled { opacity:0.5;cursor:not-allowed; }
    .pte-btn--primary { background:#6366f1;border-color:#4f46e5;color:#fff; }
    .pte-btn--primary:hover:not(:disabled) { background:#4f46e5; }
    .pte-btn--secondary {
        background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.65);
    }
    body.app-theme-light .pte-btn--secondary { background:#fff;border-color:#e2e8f0;color:#475569; }
    .pte-btn--secondary:hover:not(:disabled) { background:rgba(255,255,255,0.1);color:#fff; }
    body.app-theme-light .pte-btn--secondary:hover:not(:disabled) { background:#f1f5f9;color:#1e293b; }
    .pte-btn--danger {
        background:rgba(239,68,68,0.08);border-color:rgba(239,68,68,0.25);color:#f87171;
    }
    .pte-btn--danger:hover:not(:disabled) { background:rgba(239,68,68,0.18); }
    .pte-btn--actions {
        background:rgba(6,182,212,0.08);border-color:rgba(6,182,212,0.3);color:#67e8f9;
    }
    .pte-btn--actions:hover:not(:disabled),
    .pte-btn--actions.is-active { background:rgba(6,182,212,0.18);color:#a5f3fc; }
    .pte-btn--actions svg:first-child { transition:transform .35s ease; }
    .pte-btn--actions:hover:not(:disabled) svg:first-child,
    .pte-btn--actions.is-active svg:first-child { transform:rotate(60deg); }
    body.app-theme-light .pte-btn--actions {
        background:rgba(6,182,212,0.06);border-color:rgba(6,182,212,0.4);color:#0891b2;
    }
    body.app-theme-light .pte-btn--actions:hover:not(:disabled),
    body.app-theme-light .pte-btn--actions.is-active {
        background:rgba(6,182,212,0.14);color:#0e7490;
    }

    /* ── Islemler dropdown menu ──
       NOT: position:fixed — `.app-content-area`'da overflow:hidden var, bu yuzden
       absolute olunca clipped oluyordu. Konum JS tarafinda buton rect'ine gore
       set edilir (top + right). z-index 9999 = toast (10000) altinda. */
    .pte-actions-wrap { position:relative;display:inline-flex; }
    .pte-actions-menu {
        position:fixed;z-index:9999;
        min-width:240px;display:none;
        background:rgba(23,26,43,.96);border:1px solid rgba(255,255,255,.1);
        border-radius:10px;overflow:hidden;
        box-shadow:0 12px 32px rgba(0,0,0,.5);
        backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
        animation:pteActMenuIn .14s ease-out;
    }
    .pte-actions-menu.is-open { display:block; }
    body.app-theme-light .pte-actions-menu {
        background:#fff;border-color:#e2e8f0;box-shadow:0 12px 32px rgba(15,23,42,.16);
    }
    @@keyframes pteActMenuIn {
        from { opacity:0;transform:translateY(-4px); }
        to   { opacity:1;transform:translateY(0); }
    }
    .pte-actions-menu__item {
        display:flex;align-items:center;gap:10px;
        width:100%;padding:10px 14px;border:0;background:transparent;
        font-size:.8rem;font-weight:500;color:rgba(255,255,255,.85);
        cursor:pointer;text-align:left;
        transition:background .12s,color .12s;
    }
    body.app-theme-light .pte-actions-menu__item { color:#1e293b; }
    .pte-actions-menu__item:hover {
        background:rgba(99,102,241,.14);color:#a5b4fc;
    }
    body.app-theme-light .pte-actions-menu__item:hover {
        background:#eef2ff;color:#4f46e5;
    }
    .pte-actions-menu__item:disabled {
        opacity:.45;cursor:not-allowed;
    }
    .pte-actions-menu__item svg { flex-shrink:0;opacity:.7; }
    .pte-actions-menu__divider {
        height:1px;background:rgba(255,255,255,.08);margin:4px 0;
    }
    body.app-theme-light .pte-actions-menu__divider { background:#e2e8f0; }
    .pte-btn--sm { padding:5px 10px;font-size:0.72rem;border-radius:6px; }

    /* ── Islemler modal ── */
    .pta-overlay {
        position:fixed;inset:0;z-index:9999;display:none;
        background:rgba(8,12,24,.6);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
        align-items:center;justify-content:center;padding:24px;
        animation:ptaFadeIn .15s ease-out;
    }
    .pta-overlay.is-open { display:flex; }
    @@keyframes ptaFadeIn { from { opacity:0; } to { opacity:1; } }
    .pta-panel {
        width:min(520px, 96vw);max-height:88vh;overflow:auto;
        background:rgba(23,26,43,.96);border:1px solid rgba(255,255,255,.08);
        border-radius:14px;box-shadow:0 24px 64px rgba(0,0,0,.55);
        color:rgba(255,255,255,.88);
        animation:ptaSlide .2s cubic-bezier(.2,.9,.3,1);
    }
    body.app-theme-light .pta-panel {
        background:#fff;border-color:#e2e8f0;color:#1e293b;
    }
    @@keyframes ptaSlide { from { transform:translateY(8px) scale(.97); opacity:0; } to { transform:none; opacity:1; } }
    .pta-header {
        display:flex;align-items:center;gap:10px;
        padding:14px 18px;border-bottom:1px solid rgba(255,255,255,.08);
    }
    body.app-theme-light .pta-header { border-bottom-color:#e2e8f0; }
    .pta-header h3 { margin:0;font-size:.92rem;font-weight:700;flex:1; }
    .pta-close {
        background:transparent;border:0;color:inherit;opacity:.6;cursor:pointer;
        padding:4px 8px;border-radius:6px;font-size:1.2rem;line-height:1;
    }
    .pta-close:hover { opacity:1;background:rgba(255,255,255,.06); }
    .pta-section { padding:16px 18px;border-bottom:1px solid rgba(255,255,255,.06); }
    body.app-theme-light .pta-section { border-bottom-color:#e2e8f0; }
    .pta-section:last-of-type { border-bottom:0; }
    .pta-section h4 {
        margin:0 0 10px;font-size:.78rem;font-weight:700;text-transform:uppercase;
        letter-spacing:.04em;color:rgba(255,255,255,.55);
    }
    body.app-theme-light .pta-section h4 { color:#64748b; }
    .pta-source {
        font-size:.78rem;color:rgba(255,255,255,.7);
        padding:8px 12px;border-radius:8px;background:rgba(255,255,255,.04);
        border:1px dashed rgba(255,255,255,.12);margin-bottom:12px;
    }
    body.app-theme-light .pta-source { background:#f8fafc;border-color:#cbd5e1;color:#475569; }
    .pta-source strong { color:#a5b4fc;font-weight:700; }
    body.app-theme-light .pta-source strong { color:#4f46e5; }
    .pta-field { display:flex;flex-direction:column;gap:6px;margin-bottom:12px; }
    .pta-field-label {
        font-size:.74rem;font-weight:600;color:rgba(255,255,255,.7);
    }
    body.app-theme-light .pta-field-label { color:#475569; }
    .pta-field-required::after { content:' *';color:#f87171; }
    .pta-field-row { display:flex;gap:8px;align-items:stretch; }
    .pta-field-row .pte-input { flex:1; }
    .pta-field-name {
        flex:1;padding:9px 12px;border-radius:9px;
        background:rgba(255,255,255,.02);border:1px dashed rgba(255,255,255,.08);
        color:rgba(255,255,255,.55);font-size:.82rem;
    }
    body.app-theme-light .pta-field-name {
        background:#f8fafc;border-color:#e2e8f0;color:#94a3b8;
    }
    .pta-actions {
        padding:14px 18px;display:flex;justify-content:flex-end;gap:10px;
        background:rgba(255,255,255,.02);border-top:1px solid rgba(255,255,255,.06);
    }
    body.app-theme-light .pta-actions { background:#f8fafc;border-top-color:#e2e8f0; }

    /* Modal'da hedef alanlar — LookupCard mount edildiginde dolan kart-input */
    .pta-field-row { position:relative; }
    .pta-field-row .gl-wrapper { flex:1;min-width:0; }
    .pta-field-row .gl-card { width:100%; }

    /* ── Body: sidenav + content ── */
    .pte-body { flex:1 1 0;min-height:0;display:flex;flex-direction:row;overflow:hidden;position:relative; }

    /* ── Sidebar navigation ── */
    .pte-sidenav {
        width:192px;flex-shrink:0;display:flex;flex-direction:column;gap:2px;
        padding:12px 8px;
        background:rgba(255,255,255,0.02);border-right:1px solid rgba(255,255,255,0.07);
        overflow-y:auto;
    }
    body.app-theme-light .pte-sidenav {
        background:#f8fafc;border-right-color:#e2e8f0;
    }
    .pte-sidenav-label {
        font-size:0.7rem;font-weight:700;
        color:rgba(255,255,255,0.55);padding:8px 10px 4px;
    }
    body.app-theme-light .pte-sidenav-label { color:#94a3b8; }
    .pte-nav-btn {
        display:flex;align-items:center;gap:8px;width:100%;
        padding:9px 12px;border:none;background:transparent;cursor:pointer;
        font-size:0.78rem;font-weight:500;color:rgba(255,255,255,0.55);
        border-radius:8px;border-left:3px solid transparent;
        transition:all 0.12s;text-align:left;
    }
    body.app-theme-light .pte-nav-btn { color:#64748b; }
    .pte-nav-btn:hover { background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.8); }
    body.app-theme-light .pte-nav-btn:hover { background:rgba(99,102,241,0.05);color:#475569; }
    .pte-nav-btn.is-active {
        border-left-color:#6366f1;background:rgba(99,102,241,0.09);color:#a5b4fc;font-weight:600;
    }
    body.app-theme-light .pte-nav-btn.is-active {
        background:rgba(99,102,241,0.07);color:#4f46e5;
    }
    .pte-nav-dot {
        width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0;opacity:0.5;
    }
    .pte-nav-btn.is-active .pte-nav-dot { opacity:1; }
    .pte-nav-count {
        margin-left:auto;padding:1px 6px;border-radius:999px;
        font-size:0.6rem;font-weight:700;font-family:monospace;
        background:rgba(99,102,241,0.12);color:#a5b4fc;
        border:1px solid rgba(99,102,241,0.25);flex-shrink:0;
    }
    body.app-theme-light .pte-nav-count { background:rgba(99,102,241,0.08);color:#4f46e5; }

    /* ── Content area ── */
    .pte-content {
        flex:1 1 auto;min-width:0;overflow-y:auto;padding:20px 24px;background:transparent;
    }
    body.app-theme-dark .pte-content,
    html.dark .pte-content {
        background:#0c0f1a;
        background-image:radial-gradient(at 20% 30%,rgba(99,102,241,0.12) 0px,transparent 50%),
                         radial-gradient(at 80% 20%,rgba(14,165,233,0.08) 0px,transparent 50%),
                         radial-gradient(at 50% 80%,rgba(168,85,247,0.08) 0px,transparent 50%);
    }
    body.app-theme-light .pte-content { background:#f8fafc; }

    /* ── Cards ── */
    .pte-card {
        background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);
        border-radius:14px;padding:22px;
        backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
        margin-bottom:16px;
    }
    body.app-theme-light .pte-card {
        background:rgba(255,255,255,0.8);border-color:rgba(15,23,42,0.08);
        box-shadow:0 2px 6px rgba(15,23,42,0.04);
    }
    .pte-card-title {
        font-size:0.85rem;font-weight:700;
        color:rgba(255,255,255,0.85);
        margin:0 0 14px 0;display:flex;align-items:center;gap:8px;
    }
    body.app-theme-light .pte-card-title { color:#64748b; }
    .pte-card-title::before {
        content:'';width:6px;height:6px;border-radius:50%;background:#6366f1;
    }

    /* ── Form grid ── */
    .pte-grid { display:flex;flex-direction:column;gap:12px; }
    .pte-row { display:flex;align-items:center;gap:10px;flex-wrap:wrap; }
    .pte-field { display:flex;flex-direction:column;gap:5px; }
    .pte-label {
        font-size:0.72rem;font-weight:600;color:rgba(255,255,255,0.65);
        letter-spacing:0.02em;white-space:nowrap;flex-shrink:0;
    }
    body.app-theme-light .pte-label { color:#64748b; }
    .pte-label--req::after { content:' *';color:#f87171; }

    /* ── Inputs ── */
    .pte-input {
        padding:9px 12px;border-radius:9px;
        background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);
        color:rgba(255,255,255,0.85);font-size:0.85rem;
        transition:border-color 0.15s,background 0.15s;
        outline:none;
    }
    body.app-theme-light .pte-input { background:#fff;border-color:#e2e8f0;color:#1e293b; }
    .pte-input:focus {
        border-color:#6366f1;background:rgba(255,255,255,0.06);
        box-shadow:0 0 0 3px rgba(99,102,241,0.12);
    }
    body.app-theme-light .pte-input:focus { background:#fff; }
    .pte-input::placeholder { color:rgba(255,255,255,0.4); }
    body.app-theme-light .pte-input::placeholder { color:#94a3b8; }
    .pte-input[readonly] { opacity:0.7;cursor:default; }
    .pte-input.is-invalid {
        border-color:#ef4444;background:rgba(239,68,68,0.06);
        animation:pteShake 0.4s cubic-bezier(.36,.07,.19,.97) both;
    }
    .pte-input[type="number"] { text-align:right;-moz-appearance:textfield; }
    .pte-input[type="number"]::-webkit-outer-spin-button,
    .pte-input[type="number"]::-webkit-inner-spin-button { -webkit-appearance:none;margin:0; }

    /* ── Lookup ── */
    .pte-lookup {
        display:inline-flex;align-items:stretch;border-radius:9px;overflow:hidden;
    }
    .pte-lookup .pte-input { border-radius:9px 0 0 9px;border-right:0; }
    /* LookupCard mount edilince gl-wrapper/gl-card pte-lookup container'ini tam doldursun
       (Mamul Kodu vs Kombinasyon Kodu satirlarinin gorsel paritesi icin). */
    .pte-lookup .gl-wrapper { width:100%;flex:1 1 auto; }
    .pte-lookup .gl-card    { width:100%; }
    .pte-lookup-btn {
        display:flex;align-items:center;justify-content:center;width:36px;
        background:rgba(99,102,241,0.08);border:1px solid rgba(255,255,255,0.1);
        border-left:0;border-radius:0 9px 9px 0;cursor:pointer;
        color:#a5b4fc;transition:all 0.12s;
    }
    body.app-theme-light .pte-lookup-btn {
        background:rgba(99,102,241,0.06);border-color:#e2e8f0;color:#6366f1;
    }
    .pte-lookup-btn:hover { background:rgba(99,102,241,0.18); }

    /* ── Bridge wrapper'i flex stretch — ffl-clear-btn input ile ayni yukseklikte ── */
    .pte-lookup .ffl-wrapper {
        display:flex;align-items:stretch;
    }
    /* ── Bridge clear (X) butonu — rehber (buyutec) butonu ile oranli ── */
    .pte-lookup .ffl-clear-btn {
        width:30px;height:auto;min-height:100%;
        background:transparent;
        border:1px solid rgba(255,255,255,0.1);
        border-left:0;border-right:0;border-radius:0;
        color:rgba(255,255,255,0.35);
        display:flex;align-items:center;justify-content:center;
        transition:all 0.12s;
    }
    .pte-lookup .ffl-clear-btn:hover {
        background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.7);
    }
    body.app-theme-light .pte-lookup .ffl-clear-btn {
        background:transparent;border-color:#e2e8f0;color:#94a3b8;
    }
    body.app-theme-light .pte-lookup .ffl-clear-btn:hover {
        background:rgba(15,23,42,0.04);color:#475569;
    }

    /* ── Image tab — tam yukseklik ── */
    #pteTab-gorsel {
        height:100%;display:flex;flex-direction:column;
    }
    #pteTab-gorsel .pte-card {
        flex:1;min-height:0;display:flex;flex-direction:column;margin-bottom:0;
    }
    #pteTab-gorsel .pte-card-title { flex-shrink:0; }

    /* ── Image area ── */
    .pte-image-area {
        display:flex;align-items:stretch;gap:10px;
        margin-top:10px;padding:14px;border-radius:12px;
        background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);
    }
    #pteTab-gorsel .pte-image-area { flex:1;min-height:0;margin-top:10px; }
    body.app-theme-light .pte-image-area {
        background:#fafbfd;border-color:rgba(15,23,42,0.06);
    }
    .pte-img-actions {
        display:flex;flex-direction:column;gap:6px;flex-shrink:0;
    }
    .pte-img-btn {
        width:32px;height:32px;border-radius:50%;border:1px solid;display:flex;
        align-items:center;justify-content:center;cursor:pointer;transition:all 0.12s;
    }
    .pte-img-btn--upload { background:#6366f1;border-color:#4f46e5;color:#fff; }
    .pte-img-btn--upload:hover { background:#4f46e5; }
    .pte-img-btn--mode {
        background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.12);color:rgba(255,255,255,0.5);
    }
    body.app-theme-light .pte-img-btn--mode { background:#fff;border-color:#e2e8f0;color:#94a3b8; }
    .pte-img-btn--mode.is-active { background:#6366f1;border-color:#4f46e5;color:#fff; }
    .pte-img-btn--clear { background:rgba(239,68,68,0.08);border-color:rgba(239,68,68,0.25);color:#f87171; }
    .pte-img-btn--clear:hover { background:rgba(239,68,68,0.18); }
    .pte-img-preview {
        flex:1 1 0;min-height:140px;border-radius:10px;
        border:2px dashed rgba(255,255,255,0.12);overflow:hidden;position:relative;
        display:flex;align-items:center;justify-content:center;flex-direction:column;
        background:rgba(255,255,255,0.02);
    }
    #pteTab-gorsel .pte-img-preview { min-height:0; }
    body.app-theme-light .pte-img-preview {
        border-color:#cbd5e1;background:#f1f5f9;
    }


    /* ── Bilesen Ekle form — hizali grid ── */
    .pte-card--compact { padding:12px 14px; }
    .pte-bilesen-form {
        display:grid;
        grid-template-columns:100px 1fr;
        row-gap:9px;column-gap:10px;
        align-items:center;
    }
    .pte-bilesen-form .pte-label { text-align:right;white-space:nowrap; }
    .pte-bilesen-form .pte-input { padding:5px 8px;min-width:0; }
    .pte-bilesen-vals {
        display:flex;align-items:center;gap:8px;flex-wrap:nowrap;min-width:0;
    }
    .pte-bilesen-vals .pte-input { min-width:0; }
    .pte-bilesen-actions {
        grid-column:2 / -1;display:flex;gap:8px;margin-top:4px;
    }
    .pte-cfg-disabled { opacity:0.38;pointer-events:none; }

    /* ── Component grid (Bilesen tab) ── */
    .pte-comp-grid {
        margin-top:16px;border-radius:12px;overflow:hidden;
        background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);
    }
    body.app-theme-light .pte-comp-grid {
        background:#fafbfd;border-color:rgba(15,23,42,0.06);
    }
    .pte-comp-header {
        display:flex;align-items:center;gap:8px;padding:10px 14px;
        border-bottom:1px solid rgba(255,255,255,0.06);
    }
    body.app-theme-light .pte-comp-header { border-bottom-color:#e2e8f0; }
    .pte-comp-title {
        font-size:0.85rem;font-weight:700;color:rgba(255,255,255,0.85);
    }
    body.app-theme-light .pte-comp-title { color:#94a3b8; }
    .pte-comp-badge {
        padding:1px 8px;border-radius:999px;font-size:0.62rem;font-weight:700;
        background:rgba(99,102,241,0.12);color:#a5b4fc;
        border:1px solid rgba(99,102,241,0.25);
    }
    body.app-theme-light .pte-comp-badge { background:rgba(99,102,241,0.08);color:#4f46e5; }
    .pte-comp-body { max-height:320px;overflow-y:auto;overflow-x:auto; }
    .pte-comp-table { width:100%;border-collapse:collapse;font-size:0.82rem; }
    .pte-comp-th {
        padding:8px 10px;text-align:left;font-size:0.78rem;font-weight:600;
        color:rgba(255,255,255,0.7);border-bottom:1px solid rgba(255,255,255,0.08);
        position:sticky;top:0;z-index:3;
        background:rgba(15,15,26,0.6);backdrop-filter:blur(8px);
    }
    body.app-theme-light .pte-comp-th {
        color:#64748b;border-bottom-color:#e2e8f0;background:rgba(248,250,252,0.95);
    }
    .pte-comp-td {
        padding:7px 10px;border-bottom:1px solid rgba(255,255,255,0.04);
        color:rgba(255,255,255,0.75);
    }
    body.app-theme-light .pte-comp-td { color:#334155;border-bottom-color:#f0f2f6; }
    .pte-comp-table tbody tr { cursor:pointer;transition:background 0.1s; }
    .pte-comp-table tbody tr:hover .pte-comp-td { background:rgba(99,102,241,0.06); }
    body.app-theme-light .pte-comp-table tbody tr:hover .pte-comp-td { background:rgba(99,102,241,0.04); }
    .pte-comp-table tbody tr.selected .pte-comp-td {
        background:rgba(99,102,241,0.12);
    }
    body.app-theme-light .pte-comp-table tbody tr.selected .pte-comp-td {
        background:rgba(99,102,241,0.08);
    }
    .pte-comp-table tbody tr.selected {
        outline:2px solid rgba(99,102,241,0.4);outline-offset:-1px;border-radius:4px;
    }
    .pte-row-badge {
        display:inline-flex;align-items:center;padding:1px 7px;border-radius:4px;
        font-size:0.7rem;font-weight:600;
        background:rgba(99,102,241,0.12);color:#a5b4fc;
    }
    body.app-theme-light .pte-row-badge { background:rgba(99,102,241,0.08);color:#4f46e5; }
    .pte-icon-btn {
        background:transparent;border:none;cursor:pointer;padding:3px;
        border-radius:4px;transition:all 0.1s;color:rgba(255,255,255,0.45);
        outline:none;box-shadow:none;
    }
    .pte-icon-btn:hover { background:rgba(255,255,255,0.08); }
    .pte-icon-btn--edit:hover { color:#6366f1; }
    .pte-icon-btn--del:hover { color:#f87171; background:transparent; }
    body.app-theme-light .pte-icon-btn { color:#94a3b8; }
    body.app-theme-light .pte-icon-btn--edit:hover { color:#4f46e5; }
    body.app-theme-light .pte-icon-btn--del:hover { color:#ef4444; background:transparent; }

    /* ── Empty state ── */
    .pte-empty {
        text-align:center;padding:32px 16px;color:rgba(255,255,255,0.35);font-size:0.82rem;
    }
    body.app-theme-light .pte-empty { color:rgba(71,85,105,0.5); }

    /* ── Toast — sag alt kose, slide-in ── */
    .pte-message {
        position:fixed;right:24px;bottom:24px;left:auto;top:auto;z-index:10000;
        max-width:380px;min-width:240px;
        padding:0;border-radius:10px;
        font-size:0.82rem;font-weight:500;white-space:normal;overflow:hidden;
        max-height:0;opacity:0;transform:translateY(12px);pointer-events:none;
        transition:max-height 0.22s ease,opacity 0.22s ease,transform 0.22s ease,padding 0.22s ease;
        backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);
        box-shadow:0 10px 28px rgba(0,0,0,.42);
    }
    .pte-message.ok, .pte-message.err {
        max-height:200px;opacity:1;padding:12px 16px;transform:translateY(0);
        border:1px solid;
    }
    .pte-message.ok {
        background:rgba(8,26,17,.92);border-color:rgba(16,185,129,.45);color:#6ee7b7;
    }
    .pte-message.err {
        background:rgba(26,8,8,.92);border-color:rgba(239,68,68,.45);color:#fca5a5;
    }
    body.app-theme-light .pte-message.ok {
        background:rgba(235,253,245,.96);border-color:rgba(16,185,129,.4);color:#047857;
    }
    body.app-theme-light .pte-message.err {
        background:rgba(255,241,241,.96);border-color:rgba(239,68,68,.4);color:#b91c1c;
    }

    /* ── Dropdown (glassmorphic) ── */
    .pte-dd {
        position:fixed !important;z-index:99999 !important;
        background:rgba(15,23,42,0.95);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
        border:1px solid rgba(255,255,255,0.12);border-radius:10px;
        box-shadow:0 8px 32px rgba(0,0,0,0.35);min-width:360px;overflow:hidden;
    }
    body.app-theme-light .pte-dd {
        background:rgba(255,255,255,0.97);border-color:#e2e8f0;
        box-shadow:0 8px 24px rgba(0,0,0,0.12);
    }
    .pte-dd-search {
        padding:8px;border-bottom:1px solid rgba(255,255,255,0.08);
    }
    body.app-theme-light .pte-dd-search { border-bottom-color:#f0f2f6; }
    .pte-dd-list { max-height:240px;overflow-y:auto; }
    .pte-dd-item {
        padding:8px 14px;cursor:pointer;border-bottom:1px solid rgba(255,255,255,0.04);
        font-size:0.82rem;color:rgba(255,255,255,0.8);transition:background 0.1s;
    }
    body.app-theme-light .pte-dd-item { color:#334155;border-bottom-color:#f5f7fb; }
    .pte-dd-item:hover { background:rgba(99,102,241,0.08); }
    body.app-theme-light .pte-dd-item:hover { background:#f0f4ff; }
    .pte-dd-item strong { color:#a5b4fc; }
    body.app-theme-light .pte-dd-item strong { color:#1e293b; }
    .pte-dd-muted { color:rgba(255,255,255,0.45);font-size:0.78rem; }
    body.app-theme-light .pte-dd-muted { color:#64748b; }
    .pte-dd-empty { padding:12px 14px;color:rgba(255,255,255,0.4);font-size:0.82rem; }
    body.app-theme-light .pte-dd-empty { color:#94a3b8; }
    .pte-badge-cfg {
        display:inline-block;padding:1px 6px;border-radius:4px;font-size:0.65rem;font-weight:600;
        background:rgba(99,102,241,0.15);color:#a5b4fc;margin-left:6px;
    }
    body.app-theme-light .pte-badge-cfg { background:rgba(99,102,241,0.1);color:#4f46e5; }

    /* ── Mamul Rehberi (satis teklifi kalem rehberi tarzi) ── */
    .pte-dd--lookup { min-width: 420px; max-width: 520px; border-radius: 8px; }
    .pte-dd--lookup .pte-dd-search { padding: 10px 12px; }
    .pte-dd--lookup .pte-dd-search .pte-input {
        font-size: 0.82rem; padding: 8px 12px; border-radius: 6px;
    }
    .pte-dd--lookup .pte-dd-list { max-height: 320px; padding: 4px; }
    .pte-dd-row {
        display: flex; align-items: center; gap: 12px;
        width: 100%; padding: 8px 12px;
        background: transparent; border: 0; border-radius: 6px;
        text-align: left; cursor: pointer; transition: background .12s;
    }
    .pte-dd-row:hover { background: rgba(99,102,241,0.12); }
    body.app-theme-light .pte-dd-row:hover { background: #eef2ff; }
    .pte-dd-row.is-active { background: rgba(99,102,241,0.18); }
    body.app-theme-light .pte-dd-row.is-active { background: #e0e7ff; }
    .pte-dd-code {
        font-family: 'JetBrains Mono','Fira Code',monospace;
        font-size: 0.76rem; color: #a5b4fc;
        font-variant-numeric: tabular-nums;
        min-width: 120px; flex-shrink: 0; font-weight: 600;
    }
    body.app-theme-light .pte-dd-code { color: #4f46e5; }
    .pte-dd-name {
        font-size: 0.82rem; color: rgba(255,255,255,0.78);
        flex: 1 1 auto; min-width: 0;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    body.app-theme-light .pte-dd-name { color: #334155; }
    .pte-dd-tag {
        flex-shrink: 0; padding: 2px 8px; border-radius: 999px;
        font-size: 0.65rem; font-weight: 700; letter-spacing: 0.02em;
        background: rgba(99,102,241,0.18); color: #a5b4fc;
        border: 1px solid rgba(99,102,241,0.32);
    }
    body.app-theme-light .pte-dd-tag { background: #eef2ff; color: #4f46e5; border-color: #c7d2fe; }
    .pte-chip {
        display:inline-flex;align-items:center;gap:3px;
        background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.25);
        border-radius:4px;padding:0 6px;font-size:0.7rem;margin:2px 2px 0 0;white-space:nowrap;
    }
    body.app-theme-light .pte-chip { background:#f0f4ff;border-color:#c7d2fe; }
    .pte-chip-feat { color:#a5b4fc;font-weight:600; }
    body.app-theme-light .pte-chip-feat { color:#4f46e5; }
    .pte-chip-val { color:rgba(255,255,255,0.7); }
    body.app-theme-light .pte-chip-val { color:#1e293b; }

    /* ── Animations ── */
    @@keyframes pteShake {
        10%,90% { transform:translateX(-1px); }
        20%,80% { transform:translateX(2px); }
        30%,50%,70% { transform:translateX(-4px); }
        40%,60% { transform:translateX(4px); }
    }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide page-product-trees">
  <div class="integrator-dashboard__content">

