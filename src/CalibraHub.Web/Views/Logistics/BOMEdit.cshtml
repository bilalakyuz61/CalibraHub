                    <input type="text" id="ptaTargetConfigCode" class="pte-input" placeholder="Kombinasyon kodunu yazin..." autocomplete="off" />
                    <button type="button" class="pte-btn pte-btn--secondary pte-btn--sm" id="ptaBtnTargetConfigLookup" title="Kombinasyon secimi">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
                    </button>
                </div>
                <input type="text" id="ptaTargetConfigDesc" class="pta-field-name" readonly placeholder="Kombinasyon aciklamasi..." />
            </div>
        </div>

        <div class="pta-actions">
            <button type="button" class="pte-btn pte-btn--secondary" id="ptaBtnCancel">Iptal</button>
            <button type="button" class="pte-btn pte-btn--primary" id="ptaBtnApply">Kopyala ve Kaydet</button>
        </div>
    </div>
</div>


@section Scripts {
<script>
/* ===== SCROLL-AWARE GLASS HEADER =====
   pteContent scroll'unda action bar uzerine 'is-scrolled' class'i ekler —
   gozun ayrim hissetmesi icin border-color + box-shadow degisimi.
   CSS: .pte-action-bar.is-scrolled (yukarida tanimli). */
(function() {
    function attach() {
        var bar = document.querySelector('.pte-action-bar');
        var content = document.getElementById('pteContent');
        if (!bar || !content) return;
        function onScroll() {
            bar.classList.toggle('is-scrolled', content.scrollTop > 4);
        }
        content.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', attach);
    } else {
        attach();
    }
})();

/* ===== REACT BUNDLE YUKLEYICI =====
   BOMs sayfasi workspace iframe'inde calistiginda _Layout.cshtml bundle'i
   yuklemez (shouldUseReactShell = false). Bu yuzden rehber ve kombinasyon
   modali icin gereken window.CalibraHub.* fonksiyonlarini burada dinamik
   yukluyoruz. Shell frame'inde zaten yuklenmis ise tekrar yuklenmez. */
(function() {
    if (window.CalibraHub && window.CalibraHub.openCombinationPicker) return;
    if (document.querySelector('script[data-bom-react-bundle]')) return;
    var BUNDLE_URL = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
    var CSS_URL    = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
    if (!document.querySelector('link[data-bom-react-bundle]')) {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = CSS_URL;
        link.setAttribute('data-bom-react-bundle', '1');
        document.head.appendChild(link);
    }
    var script = document.createElement('script');
    script.src = BUNDLE_URL;
    script.setAttribute('data-bom-react-bundle', '1');
    script.onerror = function() { console.error('[BOM] React bundle yuklenemedi'); };
    document.head.appendChild(script);
})();

(function () {

    /* ===== TOAST ===== */
    function showMsg(text, ok) {
        var m = document.getElementById('pteMsg');
        if (!m) return;
        m.textContent = text;
        m.className = 'pte-message ' + (ok ? 'ok' : 'err');
        setTimeout(function() { m.className = 'pte-message'; m.textContent = ''; }, 4000);
    }

    /* ===== IMAGE PROCESSING (Canvas-based) ===== */
    let ptCurrentImageMode = 'square';
    let ptCurrentLoadedImg = null;
    let ptCurrentImageRotation = 0; // 0/90/180/270 derece (saat yonu)

    /* ===== COMBINATION LOOKUP STATE ===== */
    let ptCurrentMaterialCode = null;

    function ptProcessImageToCanvas() {
        if (!ptCurrentLoadedImg) return;
        const img = ptCurrentLoadedImg;
        const container = document.getElementById('ptImagePreviewContainer');
        const base64Input = document.getElementById('ptImageBase64');
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        const rot = ((ptCurrentImageRotation % 360) + 360) % 360; // normalize
        const swap = (rot === 90 || rot === 270);
        // Onceki crop/scale logic'inin urettigi tx/ty boyutlari (rotation oncesi canvas)
        let tx, ty, drawCall;
        if (ptCurrentImageMode === 'square') {
            const size = Math.min(img.width, img.height);
            const x = (img.width - size) / 2, y = (img.height - size) / 2;
            tx = ty = Math.min(size, 800);
            drawCall = (c) => c.drawImage(img, x, y, size, size, 0, 0, tx, ty);
        } else {
            let scale = Math.min(800 / img.width, 800 / img.height);
            if (scale > 1) scale = 1;
            tx = img.width * scale; ty = img.height * scale;
            drawCall = (c) => c.drawImage(img, 0, 0, img.width, img.height, 0, 0, tx, ty);
        }
        // Rotation icin canvas boyutunu swap et (90/270'te w<->h)
        canvas.width  = swap ? ty : tx;
        canvas.height = swap ? tx : ty;
        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        // Canvas merkezini origin yap, saat yonunde dondur, sonra original tx/ty rect'ini ciz
        ctx.translate(canvas.width / 2, canvas.height / 2);
        ctx.rotate(rot * Math.PI / 180);
        ctx.translate(-tx / 2, -ty / 2);
        drawCall(ctx);
        // Reset transform — sonraki olasi cizimleri etkilemesin
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
        base64Input.value = dataUrl;
        const fitMode = ptCurrentImageMode === 'square' ? 'cover' : 'contain';
        container.innerHTML = '<img id="ptPreviewImgEl" src="' + dataUrl + '" style="width:100%;height:100%;object-fit:' + fitMode + ';border-radius:10px;position:absolute;top:0;left:0;" />';
        container.style.borderStyle = 'solid';
    }

    // Her tiklamada 90° saat yonunde dondurur (0 → 90 → 180 → 270 → 0)
    window.ptRotateImage = function() {
        ptCurrentImageRotation = (ptCurrentImageRotation + 90) % 360;
        var rotInput = document.getElementById('ptImageRotation');
        if (rotInput) rotInput.value = String(ptCurrentImageRotation);
        if (ptCurrentLoadedImg) {
            ptProcessImageToCanvas();
        }
    };

    window.ptSetImageMode = function(mode) {
        ptCurrentImageMode = mode;
        document.getElementById('ptImageFitMode').value = mode;
        document.querySelectorAll('.pte-img-btn--mode').forEach(function(b) {
            b.classList.toggle('is-active', b.dataset.mode === mode);
        });
        if (ptCurrentLoadedImg) {
            ptProcessImageToCanvas();
        } else {
            var el = document.getElementById('ptPreviewImgEl');
            if (el) el.style.objectFit = mode === 'square' ? 'cover' : 'contain';
        }
    };

    window.ptClearImage = function() {
        ptCurrentLoadedImg = null;
        ptCurrentImageRotation = 0;
        var rotInput = document.getElementById('ptImageRotation');
        if (rotInput) rotInput.value = '0';
        document.getElementById('ptImageInput').value = '';
        document.getElementById('ptImageBase64').value = 'CLEAR';
        var container = document.getElementById('ptImagePreviewContainer');
        container.innerHTML = '<svg fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" style="width:36px;height:36px;opacity:.4;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z"></path></svg><span style="font-size:0.75rem;opacity:0.4;padding:0 8px;text-align:center;">Gorsel yukle</span>';
        container.style.borderStyle = 'dashed';
    };

    window.ptPreviewImage = function(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var img = new Image();
                img.onload = function() { ptCurrentLoadedImg = img; ptProcessImageToCanvas(); };
                img.src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        } else {
            ptClearImage();
        }
    };

    /* ===== TAB NAVIGATION ===== */
    // Uyari mesaji yerine alani kirmizi cerceve + titreme ile vurgula — ekrana
    // ek panel/modal acmaz, formu kaydirmaz.
    function ptShakeField(inputId) {
        var el = document.getElementById(inputId);
        if (!el) return;
        // LookupCard mount edildiginde input gizli (display:none) — kullanici
        // shake'i goremez. Bu durumda yakindaki .gl-card elementini shake et.
        var target = el;
        var hidden = el.style.display === 'none' ||
                     (typeof getComputedStyle === 'function' && getComputedStyle(el).display === 'none');
        if (hidden) {
            var card = el.parentNode?.querySelector('.gl-card');
            if (card) target = card;
        }
        target.classList.remove('cb-invalid-shake');
        void target.offsetWidth; // reflow
        target.classList.add('cb-invalid-shake');
        setTimeout(function () {
            target.classList.remove('cb-invalid-shake');
        }, 650);
        // Focus: kart varsa kart-input'a, yoksa orijinal input'a
        var focusEl = (target !== el) ? (target.querySelector('.gl-card__input') || el) : el;
        try { focusEl.focus({ preventScroll: true }); } catch (e) { try { focusEl.focus(); } catch (_) {} }
    }

    function ptCanSwitchToBilesen() {
        var mamulKodu = document.getElementById('ptParentCode')?.value.trim();
        if (!mamulKodu) {
            ptShakeField('ptParentCode');
            return false;
        }
        var cfgRow  = document.getElementById('ptConfigRow');
        var cfgCode = document.getElementById('ptConfigCode')?.value.trim();
        // pte-cfg-disabled aktif degilse => kombinasyon zorunlu
        if (cfgRow && !cfgRow.classList.contains('pte-cfg-disabled') && !cfgCode) {
            ptShakeField('ptConfigCode');
            return false;
        }
        return true;
    }

    document.querySelectorAll('.pte-nav-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var tab = btn.dataset.tab;
            if ((tab === 'bilesen' || tab === 'gorsel') && !ptCanSwitchToBilesen()) return;

            document.querySelectorAll('.pte-nav-btn').forEach(function(b) { b.classList.remove('is-active'); });
            btn.classList.add('is-active');

            // Tab panels
            document.getElementById('pteTab-genel').style.display = (tab === 'genel') ? '' : 'none';
            document.getElementById('pteTab-bilesen').style.display = (tab === 'bilesen') ? '' : 'none';
            var gorselEl = document.getElementById('pteTab-gorsel');
            if (gorselEl) gorselEl.style.display = (tab === 'gorsel') ? '' : 'none';

            if (tab === 'bilesen') renderGrid();
        });
    });

    /* ===== DROPDOWN HELPER ===== */
    function positionDropdown(dd, anchor) {
        var r = anchor.getBoundingClientRect();
        dd.style.top  = (r.bottom + 2) + 'px';
        dd.style.left = r.left + 'px';
        var ddW = dd.offsetWidth || parseInt(dd.style.minWidth) || 360;
        if (r.left + ddW > window.innerWidth - 8) {
            dd.style.left = Math.max(4, window.innerWidth - ddW - 8) + 'px';
        }
        var ddH = dd.offsetHeight || 300;
        if (r.bottom + ddH > window.innerHeight - 10) {
            dd.style.top = Math.max(4, r.top - ddH - 2) + 'px';
        }
    }

    function escHtml(s) {
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(s));
        return d.innerHTML;
    }

    /* ===== KOMBINASYON REHBER MODAL (Mamul + Bilesen) =====
       React tarafindaki CombinationPickerModal'i (sol sidebar iki tab — Mevcut /
       Yeni + deger bazinda aciklama) window.CalibraHub.openCombinationPicker
       uzerinden aciyoruz. Bundle henuz yuklenmediyse butonlar sessizce devre
       disi kalir. */
    var btnConfigLookup = document.getElementById('btnConfigLookup');
    var cfgCodeInput = document.getElementById('ptConfigCode');
    var btnCompCfgLookup = document.getElementById('btnCompCfgLookup');
    let ptCompMaterialCode = null;

    function ptBuildComboDesc(details) {
        return (details || []).map(function(d) {
            var label = d.featureName + ' (' + (d.valueName || d.valueCode || '') + ')';
            return d.description ? (label + ' — ' + d.description) : label;
        }).join(', ');
    }

    function ptOpenComboPicker(materialCode, opts, retriesLeft) {
        if (retriesLeft === undefined) retriesLeft = 10;
        if (!window.CalibraHub || typeof CalibraHub.openCombinationPicker !== 'function') {
            if (retriesLeft > 0) {
                // Bundle yuklenmesi icin kisa bekleme — ilk click'te yari yarıya yuklenmis olabilir.
                setTimeout(function() { ptOpenComboPicker(materialCode, opts, retriesLeft - 1); }, 200);
                return true;
            }
            var diag = !window.CalibraHub
                ? 'window.CalibraHub tanimsiz — React bundle hic yuklenmemis'
                : 'window.CalibraHub.openCombinationPicker yok — bundle ESKI: tarayici cache siliniz veya Ctrl+Shift+R';
            showMsg(diag, false);
            console.error('[BOM]', diag, { CalibraHub: window.CalibraHub });
            return false;
        }
        CalibraHub.openCombinationPicker(materialCode, opts);
        return true;
    }

    btnConfigLookup?.addEventListener('click', function() {
        // Mamul kodu DOM input'undan okuyoruz — bridge ya da elle yazim fark etmez.
        var parentEl = document.getElementById('ptParentCode');
        var materialCode = parentEl ? (parentEl.value || '').trim() : '';
        if (!materialCode && window.ptCurrentMaterialCode) materialCode = window.ptCurrentMaterialCode;
        if (!materialCode && ptCurrentMaterialCode) materialCode = ptCurrentMaterialCode;
        if (!materialCode) {
            showMsg('Once mamul kodu girin', false);
            ptShakeField('ptParentCode');
            return;
        }
        ptOpenComboPicker(materialCode, {
            materialName: (document.getElementById('ptParentName')?.value || '').trim(),
            currentCode: cfgCodeInput ? cfgCodeInput.value : null,
            onApply: function(configId, code, details) {
                if (cfgCodeInput) cfgCodeInput.value = code;
                var descText = ptBuildComboDesc(details);
                var descEl = document.getElementById('ptConfigDesc');
                var descRowEl = document.getElementById('ptConfigDescRow');
                if (descEl) descEl.value = descText;
                if (descRowEl) descRowEl.style.display = descText ? 'flex' : 'none';
                if (typeof ptLoadExistingTree === 'function') ptLoadExistingTree(materialCode, code);
            }
        });
    });

    btnCompCfgLookup?.addEventListener('click', function() {
        var compCodeEl = document.getElementById('cfCompCode');
        var materialCode = ptCompMaterialCode || (compCodeEl ? (compCodeEl.value || '').trim() : '');
        if (!materialCode) {
            showMsg('Once bilesen kodu girin', false);
            ptShakeField('cfCompCode');
            return;
        }
        var cfCompCfgCode = document.getElementById('cfCompCfgCode');
        ptOpenComboPicker(materialCode, {
            materialName: (document.getElementById('cfCompName')?.value || '').trim(),
            currentCode: cfCompCfgCode ? cfCompCfgCode.value : null,
            onApply: function(configId, code, details) {
                if (cfCompCfgCode) cfCompCfgCode.value = code;
                var descText = ptBuildComboDesc(details);
                var cfCompCfgDesc = document.getElementById('cfCompCfgDesc');
                if (cfCompCfgDesc) cfCompCfgDesc.value = descText;
            }
        });
    });

    /* ===== KOMBINASYON ELLE GIRIS — BLUR DOGRULAMASI =====
       Kullanici ptConfigCode'a elle yazdiginda focus cikinca kodu sunucuya
       sorup dogrular. Dogru ise aciklama otomatik dolar; yanlis ise input
       kirmizi titrer ve temizlenmez (kullanici duzeltebilir). Mamul kodu
       LookupCard tarafindan yonetilir; blur dogrulamasi gerekmez. */
    var ptParentCodeEl = document.getElementById('ptParentCode');
    var ptConfigCodeEl = document.getElementById('ptConfigCode');

    async function ptValidateConfigCode() {
        if (!ptConfigCodeEl || !ptParentCodeEl) return;
        var code = (ptConfigCodeEl.value || '').trim();
        if (!code) return;
        var mat = (ptParentCodeEl.value || '').trim();
        if (!mat) {
            showMsg('Once mamul kodu girin', false);
            ptShakeField('ptParentCode');
            return;
        }
        try {
            var resp = await fetch('/Sales/GetCombinations?materialCode=' + encodeURIComponent(mat));
            var list = await resp.json();
            var match = (list || []).find(function(c) { return (c.code || '').toLowerCase() === code.toLowerCase(); });
            if (!match) {
                showMsg('Gecersiz kombinasyon kodu: ' + code, false);
                ptShakeField('ptConfigCode');
                return;
            }
            ptConfigCodeEl.value = match.code;
            var descText = (match.features || []).map(function(fv) {
                return fv.feature + ' (' + fv.value + ')';
            }).join(', ');
            var descEl = document.getElementById('ptConfigDesc');
            var descRowEl = document.getElementById('ptConfigDescRow');
            if (descEl) descEl.value = descText;
            if (descRowEl) descRowEl.style.display = descText ? 'flex' : 'none';
            if (typeof ptLoadExistingTree === 'function') ptLoadExistingTree(mat, match.code);
        } catch (err) {
            showMsg('Kombinasyon kodu dogrulanamadi', false);
        }
    }

    ptConfigCodeEl?.addEventListener('blur', ptValidateConfigCode);

    /* ===== BILESEN VERI MODELI ===== */
    let ptComponents = [];
    let ptEditIndex = -1;
    let ptSelIndex = -1;

    /* ===== GRID RENDER ===== */
    function renderGrid() {
        var tbody = document.getElementById('ptLinesBody');
        var empty = document.getElementById('ptEmptyState');
        var badge = document.getElementById('ptCompCountBadge');
        var navCount = document.getElementById('ptCompCount');
        if (!tbody) return;
        var countText = ptComponents.length + ' bilesen';
        if (badge) badge.textContent = countText;
        if (navCount) {
            navCount.textContent = String(ptComponents.length);
            // data-count attribute → CSS'te muted/accent state ayrimi (badge polish)
            navCount.setAttribute('data-count', String(ptComponents.length));
        }
        if (!ptComponents.length) {
            empty.style.display = '';
            tbody.innerHTML = '';
            return;
        }
        empty.style.display = 'none';
        tbody.innerHTML = ptComponents.map(function(c, i) {
            var sel = i === ptSelIndex ? 'selected' : '';
            var cfgBadge = c.hasConfig
                ? '<span class="pte-row-badge">' + escHtml(c.cfgCode || 'Secilmedi') + '</span>'
                : '<span style="opacity:0.3;">-</span>';
            return '<tr class="' + sel + '" data-idx="' + i + '">' +
                '<td class="pte-comp-td" style="white-space:nowrap;">' +
                    '<button class="pte-icon-btn pte-icon-btn--edit pt-edit-row" data-idx="' + i + '" title="Duzelt">' +
                        '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>' +
                    '</button>' +
                    '<button class="pte-icon-btn pte-icon-btn--del pt-delete-row" data-idx="' + i + '" title="Sil">' +
                        '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>' +
                    '</button>' +
                '</td>' +
                '<td class="pte-comp-td" style="opacity:0.4;">' + (i + 1) + '</td>' +
                '<td class="pte-comp-td"><strong>' + escHtml(c.code) + '</strong></td>' +
                '<td class="pte-comp-td">' + escHtml(c.name || '-') + '</td>' +
                '<td class="pte-comp-td">' + c.qty + '</td>' +
                '<td class="pte-comp-td">' + c.scrap + '</td>' +
                '<td class="pte-comp-td">' + cfgBadge + '</td>' +
                '</tr>';
        }).join('');
    }

    /* ===== COMP FORM LOAD/CLEAR ===== */
    function loadCompForm(idx) {
        var btn = document.getElementById('ptCompFormSubmit');
        var cancelBtn = document.getElementById('ptCompFormCancel');
        ptEditIndex = idx;
        if (idx >= 0) {
            var c = ptComponents[idx];
            if (btn) { btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Guncelle'; }
            if (cancelBtn) cancelBtn.style.display = '';
            var f = function(id, val) { var el = document.getElementById(id); if (el) el.value = val; };
            f('cfCompCode', c.code); f('cfCompName', c.name);
            f('cfCompQty', c.qty); f('cfCompScrap', c.scrap);
            f('cfCompCfgCode', c.cfgCode || ''); f('cfCompCfgDesc', c.cfgDesc || '');
            f('cfCompNote', c.note || '');
            // cfCompCode FixedFieldLookupBridge mount edilmis — DOM value set
            // tek basina React state'i guncellemiyor. data-* attribute'larini
            // doldur ve ffl-sync ile bridge'a tazeleme sinyali yolla; bridge
            // value + display'i DOM'dan okur.
            var compCodeEl = document.getElementById('cfCompCode');
            if (compCodeEl) {
                compCodeEl.setAttribute('data-value', c.code);
                compCodeEl.setAttribute('data-display', c.name || c.code);
                try { compCodeEl.dispatchEvent(new CustomEvent('ffl-sync')); } catch (e) { /* ignore */ }
            }
            var cfgWrap = document.getElementById('cfCompCfgWrap');
            var cfgLabel = document.getElementById('cfCompCfgLabel');
            if (cfgWrap) cfgWrap.classList.toggle('pte-cfg-disabled', !c.hasConfig);
            if (cfgLabel) cfgLabel.classList.toggle('pte-cfg-disabled', !c.hasConfig);
            ptCompMaterialCode = c.hasConfig ? c.code : null;
        } else {
            clearCompForm();
        }
    }

    function clearCompForm() {
        var btn = document.getElementById('ptCompFormSubmit');
        var cancelBtn = document.getElementById('ptCompFormCancel');
        if (btn) btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="13" height="13"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14"/></svg> Ekle';
        if (cancelBtn) cancelBtn.style.display = 'none';
        var f = function(id, val) { var el = document.getElementById(id); if (el) el.value = val; };
        f('cfCompCode', ''); f('cfCompName', ''); f('cfCompQty', '1'); f('cfCompScrap', '0');
        f('cfCompCfgCode', ''); f('cfCompCfgDesc', ''); f('cfCompNote', '');
        // cfCompCode FixedFieldLookupBridge mount edilmis — DOM value=null tek
        // basina React state'ini temizlemiyor. ffl-clear event'i bridge'a sinyal
        // gonderir; useState + data-* attribute'larini sifirlar.
        var compCodeEl = document.getElementById('cfCompCode');
        if (compCodeEl) {
            try { compCodeEl.dispatchEvent(new CustomEvent('ffl-clear')); } catch (e) { /* ignore */ }
        }
        var cfgWrap = document.getElementById('cfCompCfgWrap');
        var cfgLabel = document.getElementById('cfCompCfgLabel');
        if (cfgWrap) cfgWrap.classList.add('pte-cfg-disabled');
        if (cfgLabel) cfgLabel.classList.add('pte-cfg-disabled');
        ptEditIndex = -1; ptSelIndex = -1;
        ptCompMaterialCode = null;
        document.querySelectorAll('#ptLinesBody tr').forEach(function(r) { r.classList.remove('selected'); });
        renderGrid();
    }

    document.getElementById('ptCompFormCancel')?.addEventListener('click', clearCompForm);

    /* ===== COMP ADD/UPDATE ===== */
    document.getElementById('ptCompFormSubmit')?.addEventListener('click', function() {
        var codeEl = document.getElementById('cfCompCode');
        var code = codeEl.value.trim();
        var name = document.getElementById('cfCompName')?.value.trim() || '';
        var qty = parseFloat(document.getElementById('cfCompQty').value);
        var scrap = parseFloat(document.getElementById('cfCompScrap').value) || 0;
        var cfgWrapEl = document.getElementById('cfCompCfgWrap');
        var hasConfig = cfgWrapEl && !cfgWrapEl.classList.contains('pte-cfg-disabled');
        var cfgCode = document.getElementById('cfCompCfgCode').value.trim();
        var cfgDesc = document.getElementById('cfCompCfgDesc').value.trim();
        var note = document.getElementById('cfCompNote')?.value.trim() || '';

        if (!code) { codeEl.classList.add('is-invalid'); setTimeout(function() { codeEl.classList.remove('is-invalid'); }, 2000); return; }
        if (!qty || qty <= 0) {
            var qtyEl = document.getElementById('cfCompQty');
            qtyEl.classList.add('is-invalid'); qtyEl.focus();
            setTimeout(function() { qtyEl.classList.remove('is-invalid'); }, 2000); return;
        }
        if (hasConfig && !cfgCode) {
            var cfgEl = document.getElementById('cfCompCfgCode');
            cfgEl.classList.add('is-invalid');
            setTimeout(function() { cfgEl.classList.remove('is-invalid'); }, 2000); return;
        }

        var component = { code: code, name: name, qty: qty, scrap: scrap, hasConfig: hasConfig, cfgCode: cfgCode, cfgDesc: cfgDesc, note: note };
        if (ptEditIndex >= 0) { ptComponents[ptEditIndex] = component; }
        else { ptComponents.push(component); }
        clearCompForm();
        renderGrid();
    });

    /* ===== GRID ROW CLICK ===== */
    document.getElementById('ptLinesBody')?.addEventListener('click', function(e) {
        var delBtn = e.target.closest('.pt-delete-row');
        var editBtn = e.target.closest('.pt-edit-row');
        if (delBtn) {
            var idx = parseInt(delBtn.dataset.idx);
            ptComponents.splice(idx, 1);
            if (ptEditIndex === idx) clearCompForm();
            else if (ptEditIndex > idx) ptEditIndex--;
            ptSelIndex = -1;
            renderGrid(); return;
        }
        if (editBtn) {
            var idx = parseInt(editBtn.dataset.idx);
            ptSelIndex = idx;
            renderGrid();
            loadCompForm(idx); return;
        }
    });

    /* ===== LOAD EXISTING TREE ===== */
    let ptCurrentId = null;

    // Kombinasyon row'u her zaman gorunur; konfigurasyon yoksa pasif (gri+disable)
    // pte-cfg-disabled toggle pattern'i bilesen form'undaki ile birebir.
    function ptSetConfigRowEnabled(enabled) {
        var row   = document.getElementById('ptConfigRow');
        var label = document.getElementById('ptConfigLabel');
        if (row)   row.classList.toggle('pte-cfg-disabled', !enabled);
        if (label) label.classList.toggle('pte-cfg-disabled', !enabled);
    }
    // Module-disi (parent listener IIFE) erisimi icin window'a expose
    window.ptSetConfigRowEnabled = ptSetConfigRowEnabled;

    // Recete durum pill'i (Mamul Bilgileri kart basliginda gosterilir)
    function ptSetRecipeStatus(mode) {
        var el = document.getElementById('pteRecipeStatus');
        if (!el) return;
        if (mode === 'existing') {
            el.textContent = 'Mevcut reçete yüklendi';
            el.className = 'pte-recipe-status pte-recipe-status--existing';
            el.style.display = '';
        } else if (mode === 'new') {
            el.textContent = 'Yeni reçete tanımlanıyor';
            el.className = 'pte-recipe-status pte-recipe-status--new';
            el.style.display = '';
        } else {
            el.className = 'pte-recipe-status';
            el.style.display = 'none';
            el.textContent = '';
        }
    }
    window.ptSetRecipeStatus = ptSetRecipeStatus;

    // ── Rota (Routing) — standart rehber (tip 1) baglantisi (2026-05-20) ──
    // BOMEdit.cshtml input id="ptRoutingCode" data-field-key="routingCode" tasiyor.
    // FixedFieldLookupBridge (mountFixedFieldLookups('PRODUCT_TREES')) bu input'a
    // LookupCard'i giydirir; kullanici 🔍 ile cbv_Guide_Routing rehberini acar veya
    // kod yazip blur'da resolve eder. Bridge input.value = Code stringi (Code rehber
    // ValueColumn'u), data-display = Name (DisplayColumn).
    //
    // Save oncesi Code -> Id resolve etmek icin /Production/RoutingsList cache'i kullaniyoruz.
    // BOM.RoutingId int FK — backend SaveBOMRequest.RoutingId bekliyor; hidden ptRoutingId
    // de bu degeri tasiyor. Bridge -> code degisince listener resolve eder.
    var ptRoutingsCache = null; // [{ id, code, name, description }, ...]
    async function ptLoadRoutingsOnce() {
        if (ptRoutingsCache !== null) return ptRoutingsCache;
        try {
            var resp = await fetch('/Production/RoutingsList', { credentials: 'include' });
            if (!resp.ok) { ptRoutingsCache = []; return ptRoutingsCache; }
            var list = await resp.json();
            ptRoutingsCache = Array.isArray(list)
                ? list.filter(function(r) { return r && r.isActive !== false; })
                : [];
        } catch {
            ptRoutingsCache = [];
        }
        return ptRoutingsCache;
    }

    // Display + hidden ID + name/desc satellite input'lari senkronize et.
    function ptSetRoutingSelection(id, code, name, description) {
        var hid     = document.getElementById('ptRoutingId');
        var codeEl  = document.getElementById('ptRoutingCode');
        var nameEl  = document.getElementById('ptRoutingName');
        var descEl  = document.getElementById('ptRoutingDesc');
        if (!hid || !codeEl) return;
        if (id == null || id === '' || id === 0 || id === '0') {
            hid.value = '';
            if (codeEl.value) {
                try { codeEl.dispatchEvent(new CustomEvent('ffl-clear')); } catch (e) { /* ignore */ }
            }
            codeEl.value = '';
            codeEl.removeAttribute('data-value');
            codeEl.removeAttribute('data-display');
            if (nameEl) nameEl.value = '';
            if (descEl) { descEl.value = ''; descEl.style.display = 'none'; }
            return;
        }
        hid.value = String(id);
        codeEl.value = code || '';
        codeEl.setAttribute('data-value', code || '');
        codeEl.setAttribute('data-display', name || '');
        try { codeEl.dispatchEvent(new CustomEvent('ffl-sync')); } catch (e) { /* ignore */ }
        if (nameEl) nameEl.value = name || '';
        if (descEl) {
            descEl.value = description || '';
            descEl.style.display = description ? '' : 'none';
        }
    }

    // Bridge kullanici secimi yapinca codeEl.value = Code olur; cache'den
    // Id/Name/Description'i bulup hidden + satellite input'lara yansit.
    async function ptResolveRoutingFromCode() {
        var codeEl = document.getElementById('ptRoutingCode');
        var hid    = document.getElementById('ptRoutingId');
        if (!codeEl || !hid) return;
        var code = (codeEl.value || '').trim();
        if (!code) {
            // Kullanici elle sildi → secimi kaldir
            hid.value = '';
            var nameEl = document.getElementById('ptRoutingName');
            var descEl = document.getElementById('ptRoutingDesc');
            if (nameEl) nameEl.value = '';
            if (descEl) { descEl.value = ''; descEl.style.display = 'none'; }
            return;
        }
        var list = await ptLoadRoutingsOnce();
        var match = (list || []).find(function(r) {
            return (r.code || '').toLowerCase() === code.toLowerCase();
        });
        var nameEl = document.getElementById('ptRoutingName');
        var descEl = document.getElementById('ptRoutingDesc');
        if (match) {
            hid.value = String(match.id);
            if (nameEl) nameEl.value = match.name || '';
            if (descEl) {
                descEl.value = match.description || '';
                descEl.style.display = match.description ? '' : 'none';
            }
        } else {
            // Bridge data-display'i set etmis olabilir; ondan name'i al
            var disp = codeEl.getAttribute('data-display') || '';
            if (nameEl) nameEl.value = disp;
            // ID resolve edemedik — backend Code lookup ile resolve etsin diye hidden bos kalir.
            // (Service zaten "kod -> Id" fallback'i uygulayabilir; aksi halde "Rota bulunamadi" hatasi.)
            hid.value = '';
            if (descEl) { descEl.value = ''; descEl.style.display = 'none'; }
        }
    }

    // ID-bazli rehber preload: cache'den eslesen rotayi bulup display + hidden'a yansit.
    function ptApplyRoutingIdFromCache(routingId) {
        if (routingId == null || routingId === '' || routingId === 0) {
            ptSetRoutingSelection(null);
            return;
        }
        ptLoadRoutingsOnce().then(function(list) {
            var match = (list || []).find(function(r) { return r.id === routingId || r.id === Number(routingId); });
            if (match) ptSetRoutingSelection(match.id, match.code, match.name, match.description);
            else ptSetRoutingSelection(null);
        });
    }

    window.ptLoadRoutingsOnce      = ptLoadRoutingsOnce;
    window.ptApplyRoutingIdFromCache = ptApplyRoutingIdFromCache;
    window.ptSetRoutingSelection   = ptSetRoutingSelection;
    window.ptResolveRoutingFromCode = ptResolveRoutingFromCode;

    // Bridge code degisikliklerini dinle → satellite input'lar tazelensin.
    function ptWireRoutingInputListener() {
        var codeEl = document.getElementById('ptRoutingCode');
        if (!codeEl || codeEl._routingWired) return;
        codeEl._routingWired = true;
        // 'change' bridge syncToDom + native typing sonrasi tetiklenir.
        codeEl.addEventListener('change', function() { ptResolveRoutingFromCode(); });
        // Blur'da da tazele — bridge async resolve yapmis olabilir.
        codeEl.addEventListener('blur', function() { setTimeout(ptResolveRoutingFromCode, 50); });
        // Listeyi arka planda yukle — modal acildiginda anlik veri olur
        ptLoadRoutingsOnce();
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', ptWireRoutingInputListener);
    } else {
        ptWireRoutingInputListener();
    }

    function ptApplyTreeData(data, switchTab) {
        ptComponents = []; ptCurrentId = null; ptSelIndex = -1; ptEditIndex = -1;

        if (data && data.found) {
            ptCurrentId = data.id;
            ptComponents = (data.lines || []).map(function(l) { return {
                code: l.componentMaterialCode,
                name: l.componentMaterialName || l.componentMaterialCode,
                qty: l.quantity, scrap: l.scrapRatio,
                hasConfig: !!l.componentConfigCode,
                cfgCode: l.componentConfigCode || null
            }; });

            // ID-bazli yuklemede mamul + config alanlarini da doldur (kullanici dogru
            // recetenin actigini gormeli; eski code-bazli akista preloadFromUrl bunu
            // zaten yapiyordu, ID-bazli akista burada yapariz).
            // ptParentCode FixedFieldLookupBridge mount edilmis — data-* attribute'lari
            // set edip ffl-sync ile bridge React state'ini DOM'dan tazele.
            var parentCodeEl = document.getElementById('ptParentCode');
            var parentNameEl = document.getElementById('ptParentName');
            if (parentCodeEl && data.itemCode) {
                parentCodeEl.value = data.itemCode;
                parentCodeEl.setAttribute('data-value', data.itemCode);
                parentCodeEl.setAttribute('data-display', data.itemName || data.itemCode);
                try { parentCodeEl.dispatchEvent(new CustomEvent('ffl-sync')); } catch (e) { /* ignore */ }
            }
            if (parentNameEl && data.itemName) parentNameEl.value = data.itemName;

            var cfgInput = document.getElementById('ptConfigCode');
            if (data.configCode) {
                ptSetConfigRowEnabled(true);
                if (cfgInput) cfgInput.value = data.configCode;
            }

            var descInput = document.getElementById('ptRecipeNote');
            if (descInput && data.description != null) descInput.value = data.description;

            // Rota (RoutingId) — opsiyonel header-level FK. Rehber listesi async yuklenir;
            // ptApplyRoutingIdFromCache cache'i bekleyip display'i doldurur.
            if (data.routingId != null && (data.routingCode || data.routingName)) {
                // Backend zaten JOIN ile code/name doldurmus — anlik display, cache beklemeye gerek yok.
                ptSetRoutingSelection(data.routingId, data.routingCode, data.routingName, null);
            } else if (typeof window.ptApplyRoutingIdFromCache === 'function') {
                window.ptApplyRoutingIdFromCache(data.routingId);
            }

            var savedFitMode = data.imageFitMode || 'square';
            ptCurrentImageMode = savedFitMode;
            document.getElementById('ptImageFitMode').value = savedFitMode;
            document.querySelectorAll('.pte-img-btn--mode').forEach(function(b) {
                b.classList.toggle('is-active', b.dataset.mode === savedFitMode);
            });

            // ImageRotation — BE 0/90/180/270 derece olarak doner
            var savedRotation = parseInt(data.imageRotation, 10);
            if (!(savedRotation === 0 || savedRotation === 90 || savedRotation === 180 || savedRotation === 270))
                savedRotation = 0;
            ptCurrentImageRotation = savedRotation;
            var rotInput = document.getElementById('ptImageRotation');
            if (rotInput) rotInput.value = String(savedRotation);

            var imgBase64 = data.imageBase64;
            var imgMimeType = data.imageMimeType || 'image/png';
            if (imgBase64) {
                var dataUrl = 'data:' + imgMimeType + ';base64,' + imgBase64;
                document.getElementById('ptImageBase64').value = dataUrl;
                var img = new Image();
                // Yuklenmis goruntuye rotation tekrar uygulamayalim — DB'de zaten
                // dondurulmus halde saklaniyor. ptCurrentImageRotation 0'a reset.
                ptCurrentImageRotation = 0;
                if (rotInput) rotInput.value = '0';
                img.onload = function() { ptCurrentLoadedImg = img; ptProcessImageToCanvas(); };
                img.src = dataUrl;
            } else {
                if (typeof ptClearImage === 'function') ptClearImage();
            }

            if (switchTab)
                document.querySelector('.pte-nav-btn[data-tab="bilesen"]')?.click();
            ptSetRecipeStatus('existing');
        } else {
            // Yeni recete modu — kullanici girilen mamul kodu icin recete yok.
            // Form'u temiz duruma getir: aciklama, gorsel, mod/rotation reset.
            // Mamul kodu ve adi parent input'larda korunur (kullanici onlari yazdi).
            var descEl = document.getElementById('ptRecipeNote');
            if (descEl) descEl.value = '';

            // Rota secimini de bos duruma getir (yeni recete varsayilani: secilmedi).
            if (typeof window.ptSetRoutingSelection === 'function') window.ptSetRoutingSelection(null);
            if (typeof ptClearImage === 'function') ptClearImage();
            if (typeof ptSetImageMode === 'function') ptSetImageMode('square');
            ptCurrentImageRotation = 0;
            var rotInputClr = document.getElementById('ptImageRotation');
            if (rotInputClr) rotInputClr.value = '0';

            // Status pill: yalniz kullanici parent kod girmisken "yeni" goster.
            // Form henuz bos ise pill'i de gizli tut.
            var parentCodeNowEl = document.getElementById('ptParentCode');
            var parentCodeNow = parentCodeNowEl ? (parentCodeNowEl.value || '').trim() : '';
            ptSetRecipeStatus(parentCodeNow ? 'new' : null);
        }
        renderGrid();
    }
    window.ptApplyTreeData = ptApplyTreeData;

    async function ptLoadExistingTree(materialCode, configCode, switchTab) {
        if (switchTab === undefined) switchTab = true;
        try {
            var url = '/Logistics/GetBOM?materialCode=' + encodeURIComponent(materialCode)
                + (configCode ? '&configCode=' + encodeURIComponent(configCode) : '');
            var resp = await fetch(url, { credentials: 'include' });
            // Sunucu hatasi olsa bile form'u "yeni" duruma geciren reset cagirilsin
            // (ptApplyTreeData {found:false} ile gorsel/aciklama/bilesen temizler).
            var data = resp.ok ? await resp.json() : { found: false };
            ptApplyTreeData(data, switchTab);
        } catch {
            // baglanti hatasi: yine de yeni-recete moduna gec
            ptApplyTreeData({ found: false }, false);
        }
    }
    window.ptLoadExistingTree = ptLoadExistingTree;

    async function ptLoadExistingTreeById(id, switchTab) {
        if (switchTab === undefined) switchTab = true;
        if (!id || id <= 0) return;
        try {
            var resp = await fetch('/Logistics/GetBOMById?id=' + id, { credentials: 'include' });
            if (!resp.ok) return;
            var data = await resp.json();
            ptApplyTreeData(data, switchTab);
        } catch { /* connection error */ }
    }

    /* ===== RESET FORM ===== */
    function ptResetMainForm() {
        ptCurrentId = null;
        // FixedFieldLookupBridge'lar React state'i tutar — DOM input.value=null tek
        // basina kart-input'u temizlemez. 'ffl-clear' custom event ile bridge'a
        // signal yolla; bridge useState'leri temizler ve attribute'lari siler.
        ['ptParentCode','ptConfigCode','cfCompCode'].forEach(function(id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.value = '';
            try { el.dispatchEvent(new CustomEvent('ffl-clear')); } catch (e) { /* ignore */ }
        });
        ['ptParentName','cfCompName'].forEach(function(id) {
            var el = document.getElementById(id); if (el) el.value = '';
        });
        var descRow = document.getElementById('ptConfigDescRow');
        if (descRow) descRow.style.display = 'none';
        ptSetConfigRowEnabled(false);
        var configDesc = document.getElementById('ptConfigDesc');
        if (configDesc) configDesc.value = '';
        if (typeof ptClearImage === 'function') ptClearImage();
        ptSetImageMode('square');
        ptComponents = []; ptSelIndex = -1; ptEditIndex = -1;
        renderGrid(); clearCompForm();
        var genel = document.querySelector('.pte-nav-btn[data-tab="genel"]');
        if (genel) genel.click();
    }

    document.getElementById('ptBtnNew')?.addEventListener('click', function() {
        // "Yeni Recete" — bos edit ekranina (id=0 = yeni kayit) yonlendir.
        // Liste pattern'iyle tutarli: kullanici listenin "Yeni" akisindan da ayni
        // ekrana ulasir. ptResetMainForm hala mevcut (ptaMenuCopy gibi internal
        // resetler icin korunur).
        window.location.href = '/Logistics/BOMEdit';
    });

    /* ===== ISLEMLER MODAL =====
       Aksiyon seridindeki cark butonu modal acar. Modal icinde:
         - Kaynak: aktif recete (ozet)
         - Hedef Mamul Kodu: arama + StockLookup ile resolve
         - Hedef Kombinasyon: hedef mamul hasConfig ise gorunur, validation Sales/GetCombinations
       Uygula → form'a yansit (ptCurrentId=null, bilesenler/gorsel korunur),
       modal kapan, kullanici Kaydet ile yeni BOM olusturur. */
    var ptaOverlay = document.getElementById('ptActionsOverlay');

    function ptaResetTargetFields() {
        var ids = ['ptaTargetCode','ptaTargetName','ptaTargetConfigCode','ptaTargetConfigDesc'];
        ids.forEach(function(id) { var el = document.getElementById(id); if (el) el.value = ''; });
        // Bridge state'i de temizle (LookupCard mount edildiyse kart-input bos olsun)
        ptaTargetLookup?.clear();
        var cfgField = document.getElementById('ptaTargetConfigField');
        if (cfgField) cfgField.style.display = 'none';
        document.getElementById('ptaTargetCode')?.removeAttribute('data-has-config');
    }

    function ptaUpdateSourceText() {
        var srcEl = document.getElementById('ptaCopySource');
        if (!srcEl) return;
        var parentCode = (document.getElementById('ptParentCode')?.value || '').trim();
        var parentName = (document.getElementById('ptParentName')?.value || '').trim();
        var cfgCode = (document.getElementById('ptConfigCode')?.value || '').trim();
        var compCount = (ptComponents || []).length;
        if (!parentCode && compCount === 0) {
            srcEl.innerHTML = 'Aktif recete yok. Once bir recete acin.';
            return;
        }
        var lbl = '<strong>' + (parentCode || '(kod yok)') + '</strong>';
        if (parentName) lbl += ' &middot; ' + parentName;
        if (cfgCode) lbl += ' &middot; Kombinasyon: <strong>' + cfgCode + '</strong>';
        lbl += ' &middot; ' + compCount + ' bilesen';
        srcEl.innerHTML = 'Kaynak: ' + lbl;
    }

    function ptaOpen() {
        if (!ptaOverlay) return;
        ptaResetTargetFields();
        ptaUpdateSourceText();
        ptaOverlay.classList.add('is-open');
        ptaOverlay.setAttribute('aria-hidden', 'false');
        // LookupCard'i ilk acilis'ta mount et (CalibraHub bundle hazir olunca)
        ptaEnsureTargetLookup();
        setTimeout(function() {
            // LookupCard'in kart-input'una focus
            var card = document.querySelector('.pta-field-row .gl-card__input');
            if (card && typeof card.focus === 'function') {
                try { card.focus(); } catch (e) { /* ignore */ }
            } else {
                document.getElementById('ptaTargetCode')?.focus();
            }
        }, 80);
    }

    function ptaClose() {
        if (!ptaOverlay) return;
        ptaOverlay.classList.remove('is-open');
        ptaOverlay.setAttribute('aria-hidden', 'true');
        // LookupCard state temizle (kod/ad bridge'den siler)
        ptaTargetLookup?.clear();
    }

    // Islemler dropdown menu toggle
    var ptaMenuEl = document.getElementById('ptActionsMenu');
    var ptaBtnEl  = document.getElementById('ptBtnActions');
    // Body'ye portal et — herhangi bir ancestor'in stacking context'i veya
    // overflow:hidden'i menuyu etkilemesin (.app-content-area kesiyordu).
    if (ptaMenuEl && ptaMenuEl.parentNode !== document.body) {
        document.body.appendChild(ptaMenuEl);
    }
    function ptaMenuOpen() {
        if (!ptaMenuEl || !ptaBtnEl) return;
        // position:fixed — buton rect'ine gore konumlandir (parent overflow:hidden bypass)
        var rect = ptaBtnEl.getBoundingClientRect();
        ptaMenuEl.style.top = (rect.bottom + 6) + 'px';
        ptaMenuEl.style.right = (window.innerWidth - rect.right) + 'px';
        ptaMenuEl.classList.add('is-open');
        ptaBtnEl.classList.add('is-active');
        ptaBtnEl.setAttribute('aria-expanded', 'true');
    }
    // Resize/scroll sirasinda menu acikken pozisyon guncellensin
    window.addEventListener('resize', function() {
        if (ptaMenuEl?.classList.contains('is-open')) ptaMenuOpen();
    });
    window.addEventListener('scroll', function() {
        if (ptaMenuEl?.classList.contains('is-open')) ptaMenuOpen();
    }, true);
    function ptaMenuClose() {
        if (!ptaMenuEl || !ptaBtnEl) return;
        ptaMenuEl.classList.remove('is-open');
        ptaBtnEl.classList.remove('is-active');
        ptaBtnEl.setAttribute('aria-expanded', 'false');
    }
    ptaBtnEl?.addEventListener('click', function(e) {
        e.stopPropagation();
        if (ptaMenuEl?.classList.contains('is-open')) ptaMenuClose(); else ptaMenuOpen();
    });
    document.addEventListener('click', function(e) {
        if (!ptaMenuEl?.classList.contains('is-open')) return;
        if (ptaMenuEl.contains(e.target) || ptaBtnEl?.contains(e.target)) return;
        ptaMenuClose();
    });
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && ptaMenuEl?.classList.contains('is-open')) ptaMenuClose();
    });

    // Menu item: Receteyi Kopyala → mevcut modali ac
    document.getElementById('ptaMenuCopy')?.addEventListener('click', function() {
        ptaMenuClose();
        ptaOpen();
    });

    document.getElementById('ptaBtnClose')?.addEventListener('click', ptaClose);
    document.getElementById('ptaBtnCancel')?.addEventListener('click', ptaClose);
    ptaOverlay?.addEventListener('click', function(e) { if (e.target === ptaOverlay) ptaClose(); });
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && ptaOverlay?.classList.contains('is-open')) ptaClose();
    });

    // Hedef mamul resolve — kod yazildiginda blur veya buton ile StockLookup'a sor
    async function ptaResolveTarget() {
        var codeEl = document.getElementById('ptaTargetCode');
        var nameEl = document.getElementById('ptaTargetName');
        var cfgField = document.getElementById('ptaTargetConfigField');
        if (!codeEl) return null;
        var code = (codeEl.value || '').trim();
        if (!code) {
            if (nameEl) nameEl.value = '';
            if (cfgField) cfgField.style.display = 'none';
            return null;
        }
        try {
            var resp = await fetch('/Logistics/StockLookup?q=' + encodeURIComponent(code));
            var list = await resp.json();
            var match = (list || []).find(function(s) { return (s.code || '').toLowerCase() === code.toLowerCase(); });
            if (!match) {
                if (nameEl) nameEl.value = '';
                if (cfgField) cfgField.style.display = 'none';
                codeEl.setAttribute('data-has-config', '');
                return null;
            }
            codeEl.value = match.code;
            if (nameEl) nameEl.value = match.name || '';
            var hasCfg = match.hasConfig === true || match.hasConfig === 'true';
            codeEl.setAttribute('data-has-config', hasCfg ? '1' : '0');
            if (cfgField) cfgField.style.display = hasCfg ? '' : 'none';
            if (!hasCfg) {
                document.getElementById('ptaTargetConfigCode').value = '';
                document.getElementById('ptaTargetConfigDesc').value = '';
            }
            return match;
        } catch (err) {
            console.error('[ptaResolveTarget]', err);
            return null;
        }
    }

    // Hedef mamul kodu icin LookupCard (tip 1 standart rehber) mount.
    // Modal acildiginda parentCode'un guideCode'unu FldSet binding'inden alir,
    // modal kapaninca state temizlenir. Pick sonrasi gizli input change event
    // tetiklenir → ptaResolveTarget hasConfig'i StockLookup ile gunceller.
    var ptaTargetLookup = null;
    var ptaParentGuideCode = null;
    async function ptaEnsureTargetLookup() {
        if (ptaTargetLookup || !window.CalibraHub?.mountLookupForInput) return;
        // parentCode binding'inden guide code'u oku — admin'in baglamasi standart
        if (!ptaParentGuideCode) {
            try {
                var resp = await fetch('/api/field-settings/runtime/PRODUCT_TREES');
                var bindings = await resp.json();
                var pb = (bindings || []).find(function(b) { return b.fieldKey === 'parentCode'; });
                ptaParentGuideCode = pb?.viewName || pb?.guideCode || 'ITEMS';
            } catch (e) {
                ptaParentGuideCode = 'ITEMS';
            }
        }
        var input = document.getElementById('ptaTargetCode');
        if (!input) return;
        ptaTargetLookup = CalibraHub.mountLookupForInput({
            inputElement: input,
            guideCode: ptaParentGuideCode,
            isRequired: true,
        });
    }
    // Pick sonrasi change event → hasConfig kontrolu
    document.getElementById('ptaTargetCode')?.addEventListener('change', ptaResolveTarget);

    // Hedef kombinasyon resolve — features icin /Sales/GetCombinations
    async function ptaResolveTargetConfig() {
        var matCode = (document.getElementById('ptaTargetCode')?.value || '').trim();
        var cfgCode = (document.getElementById('ptaTargetConfigCode')?.value || '').trim();
        var descEl = document.getElementById('ptaTargetConfigDesc');
        if (!matCode || !cfgCode) {
            if (descEl) descEl.value = '';
            return null;
        }
        try {
            var resp = await fetch('/Sales/GetCombinations?materialCode=' + encodeURIComponent(matCode));
            var list = await resp.json();
            var match = (list || []).find(function(c) { return (c.code || '').toLowerCase() === cfgCode.toLowerCase(); });
            if (!match) { if (descEl) descEl.value = ''; return null; }
            document.getElementById('ptaTargetConfigCode').value = match.code;
            if (descEl) {
                descEl.value = (match.features || []).map(function(f) {
                    return f.feature + ': ' + (f.value || f.valueCode || '');
                }).join(' | ');
            }
            return match;
        } catch (err) {
            console.error('[ptaResolveTargetConfig]', err);
            return null;
        }
    }

    document.getElementById('ptaTargetConfigCode')?.addEventListener('blur', ptaResolveTargetConfig);
    // Kombinasyon rehberi butonu — mevcut CombinationPickerModal'i kullan
    document.getElementById('ptaBtnTargetConfigLookup')?.addEventListener('click', function() {
        var matCode = (document.getElementById('ptaTargetCode')?.value || '').trim();
        if (!matCode) { showMsg('Once hedef mamul kodu girin', false); return; }
        var matName = (document.getElementById('ptaTargetName')?.value || '').trim();
        ptOpenComboPicker(matCode, {
            materialName: matName,
            currentCode: document.getElementById('ptaTargetConfigCode')?.value || null,
            onApply: function(configId, code, details) {
                document.getElementById('ptaTargetConfigCode').value = code;
                var descEl = document.getElementById('ptaTargetConfigDesc');
                if (descEl) {
                    descEl.value = (details || []).map(function(d) {
                        return d.featureName + ': ' + (d.valueName || d.valueCode || '');
                    }).join(' | ');
                }
            }
        });
    });

    // Uygula → kaynaktaki bilesenler/gorsel korunur, mamul/kombinasyon yeni
    document.getElementById('ptaBtnApply')?.addEventListener('click', async function() {
        var hasContent = ptCurrentId || (ptComponents && ptComponents.length > 0);
        if (!hasContent) {
            showMsg('Kopyalanacak bir recete yok.', false);
            return;
        }
        // Hedef alanlari resolve et (blur henuz tetiklenmemisse)
        var match = await ptaResolveTarget();
        if (!match) {
            showMsg('Hedef mamul kodu gecersiz.', false);
            ptShakeField('ptaTargetCode');
            return;
        }
        var hasCfg = match.hasConfig === true || match.hasConfig === 'true';
        var targetCfg = (document.getElementById('ptaTargetConfigCode')?.value || '').trim();
        if (hasCfg && !targetCfg) {
            showMsg('Bu mamul kombinasyonlu. Hedef kombinasyon kodu girin.', false);
            ptShakeField('ptaTargetConfigCode');
            return;
        }
        if (hasCfg && targetCfg) {
            var cfgMatch = await ptaResolveTargetConfig();
            if (!cfgMatch) {
                showMsg('Hedef kombinasyon kodu gecersiz.', false);
                ptShakeField('ptaTargetConfigCode');
                return;
            }
        }

        // Yeni kayit olarak gitsin (bilesenler/gorsel olduğu gibi kalir)
        ptCurrentId = null;
        // Mamul/kombinasyon alanlarini hedef ile doldur
        var parentInput = document.getElementById('ptParentCode');
        if (parentInput) {
            parentInput.value = match.code;
            try { parentInput.dispatchEvent(new Event('change', { bubbles: true })); } catch (e) {}
        }
        var nameInput = document.getElementById('ptParentName');
        if (nameInput) nameInput.value = match.name || '';
        var cfgInput = document.getElementById('ptConfigCode');
        var cfgDesc = document.getElementById('ptConfigDesc');
        if (hasCfg) {
            ptSetConfigRowEnabled(true);
            if (cfgInput) cfgInput.value = targetCfg;
            if (cfgDesc) cfgDesc.value = document.getElementById('ptaTargetConfigDesc')?.value || '';
            window.ptCurrentMaterialCode = match.code;
        } else {
            ptSetConfigRowEnabled(false);
            if (cfgInput) cfgInput.value = '';
            if (cfgDesc) cfgDesc.value = '';
            window.ptCurrentMaterialCode = null;
        }

        ptaClose();

        // Genel Bilgiler tab'ina don, ardindan otomatik Kaydet — kullanici tekrar
        // basmasin. Save handler tum akisi yonetir (KITT animasyonu, success toast,
        // form reset). Form'a yansitma sonrasi cok kisa gecikme ile click tetikle.
        var genel = document.querySelector('.pte-nav-btn[data-tab="genel"]');
        if (genel) genel.click();
        setTimeout(function() {
            document.getElementById('ptBtnSave')?.click();
        }, 80);
    });

    /* ===== SAVE ===== */
    document.getElementById('ptBtnSave')?.addEventListener('click', async function() {
        var parentCode = document.getElementById('ptParentCode')?.value?.trim();
        if (!parentCode) {
            // Uyari mesaji yerine alani kirmizi cerceve + titreme ile isaretle.
            ptShakeField('ptParentCode');
            return;
        }
        if (ptComponents.length === 0) { showMsg('Recetede en az bir bilesen olmalidir.', false); return; }

        var btn = document.getElementById('ptBtnSave');
        btn.disabled = true;
        var actionBar = document.querySelector('.pte-action-bar');

        var imageBase64 = null, imageMimeType = null;
        var rawImg = document.getElementById('ptImageBase64')?.value || '';
        if (rawImg && rawImg !== 'CLEAR') {
            if (rawImg.startsWith('data:')) {
                var parts = rawImg.split(',');
                imageBase64 = parts[1] || null;
                imageMimeType = parts[0].split(':')[1]?.split(';')[0] || 'image/png';
            } else {
                imageBase64 = rawImg;
            }
        }

        var payload = {
            id: ptCurrentId || null,
            // ItemId 0 — backend ParentMaterialCode'u Items.code uzerinden lookup eder
            itemId: 0,
            configId: null,
            parentMaterialCode: parentCode,
            configurationCode: document.getElementById('ptConfigCode')?.value?.trim() || null,
            description: null,
            imageBase64: imageBase64,
            imageMimeType: imageMimeType,
            imageFitMode: document.getElementById('ptImageFitMode')?.value || 'square',
            imageRotation: parseInt(document.getElementById('ptImageRotation')?.value || '0', 10) || 0,
            // Rota (opsiyonel) — header-level Routing FK. Standart rehber pattern:
            // hidden ptRoutingId cache'den dolar; bos kalirsa backend routingCode'dan
            // lookup eder. Ikisi de bosa null gonder → BOM rotasiz kayit olur.
            routingId: (function() {
                var v = document.getElementById('ptRoutingId')?.value || '';
                var n = parseInt(v, 10);
                return (isNaN(n) || n <= 0) ? null : n;
            })(),
            routingCode: (document.getElementById('ptRoutingCode')?.value || '').trim() || null,
            lines: ptComponents.map(function(c) { return {
                itemId: 0,
                configId: null,
                componentMaterialCode: c.code,
                componentConfigCode: c.cfgCode || null,
                quantity: c.qty,
                scrapRatio: c.scrap,
                note: c.note || null
            }; })
        };

        try {
            var resp = await fetch('@Url.Action("SaveBOM","Logistics")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify(payload)
            });
            if (!resp.ok) {
                showMsg('Sunucu hatasi (' + resp.status + '). Lutfen sayfayi yenileyin.', false);
                return;
            }
            var data = await resp.json();
            if (data.success) {
                showMsg('Recete basariyla kaydedildi.', true);
                if (actionBar) {
                    actionBar.classList.remove('is-save-flash');
                    void actionBar.offsetWidth;  // animasyonu yeniden tetikle
                    actionBar.classList.add('is-save-flash');
                    setTimeout(function() { actionBar.classList.remove('is-save-flash'); }, 1850);
                }
                // URL'i id ile guncelle (yeni kayit ise) — form dolu kalsin, kullanici
                // duzenlemeye devam edebilsin veya "Liste" ile geri donsun.
                if (data.id) {
                    ptCurrentId = data.id;
                    var urlParams = new URLSearchParams(window.location.search);
                    if (urlParams.get('id') !== String(data.id)) {
                        history.replaceState({}, '', '/Logistics/BOMEdit?id=' + data.id);
                    }
                }
            } else {
                showMsg('Kayit hatasi: ' + (data.message || 'Bilinmeyen hata'), false);
            }
        } catch (err) {
            showMsg('Islem tamamlanamadi. Baglanti veya sunucu hatasi.', false);
            console.error('[BOM][save]', err);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg> Kaydet';
        }
    });

    /* ===== URL PRELOAD ===== */
    (async function preloadFromUrl() {
        var p = new URLSearchParams(window.location.search);
        var idStr = p.get('id');
        var id = idStr ? parseInt(idStr, 10) : 0;
        if (id && id > 0) {
            await ptLoadExistingTreeById(id, false);
            return;
        }

        var mat = p.get('mat');
        var cfg = p.get('cfg');
        if (!mat) return;

        try {
            var r = await fetch('/Logistics/StockLookup?q=' + encodeURIComponent(mat), { credentials: 'include' });
            var cards = await r.json();
            var card = cards.find(function(c) { return c.code.toUpperCase() === mat.toUpperCase(); });
            if (!card) return;

            document.getElementById('ptParentCode').value = card.code;
            document.getElementById('ptParentName').value = card.name || '';
            ptCurrentMaterialCode = card.hasConfig ? card.code : null;

            var cfgInput = document.getElementById('ptConfigCode');
            var cfgDescRow = document.getElementById('ptConfigDescRow');

            if (card.hasConfig && cfg) {
                ptSetConfigRowEnabled(true);
                if (cfgInput) cfgInput.value = cfg;
                if (cfgDescRow) cfgDescRow.style.display = 'none';
                ptLoadExistingTree(card.code, cfg, false);
            } else {
                ptSetConfigRowEnabled(!!card.hasConfig);
                ptLoadExistingTree(card.code, null, false);
            }
        } catch { /* silent */ }
    })();

})();

/* ──────────────────────────────────────────────────────────────
   Rehber ozellestirme — admin "Alan ve Widget Tanimlari" ekranindan
   PRODUCT_TREES formundaki alanlara rehber baglandiysa
   FixedFieldLookupBridge LookupCard'i mount eder. parentCode (mamul)
   icin binding zorunludur; binding yoksa kullanici hicbir buton gormez.
   ────────────────────────────────────────────────────────────── */
(function () {
    // ── Mamul kodu resolve — module scope ──
    // Onceden bridge mount tamamlanmadan listener bagligi yapilmadigi icin
    // kullanici yazip blur etse bile reçete yuklenmiyordu. Sebep: wireCustomLookups
    // bridge bundle yuklenmesini bekliyordu (CalibraHub.mountFixedFieldLookups async).
    // Yeni yaklasim: ptResolveParent + listener'lar bundle'a bagimsiz olarak DOM
    // hazir olunca baglanir; bridge ek olarak gelmis ise sadece display fill yapar.
    // window.X formati ile cagri — helper'lar farkli IIFE icinde tanimli; lokal
    // scope'tan erisilemez. Birinci IIFE bunlari window'a expose ediyor.
    function ptResolveParent(code, bridgeDisplay) {
        var nameEl = document.getElementById('ptParentName');
        if (!code) {
            if (nameEl) nameEl.value = '';
            if (typeof window.ptSetConfigRowEnabled === 'function') window.ptSetConfigRowEnabled(false);
            window.ptCurrentMaterialCode = null;
            if (typeof window.ptSetRecipeStatus === 'function') window.ptSetRecipeStatus(null);
            return;
        }
        if (nameEl && bridgeDisplay) nameEl.value = bridgeDisplay;
        fetch('/Logistics/StockLookup?q=' + encodeURIComponent(code))
            .then(function (r) { return r.json(); })
            .then(function (list) {
                var match = (list || []).find(function (s) { return (s.code || '').toLowerCase() === code.toLowerCase(); });
                var cfgInput  = document.getElementById('ptConfigCode');
                var cfgDescRow = document.getElementById('ptConfigDescRow');
                var cfgDesc   = document.getElementById('ptConfigDesc');
                if (!match) {
                    // Stok yok — yine de BOM lookup deneyelim (silinmis stok edge case)
                    // ve sonuc yoksa form'u "yeni recete" durumuna getir.
                    if (typeof window.ptLoadExistingTree === 'function') window.ptLoadExistingTree(code, null, false);
                    return;
                }
                if (nameEl && !bridgeDisplay) nameEl.value = match.name || '';
                var isCfg = match.hasConfig === true || match.hasConfig === 'true';
                if (typeof window.ptSetConfigRowEnabled === 'function') window.ptSetConfigRowEnabled(isCfg);
                if (cfgDescRow) cfgDescRow.style.display = 'none';
                window.ptCurrentMaterialCode = isCfg ? match.code : null;
                if (isCfg) {
                    if (cfgInput) cfgInput.value = '';
                    if (cfgDesc) cfgDesc.value = '';
                    if (typeof window.ptLoadExistingTree === 'function') window.ptLoadExistingTree(match.code, null, false);
                } else {
                    if (typeof window.ptLoadExistingTree === 'function') window.ptLoadExistingTree(match.code, null);
                }
            })
            .catch(function (err) {
                console.warn('[BOMEdit] ptResolveParent fetch hatasi:', err);
            });
    }
    // Disaridan da cagrilabilsin (admin tools, debug) — window'a expose
    window.ptResolveParent = ptResolveParent;

    // ── Resolve dedup + debounce ──
    // Bridge mount durumuna bagimli olmadan, kullanici yazarken AJAX in-place
    // fill calismali (stok/cari kart pattern'i). Bridge varsa her keystroke
    // change dispatch eder; yoksa change sadece blur'da fire eder. Bu yuzden
    // ek olarak debounced 'input' handler — her iki senaryoda da calisir.
    // Dedup: ayni kod tekrar gelirse fetch atma.
    var lastResolvedCode = null;
    var debouncedTimer = null;
    function maybeResolve(code, bridgeDisplay, immediate) {
        code = (code || '').trim();
        if (code === lastResolvedCode) return;
        clearTimeout(debouncedTimer);
        if (immediate) {
            lastResolvedCode = code;
            ptResolveParent(code, bridgeDisplay);
        } else {
            debouncedTimer = setTimeout(function () {
                lastResolvedCode = code;
                ptResolveParent(code, bridgeDisplay);
            }, 250);
        }
    }

    function attachParentListeners() {
        var parentInput = document.getElementById('ptParentCode');
        if (!parentInput) { setTimeout(attachParentListeners, 100); return; }
        if (parentInput.dataset.ptListenersAttached === '1') return;
        parentInput.dataset.ptListenersAttached = '1';

        parentInput.addEventListener('change', function () {
            maybeResolve(parentInput.value, parentInput.getAttribute('data-display'), false);
        });
        parentInput.addEventListener('input', function () {
            maybeResolve(parentInput.value, parentInput.getAttribute('data-display'), false);
        });
        parentInput.addEventListener('blur', function () {
            maybeResolve(parentInput.value, null, true);
        });
        parentInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); maybeResolve(parentInput.value, null, true); }
        });
        parentInput.addEventListener('ffl-clear', function () { lastResolvedCode = null; });
        parentInput.addEventListener('ffl-sync',  function () {
            lastResolvedCode = (parentInput.value || '').trim();
        });
    }

    function attachComponentListeners() {
        var compInput = document.getElementById('cfCompCode');
        if (!compInput) { setTimeout(attachComponentListeners, 100); return; }
        if (compInput.dataset.cfListenersAttached === '1') return;
        compInput.dataset.cfListenersAttached = '1';

        compInput.addEventListener('change', function () {
            var code = (compInput.value || '').trim();
            var nameEl = document.getElementById('cfCompName');
            var cfgWrap  = document.getElementById('cfCompCfgWrap');
            var cfgLabel = document.getElementById('cfCompCfgLabel');
            var cfgCodeEl = document.getElementById('cfCompCfgCode');
            var cfgDescEl = document.getElementById('cfCompCfgDesc');
            if (!code) {
                if (nameEl) nameEl.value = '';
                if (cfgWrap)  cfgWrap.classList.add('pte-cfg-disabled');
                if (cfgLabel) cfgLabel.classList.add('pte-cfg-disabled');
                return;
            }
            var bridgeDisplay = compInput.getAttribute('data-display');
            if (nameEl && bridgeDisplay) nameEl.value = bridgeDisplay;
            fetch('/Logistics/StockLookup?q=' + encodeURIComponent(code))
                .then(function (r) { return r.json(); })
                .then(function (list) {
                    var match = (list || []).find(function (s) { return (s.code || '').toLowerCase() === code.toLowerCase(); });
                    if (match) {
                        if (nameEl && !bridgeDisplay) nameEl.value = match.name || '';
                        var isCfg = match.hasConfig === true || match.hasConfig === 'true';
                        if (cfgWrap)  cfgWrap.classList.toggle('pte-cfg-disabled', !isCfg);
                        if (cfgLabel) cfgLabel.classList.toggle('pte-cfg-disabled', !isCfg);
                        if (cfgCodeEl) cfgCodeEl.value = '';
                        if (cfgDescEl) cfgDescEl.value = '';
                        ptCompMaterialCode = isCfg ? match.code : null;
                    }
                })
                .catch(function () {});
        });
    }

    // Bridge bundle (CalibraHub.mountFixedFieldLookups) varsa onu da cagir;
    // yoksa endise yok — listener'lar zaten bagli, plain input olarak calisir.
    function tryMountFixedFieldLookups() {
        if (!window.CalibraHub || typeof CalibraHub.mountFixedFieldLookups !== 'function') {
            setTimeout(tryMountFixedFieldLookups, 200);
            return;
        }
        CalibraHub.mountFixedFieldLookups('PRODUCT_TREES').catch(function () { /* sessizce */ });
    }

    function init() {
        attachParentListeners();
        attachComponentListeners();
        tryMountFixedFieldLookups();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
}
