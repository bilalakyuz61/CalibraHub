@{
    ViewData["Title"] = ViewBag.Title;
    ViewData["BodyClass"] = "page-product-trees";

    // 2026-07-05: Bundle URL'leri _Layout ile AYNI versiyonlama (dosya hash'i).
    // Onceki ?v=Ticks her istekte degistigi icin tarayici bundle'i HIC cache'leyemiyordu
    // → sayfa acilisinda ~5MB JS yeniden iniyor, rehber kartlari "sonradan geliyordu".
    // Ayni URL = _Layout'un shell'de indirdigi kopya iframe'de cache'ten gelir.
    var bundleJsUrl  = FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js");
    var bundleCssUrl = FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css");
}

@section Styles {
<script>
/* ===== ERKEN YUKLEME (head) — 2026-07-05 =====
   Olcum: bundle istegi body-sonu loader ile ~640ms'de basliyor, binding fetch'i
   bundle exec'ini bekliyordu → rehber kartlari ~2.4sn'de geliyordu.
   1) Bundle <head>'de enjekte edilir (parse ile paralel indirme/cache).
   2) Runtime binding'leri bundle'i BEKLEMEDEN prefetch edilir;
      fieldSettingService.getRuntimeBindings ayni promise'i tuketir. */
(function () {
    window.__CALIBRA_PREFETCH_BINDINGS = window.__CALIBRA_PREFETCH_BINDINGS || {};
    if (!window.__CALIBRA_PREFETCH_BINDINGS['PRODUCT_TREES']) {
        window.__CALIBRA_PREFETCH_BINDINGS['PRODUCT_TREES'] =
            fetch('/api/field-settings/runtime/PRODUCT_TREES', {
                credentials: 'same-origin',
                headers: { 'Accept': 'application/json' }
            })
            .then(function (r) { return r.ok ? r.json() : []; })
            .catch(function () { return []; });
    }
    if ((window.CalibraHub && window.CalibraHub.openCombinationPicker) ||
        document.querySelector('script[data-bom-react-bundle]')) return;
    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = '@bundleCssUrl';
    link.setAttribute('data-bom-react-bundle', '1');
    document.head.appendChild(link);
    var s = document.createElement('script');
    s.src = '@bundleJsUrl';
    s.setAttribute('data-bom-react-bundle', '1');
    s.onload = function () {
        try { window.dispatchEvent(new Event('calibrahub-bundle-ready')); } catch (e) { /* ignore */ }
    };
    s.onerror = function () { console.error('[BOM] React bundle yuklenemedi'); };
    document.head.appendChild(s);
})();
</script>
<style>
    /* ============================================================
       BOMEdit Premium Skin — token-based, Apple/Linear/Vercel grade
       Tokens kaynak: /css/tokens.css (--surface-*, --text-*, --accent-*,
       --motion-*, --shadow-*, --radius-*, --space-*). Tema otomatik
       (body.app-theme-light/dark CSS variable override).
       Class isimleri KORUNUR — JS event delegation kirilmaz.
       ============================================================ */

    /* ── Page-level overrides ── */
    .page-product-trees { --workspace-action-bar-height: 0px; }
    .page-product-trees .workspace-tabs {
        position:relative; top:unset; flex:0 0 auto;
        border-bottom:1px solid var(--border-subtle);
        z-index:2;
    }
    .page-product-trees .workspace-tabs[hidden] { display:block !important; min-height:42px; visibility:hidden; pointer-events:none; }
    .page-product-trees .workspace-action-bar { display:none !important; }
    .page-product-trees .app-content-area { display:flex; flex-direction:column; overflow:hidden; }
    .page-product-trees .integrator-dashboard { flex:1 1 0; min-height:0; display:flex; flex-direction:column; }
    .page-product-trees .integrator-dashboard__content {
        flex:1 1 0; min-height:0; width:auto !important; max-width:none !important;
        padding:0 !important; margin:0 !important;
        display:flex !important; flex-direction:column !important; overflow:hidden;
        font-family: var(--font-stack);
        color: var(--text-primary);
    }


    /* ── Islemler modal — premium dialog ── */
    .pta-overlay {
        position:fixed; inset:0; z-index:9999; display:none;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(8px) saturate(160%);
        -webkit-backdrop-filter: blur(8px) saturate(160%);
        align-items:center; justify-content:center; padding: var(--space-5);
        animation: ptaFadeIn var(--motion-base) var(--motion-ease-out);
    }
    .pta-overlay.is-open { display:flex; }
    @@keyframes ptaFadeIn { from { opacity:0; } to { opacity:1; } }
    .pta-panel {
        width: min(560px, 96vw); max-height: 88vh; overflow: auto;
        background: var(--surface-elev-1);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-elev-3);
        color: var(--text-primary);
        animation: ptaSlide var(--motion-slow) var(--motion-ease-spring);
    }
    @@keyframes ptaSlide {
        from { transform: translateY(12px) scale(0.96); opacity:0; }
        to   { transform: none;                          opacity:1; }
    }
    .pta-header {
        display:flex; align-items:center; gap: var(--space-3);
        padding: 16px 20px;
        border-bottom: 1px solid var(--border-subtle);
    }
    .pta-header h3 {
        margin:0; font-size: 14px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: -0.01em;
        flex:1;
        color: var(--text-primary);
    }
    .pta-close {
        background: transparent; border:0;
        color: var(--text-muted);
        cursor:pointer;
        width: 28px; height: 28px;
        border-radius: var(--radius-sm);
        font-size: 18px; line-height:1;
        display:flex; align-items:center; justify-content:center;
        transition: background var(--motion-fast) var(--motion-ease-out),
                    color      var(--motion-fast) var(--motion-ease-out);
    }
    .pta-close:hover {
        background: var(--surface-elev-2);
        color: var(--text-primary);
    }
    .pta-section {
        padding: 18px 20px;
        border-bottom: 1px solid var(--border-subtle);
    }
    .pta-section:last-of-type { border-bottom: 0; }
    .pta-section h4 {
        margin: 0 0 12px;
        font-size: 11.5px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.01em;
        color: var(--text-muted);
    }
    .pta-source {
        font-size: 12.5px;
        color: var(--text-secondary);
        padding: 10px 14px;
        border-radius: var(--radius-md);
        background: var(--surface-base);
        border: 1px dashed var(--border-strong);
        margin-bottom: var(--space-3);
    }
    .pta-source strong {
        color: var(--accent-soft-fg);
        font-weight: var(--font-weight-semibold);
    }
    .pta-field { display:flex; flex-direction:column; gap: 6px; margin-bottom: var(--space-3); }
    .pta-field-label {
        font-size: 11.5px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.01em;
        color: var(--text-muted);
    }
    .pta-field-required::after { content: ' *'; color: var(--danger); }
    .pta-field-row { display:flex; gap: var(--space-2); align-items:stretch; position:relative; }
    .pta-field-row .pte-input { flex:1; }
    .pta-field-row .gl-wrapper { flex:1; min-width:0; }
    .pta-field-row .gl-card    { width:100%; }
    .pta-field-name {
        flex:1; padding: 9px 12px;
        border-radius: var(--radius-md);
        background: transparent;
        border: 1px dashed var(--border-subtle);
        color: var(--text-muted);
        font-size: 12.5px;
        font-style: italic;
    }
    .pta-actions {
        padding: 14px 20px;
        display:flex; justify-content:flex-end; gap: var(--space-2);
        background: var(--surface-base);
        border-top: 1px solid var(--border-subtle);
    }

    /* ── Body: sidenav + content ── */
    .pte-body {
        flex:1 1 0; min-height:0;
        display:flex; flex-direction:row;
        overflow:hidden; position:relative;
        background: var(--surface-base);
    }

    /* ── Sidebar navigation (Apple Settings DNA — vertical pills) ── */
    .pte-sidenav {
        width: 208px;
        flex-shrink: 0;
        display:flex; flex-direction:column;
        gap: 2px;
        padding: var(--space-4) var(--space-2);
        background: transparent;
        border-right: 1px solid var(--border-subtle);
        overflow-y: auto;
    }
    .pte-sidenav-label {
        font-size: 11px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.01em;
        color: var(--text-muted);
        padding: 10px 12px 6px;
    }
    .pte-nav-btn {
        position: relative;
        display:flex; align-items:center; gap: var(--space-2);
        width:100%;
        padding: 9px 12px;
        border:none; background:transparent;
        cursor:pointer;
        font-size: 12.5px;
        font-weight: var(--font-weight-medium);
        color: var(--text-secondary);
        border-radius: var(--radius-md);
        text-align:left;
        transition: background var(--motion-fast) var(--motion-ease-out),
                    color      var(--motion-fast) var(--motion-ease-out),
                    transform  var(--motion-fast) var(--motion-ease-out);
    }
    .pte-nav-btn::before {
        /* Sol kenarda 2px accent bar — Linear DNA. Hidden when not active. */
        content:'';
        position:absolute;
        left: 4px; top: 50%;
        width: 2px; height: 0;
        background: var(--accent);
        border-radius: 2px;
        transform: translateY(-50%);
        transition: height var(--motion-base) var(--motion-ease-spring);
    }
    .pte-nav-btn:hover {
        background: var(--surface-elev-1);
        color: var(--text-primary);
        transform: translateX(1px);
    }
    .pte-nav-btn.is-active {
        background: var(--accent-soft-bg);
        color: var(--accent-soft-fg);
        font-weight: var(--font-weight-semibold);
    }
    .pte-nav-btn.is-active::before { height: 60%; }

    /* Malzeme Kartı sol-menü paritesi (2026-07-11): mevcut .pte-nav-dot span'i
       ring→dolu+glow indikatöre dönüştürülür. Accent bar (.pte-nav-btn::before)
       KORUNUR — bu ekranda ikisi birlikte çalışır. Markup/JS değişmez. */
    .pte-nav-dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
        border: 1.5px solid #cbd5e1; background: transparent; transition: all .18s;
    }
    .pte-nav-btn:hover .pte-nav-dot { border-color: #94a3b8; }
    .pte-nav-btn.is-active .pte-nav-dot {
        background: #6366f1; border-color: #6366f1; box-shadow: 0 0 7px rgba(99,102,241,.5);
    }
    body.app-theme-dark .pte-nav-dot { border-color: rgba(255,255,255,.24); }
    body.app-theme-dark .pte-nav-btn:hover .pte-nav-dot { border-color: rgba(255,255,255,.48); }
    body.app-theme-dark .pte-nav-btn.is-active .pte-nav-dot {
        background: #6366f1; border-color: #6366f1; box-shadow: 0 0 7px rgba(99,102,241,.55);
    }

    .pte-nav-count {
        margin-left: auto;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 10.5px;
        font-weight: var(--font-weight-semibold);
        font-variant-numeric: tabular-nums;
        background: var(--surface-elev-2);
        color: var(--text-muted);
        border: 1px solid var(--border-subtle);
        flex-shrink: 0;
        transition: background var(--motion-fast) var(--motion-ease-out),
                    color      var(--motion-fast) var(--motion-ease-out);
    }
    /* Badge >0 (data-count attr ile JS yazarsa) → accent renge geçer.
       Fallback: count "0" string'i ise muted, aksi halde accent. */
    .pte-nav-count:not(:empty):not([data-count="0"]) {
        background: var(--accent);
        color: #ffffff;
        border-color: transparent;
    }

    /* ── Content area ──
       Sade navy yuzey — WorkOrderEdit DNA. Onceki radial gradient kaldirildi:
       "fazla parilti" hissi yerine temiz, gozu yormayan zemin. */
    .pte-content {
        flex:1 1 auto; min-width:0;
        overflow-y:auto;
        padding: var(--space-5) var(--space-6);
        background: var(--surface-base);
    }

    /* ── Cards (premium elevation) ── */
    .pte-card {
        background: var(--surface-elev-1);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg);
        padding: var(--space-5);
        margin-bottom: var(--space-4);
        box-shadow: var(--shadow-elev-1);
        transition: border-color var(--motion-base) var(--motion-ease-out),
                    box-shadow   var(--motion-base) var(--motion-ease-out);
    }
    .pte-card-title {
        font-size: 13px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: -0.005em;
        color: var(--text-primary);
        margin: 0 0 var(--space-4) 0;
        display:flex; align-items:center; gap: 10px;
    }
    .pte-card-title::before {
        content:'';
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-soft-bg);
    }

    /* ── Form grid ── */
    .pte-grid { display:flex; flex-direction:column; gap: var(--space-3); }
    .pte-row  { display:flex; align-items:center; gap: var(--space-3); flex-wrap:wrap; }
    .pte-field { display:flex; flex-direction:column; gap: 5px; }
    /* Title Case standardı (CLAUDE.md) — uppercase dönüşümü kaldırıldı;
       metin kaynakta zaten "Mamul Kodu" gibi doğru yazılır. */
    .pte-label {
        font-size: 12px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.01em;
        color: var(--text-muted);
        white-space: nowrap;
        flex-shrink: 0;
    }
    .pte-label--req::after { content: ' *'; color: var(--danger); margin-left: 1px; }

    /* ── Inputs (premium polish) ──
       Hover'da hafif elevation, focus'ta accent ring (3px), placeholder muted. */
    .pte-input {
        padding: 9px 12px;
        border-radius: var(--radius-md);
        background: var(--surface-elev-2);
        border: 1px solid var(--border-subtle);
        color: var(--text-primary);
        font-family: var(--font-stack);
        font-size: 13px;
        font-weight: var(--font-weight-medium);
        letter-spacing: -0.005em;
        transition: border-color var(--motion-fast) var(--motion-ease-out),
                    background   var(--motion-fast) var(--motion-ease-out),
                    box-shadow   var(--motion-fast) var(--motion-ease-out);
        outline: none;
    }
    .pte-input:hover:not(:focus):not([readonly]) {
        border-color: var(--border-strong);
    }
    .pte-input:focus {
        border-color: var(--border-focus);
        box-shadow: 0 0 0 var(--ring-width) var(--ring-color);
    }
    .pte-input::placeholder {
        color: var(--text-muted);
        font-weight: var(--font-weight-regular);
        font-style: italic;
        opacity: 0.7;
    }
    .pte-input[readonly] {
        background: transparent;
        cursor: default;
    }
    .pte-input.is-invalid {
        border-color: var(--danger);
        background: var(--danger-soft-bg);
        animation: pteShake 0.4s cubic-bezier(.36,.07,.19,.97) both;
    }
    .pte-input[type="number"] {
        text-align: right;
        font-variant-numeric: tabular-nums;
        -moz-appearance: textfield;
    }
    .pte-input[type="number"]::-webkit-outer-spin-button,
    .pte-input[type="number"]::-webkit-inner-spin-button { -webkit-appearance:none; margin:0; }

    /* ── Lookup pair pattern (Apple Settings DNA) ──
       Sol "kod" input — interaktif, normal border + focus ring
       Sag "ad/aciklama" input — readonly, BORDER YOK, transparan, secondary text
       Bu kombinasyon "kod = source of truth, ad = derived display" hiyerarsisini
       gorsel olarak iletir. Bridge lookup popup'i sol input'a mount olur. */
    .pte-bilesen-vals .pte-input[readonly] {
        background: transparent;
        border-color: transparent;
        color: var(--text-secondary);
        font-weight: var(--font-weight-regular);
        padding-left: 0;
    }
    .pte-bilesen-vals .pte-input[readonly]:hover { border-color: transparent; }
    .pte-bilesen-vals .pte-input[readonly]::placeholder { color: var(--text-disabled); }

    /* ── Recete durum pill'i ── */
    .pte-recipe-status {
        font-size: 11px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.01em;
        padding: 3px 10px;
        border-radius: 999px;
        border: 1px solid transparent;
        line-height: 1.4;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .pte-recipe-status::before {
        content: '';
        width: 6px; height: 6px;
        border-radius: 50%;
        display: inline-block;
    }
    .pte-recipe-status--existing {
        color: var(--success-soft-fg);
        background: var(--success-soft-bg);
        border-color: transparent;
    }
    .pte-recipe-status--existing::before { background: var(--success); box-shadow: 0 0 0 3px var(--success-soft-bg); }
    .pte-recipe-status--new {
        color: var(--accent-soft-fg);
        background: var(--accent-soft-bg);
        border-color: transparent;
    }
    .pte-recipe-status--new::before { background: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft-bg); }

    /* ── Lookup ──
       pte-lookup: input + (optional) buyutec butonu — tek border'li capsule.
       Bridge LookupCard'i veya FixedFieldLookupBridge'i icine mount edebilir. */
    .pte-lookup {
        display: inline-flex;
        align-items: stretch;
        border-radius: var(--radius-md);
        overflow: hidden;
    }
    .pte-lookup .pte-input {
        border-radius: var(--radius-md) 0 0 var(--radius-md);
        border-right: 0;
    }
    /* LookupCard mount edildiginde gl-wrapper/gl-card pte-lookup container'ini doldursun. */
    .pte-lookup .gl-wrapper { width: 100%; flex: 1 1 auto; }
    .pte-lookup .gl-card    { width: 100%; }

    .pte-lookup-btn {
        display: flex; align-items: center; justify-content: center;
        width: 36px;
        background: var(--accent-soft-bg);
        border: 1px solid var(--border-subtle);
        border-left: 0;
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        cursor: pointer;
        color: var(--accent-soft-fg);
        transition: background var(--motion-fast) var(--motion-ease-out),
                    color      var(--motion-fast) var(--motion-ease-out);
    }
    .pte-lookup-btn:hover {
        background: var(--accent);
        color: #ffffff;
    }

    /* Bridge wrapper'i flex stretch — ffl-clear-btn input ile ayni yukseklikte */
    .pte-lookup .ffl-wrapper { display: flex; align-items: stretch; }
    .pte-lookup .ffl-clear-btn {
        width: 30px; height: auto; min-height: 100%;
        background: transparent;
        border: 1px solid var(--border-subtle);
        border-left: 0; border-right: 0;
        border-radius: 0;
        color: var(--text-muted);
        display: flex; align-items: center; justify-content: center;
        transition: background var(--motion-fast) var(--motion-ease-out),
                    color      var(--motion-fast) var(--motion-ease-out);
    }
    .pte-lookup .ffl-clear-btn:hover {
        background: var(--surface-elev-1);
        color: var(--text-primary);
    }

    /* ── Image tab — tam yukseklik ── */
    #pteTab-gorsel { height: 100%; display: flex; flex-direction: column; }
    #pteTab-gorsel .pte-card {
        flex: 1; min-height: 0;
        display: flex; flex-direction: column;
        margin-bottom: 0;
    }
    #pteTab-gorsel .pte-card-title { flex-shrink: 0; }

    /* ── Image area ── */
    .pte-image-area {
        display: flex; align-items: stretch; gap: var(--space-3);
        margin-top: var(--space-3);
        padding: var(--space-4);
        border-radius: var(--radius-lg);
        background: var(--surface-base);
        border: 1px solid var(--border-subtle);
    }
    #pteTab-gorsel .pte-image-area {
        flex: 1; min-height: 0;
        margin-top: var(--space-3);
    }
    .pte-img-actions {
        display: flex; flex-direction: column; gap: 6px; flex-shrink: 0;
    }
    .pte-img-btn {
        width: 34px; height: 34px;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-subtle);
        background: var(--surface-elev-2);
        color: var(--text-secondary);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: background var(--motion-fast) var(--motion-ease-out),
                    color      var(--motion-fast) var(--motion-ease-out),
                    border-color var(--motion-fast) var(--motion-ease-out),
                    transform  var(--motion-fast) var(--motion-ease-out);
    }
    .pte-img-btn:hover {
        background: var(--surface-elev-1);
        color: var(--text-primary);
        border-color: var(--border-strong);
        transform: translateY(-1px);
    }
    .pte-img-btn:active { transform: translateY(0); }
    .pte-img-btn--upload {
        background: var(--accent);
        border-color: var(--accent);
        color: #ffffff;
    }
    .pte-img-btn--upload:hover {
        background: var(--accent-hover);
        border-color: var(--accent-hover);
        color: #ffffff;
    }
    .pte-img-btn--mode.is-active {
        background: var(--accent);
        border-color: var(--accent);
        color: #ffffff;
    }
    .pte-img-btn--clear {
        background: var(--danger-soft-bg);
        border-color: transparent;
        color: var(--danger-soft-fg);
    }
    .pte-img-btn--clear:hover {
        background: var(--danger);
        border-color: var(--danger);
        color: #ffffff;
    }
    .pte-img-preview {
        flex: 1 1 0; min-height: 160px;
        border-radius: var(--radius-md);
        border: 2px dashed var(--border-strong);
        overflow: hidden; position: relative;
        display: flex; align-items: center; justify-content: center; flex-direction: column;
        background: var(--surface-elev-2);
        color: var(--text-muted);
        transition: border-color var(--motion-base) var(--motion-ease-out),
                    background   var(--motion-base) var(--motion-ease-out);
    }
    .pte-img-preview:hover {
        border-color: var(--accent);
        background: var(--accent-soft-bg);
    }
    #pteTab-gorsel .pte-img-preview { min-height: 0; }

    /* ── Bilesen Ekle form — hizali grid ── */
    .pte-card--compact { padding: var(--space-4); }
    .pte-bilesen-form {
        display: grid;
        grid-template-columns: 100px 1fr;
        row-gap: 12px;
        column-gap: var(--space-3);
        align-items: center;
    }
    .pte-bilesen-form .pte-label {
        text-align: right;
        white-space: nowrap;
        font-size: 11px;
    }
    .pte-bilesen-form .pte-input { padding: 7px 10px; min-width: 0; }
    .pte-bilesen-vals {
        display: flex; align-items: center;
        gap: var(--space-2);
        flex-wrap: nowrap; min-width: 0;
    }
    .pte-bilesen-vals .pte-input { min-width: 0; }
    .pte-bilesen-actions {
        grid-column: 2 / -1;
        display: flex; gap: var(--space-2);
        margin-top: 6px;
    }
    .pte-cfg-disabled { opacity: 0.38; pointer-events: none; }

    /* ── Component grid (Bilesen tab) — Linear DNA ── */
    .pte-comp-grid {
        margin-top: var(--space-4);
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: var(--surface-elev-1);
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-elev-1);
    }
    .pte-comp-header {
        display: flex; align-items: center;
        gap: var(--space-2);
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-subtle);
        background: var(--surface-elev-2);
    }
    .pte-comp-title {
        font-size: 12.5px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.01em;
        color: var(--text-muted);
    }
    .pte-comp-badge {
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 10.5px;
        font-weight: var(--font-weight-semibold);
        font-variant-numeric: tabular-nums;
        background: var(--accent-soft-bg);
        color: var(--accent-soft-fg);
        border: 1px solid transparent;
    }
    .pte-comp-body {
        max-height: 360px;
        overflow-y: auto; overflow-x: auto;
    }
    .pte-comp-table {
        width: 100%; border-collapse: collapse;
        font-size: 12.5px;
    }
    .pte-comp-th {
        padding: 10px 12px;
        text-align: left;
        font-size: 11px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.01em;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border-subtle);
        position: sticky; top: 0; z-index: 3;
        background: var(--surface-elev-2);
        backdrop-filter: blur(8px);
    }
    .pte-comp-td {
        padding: 10px 12px;
        border-bottom: 1px solid var(--border-subtle);
        color: var(--text-primary);
        font-weight: var(--font-weight-medium);
    }
    .pte-comp-table tbody tr {
        cursor: pointer;
        transition: background var(--motion-fast) var(--motion-ease-out);
    }
    .pte-comp-table tbody tr:hover .pte-comp-td { background: var(--accent-soft-bg); }
    .pte-comp-table tbody tr.selected .pte-comp-td {
        background: var(--accent-soft-bg);
        color: var(--accent-soft-fg);
    }
    .pte-comp-table tbody tr.selected {
        box-shadow: inset 2px 0 0 var(--accent);
    }
    .pte-row-badge {
        display: inline-flex; align-items: center;
        padding: 2px 8px;
        border-radius: var(--radius-sm);
        font-size: 11px;
        font-weight: var(--font-weight-semibold);
        background: var(--accent-soft-bg);
        color: var(--accent-soft-fg);
    }

    /* Action icon butonlari — Linear/Notion DNA: hover'da görünür */
    .pte-comp-table tbody tr .pte-icon-btn {
        opacity: 0.45;
        transition: opacity var(--motion-fast) var(--motion-ease-out),
                    background var(--motion-fast) var(--motion-ease-out),
                    color var(--motion-fast) var(--motion-ease-out);
    }
    .pte-comp-table tbody tr:hover .pte-icon-btn { opacity: 1; }
    .pte-icon-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 5px;
        border-radius: var(--radius-sm);
        color: var(--text-muted);
        outline: none;
        box-shadow: none;
        display: inline-flex; align-items: center; justify-content: center;
    }
    .pte-icon-btn:hover { background: var(--surface-elev-2); }
    .pte-icon-btn--edit:hover { color: var(--accent); }
    .pte-icon-btn--del:hover  { color: var(--danger); background: var(--danger-soft-bg); }

    /* ── Empty state — Linear DNA ── */
    .pte-empty {
        text-align: center;
        padding: var(--space-7) var(--space-4);
        color: var(--text-muted);
        font-size: 12.5px;
        font-weight: var(--font-weight-medium);
        line-height: 1.5;
    }
    .pte-empty svg {
        width: 40px !important; height: 40px !important;
        opacity: 0.5;
        margin-bottom: 10px;
    }

    /* ── Toast — sag alt kose, slide-in ── */
    .pte-message {
        position: fixed;
        right: var(--space-5); bottom: var(--space-5);
        left: auto; top: auto;
        z-index: 10000;
        max-width: 400px; min-width: 260px;
        padding: 0;
        border-radius: var(--radius-lg);
        font-size: 12.5px;
        font-weight: var(--font-weight-medium);
        white-space: normal; overflow: hidden;
        max-height: 0; opacity: 0;
        transform: translateY(12px);
        pointer-events: none;
        transition: max-height var(--motion-slow) var(--motion-ease-out),
                    opacity    var(--motion-slow) var(--motion-ease-out),
                    transform  var(--motion-slow) var(--motion-ease-spring),
                    padding    var(--motion-slow) var(--motion-ease-out);
        backdrop-filter: blur(var(--blur-strength)) saturate(var(--blur-saturate));
        -webkit-backdrop-filter: blur(var(--blur-strength)) saturate(var(--blur-saturate));
        box-shadow: var(--shadow-elev-3);
    }
    .pte-message.ok, .pte-message.err {
        max-height: 200px;
        opacity: 1;
        padding: 14px 18px;
        transform: translateY(0);
        border: 1px solid;
    }
    .pte-message.ok {
        background: var(--success-soft-bg);
        border-color: var(--success);
        color: var(--success-soft-fg);
    }
    .pte-message.err {
        background: var(--danger-soft-bg);
        border-color: var(--danger);
        color: var(--danger-soft-fg);
    }

    /* ── Dropdown (glassmorphic) ── */
    .pte-dd {
        position: fixed !important;
        z-index: 99999 !important;
        background: var(--surface-overlay);
        backdrop-filter: blur(var(--blur-strength)) saturate(var(--blur-saturate));
        -webkit-backdrop-filter: blur(var(--blur-strength)) saturate(var(--blur-saturate));
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-elev-3);
        min-width: 380px;
        overflow: hidden;
    }
    .pte-dd-search {
        padding: var(--space-2);
        border-bottom: 1px solid var(--border-subtle);
    }
    .pte-dd-list { max-height: 280px; overflow-y: auto; padding: 4px; }
    .pte-dd-item {
        padding: 8px 14px;
        cursor: pointer;
        font-size: 12.5px;
        color: var(--text-primary);
        border-radius: var(--radius-sm);
        transition: background var(--motion-fast) var(--motion-ease-out);
    }
    .pte-dd-item:hover { background: var(--accent-soft-bg); }
    .pte-dd-item strong { color: var(--accent-soft-fg); font-weight: var(--font-weight-semibold); }
    .pte-dd-muted {
        color: var(--text-muted);
        font-size: 11.5px;
    }
    .pte-dd-empty {
        padding: var(--space-3) var(--space-4);
        color: var(--text-muted);
        font-size: 12.5px;
        text-align: center;
        font-style: italic;
    }
    .pte-badge-cfg {
        display: inline-block;
        padding: 2px 8px;
        border-radius: var(--radius-sm);
        font-size: 10.5px;
        font-weight: var(--font-weight-semibold);
        background: var(--accent-soft-bg);
        color: var(--accent-soft-fg);
        margin-left: 8px;
    }

    /* ── Mamul Rehberi (satis teklifi kalem rehberi tarzi) ── */
    .pte-dd--lookup {
        min-width: 460px; max-width: 560px;
        border-radius: var(--radius-lg);
    }
    .pte-dd--lookup .pte-dd-search { padding: var(--space-3); }
    .pte-dd--lookup .pte-dd-search .pte-input {
        font-size: 13px;
        padding: 9px 12px;
        border-radius: var(--radius-md);
    }
    .pte-dd--lookup .pte-dd-list { max-height: 360px; padding: 4px; }
    .pte-dd-row {
        display: flex; align-items: center; gap: var(--space-3);
        width: 100%;
        padding: 10px 12px;
        background: transparent;
        border: 0;
        border-radius: var(--radius-md);
        text-align: left;
        cursor: pointer;
        transition: background var(--motion-fast) var(--motion-ease-out);
    }
    .pte-dd-row:hover { background: var(--accent-soft-bg); }
    .pte-dd-row.is-active { background: var(--accent-soft-bg); box-shadow: inset 2px 0 0 var(--accent); }
    .pte-dd-code {
        font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
        font-size: 11.5px;
        color: var(--accent-soft-fg);
        font-variant-numeric: tabular-nums;
        min-width: 130px;
        flex-shrink: 0;
        font-weight: var(--font-weight-semibold);
    }
    .pte-dd-name {
        font-size: 12.5px;
        color: var(--text-primary);
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .pte-dd-tag {
        flex-shrink: 0;
        padding: 2px 10px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.05em;
        background: var(--accent-soft-bg);
        color: var(--accent-soft-fg);
        border: 1px solid transparent;
    }

    /* ── Chip (Kombinasyon ozellik-deger) ── */
    .pte-chip {
        display: inline-flex; align-items: center; gap: 4px;
        background: var(--accent-soft-bg);
        border: 1px solid transparent;
        border-radius: var(--radius-sm);
        padding: 1px 8px;
        font-size: 11px;
        font-weight: var(--font-weight-medium);
        margin: 2px 2px 0 0;
        white-space: nowrap;
    }
    .pte-chip-feat { color: var(--accent-soft-fg); font-weight: var(--font-weight-semibold); }
    .pte-chip-val  { color: var(--text-secondary); }

    /* ── Premium veri girişi (2026-07-05) ─────────────────────────── */

    /* Rehber kartı mount olana kadar input, kartın SON halini taklit eder:
       sağda büyüteç + solda 3px indigo accent bar. Mount olunca JS sınıfı
       kaldırır — görsel olarak hiçbir şey değişmez ("sonradan geldi" hissi yok). */
    .pte-lookup--pending .pte-input {
        background-image:
            url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgb(139,148,166)' stroke-width='2' stroke-linecap='round'><circle cx='11' cy='11' r='8'/><path d='M21 21l-4.3-4.3'/></svg>"),
            linear-gradient(180deg, rgba(99,102,241,0.85) 0%, rgba(79,70,229,0.85) 100%);
        background-repeat: no-repeat, no-repeat;
        background-position: right 10px center, left top;
        background-size: 14px 14px, 3px 100%;
        padding-right: 34px;
    }

    /* Mount SONRASI kart, plain input ile piksel uyumlu — swap görünmez olur.
       Ölçülen fark: kart 38px/10px-radius/.875rem (root 12.5px → 10.9px font),
       input 35.5px/8px/13px + farklı arka plan. Bu blok kartı input'a eşitler. */
    .pte-lookup .gl-card {
        height: 35.5px;
        border-radius: 8px;
        background: var(--surface-elev-2);
        border-color: var(--border-subtle);
        box-shadow: none;
    }
    /* Tema kurali (body.app-theme-dark .gl-card) daha spesifik oldugu icin
       arka plani eziyordu — ayni spesifiklikte pte-input paritesi korunur. */
    body.app-theme-dark .pte-lookup .gl-card,
    body.app-theme-light .pte-lookup .gl-card {
        background: var(--surface-elev-2);
        border-color: var(--border-subtle);
        box-shadow: none;
    }
    .pte-lookup .gl-card__input {
        font-size: 13px;
        font-weight: var(--font-weight-medium);
        letter-spacing: -0.005em;
        color: var(--text-primary);
    }

    /* Toast içinde aksiyon butonu (Geri Al) — toast görünürken tıklanabilir olmalı */
    .pte-message.ok, .pte-message.err { pointer-events: auto; }
    .pte-msg-action {
        margin-left: 10px;
        padding: 3px 12px;
        border-radius: var(--radius-sm);
        border: 1px solid currentColor;
        background: transparent;
        color: inherit;
        font-size: 11.5px;
        font-weight: var(--font-weight-semibold);
        cursor: pointer;
        transition: background var(--motion-fast) var(--motion-ease-out);
    }
    .pte-msg-action:hover { background: rgba(255,255,255,0.12); }

    /* Grid'e yeni eklenen satır vurgusu */
    .pte-row-flash .pte-comp-td { animation: pteRowFlash 1.6s var(--motion-ease-out); }
    @@keyframes pteRowFlash {
        0%   { background: var(--accent-soft-bg); }
        100% { background: transparent; }
    }

    /* Çift tıkla hücre içi düzenleme */
    .pte-cell-edit { cursor: text; }
    .pte-cell-edit:hover { box-shadow: inset 0 -1px 0 var(--accent); }
    .pte-inline-edit {
        width: 72px;
        padding: 4px 8px;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border-focus);
        background: var(--surface-elev-2);
        color: var(--text-primary);
        font-size: 12.5px;
        font-variant-numeric: tabular-nums;
        text-align: right;
        outline: none;
        box-shadow: 0 0 0 var(--ring-width) var(--ring-color);
    }

    /* Satır notu — Ad hücresi altında sessiz ikinci satır */
    .pte-line-note {
        display: block;
        font-size: 11px;
        color: var(--text-muted);
        font-weight: var(--font-weight-regular);
        margin-top: 2px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        max-width: 340px;
    }

    /* Klavye ipucu şeridi */
    .pte-hint {
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
        grid-column: 2 / -1;
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 2px;
    }
    .pte-kbd {
        display: inline-block;
        padding: 1px 6px;
        border-radius: 4px;
        border: 1px solid var(--border-subtle);
        background: var(--surface-elev-2);
        font-family: ui-monospace, Menlo, Consolas, monospace;
        font-size: 10.5px;
        color: var(--text-secondary);
        line-height: 1.5;
    }

    /* Yapıştırma önizleme durum rozetleri */
    .pte-paste-status {
        display: inline-flex; align-items: center;
        padding: 2px 8px; border-radius: 999px;
        font-size: 10.5px; font-weight: var(--font-weight-semibold);
    }
    .pte-paste-status--ok    { background: var(--success-soft-bg); color: var(--success-soft-fg); }
    .pte-paste-status--warn  { background: var(--warning-soft-bg, rgba(245,158,11,0.15)); color: var(--warning-soft-fg, #f59e0b); }
    .pte-paste-status--err   { background: var(--danger-soft-bg); color: var(--danger-soft-fg); }
    .pte-paste-status--merge { background: var(--accent-soft-bg); color: var(--accent-soft-fg); }
    .pte-paste-textarea {
        width: 100%; min-height: 96px; resize: vertical;
        padding: 10px 12px;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-subtle);
        background: var(--surface-elev-2);
        color: var(--text-primary);
        font-family: ui-monospace, Menlo, Consolas, monospace;
        font-size: 12px;
        outline: none;
    }
    .pte-paste-textarea:focus {
        border-color: var(--border-focus);
        box-shadow: 0 0 0 var(--ring-width) var(--ring-color);
    }
    .pte-paste-preview { max-height: 260px; overflow: auto; margin-top: var(--space-3);
        border: 1px solid var(--border-subtle); border-radius: var(--radius-md); }
    .pte-paste-summary { font-size: 11.5px; color: var(--text-muted); margin-top: 8px; }

    /* ── Animations ── */
    @@keyframes pteShake {
        10%, 90% { transform: translateX(-1px); }
        20%, 80% { transform: translateX(2px); }
        30%, 50%, 70% { transform: translateX(-4px); }
        40%, 60% { transform: translateX(4px); }
    }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide page-product-trees">
  <div class="integrator-dashboard__content">

    <!-- Action Bar (ortak partial — Views/Shared/_CalibraActionBar.cshtml) -->
    @await Html.PartialAsync("_CalibraActionBar", new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["Title"]       = (string)(ViewBag.Title ?? ""),
        ["ListUrl"]     = "/Logistics/BOMs",
        ["NewUrl"]      = "/Logistics/BOMEdit",
        ["ShowDelete"]  = false,
        ["ShowActions"] = true,
    })
    @* Reçete'ye özel İşlemler dropdown içeriği — JS sayfada wire'lenmiş *@
    <div class="pte-actions-menu" id="ptActionsMenu" role="menu" aria-labelledby="ptBtnActions">
        <button type="button" class="pte-actions-menu__item" id="ptaMenuCopy" role="menuitem">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            Reçeteyi Kopyala
        </button>
        <!-- Yeni islem item'lari buraya eklenecek -->
    </div>

    <!-- Body: sidenav + content -->
    <div class="pte-body">
        <div class="pte-message" id="pteMsg"></div>

        <!-- Sidebar Navigation -->
        <nav class="pte-sidenav" id="pteSideNav">
            <button type="button" class="pte-nav-btn is-active" data-tab="genel">
                <span class="pte-nav-dot"></span>
                Genel Bilgiler
            </button>
            <button type="button" class="pte-nav-btn" data-tab="bilesen">
                <span class="pte-nav-dot"></span>
                Bileşen Bilgileri
                <span class="pte-nav-count" id="ptCompCount" data-count="0">0</span>
            </button>
            <button type="button" class="pte-nav-btn" data-tab="gorsel">
                <span class="pte-nav-dot"></span>
                Ürün Görseli
            </button>
        </nav>

        <!-- Content Area -->
        <div class="pte-content" id="pteContent">

            <!-- ── Genel Bilgiler ── -->
            <!-- Layout: Bilesen Bilgileri ile birebir (grid 100px label + flex values),
                 kod input 300px, kombinasyon her zaman gorunur (konfig yoksa pasif). -->
            <div id="pteTab-genel">
                <div class="pte-card pte-card--compact">
                    <p class="pte-card-title" style="display:flex;align-items:center;gap:10px;">
                        <span>Mamul Bilgileri</span>
                        <span id="pteRecipeStatus" class="pte-recipe-status" style="display:none;"></span>
                    </p>
                    <div class="pte-bilesen-form">

                        <!-- Mamul Kodu + Adi -->
                        <label class="pte-label pte-label--req">Mamul Kodu</label>
                        <div class="pte-bilesen-vals">
                            <div class="pte-lookup pte-lookup--pending" style="width:300px;flex-shrink:0;">
                                <input type="text" id="ptParentCode" data-field-key="parentCode" data-cb-allow-typing="true" class="pte-input" style="flex:1 1 0;min-width:0;" placeholder="Kod girin veya rehberden seçin..." autocomplete="off" />
                            </div>
                            <input type="text" id="ptParentName" class="pte-input" readonly placeholder="Mamul adı..." style="flex:1 1 0;min-width:0;" />
                        </div>

                        <!-- Kombinasyon Kodu (her zaman gorunur, konfig yoksa pasif) -->
                        <label id="ptConfigLabel" class="pte-label pte-label--req pte-cfg-disabled" style="color:#a5b4fc;">Kombinasyon</label>
                        <div id="ptConfigRow" class="pte-bilesen-vals pte-cfg-disabled">
                            <div class="pte-lookup" style="width:300px;flex-shrink:0;">
                                <input type="text" id="ptConfigCode" data-field-key="combinationCode" data-cb-allow-typing="true" class="pte-input" style="flex:1 1 0;min-width:0;border-color:rgba(99,102,241,0.3);" placeholder="Kombinasyon seçin veya yazın..." />
                                <button type="button" class="pte-lookup-btn" id="btnConfigLookup" title="Kombinasyon Rehberi">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.3-4.3"/></svg>
                                </button>
                            </div>
                            <input type="text" id="ptConfigDesc" class="pte-input" readonly placeholder="Kombinasyon açıklaması..." style="flex:1 1 0;min-width:0;" />
                        </div>

                        <!-- Recete Aciklamasi -->
                        <label class="pte-label" for="ptRecipeNote">Açıklama</label>
                        <div class="pte-bilesen-vals">
                            <input type="text" id="ptRecipeNote" class="pte-input" placeholder="İsteğe bağlı..." style="flex:1 1 0;min-width:0;" />
                        </div>

                        <!-- Rota (Routing) - opsiyonel header-level FK (2026-05-20).
                             Standart rehber (tip 1) pattern'i: GuideCode=ROUTING (FldSet'te
                             routingCode field key'i ile baglanir). FixedFieldLookupBridge
                             input'u LookupCard'a sarip Kod/Ad sutunlu searchli popup acar.
                             Hidden ptRoutingId backend save oncesi Code -> Id resolver ile dolar. -->
                        <label class="pte-label" for="ptRoutingCode">Rota</label>
                        <div class="pte-bilesen-vals">
                            <div class="pte-lookup pte-lookup--pending" style="width:300px;flex-shrink:0;">
                                <input type="text" id="ptRoutingCode"
                                       data-field-key="routingCode" data-cb-allow-typing="true"
                                       class="pte-input"
                                       style="flex:1 1 0;min-width:0;border-color:rgba(99,102,241,0.3);"
                                       placeholder="Rota seçin veya yazın..." autocomplete="off" />
                                <input type="hidden" id="ptRoutingId" value="" />
                            </div>
                            <input type="text" id="ptRoutingName" class="pte-input" readonly placeholder="Rota adı..." style="flex:1 1 0;min-width:0;" />
