    </div>

    <!-- LOKASYONLAR paneli (orijinal) -->
    <div class="wl-panel" id="wlPanelLocations">
        <div class="wl-layout">
            <div class="wl-form-panel">
                <input type="hidden" id="wlId" value="" />
                <div class="cs-line"><label>Tip *</label>
                    <select id="wlTypeCode" class="form-select form-select-sm">
                        <!-- Dinamik olarak JS ile doldurulur -->
                    </select>
                </div>
                <div class="cs-line"><label>Ust</label>
                    <select id="wlParentId" class="form-select form-select-sm">
                        <option value="">Ust kirilim yok</option>
                    </select>
                </div>
                <div class="cs-line"><label>Kod *</label><input id="wlCode" class="form-control form-control-sm" maxlength="50" style="max-width:120px;" /></div>
