                <div class="cs-line"><label>Sira</label><input id="wlSortOrder" class="form-control form-control-sm" type="number" min="0" style="max-width:80px;" value="0" /></div>
                <div class="cs-line"><label>Agirlik</label><input id="wlWeight" class="form-control form-control-sm" type="number" min="0" step="0.01" style="max-width:100px;" /></div>
                <div class="cs-line"><label>Hacim</label><input id="wlVolume" class="form-control form-control-sm" type="number" min="0" step="0.01" style="max-width:100px;" /></div>
                <div class="cs-line"><label>Durum</label><div class="form-check form-switch" style="margin:0;"><input id="wlIsActive" class="form-check-input" type="checkbox" role="switch" checked /></div></div>
