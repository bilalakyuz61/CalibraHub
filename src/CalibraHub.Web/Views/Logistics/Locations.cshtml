            </div>
            <div class="wl-grid-panel">
                <div class="wl-toolbar">
                    <input type="text" id="wlSearch" class="form-control form-control-sm" placeholder="Tip, kod, ad veya ust kirilima gore ara..." oninput="wlLoad()" style="max-width:280px;" />
                </div>
                <div class="wl-table-wrap">
                    <table class="wl-grid"><thead><tr>
                        <th style="width:70px;"></th><th>Tip</th><th>Kod</th><th>Ad</th><th>Ust Kirilim</th><th>Sira</th><th>Agirlik</th><th>Hacim</th><th>Durum</th>
                    </tr></thead><tbody id="wlBody"></tbody></table>
                </div>
            </div>
        </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function() {
    var API = function(a) { return '/Logistics/' + a; };
    var selId = 0;
    var allLocations = [];

    // Duz listeyi agac sirasinda (parent once, children indented) dizer
    function wlBuildTreeOrder(data) {
        var byId = {};
        data.forEach(function(d) { byId[d.id] = d; d._children = []; });
        var roots = [];
        data.forEach(function(d) {
            if (d.parentId != null && byId[d.parentId]) byId[d.parentId]._children.push(d);
            else roots.push(d);
        });
        function sortFn(a, b) {
            if (a.sortOrder !== b.sortOrder) return a.sortOrder - b.sortOrder;
            return (a.locationCode || '').localeCompare(b.locationCode || '', 'tr');
        }
        roots.sort(sortFn);
        var out = [];
        function walk(node, depth, isLastSibling, parentPrefix) {
            node._depth = depth;
            node._isLast = isLastSibling;
            node._parentPrefix = parentPrefix;
            node._hasChildren = node._children.length > 0;
            out.push(node);
            var childPrefix = parentPrefix + (isLastSibling ? '   ' : '│  ');
            var children = node._children.slice().sort(sortFn);
            children.forEach(function(c, i) {
                walk(c, depth + 1, i === children.length - 1, childPrefix);
            });
        }
        roots.forEach(function(r, i) { walk(r, 0, i === roots.length - 1, ''); });
        return out;
    }

    window.wlLoad = function() {
        var s = document.getElementById('wlSearch').value;
        fetch(API('GetAllLocations') + '?search=' + encodeURIComponent(s))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                allLocations = data;
                wlBuildParentOptions();
                var body = document.getElementById('wlBody');
                if (data.length === 0) { body.innerHTML = '<tr><td colspan="9" class="wl-empty">Kayit bulunamadi.</td></tr>'; return; }

                // Arama yoksa agac gosterimi; varsa duz liste (arama sonucu hiyerarsiyi bozmasin diye)
                var ordered = s ? data : wlBuildTreeOrder(data);
                body.innerHTML = ordered.map(function(d) {
                    var w = d.maxWeightCapacity != null ? d.maxWeightCapacity.toFixed(2).replace(/\.?0+$/, '') : '-';
                    var v = d.volumeCapacity != null ? d.volumeCapacity.toFixed(2).replace(/\.?0+$/, '') : '-';
                    // Agac prefix'i — depth > 0 ise
                    var indent = '';
                    if (!s && d._depth > 0) {
                        var connector = d._isLast ? '└─ ' : '├─ ';
                        indent = '<span style="color:#94a3b8;font-family:monospace;white-space:pre;">' + d._parentPrefix + connector + '</span>';
                    }
                    // Yaprak olmayan (child'i olan) satirlari hafifce vurgula — gruplama/raporlama icin
                    var isGroup = !s && d._hasChildren;
                    var codeStyle = 'font-weight:' + (isGroup ? '700' : '600') + ';' +
                        (isGroup ? 'color:#6366f1;' : '');
                    var rowAttr = 'class="' + (d.id === selId ? 'is-sel' : '') + (isGroup ? ' wl-group' : '') + '"';
                    var editBtn = '<button type="button" class="act-btn act-btn--edit" title="Düzenle" onclick="wlSelect(' + d.id + ')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></button>';
                    var delBtn = '<button type="button" class="act-btn act-btn--delete" title="Sil" onclick="wlDeleteRow(' + d.id + ')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>';
                    return '<tr ' + rowAttr + ' onclick="wlSelect(' + d.id + ')">' +
                        '<td onclick="event.stopPropagation()" style="white-space:nowrap;">' + editBtn + delBtn + '</td>' +
                        '<td>' + d.locationTypeDisplayName + '</td>' +
                        '<td style="' + codeStyle + '">' + indent + d.locationCode + '</td>' +
                        '<td>' + (d.locationName || '-') + '</td>' +
                        '<td>' + d.parentDisplayName + '</td>' +
                        '<td>' + d.sortOrder + '</td>' +
                        '<td>' + w + '</td>' +
                        '<td>' + v + '</td>' +
                        '<td style="font-size:0.72rem;color:' + (d.isActive ? '#15803d' : '#dc2626') + ';">' + (d.isActive ? 'Aktif' : 'Pasif') + '</td></tr>';
                }).join('');
            });
    };

    function wlBuildParentOptions() {
        var sel = document.getElementById('wlParentId');
        var curVal = sel.value;
        sel.innerHTML = '<option value="">Ust kirilim yok</option>';
        allLocations.forEach(function(d) {
            if (d.id === selId) return;
            var label = d.locationName ? d.locationCode + ' - ' + d.locationName : d.locationCode;
            var opt = document.createElement('option');
            opt.value = d.id;
            opt.textContent = label;
            if (String(d.id) === curVal) opt.selected = true;
            sel.appendChild(opt);
        });
    }

    window.wlSelect = function(id) {
        selId = id;
        fetch(API('GetLocation') + '?id=' + id)
            .then(function(r) { return r.json(); })
            .then(function(d) {
                document.getElementById('wlId').value = d.id;
                document.getElementById('wlTypeCode').value = d.locationTypeCode;
                document.getElementById('wlCode').value = d.locationCode;
                document.getElementById('wlName').value = d.locationName;
                document.getElementById('wlSortOrder').value = d.sortOrder;
                document.getElementById('wlWeight').value = d.maxWeightCapacity != null ? d.maxWeightCapacity : '';
                document.getElementById('wlVolume').value = d.volumeCapacity != null ? d.volumeCapacity : '';
                document.getElementById('wlIsActive').checked = d.isActive;
                wlSyncTopDeleteState();
                wlBuildParentOptions();
                document.getElementById('wlParentId').value = d.parentId != null ? d.parentId : '';
                wlLoad();
            });
    };

    window.wlNew = function() {
        selId = 0;
        document.getElementById('wlId').value = '';
        document.getElementById('wlTypeCode').value = 'SECTION';
        document.getElementById('wlParentId').value = '';
        document.getElementById('wlCode').value = '';
        document.getElementById('wlName').value = '';
        document.getElementById('wlSortOrder').value = '0';
        document.getElementById('wlWeight').value = '';
        document.getElementById('wlVolume').value = '';
        document.getElementById('wlIsActive').checked = true;
        wlSyncTopDeleteState();
        wlMsg('');
        wlLoad();
    };

    function wlShakeInvalid(el) {
        if (!el) return;
        el.classList.remove('is-invalid');
        void el.offsetWidth;
        el.classList.add('is-invalid');
        setTimeout(function() { el.classList.remove('is-invalid'); }, 1400);
    }
    // Kullanici yazmaya baslarsa hata sinifini temizle
    ['wlTypeCode','wlCode','wlName'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('input', function() { el.classList.remove('is-invalid'); });
        if (el) el.addEventListener('change', function() { el.classList.remove('is-invalid'); });
    });

    window.wlSave = function() {
        var typeEl = document.getElementById('wlTypeCode');
        var codeEl = document.getElementById('wlCode');
        var nameEl = document.getElementById('wlName');
        var typeVal = typeEl.value.trim();
        var codeVal = codeEl.value.trim();
        var nameVal = nameEl.value.trim();
        var invalid = false;
        if (!typeVal) { wlShakeInvalid(typeEl); invalid = true; }
        if (!codeVal) { wlShakeInvalid(codeEl); invalid = true; }
        if (!nameVal) { wlShakeInvalid(nameEl); invalid = true; }
        if (invalid) return;

        var wVal = document.getElementById('wlWeight').value;
        var vVal = document.getElementById('wlVolume').value;
        var pVal = document.getElementById('wlParentId').value;
        var payload = {
            id: parseInt(document.getElementById('wlId').value) || null,
            locationTypeCode: typeVal,
            parentId: pVal ? parseInt(pVal) : null,
            locationCode: codeVal,
            locationName: nameVal,
            sortOrder: parseInt(document.getElementById('wlSortOrder').value) || 0,
            maxWeightCapacity: wVal !== '' ? parseFloat(wVal) : null,
            volumeCapacity: vVal !== '' ? parseFloat(vVal) : null,
            isActive: document.getElementById('wlIsActive').checked
        };
        fetch(API('SaveLocationJson'), { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(payload) })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.success) { wlFlashKitt(); wlNew(); }
                else wlMsg(d.message || 'Hata', false);
            });
    };

    function wlHasChildren(id) {
        return allLocations.some(function(x) { return x.parentId === id; });
    }

    function wlConfirmDialog(message, opts) {
        if (window.CalibraAlert && typeof window.CalibraAlert.confirm === 'function') {
            return window.CalibraAlert.confirm(message, opts || {});
        }
        return Promise.resolve(window.confirm(message));
    }
    function wlAlert(message, opts) {
        if (window.CalibraAlert && typeof window.CalibraAlert.warning === 'function') {
            return window.CalibraAlert.warning(message, opts || {});
        }
        window.alert(message);
    }

    function wlDoDelete(id, onSuccess) {
        // Sunucu tarafi da blokluyorsa hata mesajini goster
        fetch(API('DeleteLocationJson') + '?id=' + id, { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.success) { if (onSuccess) onSuccess(); }
                else {
                    wlAlert(d.message || 'Lokasyon silinemedi.', { title: 'Silme Basarisiz' });
                }
            })
            .catch(function() { wlAlert('Baglanti hatasi. Lutfen tekrar deneyin.', { title: 'Hata' }); });
    }

    function wlAttemptDelete(id, onSuccess) {
        if (!id) return;
        var loc = allLocations.find(function(x) { return x.id === id; });
        if (loc && wlHasChildren(id)) {
            var label = loc.locationCode + (loc.locationName ? ' — ' + loc.locationName : '');
            wlAlert(
                '"' + label + '" lokasyonu altinda bir veya daha fazla lokasyon bulundugu icin silinemez. Silmeden once once alt kirilimlarini kaldirin veya baska bir gruba tasiyin.',
                { title: 'Silinemez — Alt Kirilim Var' }
            );
            return;
        }
        var title = loc
            ? 'Sil: ' + loc.locationCode + (loc.locationName ? ' — ' + loc.locationName : '')
            : 'Lokasyon Silinsin Mi?';
        wlConfirmDialog('Bu lokasyonu silmek istediginize emin misiniz?', {
            title: title, okText: 'Evet, Sil', danger: true
        }).then(function(ok) {
            if (!ok) return;
            wlDoDelete(id, onSuccess);
        });
    }

    window.wlDelete = function() {
        var id = parseInt(document.getElementById('wlId').value);
        wlAttemptDelete(id, function() { wlMsg('Silindi.', true); wlNew(); });
    };

    window.wlDeleteRow = function(id) {
        wlAttemptDelete(id, function() { wlLoad(); });
    };

    function wlMsg(msg, ok) {
        var el = document.getElementById('wlMsg');
        if (!msg) { el.innerHTML = ''; return; }
        el.innerHTML = '<div class="wl-msg ' + (ok ? 'ok' : 'err') + '">' + msg + '</div>';
        if (ok) setTimeout(function() { el.innerHTML = ''; }, 3000);
    }

    // ═══════════════════════════════════════════════════════════════
    // TAB yonetimi + global toolbar dispatcher
    // ═══════════════════════════════════════════════════════════════
    var _wlActiveTab = 'locations';

    window.wlSwitchTab = function(key) {
        _wlActiveTab = key;
        var panels = { types: 'wlPanelTypes', locations: 'wlPanelLocations' };
        var navs = { types: 'wlNavTypes', locations: 'wlNavLocations' };
        Object.keys(panels).forEach(function(k) {
            var p = document.getElementById(panels[k]); if (p) p.classList.toggle('is-hidden', k !== key);
            var n = document.getElementById(navs[k]); if (n) n.classList.toggle('is-active', k === key);
        });
        if (key === 'types') wltLoad();
        else wlPopulateTypeDropdown().then(function() { wlLoad(); });
        wlSyncTopDeleteState();
    };

    // Global Sil butonunun disabled durumunu aktif tab'a gore guncelle
    window.wlSyncTopDeleteState = function() {
        var btn = document.getElementById('wlTopBtnDelete');
        if (!btn) return;
        if (_wlActiveTab === 'types') {
            var tid = parseInt(document.getElementById('wltId').value) || 0;
            btn.disabled = tid <= 0;
        } else {
            var lid = parseInt(document.getElementById('wlId').value) || 0;
            btn.disabled = lid <= 0;
        }
    };

    // Global toolbar -> aktif tab'in fonksiyonuna yonlendirici
    window.wlActiveSave   = function() { (_wlActiveTab === 'types') ? wltSave()          : wlSave();   };
    window.wlActiveNew    = function() { (_wlActiveTab === 'types') ? wltNew()           : wlNew();    };
    window.wlActiveDelete = function() { (_wlActiveTab === 'types') ? wltDeleteCurrent() : wlDelete(); };

    // ═══════════════════════════════════════════════════════════════
    // Bolum Tipleri — CRUD
    // ═══════════════════════════════════════════════════════════════
    var wltAll = [];

    function wltMsg(msg, ok) {
        var el = document.getElementById('wltMsg');
        if (!msg) { el.innerHTML = ''; return; }
        el.innerHTML = '<div class="wl-msg ' + (ok ? 'ok' : 'err') + '">' + msg + '</div>';
        if (ok) setTimeout(function() { el.innerHTML = ''; }, 2500);
    }
    function wltEsc(s) { var d = document.createElement('div'); d.textContent = s == null ? '' : String(s); return d.innerHTML; }

    function wltLoad() {
        return fetch(API('GetLocationTypes')).then(function(r) { return r.json(); })
            .then(function(data) {
                wltAll = data || [];
                var body = document.getElementById('wltBody');
                if (wltAll.length === 0) {
                    body.innerHTML = '<tr><td colspan="5" class="wl-empty">Tip tanimi bulunamadi.</td></tr>';
                    return;
                }
                body.innerHTML = wltAll.map(function(t) {
                    var status = t.isActive
                        ? '<span style="color:#15803d;font-size:.72rem;">Aktif</span>'
                        : '<span style="color:#dc2626;font-size:.72rem;">Pasif</span>';
                    var edit = '<button type="button" class="act-btn act-btn--edit" title="Düzenle" onclick="wltSelect(' + t.id + ')"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></button>';
                    return '<tr onclick="wltSelect(' + t.id + ')">' +
                        '<td onclick="event.stopPropagation()" style="white-space:nowrap;">' + edit + '</td>' +
                        '<td style="font-weight:600;font-family:monospace;color:#6366f1;">' + wltEsc(t.code) + '</td>' +
                        '<td>' + wltEsc(t.name) + '</td>' +
                        '<td>' + t.sortOrder + '</td>' +
                        '<td>' + status + '</td></tr>';
                }).join('');
            });
    }

    window.wltSelect = function(id) {
        var t = wltAll.find(function(x) { return x.id === id; });
        if (!t) return;
        document.getElementById('wltId').value = t.id;
        document.getElementById('wltCode').value = t.code;
        document.getElementById('wltName').value = t.name;
        document.getElementById('wltSortOrder').value = t.sortOrder;
        document.getElementById('wltIsActive').checked = t.isActive;
        wlSyncTopDeleteState();
        wltMsg('');
    };

    window.wltNew = function() {
        document.getElementById('wltId').value = '';
        document.getElementById('wltCode').value = '';
        document.getElementById('wltName').value = '';
        document.getElementById('wltSortOrder').value = '0';
        document.getElementById('wltIsActive').checked = true;
        wlSyncTopDeleteState();
        wltMsg('');
    };

    function wlFlashKitt() {
        var bar = document.getElementById('wlTopToolbar');
        if (!bar) return;
        bar.classList.remove('is-save-flash');
        void bar.offsetWidth;
        bar.classList.add('is-save-flash');
        setTimeout(function() { bar.classList.remove('is-save-flash'); }, 1850);
    }
    var wltFlashKitt = wlFlashKitt;

    window.wltSave = function() {
        var codeEl = document.getElementById('wltCode');
        var nameEl = document.getElementById('wltName');
        var code = codeEl.value.trim().toUpperCase();
        var name = nameEl.value.trim();
        var invalid = false;
        if (!code) { wlShakeInvalid(codeEl); invalid = true; }
        if (!name) { wlShakeInvalid(nameEl); invalid = true; }
        if (invalid) return;

        var payload = {
            id: parseInt(document.getElementById('wltId').value) || null,
            code: code, name: name,
            sortOrder: parseInt(document.getElementById('wltSortOrder').value) || 0,
            isActive: document.getElementById('wltIsActive').checked
        };
        fetch(API('SaveLocationType'), {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.success) { wltFlashKitt(); wltNew(); wltLoad(); wlPopulateTypeDropdown(); }
            else wltMsg(d.message || 'Hata', false);
        });
    };

    // Toolbar'daki Sil butonu — formdaki secili tipi siler
    window.wltDeleteCurrent = function() {
        var id = parseInt(document.getElementById('wltId').value);
        if (!id) { wltMsg('Silmek icin bir tip secin.', false); return; }
        var name = document.getElementById('wltName').value || 'Secili tip';
        wlConfirmDialog('"' + name + '" tipini silmek istediginize emin misiniz?', {
            title: 'Tip Silinsin Mi?', okText: 'Evet, Sil', danger: true
        }).then(function(ok) {
            if (!ok) return;
            fetch(API('DeleteLocationType') + '?id=' + id, { method: 'POST' })
                .then(function(r) { return r.json(); })
                .then(function(d) {
                    if (d && d.success) {
                        wltNew();
                        wltLoad();
                        wlPopulateTypeDropdown();
                    } else {
                        wlAlert((d && d.message) || 'Silinemedi.', { title: 'Silme Basarisiz' });
                    }
                })
                .catch(function(e) { wlAlert('Baglanti hatasi: ' + e.message, { title: 'Hata' }); });
        });
    };

    // wlTypeCode dropdown'unu DB'den doldur
    function wlPopulateTypeDropdown() {
        return fetch(API('GetLocationTypes')).then(function(r) { return r.json(); })
            .then(function(types) {
                var sel = document.getElementById('wlTypeCode');
                if (!sel) return;
                var curVal = sel.value;
                var active = (types || []).filter(function(t) { return t.isActive; });
                sel.innerHTML = active.map(function(t) {
                    return '<option value="' + wltEsc(t.code) + '">' + wltEsc(t.name) + '</option>';
                }).join('');
                if (curVal && active.some(function(t) { return t.code === curVal; })) sel.value = curVal;
                else if (active.length > 0) sel.value = active[0].code;
            });
    }

    // Init — tum window.xxx fonksiyonlari tanimlandiktan sonra ilk yukleme
    wlPopulateTypeDropdown().then(function() { wlLoad(); });
})();
</script>
}
