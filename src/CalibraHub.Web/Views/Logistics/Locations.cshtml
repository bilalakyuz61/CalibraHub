        border-bottom: 2px solid #e2e8f0; background: #f8fafc; white-space: nowrap;
    }
    body.app-theme-dark .wl-types-table thead th { color: rgba(165,180,252,.85); background: rgba(255,255,255,0.03); border-bottom-color: rgba(255,255,255,0.1); }
    .wl-types-table tbody tr { border-bottom: 1px solid #f1f5f9; cursor: pointer; }
    body.app-theme-dark .wl-types-table tbody tr { border-bottom-color: rgba(255,255,255,0.05); }
    .wl-types-table tbody tr:hover { background: #f8fafc; }
    body.app-theme-dark .wl-types-table tbody tr:hover { background: rgba(255,255,255,0.04); }
    .wl-types-table tbody tr.is-sel { background: #eff6ff; }
