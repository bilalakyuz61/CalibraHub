@{
    ViewData["Title"] = "Lokasyon Tanimlamalari";
    ViewData["FormCode"] = "LOCATIONS";
    ViewData["BodyClass"] = "page-locations-edit";
    ViewData["DbInfo"] = "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>warehouse_locations</td><td style='padding:6px 8px;'>Lokasyon tanimlari (tip, kod, ad, ust kirilim, sira, agirlik kapasitesi, hacim, durum). Hiyerarsik yapi ParentId ile saglanir.</td></tr>"
        + "</table>";
}

@section Styles {
<style>
    /* Page full-height layout */
    .page-locations-edit .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-locations-edit .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important; margin: 0 !important;
        overflow: hidden !important;
    }
    .workspace-frame-body.page-locations-edit .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column; overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-locations-edit .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    /* React tree mount — full height */
    #locationTreeMount {
        flex: 1 1 auto; min-height: 0;
        display: flex; flex-direction: column; height: 100%;
    }
</style>
}

<div id="locationTreeMount"></div>

@section Scripts {
<script>
(function() {
    var BUNDLE_URL = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js")';
    var CSS_URL    = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css")';
    var el = document.getElementById('locationTreeMount');

    function showError(msg) {
        if (el) el.innerHTML = '<div style="padding:24px;color:#dc2626;font-size:13px;">' + msg + '</div>';
    }

    function loadCss() {
        if (document.querySelector('link[data-locations-tree]')) return;
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = CSS_URL;
        link.setAttribute('data-locations-tree', '1');
        document.head.appendChild(link);
    }
    function loadScript(cb) {
        var prev = document.querySelector('script[data-locations-tree]');
        if (prev) { prev.addEventListener('load', cb); return; }
        var script = document.createElement('script');
        script.src = BUNDLE_URL;
        script.setAttribute('data-locations-tree', '1');
        script.onload  = function() { setTimeout(cb, 0); };
        script.onerror = function() { showError('React bundle yüklenemedi.'); };
        document.head.appendChild(script);
    }

    function doMount() {
        if (!window.CalibraHub || !window.CalibraHub.mountLocationTree) {
            showError('mountLocationTree fonksiyonu bulunamadı.'); return;
        }
        fetch('/Logistics/LocationsTree', { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(cfg) {
                window.CalibraHub.mountLocationTree(el, cfg);
                console.log('[Locations] LocationTree mounted, ', (cfg.roots || []).length, 'kök');
            })
            .catch(function(err) {
                showError('Lokasyon ağacı yüklenemedi: ' + (err && err.message || err));
            });
    }

    loadCss();
    if (window.CalibraHub && window.CalibraHub.mountLocationTree) doMount();
    else loadScript(doMount);
})();
</script>
}
