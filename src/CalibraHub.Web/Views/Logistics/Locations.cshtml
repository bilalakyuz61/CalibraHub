@{
    ViewData["Title"] = "Lokasyon Tanimlamalari";
    ViewData["FormCode"] = "LOCATIONS";
    ViewData["BodyClass"] = "page-locations-edit";
    ViewData["DbInfo"] = "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>warehouse_locations</td><td style='padding:6px 8px;'>Lokasyon tanimlari (tip, kod, ad, ust kirilim, sira, agirlik kapasitesi, hacim, durum). Hiyerarsik yapi ParentId ile saglanir.</td></tr>"
        + "</table>";
}

@section Styles {
<style>
    /* Page full-height layout */
    .page-locations-edit .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-locations-edit .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important; margin: 0 !important;
        overflow: hidden !important;
    }
    .workspace-frame-body.page-locations-edit .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column; overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-locations-edit .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }
    .wl-root { display: flex; flex-direction: column; height: 100%; min-height: 0; overflow: hidden; }

    .wl-layout { display: flex; flex-direction: column; gap: 0; height: 100%; overflow: hidden; }
    .wl-form-panel {
        flex: 1 1 50%; max-height: 50%;
        background: #fff; color: #1e293b;
        display: flex; flex-direction: column; overflow-y: auto;
        padding: 10px 14px; border-bottom: 1px solid #e2e8f0;
    }
    .wl-grid-panel { flex: 1 1 50%; min-height: 0; display: flex; flex-direction: column; overflow: hidden; position: relative; }
    .wl-grid-panel .wl-table-wrap { flex: 1 1 auto; overflow: auto; }

    .cs-line { display: flex; align-items: center; gap: 10px; padding: 4px 0; border-bottom: 1px solid #f1f5f9; }
    .cs-line:last-child { border-bottom: none; }
    .cs-line > label:first-child { width: 58px; flex-shrink: 0; font-size: 0.76rem; font-weight: 600; color: #64748b; text-align: right; }

    .wl-toolbar { padding: 5px 10px; border-bottom: 1px solid #e2e8f0; }
    .wl-grid { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
    .wl-grid thead th { text-align: left; padding: 3px 8px; font-weight: 600; color: #64748b; font-size: 0.7rem; text-transform: uppercase; border-bottom: 2px solid #e2e8f0; background: #f8fafc; white-space: nowrap; }
    .wl-grid tbody tr { border-bottom: 1px solid #f1f5f9; transition: background .1s; cursor: pointer; color: #1e293b; }
    .wl-grid tbody tr:hover { background: #f8fafc; }
    .wl-grid tbody tr.is-sel { background: #eff6ff; }
    .wl-grid tbody tr.wl-group { background: rgba(99,102,241,.04); }
    .wl-grid tbody tr.wl-group:hover { background: rgba(99,102,241,.10); }
    body.app-theme-dark .wl-grid tbody tr.wl-group { background: rgba(129,140,248,.05); }
    body.app-theme-dark .wl-grid tbody tr.wl-group:hover { background: rgba(129,140,248,.12); }
    .wl-grid td { padding: 2px 8px; vertical-align: middle; }
    .wl-empty { text-align: center; padding: 20px; color: #94a3b8; font-style: italic; }

    .act-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; padding: 0; border-radius: 4px;
        background: #fff; border: 1px solid #e2e8f0; color: #64748b;
        cursor: pointer; margin-right: 3px; transition: all .12s;
    }
    .act-btn:hover { background: #f1f5f9; border-color: #cbd5e1; }
    body.app-theme-dark .act-btn {
        background: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.6);
    }
    body.app-theme-dark .act-btn:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.2); }

    .act-btn--edit { border-color: #bfdbfe; color: #2563eb; background: #fff; }
    .act-btn--edit:hover { background: #eff6ff; border-color: #93c5fd; }
    body.app-theme-dark .act-btn--edit {
        background: rgba(59,130,246,0.12);
        border-color: rgba(59,130,246,0.35);
        color: #93c5fd;
    }
    body.app-theme-dark .act-btn--edit:hover { background: #3b82f6; color: #fff; border-color: #2563eb; }

    .act-btn--delete { border-color: #fecaca; color: #dc2626; background: #fff; }
    .act-btn--delete:hover { background: #fef2f2; border-color: #f87171; }
    body.app-theme-dark .act-btn--delete {
        background: rgba(239,68,68,0.12);
        border-color: rgba(239,68,68,0.35);
        color: #fca5a5;
    }
    body.app-theme-dark .act-btn--delete:hover { background: #ef4444; color: #fff; border-color: #dc2626; }

    .wl-msg { padding: 4px 8px; border-radius: 5px; font-size: 0.7rem; margin-top: 6px; }
    .wl-msg.ok  { background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0; }
    .wl-msg.err { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }

    /* ── Iki-tab layout: sol sidenav + sag icerik ─────────────────── */
    .wl-shell { display: flex; height: 100%; min-height: 0; overflow: hidden; }
    .wl-sidenav {
        width: 200px; flex-shrink: 0;
        border-right: 1px solid #e2e8f0;
        background: #f8fafc;
        display: flex; flex-direction: column;
        padding: 10px 8px; gap: 4px; overflow-y: auto;
    }
    body.app-theme-dark .wl-sidenav { background: rgba(255,255,255,0.02); border-right-color: rgba(255,255,255,0.07); }
    .wl-nav-btn {
        display: flex; align-items: center; gap: 8px;
        width: 100%; padding: 8px 12px;
        background: #f1f5f9; border: 1px solid #e2e8f0;
        border-radius: 8px; color: #64748b;
        font-size: 0.76rem; font-weight: 500; text-align: left;
        cursor: pointer; transition: all 0.15s; line-height: 1.35;
    }
    body.app-theme-dark .wl-nav-btn { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); }
    .wl-nav-btn:hover { background: #e2e8f0; color: #1e293b; border-color: #cbd5e1; }
    body.app-theme-dark .wl-nav-btn:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.85); }
    .wl-nav-btn.is-active {
        background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.3);
        color: #059669; font-weight: 600;
    }
    body.app-theme-dark .wl-nav-btn.is-active {
        background: rgba(16,185,129,0.12); border-color: rgba(16,185,129,0.35); color: #34d399;
    }
    .wl-nav-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; opacity: 0.5; }
    .wl-nav-btn.is-active .wl-nav-dot { opacity: 1; }
    .wl-panel { flex: 1 1 auto; min-width: 0; min-height: 0; display: flex; flex-direction: column; overflow: hidden; }
    .wl-panel.is-hidden { display: none; }

    /* Tipler tabi */
    .wl-types-wrap { display: flex; flex-direction: column; height: 100%; min-height: 0; overflow: hidden; }
    .wl-types-form-panel {
        flex: 0 0 auto; background: #fff; color: #1e293b;
        padding: 10px 14px; border-bottom: 1px solid #e2e8f0;
    }
    body.app-theme-dark .wl-types-form-panel {
        background: rgba(15, 15, 26, 0.6);
        color: rgba(255, 255, 255, 0.9);
        border-bottom-color: rgba(255,255,255,0.08);
    }
    .wl-types-grid { flex: 1 1 auto; overflow: auto; padding: 8px 12px; }

    /* Kaydet KITT tarayici — ust toolbar alti */
    #wlTopToolbar { position: relative; overflow: hidden; }
    #wlTopToolbar::before {
        content: ''; position: absolute;
        left: 0; right: 0; bottom: 0;
        height: 2px;
        pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,
            rgba(0, 60, 20, 0) 0%,
            rgba(10, 120, 40, .55) 50%,
            rgba(0, 60, 20, 0) 100%);
    }
    #wlTopToolbar::after {
        content: ''; position: absolute;
        left: 0; bottom: -1px;
        width: 18%; height: 4px;
        pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,
            transparent 0%,
            rgba(34, 197, 94, .35) 18%,
            rgba(74, 255, 140, 1) 50%,
            rgba(34, 197, 94, .35) 82%,
            transparent 100%);
        box-shadow:
            0 0 10px 2px rgba(34, 197, 94, .95),
            0 0 22px 6px rgba(34, 197, 94, .55),
            0 0 40px 12px rgba(34, 197, 94, .22);
        border-radius: 50%;
    }
    #wlTopToolbar.is-save-flash::before { animation: wlKittBg   1800ms ease-out forwards; }
    #wlTopToolbar.is-save-flash::after  { animation: wlKittScan 1800ms cubic-bezier(.45,.05,.55,.95) forwards; }
    @@keyframes wlKittBg {
        0%, 100% { opacity: 0; }
        10%, 90% { opacity: 1; }
    }
    @@keyframes wlKittScan {
        0%   { opacity: 0; left: 0; }
        8%   { opacity: 1; }
        48%  { opacity: 1; left: 82%; }
        52%  { opacity: 1; left: 82%; }
        92%  { opacity: 1; left: 0; }
        100% { opacity: 0; left: 0; }
    }
    .wl-types-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .wl-types-table thead th {
        text-align: left; padding: 6px 10px; font-weight: 600; color: #64748b;
