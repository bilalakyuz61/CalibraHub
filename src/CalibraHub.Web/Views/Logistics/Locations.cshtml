        border-bottom-color: rgba(255, 255, 255, 0.04);
    }
    body.app-theme-dark .wl-grid tbody tr:hover  { background: rgba(255, 255, 255, 0.04); }
    body.app-theme-dark .wl-grid tbody tr.is-sel { background: rgba(99, 102, 241, 0.20); color: #fff; }
    body.app-theme-dark .wl-empty { color: rgba(255, 255, 255, 0.35); }

    body.app-theme-dark .act-btn {
        background: rgba(239, 68, 68, 0.12);
        border-color: rgba(239, 68, 68, 0.30);
        color: #fca5a5;
    }
    body.app-theme-dark .act-btn:hover { background: #ef4444; color: #fff; border-color: #dc2626; }

    body.app-theme-dark .wl-msg.ok {
        background: rgba(16, 185, 129, 0.15); color: #34d399;
        border-color: rgba(16, 185, 129, 0.35);
    }
    body.app-theme-dark .wl-msg.err {
        background: rgba(239, 68, 68, 0.15); color: #fca5a5;
        border-color: rgba(239, 68, 68, 0.35);
    }
</style>
}

<div class="wl-root">
