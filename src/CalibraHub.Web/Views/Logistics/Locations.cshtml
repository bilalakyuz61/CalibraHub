    body.app-theme-dark .wl-form-panel .form-control.is-invalid,
    body.app-theme-dark .wl-form-panel .form-select.is-invalid {
        background: rgba(239, 68, 68, 0.12) !important;
        border-color: #f87171 !important;
        box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.25) !important;
    }

    /* ══════════════════════════════════════════════════════════════
       DARK THEME
       ══════════════════════════════════════════════════════════════ */
    body.app-theme-dark .wl-form-panel {
        background: rgba(15, 15, 26, 0.6);
        color: rgba(255, 255, 255, 0.9);
        border-bottom-color: rgba(255, 255, 255, 0.08);
    }
    body.app-theme-dark .cs-line { border-bottom-color: rgba(255, 255, 255, 0.05); }
    body.app-theme-dark .cs-line > label:first-child { color: rgba(255, 255, 255, 0.55); }

    body.app-theme-dark .wl-form-panel .form-control,
    body.app-theme-dark .wl-form-panel .form-select {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.92);
    }
    body.app-theme-dark .wl-form-panel .form-control:hover,
    body.app-theme-dark .wl-form-panel .form-select:hover {
        background: rgba(255, 255, 255, 0.09);
        border-color: rgba(255, 255, 255, 0.18);
    }
    body.app-theme-dark .wl-form-panel .form-control:focus,
    body.app-theme-dark .wl-form-panel .form-select:focus {
        background: rgba(99, 102, 241, 0.08);
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.18);
        outline: none;
    }

    body.app-theme-dark .wl-toolbar { border-bottom-color: rgba(255, 255, 255, 0.08); }

    body.app-theme-dark .wl-grid thead th {
        color: rgba(165, 180, 252, 0.85);
        background: rgba(255, 255, 255, 0.03);
        border-bottom-color: rgba(255, 255, 255, 0.10);
    }
    body.app-theme-dark .wl-grid tbody tr {
