        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
        <polyline points="17 21 17 13 7 13 7 21"/>
        <polyline points="7 3 7 8 15 8"/>
      </svg>Kaydet
    </button>
    <button type="button" class="btn btn-secondary integrator-btn-secondary" onclick="wlActiveNew()" title="Yeni">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:6px;">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>Yeni
    </button>
    <button type="button" class="btn btn-outline-danger integrator-btn-tertiary" id="wlTopBtnDelete" disabled onclick="wlActiveDelete()" title="Sil">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-2px;margin-right:6px;">
        <polyline points="3 6 5 6 21 6"/>
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
        <line x1="10" y1="11" x2="10" y2="17"/>
        <line x1="14" y1="11" x2="14" y2="17"/>
      </svg>Sil
    </button>
  </div>

  <div class="wl-shell">
    <!-- Sol navigasyon -->
    <nav class="wl-sidenav" aria-label="Sekmeler">
        <button type="button" class="wl-nav-btn" id="wlNavTypes" onclick="wlSwitchTab('types')">
            <span class="wl-nav-dot"></span> Bölüm Tipleri
        </button>
        <button type="button" class="wl-nav-btn is-active" id="wlNavLocations" onclick="wlSwitchTab('locations')">
