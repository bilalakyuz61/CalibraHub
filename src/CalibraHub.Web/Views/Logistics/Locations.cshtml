                <div class="cs-line"><label>Kod *</label>
                    <input id="wltCode" class="form-control form-control-sm" maxlength="50" style="max-width:180px;text-transform:uppercase;" placeholder="FACTORY" />
                </div>
                <div class="cs-line"><label>Ad *</label>
                    <input id="wltName" class="form-control form-control-sm" maxlength="100" style="max-width:280px;" placeholder="Fabrika" />
                </div>
