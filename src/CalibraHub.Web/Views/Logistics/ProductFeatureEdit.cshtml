    body.app-theme-light .pfe-guide-row__code { color: #6366f1; }
    .pfe-guide-row__name { flex: 1; font-size: .82rem; color: rgba(255,255,255,.75); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    body.app-theme-light .pfe-guide-row__name { color: #475569; }
    .pfe-guide-row__switch { position: relative; width: 36px; height: 20px; flex-shrink: 0; }
    .pfe-guide-row__switch input { opacity: 0; width: 0; height: 0; }
    .pfe-guide-row__switch .pfe-switch-track {
        position: absolute; inset: 0; background: rgba(255,255,255,.12);
        border-radius: 10px; transition: background .2s; cursor: pointer;
