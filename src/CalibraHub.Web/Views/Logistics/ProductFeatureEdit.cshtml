@model CalibraHub.Web.Models.Logistics.ProductFeatureEditViewModel
@{
    ViewData["Title"] = Model.FeatureId.HasValue ? "Ozellik Duzenle" : "Yeni Ozellik";
    ViewData["FormCode"] = "PRODUCT_FEATURE_EDIT";
    ViewData["BodyClass"] = "page-product-feature-edit";
    var editId = (int)(ViewData["ProductFeatureEditId"] ?? 0);
}

@section Styles {
<style>
    /* ── Viewport setup ───────────────────────────────────────────────── */
    .page-product-feature-edit .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-product-feature-edit .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important;
        margin: 0 !important; overflow: hidden !important;
    }
    .workspace-frame-body.page-product-feature-edit .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-product-feature-edit .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    /* ── Action bar ───────────────────────────────────────────────────── */
    .pfe-action-bar {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px; flex-shrink: 0;
        background: rgba(15,15,26,0.85); border-bottom: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    }
    body.app-theme-light .pfe-action-bar {
        background: rgba(248,250,252,0.92); border-bottom-color: #e2e8f0;
    }
    .pfe-action-bar .pfe-meta {
        margin-right: auto; font-size: 0.72rem; color: rgba(255,255,255,0.5); font-weight: 500;
    }
    body.app-theme-light .pfe-action-bar .pfe-meta { color: #94a3b8; }
    .pfe-action-bar .pfe-meta strong { color: rgba(255,255,255,0.75); font-weight: 700; }
    body.app-theme-light .pfe-action-bar .pfe-meta strong { color: #334155; }

    /* ── Buttons ──────────────────────────────────────────────────────── */
    .pfe-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 14px; border-radius: 8px; border: 1px solid;
        font-size: 0.78rem; font-weight: 600; cursor: pointer;
        transition: all 0.12s ease; background: transparent;
    }
    .pfe-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .pfe-btn--primary { background: #6366f1; border-color: #4f46e5; color: #fff; }
    .pfe-btn--primary:hover:not(:disabled) { background: #4f46e5; }
    .pfe-btn--secondary {
        background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.65);
    }
    body.app-theme-light .pfe-btn--secondary { background: #fff; border-color: #e2e8f0; color: #475569; }
    .pfe-btn--secondary:hover:not(:disabled) { background: rgba(255,255,255,0.1); color: #fff; }
    body.app-theme-light .pfe-btn--secondary:hover:not(:disabled) { background: #f1f5f9; color: #1e293b; }
    .pfe-btn--danger { background: rgba(239,68,68,0.08); border-color: rgba(239,68,68,0.25); color: #f87171; }
    .pfe-btn--danger:hover:not(:disabled) { background: rgba(239,68,68,0.18); }
    body.app-theme-light .pfe-btn--danger { color: #dc2626; }
    .pfe-btn--sm { padding: 5px 11px; font-size: 0.75rem; }

    /* ── Body layout ──────────────────────────────────────────────────── */
    .pfe-body {
        display: flex; flex: 1 1 auto; min-height: 0; overflow: hidden;
    }

    /* ── Sidenav ──────────────────────────────────────────────────────── */
    .pfe-sidenav {
        width: 192px; flex-shrink: 0;
        border-right: 1px solid rgba(255,255,255,0.07);
        background: rgba(255,255,255,0.02);
        display: flex; flex-direction: column;
        padding: 10px 0; overflow-y: auto;
    }
    body.app-theme-light .pfe-sidenav { background: #f8fafc; border-right-color: #e2e8f0; }
    .pfe-sidenav-label {
        font-size: 0.6rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.08em; color: rgba(255,255,255,0.4);
        padding: 10px 16px 5px; margin-top: 4px;
    }
    .pfe-sidenav-label:first-child { margin-top: 0; }
    body.app-theme-light .pfe-sidenav-label { color: #94a3b8; }
    .pfe-nav-btn {
        display: flex; align-items: center; gap: 8px;
        width: 100%; padding: 8px 16px;
        background: transparent; border: none;
        border-left: 3px solid transparent;
        color: rgba(255,255,255,0.65);
        font-size: 0.78rem; font-weight: 500; text-align: left;
        cursor: pointer; transition: all 0.15s; line-height: 1.35;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    body.app-theme-light .pfe-nav-btn { color: #64748b; }
    .pfe-nav-btn:hover { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.9); }
    body.app-theme-light .pfe-nav-btn:hover { background: rgba(15,23,42,0.04); color: #1e293b; }
    .pfe-nav-btn.is-active {
        border-left-color: #6366f1;
        background: rgba(99,102,241,0.09);
        color: #a5b4fc; font-weight: 600;
    }
    body.app-theme-light .pfe-nav-btn.is-active { background: rgba(99,102,241,0.07); color: #4f46e5; }
    .pfe-nav-dot {
        width: 6px; height: 6px; border-radius: 50%;
        background: currentColor; flex-shrink: 0; opacity: 0.5;
    }
    .pfe-nav-btn.is-active .pfe-nav-dot { opacity: 1; }
    .pfe-nav-count {
        margin-left: auto; padding: 1px 6px; border-radius: 999px;
        font-size: 0.6rem; font-weight: 700; font-family: monospace;
        background: rgba(99,102,241,0.12); color: #a5b4fc;
        border: 1px solid rgba(99,102,241,0.25); flex-shrink: 0;
    }
    body.app-theme-light .pfe-nav-count { background: rgba(99,102,241,0.08); color: #4f46e5; }

    /* ── Content area ─────────────────────────────────────────────────── */
    .pfe-content {
        flex: 1 1 auto; min-width: 0; overflow: hidden;
        padding: 20px 24px;
        display: flex; flex-direction: column;
    }
    body.app-theme-dark .pfe-content,
    html.dark .pfe-content {
        background: #0c0f1a;
        background-image: radial-gradient(at 20% 30%,rgba(99,102,241,0.12) 0px,transparent 50%),
                          radial-gradient(at 80% 20%,rgba(14,165,233,0.08) 0px,transparent 50%),
                          radial-gradient(at 50% 80%,rgba(168,85,247,0.08) 0px,transparent 50%);
    }
    body.app-theme-light .pfe-content { background: #f8fafc; }

    /* ── Section fill ────────────────────────────────────────────────── */
    .pfe-section {
        flex: 1 1 auto; min-height: 0;
        display: flex; flex-direction: column;
    }
    /* Genel ve Stoklar bölümleri kendileri scroll eder (içerik azsa boşluk bırakmaz) */
    .pfe-section[data-section="general"],
    .pfe-section[data-section="stocks"] {
        overflow-y: auto;
    }

    /* ── Glass card ───────────────────────────────────────────────────── */
    .pfe-card {
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 14px; padding: 22px;
        backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
        margin-bottom: 0;
        flex: 1 1 auto; min-height: 0;
        display: flex; flex-direction: column;
    }
    body.app-theme-light .pfe-card {
        background: rgba(255,255,255,0.85); border-color: rgba(15,23,42,0.08);
        box-shadow: 0 2px 6px rgba(15,23,42,0.04);
    }
    .pfe-card-title {
        font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.06em; color: rgba(255,255,255,0.6);
        margin: 0 0 16px 0; display: flex; align-items: center; gap: 8px;
        flex-shrink: 0;
    }
    body.app-theme-light .pfe-card-title { color: #64748b; }
    .pfe-card-title::before {
        content: ''; width: 6px; height: 6px; border-radius: 50%; background: #6366f1; flex-shrink: 0;
    }
    .pfe-card-hdr {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 16px; gap: 12px;
    }
    .pfe-card-hdr .pfe-card-title { margin-bottom: 0; }

    /* ── Flash animations ─────────────────────────────────────────────── */
    @@keyframes pfeSuccessFlash {
        0%   { border-color: rgba(255,255,255,0.1); box-shadow: none; }
        25%  { border-color: #10b981; box-shadow: 0 0 0 4px rgba(16,185,129,0.25),0 0 32px rgba(16,185,129,0.35); }
        50%  { border-color: #34d399; box-shadow: 0 0 0 6px rgba(16,185,129,0.15),0 0 40px rgba(16,185,129,0.4); }
        75%  { border-color: #10b981; box-shadow: 0 0 0 4px rgba(16,185,129,0.1),0 0 24px rgba(16,185,129,0.2); }
        100% { border-color: rgba(255,255,255,0.1); box-shadow: none; }
    }
    .pfe-action-bar.is-success { animation: pfeSuccessFlash 1.4s ease-out; }

    /* ── Form grid & fields ───────────────────────────────────────────── */
    .pfe-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .pfe-field { display: flex; flex-direction: column; gap: 5px; }
    .pfe-field--full { grid-column: 1 / -1; }
    .pfe-field label {
        font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.65);
        letter-spacing: 0.02em;
    }
    body.app-theme-light .pfe-field label { color: #64748b; }
    .pfe-input, .pfe-select {
        padding: 9px 12px; border-radius: 9px;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.85); font-size: 0.85rem;
        transition: border-color 0.15s, background 0.15s;
        width: 100%;
    }
    body.app-theme-light .pfe-input, body.app-theme-light .pfe-select {
        background: #fff; border-color: #e2e8f0; color: #1e293b;
    }
    .pfe-input:focus, .pfe-select:focus {
        outline: none; border-color: #6366f1;
        background: rgba(255,255,255,0.06);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }
    body.app-theme-light .pfe-input:focus, body.app-theme-light .pfe-select:focus { background: #fff; }
    .pfe-input::placeholder { color: rgba(255,255,255,0.35); }
    body.app-theme-light .pfe-input::placeholder { color: #94a3b8; }
    .pfe-input[readonly] { opacity: 0.65; cursor: default; }
    .pfe-select option { background: #0d1117; color: rgba(255,255,255,0.85); }
    body.app-theme-light .pfe-select option { background: #fff; color: #1e293b; }
    .pfe-select {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23ffffff80' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat; background-position: right 0.5rem center; background-size: 14px 14px;
        padding-right: 28px; appearance: none;
    }
    body.app-theme-light .pfe-select {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%2364748b' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e");
        background-repeat: no-repeat; background-position: right 0.5rem center; background-size: 14px 14px;
    }
    .pfe-toggle {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 12px; border-radius: 9px; cursor: pointer; user-select: none;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
        font-size: 0.82rem; color: rgba(255,255,255,0.7); font-weight: 500;
    }
    body.app-theme-light .pfe-toggle { background: #fff; border-color: #e2e8f0; color: #475569; }
    .pfe-toggle input { margin: 0; accent-color: #6366f1; }

    /* ── Value grid table ─────────────────────────────────────────────── */
    .pfe-val-empty {
        padding: 28px 16px; text-align: center;
        font-size: 0.82rem; color: rgba(255,255,255,0.3); font-style: italic;
        border: 1.5px dashed rgba(255,255,255,0.1); border-radius: 10px;
    }
    body.app-theme-light .pfe-val-empty { color: #94a3b8; border-color: #e2e8f0; }

    /* Kolon sabiti — header + her satir ayni template'i kullanir */
    .pfe-val-thead,
    .pfe-val-row {
        display: grid;
        grid-template-columns: 36px 1fr 96px 1.8fr 64px;
        align-items: center;
    }
    /* Tablo kap */
    .pfe-val-table {
        border-radius: 10px; overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
    }
    body.app-theme-light .pfe-val-table { border-color: #e2e8f0; }
    /* Baslik satiri */
    .pfe-val-thead {
        background: rgba(0,0,0,0.22);
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    body.app-theme-light .pfe-val-thead { background: #f1f5f9; border-bottom-color: #e2e8f0; }
    .pfe-val-th {
        padding: 7px 10px;
        font-size: 0.6rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.07em; color: rgba(255,255,255,0.38);
    }
    body.app-theme-light .pfe-val-th { color: #94a3b8; }
    /* Veri satiri */
    .pfe-val-row {
        border-bottom: 1px solid rgba(255,255,255,0.05);
        transition: background 0.1s;
    }
    .pfe-val-row:last-child { border-bottom: none; }
    .pfe-val-row:hover { background: rgba(20,184,166,0.06); }
    body.app-theme-light .pfe-val-row { border-bottom-color: #f1f5f9; }
    body.app-theme-light .pfe-val-row:hover { background: #f0fdfa; }
    /* Hucre */
    .pfe-val-td {
        padding: 9px 10px;
        font-size: 0.82rem; color: rgba(255,255,255,0.78);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    body.app-theme-light .pfe-val-td { color: #334155; }
    /* # sutunu */
    .pfe-val-td--idx { display: flex; align-items: center; justify-content: center; padding: 0; }
    .pfe-val-row__idx {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; border-radius: 999px;
        background: rgba(20,184,166,0.12); border: 1px solid rgba(20,184,166,0.28);
        color: #5eead4; font-size: 0.62rem; font-weight: 700;
    }
    body.app-theme-light .pfe-val-row__idx { color: #0d9488; }
    /* Deger sutunu */
    .pfe-val-td--val { font-weight: 600; color: rgba(255,255,255,0.88); }
    body.app-theme-light .pfe-val-td--val { color: #1e293b; }
    .pfe-val-td--numeric { text-align: right; font-variant-numeric: tabular-nums; letter-spacing: 0.01em; }
    .pfe-val-th.pfe-val-th--numeric { text-align: right; }
    /* Olcu birimi sutunu */
    .pfe-val-uom-badge {
        display: inline-block; padding: 2px 8px; border-radius: 5px;
        font-size: 0.68rem; font-weight: 700; letter-spacing: 0.03em;
        background: rgba(20,184,166,0.12); border: 1px solid rgba(20,184,166,0.28);
        color: #5eead4;
    }
    body.app-theme-light .pfe-val-uom-badge { background: #ccfbf1; border-color: #99f6e4; color: #0d9488; }
    /* Aciklama sutunu */
    .pfe-val-td--acik { color: rgba(255,255,255,0.4); font-size: 0.78rem; }
    body.app-theme-light .pfe-val-td--acik { color: #94a3b8; }
    /* Sil sutunu */
    .pfe-val-td--del { display: flex; align-items: center; justify-content: center; padding: 0; }
    .pfe-val-row__del {
        display: inline-flex; align-items: center; justify-content: center;
        width: 26px; height: 26px; border-radius: 6px; cursor: pointer;
        background: transparent; border: 1px solid transparent;
        color: rgba(255,255,255,0.18); transition: all 0.12s;
    }
    .pfe-val-row:hover .pfe-val-row__del { color: rgba(255,255,255,0.38); border-color: rgba(255,255,255,0.08); }
    .pfe-val-row__del:hover { background: rgba(239,68,68,0.18)!important; border-color: rgba(239,68,68,0.45)!important; color: #fca5a5!important; }
    body.app-theme-light .pfe-val-row__del { color: #d1d5db; }
    body.app-theme-light .pfe-val-row:hover .pfe-val-row__del { border-color: #e2e8f0; color: #94a3b8; }
    body.app-theme-light .pfe-val-row__del:hover { background: #fee2e2!important; border-color: #fca5a5!important; color: #dc2626!important; }

    /* Satır düzenleme — row edit modu */
    .pfe-val-row.is-editing { background: rgba(20,184,166,0.08); }
    body.app-theme-light .pfe-val-row.is-editing { background: #f0fdfa; }
    .pfe-val-row.is-editing .pfe-val-td--val,
    .pfe-val-row.is-editing .pfe-val-td--acik { padding: 5px 6px; }
    .pfe-val-edit-input {
        width: 100%; padding: 5px 8px; border-radius: 6px; font-size: 0.82rem;
        background: rgba(255,255,255,0.07); border: 1px solid rgba(20,184,166,0.4);
        color: rgba(255,255,255,0.9); outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .pfe-val-edit-input:focus { border-color: rgba(20,184,166,0.7); box-shadow: 0 0 0 3px rgba(20,184,166,0.12); }
    body.app-theme-light .pfe-val-edit-input { background: #fff; border-color: #14b8a6; color: #1e293b; }
    body.app-theme-light .pfe-val-edit-input:focus { box-shadow: 0 0 0 3px rgba(20,184,166,0.12); }
    .pfe-val-td--del-edit { display: flex; align-items: center; gap: 4px; justify-content: center; padding: 0; }
    .pfe-val-row__save {
        display: inline-flex; align-items: center; justify-content: center;
        width: 26px; height: 26px; border-radius: 6px; cursor: pointer;
        background: rgba(20,184,166,0.15); border: 1px solid rgba(20,184,166,0.4);
        color: #5eead4; transition: all 0.12s;
    }
    .pfe-val-row__save:hover { background: rgba(20,184,166,0.3); border-color: rgba(20,184,166,0.7); }
    body.app-theme-light .pfe-val-row__save { color: #0d9488; }

    /* ── Add row ──────────────────────────────────────────────────────── */
    .pfe-add-row {
        display: flex; gap: 8px; align-items: center;
        padding: 10px 14px; border-radius: 10px;
        background: rgba(20,184,166,0.04); border: 1px dashed rgba(20,184,166,0.2);
        transition: border-color 0.15s, background 0.15s;
        flex-shrink: 0;
    }
    .pfe-add-row:focus-within { border-color: rgba(20,184,166,0.5); background: rgba(20,184,166,0.08); }
    body.app-theme-light .pfe-add-row { background: #f0fdfa; border-color: #99f6e4; }
    body.app-theme-light .pfe-add-row:focus-within { border-color: #14b8a6; }
    .pfe-add-row__fields {
        flex: 1; min-width: 0; display: grid;
        grid-template-columns: 1fr 1.6fr; gap: 8px;
    }
    .pfe-add-row__fields .pfe-input { width: 100%; }

    /* Duplicate shake — kirmizi titresim */
    @@keyframes pfeInputShake {
        0%,100% { transform: translateX(0); }
        15%,45%,75% { transform: translateX(-5px); }
        30%,60%,90% { transform: translateX(5px); }
    }
    .pfe-input.is-duplicate {
        border-color: #ef4444 !important;
        background: rgba(239,68,68,0.08) !important;
        box-shadow: 0 0 0 3px rgba(239,68,68,0.18) !important;
        animation: pfeInputShake 0.4s cubic-bezier(0.36,0.07,0.19,0.97);
    }

    /* ── Stock rows ───────────────────────────────────────────────────── */
    .pfe-stock-empty {
        padding: 28px 16px; text-align: center;
        font-size: 0.82rem; color: rgba(255,255,255,0.3); font-style: italic;
        border: 1.5px dashed rgba(255,255,255,0.1); border-radius: 10px;
    }
    body.app-theme-light .pfe-stock-empty { color: #94a3b8; border-color: #e2e8f0; }
    .pfe-stock-rows { display: flex; flex-direction: column; gap: 8px; }
    .pfe-stock-row {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 14px; border-radius: 10px;
        background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.07);
        transition: all 0.15s;
    }
    .pfe-stock-row:hover {
        background: rgba(99,102,241,0.06); border-color: rgba(99,102,241,0.2);
    }
    body.app-theme-light .pfe-stock-row { background: #f8fafc; border-color: #e2e8f0; }
    body.app-theme-light .pfe-stock-row:hover { background: #f1f5f9; border-color: #c7d2fe; }
    .pfe-stock-row__idx {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 26px; height: 26px; border-radius: 999px;
        background: rgba(99,102,241,0.14); border: 1px solid rgba(99,102,241,0.3);
        color: #a5b4fc; font-size: 0.68rem; font-weight: 700; flex-shrink: 0;
    }
    body.app-theme-light .pfe-stock-row__idx { color: #4f46e5; }
    .pfe-stock-row__code {
        font-family: ui-monospace, monospace; font-size: 0.8rem; font-weight: 700;
        color: #a5b4fc; min-width: 90px; flex-shrink: 0;
