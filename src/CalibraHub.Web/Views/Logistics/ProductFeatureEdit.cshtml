        background-image:
            radial-gradient(at 12% 8%, rgba(99,102,241,0.18) 0px, transparent 50%),
            radial-gradient(at 88% 12%, rgba(14,165,233,0.12) 0px, transparent 50%),
            radial-gradient(at 50% 100%, rgba(168,85,247,0.12) 0px, transparent 50%);
    }

    /* ── Toast bildirimleri ───────────────────────────────────────────── */
    #pfeToastContainer {
        position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
        z-index: 99999; display: flex; flex-direction: column;
        align-items: center; gap: 10px; pointer-events: none;
    }
    .pfe-toast {
        display: flex; align-items: flex-start; gap: 12px;
        padding: 14px 20px; border-radius: 14px; min-width: 260px; max-width: 480px;
        font-size: 0.83rem; font-weight: 500; line-height: 1.45;
        box-shadow: 0 8px 40px rgba(0,0,0,0.45), 0 2px 8px rgba(0,0,0,0.3);
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        pointer-events: auto; cursor: default;
        animation: pfeToastIn 0.22s cubic-bezier(0.34,1.56,0.64,1) forwards;
        border: 1px solid;
    }
    .pfe-toast.is-leaving {
        animation: pfeToastOut 0.18s ease-in forwards;
    }
    .pfe-toast--ok {
        background: rgba(16,185,129,0.15);
        border-color: rgba(16,185,129,0.35);
        color: #6ee7b7;
    }
    .pfe-toast--err {
        background: rgba(239,68,68,0.15);
        border-color: rgba(239,68,68,0.35);
        color: #fca5a5;
    }
    body.app-theme-light .pfe-toast--ok {
        background: rgba(16,185,129,0.12); border-color: rgba(16,185,129,0.3); color: #059669;
    }
    body.app-theme-light .pfe-toast--err {
        background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.3); color: #dc2626;
    }
    .pfe-toast__icon {
        flex-shrink: 0; width: 18px; height: 18px; margin-top: 1px;
    }
    .pfe-toast__text { flex: 1; word-break: break-word; }
    .pfe-toast__close {
        flex-shrink: 0; background: none; border: none; cursor: pointer;
        padding: 0; line-height: 1; opacity: 0.6; transition: opacity .12s;
        color: inherit; font-size: 1rem; margin-left: 4px;
    }
    .pfe-toast__close:hover { opacity: 1; }
    @@keyframes pfeToastIn {
        from { opacity: 0; transform: scale(0.82); }
        to   { opacity: 1; transform: scale(1); }
    }
    @@keyframes pfeToastOut {
        from { opacity: 1; transform: scale(1); }
        to   { opacity: 0; transform: scale(0.82); }
    }
</style>
}

