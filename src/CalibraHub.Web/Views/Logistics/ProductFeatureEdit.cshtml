        <div class="pfe-confirm-box" onclick="event.stopPropagation()">
            <div class="pfe-confirm-ico">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </div>
            <h3 class="pfe-confirm-title" id="pfeValueConfirmTitle">Degeri Sil</h3>
            <p class="pfe-confirm-text" id="pfeValueConfirmText">Bu deger kalici olarak silinecek.</p>
            <div class="pfe-confirm-btns">
                <button type="button" class="pfe-confirm-btn pfe-confirm-btn--ghost" id="pfeValueConfirmCancel">Iptal</button>
                <button type="button" class="pfe-confirm-btn pfe-confirm-btn--danger" id="pfeValueConfirmOk">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                    <span id="pfeValueConfirmOkLabel">Evet, Sil</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Ozellik Sil Onay Modali -->
    <div id="pfeDeleteModal" class="pfe-del-backdrop" style="display:none;" onclick="pfeDeleteCancel()">
        <div class="pfe-del-box" onclick="event.stopPropagation()">
            <div class="pfe-del-ico">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                    <line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/>
                </svg>
            </div>
            <h3 class="pfe-del-title">Ozelligi Sil</h3>
            <p class="pfe-del-text">Bu islem geri alinamaz. Devam etmek istiyor musunuz?</p>
            <span class="pfe-del-code" id="pfeDeleteModalCode"></span>
            <div class="pfe-del-btns">
                <button type="button" class="pfe-del-cancel" id="pfeDelCancelBtn" onclick="pfeDeleteCancel()">Iptal</button>
                <button type="button" class="pfe-del-confirm" id="pfeDelConfirmBtn" onclick="pfeDeleteConfirm()">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                    </svg>
                    Evet, Sil
                </button>
            </div>
        </div>
    </div>

</section>

@section Scripts {
<script>
(function () {
    var editId = @editId;
    var currentId = editId > 0 ? editId : 0;
    var linkedStocks = [];
    var currentUom = '';
    var currentDataType = 'Text';

    function $(id) { return document.getElementById(id); }

    function escHtml(str) {
        return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Sidenav ──────────────────────────────────────────────────────────
    (function initSideNav() {
        var navBtns  = document.querySelectorAll('.pfe-nav-btn[data-nav-section]');
        var sections = document.querySelectorAll('.pfe-section[data-section]');

        function activate(sectionId) {
            navBtns.forEach(function (btn) {
                btn.classList.toggle('is-active', btn.dataset.navSection === sectionId);
            });
            sections.forEach(function (sec) {
                sec.style.display = sec.dataset.section === sectionId ? '' : 'none';
            });
        }

        navBtns.forEach(function (btn) {
            btn.addEventListener('click', function () { activate(btn.dataset.navSection); });
        });

        activate('general');
    })();

    // ── Toast mesaj sistemi ────────────────────────────────────────────────
    function showMsg(text, ok) {
        var container = document.getElementById('pfeToastContainer');
        if (!container) return;

        var toast = document.createElement('div');
        toast.className = 'pfe-toast ' + (ok ? 'pfe-toast--ok' : 'pfe-toast--err');

        // İkon
        var iconSvg = ok
            ? '<svg class="pfe-toast__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>'
            : '<svg class="pfe-toast__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';

        toast.innerHTML = iconSvg
            + '<span class="pfe-toast__text">' + text.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span>'
            + '<button class="pfe-toast__close" title="Kapat">✕</button>';

        container.appendChild(toast);

        // Kapat butonu
        toast.querySelector('.pfe-toast__close').addEventListener('click', function () {
            dismissToast(toast);
        });

        // Otomatik kapat
        var timer = setTimeout(function () { dismissToast(toast); }, ok ? 3000 : 5000);

        // Üzerine gelince süreyi durdur
        toast.addEventListener('mouseenter', function () { clearTimeout(timer); });
        toast.addEventListener('mouseleave', function () {
            timer = setTimeout(function () { dismissToast(toast); }, 1500);
        });
    }

    function dismissToast(toast) {
        if (!toast || toast.classList.contains('is-leaving')) return;
        toast.classList.add('is-leaving');
        setTimeout(function () { if (toast.parentNode) toast.parentNode.removeChild(toast); }, 180);
    }

    function flashSuccess() {
        var bar = $('pfeActionBar');
        if (!bar) return;
        bar.classList.remove('is-success');
        void bar.offsetWidth;
        bar.classList.add('is-success');
        setTimeout(function () { bar.classList.remove('is-success'); }, 1600);
    }

    // ── Badge & count helpers ─────────────────────────────────────────────
    function updateNavCount(elemId, count) {
        var el = $(elemId);
        if (!el) return;
        el.textContent = count;
        el.style.display = count > 0 ? '' : 'none';
    }

    function pfeUpdateValuesCount() {
        var count = $('pfeValuesList') ? $('pfeValuesList').querySelectorAll('.pfe-val-row').length : 0;
        updateNavCount('pfeNavValuesCount', count);
    }

    function pfeUpdateStocksCount() {
        updateNavCount('pfeNavStocksCount', linkedStocks.length);
    }

    // ── Stocks list render ────────────────────────────────────────────────
    function renderStocksList(stocks) {
        linkedStocks = Array.isArray(stocks) ? stocks.slice() : [];
        var list = $('pfeStockList');
        if (!list) return;
        list.innerHTML = '';

        if (linkedStocks.length === 0) {
            list.innerHTML = '<div class="pfe-stock-empty">Henuz bagli stok yok. <strong>Stok Ekle / Duzenle</strong> butonunu kullanin.</div>';
        } else {
            var rows = document.createElement('div');
            rows.className = 'pfe-stock-rows';
            linkedStocks.forEach(function (s, idx) {
                var row = document.createElement('div');
                row.className = 'pfe-stock-row';
                row.innerHTML =
                    '<span class="pfe-stock-row__idx">' + (idx + 1) + '</span>' +
                    '<span class="pfe-stock-row__code">' + escHtml(s.code) + '</span>' +
                    '<span class="pfe-stock-row__name">' + escHtml(s.name || s.code) + '</span>';
                var unlinkBtn = document.createElement('button');
                unlinkBtn.type = 'button';
                unlinkBtn.className = 'pfe-stock-row__unlink';
                unlinkBtn.innerHTML =
                    '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>' +
                    ' Kaldir';
                unlinkBtn.addEventListener('click', function () { pfeUnlinkStock(s.code); });
                row.appendChild(unlinkBtn);
                rows.appendChild(row);
            });
            list.appendChild(rows);
        }

        pfeUpdateStocksCount();
        pfeUpdateGuideCount();
    }

    window.pfeUnlinkStock = function (code) {
        var stock = linkedStocks.find(function (s) { return s.code === code; });
        var label = stock ? (stock.name ? stock.code + ' — ' + stock.name : stock.code) : code;
        pfeConfirm('"' + label + '" stok baglantisi kaldirilacak. Devam edilsin mi?', { title: 'Stok Kaldir', okLabel: 'Evet, Kaldir' }).then(function (ok) {
            if (!ok) return;
            linkedStocks = linkedStocks.filter(function (s) { return s.code !== code; });
            renderStocksList(linkedStocks);
            // Guide aciksa yenile
            var guide = $('pfeStockGuideBackdrop');
            if (guide && guide.style.display !== 'none') {
                pfeRenderGuide(($('pfeGuideSearch') || {}).value || '');
            }
            saveStocks();
        });
    };

    // ── Value rows (grid tablo) ───────────────────────────────────────────
    function buildValueRow(value, idx) {
        var row = document.createElement('div');
        row.className = 'pfe-val-row';
        row.dataset.valueId = value.id;

        // # hücresi
        var tdIdx = document.createElement('div');
        tdIdx.className = 'pfe-val-td pfe-val-td--idx';
        var idxEl = document.createElement('span');
        idxEl.className = 'pfe-val-row__idx';
        idxEl.textContent = idx;
        tdIdx.appendChild(idxEl);

        // Değer hücresi
        var isNumeric = (currentDataType === 'Numeric');
        var tdVal = document.createElement('div');
        tdVal.className = 'pfe-val-td pfe-val-td--val' + (isNumeric ? ' pfe-val-td--numeric' : '');
        tdVal.textContent = value.description || value.value || value.code || '-';

        // Ölçü birimi hücresi
        var tdUom = document.createElement('div');
        tdUom.className = 'pfe-val-td pfe-val-td--uom';
        if (currentUom) {
            var badge = document.createElement('span');
            badge.className = 'pfe-val-uom-badge';
            badge.textContent = currentUom;
            tdUom.appendChild(badge);
        }

        // Açıklama hücresi
        var tdAcik = document.createElement('div');
        tdAcik.className = 'pfe-val-td pfe-val-td--acik';
        tdAcik.textContent = value.aciklama || '—';

        // Aksiyon hücresi: kalem + çöp
        var tdDel = document.createElement('div');
        tdDel.className = 'pfe-val-td pfe-val-td--del';

        var editBtn = document.createElement('button');
        editBtn.type = 'button'; editBtn.className = 'pfe-val-row__del'; editBtn.title = 'Duzenle';
        editBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>';
        editBtn.addEventListener('click', function () { pfeEnterEditMode(row, value); });

        var del = document.createElement('button');
        del.type = 'button'; del.className = 'pfe-val-row__del'; del.title = 'Sil';
        del.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>';
        del.addEventListener('click', function () { pfeDeleteValue(value.id, row); });

        tdDel.appendChild(editBtn);
        tdDel.appendChild(del);

        row.appendChild(tdIdx);
        row.appendChild(tdVal);
        row.appendChild(tdUom);
        row.appendChild(tdAcik);
        row.appendChild(tdDel);
        return row;
    }

    // ── Satır inline düzenleme ────────────────────────────────────────────
    function pfeEnterEditMode(row, value) {
        if (row.classList.contains('is-editing')) return;
        row.classList.add('is-editing');

        var tdVal  = row.querySelector('.pfe-val-td--val');
        var tdAcik = row.querySelector('.pfe-val-td--acik');
        var tdDel  = row.querySelector('.pfe-val-td--del');

        var origVal  = tdVal.textContent;
        var origAcik = tdAcik.textContent === '—' ? '' : tdAcik.textContent;

        // Değer inputu
        var inpVal = document.createElement('input');
        inpVal.type = 'text'; inpVal.className = 'pfe-val-edit-input';
        inpVal.value = origVal;
        tdVal.textContent = '';
        tdVal.appendChild(inpVal);

        // Açıklama inputu
        var inpAcik = document.createElement('input');
        inpAcik.type = 'text'; inpAcik.className = 'pfe-val-edit-input';
        inpAcik.value = origAcik;
        inpAcik.placeholder = 'Aciklama...';
        tdAcik.textContent = '';
        tdAcik.appendChild(inpAcik);

        // Kaydet butonu, İptal butonu
        tdDel.innerHTML = '';
        tdDel.className = 'pfe-val-td pfe-val-td--del-edit';

        var saveBtn = document.createElement('button');
        saveBtn.type = 'button'; saveBtn.className = 'pfe-val-row__save'; saveBtn.title = 'Kaydet';
        saveBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

        var cancelBtn = document.createElement('button');
        cancelBtn.type = 'button'; cancelBtn.className = 'pfe-val-row__del'; cancelBtn.title = 'Iptal';
        cancelBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>';

        function cancelEdit() {
            row.classList.remove('is-editing');
            tdVal.textContent = origVal;
            tdAcik.textContent = origAcik || '—';
            tdDel.className = 'pfe-val-td pfe-val-td--del';
            tdDel.innerHTML = '';
            var editBtn2 = document.createElement('button');
            editBtn2.type = 'button'; editBtn2.className = 'pfe-val-row__del'; editBtn2.title = 'Duzenle';
            editBtn2.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>';
            editBtn2.addEventListener('click', function () { pfeEnterEditMode(row, { id: value.id, description: origVal, aciklama: origAcik }); });
            var del2 = document.createElement('button');
            del2.type = 'button'; del2.className = 'pfe-val-row__del'; del2.title = 'Sil';
            del2.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>';
            del2.addEventListener('click', function () { pfeDeleteValue(value.id, row); });
            tdDel.appendChild(editBtn2);
            tdDel.appendChild(del2);
        }

        saveBtn.addEventListener('click', function () {
            var newVal  = inpVal.value.trim();
            var newAcik = inpAcik.value.trim();
            if (!newVal) { inpVal.focus(); return; }
            pfeSaveValueEdit(value.id, newVal, newAcik, row, tdVal, tdAcik, tdDel, cancelEdit);
        });
        cancelBtn.addEventListener('click', cancelEdit);
        inpVal.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); saveBtn.click(); }
            if (e.key === 'Escape') cancelEdit();
        });
        inpAcik.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); saveBtn.click(); }
            if (e.key === 'Escape') cancelEdit();
        });

        tdDel.appendChild(saveBtn);
        tdDel.appendChild(cancelBtn);
        inpVal.focus(); inpVal.select();
    }

    function pfeSaveValueEdit(id, newVal, newAcik, row, tdVal, tdAcik, tdDel, cancelEdit) {
        fetch('/Logistics/UpdateProductValueJson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ id: id, description: newVal, aciklama: newAcik || null }),
        })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.success) { showMsg('Guncelleme hatasi: ' + (data.message || 'Bilinmeyen'), false); return; }
                row.classList.remove('is-editing');
                tdVal.textContent = newVal;
                tdAcik.textContent = newAcik || '—';
                tdDel.className = 'pfe-val-td pfe-val-td--del';
                tdDel.innerHTML = '';
                var editBtn3 = document.createElement('button');
                editBtn3.type = 'button'; editBtn3.className = 'pfe-val-row__del'; editBtn3.title = 'Duzenle';
                editBtn3.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>';
                editBtn3.addEventListener('click', function () { pfeEnterEditMode(row, { id: id, description: newVal, aciklama: newAcik }); });
                var del3 = document.createElement('button');
                del3.type = 'button'; del3.className = 'pfe-val-row__del'; del3.title = 'Sil';
                del3.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>';
                del3.addEventListener('click', function () { pfeDeleteValue(id, row); });
                tdDel.appendChild(editBtn3);
                tdDel.appendChild(del3);
            })
            .catch(function (e) { showMsg('Guncelleme hatasi: ' + e.message, false); });
    }

    function buildValuesHeader() {
        var thead = document.createElement('div');
        thead.className = 'pfe-val-thead';
        var isNumeric = (currentDataType === 'Numeric');
        ['#', 'Deger', 'Olcu Birimi', 'Aciklama', ''].forEach(function (label, i) {
            var th = document.createElement('div');
            th.className = 'pfe-val-th' + (i === 1 && isNumeric ? ' pfe-val-th--numeric' : '');
            th.textContent = label;
            thead.appendChild(th);
        });
        return thead;
    }

    function sortValues(values) {
        if (!Array.isArray(values) || values.length === 0) return values;
        var dt = currentDataType || ($('pfeDataType') ? normalizeDataType($('pfeDataType').value) : 'Text');
        var sorted = values.slice();
        if (dt === 'Numeric') {
            sorted.sort(function (a, b) {
                var na = parseFloat((a.value || a.description || '').replace(',', '.'));
                var nb = parseFloat((b.value || b.description || '').replace(',', '.'));
                if (isNaN(na) && isNaN(nb)) return 0;
                if (isNaN(na)) return 1;
                if (isNaN(nb)) return -1;
                return na - nb;
            });
        } else if (dt === 'Date') {
            sorted.sort(function (a, b) {
                var da = new Date(a.value || a.description || '');
                var db = new Date(b.value || b.description || '');
                return da - db;
            });
        } else {
            sorted.sort(function (a, b) {
                var sa = (a.description || a.value || '').toLowerCase();
                var sb = (b.description || b.value || '').toLowerCase();
                return sa < sb ? -1 : sa > sb ? 1 : 0;
            });
        }
        return sorted;
    }

    function renderValuesList(values) {
        var vl = $('pfeValuesList');
        vl.innerHTML = '';

        if (Array.isArray(values) && values.length > 0) {
            var sorted = sortValues(values);
            var table = document.createElement('div');
            table.className = 'pfe-val-table';
            table.appendChild(buildValuesHeader());
            sorted.forEach(function (v, i) { table.appendChild(buildValueRow(v, i + 1)); });
            vl.appendChild(table);
        } else {
            var empty = document.createElement('div');
            empty.className = 'pfe-val-empty';
            empty.textContent = 'Henuz deger tanimlanmamis';
            vl.appendChild(empty);
        }
        pfeUpdateValuesCount();
    }

    // Sildikten sonra index numaralarini guncelle
    function reindexValueRows() {
        var rows = $('pfeValuesList') ? $('pfeValuesList').querySelectorAll('.pfe-val-row') : [];
        rows.forEach(function (r, i) {
            var idx = r.querySelector('.pfe-val-row__idx');
            if (idx) idx.textContent = i + 1;
        });
        pfeUpdateValuesCount();
    }

    // ── DataType → input type senkronizasyonu ────────────────────────────
    function pfeUpdateValueInputType() {
        var dt    = $('pfeDataType').value;
        var input = $('pfeNewValueInput');
        if (!input) return;
        if (dt === 'Numeric') {
            input.type = 'number'; input.step = 'any';
            input.placeholder = 'Yeni sayisal deger...';
        } else if (dt === 'Date') {
            input.type = 'date'; input.placeholder = '';
        } else {
            input.type = 'text'; input.placeholder = 'Yeni deger...';
        }
    }

    // DB legacy enum normalize
    function normalizeDataType(raw) {
        if (!raw) return 'Text';
        var u = String(raw).trim().toUpperCase();
        if (u === 'NUMBER' || u === 'NUMERIC') return 'Numeric';
        if (u === 'DATE') return 'Date';
        return raw;
    }

    // ── Populate ──────────────────────────────────────────────────────────
    function populate(data) {
        currentUom = data.unitOfMeasure || '';
        currentDataType = normalizeDataType(data.dataType);
        $('pfeCode').value = data.code || '';
        $('pfeName').value = data.name || '';
        $('pfeDataType').value = normalizeDataType(data.dataType);
        var hasValues = Array.isArray(data.values) && data.values.length > 0;
        $('pfeDataType').disabled = hasValues;
        $('pfeDataType').title = hasValues ? 'Deger girilen ozelligin veri tipi degistirilemez' : '';
        $('pfeUnitOfMeasure').value = data.unitOfMeasure || '';
        $('pfeIsActive').checked = data.isActive !== false;

        var meta = $('pfeMeta');
        if (meta) meta.innerHTML =
            'ID: <strong>' + (data.id || '-') + '</strong>'
            + ' &nbsp;·&nbsp; <strong>' + escHtml(data.code || 'Yeni') + '</strong>'
            + ' &nbsp;·&nbsp; ' + escHtml(data.name || '');
        $('pfeBtnDelete').style.display = 'inline-flex';
        if ($('pfeDeleteModalCode')) $('pfeDeleteModalCode').textContent = data.code || data.name || '';

        renderValuesList(data.values);

        if (Array.isArray(data.linkedStocks)) {
            renderStocksList(data.linkedStocks);
        } else if (Array.isArray(data.stockCodes)) {
            renderStocksList(data.stockCodes.map(function (c) { return { code: c, name: c }; }));
        } else {
            renderStocksList([]);
        }
        pfeUpdateValueInputType();
    }

    // ── Load ──────────────────────────────────────────────────────────────
    async function load() {
        if (currentId <= 0) return;
        try {
            var resp = await fetch('/Logistics/GetProductFeature?id=' + currentId, { credentials: 'same-origin' });
            if (!resp.ok) throw new Error('HTTP ' + resp.status);
            var data = await resp.json();
            populate(data);
        } catch (e) {
            console.error('[PFE] Load error:', e);
            showMsg('Yuklenirken hata: ' + e.message, false);
        }
    }

    // ── Save ──────────────────────────────────────────────────────────────
    window.pfeSave = async function () {
        var nameEl = $('pfeName');
        var name   = nameEl.value.trim();
        if (!name) {
            showMsg('Ozellik adi bos olamaz', false);
            nameEl.focus();
            return;
        }

        var payload = {
            id:            currentId > 0 ? currentId : null,
            name:          name,
            dataType:      $('pfeDataType').value,
            unitOfMeasure: $('pfeUnitOfMeasure').value.trim() || null,
            isActive:      $('pfeIsActive').checked,
        };

        try {
            var resp = await fetch('/Logistics/SaveProductFeatureJson', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify(payload),
            });
            var data = await resp.json();
            if (!data.success) { showMsg('Hata: ' + (data.message || 'Bilinmeyen'), false); return; }
            if (data.id && data.id > 0) {
                currentId = data.id;
                if (editId <= 0) {
                    var newUrl = '/Logistics/ProductFeatureEdit?id=' + data.id;
                    if (location.search.indexOf('workspace=1') !== -1) newUrl += '&workspace=1';
                    history.replaceState({}, '', newUrl);
                }
            }
            flashSuccess();
            await load();
        } catch (e) { showMsg('Kayit hatasi: ' + e.message, false); }
    };

    // ── Delete Feature ────────────────────────────────────────────────────
    window.pfeDeleteFeature = function () {
        if (currentId <= 0) return;
        $('pfeDeleteModal').style.display = '';
    };
    window.pfeDeleteCancel = function () {
        $('pfeDeleteModal').style.display = 'none';
    };
    window.pfeDeleteConfirm = async function () {
        var cancelBtn  = $('pfeDelCancelBtn');
        var confirmBtn = $('pfeDelConfirmBtn');
        if (cancelBtn)  cancelBtn.disabled  = true;
        if (confirmBtn) confirmBtn.disabled = true;
        try {
            var resp = await fetch('/Logistics/DeleteProductFeatureJson?id=' + currentId, {
                method: 'POST', credentials: 'same-origin',
            });
            var data = await resp.json();
            if (data.success) {
                pfeBackToList();
            } else {
                showMsg('Silme hatasi: ' + (data.message || 'Bilinmeyen'), false);
                $('pfeDeleteModal').style.display = 'none';
            }
        } catch (e) {
            showMsg('Silme hatasi: ' + e.message, false);
            $('pfeDeleteModal').style.display = 'none';
        } finally {
            if (cancelBtn)  cancelBtn.disabled  = false;
            if (confirmBtn) confirmBtn.disabled = false;
        }
    };

    // ── Back ──────────────────────────────────────────────────────────────
    window.pfeBackToList = function () {
        var url = '/Logistics/ProductConfiguration';
        if (location.search.indexOf('workspace=1') !== -1) url += '?workspace=1';
        location.replace(url);
    };

    // ── Value: Add ────────────────────────────────────────────────────────
    window.pfeAddValue = function () {
        if (currentId <= 0) { showMsg('Once ozelligi kaydedin', false); return; }
        var input    = $('pfeNewValueInput');
        var acikEl   = $('pfeNewAciklamaInput');
        var rawValue = (input.value || '').trim();
        var aciklama = acikEl ? (acikEl.value || '').trim() : '';
        if (!rawValue) { input.focus(); return; }

        var existingRows = $('pfeValuesList').querySelectorAll('.pfe-val-row');
        for (var i = 0; i < existingRows.length; i++) {
            var rowText = (existingRows[i].querySelector('.pfe-val-row__text') || {}).textContent || '';
            if (rowText.trim().toLowerCase() === rawValue.toLowerCase()) {
                input.classList.remove('is-duplicate');
                void input.offsetWidth; // reflow — animasyonu yeniden tetikle
                input.classList.add('is-duplicate');
                input.select();
                setTimeout(function () { input.classList.remove('is-duplicate'); }, 600);
                return;
            }
        }

        var dataType = $('pfeDataType').value;
        var payload  = { featureId: currentId, description: rawValue, aciklama: aciklama || null };

        if (dataType === 'Numeric') {
            var num = parseFloat(rawValue.replace(',', '.'));
            if (isNaN(num)) { showMsg('Gecerli sayisal deger girin', false); input.focus(); return; }
            payload.numericValue = num;
        } else if (dataType === 'Date') {
            payload.dateValue = rawValue;
        } else {
            payload.textValue = rawValue;
        }

        fetch('/Logistics/SaveProductValueJson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload),
        })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.success) { showMsg('Hata: ' + (data.message || 'Bilinmeyen'), false); return; }
                var vl    = $('pfeValuesList');
                var empty = vl.querySelector('.pfe-val-empty');
                if (empty) empty.remove();
                var table = vl.querySelector('.pfe-val-table');
                if (!table) {
                    table = document.createElement('div');
                    table.className = 'pfe-val-table';
                    table.appendChild(buildValuesHeader());
                    vl.appendChild(table);
                }
                var newIdx = table.querySelectorAll('.pfe-val-row').length + 1;
                table.appendChild(buildValueRow({ id: data.id, description: rawValue, aciklama: aciklama || null }, newIdx));
                input.value = '';
                if (acikEl) acikEl.value = '';
                input.focus();
                pfeUpdateValuesCount();
            })
            .catch(function (e) { showMsg('Kayit hatasi: ' + e.message, false); });
    };

    // ── Value: Delete ─────────────────────────────────────────────────────
    window.pfeDeleteValue = function (valueId, chipEl) {
        if (!valueId) return;
        pfeConfirm('Bu deger kalici olarak silinecek. Devam edilsin mi?').then(function (ok) {
            if (!ok) return;
            fetch('/Logistics/DeleteProductValueJson?id=' + valueId, {
                method: 'POST', credentials: 'same-origin',
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data.success) { showMsg('Silme hatasi: ' + (data.message || 'Bilinmeyen'), false); return; }
                    chipEl.remove();
                    var vl = $('pfeValuesList');
                    var table = vl.querySelector('.pfe-val-table');
                    if (table && table.querySelectorAll('.pfe-val-row').length === 0) {
                        table.remove();
                        var empty = document.createElement('div');
                        empty.className = 'pfe-val-empty';
                        empty.textContent = 'Henuz deger tanimlanmamis';
                        vl.appendChild(empty);
                    } else {
                        reindexValueRows();
                    }
                })
                .catch(function (e) { showMsg('Silme hatasi: ' + e.message, false); });
        });
    };

    function pfeConfirm(text, options) {
        var opts = options || {};
        return new Promise(function (resolve) {
            var backdrop = $('pfeValueConfirmBackdrop');
            $('pfeValueConfirmTitle').textContent   = opts.title   || 'Degeri Sil';
            $('pfeValueConfirmText').textContent    = text;
            $('pfeValueConfirmOkLabel').textContent = opts.okLabel || 'Evet, Sil';
            backdrop.style.display = '';
            function close(result) {
                backdrop.style.display = 'none';
                $('pfeValueConfirmCancel').removeEventListener('click', onCancel);
                $('pfeValueConfirmOk').removeEventListener('click', onOk);
                backdrop.removeEventListener('click', onBack);
                // Varsayılanlara sıfırla
                $('pfeValueConfirmTitle').textContent   = 'Degeri Sil';
                $('pfeValueConfirmOkLabel').textContent = 'Evet, Sil';
                resolve(result);
            }
            function onCancel() { close(false); }
            function onOk()     { close(true); }
            function onBack(e)  { if (e.target === backdrop) close(false); }
            $('pfeValueConfirmCancel').addEventListener('click', onCancel);
            $('pfeValueConfirmOk').addEventListener('click', onOk);
            backdrop.addEventListener('click', onBack);
        });
    }

    // ── Stock guide ───────────────────────────────────────────────────────
    var allStocksCache    = null;
    var guideSearchTimer  = null;

    window.pfeOpenStockGuide = function () {
        if (currentId <= 0) { showMsg('Once ozelligi kaydedin', false); return; }
        $('pfeStockGuideBackdrop').style.display = '';
        $('pfeGuideSearch').value = '';
        pfeLoadGuide();
        setTimeout(function () { $('pfeGuideSearch').focus(); }, 80);
    };

    window.pfeCloseStockGuide = function () {
        $('pfeStockGuideBackdrop').style.display = 'none';
    };

    function pfeLoadGuide() {
        var body = $('pfeGuideBody');
        body.innerHTML = '<div class="pfe-guide-loading">Yukleniyor...</div>';
        fetch('/Logistics/StockLookup?q=', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (results) { allStocksCache = results || []; pfeRenderGuide(''); })
            .catch(function (e) { body.innerHTML = '<div class="pfe-guide-empty">Hata: ' + escHtml(e.message) + '</div>'; });
    }

    function pfeRenderGuide(query) {
        var body   = $('pfeGuideBody');
        body.innerHTML = '';
        var q      = (query || '').trim().toLowerCase();
        var stocks = (allStocksCache || []);
        if (q) {
            stocks = stocks.filter(function (s) {
                return (s.code || '').toLowerCase().indexOf(q) !== -1 ||
                       (s.name || '').toLowerCase().indexOf(q) !== -1;
            });
        }

        var linked   = [];
        var unlinked = [];
        stocks.forEach(function (s) {
            var isLinked = linkedStocks.some(function (ls) { return ls.code === s.code; });
            if (isLinked) linked.push(s); else unlinked.push(s);
        });

        if (stocks.length === 0) {
            body.innerHTML = '<div class="pfe-guide-empty">Eslesme bulunamadi</div>';
            pfeUpdateGuideCount(); return;
        }

        if (linked.length > 0) {
            var sep1 = document.createElement('div');
            sep1.className = 'pfe-guide-sep';
            sep1.textContent = 'Bagli stoklar (' + linked.length + ')';
            body.appendChild(sep1);
            linked.forEach(function (s) { body.appendChild(pfeGuideRow(s, true)); });
        }
        if (unlinked.length > 0) {
            var sep2 = document.createElement('div');
            sep2.className = 'pfe-guide-sep';
            sep2.textContent = 'Diger stoklar (' + unlinked.length + ')';
            body.appendChild(sep2);
            unlinked.forEach(function (s) { body.appendChild(pfeGuideRow(s, false)); });
        }
        pfeUpdateGuideCount();
    }

    function pfeGuideRow(stock, isLinked) {
        var row = document.createElement('div');
        row.className = 'pfe-guide-row';

        var code  = document.createElement('span'); code.className  = 'pfe-guide-row__code'; code.textContent  = stock.code;
        var name  = document.createElement('span'); name.className  = 'pfe-guide-row__name'; name.textContent  = stock.name || '';
        var sw    = document.createElement('label'); sw.className   = 'pfe-guide-row__switch';
        var cb    = document.createElement('input'); cb.type = 'checkbox'; cb.checked = isLinked;
        var track = document.createElement('span'); track.className = 'pfe-switch-track';
        sw.appendChild(cb); sw.appendChild(track);

        cb.addEventListener('change', function () { pfeToggleStock(stock, cb.checked); });
        row.addEventListener('click', function (e) {
            if (e.target === cb || e.target === track) return;
            cb.checked = !cb.checked; pfeToggleStock(stock, cb.checked);
        });

        row.appendChild(code); row.appendChild(name); row.appendChild(sw);
        return row;
    }

    function pfeToggleStock(stock, checked) {
        if (checked) {
            if (!linkedStocks.some(function (s) { return s.code === stock.code; })) {
                linkedStocks.push({ code: stock.code, name: stock.name || stock.code });
            }
        } else {
            linkedStocks = linkedStocks.filter(function (s) { return s.code !== stock.code; });
        }
        pfeUpdateGuideCount();
        renderStocksList(linkedStocks);
        saveStocks();
    }

    function pfeUpdateGuideCount() {
        var el = $('pfeGuideCount');
        if (el) el.textContent = linkedStocks.length + ' stok bagli';
    }

    function saveStocks(onSuccess, onError) {
        fetch('/Logistics/SaveProductFeatureStocksJson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ featureId: currentId, stockCodes: linkedStocks.map(function (s) { return s.code; }) }),
        })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (!data.success) { showMsg('Hata: ' + (data.message || 'Bilinmeyen'), false); if (onError) onError(); return; }
                if (onSuccess) onSuccess();
            })
            .catch(function (e) { showMsg('Kayit hatasi: ' + e.message, false); if (onError) onError(); });
    }

    // ── Init ──────────────────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        var dtSelect = $('pfeDataType');
        if (dtSelect) dtSelect.addEventListener('change', pfeUpdateValueInputType);
        pfeUpdateValueInputType();

        var guideSearch = $('pfeGuideSearch');
        if (guideSearch) {
            guideSearch.addEventListener('input', function () {
                if (guideSearchTimer) clearTimeout(guideSearchTimer);
                guideSearchTimer = setTimeout(function () { pfeRenderGuide(guideSearch.value); }, 180);
            });
        }

        // ESC ile modalleri kapat
        document.addEventListener('keydown', function (e) {
            if (e.key !== 'Escape') return;
            if ($('pfeStockGuideBackdrop').style.display !== 'none') { pfeCloseStockGuide(); return; }
            if ($('pfeDeleteModal').style.display !== 'none') { pfeDeleteCancel(); }
        });
    });

    if (currentId > 0) load();
})();
</script>
}
