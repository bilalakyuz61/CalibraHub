    // ── Ek alanlar renderer'ini mount et (WidgetMas/WidgetTra) ──
    // Workspace frame'de (_Layout bundle yuklemez) dinamik bundle yukleme gerekir.
    (function initDynRenderer() {
        var el = document.getElementById('mceDynamicWidgets');
        if (!el) return;

        function doMount() {
            if (!window.CalibraHub || !window.CalibraHub.mountDynamicWidgetRenderer) {
                console.warn('[MCE] mountDynamicWidgetRenderer bulunamadi');
                return;
            }
            try {
                window._mceDynRenderer = window.CalibraHub.mountDynamicWidgetRenderer(el, {
                    formCode: el.getAttribute('data-form-code') || 'ITEMS',
                    recordId: el.getAttribute('data-record-id') || '',
                    classPrefix: 'mce',
                    containerId: 'mceDynamicWidgetsCard'
                });
            } catch (e) { console.warn('[MCE] mountDynamicWidgetRenderer hatasi:', e); }
        }

        if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
            // Bundle zaten yuklu (React Shell modunda calisiyor)
            doMount();
        } else {
            // Workspace frame — bundle'i dinamik yukle
            var cssUrl = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
            var jsUrl  = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';

            // CSS (yoksa ekle)
            if (!document.querySelector('link[data-mce-bundle]')) {
                var link = document.createElement('link');
                link.rel = 'stylesheet'; link.href = cssUrl;
                link.setAttribute('data-mce-bundle', '1');
                document.head.appendChild(link);
            }

            // JS
            if (!document.querySelector('script[data-mce-bundle]')) {
                var script = document.createElement('script');
                script.src = jsUrl;
                script.setAttribute('data-mce-bundle', '1');
                script.onload = function() { setTimeout(doMount, 0); };
                script.onerror = function() { console.error('[MCE] Bundle yuklenemedi'); };
                document.head.appendChild(script);
            }
        }
    })();

    // ── Ölçü Birimleri — load / save ───────────────────────────────
    var _unitLoaded = false;
    var _availableUnits = [];

    function mceUnitPopulateSelects() {
        var opts = '<option value="">Seciniz</option>';
        _availableUnits.forEach(function(u) {
            opts += '<option value="' + u.unitCode + '">' + u.unitCode + ' — ' + u.unitName + '</option>';
