@{
    ViewData["Title"] = "Malzeme Karti Duzenle";
    ViewData["FormCode"] = "ITEM_EDIT";
    ViewData["BodyClass"] = "page-material-card-edit workspace-frame-body";
    var editId = (int)(ViewData["MaterialCardEditId"] ?? 0);
}

@section Styles {
<style>
    .page-material-card-edit .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-material-card-edit .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important;
        margin: 0 !important; overflow: hidden !important;
    }
    .workspace-frame-body.page-material-card-edit .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-material-card-edit .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    /* Form container — glassmorphism */
    .mce-shell {
        flex: 1 1 auto; min-height: 0; overflow-y: auto;
        padding: 24px; background: transparent;
    }
    body.app-theme-dark .mce-shell,
    html.dark .mce-shell { background: #0c0f1a; background-image: radial-gradient(at 20% 30%,rgba(99,102,241,0.12) 0px,transparent 50%),radial-gradient(at 80% 20%,rgba(14,165,233,0.08) 0px,transparent 50%),radial-gradient(at 50% 80%,rgba(168,85,247,0.08) 0px,transparent 50%); }
    body.app-theme-light .mce-shell { background: #f8fafc; }

    .mce-wrap { max-width: none; margin: 0; padding-top: 20px; }

    .mce-header { display: none; }

    /* Kimlik alani — action bar title slot'una JS ile enjekte edilir */
    .mce-bar-identity {
        display: flex; align-items: center; gap: 10px;
        margin-right: auto; min-width: 0;
    }
    .mce-bar-icon-box {
        width: 34px; height: 34px; border-radius: 9px; flex-shrink: 0;
        background: linear-gradient(135deg, #4f46e5 0%, #0891b2 100%);
        display: flex; align-items: center; justify-content: center;
        color: #fff;
        box-shadow: 0 2px 8px rgba(79,70,229,0.35);
    }
    .mce-bar-id-info {
        display: flex; flex-direction: column; gap: 1px; min-width: 0;
    }
    .mce-bar-id-code {
        font-size: 0.88rem; font-weight: 700;
        color: rgba(255,255,255,0.92); letter-spacing: 0.01em;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    body.app-theme-light .mce-bar-id-code { color: #1e293b; }
    .mce-bar-id-name {
        font-size: 0.72rem; font-weight: 400;
        color: rgba(255,255,255,0.42);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    body.app-theme-light .mce-bar-id-name { color: #94a3b8; }
    .mce-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 14px; border-radius: 10px; border: 1px solid transparent;
        font-size: 12.5px; font-weight: 600; cursor: pointer;
        transition: background-color .18s ease, border-color .18s ease, color .18s ease,
                    transform .15s ease, box-shadow .18s ease;
        white-space: nowrap;
    }
    .mce-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .mce-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 4px 10px rgba(15,23,42,0.06); }
    .mce-btn:active:not(:disabled) { transform: translateY(0); box-shadow: none; }
    /* Kaydet — indigo soft */
    .mce-btn--primary {
        background: #eef2ff; border-color: #c7d2fe; color: #4f46e5;
    }
    .mce-btn--primary:hover:not(:disabled) {
        background: #e0e7ff; border-color: #a5b4fc; color: #4338ca;
    }
    body.app-theme-dark .mce-btn--primary {
        background: rgba(99,102,241,0.18); border-color: rgba(129,140,248,0.35); color: #a5b4fc;
    }
    body.app-theme-dark .mce-btn--primary:hover:not(:disabled) {
        background: rgba(99,102,241,0.28); border-color: rgba(129,140,248,0.55); color: #c7d2fe;
    }
    /* Liste — slate (nötr) */
    .mce-btn--secondary {
        background: #f1f5f9; border-color: #e2e8f0; color: #475569;
    }
    .mce-btn--secondary:hover:not(:disabled) {
        background: #e2e8f0; border-color: #cbd5e1; color: #1e293b;
    }
    body.app-theme-dark .mce-btn--secondary {
        background: rgba(100,116,139,0.15); border-color: rgba(148,163,184,0.25); color: #cbd5e1;
    }
    body.app-theme-dark .mce-btn--secondary:hover:not(:disabled) {
        background: rgba(100,116,139,0.25); border-color: rgba(148,163,184,0.40); color: #f1f5f9;
    }
    /* Sil — red soft */
    .mce-btn--danger {
        background: #fef2f2; border-color: #fecaca; color: #dc2626;
    }
    .mce-btn--danger:hover:not(:disabled) {
        background: #fee2e2; border-color: #fca5a5; color: #b91c1c;
    }
    body.app-theme-dark .mce-btn--danger {
        background: rgba(220,38,38,0.18); border-color: rgba(248,113,113,0.35); color: #fca5a5;
    }
    body.app-theme-dark .mce-btn--danger:hover:not(:disabled) {
        background: rgba(220,38,38,0.28); border-color: rgba(248,113,113,0.55); color: #fecaca;
    }

    /* Card */
    .mce-card {
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.09);
        border-top-color: rgba(255,255,255,0.14);
        border-radius: 14px; padding: 22px;
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        margin-bottom: 16px;
        box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset;
    }
    body.app-theme-light .mce-card {
        background: rgba(255,255,255,0.9); border-color: rgba(15,23,42,0.08);
        border-top-color: rgba(15,23,42,0.12);
        box-shadow: 0 2px 6px rgba(15,23,42,0.04);
    }
    .mce-card-title {
        font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
        color: rgba(255,255,255,0.38);
        margin: 0 0 18px 0; display: flex; align-items: center; gap: 10px;
    }
    body.app-theme-light .mce-card-title { color: #94a3b8; }
    .mce-card-title::before {
        content: ''; width: 3px; height: 14px; border-radius: 2px; flex-shrink: 0;
        background: linear-gradient(180deg, #6366f1 0%, #06b6d4 100%);
    }
    .mce-card-title::after {
        content: ''; flex: 1; height: 1px;
        background: linear-gradient(90deg, rgba(255,255,255,0.08) 0%, transparent 100%);
    }
    body.app-theme-light .mce-card-title::after {
        background: linear-gradient(90deg, #e2e8f0 0%, transparent 100%);
    }

    /* Form fields — horizontal rows (label left, input right) */
    .mce-rows { display: flex; flex-direction: column; gap: 0; }
    .mce-row {
        display: flex; align-items: center; gap: 16px;
        padding: 9px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .mce-row:last-child { border-bottom: none; }
    body.app-theme-light .mce-row { border-bottom-color: rgba(15,23,42,0.06); }
    .mce-row > label:not(.mce-switch) {
        width: 140px; min-width: 140px; flex-shrink: 0;
        font-size: 0.75rem; font-weight: 600; color: rgba(255,255,255,0.55);
        letter-spacing: 0.02em; text-align: right; padding-right: 4px;
    }
    body.app-theme-light .mce-row > label:not(.mce-switch) { color: #64748b; }
    .mce-row .mce-input,
    .mce-row .mce-select { flex: 1 1 auto; min-width: 0; }

    /* Legacy grid (Razor template'leri icin — widget renderer artik wf-grid kullanir) */
    .mce-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .mce-grid--full > .mce-field { grid-column: 1 / -1; }

    /* NOT: .mce-input, .mce-select, .mce-textarea, .mce-field, .mce-multicheck,
       .mce-link-group, .mce-link-btn, .mce-lookup-group, .mce-required ve
       .mce-grid-2:has(.calibra-modern-wrap) hizalama kurallari widgetField.css'e
       (DynamicWidgetRenderer/widgetField.css) tasindi. Tek nokta tasarim sistemi
       ile Razor template'lerindeki sabit form alanlari ve React widget renderer
       ayni gorunume sahip. Burada sadece sayfa-bazli chrome (mce-card, mce-row,
       mce-grid-modal*) ve disabled-row legacy mantigi tutulmaktadir. */

    /* Ardisik aktiflik: onceki satir doldurulmadan sonraki pasif */
    .mce-row-disabled { opacity: 0.45; pointer-events: none; }
    .mce-row-disabled .mce-input,
    .mce-row-disabled .mce-select { cursor: not-allowed; }

    /* NOT: .mce-multicheck*, .mce-select option, .mce-link-group/.mce-link-btn,
       .mce-lookup-group widgetField.css'e tasindi — tek nokta tasarim sistemi.
       .mce-lookup-btn / .mce-lookup-clear / .mce-lookup-modal* legacy
       (FixedFieldLookupBridge / Razor inline lookup) icin burada kalir. */

    /* Lookup widget legacy buton + modal (FixedFieldLookupBridge / sabit alan) */
    .mce-lookup-btn, .mce-lookup-clear {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 34px; min-height: 34px; padding: 0 10px;
        border-radius: 10px; cursor: pointer; flex-shrink: 0;
        border: 1px solid rgba(99, 102, 241, 0.45);
        background: rgba(99, 102, 241, 0.14);
        color: #fcd34d;
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        transition: all 0.18s ease;
    }
    .mce-lookup-btn:hover:not(:disabled) {
        background: rgba(99, 102, 241, 0.25);
        border-color: rgba(99, 102, 241, 0.65);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    }
    .mce-lookup-btn:disabled { opacity: 0.35; cursor: not-allowed; }
    .mce-lookup-clear {
        background: rgba(244, 63, 94, 0.1);
        border-color: rgba(244, 63, 94, 0.4);
        color: #fda4af;
    }
    .mce-lookup-clear:hover {
        background: rgba(244, 63, 94, 0.2);
        border-color: rgba(244, 63, 94, 0.6);
    }
    body.app-theme-light .mce-lookup-btn { color: #4f46e5; }
    body.app-theme-light .mce-lookup-clear { color: #be123c; }

    /* Modal backdrop + container */
    .mce-lookup-modal-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0, 0, 0, 0.55); backdrop-filter: blur(4px);
        -webkit-backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        animation: mceLookupFadeIn 0.15s ease-out;
    }
    @@keyframes mceLookupFadeIn {
        from { opacity: 0; } to { opacity: 1; }
    }
    .mce-lookup-modal {
        width: min(900px, 95vw); max-height: 80vh;
        display: flex; flex-direction: column;
        background: var(--app-surface, #1a1f2e);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        box-shadow: 0 24px 72px rgba(0, 0, 0, 0.5);
        overflow: hidden;
        animation: mceLookupSlideIn 0.2s cubic-bezier(0.23, 1, 0.32, 1);
    }
    @@keyframes mceLookupSlideIn {
        from { transform: translateY(12px) scale(0.98); opacity: 0; }
        to { transform: translateY(0) scale(1); opacity: 1; }
    }
    body.app-theme-light .mce-lookup-modal { background: #ffffff; border-color: #e2e8f0; }
    .mce-lookup-modal header {
        padding: 14px 18px; display: flex; align-items: center; gap: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        color: #a5b4fc;
    }
    body.app-theme-light .mce-lookup-modal header {
        border-bottom-color: #e2e8f0; color: #6366f1;
    }
    .mce-lookup-modal header input {
        flex: 1; min-width: 0;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px; padding: 8px 12px;
        color: inherit; font-size: 0.85rem;
        outline: none;
    }
    .mce-lookup-modal header input:focus {
        border-color: rgba(99, 102, 241, 0.5);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
    }
    body.app-theme-light .mce-lookup-modal header input {
        background: #f8fafc; border-color: #e2e8f0; color: #1e293b;
    }
    .mce-lookup-close {
        background: transparent; border: none; color: inherit;
        cursor: pointer; padding: 6px; border-radius: 6px;
        display: inline-flex; align-items: center; justify-content: center;
        transition: background 0.15s;
    }
    .mce-lookup-close:hover { background: rgba(255, 255, 255, 0.08); }
    .mce-lookup-error {
        padding: 10px 18px; background: rgba(239, 68, 68, 0.1);
        color: #f87171; font-size: 0.75rem;
        border-bottom: 1px solid rgba(239, 68, 68, 0.2);
    }
    .mce-lookup-scroll {
        flex: 1; overflow-y: auto; min-height: 0;
    }
    .mce-lookup-table {
        width: 100%; border-collapse: collapse; font-size: 0.78rem;
    }
    .mce-lookup-table thead th {
        position: sticky; top: 0; z-index: 1;
        background: var(--app-surface, #1a1f2e);
        text-align: left; padding: 10px 14px;
        font-weight: 700;
        font-size: 0.78rem;
        color: #a5b4fc;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    body.app-theme-light .mce-lookup-table thead th {
        background: #f8fafc; color: #4f46e5; border-bottom-color: #e2e8f0;
    }
    .mce-lookup-table tbody tr {
        cursor: pointer;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        transition: background 0.12s;
    }
    .mce-lookup-table tbody tr:hover {
        background: rgba(99, 102, 241, 0.1);
    }
    body.app-theme-light .mce-lookup-table tbody tr { border-bottom-color: #f1f5f9; }
    body.app-theme-light .mce-lookup-table tbody tr:hover { background: rgba(99, 102, 241, 0.08); }
    .mce-lookup-table td {
        padding: 9px 14px; color: var(--app-text, #e2e8f0);
    }
    body.app-theme-light .mce-lookup-table td { color: #334155; }
    .mce-lookup-empty, .mce-lookup-sentinel {
        text-align: center; padding: 20px;
        color: rgba(255, 255, 255, 0.35); font-size: 0.75rem;
    }
    .mce-lookup-sentinel span { display: inline-flex; align-items: center; gap: 6px; }
    .mce-lookup-sentinel .spin {
        animation: mceLookupSpin 0.9s linear infinite;
    }
    @@keyframes mceLookupSpin {
        from { transform: rotate(0); } to { transform: rotate(360deg); }
    }
    .mce-lookup-footer {
        padding: 10px 18px; font-size: 0.7rem; opacity: 0.6;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }
    body.app-theme-light .mce-lookup-footer { border-top-color: #e2e8f0; }

    /* ── Kolon basligi (distinct filtre ikonu icerebilir) ── */
    .mce-lookup-th-inner { display: flex; align-items: center; gap: 6px; }
    .mce-lookup-th-label { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; }
    .mce-lookup-col-filter {
        background: transparent; border: none; cursor: pointer;
        padding: 3px; border-radius: 4px;
        color: rgba(255, 255, 255, 0.40);
        display: inline-flex; align-items: center; gap: 3px;
        transition: all .12s;
    }
    body.app-theme-light .mce-lookup-col-filter { color: rgba(0,0,0,0.35); }
    .mce-lookup-col-filter:hover {
        background: rgba(165, 180, 252, 0.14); color: #a5b4fc;
    }
    body.app-theme-light .mce-lookup-col-filter:hover {
        background: rgba(99, 102, 241, 0.12); color: #4f46e5;
    }
    .mce-lookup-col-filter--active {
        background: rgba(165, 180, 252, 0.18) !important; color: #a5b4fc !important;
    }
    body.app-theme-light .mce-lookup-col-filter--active {
        background: rgba(99, 102, 241, 0.18) !important; color: #4f46e5 !important;
    }
    .mce-lookup-col-filter-count {
        font-size: .58rem; font-weight: 700;
        background: #6366f1; color: #fff;
        padding: 1px 5px; border-radius: 999px;
        line-height: 1.1; min-width: 12px; text-align: center;
    }
    .mce-lookup-footer-filter { margin-left: auto; font-size: .68rem; font-weight: 600; color: #a5b4fc; }
    body.app-theme-light .mce-lookup-footer-filter { color: #6366f1; }

    /* ── Excel-tarzi kolon filtre acilir popover'i ──
       Modal ile ayni surface tonu (var(--app-surface)). */
    .mce-lookup-popover {
        background: var(--app-surface, #1a1f2e);
        border: 1px solid rgba(255, 255, 255, 0.10);
        border-radius: 12px;
        box-shadow: 0 22px 64px rgba(0, 0, 0, 0.65), 0 0 0 1px rgba(255, 255, 255, 0.02);
        overflow: hidden;
        display: flex; flex-direction: column;
        animation: mceLookupPopIn .12s ease-out;
        font-size: .75rem;
        color: rgba(255, 255, 255, 0.85);
    }
    body.app-theme-light .mce-lookup-popover {
        background: #ffffff; border-color: #e2e8f0; color: #334155;
        box-shadow: 0 22px 64px rgba(0, 0, 0, 0.20);
    }
    @@keyframes mceLookupPopIn {
        from { opacity: 0; transform: translateY(-4px) scale(0.98); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .mce-lookup-popover-title {
        display: flex; align-items: center; gap: 6px;
        padding: 9px 12px 8px;
        font-size: .68rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .55px;
        color: rgba(255, 255, 255, 0.82);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    body.app-theme-light .mce-lookup-popover-title {
        color: #475569; border-bottom-color: #e2e8f0;
    }
    .mce-lookup-popover-title svg { color: #a5b4fc; opacity: .9; }
    body.app-theme-light .mce-lookup-popover-title svg { color: #6366f1; }
    .mce-lookup-popover-search-wrap { position: relative; padding: 8px 10px 4px; }
    .mce-lookup-popover-search-ico {
        position: absolute; left: 18px; top: 50%; transform: translateY(-30%);
        opacity: .45; pointer-events: none;
    }
    .mce-lookup-popover-search {
        width: 100%; padding: 6px 8px 6px 26px;
        font-size: .72rem;
        border: 1px solid rgba(255, 255, 255, 0.10);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.04);
        color: inherit; outline: none;
    }
    body.app-theme-light .mce-lookup-popover-search {
        background: #f8fafc; border-color: #e2e8f0;
    }
    .mce-lookup-popover-search:focus {
        border-color: rgba(165, 180, 252, 0.55);
        box-shadow: 0 0 0 2px rgba(165, 180, 252, 0.15);
    }
    .mce-lookup-popover-actions {
        display: flex; align-items: center; gap: 6px;
        padding: 4px 12px 6px; font-size: .68rem;
    }
    .mce-lookup-popover-actions button {
        background: transparent; border: none; cursor: pointer;
        color: #a5b4fc; font-weight: 600;
        padding: 2px 4px; border-radius: 4px;
        transition: background .12s;
    }
    body.app-theme-light .mce-lookup-popover-actions button { color: #6366f1; }
    .mce-lookup-popover-actions button:hover { background: rgba(165, 180, 252, 0.12); }
    body.app-theme-light .mce-lookup-popover-actions button:hover { background: rgba(99, 102, 241, 0.12); }
    .mce-lookup-popover-divider { opacity: .35; }
    .mce-lookup-popover-count { margin-left: auto; opacity: .55; font-weight: 500; }
    .mce-lookup-popover-list {
        flex: 1; overflow-y: auto;
        max-height: 240px; padding: 2px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    body.app-theme-light .mce-lookup-popover-list { border-color: #e2e8f0; }
    .mce-lookup-popover-empty {
        text-align: center; padding: 16px 8px;
        font-size: .7rem; opacity: .55;
    }
    .mce-lookup-popover-row {
        display: flex; align-items: center; gap: 8px;
        padding: 5px 12px; cursor: pointer;
        transition: background .1s; font-size: .72rem;
        user-select: none;
    }
    .mce-lookup-popover-row:hover { background: rgba(165, 180, 252, 0.10); }
    body.app-theme-light .mce-lookup-popover-row:hover { background: rgba(99, 102, 241, 0.10); }
    .mce-lookup-popover-row--checked {
        background: rgba(165, 180, 252, 0.18);
        color: #c7d2fe;
        font-weight: 600;
    }
    body.app-theme-light .mce-lookup-popover-row--checked {
        background: rgba(99, 102, 241, 0.15);
        color: #4f46e5;
    }
    .mce-lookup-popover-row--checked:hover { background: rgba(165, 180, 252, 0.26) !important; }
    body.app-theme-light .mce-lookup-popover-row--checked:hover { background: rgba(99, 102, 241, 0.22) !important; }
    .mce-lookup-popover-checkbox {
        width: 14px; height: 14px;
        border: 1.5px solid rgba(255, 255, 255, 0.20);
        border-radius: 3px;
        background: rgba(255, 255, 255, 0.04);
        display: inline-flex; align-items: center; justify-content: center;
        flex-shrink: 0; color: #fff; transition: all .1s;
    }
    body.app-theme-light .mce-lookup-popover-checkbox {
        background: #ffffff; border-color: #cbd5e1;
    }
    .mce-lookup-popover-row--checked .mce-lookup-popover-checkbox {
        background: #6366f1; border-color: #6366f1;
    }
    .mce-lookup-popover-row-label {
        flex: 1; min-width: 0;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .mce-lookup-popover-footer {
        display: flex; gap: 6px; justify-content: flex-end;
        padding: 8px 10px;
    }
    .mce-lookup-popover-btn {
        padding: 5px 12px; border-radius: 6px; cursor: pointer;
        font-size: .72rem; font-weight: 600;
        border: 1px solid transparent; transition: all .12s;
    }
    .mce-lookup-popover-btn--ghost {
        background: transparent;
        border-color: rgba(255, 255, 255, 0.10);
        color: inherit;
    }
    body.app-theme-light .mce-lookup-popover-btn--ghost { border-color: #e2e8f0; }
    .mce-lookup-popover-btn--ghost:hover { background: rgba(255, 255, 255, 0.05); }
    body.app-theme-light .mce-lookup-popover-btn--ghost:hover { background: #f1f5f9; }
    .mce-lookup-popover-btn--primary {
        background: #6366f1; color: #fff; border-color: #6366f1;
    }
    .mce-lookup-popover-btn--primary:hover { background: #4f46e5; border-color: #4f46e5; }

    /* ══════════════════════════════════════════════════════════
       Grid (Alt Tablo / Master-Detail) widget — Faz E
       Card-based row list + portal modal with embedded renderer
       ══════════════════════════════════════════════════════════ */
    .mce-field--grid { grid-column: 1 / -1; }

    .mce-grid-wrap {
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 14px 16px 16px;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    body.app-theme-light .mce-grid-wrap {
        background: #ffffff; border-color: #e2e8f0;
    }
    .mce-grid-header {
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px; margin-bottom: 12px;
    }
    .mce-grid-header__title {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.85rem; font-weight: 700;
        color: #60a5fa;
    }
    body.app-theme-light .mce-grid-header__title { color: #2563eb; }
    .mce-grid-add-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 14px; min-height: 34px;
        border-radius: 10px; font-size: 0.78rem; font-weight: 600;
        color: #93c5fd;
        background: rgba(59, 130, 246, 0.14);
        border: 1px solid rgba(59, 130, 246, 0.45);
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        transition: all 0.18s ease; cursor: pointer;
    }
    .mce-grid-add-btn:hover:not(:disabled) {
        background: rgba(59, 130, 246, 0.25);
        border-color: rgba(59, 130, 246, 0.65);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(59, 130, 246, 0.22);
    }
    .mce-grid-add-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    body.app-theme-light .mce-grid-add-btn { color: #1d4ed8; }
    .mce-grid-error {
        padding: 10px 14px; margin-bottom: 10px;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.25);
        border-radius: 10px; color: #f87171; font-size: 0.75rem;
    }
    .mce-grid-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 6px; padding: 32px 16px;
        border-radius: 12px;
        border: 1.5px dashed rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.35); font-size: 0.82rem;
    }
    .mce-grid-empty small { font-size: 0.7rem; opacity: 0.7; }
    body.app-theme-light .mce-grid-empty {
        border-color: #e2e8f0; color: #94a3b8;
    }
    .mce-grid-rows { display: flex; flex-direction: column; gap: 10px; }
    .mce-grid-row {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center; gap: 14px;
        padding: 12px 14px;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.035);
        border: 1px solid rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        transition: all 0.18s ease;
    }
    .mce-grid-row:hover {
        background: rgba(59, 130, 246, 0.08);
        border-color: rgba(59, 130, 246, 0.25);
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(59, 130, 246, 0.08);
    }
    body.app-theme-light .mce-grid-row {
        background: #f8fafc; border-color: #e2e8f0;
    }
    body.app-theme-light .mce-grid-row:hover {
        background: #eff6ff; border-color: #bfdbfe;
    }
    .mce-grid-row__index {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 28px; height: 28px;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.16);
        border: 1px solid rgba(59, 130, 246, 0.35);
        color: #93c5fd; font-size: 0.7rem; font-weight: 700;
    }
    body.app-theme-light .mce-grid-row__index { color: #1d4ed8; }
    .mce-grid-row__cells {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 10px 18px; min-width: 0;
    }
    .mce-grid-row__cell { display: flex; flex-direction: column; min-width: 0; }
    .mce-grid-row__label {
        font-size: 0.72rem; font-weight: 600;
        color: rgba(255, 255, 255, 0.55); margin-bottom: 2px;
    }
    body.app-theme-light .mce-grid-row__label { color: #94a3b8; }
    .mce-grid-row__value {
        font-size: 0.82rem; color: rgba(255, 255, 255, 0.88);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    body.app-theme-light .mce-grid-row__value { color: #1e293b; }
    .mce-grid-row__actions {
        display: flex; gap: 6px; flex-shrink: 0;
    }
    .mce-grid-row__edit, .mce-grid-row__delete {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px;
        border-radius: 8px; cursor: pointer;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.55);
        transition: all 0.15s;
    }
    .mce-grid-row__edit:hover {
        background: rgba(59, 130, 246, 0.2);
        border-color: rgba(59, 130, 246, 0.5);
        color: #93c5fd;
    }
    .mce-grid-row__delete:hover {
        background: rgba(239, 68, 68, 0.18);
        border-color: rgba(239, 68, 68, 0.5);
        color: #fca5a5;
    }
    body.app-theme-light .mce-grid-row__edit,
    body.app-theme-light .mce-grid-row__delete {
        background: #fff; border-color: #e2e8f0; color: #64748b;
    }
    body.app-theme-light .mce-grid-row__edit:hover { color: #1d4ed8; }
    body.app-theme-light .mce-grid-row__delete:hover { color: #be123c; }

    /* Grid satir modal — portal edilmis, icine DynamicWidgetRenderer mount edilir */
    .mce-grid-modal-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        animation: mceGridFadeIn 0.15s ease-out;
    }
    @@keyframes mceGridFadeIn { from { opacity: 0; } to { opacity: 1; } }
    .mce-grid-modal {
        width: min(780px, 95vw); max-height: 85vh;
        display: flex; flex-direction: column;
        background: var(--app-surface, #1a1f2e);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        box-shadow: 0 24px 72px rgba(0, 0, 0, 0.55);
        overflow: hidden;
        animation: mceGridSlide 0.22s cubic-bezier(0.23, 1, 0.32, 1);
    }
    @@keyframes mceGridSlide {
        from { transform: translateY(16px) scale(0.97); opacity: 0; }
        to { transform: translateY(0) scale(1); opacity: 1; }
    }
    body.app-theme-light .mce-grid-modal {
        background: #ffffff; border-color: #e2e8f0;
    }
    .mce-grid-modal header {
        padding: 16px 20px; display: flex; align-items: center; gap: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        color: #60a5fa;
    }
    body.app-theme-light .mce-grid-modal header {
        border-bottom-color: #e2e8f0; color: #2563eb;
    }
    .mce-grid-modal__title {
        flex: 1; font-size: 0.88rem; font-weight: 700;
        color: rgba(255, 255, 255, 0.9);
    }
    body.app-theme-light .mce-grid-modal__title { color: #1e293b; }
    .mce-grid-modal__close {
        background: transparent; border: none; color: inherit;
        cursor: pointer; padding: 6px; border-radius: 6px;
        display: inline-flex; align-items: center; justify-content: center;
        transition: background 0.15s;
    }
    .mce-grid-modal__close:hover { background: rgba(255, 255, 255, 0.08); }
    .mce-grid-modal__body {
        flex: 1; overflow-y: auto; padding: 18px 20px;
    }
    .mce-grid-modal__footer {
        padding: 14px 20px; display: flex; justify-content: flex-end; gap: 10px;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }
    body.app-theme-light .mce-grid-modal__footer { border-top-color: #e2e8f0; }
    .mce-grid-modal__cancel, .mce-grid-modal__confirm {
        padding: 8px 18px; min-height: 36px;
        border-radius: 10px; cursor: pointer;
        font-size: 0.78rem; font-weight: 600;
        transition: all 0.15s;
    }
    .mce-grid-modal__cancel {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.65);
    }
    .mce-grid-modal__cancel:hover {
        background: rgba(255, 255, 255, 0.08);
    }
    body.app-theme-light .mce-grid-modal__cancel {
        background: #fff; border-color: #e2e8f0; color: #64748b;
    }
    body.app-theme-light .mce-grid-modal__cancel:hover { background: #f1f5f9; }
    .mce-grid-modal__confirm {
        background: rgba(59, 130, 246, 0.18);
        border: 1px solid rgba(59, 130, 246, 0.55);
        color: #93c5fd;
    }
    .mce-grid-modal__confirm:hover {
        background: rgba(59, 130, 246, 0.3);
        border-color: rgba(59, 130, 246, 0.75);
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(59, 130, 246, 0.25);
    }
    body.app-theme-light .mce-grid-modal__confirm { color: #1d4ed8; }

    /* ══════════════════════════════════════════════════════════
       Rule Engine (Faz G) — visibility / disabled / formula / error
       ══════════════════════════════════════════════════════════ */
    /* Readonly widget: formula sahibi veya disabledIf true olan. pointer-events
       capsul katmanda kapali, yari transparent + curzor not-allowed. */
    .mce-field--readonly .mce-field__readonly-wrap {
        opacity: 0.62;
        cursor: not-allowed;
        position: relative;
    }
    .mce-field--readonly .mce-field__readonly-wrap::after {
        content: '';
        position: absolute; inset: 0;
        border-radius: 8px;
        background: repeating-linear-gradient(
            45deg,
            rgba(255, 255, 255, 0.02),
            rgba(255, 255, 255, 0.02) 8px,
            rgba(255, 255, 255, 0.05) 8px,
            rgba(255, 255, 255, 0.05) 16px
        );
        pointer-events: none;
    }
    body.app-theme-light .mce-field--readonly .mce-field__readonly-wrap::after {
        background: repeating-linear-gradient(
            45deg,
            rgba(15, 23, 42, 0.015),
            rgba(15, 23, 42, 0.015) 8px,
            rgba(15, 23, 42, 0.04) 8px,
            rgba(15, 23, 42, 0.04) 16px
        );
    }
    /* Formula sahibi widget'larda label'in yanina kucuk bir 'f(x)' rozeti */
    .mce-field--formula .mce-label::after {
        content: ' ƒ';
        display: inline-block;
        margin-left: 4px;
        padding: 1px 6px;
        border-radius: 6px;
        font-size: 0.62rem;
        font-weight: 700;
        font-family: 'Courier New', monospace;
        color: #a78bfa;
        background: rgba(139, 92, 246, 0.14);
        border: 1px solid rgba(139, 92, 246, 0.32);
    }
    body.app-theme-light .mce-field--formula .mce-label::after {
        color: #7c3aed;
        background: rgba(139, 92, 246, 0.1);
    }

    /* Inline rule error — widget'in altinda kucuk kirmizi metin */
    .mce-rule-error {
        display: flex; align-items: flex-start; gap: 5px;
        margin-top: 4px; padding: 5px 9px;
        font-size: 0.7rem; line-height: 1.35;
        color: #fca5a5;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.22);
        border-radius: 8px;
    }
    .mce-rule-error::before {
        content: '⚠'; flex-shrink: 0;
        color: #f87171; font-size: 0.78rem;
    }
    body.app-theme-light .mce-rule-error {
        color: #b91c1c;
        background: rgba(239, 68, 68, 0.06);
        border-color: rgba(239, 68, 68, 0.28);
    }
    body.app-theme-light .mce-rule-error::before { color: #dc2626; }

    /* Mount-time cycle banner — renderer hic cizilmez, sadece bu banner gorunur */
    .mce-rule-cycle {
        padding: 18px 22px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.35);
        border-radius: 12px;
        color: #fca5a5;
    }
    .mce-rule-cycle strong { color: #f87171; }
    .mce-rule-cycle code {
        display: inline-block; margin-top: 4px;
        padding: 3px 9px;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 6px;
        font-family: 'Courier New', monospace;
    }
    body.app-theme-light .mce-rule-cycle {
        background: rgba(239, 68, 68, 0.07);
        border-color: rgba(239, 68, 68, 0.3);
        color: #991b1b;
    }
    body.app-theme-light .mce-rule-cycle strong { color: #dc2626; }
    body.app-theme-light .mce-rule-cycle code {
        background: #fef2f2;
        border-color: #fecaca;
        color: #7f1d1d;
    }

    /* DynamicWidgetRenderer — EK ALANLAR label + group title dark mode renkleri */
    .mce-label {
        font-size: 0.72rem; font-weight: 600;
        color: rgba(255,255,255,0.65);
        letter-spacing: 0.02em;
    }
    body.app-theme-light .mce-label { color: #64748b; }

    /* Ölçü Birimleri oran etiketi: "1 {birim} = [çarpan] {ana birim}" */
    .mce-unit-prefix, .mce-unit-suffix { font-variant-numeric: tabular-nums; }
    .mce-unit-suffix { min-width: 34px; }
    body.app-theme-light .mce-unit-prefix,
    body.app-theme-light .mce-unit-suffix { color: #475569 !important; }

    .mce-dyn-group__title {
        color: rgba(255,255,255,0.7);
    }
    body.app-theme-light .mce-dyn-group__title { color: #475569; }

    /* .mce-grid-2: React inline olarak 24-col grid + gap uygular (colSpan feature).
       !important yok — inline style'in calismasi icin. */
    .mce-grid-2 {
        gap: 14px;
    }

    /* Invalid field — kirmizi cerceve + shake */
    .mce-input.is-invalid,
    .mce-select.is-invalid,
    .mce-textarea.is-invalid {
        border-color: #ef4444 !important;
        background: rgba(239, 68, 68, 0.06) !important;
        box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.20) !important;
        animation: mceShake 0.45s cubic-bezier(.36,.07,.19,.97) both;
    }

    /* Coklu secim (multi-select) zorunlu alan hatasi */
    .mce-multicheck.is-invalid {
        outline: 2px solid #ef4444 !important;
        outline-offset: 2px;
        border-radius: 8px;
        background: rgba(239, 68, 68, 0.04) !important;
        animation: mceShake 0.45s cubic-bezier(.36,.07,.19,.97) both;
    }
    @@keyframes mceShake {
        10%, 90% { transform: translateX(-2px); }
        20%, 80% { transform: translateX(3px); }
        30%, 50%, 70% { transform: translateX(-4px); }
        40%, 60% { transform: translateX(4px); }
    }

    /* KITT animasyonu — pte-action-bar'ın absolute pseudo-element'ları için */
    .page-material-card-edit .pte-action-bar { position: relative; overflow: hidden; }
    /* Identity badge: aksiyon şeridinde ORTADA (absolute-center) */
    .page-material-card-edit .pte-action-bar__title {
        position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
        pointer-events: auto; white-space: nowrap;
    }

    /* Success flash — K.I.T.T. on tarayici tarzi yesil sweep (aksiyon seridi alti) */
    .pte-action-bar::before {
        content: ''; position: absolute;
        left: 0; right: 0; bottom: 0;
        height: 2px;
        pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,
            rgba(0, 60, 20, 0) 0%,
            rgba(10, 120, 40, .55) 50%,
            rgba(0, 60, 20, 0) 100%);
    }
    .pte-action-bar::after {
        content: ''; position: absolute;
        left: 0; bottom: -1px;
        width: 18%; height: 4px;
        pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,
            transparent 0%,
            rgba(34, 197, 94, .35) 18%,
            rgba(74, 255, 140, 1) 50%,
            rgba(34, 197, 94, .35) 82%,
            transparent 100%);
        box-shadow:
            0 0 10px 2px rgba(34, 197, 94, .95),
            0 0 22px 6px rgba(34, 197, 94, .55),
            0 0 40px 12px rgba(34, 197, 94, .22);
        border-radius: 50%;
    }
    .pte-action-bar.is-save-flash::before { animation: mceKittBg   1800ms ease-out forwards; }
    .pte-action-bar.is-save-flash::after  { animation: mceKittScan 1800ms cubic-bezier(.45,.05,.55,.95) forwards; }
    @@keyframes mceKittBg {
        0%, 100% { opacity: 0; }
        10%, 90% { opacity: 1; }
    }
    @@keyframes mceKittScan {
        0%   { opacity: 0; left: 0; }
        8%   { opacity: 1; }
        48%  { opacity: 1; left: 82%; }
        52%  { opacity: 1; left: 82%; }
        92%  { opacity: 1; left: 0; }
        100% { opacity: 0; left: 0; }
    }
    body.app-theme-light .mce-card.is-success {
        animation: mceSuccessFlashLight 1.4s ease-out;
    }
    @@keyframes mceSuccessFlashLight {
        0% {
            border-color: rgba(15,23,42,0.08);
            box-shadow: 0 2px 6px rgba(15,23,42,0.04);
        }
        20% {
            border-color: #10b981;
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.2), 0 0 32px rgba(16, 185, 129, 0.3);
        }
        50% {
            border-color: #059669;
            box-shadow: 0 0 0 6px rgba(16, 185, 129, 0.15), 0 0 40px rgba(16, 185, 129, 0.35);
        }
        80% {
            border-color: #10b981;
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1), 0 0 24px rgba(16, 185, 129, 0.2);
        }
        100% {
            border-color: rgba(15,23,42,0.08);
            box-shadow: 0 2px 6px rgba(15,23,42,0.04);
        }
    }

    .mce-toggle {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 12px; border-radius: 9px;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
        cursor: pointer; user-select: none;
    }
    body.app-theme-light .mce-toggle { background: #fff; border-color: #e2e8f0; }
    .mce-toggle input { margin: 0; }
    .mce-toggle span { font-size: 0.82rem; color: rgba(255,255,255,0.7); }
    body.app-theme-light .mce-toggle span { color: #475569; }

    /* Switch (iOS-style toggle) */
    .mce-switch {
        position: relative; width: 40px !important; height: 22px;
        display: inline-block; flex: 0 0 40px; flex-shrink: 0;
        max-width: 40px; min-width: 40px; cursor: pointer;
    }
    .mce-switch input { opacity: 0; width: 0; height: 0; position: absolute; }
    .mce-switch-track {
        position: absolute; inset: 0; border-radius: 22px; cursor: pointer;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.15); transition: .25s;
    }
    .mce-switch input:checked + .mce-switch-track { background: #10b981; border-color: #34d399; box-shadow: 0 0 0 3px rgba(16,185,129,0.15); }
    .mce-switch-track::before {
        content: ''; position: absolute; height: 16px; width: 16px;
        left: 2px; top: 2px; border-radius: 50%;
        background: rgba(255,255,255,0.6); transition: .25s;
    }
    .mce-switch input:checked + .mce-switch-track::before {
        transform: translateX(18px); background: #fff;
    }
    body.app-theme-light .mce-switch-track {
        background: #e2e8f0; border-color: #cbd5e1;
    }
    body.app-theme-light .mce-switch input:checked + .mce-switch-track {
        background: #10b981; border-color: #059669; box-shadow: 0 0 0 3px rgba(16,185,129,0.15);
    }
    /* Kombinasyonda kullaniliyor — kilitli switch (toggle off edilemez) */
    .mce-switch.is-locked { cursor: not-allowed; }
    .mce-switch.is-locked input:disabled + .mce-switch-track {
        background: rgba(251,191,36,0.20); border-color: rgba(251,191,36,0.45);
        box-shadow: 0 0 0 3px rgba(251,191,36,0.10);
    }
    .mce-switch.is-locked input:checked:disabled + .mce-switch-track {
        background: #d97706; border-color: #b45309; box-shadow: 0 0 0 3px rgba(217,119,6,0.20);
    }

    /* ── Deger Rehberi Modali (per-feature allowed values) ─────────────── */
    .mce-vguide-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
        display: none; align-items: center; justify-content: center;
        padding: 20px;
    }
    .mce-vguide-backdrop.is-open { display: flex; }
    .mce-vguide-modal {
        width: min(640px, 95vw); max-height: 80vh;
        display: flex; flex-direction: column;
        background: #1e293b;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 16px;
        box-shadow: 0 24px 72px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }
    body.app-theme-light .mce-vguide-modal {
        background: #ffffff; border-color: #e2e8f0;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.12);
    }
    .mce-vguide-header {
        padding: 14px 18px; display: flex; align-items: center; gap: 10px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        color: #a5b4fc; background: rgba(255, 255, 255, 0.02);
    }
    body.app-theme-light .mce-vguide-header {
        border-bottom-color: #e2e8f0; color: #6366f1; background: #f8fafc;
    }
    .mce-vguide-header__title {
        font-weight: 700; font-size: 0.9rem;
        color: #f1f5f9;
        flex: 1; min-width: 0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    body.app-theme-light .mce-vguide-header__title { color: #0f172a; }
    .mce-vguide-header__title strong { color: #a5b4fc; font-weight: 700; }
    body.app-theme-light .mce-vguide-header__title strong { color: #6366f1; }
    .mce-vguide-close {
        margin-left: auto; background: transparent; border: none;
        color: #94a3b8; cursor: pointer; padding: 6px; border-radius: 6px;
        font-size: 1.4rem; line-height: 1;
        display: inline-flex; align-items: center; justify-content: center;
        transition: background 0.15s, color 0.15s;
    }
    .mce-vguide-close:hover { background: rgba(255, 255, 255, 0.08); color: #f1f5f9; }
    body.app-theme-light .mce-vguide-close { color: #64748b; }
    body.app-theme-light .mce-vguide-close:hover { background: #f1f5f9; color: #1e293b; }
    .mce-vguide-search {
        padding: 10px 14px; display: flex; align-items: center; gap: 8px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    body.app-theme-light .mce-vguide-search { border-bottom-color: #e2e8f0; }
    .mce-vguide-search__ico { color: #64748b; flex-shrink: 0; }
    .mce-vguide-search__input {
        flex: 1; min-width: 0;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px; padding: 8px 12px;
        color: #f1f5f9; font-size: 0.85rem;
        outline: none;
    }
    .mce-vguide-search__input::placeholder { color: #64748b; }
    .mce-vguide-search__input:focus {
        border-color: rgba(99, 102, 241, 0.5);
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
    }
    body.app-theme-light .mce-vguide-search__input {
        background: #f8fafc; border-color: #e2e8f0; color: #0f172a;
    }
    .mce-vguide-body {
        flex: 1; overflow-y: auto; min-height: 200px;
        background: #1e293b;
    }
    body.app-theme-light .mce-vguide-body { background: #ffffff; }
    .mce-vguide-empty {
        padding: 24px; text-align: center;
        color: rgba(255, 255, 255, 0.45); font-size: 0.82rem; font-style: italic;
    }
    body.app-theme-light .mce-vguide-empty { color: #94a3b8; }
    .mce-vguide-sep {
        padding: 8px 18px;
        font-size: 0.7rem; font-weight: 700;
        letter-spacing: 0.04em; text-transform: uppercase;
        color: #94a3b8;
        background: rgba(255, 255, 255, 0.03);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    body.app-theme-light .mce-vguide-sep {
        color: #64748b; background: #f8fafc; border-bottom-color: #e2e8f0;
    }
    .mce-vguide-row {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 18px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        cursor: pointer; transition: background 0.12s;
        background: transparent;
    }
    .mce-vguide-row:hover { background: rgba(255, 255, 255, 0.05); }
    body.app-theme-light .mce-vguide-row { border-bottom-color: #f1f5f9; }
    body.app-theme-light .mce-vguide-row:hover { background: #f8fafc; }
    .mce-vguide-row__code {
        font-family: ui-monospace, monospace;
        font-weight: 700; font-size: 0.78rem;
        color: #a5b4fc; min-width: 80px;
    }
    body.app-theme-light .mce-vguide-row__code { color: #6366f1; }
    .mce-vguide-row__name {
        flex: 1; font-size: 0.82rem;
        color: rgba(255, 255, 255, 0.78);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    body.app-theme-light .mce-vguide-row__name { color: #475569; }
    .mce-vguide-footer {
        padding: 10px 14px;
        display: flex; align-items: center; justify-content: space-between;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.02);
    }
    body.app-theme-light .mce-vguide-footer {
        border-top-color: #e2e8f0; background: #f8fafc;
    }
    .mce-vguide-footer__count {
        font-size: 0.78rem; color: #94a3b8;
    }
    body.app-theme-light .mce-vguide-footer__count { color: #64748b; }
    .mce-vguide-footer__close {
        padding: 7px 18px; border-radius: 8px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.10);
        color: #f1f5f9;
        cursor: pointer; font-size: 0.8rem; font-weight: 600;
        transition: background 0.15s, border-color 0.15s;
    }
    .mce-vguide-footer__close:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.20);
    }
    body.app-theme-light .mce-vguide-footer__close {
        background: #ffffff; border-color: #cbd5e1; color: #1e293b;
    }
    body.app-theme-light .mce-vguide-footer__close:hover {
        background: #f1f5f9; border-color: #94a3b8;
    }

    /* Tetikleyici buton — yesil ton (mce-switch checked rengiyle uyumlu) */
    .mce-feat-values-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 10px; border-radius: 7px;
        font-size: 0.72rem; font-weight: 600;
        background: rgba(16, 185, 129, 0.10);
        border: 1px solid rgba(16, 185, 129, 0.30);
        color: #34d399; cursor: pointer; flex-shrink: 0;
        transition: background 0.15s, border-color 0.15s;
    }
    .mce-feat-values-btn:hover {
        background: rgba(16, 185, 129, 0.20);
        border-color: rgba(16, 185, 129, 0.55);
    }
    body.app-theme-light .mce-feat-values-btn {
        background: #d1fae5; border-color: #6ee7b7; color: #047857;
    }
    body.app-theme-light .mce-feat-values-btn:hover {
        background: #a7f3d0; border-color: #10b981;
    }

    /* Mesaj barı: formun üstünde yukarıdan aşağı belirir, formu itmez (absolute) */
    .mce-message {
        position: absolute; top: 12px; left: 50%;
        min-width: 260px; max-width: min(560px, 80%);
        padding: 10px 16px; border-radius: 10px;
        font-size: 0.82rem; font-weight: 500;
        z-index: 50; pointer-events: none;
        opacity: 0; transform: translate(-50%, -120%);
        transition: opacity .25s ease, transform .3s cubic-bezier(.34,1.56,.64,1);
        box-shadow: 0 8px 24px rgba(0,0,0,0.18);
        backdrop-filter: blur(8px);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .mce-message.ok, .mce-message.err {
        opacity: 1; transform: translate(-50%, 0);
        pointer-events: auto;
    }
    .mce-message.ok {
        background: rgba(16,185,129,0.92); color: #fff;
        border: 1px solid rgba(16,185,129,0.4);
    }
    .mce-message.err {
        background: rgba(239,68,68,0.92); color: #fff;
        border: 1px solid rgba(239,68,68,0.4);
    }
    body.app-theme-light .mce-message.ok { background: #10b981; }
    body.app-theme-light .mce-message.err { background: #ef4444; }
    /* .mce-content parent'ı relative olmalı — position: absolute referansı için */
    .mce-content { position: relative; }

    /* ── Katlanir dinamik alan gruplari ──────────────────────────── */
    .mce-group-details {
        border: 1px solid rgba(255,255,255,0.1); border-radius: 14px;
        background: rgba(255,255,255,0.06); margin-bottom: 14px;
        backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
        overflow: hidden;
    }
    body.app-theme-light .mce-group-details {
        background: rgba(255,255,255,0.8);
        border-color: rgba(15,23,42,0.08);
        box-shadow: 0 2px 6px rgba(15,23,42,0.04);
    }
    .mce-group-summary {
        padding: 14px 18px; cursor: pointer; user-select: none;
        display: flex; align-items: center; gap: 10px;
        font-size: 0.85rem; font-weight: 700;
        color: rgba(255,255,255,0.85);
        list-style: none;
    }
    body.app-theme-light .mce-group-summary { color: #64748b; }
    .mce-group-summary::-webkit-details-marker { display: none; }
    .mce-group-summary::before {
        content: ''; display: inline-block;
        width: 0; height: 0;
        border-left: 5px solid currentColor;
        border-top: 4px solid transparent;
        border-bottom: 4px solid transparent;
        transition: transform 0.2s ease;
        opacity: 0.6;
    }
    .mce-group-details[open] > .mce-group-summary::before {
        transform: rotate(90deg);
    }
    .mce-group-summary:hover { background: rgba(255,255,255,0.03); }
    body.app-theme-light .mce-group-summary:hover { background: rgba(15,23,42,0.02); }
    .mce-group-body {
        padding: 4px 18px 18px 18px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }
    body.app-theme-light .mce-group-body { border-top-color: rgba(15,23,42,0.06); }
    .mce-group-count {
        margin-left: auto; padding: 2px 8px; border-radius: 999px;
        font-size: 0.62rem; font-weight: 700; font-family: monospace;
        background: rgba(99,102,241,0.15); color: #a5b4fc;
        border: 1px solid rgba(99,102,241,0.3);
        text-transform: none; letter-spacing: 0;
    }
    body.app-theme-light .mce-group-count {
        background: rgba(99,102,241,0.1); color: #4f46e5;
        border-color: rgba(99,102,241,0.25);
    }

    /* ── Sidebar layout ──────────────────────────────────────────────── */
    .mce-body {
        display: flex; flex: 1 1 auto; min-height: 0; overflow: hidden;
    }
    .mce-sidenav {
        width: 216px; flex-shrink: 0;
        border-right: 1px solid rgba(255,255,255,0.06);
        background: rgba(6,8,18,0.55);
        display: flex; flex-direction: column;
        padding: 10px 0 14px; gap: 1px; overflow-y: auto;
    }
    body.app-theme-light .mce-sidenav {
        background: #f1f5f9; border-right-color: #e2e8f0;
    }

    .mce-sidenav-label {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.63rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
        color: rgba(255,255,255,0.28);
        padding: 10px 16px 5px; margin-top: 10px;
    }
    .mce-sidenav-label:first-child { margin-top: 0; }
    .mce-sidenav-label::after {
        content: ''; flex: 1; height: 1px;
        background: rgba(255,255,255,0.07);
    }
    body.app-theme-light .mce-sidenav-label { color: #94a3b8; }
    body.app-theme-light .mce-sidenav-label::after { background: #e2e8f0; }

    /* Widget gruplarini varsayilan olarak gizle — JS activateSection onlari acacak */
    .mce-content [data-dyn-group-id] { display: none; }

    /* Sidenav skeleton */
    .mce-nav-skeleton-row {
        height: 34px; margin: 2px 16px; border-radius: 6px;
        background: linear-gradient(90deg,
            rgba(255,255,255,0.03) 0%,
            rgba(255,255,255,0.08) 50%,
            rgba(255,255,255,0.03) 100%);
        background-size: 200% 100%;
        animation: mceSkeletonShimmer 1.4s ease-in-out infinite;
    }
    body.app-theme-light .mce-nav-skeleton-row {
        background: linear-gradient(90deg, #f1f5f9 0%, #e2e8f0 50%, #f1f5f9 100%);
        background-size: 200% 100%;
    }
    @@keyframes mceSkeletonShimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* Nav button — flat, left-border indicator */
    .mce-nav-btn {
        display: flex; align-items: center; gap: 10px;
        width: 100%; padding: 9px 16px;
        background: transparent;
        border: none; border-left: 2px solid transparent; border-radius: 0;
        color: rgba(255,255,255,0.42);
        font-size: 0.83rem; font-weight: 500; text-align: left;
        cursor: pointer; transition: all 0.15s; line-height: 1.4;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    body.app-theme-light .mce-nav-btn { color: #94a3b8; }
    .mce-nav-btn:hover {
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.78);
        border-left-color: rgba(255,255,255,0.18);
    }
    body.app-theme-light .mce-nav-btn:hover {
        background: rgba(0,0,0,0.04); color: #334155;
        border-left-color: #cbd5e1;
    }
    .mce-nav-btn.is-active {
        background: rgba(99,102,241,0.09);
        border-left-color: #6366f1;
        color: #a5b4fc; font-weight: 600;
    }
    body.app-theme-light .mce-nav-btn.is-active {
        background: rgba(99,102,241,0.07);
        border-left-color: #6366f1; color: #6366f1;
    }

    /* Dot — halka (inactive) → dolu+glow (active) */
    .mce-nav-dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
        border: 1.5px solid rgba(255,255,255,0.22);
        background: transparent;
        transition: all 0.18s;
    }
    body.app-theme-light .mce-nav-dot { border-color: #cbd5e1; }
    .mce-nav-btn:hover .mce-nav-dot { border-color: rgba(255,255,255,0.48); }
    body.app-theme-light .mce-nav-btn:hover .mce-nav-dot { border-color: #94a3b8; }
    .mce-nav-btn.is-active .mce-nav-dot {
        background: #6366f1; border-color: #6366f1;
        box-shadow: 0 0 7px rgba(99,102,241,0.65);
    }
    body.app-theme-light .mce-nav-btn.is-active .mce-nav-dot {
        background: #6366f1; border-color: #6366f1;
        box-shadow: 0 0 7px rgba(99,102,241,0.4);
    }

    .mce-nav-count {
        margin-left: auto; padding: 1px 6px; border-radius: 999px;
        font-size: 0.6rem; font-weight: 700; font-family: monospace;
        background: rgba(99,102,241,0.15); color: #a5b4fc;
        border: 1px solid rgba(99,102,241,0.28); flex-shrink: 0;
        min-width: 22px; text-align: center;
        transition: opacity .12s, background .12s;
    }
    .mce-nav-count.is-empty { opacity: 0; pointer-events: none; }
    body.app-theme-light .mce-nav-count { background: rgba(99,102,241,0.08); color: #6366f1; border-color: rgba(99,102,241,0.2); }

    /* Kombinasyonlar tablosu */
    .mce-comb-table {
        width: 100%; border-collapse: collapse; font-size: 0.82rem;
    }
    .mce-comb-th, .mce-comb-td {
        padding: 7px 10px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .mce-comb-th {
        font-size: 0.78rem;
        color: rgba(165,180,252,0.85); font-weight: 600;
    }
    /* Satir (td) metin rengi — dark-default, light-mode override */
    .mce-comb-td { color: rgba(255,255,255,0.88); }
    .mce-comb-code {
        font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 0.78rem;
        color: #a5b4fc; white-space: nowrap;
    }
    .mce-comb-name { color: rgba(255,255,255,0.75); }
    body.app-theme-light .mce-comb-th { color: rgba(71,85,105,0.7); }
    body.app-theme-light .mce-comb-td { color: #1e293b; border-bottom-color: rgba(0,0,0,0.06); }
    body.app-theme-light .mce-comb-code { color: #4f46e5; }
    body.app-theme-light .mce-comb-name { color: #334155; }
    /* Planlama depo tablosu — daha sıkı satır aralığı */
    #mceLocListTable .mce-comb-th, #mceLocListTable .mce-comb-td { padding-top: 4px; padding-bottom: 4px; }
    /* Kombinasyon kodu link + aciklama inline input + ust toolbar */
    .mce-comb-toolbar { display:flex; justify-content:flex-end; padding:6px 4px 10px 4px; }
    .mce-comb-goto-btn {
        display:inline-flex; align-items:center; gap:6px;
        padding:6px 12px; font-size:0.78rem; font-weight:600;
        color:#a5b4fc; background:rgba(165,180,252,0.1);
        border:1px solid rgba(165,180,252,0.25); border-radius:6px;
        text-decoration:none; transition: background 0.15s, color 0.15s;
    }
    .mce-comb-goto-btn:hover { background:rgba(165,180,252,0.2); color:#c7d2fe; }
    body.app-theme-light .mce-comb-goto-btn { color:#4f46e5; background:rgba(79,70,229,0.08); border-color:rgba(79,70,229,0.2); }
    body.app-theme-light .mce-comb-goto-btn:hover { background:rgba(79,70,229,0.15); }

    .mce-comb-link { color: inherit; text-decoration: underline; text-decoration-style: dotted; text-underline-offset: 3px; cursor: pointer; }
    .mce-comb-link:hover { color: #c7d2fe; text-decoration-style: solid; }
    body.app-theme-light .mce-comb-link:hover { color: #3730a3; }

    .mce-comb-desc-input {
        width: 100%; padding: 4px 8px; font-size: 0.8rem;
        background: transparent; color: inherit;
        border: 1px solid transparent; border-radius: 4px;
        transition: border-color 0.15s, background 0.15s;
    }
    .mce-comb-desc-input:hover { border-color: rgba(255,255,255,0.1); }
    .mce-comb-desc-input:focus { outline: none; border-color: rgba(165,180,252,0.6); background: rgba(255,255,255,0.03); }
    body.app-theme-light .mce-comb-desc-input:hover { border-color: rgba(0,0,0,0.1); }
    body.app-theme-light .mce-comb-desc-input:focus { border-color: rgba(79,70,229,0.55); background: rgba(0,0,0,0.02); }
    .mce-comb-desc-input.is-saving { border-color: rgba(245,158,11,0.5); }
    .mce-comb-desc-input.is-saved { border-color: rgba(16,185,129,0.6); background: rgba(16,185,129,0.08); }
    .mce-comb-desc-input.is-error { border-color: rgba(239,68,68,0.6); background: rgba(239,68,68,0.06); }
    .mce-comb-empty {
        padding: 32px 16px; text-align: center;
        color: rgba(255,255,255,0.35); font-size: 0.82rem;
    }
    body.app-theme-light .mce-comb-empty { color: rgba(71,85,105,0.5); }

    .mce-content {
        flex: 1 1 auto; min-width: 0; overflow-y: auto;
        padding: 20px 24px;
        background: transparent;
    }
    body.app-theme-dark .mce-content,
    html.dark .mce-content { background: #0c0f1a; background-image: radial-gradient(at 20% 30%,rgba(99,102,241,0.12) 0px,transparent 50%),radial-gradient(at 80% 20%,rgba(14,165,233,0.08) 0px,transparent 50%),radial-gradient(at 50% 80%,rgba(168,85,247,0.08) 0px,transparent 50%); }
    body.app-theme-light .mce-content { background: #f8fafc; }

    .mce-section-anchor { scroll-margin-top: 8px; }

    /* ── Silme onay modalı ─────────────────────────────────────────── */
    .mce-del-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,.55); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center; padding: 20px;
        animation: mceDelFadeIn .15s ease-out;
    }
    @@keyframes mceDelFadeIn { from { opacity: 0; } to { opacity: 1; } }
    .mce-del-box {
        background: #1e293b; border: 1px solid rgba(255,255,255,.12);
        border-radius: 16px; padding: 32px 28px;
        max-width: 380px; width: 90vw; text-align: center;
        display: flex; flex-direction: column; align-items: center; gap: 12px;
        box-shadow: 0 24px 64px rgba(0,0,0,.5);
        animation: mceDelSlide .18s cubic-bezier(.23,1,.32,1);
    }
    @@keyframes mceDelSlide {
        from { transform: translateY(10px) scale(.97); opacity: 0; }
        to   { transform: translateY(0)    scale(1);   opacity: 1; }
    }
    body.app-theme-light .mce-del-box {
        background: #ffffff; border-color: #e2e8f0;
        box-shadow: 0 24px 64px rgba(0,0,0,.15);
    }
    .mce-del-ico { color: #ef4444; }
    .mce-del-title { font-size: 1.05rem; font-weight: 700; color: #f1f5f9; margin: 0; }
    body.app-theme-light .mce-del-title { color: #0f172a; }
    .mce-del-text { font-size: .84rem; color: #94a3b8; margin: 0; }
    body.app-theme-light .mce-del-text { color: #64748b; }
    .mce-del-code {
        font-family: monospace; font-size: .88rem; font-weight: 700;
        color: #a5b4fc; background: rgba(245,158,11,.1);
        border: 1px solid rgba(245,158,11,.25);
        border-radius: 8px; padding: 4px 12px;
    }
    body.app-theme-light .mce-del-code { color: #6366f1; background: rgba(245,158,11,.08); }
    .mce-del-name {
        font-size: .84rem; font-weight: 500;
        color: #cbd5e1;
        max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    body.app-theme-light .mce-del-name { color: #475569; }
    .mce-del-btns { display: flex; gap: 10px; margin-top: 8px; }
    .mce-del-cancel {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 8px; font-size: .84rem; font-weight: 600;
        background: rgba(255,255,255,.07); color: #f1f5f9;
        border: 1px solid rgba(255,255,255,.1); cursor: pointer; transition: all .15s;
    }
    .mce-del-cancel:disabled { opacity: .5; cursor: default; }
    .mce-del-cancel:hover:not(:disabled) { background: rgba(255,255,255,.13); }
    body.app-theme-light .mce-del-cancel {
        background: #f1f5f9; border-color: #e2e8f0; color: #374151;
    }
    body.app-theme-light .mce-del-cancel:hover:not(:disabled) { background: #e2e8f0; }
    .mce-del-confirm {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 8px; font-size: .84rem; font-weight: 600;
        background: linear-gradient(135deg,#ef4444,#dc2626); color: #fff;
        border: none; cursor: pointer; transition: all .15s;
    }
    .mce-del-confirm:disabled { opacity: .5; cursor: default; }
    .mce-del-confirm:hover:not(:disabled) { background: linear-gradient(135deg,#f87171,#ef4444); }
    @@keyframes mceDelSpin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    /* ── Custom Combobox (mce-cbx) — dark tema uyumlu select replacement ── */
    .mce-cbx { position: relative; flex: 1 1 auto; min-width: 0; }
    .mce-cbx__trigger {
        width: 100%;
        height: 36px;
        padding: 0 32px 0 12px;
        border-radius: 8px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.10);
        color: rgba(255,255,255,0.92);
        font-size: 0.875rem;
        font-weight: 500;
        text-align: left;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
        transition: border-color .12s, background .12s, box-shadow .12s;
        outline: none;
        box-sizing: border-box;
    }
    .mce-cbx__trigger:hover:not([disabled]) { border-color: rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); }
    .mce-cbx__trigger.is-open { border-color: rgba(99,102,241,0.55); box-shadow: 0 0 0 3px rgba(99,102,241,0.12); }
    .mce-cbx__trigger.is-invalid { border-color: rgba(239,68,68,0.7); box-shadow: 0 0 0 3px rgba(239,68,68,0.12); }
    .mce-cbx__trigger[disabled] { opacity: .5; cursor: not-allowed; }
    .mce-cbx__label { flex: 1 1 auto; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .mce-cbx__label--placeholder { color: rgba(255,255,255,0.35); font-weight: 400; }
    .mce-cbx__arrow {
        position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
        font-size: 0.65rem; opacity: .55; transition: transform .15s, opacity .15s;
        pointer-events: none;
    }
    .mce-cbx__trigger.is-open .mce-cbx__arrow { transform: translateY(-50%) rotate(180deg); opacity: .85; }

    .mce-cbx__panel {
        position: absolute; top: calc(100% + 4px); left: 0; right: 0;
        max-height: 240px; overflow-y: auto;
        background: rgba(17,24,39,0.98);
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.45), 0 2px 6px rgba(0,0,0,0.3);
        z-index: 1000;
        padding: 4px;
        backdrop-filter: blur(6px);
    }
    .mce-cbx__panel::-webkit-scrollbar { width: 8px; }
    .mce-cbx__panel::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); border-radius: 4px; }
    .mce-cbx__panel::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 4px; }
    .mce-cbx__panel::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.20); }

    .mce-cbx__option {
        padding: 7px 10px;
        font-size: 0.825rem;
        cursor: pointer;
        color: rgba(255,255,255,0.85);
        border-radius: 6px;
        transition: background .08s, color .08s;
        user-select: none;
    }
    .mce-cbx__option:hover { background: rgba(99,102,241,0.18); color: #fff; }
    .mce-cbx__option.is-selected { background: rgba(99,102,241,0.28); color: #fff; font-weight: 600; }
    .mce-cbx__option.is-placeholder { color: rgba(255,255,255,0.40); font-style: italic; }
    .mce-cbx__option.is-used {
        color: rgba(255,255,255,0.32);
        text-decoration: line-through;
        cursor: not-allowed;
        background: rgba(239,68,68,0.06);
    }
    .mce-cbx__option.is-used:hover { background: rgba(239,68,68,0.10); color: rgba(255,255,255,0.40); }
    .mce-cbx__option.is-used::after {
        content: ' (kullaniliyor)';
        font-size: 0.70rem; font-style: italic; opacity: .65;
    }
    .mce-cbx__option.is-inactive {
        color: rgba(248,113,113,0.65);
        text-decoration: line-through;
        cursor: not-allowed;
        background: rgba(239,68,68,0.04);
    }
    .mce-cbx__option.is-inactive::after {
        content: ' (pasif)';
        font-size: 0.70rem; font-style: italic; opacity: .75;
    }
    .mce-cbx__option.is-inactive:hover { background: rgba(239,68,68,0.08); }

    /* Light tema */
    body.app-theme-light .mce-cbx__trigger {
        background: #fff; border-color: rgba(15,23,42,0.10); color: #1e293b;
    }
    body.app-theme-light .mce-cbx__trigger:hover:not([disabled]) { border-color: rgba(15,23,42,0.20); background: #f8fafc; }
    body.app-theme-light .mce-cbx__label--placeholder { color: rgba(15,23,42,0.40); }
    body.app-theme-light .mce-cbx__panel { background: #fff; border-color: rgba(15,23,42,0.12); box-shadow: 0 10px 30px rgba(0,0,0,0.12); }
    body.app-theme-light .mce-cbx__option { color: #1e293b; }
    body.app-theme-light .mce-cbx__option:hover { background: rgba(99,102,241,0.10); color: #4f46e5; }
    body.app-theme-light .mce-cbx__option.is-selected { background: rgba(99,102,241,0.15); color: #4f46e5; }
    body.app-theme-light .mce-cbx__option.is-used { color: rgba(15,23,42,0.40); background: rgba(239,68,68,0.04); }
    body.app-theme-light .mce-cbx__option.is-inactive { color: rgba(220,38,38,0.65); background: rgba(239,68,68,0.04); }

</style>
}

