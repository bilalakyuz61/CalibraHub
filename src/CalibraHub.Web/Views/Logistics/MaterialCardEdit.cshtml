            </div>
            <div class="mce-vguide-search">
                <svg class="mce-vguide-search__ico" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="mceValuesGuideSearch" class="mce-vguide-search__input" placeholder="Deger ara..." autocomplete="off" />
            </div>
            <div id="mceValuesGuideBody" class="mce-vguide-body"></div>
            <div class="mce-vguide-footer">
                <span id="mceValuesGuideCount" class="mce-vguide-footer__count">0 deger secili</span>
                <button type="button" class="mce-vguide-footer__close" onclick="mceCloseValuesGuide()">Kapat</button>
            </div>
        </div>
    </div>

</section>
</div>

@section Scripts {
<script>
(function() {
    var editId = @editId;
    var currentId = editId > 0 ? editId : 0;

    function $(id) { return document.getElementById(id); }

    // Action bar setup — identity badge enjeksiyonu + collaboration attribute'ları
    (function() {
        var bar = document.querySelector('.pte-action-bar');
        if (!bar) return;
        bar.setAttribute('data-no-proxy', '');
        bar.setAttribute('data-collaboration-banner-host', '');

        // Title slot → identity rozeti
        var titleEl = document.querySelector('.pte-action-bar__title');
        if (titleEl) {
            titleEl.id = 'mceMeta';
            titleEl.style.cssText = 'display:inline-flex;align-items:center;gap:10px;flex:0 0 auto;min-width:0;';
            titleEl.innerHTML =
                '<div class="mce-bar-icon-box">' +
                    '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                    '<path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>' +
                    '<polyline points="3.27 6.96 12 12.01 20.73 6.96"/>' +
                    '<line x1="12" y1="22.08" x2="12" y2="12"/></svg>' +
                '</div>' +
                '<div class="mce-bar-id-info">' +
                    '<span class="mce-bar-id-code">Yeni Malzeme</span>' +
                    '<span class="mce-bar-id-name"></span>' +
                '</div>';
        }

        // Save + Delete: collaboration attribute + onclick bağla
        var savBtn = document.getElementById('mceSaveBtn');
        if (savBtn) {
            savBtn.setAttribute('data-collaboration-write', 'true');
            savBtn.addEventListener('click', function() { window.mceSave && window.mceSave(); });
        }
        var delBtn = document.getElementById('mceDeleteBtn');
        if (delBtn) {
            delBtn.setAttribute('data-collaboration-write', 'true');
            delBtn.style.display = 'none';
            delBtn.addEventListener('click', function() { window.mceDelete && window.mceDelete(); });
        }
    })();

    var _mceMsgTimer = null;
    // Bilgilendirme: ortalanmis modal — ekranda yer kaplamasin.
    // Basari durumunda KITT yesil tarayici yeterli, text mesaj yok.
    function showMsg(text, ok) {
        if (ok) return; // success mesajini bastir
        if (window.CalibraAlert && CalibraAlert.error) {
            CalibraAlert.error(text);
            return;
        }
        return showMsgLegacy(text, ok);
    }
    function showMsgLegacy(text, ok) {
        var m = $('mceMsg');
        if (!m) return;
        // Animasyonu yeniden basa almak icin classlari temizle, reflow tetikle
        m.className = 'mce-message';
        void m.offsetWidth; // reflow
        m.textContent = text;
        m.className = 'mce-message ' + (ok ? 'ok' : 'err');
        if (_mceMsgTimer) clearTimeout(_mceMsgTimer);
        _mceMsgTimer = setTimeout(function() {
            m.className = 'mce-message';
            // Animasyon bittikten sonra metni temizle
            setTimeout(function() { m.textContent = ''; }, 350);
        }, 4000);
    }

    // ── Ust bilgi seridi: kimlik alani dogrudan DOM elemanlarina yazilir ──
    function mceFormatMeta(id, code, name) {
        var codeEl = document.querySelector('#mceMeta .mce-bar-id-code');
        var nameEl = document.querySelector('#mceMeta .mce-bar-id-name');
        if (codeEl) codeEl.textContent = code || 'Yeni Malzeme';
        if (nameEl) nameEl.textContent = name || '';
        return '';
    }

    // ── populate() — Master alanlari doldurur ──
    // Dinamik alanlar artik yeni EAV renderer (DynamicWidgetRenderer) tarafindan
    // kendi API'si (/api/widgets/forms/ITEMS/records/{materialCode}) ile yuklenir.
    // Null guard: degistirilmis sayfa duzeninde bazi sabit alanlar (Eski "Aciklama"
    // textarea gibi) artik widget olarak tanimlanmis olabilir → eleman DOM'da
    // bulunmayinca sessizce atla, throw etme.
    function _setHTML(id, html)  { var el = $(id); if (el) el.innerHTML = html; }
    function _setVal(id, val)    { var el = $(id); if (el) el.value = val; }
    function _setChk(id, val)    { var el = $(id); if (el) el.checked = !!val; }

    // İzlenebilirlik alt satırlarının görünürlüğü: mod (Lot/Seri) yalnız izlenebilirlik açıkken,
    // "Giriş Serisi Otomatik" yalnız Seri modundayken görünür.
    window.mceSyncTrackingUi = function () {
        var on   = !!($('mceTraceability') && $('mceTraceability').checked);
        var seri = on && !!($('mceTrackingMode') && $('mceTrackingMode').checked);
        var w = document.getElementById('mceTrackingModeWrap'); if (w) w.style.display = on ? 'inline-flex' : 'none';
        var a = document.getElementById('mceAutoSerialWrap');   if (a) a.style.display = seri ? 'inline-flex' : 'none';
    };
    function _setDisp(id, val)   { var el = $(id); if (el) el.style.display = val; }
    function populate(data) {
        // Defansif sarma: widget config tutarsizliklari (orn. ColSpan/field referans
        // degisiklikleri sonrasi) populate icinde beklenmeyen DOM hatalarina yol acabilir;
        // bunlari yutup console'a logla, "Yuklenirken hata" toast'unu kullaniciya gosterme.
        try {
            mceFormatMeta(data.stockCardId, data.materialCode, data.materialName);
            _setVal('mceMaterialCode',         data.materialCode || '');
            _setVal('mceMaterialName',         data.materialName || '');
            _setVal('mceMaterialTypeId',       data.materialTypeId != null ? String(data.materialTypeId) : '');
            _setChk('mceTrackCombinations',    !!data.trackCombinations);
            _setVal('mceTaxRate',              data.taxRate != null ? data.taxRate : 20);
            _setVal('mceGeneralMinStock',      data.minStock != null ? data.minStock : 0);
            (function (tt) {
                var on = tt && tt !== 'None';
                if ($('mceTraceability')) $('mceTraceability').checked = on;
                if ($('mceTrackingMode')) $('mceTrackingMode').checked = (tt === 'Serial');
                if ($('mceAutoSerial')) $('mceAutoSerial').checked = !!data.autoSerial;
                if (window.mceSyncTrackingUi) window.mceSyncTrackingUi();
            })(data.trackingType);
            _setDisp('mceDeleteBtn',           'inline-flex');

            // Ana Birim — dropdown options mceUnitLoad sirasinda dolduruluyor; secilenler
            // hazir olur olmaz set etsin diye deferred set yapiyoruz.
            var pendingUnitId = data.unitId != null ? String(data.unitId) : '';
            window._mceApplyUnitId = function() {
                var el = $('mceUnitId');
                if (!el) return;
                el.value = pendingUnitId;
                // Programatik value degisimi change event uretmiyor — combobox UI label
                // ve selected state'i manuel olarak yenile, yoksa "Seciniz" placeholder'i kalir.
                if (typeof mceCbxRebuild === 'function') mceCbxRebuild(el);
                // Ana Birim degistiyse alternat satirlarda ayni birimin secilebilirligi yenilenmeli.
                if (typeof mceUnitRefreshSelects === 'function') mceUnitRefreshSelects();
            };
            if (window._mceUnitsLoaded) window._mceApplyUnitId();

            // Kombinasyonlar
            var combos = data.combinations || [];
            renderCombinations(combos);
            updateCombNav(!!data.trackCombinations, combos.length);

            // Recete nav buton gorunurlugu (Mamul/Yari Mamul ise goster)
            if (typeof window.mceRecipeSyncVisibility === 'function') {
                window.mceRecipeSyncVisibility();
            }
            // Kit nav buton gorunurlugu (Kit tipinde goster)
            if (typeof window.mceKitSyncVisibility === 'function') {
                window.mceKitSyncVisibility();
            }

            // Eski sayfa kayitlari icin renderer recordId'yi reload et (integer Id ile)
            if (window._mceDynRenderer && data.stockCardId) {
                try { window._mceDynRenderer.reload({ recordId: String(data.stockCardId) }); }
                catch (e) { console.warn('[MCE] dyn renderer reload hatasi:', e); }
            }

            // Ozellik Eslestirme sayim rozetini sayfa acilisinda dogru goster — trackCombinations
            // acikken ve kart kayitliyken feature listesini eager olarak yukleyip rozete yansitir.
            if (!!data.trackCombinations && data.stockCardId && data.stockCardId > 0
                && typeof window.mceFeatureLoad === 'function') {
                try { window.mceFeatureLoad(); } catch (e) { /* ignore */ }
            }
        } catch (e) {
            console.error('[MCE] populate icinde DOM hatasi (yutuldu):', e);
        }
    }

    // ── Kombinasyonlar — tablo render + nav guncelleme ──
    function escHtml(s) {
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(s));
        return d.innerHTML;
    }

    // Kombinasyon detayi popup icin cache.
    // combNameById[id]      = "Motor Gucu: 100 | ..." (metin ozet)
    // combCodeById[id]      = "1500 2339-CRM-12" (kombinasyon kodu)
    // combFeaturesById[id]  = [{ featureId, featureName, visibleInDesign, valueId, valueName, aciklama }, ...]
    var combNameById = {};
    var combCodeById = {};
    var combFeaturesById = {};

    function renderCombinations(combos) {
        var body = $('mceCombBody');
        if (!body) return;

        // Eski toolbar kaldirildi — "Kombinasyon Uretici" butonu artik kartin
        // basliginda (mceGoToCombGenBtnCombos). Ozellik Eslestirme kartindaki
        // ile ayni sekil ve konumda.

        if (!combos || combos.length === 0) {
            body.innerHTML = '<div class="mce-comb-empty">Henuz kombinasyon tanimlanmamis.</div>';
            return;
        }

        combNameById = {};
        combCodeById = {};
        combFeaturesById = {};
        combos.forEach(function (c) {
            if (Array.isArray(c.features)) combFeaturesById[c.id] = c.features;
        });
        var html = '<table class="mce-comb-table"><thead><tr>' +
            '<th class="mce-comb-th" style="width:40px;">#</th>' +
            '<th class="mce-comb-th">Kod</th>' +
            '<th class="mce-comb-th">Aciklama</th>' +
            '</tr></thead><tbody>';
        for (var i = 0; i < combos.length; i++) {
            var c = combos[i];
            combNameById[c.id] = c.combinationName || '';
            combCodeById[c.id] = c.combinationCode || '';
            html += '<tr>' +
                '<td class="mce-comb-td" style="width:40px;opacity:0.4;">' + (i + 1) + '</td>' +
                '<td class="mce-comb-td mce-comb-code">' +
                    '<a href="#" class="mce-comb-link" data-comb-id="' + c.id + '" onclick="mceShowCombinationDetails(' + c.id + ', event); return false;">'
                    + escHtml(c.combinationCode || '') + '</a>'
                + '</td>' +
                '<td class="mce-comb-td">' +
                    '<input type="text" class="mce-comb-desc-input" data-comb-id="' + c.id + '" value="' + escHtml(c.description || '') + '" placeholder="Aciklama girin..." />'
                + '</td>' +
                '</tr>';
        }
        html += '</tbody></table>';
        body.innerHTML = html;

        // Inline edit: blur'da AJAX save
        body.querySelectorAll('.mce-comb-desc-input').forEach(function(inp) {
            inp.addEventListener('blur', function() { mceSaveCombinationDescription(inp); });
            inp.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') { e.preventDefault(); inp.blur(); }
                else if (e.key === 'Escape') { inp.value = inp.defaultValue; inp.blur(); }
            });
        });
    }

    // ── Kombinasyon aciklamasi kaydet (inline) ──
    function mceSaveCombinationDescription(inp) {
        var id = parseInt(inp.getAttribute('data-comb-id'), 10);
        if (!id || id <= 0) return;
        var newVal = (inp.value || '').trim();
        if (newVal === (inp.defaultValue || '').trim()) return;  // degisiklik yoksa skip
        inp.classList.add('is-saving');
        fetch('/Logistics/UpdateCombinationDescriptionJson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id, description: newVal })
        })
        .then(function(r) { return r.json(); })
        .then(function(res) {
            inp.classList.remove('is-saving');
            if (res && res.success) {
                inp.defaultValue = newVal;
                inp.classList.add('is-saved');
                setTimeout(function() { inp.classList.remove('is-saved'); }, 1200);
            } else {
                inp.classList.add('is-error');
                CalibraAlert.error('Aciklama kaydedilemedi: ' + (res && res.message ? res.message : 'Bilinmeyen hata'));
            }
        })
        .catch(function(e) {
            inp.classList.remove('is-saving');
            inp.classList.add('is-error');
            CalibraAlert.error('Aciklama kaydedilemedi: ' + e.message);
        });
    }

    // ── Kombinasyon detay popup (ozellik/deger listesi) ──
    // Kombinasyon detay popup'i — her ozellik icin "Dizaynda gorunsun" toggle'i
    // ve "Aciklama" input'u ile inline edit + otomatik kaydet.
    window.mceShowCombinationDetails = function(id, ev) {
        if (ev) ev.preventDefault();
        var features = combFeaturesById[id] || [];

        // Eski overlay varsa temizle
        var old = document.getElementById('__mce_comb_popup__');
        if (old) old.remove();

        var hostDoc = document;
        try { if (window.top && window.top.document) hostDoc = window.top.document; } catch (e) { /* cross-origin */ }

        var overlay = hostDoc.createElement('div');
        overlay.id = '__mce_comb_popup__';
        overlay.style.cssText = 'position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);padding:20px;';

        // Top-window'da CSS (mce-switch vb.) yok — self-contained switch stili inject et.
        if (!hostDoc.getElementById('__mce_comb_popup_styles__')) {
            var st = hostDoc.createElement('style');
            st.id = '__mce_comb_popup_styles__';
            st.textContent = [
                '.mcp-switch{position:relative;display:inline-block;width:40px;height:22px;cursor:pointer;vertical-align:middle;}',
                '.mcp-switch input{opacity:0;width:0;height:0;position:absolute;}',
                '.mcp-switch .mcp-track{position:absolute;inset:0;border-radius:22px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.15);transition:.25s;}',
                '.mcp-switch input:checked + .mcp-track{background:#10b981;border-color:#34d399;box-shadow:0 0 0 3px rgba(16,185,129,.15);}',
                '.mcp-switch .mcp-track::before{content:"";position:absolute;height:16px;width:16px;left:2px;top:2px;border-radius:50%;background:rgba(255,255,255,.6);transition:.25s;}',
                '.mcp-switch input:checked + .mcp-track::before{transform:translateX(18px);background:#fff;}',
                '.mcp-textarea{width:100%;min-height:46px;resize:vertical;padding:6px 10px;font:inherit;font-size:.82rem;color:#e2e8f0;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);border-radius:6px;line-height:1.4;box-sizing:border-box;}',
                '.mcp-textarea:focus{outline:none;border-color:#6366f1;background:rgba(99,102,241,.06);}'
            ].join('\n');
            hostDoc.head.appendChild(st);
        }

        var box = hostDoc.createElement('div');
        box.style.cssText = 'min-width:640px;max-width:820px;width:92vw;background:#1e293b;color:#e2e8f0;border:1px solid rgba(255,255,255,.12);border-radius:14px;box-shadow:0 24px 64px rgba(0,0,0,.5);display:flex;flex-direction:column;overflow:hidden;';

        // Baslik
        var head = hostDoc.createElement('div');
        head.style.cssText = 'padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;gap:10px;';
        head.innerHTML = '<span style="font-size:1rem;font-weight:700;">Kombinasyon Ozellikleri</span>';
        box.appendChild(head);

        // Govde — tablo
        var body = hostDoc.createElement('div');
        body.style.cssText = 'padding:12px 20px;max-height:60vh;overflow-y:auto;';
        if (features.length === 0) {
            body.innerHTML = '<div style="color:rgba(255,255,255,.45);padding:12px 4px;font-size:.86rem;">Bu kombinasyon icin ozellik detayi bulunamadi.</div>';
        } else {
            // Ozellik bazli aciklama girisi kaldirildi — aciklama Ozellik
            // Tanimlama (ProductFeatureEdit) sayfasinda yoneten 1 yere indirgendi.
            // Burada kullanici sadece feature gorunurlugunu (Dizaynda) toggle eder.
            var tbl = '<table style="width:100%;border-collapse:collapse;font-size:.82rem;table-layout:fixed;">'
                + '<colgroup>'
                + '<col style="width:50%;"><col style="width:34%;"><col style="width:16%;">'
                + '</colgroup>'
                + '<thead><tr style="color:rgba(165,180,252,.85);font-weight:600;">'
                + '<th style="text-align:left;padding:6px 8px;border-bottom:1px solid rgba(255,255,255,.08);">Ozellik</th>'
                + '<th style="text-align:left;padding:6px 8px;border-bottom:1px solid rgba(255,255,255,.08);">Deger</th>'
                + '<th style="text-align:center;padding:6px 8px;border-bottom:1px solid rgba(255,255,255,.08);white-space:nowrap;">Dizaynda</th>'
                + '</tr></thead><tbody>';
            features.forEach(function (f, i) {
                var vis = f.visibleInDesign === true;
                tbl += '<tr data-row-idx="' + i + '">'
                    + '<td style="padding:10px 8px;border-bottom:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.7);font-weight:600;word-break:break-word;">' + escHtml(f.featureName || '') + '</td>'
                    + '<td style="padding:10px 8px;border-bottom:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.88);word-break:break-word;">' + escHtml(f.valueName || '') + '</td>'
                    + '<td style="padding:10px 8px;border-bottom:1px solid rgba(255,255,255,.05);text-align:center;vertical-align:middle;">'
                        + '<label class="mcp-switch">'
                        + '<input type="checkbox" class="js-feat-vis" data-feature-id="' + f.featureId + '" ' + (vis ? 'checked' : '') + ' />'
                        + '<span class="mcp-track"></span>'
                        + '</label>'
                    + '</td>'
                    + '</tr>';
            });
            tbl += '</tbody></table>';
            body.innerHTML = tbl;
        }
        box.appendChild(body);

        // Alt buton satiri
        var foot = hostDoc.createElement('div');
        foot.style.cssText = 'padding:12px 20px;border-top:1px solid rgba(255,255,255,.08);display:flex;justify-content:space-between;align-items:center;gap:10px;';
        var status = hostDoc.createElement('span');
        status.id = '__mce_comb_popup_status__';
        status.style.cssText = 'font-size:.76rem;color:rgba(255,255,255,.45);';
        var closeBtn = hostDoc.createElement('button');
        closeBtn.type = 'button';
        closeBtn.textContent = 'Kapat';
        closeBtn.style.cssText = 'padding:8px 18px;border-radius:8px;background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;border:none;cursor:pointer;font-weight:600;font-size:.86rem;';
        foot.appendChild(status);
        foot.appendChild(closeBtn);
        box.appendChild(foot);

        overlay.appendChild(box);
        hostDoc.body.appendChild(overlay);

        function close() {
            hostDoc.removeEventListener('keydown', onKey);
            if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
        }
        function onKey(e) { if (e.key === 'Escape') close(); }
        closeBtn.addEventListener('click', close);
        overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });
        hostDoc.addEventListener('keydown', onKey);

        function setStatus(text, ok) {
            status.textContent = text || '';
            status.style.color = ok === false ? '#f87171' : (ok === true ? '#34d399' : 'rgba(255,255,255,.45)');
            if (ok === true) setTimeout(function () { if (status.textContent === text) status.textContent = ''; }, 1800);
        }

        // Auto-save — toggle degistiginde
        body.querySelectorAll('.js-feat-vis').forEach(function (cb) {
            cb.addEventListener('change', function () {
                var featureId = parseInt(cb.getAttribute('data-feature-id'), 10);
                setStatus('Kaydediliyor...');
                fetch('/Logistics/UpdateFeatureVisibilityJson', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'same-origin',
                    body: JSON.stringify({ featureId: featureId, visibleInDesign: cb.checked })
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data.success) {
                        cb.checked = !cb.checked; // rollback
                        setStatus('Hata: ' + (data.message || 'bilinmeyen'), false);
                    } else {
                        // Cache'i de guncelle (ayni feature'i kullanan diger satirlar icin)
                        Object.keys(combFeaturesById).forEach(function (cid) {
                            (combFeaturesById[cid] || []).forEach(function (f) {
                                if (f.featureId === featureId) f.visibleInDesign = cb.checked;
                            });
                        });
                        // Popup icindeki ayni feature'a bagli diger toggle'lari senkronla
                        body.querySelectorAll('.js-feat-vis[data-feature-id="' + featureId + '"]').forEach(function (other) {
                            if (other !== cb) other.checked = cb.checked;
                        });
                        setStatus('Kaydedildi', true);
                    }
                })
                .catch(function (err) { cb.checked = !cb.checked; setStatus('Hata: ' + err.message, false); });
            });
        });

        // Aciklama input handler kaldirildi — popup'ta artik sadece Dizaynda
        // toggle var. Aciklama yonetimi ProductFeatureEdit sayfasinda merkezilesti.
    };

    // ── "Kombinasyonda" badge'ine tiklaninca: bu ozellik bu stok karti icinde
    // hangi kombinasyon(lar)da kullaniliyor gosteren popup. Server'a yeni cagri
    // YAPILMAZ — combFeaturesById/combCodeById/combNameById frontend cache'leri
    // populate(data) sirasinda dolduruluyor; reverse lookup ile filtre cekiyoruz.
    window.mceShowFeatureCombinationsPopup = function(featureId, featureName, ev) {
        if (ev) ev.preventDefault();
        if (ev) ev.stopPropagation();
        featureId = parseInt(featureId, 10);
        if (!featureId) return;

        // Bu feature'i iceren kombinasyonlari topla — { combId, code, name, valueName }
        var matches = [];
        Object.keys(combFeaturesById).forEach(function(cid) {
            var arr = combFeaturesById[cid] || [];
            var hit = null;
            for (var i = 0; i < arr.length; i++) {
                if (arr[i].featureId === featureId) { hit = arr[i]; break; }
            }
            if (hit) {
                matches.push({
                    combId: parseInt(cid, 10),
                    code: combCodeById[cid] || '',
                    name: combNameById[cid] || '',
                    valueName: hit.valueName || ''
                });
            }
        });

        // Eski overlay temizle
