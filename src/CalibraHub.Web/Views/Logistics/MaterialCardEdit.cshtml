    function mceUnitPopulateSelects() {
        // Tek opsiyon listesi — hem Ana Birim (Genel Bilgiler) hem alternat (Olcu Birimleri)
        // dropdown'lari UnitId (int) ile bind edilir.
        // Pasif (isActive=false) birimler data-inactive="true" attribute aliyor — combobox
        // bunu strikethrough/disabled olarak gosterir.
        var opts = '<option value="">Seciniz</option>';
        _availableUnits.forEach(function(u) {
            var inactiveAttr = (u.isActive === false) ? ' data-inactive="true"' : '';
            opts += '<option value="' + u.id + '"' + inactiveAttr + '>' + u.unitCode + ' — ' + u.unitName + '</option>';
        });

        var masterEl = document.getElementById('mceUnitId');
        if (masterEl) { var mv = masterEl.value; masterEl.innerHTML = opts; masterEl.value = mv; }

        document.querySelectorAll('.mce-unit-code').forEach(function(sel) {
            var v = sel.value; sel.innerHTML = opts; sel.value = v;
        });

        // Native select'leri custom combobox'a yukselt (idempotent — bir kez yapilir)
        if (masterEl) mceUpgradeCombobox(masterEl);
        document.querySelectorAll('.mce-unit-code').forEach(function(sel) { mceUpgradeCombobox(sel); });

        // Mevcut combobox UI'lari yenile (option icerikleri degisti)
        if (masterEl) mceCbxRebuild(masterEl);
        document.querySelectorAll('.mce-unit-code').forEach(function(sel) { mceCbxRebuild(sel); });
    }

    /**
     * Native <select> elementini custom combobox UI'a sarar (idempotent).
     * Native select gizli kalir (form value icin), ustunde stillenebilir trigger + panel olusur.
     * Kullanim sonrasi sel.value'yu degistirmek istiyorsan mceCbxRebuild(sel) cagir.
     */
    function mceUpgradeCombobox(sel) {
        if (!sel || sel.dataset.cbxUpgraded === '1') return;
        sel.dataset.cbxUpgraded = '1';

        var wrapper = document.createElement('div');
        wrapper.className = 'mce-cbx';
        // Inherit width/style from select
        if (sel.style.maxWidth) wrapper.style.maxWidth = sel.style.maxWidth;
        sel.parentNode.insertBefore(wrapper, sel);
        wrapper.appendChild(sel);
        sel.style.display = 'none';
        sel.setAttribute('aria-hidden', 'true');

        var trigger = document.createElement('button');
        trigger.type = 'button';
        trigger.className = 'mce-cbx__trigger';
        trigger.innerHTML = '<span class="mce-cbx__label"></span><span class="mce-cbx__arrow">▾</span>';
        wrapper.appendChild(trigger);

        var panel = document.createElement('div');
        panel.className = 'mce-cbx__panel';
        panel.style.display = 'none';
        wrapper.appendChild(panel);

        function close() { panel.style.display = 'none'; trigger.classList.remove('is-open'); }
        function open() {
            // Onceki acik comboboxlari kapat
            document.querySelectorAll('.mce-cbx__trigger.is-open').forEach(function(t) {
                if (t !== trigger) {
                    t.classList.remove('is-open');
                    var sib = t.nextElementSibling;
                    if (sib && sib.classList.contains('mce-cbx__panel')) sib.style.display = 'none';
                }
            });
            mceCbxRebuild(sel);
            panel.style.display = 'block';
            trigger.classList.add('is-open');
        }

        trigger.addEventListener('click', function(e) {
            e.preventDefault();
            if (trigger.disabled) return;
            if (panel.style.display === 'block') close(); else open();
        });

        document.addEventListener('click', function(e) {
            if (!wrapper.contains(e.target)) close();
        });

        // ESC ile kapat
        wrapper.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') { close(); trigger.focus(); }
        });

        // Native select degistiginde label'i guncelle (programatik set destekli)
        sel.addEventListener('change', function() { mceCbxUpdateLabel(sel); });

        // is-invalid sinifi senkron tut
        var classObserver = new MutationObserver(function() {
            if (sel.classList.contains('is-invalid')) trigger.classList.add('is-invalid');
            else trigger.classList.remove('is-invalid');
        });
        classObserver.observe(sel, { attributes: true, attributeFilter: ['class'] });

        wrapper.dataset.cbxRoot = '1';
        mceCbxUpdateLabel(sel);
    }

    function mceCbxUpdateLabel(sel) {
        var wrapper = sel.parentElement;
        if (!wrapper || !wrapper.classList.contains('mce-cbx')) return;
        var label = wrapper.querySelector('.mce-cbx__label');
        if (!label) return;
        var opt = sel.options[sel.selectedIndex];
        var hasValue = opt && opt.value;
        label.textContent = hasValue ? opt.text : (sel.options[0] ? sel.options[0].text : 'Seciniz');
        if (hasValue) label.classList.remove('mce-cbx__label--placeholder');
        else label.classList.add('mce-cbx__label--placeholder');
    }

    /**
     * Combobox panelini yeniden cizer — option durumlari (used/inactive/selected) degistiyse
     * cagrilir (mceUnitRefreshSelects sonrasi vb.).
     */
    function mceCbxRebuild(sel) {
        var wrapper = sel.parentElement;
        if (!wrapper || !wrapper.classList.contains('mce-cbx')) return;
        var panel = wrapper.querySelector('.mce-cbx__panel');
        if (!panel) return;
        panel.innerHTML = '';
        Array.prototype.forEach.call(sel.options, function(opt) {
            var item = document.createElement('div');
            item.className = 'mce-cbx__option';
            if (!opt.value) item.classList.add('is-placeholder');
            if (opt.value === sel.value) item.classList.add('is-selected');
            // Native disabled = baska bir satir kullaniyor
            if (opt.disabled) item.classList.add('is-used');
            // Pasif birim
            if (opt.dataset && opt.dataset.inactive === 'true') item.classList.add('is-inactive');
            item.textContent = opt.text;
            item.addEventListener('click', function() {
                if (item.classList.contains('is-used') || item.classList.contains('is-inactive')) return;
                sel.value = opt.value;
                sel.dispatchEvent(new Event('change', { bubbles: true }));
                mceCbxUpdateLabel(sel);
                var trigger = wrapper.querySelector('.mce-cbx__trigger');
                if (trigger) trigger.classList.remove('is-open');
                panel.style.display = 'none';
            });
            panel.appendChild(item);
        });
        mceCbxUpdateLabel(sel);
    }

    function mceShowUnitWarning(msg) {
        var errDiv = document.getElementById('mceUnitError');
        if (!errDiv) return;
        errDiv.textContent = msg;
        errDiv.style.display = msg ? 'block' : 'none';
    }

    /**
     * Ana birim + birim 1..5 arasinda ayni olcu birimi iki kez secilemesin.
     * Her dropdown'in option'larini dolasip, baska bir satirda kullanilmis
     * option'lari (kendi secimi haric) disabled yapar.
     */
    function mceUnitRefreshSelects() {
        // Tum dropdown'lar UnitId (int) ile bind edildi — Ana Birim ve alternatler arasi
        // duplicate prevention yapilabilir.
        var usedIds = new Set();
        var masterEl = document.getElementById('mceUnitId');
        if (masterEl && masterEl.value) usedIds.add(masterEl.value);
        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!row) continue;
            var sel = row.querySelector('.mce-unit-code');
            if (sel && sel.value) usedIds.add(sel.value);
        }

        function updateSelect(sel) {
            if (!sel) return;
            var own = sel.value;
            Array.prototype.forEach.call(sel.options, function(opt) {
                if (!opt.value) { opt.disabled = false; return; }
                opt.disabled = (opt.value !== own) && usedIds.has(opt.value);
            });
            // Custom combobox panel'ini de yenile (disabled state degisti)
            if (typeof mceCbxRebuild === 'function') mceCbxRebuild(sel);
        }

        updateSelect(masterEl);
        for (var j = 1; j <= 5; j++) {
            var r2 = document.querySelector('[data-unit-line="' + j + '"]');
            if (!r2) continue;
            updateSelect(r2.querySelector('.mce-unit-code'));
        }

        // Satir aktifligi: ardisik kural
        mceUnitRefreshEnabledRows();
    }

    /**
     * Ardisik aktiflik: Birim N tanimlanmadan Birim N+1 pasif kalir.
     * "Tanimli" = kod dropdown'da secim yapilmis.
     */
    function mceUnitRefreshEnabledRows() {
        var prevFilled = true; // Birim 1 her zaman aktif
        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!row) continue;
            var codeEl = row.querySelector('.mce-unit-code');
            var multEl = row.querySelector('.mce-unit-mult');
            var shouldEnable = prevFilled;
            if (codeEl) codeEl.disabled = !shouldEnable;
            if (multEl) multEl.disabled = !shouldEnable;
            row.classList.toggle('mce-row-disabled', !shouldEnable);
            // Satir pasifse icerigini temizle (yanlis veri kalmasin)
            if (!shouldEnable) {
                if (codeEl) codeEl.value = '';
                if (multEl) { multEl.value = ''; multEl.classList.remove('is-invalid'); }
            }
            // Bir sonraki satir icin: bu satir hem aktif hem kod dolu olmali
            prevFilled = shouldEnable && !!(codeEl && codeEl.value);
        }
    }

    /**
     * Birim seçili ise carpan > 0 olmali.
     * Kod dolu ama carpan bos/0 ise input'a is-invalid class'i eklenir.
     */
    function mceUnitValidateRow(row) {
        if (!row) return true;
        var codeEl = row.querySelector('.mce-unit-code');
        var multEl = row.querySelector('.mce-unit-mult');
        if (!codeEl || !multEl) return true;
        var hasCode = !!codeEl.value;
        var mult = parseFloat(multEl.value) || 0;
        if (hasCode && mult <= 0) {
            multEl.classList.add('is-invalid');
            return false;
        }
        multEl.classList.remove('is-invalid');
        return true;
    }
    function mceUnitValidateAll() {
        var ok = true;
        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!mceUnitValidateRow(row)) ok = false;
        }
        return ok;
    }

    // Ölçü Birimleri "1 {satır birimi} = [çarpan] {ana birim}" oran etiketleri.
    // Çarpan salt sayı yerine okunur oran gösterir (örn. "1 kg = 5 ad"): satırın
    // birimi öneke, malzemenin ana birimi (Genel Bilgiler → #mceUnitId) çarpandan
    // sonraki soneke yazılır. Kod _availableUnits'ten id ile çözülür.
    function mceUnitCodeById(id) {
        if (!id) return '';
        var u = _availableUnits.find(function(x) { return String(x.id) === String(id); });
        return u ? (u.unitCode || '') : '';
    }
    window.mceUpdateUnitRatioLabels = function() {
        var masterEl = document.getElementById('mceUnitId');
        var baseCode = masterEl ? mceUnitCodeById(masterEl.value) : '';
        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!row) continue;
            var codeEl = row.querySelector('.mce-unit-code');
            var pre = row.querySelector('.mce-unit-prefix');
            var suf = row.querySelector('.mce-unit-suffix');
            var rowCode = codeEl ? mceUnitCodeById(codeEl.value) : '';
            if (pre) pre.textContent = '1 ' + (rowCode || 'birim') + ' =';
            if (suf) suf.textContent = baseCode || '—';
        }
    };

    window.mceUnitLoad = function() {
        // Kaydedilmis kayit varsa conversions da gelir; yeni kartta sadece availableUnits cekilir
        var url = currentId && currentId > 0
            ? '/Logistics/GetItemUnits?itemId=' + currentId
            : '/Logistics/GetItemUnits?itemId=0';
        fetch(url, { credentials: 'same-origin' })
            .then(function(r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function(data) {
                _availableUnits = data.availableUnits || [];
                console.log('[MCE] unitLoad: availableUnits=' + _availableUnits.length + ', conversions=' + (data.conversions || []).length);
                mceUnitPopulateSelects();

                // Ölçü birimi tanimli degilse kullaniciyi uyar
                if (_availableUnits.length === 0) {
                    mceShowUnitWarning('Hic aktif olcu birimi tanimlanmamis. Lutfen once Lojistik > Sabit Tanimlamalar > Olcu Birimleri ekranindan tanimlama yapiniz.');
                } else {
                    mceShowUnitWarning('');
                }

                // Master Items.UnitId'den geliyor — bu tab artik master row icermez.
                // Alternat satirlar UnitId (int) ile bind edilir.
                var conversions = data.conversions || [];
                for (var i = 1; i <= 5; i++) {
                    var row = document.querySelector('[data-unit-line="' + i + '"]');
                    if (!row) continue;
                    var conv = conversions.find(function(c) { return c.lineNo === i; });
                    row.querySelector('.mce-unit-code').value = conv ? String(conv.unitId) : '';
                    row.querySelector('.mce-unit-mult').value = conv ? conv.multiplier : '';
                }
                _unitLoaded = true;

                // Genel Bilgiler tab'indaki Ana Birim dropdown'i artik populate edildi —
                // populate() unitId set edilmek icin bekliyorsa simdi uygulansin.
                window._mceUnitsLoaded = true;
                if (window._mceApplyUnitId) { window._mceApplyUnitId(); window._mceApplyUnitId = null; }

                // Dropdown'larda tekrari engelle + change listener'lari bagla (bir kez)
                mceUnitRefreshSelects();
                mceUnitBindListenersOnce();
                window.mceUpdateUnitRatioLabels();
            })
            .catch(function(e) { console.error('[MCE] unit load error:', e); });
    };

    // Eager: sayfa acildiginda Ana Birim dropdown'i hemen dolsun
    // (Olcu Birimleri tab'ina tiklamayi beklemeden).
    console.log('[MCE] eager unit load triggered');
    window.mceUnitLoad();

    var _unitListenersBound = false;
    function mceUnitBindListenersOnce() {
        if (_unitListenersBound) return;
        _unitListenersBound = true;

        // Ana Birim degistiginde alternatlerin disabled state'ini yenile
        var masterEl = document.getElementById('mceUnitId');
        if (masterEl) {
            masterEl.addEventListener('change', function() { mceUnitRefreshSelects(); window.mceUpdateUnitRatioLabels(); });
        }

        // Her satir: kod degistiginde dropdown'lari yenile + carpana odaklan.
        // Anlik kirmizi uyari / titresim YOK — dogrulama Kaydet'te yapilir.
        for (var i = 1; i <= 5; i++) {
            (function(i) {
                var row = document.querySelector('[data-unit-line="' + i + '"]');
                if (!row) return;
                var codeEl = row.querySelector('.mce-unit-code');
                var multEl = row.querySelector('.mce-unit-mult');
                if (codeEl) {
                    codeEl.addEventListener('change', function() {
                        mceUnitRefreshSelects();
                        window.mceUpdateUnitRatioLabels();
                        // Onceden isaretlenmis is-invalid (kaydet sirasindan kalma) varsa temizle
                        if (multEl) multEl.classList.remove('is-invalid');
                        if (codeEl.value) {
                            // Kod secildiyse carpan 0 ise temizle ve odaklan
                            if (multEl && !parseFloat(multEl.value)) {
                                multEl.value = '';
                                multEl.focus();
                            }
                        } else {
                            // Kod temizlendiyse carpan da sifirlansin
                            if (multEl) multEl.value = '';
                        }
                    });
                }
                // Kullanici carpan yazarken onceki hata isaretini temizle
                if (multEl) {
                    multEl.addEventListener('input', function() {
                        if (parseFloat(multEl.value) > 0) multEl.classList.remove('is-invalid');
                    });
                }
            })(i);
        }
    }

    /**
     * Olcu birimlerini kaydeder. Promise (success: bool, message?: string) doner.
     * Genel Kaydet (mceSave) icinden cagrildigi icin buton referansi kullanilmaz.
     * stockCardId=0 ise (yeni kart, henuz kayit yok) atlar.
     */
    window.mceUnitSave = function() {
        var errDiv = document.getElementById('mceUnitError');
        if (errDiv) errDiv.style.display = 'none';

        if (!currentId || currentId <= 0) {
            return Promise.resolve({ success: true, skipped: true });
        }

        // Tum satirlari dogrula (carpan > 0 kurali)
        if (!mceUnitValidateAll()) {
            var msg0 = 'Olcu birimi secilen satirlarda carpan degeri sifirdan buyuk olmalidir.';
            if (errDiv) { errDiv.textContent = msg0; errDiv.style.display = 'block'; }
            return Promise.resolve({ success: false, message: msg0 });
        }

        // Birim satirlarindan data topla — master Items.UnitId'de tutuluyor, burada sadece alternatler.
        // Dropdown value'lari UnitId (int).
        var items = [];
        var usedIds = [];

        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!row) continue;
            var unitIdRaw = row.querySelector('.mce-unit-code').value;
            var mult = parseFloat(row.querySelector('.mce-unit-mult').value) || 0;
            if (!unitIdRaw) continue;
            var unitId = parseInt(unitIdRaw);
            if (usedIds.indexOf(unitId) !== -1) {
                var dupUnit = (_availableUnits.find(function(u) { return u.id === unitId; }) || {});
                var msg1 = 'Ayni olcu birimi birden fazla tanimlanamaz: ' + (dupUnit.unitCode || unitId);
                if (errDiv) { errDiv.textContent = msg1; errDiv.style.display = 'block'; }
                return Promise.resolve({ success: false, message: msg1 });
            }
            usedIds.push(unitId);
            if (mult <= 0) {
                var unitForMsg = (_availableUnits.find(function(u) { return u.id === unitId; }) || {});
                var msg2 = '"' + (unitForMsg.unitCode || unitId) + '" icin carpan degeri sifirdan buyuk olmalidir.';
                if (errDiv) { errDiv.textContent = msg2; errDiv.style.display = 'block'; }
                return Promise.resolve({ success: false, message: msg2 });
            }
            items.push({ unitId: unitId, multiplier: mult });
        }

        // Hic birim tanimlanmamissa sunucuya gitme (mevcut kayit varsa temizle:
        // yine de sunucuya bos items gonderip temizlenmesini saglayalim)
        var payload = {
            itemId: currentId,
            items: items.map(function(it) { return { unitId: it.unitId, multiplier: it.multiplier }; })
        };

        return fetch('/Logistics/SaveItemUnits', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success && errDiv) {
                errDiv.textContent = data.message || 'Olcu birimi kaydi hatali.';
                errDiv.style.display = 'block';
            }
            return data;
        })
        .catch(function(e) {
            var msg = 'Baglanti hatasi: ' + e.message;
            if (errDiv) { errDiv.textContent = msg; errDiv.style.display = 'block'; }
            return { success: false, message: msg };
        });
    };

    // ── Gruplar (5 seviyeli hiyerarsik gruplama) ───────────────────
    // entityType=1 (malzeme), level 1..5, parent_id ile cascade.
    // Endpoint'ler:
    //   GET /Definitions/GetCardGroups?cardType=1&level=N&parentId=P
    //   GET /Definitions/GetCardGroupMappings?entityType=1&entityId={itemId}
    //   POST /Definitions/SaveCardGroupMappings { entityType:1, entityId:itemId, mappings:[{level, cardGroupId}] }

    var _mceGroupsLoaded = false;
    var _mceGroupsState = {}; // { 1: [{id,code,description}], 2: [], ... }

    function mceGroupSelByLevel(level) {
        return document.querySelector('.mce-group-sel[data-level="' + level + '"]');
    }

    function mceGroupBuildOptions(level, items) {
        var sel = mceGroupSelByLevel(level);
        if (!sel) return;
        var prevValue = sel.value;
        var opts = '<option value="">Seciniz</option>';
        (items || []).forEach(function(g) {
            opts += '<option value="' + g.id + '">' + (g.code || '') + (g.description ? ' — ' + g.description : '') + '</option>';
        });
        sel.innerHTML = opts;
        // Mevcut secim listede varsa korunsun
        if (prevValue && Array.prototype.some.call(sel.options, function(o) { return o.value === prevValue; })) {
            sel.value = prevValue;
        }
        if (typeof mceUpgradeCombobox === 'function') mceUpgradeCombobox(sel);
        if (typeof mceCbxRebuild === 'function') mceCbxRebuild(sel);
    }

    function mceGroupClearLevels(fromLevel) {
        for (var lv = fromLevel; lv <= 5; lv++) {
            var sel = mceGroupSelByLevel(lv);
            if (!sel) continue;
            sel.innerHTML = '<option value="">Seciniz</option>';
            sel.value = '';
            _mceGroupsState[lv] = [];
            if (typeof mceCbxRebuild === 'function') mceCbxRebuild(sel);
        }
    }

    /**
     * Belirli bir level icin gruplari yukler. parentId null ise root level (1).
     */
    function mceGroupFetchLevel(level, parentId) {
        var url = '/Definitions/GetCardGroups?cardType=1&level=' + level;
        if (parentId) url += '&parentId=' + parentId;
        return fetch(url, { credentials: 'same-origin' })
            .then(function(r) { return r.ok ? r.json() : []; })
            .then(function(data) {
                var items = Array.isArray(data) ? data : (data.items || []);
                _mceGroupsState[level] = items;
                mceGroupBuildOptions(level, items);
                return items;
            })
            .catch(function(e) { console.error('[MCE] group fetch level=' + level + ':', e); return []; });
    }

    /**
     * Sayfa acilisinda Grup 1'i yukler ve mevcut mapping varsa cascade ile altlari da doldurur.
     */
    window.mceGroupsEnsureLoaded = function() {
        if (_mceGroupsLoaded) return;
        _mceGroupsLoaded = true;

        // Once Grup 1'i yukle
        mceGroupFetchLevel(1, null).then(function() {
            // Mevcut malzemenin atanmis gruplarini cek
            if (currentId && currentId > 0) {
                mceGroupLoadExistingMappings();
            }
        });
    };

    function mceGroupLoadExistingMappings() {
        var url = '/Definitions/GetCardGroupMappings?entityType=1&entityId=' + currentId;
        fetch(url, { credentials: 'same-origin' })
            .then(function(r) { return r.ok ? r.json() : []; })
            .then(function(data) {
                var mappings = Array.isArray(data) ? data : (data.items || data.mappings || []);
                // mappings: [{level, cardGroupId}, ...]
                var byLevel = {};
                mappings.forEach(function(m) { byLevel[m.level] = m.cardGroupId; });

                // Sirayla level 1..5 set et + bir sonraki level'i fetch et
                function applyLevel(lv) {
                    if (lv > 5) return Promise.resolve();
                    var sel = mceGroupSelByLevel(lv);
                    if (!sel) return Promise.resolve();
                    var val = byLevel[lv];
                    if (val) {
                        sel.value = String(val);
                        if (typeof mceCbxRebuild === 'function') mceCbxRebuild(sel);
                        // Bir sonraki level'i bu deger uzerinden fetch et
                        return mceGroupFetchLevel(lv + 1, val).then(function() { return applyLevel(lv + 1); });
                    }
                    return Promise.resolve();
                }

                applyLevel(1);
            })
            .catch(function(e) { console.error('[MCE] group mappings load:', e); });
    }

    // Grup dropdown'larina change listener bagla — cascade
    function mceGroupBindCascadeOnce() {
        if (window._mceGroupCascadeBound) return;
        window._mceGroupCascadeBound = true;
        for (var lv = 1; lv <= 5; lv++) {
            (function(level) {
                var sel = mceGroupSelByLevel(level);
                if (!sel) return;
                sel.addEventListener('change', function() {
                    var val = sel.value;
                    // Alt level'lari sifirla
                    mceGroupClearLevels(level + 1);
                    // Yeni level'i (level+1) fetch et
                    if (val && level < 5) {
                        mceGroupFetchLevel(level + 1, val);
                    }
                });
            })(lv);
        }
    }

    /**
     * Malzeme kartiyla birlikte secilen grup mapping'lerini kaydeder.
     * mceSave icinden cagrilir; itemId kayit sonrasi bilinir oluyorsa o degeri kullan.
     */
    window.mceGroupsSave = function(itemIdOverride) {
        var entityId = itemIdOverride || currentId;
        if (!entityId || entityId <= 0) return Promise.resolve({ success: true, skipped: true });

        // Eger Gruplar tab hic acilmadiysa (loaded false) gondermeye gerek yok —
        // mevcut mapping korunsun.
        if (!_mceGroupsLoaded) return Promise.resolve({ success: true, skipped: true });

        // Tum 5 level'i gonder (CardGroupId null = o seviyede secim yok = mevcut esleme silinir)
        var levels = [];
        for (var lv = 1; lv <= 5; lv++) {
            var sel = mceGroupSelByLevel(lv);
            if (!sel) continue;
            var v = sel.value;
            levels.push({ level: lv, cardGroupId: v ? parseInt(v) : null });
        }

        // CSRF token (AntiForgeryToken) — endpoint [ValidateAntiForgeryToken] ile korunuyor
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        var token = tokenEl ? tokenEl.value : '';

        var payload = { entityType: 1, entityId: String(entityId), levels: levels };
        return fetch('/Definitions/SaveCardGroupMappings', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json().catch(function() { return { success: r.ok }; }); })
        .catch(function(e) {
            console.error('[MCE] group save error:', e);
            return { success: false, message: e.message };
        });
    };

    // Cascade listener'lari sayfa acilisinda tek seferlik bagla
    mceGroupBindCascadeOnce();

    // ── Lokasyonlar ────────────────────────────────────────────────
    var _mceLocState = { links: [], available: [] };

    function mceLocEsc(s) {
        var d = document.createElement('div');
        d.textContent = s == null ? '' : String(s);
        return d.innerHTML;
    }
    function mceLocTypeLabel(code) {
        var map = { FACTORY: 'Fabrika', SECTION: 'Bölüm', SHELF: 'Raf', BIN: 'Hücre' };
        return map[code] || (code || '');
    }
    function mceLocSetError(msg) {
        var el = document.getElementById('mceLocError');
        if (!el) return;
        if (!msg) { el.style.display = 'none'; el.textContent = ''; return; }
        el.textContent = msg; el.style.display = 'block';
    }

    window.mceLocLoad = function() {
        if (!currentId || currentId <= 0) return Promise.resolve();
        mceLocSetError('');
        return fetch('/Logistics/GetItemLocations?itemId=' + currentId, { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                _mceLocState.links = (data && data.links) ? data.links.slice() : [];
                _mceLocState.available = (data && data.availableLocations) ? data.availableLocations.slice() : [];
                mceLocRenderPicker();
                mceLocRenderList();
            })
            .catch(function(e) { mceLocSetError('Lokasyon listesi yuklenemedi: ' + e.message); });
    };

    function mceLocRenderPicker() {
        var sel = document.getElementById('mceLocPick');
        if (!sel) return;
        var usedIds = {};
        _mceLocState.links.forEach(function(l) { usedIds[l.locationId] = true; });
        var options = ['<option value="">— Seçiniz —</option>'];
        _mceLocState.available.forEach(function(a) {
            if (usedIds[a.id]) return;
            var label = a.locationPath || (a.locationCode + (a.locationName ? ' — ' + a.locationName : ''));
            label += ' (' + mceLocTypeLabel(a.locationTypeCode) + ')';
            options.push('<option value="' + a.id + '">' + mceLocEsc(label) + '</option>');
        });
        sel.innerHTML = options.join('');
    }

    function mceLocRenderList() {
        var body = document.getElementById('mceLocListBody');
        var empty = document.getElementById('mceLocEmpty');
        var table = document.getElementById('mceLocListTable');
        var count = document.getElementById('mceLocCount');
        if (!body || !empty || !table) return;
        var links = _mceLocState.links;
        if (count) {
            var n = links.length;
            var newText = String(n);
            if (count.textContent !== newText) count.textContent = newText;
            count.classList.toggle('is-empty', n <= 0);
        }
        if (links.length === 0) {
            body.innerHTML = '';
            empty.style.display = '';
            table.style.display = 'none';
            return;
        }
        empty.style.display = 'none';
        table.style.display = '';
        body.innerHTML = links.map(function(l, idx) {
            var radio = '<label style="display:inline-flex;align-items:center;gap:6px;cursor:pointer;">' +
                '<input type="radio" name="mceLocDefault" ' + (l.isDefault ? 'checked' : '') + ' onchange="mceLocSetDefault(' + idx + ')" />' +
                (l.isDefault ? '<span style="color:#34d399;font-weight:600;font-size:.74rem;">Varsayılan</span>' : '<span style="color:rgba(255,255,255,.45);font-size:.74rem;">Ayarla</span>') +
                '</label>';
            var delBtn = '<button type="button" class="mce-btn mce-btn--danger" onclick="mceLocRemove(' + idx + ')" style="font-size:.72rem;padding:4px 10px;">Sil</button>';
            var pathCell = l.locationPath
                ? '<div style="font-size:.7rem;color:rgba(255,255,255,.4);margin-top:2px;">' + mceLocEsc(l.locationPath) + '</div>'
                : '';
            return '<tr>' +
                '<td class="mce-comb-td">' + radio + '</td>' +
                '<td class="mce-comb-td mce-comb-code">' + mceLocEsc(l.locationCode) + '</td>' +
                '<td class="mce-comb-td mce-comb-name">' + mceLocEsc(l.locationName || '') + pathCell + '</td>' +
                '<td class="mce-comb-td">' + mceLocEsc(mceLocTypeLabel(l.locationTypeCode)) + '</td>' +
                '<td class="mce-comb-td" style="text-align:right;">' + delBtn + '</td>' +
                '</tr>';
        }).join('');
    }

    window.mceLocAdd = function() {
        var sel = document.getElementById('mceLocPick');
        if (!sel) return;
        var locId = parseInt(sel.value, 10);
        if (!locId) { mceLocSetError('Lutfen bir lokasyon secin.'); return; }
        // Once eklenmis mi?
        if (_mceLocState.links.some(function(l) { return l.locationId === locId; })) {
            mceLocSetError('Bu lokasyon zaten eklenmis.');
            return;
        }
        mceLocSetError('');
        var avail = _mceLocState.available.find(function(a) { return a.id === locId; });
        if (!avail) return;
        // Ilk satirsa otomatik varsayilan
        var isFirst = _mceLocState.links.length === 0;
        _mceLocState.links.push({
            locationId: avail.id,
            locationCode: avail.locationCode,
            locationName: avail.locationName,
            locationTypeCode: avail.locationTypeCode,
            isDefault: isFirst,
            sortOrder: _mceLocState.links.length
        });
        sel.value = '';
        mceLocRenderPicker();
        mceLocRenderList();
        // Otomatik kaydet
        mceLocSave();
    };

    window.mceLocRemove = function(idx) {
        if (idx < 0 || idx >= _mceLocState.links.length) return;
        var removed = _mceLocState.links.splice(idx, 1)[0];
        // Silinen varsayilansa kalan ilk satiri varsayilan yap
        if (removed && removed.isDefault && _mceLocState.links.length > 0) {
            _mceLocState.links[0].isDefault = true;
        }
        mceLocRenderPicker();
        mceLocRenderList();
        mceLocSave();
    };

    window.mceLocSetDefault = function(idx) {
        if (idx < 0 || idx >= _mceLocState.links.length) return;
        _mceLocState.links.forEach(function(l, i) { l.isDefault = (i === idx); });
        mceLocRenderList();
        mceLocSave();
    };

    window.mceLocSave = function() {
        if (!currentId || currentId <= 0) return Promise.resolve({ success: true });
        mceLocSetError('');
        var payload = {
            itemId: currentId,
            items: _mceLocState.links.map(function(l) {
                return { locationId: l.locationId, isDefault: !!l.isDefault };
            })
        };
        return fetch('/Logistics/SaveItemLocations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (!d || !d.success) mceLocSetError(d && d.message ? d.message : 'Kaydedilemedi.');
            return d;
        })
        .catch(function(e) {
            mceLocSetError('Baglanti hatasi: ' + e.message);
            return { success: false };
        });
    };

    // ── Malzeme - Lokasyon eslestirmeleri ──────────────────────────
    // state: o anki kart icin secili lokasyon listesi — [{locationId, locationCode, locationName, locationTypeCode, isDefault, sortOrder}]
    var _mceLocLinks = [];
    var _mceLocAvailable = [];

    window.mceLocLoad = function() {
        var tbody = document.getElementById('mceLocListBody');
        var empty = document.getElementById('mceLocEmpty');
        var pickSel = document.getElementById('mceLocPick');
        var errDiv = document.getElementById('mceLocError');
        if (errDiv) errDiv.style.display = 'none';

        if (!currentId || currentId <= 0) {
            if (tbody) tbody.innerHTML = '';
            if (empty) { empty.style.display = 'block'; empty.textContent = 'Once malzeme kartini kaydediniz, sonra lokasyon ekleyebilirsiniz.'; }
            if (pickSel) pickSel.innerHTML = '<option value="">— Seciniz —</option>';
            _mceLocLinks = [];
            _mceLocAvailable = [];
            return;
        }

        fetch('/Logistics/GetItemLocations?itemId=' + currentId, { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                _mceLocLinks = (data && data.links) ? data.links.slice() : [];
                _mceLocAvailable = (data && data.availableLocations) ? data.availableLocations.slice() : [];
                mceLocRender();
            })
            .catch(function(e) {
                if (errDiv) {
                    errDiv.textContent = 'Lokasyonlar yuklenemedi: ' + e.message;
                    errDiv.style.display = 'block';
                }
            });
    };

    function mceLocTypeLabel(code) {
        if (!code) return '';
        var m = { FACTORY: 'Fabrika', SECTION: 'Bölüm', SHELF: 'Raf', BIN: 'Hücre', WAREHOUSE: 'Depo', FLOOR: 'Kat', AISLE: 'Koridor', BIN2: 'Göz' };
        return m[code.toUpperCase()] || code;
    }

    function mceLocRender() {
        var tbody = document.getElementById('mceLocListBody');
        var empty = document.getElementById('mceLocEmpty');
        var pickSel = document.getElementById('mceLocPick');
        var count = document.getElementById('mceLocCount');

        if (pickSel) {
            var taken = {};
            _mceLocLinks.forEach(function(l) { taken[l.locationId] = true; });
            var opts = ['<option value="">— Seciniz —</option>'];
            _mceLocAvailable.forEach(function(a) {
                if (taken[a.id]) return;
                var label = (a.locationCode || '') + (a.locationName ? ' — ' + a.locationName : '');
                opts.push('<option value="' + a.id + '">' + label + '</option>');
            });
            pickSel.innerHTML = opts.join('');
        }

        if (!tbody) return;
        if (_mceLocLinks.length === 0) {
            tbody.innerHTML = '';
            if (empty) { empty.style.display = 'block'; empty.textContent = 'Henuz atanmis lokasyon yok.'; }
            if (count) { count.style.display = 'none'; count.textContent = '0'; }
            return;
        }
        if (empty) empty.style.display = 'none';
        if (count) { count.style.display = 'inline-block'; count.textContent = String(_mceLocLinks.length); }

        tbody.innerHTML = _mceLocLinks.map(function(l, idx) {
            var def = l.isDefault ? 'checked' : '';
            var minVal = (l.minStock != null ? l.minStock : 0);
            return '<tr>' +
                '<td class="mce-comb-td" style="text-align:center;">' +
                    '<input type="radio" name="mceLocDefault" ' + def + ' onchange="mceLocSetDefault(' + idx + ')" title="Varsayilan yap" />' +
                '</td>' +
                '<td class="mce-comb-td" style="font-family:monospace;">' + (l.locationCode || '') + '</td>' +
                '<td class="mce-comb-td">' + (l.locationName || '') + '</td>' +
                '<td class="mce-comb-td">' + mceLocTypeLabel(l.locationTypeCode) + '</td>' +
                '<td class="mce-comb-td" style="text-align:right;">' +
                    '<input type="number" step="any" min="0" value="' + minVal + '" onchange="mceLocSetMin(' + idx + ', this.value)" class="mce-input mce-no-negative" style="width:96px;text-align:right;font-size:.76rem;padding:3px 6px;" />' +
                '</td>' +
                '<td class="mce-comb-td" style="text-align:center;">' +
                    '<button type="button" class="mce-btn mce-btn--danger" onclick="mceLocRemove(' + idx + ')" style="padding:3px 10px;font-size:.72rem;">Kaldir</button>' +
                '</td>' +
            '</tr>';
        }).join('');
    }

    window.mceLocAdd = function() {
        var pickSel = document.getElementById('mceLocPick');
        var errDiv = document.getElementById('mceLocError');
        if (errDiv) errDiv.style.display = 'none';
        var id = pickSel ? parseInt(pickSel.value, 10) : NaN;
        if (!id) {
            if (errDiv) { errDiv.textContent = 'Once bir lokasyon seciniz.'; errDiv.style.display = 'block'; }
            return;
        }
        if (_mceLocLinks.some(function(l) { return l.locationId === id; })) {
            if (errDiv) { errDiv.textContent = 'Bu lokasyon zaten eklenmis.'; errDiv.style.display = 'block'; }
            return;
        }
        var found = _mceLocAvailable.find(function(a) { return a.id === id; });
        if (!found) return;
        var isDefault = _mceLocLinks.length === 0;
        _mceLocLinks.push({
            locationId: found.id,
            locationCode: found.locationCode,
            locationName: found.locationName,
            locationTypeCode: found.locationTypeCode,
            isDefault: isDefault,
            minStock: 0,
            sortOrder: _mceLocLinks.length
        });
        mceLocRender();
    };

    window.mceLocRemove = function(idx) {
        if (idx < 0 || idx >= _mceLocLinks.length) return;
        var removed = _mceLocLinks.splice(idx, 1)[0];
        if (removed && removed.isDefault && _mceLocLinks.length > 0) {
            _mceLocLinks[0].isDefault = true;
        }
        mceLocRender();
    };

    window.mceLocSetDefault = function(idx) {
        _mceLocLinks.forEach(function(l, i) { l.isDefault = (i === idx); });
        mceLocRender();
    };

    window.mceLocSetMin = function(idx, val) {
        if (idx < 0 || idx >= _mceLocLinks.length) return;
        var n = parseFloat(val);
        _mceLocLinks[idx].minStock = (isNaN(n) || n < 0) ? 0 : n;
    };

    // ── Belge Kilitleri (planlama) ─────────────────────────────────
    var _mceDocLockTypes = [
        { code: 'satis_teklifi',  label: 'Satış Teklifi' },
        { code: 'satis_siparisi', label: 'Satış Siparişi' },
        { code: 'alis_talebi',    label: 'Alış Talebi' },
        { code: 'alis_teklifi',   label: 'Alış Teklifi' },
        { code: 'alis_siparisi',  label: 'Alış Siparişi' },
        { code: 'depo_giris',     label: 'Depo Giriş' },
        { code: 'depo_cikis',     label: 'Depo Çıkış' },
        { code: 'depo_transfer',  label: 'Depo Transfer' },
        { code: 'sayim',          label: 'Sayım' }
    ];
    var _mceDocLocks = {};

    window.mceDocLockLoad = function() {
        if (!currentId || currentId <= 0) { _mceDocLocks = {}; mceDocLockRender(); return; }
        fetch('/Logistics/GetItemDocumentLocks?itemId=' + currentId, { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                _mceDocLocks = {};
                var arr = (data && data.docTypes) ? data.docTypes : [];
                arr.forEach(function(c) { _mceDocLocks[c] = true; });
                mceDocLockRender();
            })
            .catch(function(e) {
                var err = document.getElementById('mceDocLockError');
                if (err) { err.textContent = 'Belge kilitleri yuklenemedi: ' + e.message; err.style.display = 'block'; }
            });
    };

    function mceDocLockRender() {
        var grid = document.getElementById('mceDocLockGrid');
        if (!grid) return;
        grid.innerHTML = _mceDocLockTypes.map(function(t) {
            var on = !!_mceDocLocks[t.code];
            return '<div style="display:flex;align-items:center;justify-content:space-between;gap:10px;padding:8px 12px;border-radius:8px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);">' +
                '<span style="font-size:.8rem;color:rgba(226,232,240,.9);">' + t.label + '</span>' +
                '<label class="mce-switch">' +
                    '<input type="checkbox" ' + (on ? 'checked' : '') + ' onchange="mceDocLockToggle(\'' + t.code + '\', this.checked)" />' +
                    '<span class="mce-switch-track"></span>' +
                '</label>' +
            '</div>';
        }).join('');
    }

    window.mceDocLockToggle = function(code, checked) {
        if (checked) _mceDocLocks[code] = true;
        else delete _mceDocLocks[code];
    };

    window.mceDocLockSave = function() {
        if (!currentId || currentId <= 0) return Promise.resolve({ success: true, skipped: true });
        var codes = Object.keys(_mceDocLocks).filter(function(c) { return _mceDocLocks[c]; });
        return fetch('/Logistics/SaveItemDocumentLocks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ itemId: currentId, docTypes: codes })
        })
        .then(function(r) { return r.json(); })
        .then(function(d) { return d || { success: false }; })
        .catch(function(e) { return { success: false, message: e.message }; });
    };

    /**
     * Lokasyonlari kaydeder. Promise (success, message?) doner.
     * Ana mceSave icinden cagrildigi icin buton referansi kullanilmaz.
     */
    window.mceLocSave = function() {
        var errDiv = document.getElementById('mceLocError');
        if (errDiv) errDiv.style.display = 'none';

        if (!currentId || currentId <= 0) {
            return Promise.resolve({ success: true, skipped: true });
        }

        var payload = {
            itemId: currentId,
            items: _mceLocLinks.map(function(l, i) {
                return { locationId: l.locationId, isDefault: !!l.isDefault, sortOrder: i, minStock: parseFloat(l.minStock) || 0 };
            })
        };

        return fetch('/Logistics/SaveItemLocations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success && errDiv) {
                errDiv.textContent = data.message || 'Lokasyon kaydi hatali.';
                errDiv.style.display = 'block';
            }
            return data;
        })
        .catch(function(e) {
            var msg = 'Baglanti hatasi: ' + e.message;
            if (errDiv) { errDiv.textContent = msg; errDiv.style.display = 'block'; }
            return { success: false, message: msg };
        });
    };

    // ── Fiyatlar sekmesi — genel liste (default) hedefli, tarih+doviz+alis/satis ──
    // Baz urun fiyati (ConfigId=null). SaveBulkPriceEntries ile idempotent upsert.
    var _mcePriceInited = false;
    var _mcePriceGroups = [];

    window.mcePriceActivate = function() {
        var needsSave = document.getElementById('mcePriceNeedsSave');
        var body = document.getElementById('mcePriceBody');
        if (!(currentId > 0)) {
            if (needsSave) needsSave.style.display = '';
            if (body) body.style.display = 'none';
            return;
        }
        if (needsSave) needsSave.style.display = 'none';
        if (body) body.style.display = '';
        if (_mcePriceInited) { mcePriceLoadList(); return; }
        _mcePriceInited = true;

        var dateEl = document.getElementById('mcePriceDate');
        if (dateEl && !dateEl.value) dateEl.value = new Date().toISOString().split('T')[0];

        Promise.all([
            fetch('/PriceList/GetAllPriceGroups', { credentials: 'same-origin' }).then(function(r){ return r.json(); }),
            fetch('/PriceList/GetCurrencies', { credentials: 'same-origin' }).then(function(r){ return r.json(); })
        ]).then(function(res) {
            _mcePriceGroups = res[0] || [];
            var gsel = document.getElementById('mcePriceGroup');
            if (gsel) {
                gsel.innerHTML = '';
                var defaultGroup = _mcePriceGroups.filter(function(g){ return g.isDefault; })[0];
                // "Genel Fiyat Listesi" secenegi HER ZAMAN ilk sirada. Genel liste henuz yoksa
                // '__ensure__' sentinel'i; ilk fiyat kaydinda kod otomatik olusturulur.
                var og = document.createElement('option');
                og.value = defaultGroup ? String(defaultGroup.id) : '__ensure__';
                og.textContent = 'Genel Fiyat Listesi';
                og.selected = true;
                gsel.appendChild(og);
                _mcePriceGroups.forEach(function(g) {
                    if (g.isDefault) return; // genel zaten ustte
                    var o = document.createElement('option');
                    o.value = String(g.id); o.textContent = g.name;
                    gsel.appendChild(o);
                });
            }
            var csel = document.getElementById('mcePriceCurrency');
            var fcur = document.getElementById('mcePriceFltCur');
            (res[1] || []).forEach(function(c) {
                if (csel) { var o = document.createElement('option'); o.value = c.id; o.textContent = c.code || c.name; csel.appendChild(o); }
                if (fcur) { var o2 = document.createElement('option'); o2.value = c.id; o2.textContent = c.code || c.name; fcur.appendChild(o2); }
            });
            mcePriceRefresh();
        }).catch(function(){});
    };

    // Grup degisince: tip kisidi (allowsBuying/Selling) + prefill + liste
    window.mcePriceRefresh = function() {
        var gsel = document.getElementById('mcePriceGroup');
        var g = _mcePriceGroups.filter(function(x){ return String(x.id) === String(gsel && gsel.value); })[0];
        var buyEl = document.getElementById('mcePriceBuy');
        var sellEl = document.getElementById('mcePriceSell');
        if (g) {
            if (buyEl)  { buyEl.disabled  = !g.allowsBuying;  if (!g.allowsBuying)  buyEl.value  = ''; }
            if (sellEl) { sellEl.disabled = !g.allowsSelling; if (!g.allowsSelling) sellEl.value = ''; }
        }
        mcePricePrefill();
        mcePriceLoadList();
    };

    // Doviz/tarih degisince: mevcut alis+satis fiyatini forma on-doldur (varsa duzenleme)
    window.mcePricePrefill = function() {
        var groupId = parseInt((document.getElementById('mcePriceGroup') || {}).value) || 0;
        var currencyId = parseInt((document.getElementById('mcePriceCurrency') || {}).value) || 0;
        var validOn = (document.getElementById('mcePriceDate') || {}).value || new Date().toISOString().split('T')[0];
        if (!(groupId > 0) || !(currencyId > 0)) return;
        ['b','s'].forEach(function(pt) {
            fetch('/PriceList/GetExistingPrices', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
                body: JSON.stringify({ groupId: groupId, currencyId: currencyId, priceType: pt, validFrom: validOn, keys: [{ itemId: currentId, configId: null }] })
            }).then(function(r){ return r.json(); }).then(function(rows) {
                var price = (rows && rows[0]) ? rows[0].price : null;
                var el = document.getElementById(pt === 'b' ? 'mcePriceBuy' : 'mcePriceSell');
                if (el && !el.disabled) el.value = (price != null ? price : '');
            }).catch(function(){});
        });
    };

    window.mcePriceSave = function() {
        var groupVal = (document.getElementById('mcePriceGroup') || {}).value || '';
        var currencyId = parseInt((document.getElementById('mcePriceCurrency') || {}).value) || 0;
        var validOn = (document.getElementById('mcePriceDate') || {}).value || '';
        var buyEl = document.getElementById('mcePriceBuy');
        var sellEl = document.getElementById('mcePriceSell');
        var msg = document.getElementById('mcePriceMsg');
        var btn = document.getElementById('mcePriceSaveBtn');
        function showMsg(t, ok) { if (msg) { msg.style.display = ''; msg.textContent = t; msg.style.color = ok ? '#059669' : '#dc2626'; } }
        function unlock() { if (btn) btn.disabled = false; }

        if (!(currentId > 0)) { showMsg('Önce malzeme kartını kaydedin.', false); return; }
        if (!(currencyId > 0)) { showMsg('Döviz seçin.', false); return; }
        if (!validOn) { showMsg('Geçerlilik tarihi girin.', false); return; }
        var buy = (buyEl && !buyEl.disabled && buyEl.value !== '') ? parseFloat(buyEl.value) : null;
        var sell = (sellEl && !sellEl.disabled && sellEl.value !== '') ? parseFloat(sellEl.value) : null;
        if (buy == null && sell == null) { showMsg('En az bir fiyat (alış veya satış) girin.', false); return; }

        if (btn) btn.disabled = true;

        // Genel liste henuz yoksa (__ensure__) kod OTOMATIK olusturulur → gercek groupId doner.
        function withGroup(cb) {
            if (groupVal === '__ensure__') {
                fetch('/PriceList/EnsureDefaultPriceGroup', { method: 'POST', credentials: 'same-origin' })
                    .then(function(r){ return r.json(); })
                    .then(function(d){ if (d && d.success && d.groupId) cb(d.groupId, true); else { showMsg((d && d.message) || 'Genel liste oluşturulamadı.', false); unlock(); } })
                    .catch(function(){ showMsg('Genel liste oluşturulamadı.', false); unlock(); });
            } else {
                var gid = parseInt(groupVal) || 0;
                if (gid > 0) cb(gid, false); else { showMsg('Fiyat listesi seçin.', false); unlock(); }
            }
        }

        withGroup(function(groupId, created) {
            function postBulk(pt, price) {
                return fetch('/PriceList/SaveBulkPriceEntries', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
                    body: JSON.stringify({ groupId: groupId, currencyId: currencyId, priceType: pt, validFrom: validOn, validTo: null, lines: [{ itemId: currentId, configId: null, price: price }] })
                }).then(function(r){ return r.json(); });
            }
            var calls = [];
            if (buy != null)  calls.push(postBulk('b', buy));
            if (sell != null) calls.push(postBulk('s', sell));
            Promise.all(calls).then(function(results) {
                var failed = results.filter(function(d){ return !d || d.success === false; });
                if (failed.length) showMsg((failed[0] && failed[0].message) || 'Fiyat kaydı başarısız.', false);
                else showMsg('Fiyat kaydedildi.', true);
                if (created) { _mcePriceInited = false; mcePriceActivate(); } // yeni genel liste → dropdown+liste yenile
                else mcePriceLoadList();
            }).catch(function(e){ showMsg('Bağlantı hatası: ' + e.message, false); })
              .then(unlock);
        });
    };

    window.mcePriceLoadList = function() {
        var groupVal = (document.getElementById('mcePriceGroup') || {}).value || '';
        var listEl = document.getElementById('mcePriceList');
        if (!listEl) return;
        if (!(currentId > 0)) { listEl.innerHTML = ''; return; }
        if (groupVal === '__ensure__') {
            listEl.innerHTML = '<div class="mcp-empty">Genel fiyat listesi henüz oluşturulmadı. İlk fiyatı kaydettiğinizde otomatik oluşur.</div>';
            var cnt0 = document.getElementById('mcePriceCount'); if (cnt0) { cnt0.textContent = '0'; cnt0.classList.add('is-empty'); }
            return;
        }
        var groupId = parseInt(groupVal) || 0;
        if (!(groupId > 0)) { listEl.innerHTML = ''; return; }
        listEl.innerHTML = '<div class="mcp-empty">Yükleniyor…</div>';

        var url = '/PriceList/GetPriceListEntries?groupId=' + groupId + '&itemId=' + currentId + '&pageSize=500';
        // Tarih modu: 'range' → ValidFrom aralığı; 'ason' → tek tarihte YÜRÜRLÜKTEKİ fiyat (ActiveOn)
        var mode = (document.getElementById('mcePriceFltMode') || {}).value || 'range';
        if (mode === 'ason') {
            var fActive = (document.getElementById('mcePriceFltActive') || {}).value || '';
            if (fActive) url += '&activeOn=' + fActive;
        } else {
            var fFrom = (document.getElementById('mcePriceFltFrom') || {}).value || '';
            var fTo   = (document.getElementById('mcePriceFltTo')   || {}).value || '';
            if (fFrom) url += '&validFromMin=' + fFrom;
            if (fTo)   url += '&validFromMax=' + fTo;
        }
        var fCur  = (document.getElementById('mcePriceFltCur')  || {}).value || '';
        var fType = (document.getElementById('mcePriceFltType') || {}).value || '';
        if (fCur)  url += '&currencyId=' + fCur;
        if (fType) url += '&priceType='  + fType;

        fetch(url, { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(data) {
                var items = (data && data.items) || [];
                var cntEl = document.getElementById('mcePriceCount');
                if (cntEl) { cntEl.textContent = items.length; if (items.length) cntEl.classList.remove('is-empty'); else cntEl.classList.add('is-empty'); }
                if (!items.length) { listEl.innerHTML = '<div class="mcp-empty">Seçilen filtrede kayıtlı fiyat bulunmuyor.</div>'; return; }
                var rows = items.map(function(e) {
                    var isBuy = e.priceType === 'b', isSell = e.priceType === 's';
                    var typeLabel = isBuy ? 'Alış' : (isSell ? 'Satış' : 'Maliyet');
                    var badgeBg = isBuy ? 'rgba(245,158,11,.16)' : (isSell ? 'rgba(16,185,129,.16)' : 'rgba(148,163,184,.16)');
                    var badgeFg = isBuy ? '#b45309' : (isSell ? '#047857' : '#475569');
                    var priceTxt = Number(e.price).toLocaleString('tr-TR', { minimumFractionDigits: 2 });
                    return '<tr>' +
                        '<td><span class="mcp-badge" style="background:' + badgeBg + ';color:' + badgeFg + ';">' + typeLabel + '</span></td>' +
                        '<td class="mcp-num">' + priceTxt + '</td>' +
                        '<td>' + (e.currencyCode || '') + '</td>' +
                        '<td>' + (e.validFrom || '') + '</td>' +
                        '<td>' + (e.validTo || '<span style="opacity:.5;">süresiz</span>') + '</td>' +
                        '<td style="text-align:right;"><button type="button" class="mce-btn mce-btn--danger" style="padding:3px 10px;font-size:.7rem;" onclick="mcePriceDelete(' + e.id + ')">Sil</button></td>' +
                        '</tr>';
                }).join('');
                listEl.innerHTML = '<div style="overflow-x:auto;"><table class="mcp-table">' +
                    '<thead><tr><th>Tip</th><th class="mcp-num">Fiyat</th><th>Döviz</th><th>Geçerlilik Baş.</th><th>Bitiş</th><th></th></tr></thead>' +
                    '<tbody>' + rows + '</tbody></table></div>';
            }).catch(function(){ listEl.innerHTML = '<div class="mcp-empty" style="color:#dc2626;">Fiyatlar yüklenemedi.</div>'; });
    };

    // Tarih filtresi modu: Aralık ↔ Belirli Tarih (ActiveOn) input gruplarını değiştir
    window.mcePriceModeChange = function() {
        var mode = (document.getElementById('mcePriceFltMode') || {}).value || 'range';
        var range = document.getElementById('mcePriceRangeInputs');
        var ason  = document.getElementById('mcePriceAsonInputs');
        if (range) range.style.display = (mode === 'range') ? 'inline-flex' : 'none';
        if (ason)  ason.style.display  = (mode === 'ason')  ? 'inline-flex' : 'none';
        mcePriceLoadList();
    };

    window.mcePriceDelete = function(id) {
        if (!id) return;
        fetch('/PriceList/DeletePriceListJson?id=' + id, { method: 'POST', credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(){ mcePriceLoadList(); mcePricePrefill(); })
            .catch(function(){});
    };

    // ── Ozellik Eslestirme (Kombinasyon Takibi acik iken) ──────────
    function featureEsc(s) {
        var d = document.createElement('div');
        d.textContent = s == null ? '' : String(s);
        return d.innerHTML;
    }

    // Per-feature allowedValueIds state — DOM'dan bagimsiz tutar
    window.__mceFeatureAllowed = window.__mceFeatureAllowed || {};
    // Per-feature usedValueIds (aktif kombinasyonda kullanilan, kilitli) — server'dan
    window.__mceFeatureUsedValueIds = window.__mceFeatureUsedValueIds || {};
    // Stogun aktif kombinasyon sayisi — yeni ozellik eklerken uyari icin
    window.__mceCombinationCount = 0;

    window.mceFeatureLoad = function() {
        if (!currentId || currentId <= 0) return;
        var listEl = document.getElementById('mceFeaturesList');
        var emptyEl = document.getElementById('mceFeaturesEmpty');
        var errEl = document.getElementById('mceFeaturesError');
        var okEl = document.getElementById('mceFeaturesOk');
        if (errEl) errEl.style.display = 'none';
        if (okEl) okEl.style.display = 'none';
        if (listEl) listEl.innerHTML = '<div style="padding:12px;color:rgba(255,255,255,.35);font-size:.8rem;">Yukleniyor...</div>';

        fetch('/Logistics/GetStockFeatures?stockCardId=' + currentId, { credentials: 'same-origin' })
            .then(function(r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function(data) {
                var features = (data && data.features) || [];
                var headerEl = document.getElementById('mceFeaturesHeader');
                if (features.length === 0) {
                    if (listEl) listEl.innerHTML = '';
                    if (emptyEl) emptyEl.style.display = '';
                    if (headerEl) headerEl.style.display = 'none';
                    updateFeatureCount(0, 0);
                    return;
                }
                if (emptyEl) emptyEl.style.display = 'none';
                if (headerEl) headerEl.style.display = 'flex';

                // Allowed degerleri ve kombinasyon-kilitli value'lari local state'e yaz
                window.__mceFeatureAllowed = {};
                window.__mceFeatureUsedValueIds = {};
                features.forEach(function (f) {
                    window.__mceFeatureAllowed[f.id] = (f.allowedValueIds || []).slice();
                    window.__mceFeatureUsedValueIds[f.id] = (f.usedValueIds || []).slice();
                });
                window.__mceCombinationCount = parseInt(data.combinationCount || 0, 10);

                // Veri tipi Turkcelestirme: server'dan gelen "TEXT/NUMBER/DATE" -> "Metin/Sayisal/Tarih"
                function mceDataTypeTr(dt) {
                    var v = (dt || '').toString().toUpperCase();
                    if (v === 'TEXT')   return 'Metin';
                    if (v === 'NUMBER' || v === 'NUMERIC') return 'Sayısal';
                    if (v === 'DATE')   return 'Tarih';
                    return dt || '';
                }
                var featuresHtml = features.map(function(f) {
                    var checked = f.linked ? 'checked' : '';
                    var chkId = 'mceFeatChk_' + f.id;
                    var printId = 'mceFeatPrint_' + f.id;
                    var printChecked = (f.printDescription !== false) ? 'checked' : '';
                    var printDisabled = f.linked ? '' : 'disabled';
                    var printWrapOpacity = f.linked ? '1' : '0.35';
                    var lockDueToCombo = f.inUseInCombination === true;
                    var linkDisabled = lockDueToCombo ? 'disabled' : '';
                    var linkTitle = lockDueToCombo ? 'Bu ozellik aktif kombinasyon(lar)da kullaniliyor — kaldirilamaz' : '';
                    var lockBadge = lockDueToCombo
                        ? '<span class="mce-feat-comb-badge" data-feature-id="' + f.id + '" role="button" tabindex="0" style="margin-left:8px;font-size:.62rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fbbf24;background:rgba(251,191,36,0.10);border:1px solid rgba(251,191,36,0.25);padding:2px 6px;border-radius:999px;cursor:pointer;user-select:none;transition:background .12s,border-color .12s;" title="Tikla: bu ozellik hangi kombinasyon(lar)da kullaniliyor?">🔒 Kombinasyonda</span>'
                        : '';
                    var availVals = Array.isArray(f.availableValues) ? f.availableValues : [];
                    // Bu feature'in available value'larini local cache'e koy (rehber acildiginda kullanilacak)
                    window.__mceFeatureValues = window.__mceFeatureValues || {};
                    window.__mceFeatureValues[f.id] = availVals;
                    var allowed = window.__mceFeatureAllowed[f.id] || [];
                    var allowedCnt = allowed.length;
                    var hasValues = availVals.length > 0;
                    // "Degerler" butonu yalnizca "Secili" toggle ON iken aktif olmali — kapaliyken
                    // atanan degerler zaten mceFeatureSave tarafindan gonderilmiyor (sadece :checked
                    // feature'lar siralanir). Kullaniciyi yanlis his vermesin diye disable ediyoruz.
                    var valuesDisabled = !f.linked;
                    var valuesBtnAttrs = valuesDisabled
                        ? ' disabled aria-disabled="true" title="Once \'Secili\' anahtarini aciniz" style="opacity:.4;cursor:not-allowed;"'
                        : '';
                    var valuesBtnHtml = hasValues
                        ? ('<button type="button" class="mce-feat-values-btn" data-feature-id="' + f.id + '"' + valuesBtnAttrs + '>' +
                            '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>' +
                            ' Degerler' + (allowedCnt > 0 ? ' (' + allowedCnt + ')' : '') +
                            '</button>')
                        : '';
                    return '' +
                        '<div class="mce-feature-row" style="display:flex;align-items:center;gap:14px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);transition:background .12s;">' +
                            '<div style="flex:1;min-width:0;">' +
                                '<div style="font-size:.86rem;font-weight:600;color:rgba(255,255,255,.85);display:flex;align-items:center;flex-wrap:wrap;">' + featureEsc(f.name) + lockBadge + '</div>' +
                                '<div style="font-size:.7rem;color:rgba(255,255,255,.4);margin-top:2px;">' +
                                    featureEsc(f.code || '') +
                                    (f.dataType ? ' · <span style="color:#a5b4fc;">' + featureEsc(mceDataTypeTr(f.dataType)) + '</span>' : '') +
                                    (f.unitOfMeasure ? ' · ' + featureEsc(f.unitOfMeasure) : '') +
                                '</div>' +
                            '</div>' +
                            valuesBtnHtml +
                            '<div style="width:80px;display:flex;align-items:center;justify-content:center;" title="' + linkTitle + '">' +
                                '<label class="mce-switch' + (lockDueToCombo ? ' is-locked' : '') + '" for="' + chkId + '">' +
                                    '<input type="checkbox" id="' + chkId + '" class="mce-feature-chk" data-feature-id="' + f.id + '" ' + checked + ' ' + linkDisabled + ' />' +
                                    '<span class="mce-switch-track"></span>' +
                                '</label>' +
                            '</div>' +
                            '<div data-print-wrap="' + f.id + '" style="min-width:160px;display:flex;align-items:center;justify-content:center;opacity:' + printWrapOpacity + ';transition:opacity .15s;" title="Bu ozellik secimine ait aciklama dizaynda basilsin">' +
                                '<label class="mce-switch" for="' + printId + '">' +
                                    '<input type="checkbox" id="' + printId + '" class="mce-feature-print-chk" data-feature-id="' + f.id + '" ' + printChecked + ' ' + printDisabled + ' />' +
                                    '<span class="mce-switch-track"></span>' +
                                '</label>' +
                            '</div>' +
                        '</div>';
                }).join('');
                if (listEl) listEl.innerHTML = featuresHtml;

                document.querySelectorAll('#mceFeaturesList .mce-feature-chk').forEach(function(linkChk) {
                    // wasLinked: server'dan gelen baslangic durumu — toggle ON ise "yeni ekleme" sayilmaz
                    linkChk.dataset.wasLinked = linkChk.checked ? '1' : '0';

                    // "Degerler" butonu da Secili toggle'a bagli enable/disable olmali —
                    // print-toggle ile ayni paterni izleyelim.
                    function syncValuesBtn(enabled) {
                        var id = linkChk.getAttribute('data-feature-id');
                        var valBtn = document.querySelector('#mceFeaturesList .mce-feat-values-btn[data-feature-id="' + id + '"]');
                        if (!valBtn) return;
                        valBtn.disabled = !enabled;
                        valBtn.setAttribute('aria-disabled', enabled ? 'false' : 'true');
                        if (enabled) {
                            valBtn.style.opacity = '';
                            valBtn.style.cursor = '';
                            valBtn.removeAttribute('title');
                        } else {
                            valBtn.style.opacity = '.4';
                            valBtn.style.cursor = 'not-allowed';
                            valBtn.title = 'Once \'Secili\' anahtarini aciniz';
                        }
                    }

                    linkChk.addEventListener('change', function() {
                        var id = linkChk.getAttribute('data-feature-id');
                        var printChk = document.getElementById('mceFeatPrint_' + id);
                        var wrap = document.querySelector('[data-print-wrap="' + id + '"]');

                        // Yeni ozellik ekleme uyarisi: zaten kombinasyon varsa + bu yeni ekleme ise (was=0 → check=1)
                        var wasLinked = linkChk.dataset.wasLinked === '1';
                        var isNewLink = !wasLinked && linkChk.checked;
                        if (isNewLink && (window.__mceCombinationCount || 0) > 0) {
                            var fname = (linkChk.closest('.mce-feature-row') || {}).querySelector
                                ? linkChk.closest('.mce-feature-row').querySelector('div > div').textContent
                                : ('#' + id);
                            mceFeatAddWarnShow(window.__mceCombinationCount, fname.trim(),
                                function() {
                                    // Devam Et — toggle aciyor kalmasin
                                    linkChk.dataset.wasLinked = '1';
                                    if (printChk && wrap) {
                                        printChk.disabled = false;
                                        wrap.style.opacity = '1';
                                    }
                                    syncValuesBtn(true);
                                },
                                function() {
                                    // Vazgec — toggle'i geri al
                                    linkChk.checked = false;
                                    if (printChk && wrap) {
                                        printChk.disabled = true;
                                        wrap.style.opacity = '0.35';
                                    }
                                    syncValuesBtn(false);
                                });
                            return;
                        }

                        if (printChk && wrap) {
                            printChk.disabled = !linkChk.checked;
                            wrap.style.opacity = linkChk.checked ? '1' : '0.35';
                        }
                        syncValuesBtn(linkChk.checked);
                    });
                });

                // Degerler rehber butonu — modal ac (Secili toggle ON ise)
                document.querySelectorAll('#mceFeaturesList .mce-feat-values-btn').forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        if (btn.disabled) return; // Secili kapaliyken degerler atanamaz
                        var fid = parseInt(btn.getAttribute('data-feature-id'), 10);
                        if (!fid) return;
                        var fname = features.find(function (x) { return x.id === fid; });
                        if (typeof window.mceOpenValuesGuide === 'function') {
                            window.mceOpenValuesGuide(fid, fname ? fname.name : '');
                        }
                    });
                });

                // "Kombinasyonda" badge — tiklayinca hangi kombinasyon(lar)da kullaniliyor popup'i ac
                document.querySelectorAll('#mceFeaturesList .mce-feat-comb-badge').forEach(function(badge) {
                    var openPopup = function(ev) {
                        var fid = parseInt(badge.getAttribute('data-feature-id'), 10);
                        if (!fid) return;
                        var f = features.find(function (x) { return x.id === fid; });
                        if (typeof window.mceShowFeatureCombinationsPopup === 'function') {
                            window.mceShowFeatureCombinationsPopup(fid, f ? f.name : '', ev);
                        }
                    };
                    badge.addEventListener('click', openPopup);
                    // Klavye erisilebilirligi: Enter / Space
                    badge.addEventListener('keydown', function(ev) {
                        if (ev.key === 'Enter' || ev.key === ' ') { ev.preventDefault(); openPopup(ev); }
                    });
                    // Hover feedback
                    badge.addEventListener('mouseenter', function() {
                        badge.style.background = 'rgba(251,191,36,0.20)';
                        badge.style.borderColor = 'rgba(251,191,36,0.45)';
                    });
                    badge.addEventListener('mouseleave', function() {
                        badge.style.background = 'rgba(251,191,36,0.10)';
                        badge.style.borderColor = 'rgba(251,191,36,0.25)';
                    });
                });

                var linkedCount = features.filter(function(f) { return f.linked; }).length;
                updateFeatureCount(linkedCount, features.length);
            })
            .catch(function(e) {
                if (listEl) listEl.innerHTML = '';
                if (errEl) {
                    errEl.textContent = 'Yukleme hatasi: ' + e.message;
                    errEl.style.display = 'block';
                }
            });
    };

    function updateFeatureCount(linked, total) {
        var badge = document.getElementById('mceFeatCount');
        if (!badge) return;
        var newText = String(linked);
        var newEmpty = (linked || 0) <= 0;
        // No-op: degisiklik yoksa DOM'a dokunma (kayma engelli)
        var curEmpty = badge.classList.contains('is-empty');
        if (badge.textContent === newText && curEmpty === newEmpty) return;
        if (badge.textContent !== newText) badge.textContent = newText;
        badge.classList.toggle('is-empty', newEmpty);
    }

    window.mceFeatureSave = function(opts) {
        opts = opts || {};
        if (!currentId || currentId <= 0) return Promise.resolve({ success: false, skipped: true });
        var errEl = document.getElementById('mceFeaturesError');
        if (errEl) errEl.style.display = 'none';

        // Her bagli (checked) feature icin {featureId, printDescriptionInDesign, allowedValueIds[]} topla.
        var items = [];
        document.querySelectorAll('#mceFeaturesList .mce-feature-chk:checked').forEach(function(cb) {
            var id = parseInt(cb.getAttribute('data-feature-id'), 10);
            if (id > 0) {
                var printChk = document.getElementById('mceFeatPrint_' + id);
                var allowed = (window.__mceFeatureAllowed && window.__mceFeatureAllowed[id]) || [];
                items.push({
                    featureId: id,
                    printDescriptionInDesign: printChk ? !!printChk.checked : true,
                    allowedValueIds: allowed
                });
            }
        });

        return fetch('/Logistics/SaveStockFeatures', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ itemId: currentId, items: items }),
        })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data && data.success) {
                    var total = document.querySelectorAll('#mceFeaturesList .mce-feature-chk').length;
                    updateFeatureCount(items.length, total);
                } else {
                    if (errEl && !opts.silent) {
                        errEl.textContent = (data && data.message) || 'Ozellik kaydetme basarisiz.';
                        errEl.style.display = 'block';
                    }
                    console.warn('[MCE] feature save:', (data && data.message) || 'unknown');
                }
                return data;
            })
            .catch(function(e) {
                if (errEl && !opts.silent) {
                    errEl.textContent = 'Baglanti hatasi: ' + e.message;
                    errEl.style.display = 'block';
                }
                console.warn('[MCE] feature save error:', e);
                return { success: false, message: e.message };
            });
    };

    // ── Recete (BOM) sekmesi ─────────────────────────────────────────────
    // Mamul (3) ve Yari Mamul (2) icin kombinasyonlu/kombinasyonsuz recete kart yonetimi.

    function mceRecipeIsApplicable() {
        var typeIdStr = ($('mceMaterialTypeId') && $('mceMaterialTypeId').value) || '';
        var typeId = parseInt(typeIdStr, 10);
        return typeId === 2 || typeId === 3; // Yari Mamul / Mamul
    }

    /**
     * Nav butonu gorunurlugu: TypeId Mamul/Yari Mamul ise goster, degilse gizle.
     * Aktif sekme Recete iken tip degisip uygulanamaz hale gelirse Genel Bilgiler'e don.
     */
    window.mceRecipeSyncVisibility = function () {
        var navBtn = document.getElementById('mceNavRecipe');
        if (!navBtn) return;
        var applicable = mceRecipeIsApplicable();
        navBtn.style.display = applicable ? '' : 'none';
        if (!applicable && navBtn.classList.contains('is-active') && typeof window.mceNavigateToSection === 'function') {
            window.mceNavigateToSection('general');
        }
    };

    /** Recete sekmesi icerigi: kombinasyonsuz=tek kart, kombinasyonlu=combo listesi. */
    window.mceRecipeRender = function () {
        var emptyEl = document.getElementById('mceRecipeEmpty');
        var singleEl = document.getElementById('mceRecipeSingle');
        var combosWrap = document.getElementById('mceRecipeCombosWrap');
        var combosList = document.getElementById('mceRecipeCombosList');
        var hint = document.getElementById('mceRecipeHint');
        var statusEl = document.getElementById('mceRecipeSingleStatus');
        if (!emptyEl || !singleEl || !combosWrap || !combosList) return;

        if (!currentId || currentId <= 0) {
            emptyEl.style.display = '';
            singleEl.style.display = 'none';
            combosWrap.style.display = 'none';
            mceRecipeUpdateCount(0);
            return;
        }
        emptyEl.style.display = 'none';

        var trackChk = document.getElementById('mceTrackCombinations');
        var hasCombos = trackChk ? !!trackChk.checked : false;
        var code = ($('mceMaterialCode') && $('mceMaterialCode').value || '').trim();

        if (!hasCombos) {
            singleEl.style.display = '';
            combosWrap.style.display = 'none';
            if (hint) hint.textContent = 'Reçeteyi Düzenle butonu ile detaylı reçete ekranında bileşen ekleyebilirsiniz.';
            // Status bilgisini fetch et — recete tanimli mi degil mi
            mceRecipeFetchStatus(code, null, statusEl);
            mceRecipeUpdateCount(1);
            return;
        }

        // Kombinasyonlu — combos listele
        singleEl.style.display = 'none';
        combosWrap.style.display = '';
        if (hint) hint.textContent = 'Her kombinasyon icin ayri bir recete tanimi yapabilirsiniz.';
        combosList.innerHTML = '<div style="padding:14px;color:rgba(255,255,255,.4);font-size:.78rem;font-style:italic;">Yukleniyor...</div>';

        if (!code) {
            combosList.innerHTML = '<div style="padding:14px;color:rgba(255,255,255,.45);font-size:.8rem;">Once stok kodu girin ve kaydedin.</div>';
            mceRecipeUpdateCount(0);
            return;
        }
        fetch('/Logistics/CombinationsDataJson?stockCode=' + encodeURIComponent(code), { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : { combos: [] }; })
            .then(function (data) {
                var combos = (data && data.combos) || [];
                if (combos.length === 0) {
                    combosList.innerHTML = '<div style="padding:14px;color:rgba(255,255,255,.45);font-size:.8rem;font-style:italic;">Henuz kombinasyon yok. Onceki sekmeden kombinasyon olusturun.</div>';
                    mceRecipeUpdateCount(0);
                    return;
                }
                combosList.innerHTML = '';
                combos.forEach(function (combo) {
                    combosList.appendChild(mceRecipeBuildComboRow(combo));
                });
                mceRecipeUpdateCount(combos.length);
            })
            .catch(function (e) {
                combosList.innerHTML = '<div style="padding:14px;color:#f87171;font-size:.78rem;">Kombinasyonlar yuklenemedi: ' + (e.message || 'hata') + '</div>';
                mceRecipeUpdateCount(0);
            });
    };

    function mceRecipeBuildComboRow(combo) {
        var row = document.createElement('div');
        row.style.cssText = 'display:flex;align-items:center;gap:14px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);';

        var codeEl = document.createElement('span');
        codeEl.style.cssText = 'font-family:ui-monospace,monospace;font-size:.78rem;font-weight:700;color:#a5b4fc;min-width:90px;flex-shrink:0;';
        codeEl.textContent = combo.code || '-';
        row.appendChild(codeEl);

        var descEl = document.createElement('span');
        descEl.style.cssText = 'flex:1;min-width:0;font-size:.82rem;color:rgba(255,255,255,.78);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;';
        descEl.textContent = combo.description || '-';
        row.appendChild(descEl);

        var statusEl = document.createElement('span');
        statusEl.style.cssText = 'font-size:.7rem;color:rgba(255,255,255,.45);font-style:italic;flex-shrink:0;';
        statusEl.textContent = '...';
        row.appendChild(statusEl);

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'mce-btn mce-btn--secondary';
        btn.style.cssText = 'font-size:.74rem;padding:5px 11px;flex-shrink:0;';
        btn.innerHTML =
            '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
            ' Reçeteyi Düzenle';
        btn.addEventListener('click', function () { mceOpenRecipe(combo.code); });
        row.appendChild(btn);

        // Async: bu kombo icin recete var mi?
        var code = ($('mceMaterialCode') && $('mceMaterialCode').value || '').trim();
        if (code && combo.code) {
            mceRecipeFetchStatus(code, combo.code, statusEl);
        }
        return row;
    }

    function mceRecipeFetchStatus(materialCode, configCode, targetEl) {
        if (!targetEl || !materialCode) return;
        var url = '/Logistics/GetBOM?materialCode=' + encodeURIComponent(materialCode);
        if (configCode) url += '&configCode=' + encodeURIComponent(configCode);
        fetch(url, { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : { found: false }; })
            .then(function (data) {
                if (data && data.found) {
                    var n = (data.lines && data.lines.length) || 0;
                    targetEl.textContent = n + ' bileşen';
                    targetEl.style.color = '#34d399';
                } else {
                    targetEl.textContent = 'Tanımsız';
                    targetEl.style.color = 'rgba(255,255,255,.45)';
                }
            })
            .catch(function () {
                targetEl.textContent = '';
            });
    }

    function mceRecipeUpdateCount(n) {
        var badge = document.getElementById('mceRecipeCount');
        if (!badge) return;
        var newText = String(n || 0);
        var newEmpty = (n || 0) <= 0;
        var curEmpty = badge.classList.contains('is-empty');
        if (badge.textContent === newText && curEmpty === newEmpty) return;
        if (badge.textContent !== newText) badge.textContent = newText;
        badge.classList.toggle('is-empty', newEmpty);
    }

    /** Recete duzenleme ekranina yonlendirir (BOMs sayfasi). */
    window.mceOpenRecipe = function (configCode) {
        var code = ($('mceMaterialCode') && $('mceMaterialCode').value || '').trim();
        if (!code) {
            if (typeof showMsg === 'function') showMsg('Once stok kodunu girin ve kaydedin.', false);
            return;
        }
        var url = '/Logistics/BOMs?mat=' + encodeURIComponent(code);
        if (configCode) url += '&cfg=' + encodeURIComponent(configCode);
        // Workspace iframe icindeyse parent'a navigate ettir, degilse dogrudan
        try {
            if (window.parent && window.parent !== window && typeof window.parent.location !== 'undefined') {
                window.parent.location.href = url;
                return;
            }
        } catch (e) { /* cross-origin — fallback */ }
        window.location.href = url;
    };

    // TypeId secimi degisirse nav buton gorunurlugunu sync et
    (function initRecipeTypeSync() {
        var sel = document.getElementById('mceMaterialTypeId');
        if (!sel) return;
        sel.addEventListener('change', function () {
            if (typeof window.mceRecipeSyncVisibility === 'function') window.mceRecipeSyncVisibility();
        });
    })();

    // TrackCombinations toggle degisirse Recete sekmesi yenilenmeli (tek kart <-> liste)
    (function initRecipeCombosSync() {
        var cb = document.getElementById('mceTrackCombinations');
        if (!cb) return;
        cb.addEventListener('change', function () {
            // Sadece sekme aktifse re-render (gereksiz fetch'i engelle)
            var navBtn = document.getElementById('mceNavRecipe');
            if (navBtn && navBtn.classList.contains('is-active') && typeof window.mceRecipeRender === 'function') {
                window.mceRecipeRender();
            }
        });
    })();

    // ── Kit (Paket Urun) sekmesi — yalniz Kit (TypeId=10) tipinde gorunur ─────
    function mceKitIsApplicable() {
        var typeIdStr = ($('mceMaterialTypeId') && $('mceMaterialTypeId').value) || '';
        return parseInt(typeIdStr, 10) === 10; // Kit
    }

    window.mceKitSyncVisibility = function () {
        var navBtn = document.getElementById('mceNavKit');
        if (!navBtn) return;
        var applicable = mceKitIsApplicable();
        navBtn.style.display = applicable ? '' : 'none';
        if (!applicable && navBtn.classList.contains('is-active') && typeof window.mceNavigateToSection === 'function') {
            window.mceNavigateToSection('general');
        }
    };

    window.mceKitRender = function () {
        var emptyEl = document.getElementById('mceKitEmpty');
        var singleEl = document.getElementById('mceKitSingle');
        var statusEl = document.getElementById('mceKitStatus');
        if (!emptyEl || !singleEl) return;
        if (!currentId || currentId <= 0) {
            emptyEl.style.display = '';
            singleEl.style.display = 'none';
            mceKitUpdateCount(0);
            return;
        }
        emptyEl.style.display = 'none';
        singleEl.style.display = '';
        mceKitFetchStatus(statusEl);
    };

    function mceKitFetchStatus(targetEl) {
        if (!currentId || currentId <= 0) return;
        fetch('/Logistics/GetKit?itemId=' + currentId, { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : { found: false }; })
            .then(function (data) {
                var n = (data && data.found && data.lines) ? data.lines.length : 0;
                mceKitUpdateCount(n);
                if (!targetEl) return;
                if (data && data.found) {
                    targetEl.textContent = n + ' bileşen · v' + (data.versionNo || 1);
                    targetEl.style.color = '#34d399';
                } else {
                    targetEl.textContent = 'Tanımsız';
                    targetEl.style.color = 'rgba(255,255,255,.45)';
                }
            })
            .catch(function () { if (targetEl) targetEl.textContent = ''; });
    }

    function mceKitUpdateCount(n) {
        var badge = document.getElementById('mceKitCount');
        if (!badge) return;
        var newText = String(n || 0);
        var newEmpty = (n || 0) <= 0;
        if (badge.textContent !== newText) badge.textContent = newText;
        badge.classList.toggle('is-empty', newEmpty);
    }

    window.mceOpenKit = function () {
        var code = ($('mceMaterialCode') && $('mceMaterialCode').value || '').trim();
        var name = ($('mceMaterialName') && $('mceMaterialName').value || '').trim();
        if (!currentId || currentId <= 0) {
            if (typeof showMsg === 'function') showMsg('Önce malzeme kartını kaydedin.', false);
            return;
        }
        var url = '/Logistics/KitEdit?itemId=' + currentId
                + '&code=' + encodeURIComponent(code)
                + '&name=' + encodeURIComponent(name);
        try {
            if (window.parent && window.parent !== window && typeof window.parent.location !== 'undefined') {
                window.parent.location.href = url;
                return;
            }
        } catch (e) { /* cross-origin — fallback */ }
        window.location.href = url;
    };

    // TypeId degisince Kit nav gorunurlugunu sync et
    (function initKitTypeSync() {
        var sel = document.getElementById('mceMaterialTypeId');
        if (!sel) return;
        sel.addEventListener('change', function () {
            if (typeof window.mceKitSyncVisibility === 'function') window.mceKitSyncVisibility();
        });
    })();

    // ── Yeni Ozellik Ekleme Uyari Modali ─────────────────────────────────
    var _mceFeatAddWarnOnConfirm = null;
    var _mceFeatAddWarnOnCancel = null;

    function mceFeatAddWarnShow(count, featureName, onConfirm, onCancel) {
        var bd = document.getElementById('mceFeatAddWarnBackdrop');
        if (!bd) { onConfirm && onConfirm(); return; }
        document.getElementById('mceFeatAddWarnCount').textContent = count;
        document.getElementById('mceFeatAddWarnName').textContent = featureName || '';
        _mceFeatAddWarnOnConfirm = onConfirm;
        _mceFeatAddWarnOnCancel = onCancel;
        bd.classList.add('is-open');
    }
    window.mceFeatAddWarnCancel = function () {
        var bd = document.getElementById('mceFeatAddWarnBackdrop');
        if (bd) bd.classList.remove('is-open');
        if (typeof _mceFeatAddWarnOnCancel === 'function') {
            try { _mceFeatAddWarnOnCancel(); } catch (e) { /* ignore */ }
        }
        _mceFeatAddWarnOnConfirm = null;
        _mceFeatAddWarnOnCancel = null;
    };
    document.addEventListener('DOMContentLoaded', function () {
        var btn = document.getElementById('mceFeatAddWarnConfirm');
        if (btn) {
            btn.addEventListener('click', function () {
                var bd = document.getElementById('mceFeatAddWarnBackdrop');
                if (bd) bd.classList.remove('is-open');
                var fn = _mceFeatAddWarnOnConfirm;
                _mceFeatAddWarnOnConfirm = null;
                _mceFeatAddWarnOnCancel = null;
                if (typeof fn === 'function') {
                    try { fn(); } catch (e) { /* ignore */ }
                }
            });
        }
    });

    // ── Deger Rehberi (per-feature allowed values) ────────────────────────
    var mceValuesGuideFeatureId = null;
    var mceValuesGuideSearchTimer = null;

    window.mceOpenValuesGuide = function (featureId, featureName) {
        if (!featureId) return;
        mceValuesGuideFeatureId = featureId;
        var label = document.getElementById('mceValuesGuideFeatureLabel');
        if (label) label.textContent = featureName || ('#' + featureId);
        var bd = document.getElementById('mceValuesGuideBackdrop');
        if (!bd) return;
        bd.classList.add('is-open');
        var srch = document.getElementById('mceValuesGuideSearch');
        if (srch) srch.value = '';
        mceRenderValuesGuide('');
        setTimeout(function () { if (srch) srch.focus(); }, 80);
    };

    window.mceCloseValuesGuide = function () {
        var bd = document.getElementById('mceValuesGuideBackdrop');
        if (bd) bd.classList.remove('is-open');
        mceValuesGuideFeatureId = null;
    };

    function mceRenderValuesGuide(query) {
        var body = document.getElementById('mceValuesGuideBody');
        if (!body) return;
        body.innerHTML = '';

        if (!mceValuesGuideFeatureId) {
            body.innerHTML = '<div class="mce-vguide-empty">Ozellik secimi yok</div>';
            return;
        }
        var allValues = (window.__mceFeatureValues && window.__mceFeatureValues[mceValuesGuideFeatureId]) || [];
        var allowed = (window.__mceFeatureAllowed && window.__mceFeatureAllowed[mceValuesGuideFeatureId]) || [];
        var usedInCombo = (window.__mceFeatureUsedValueIds && window.__mceFeatureUsedValueIds[mceValuesGuideFeatureId]) || [];

        var q = (query || '').trim().toLowerCase();
        var values = allValues.filter(function (v) {
            if (!q) return true;
            return ((v.description || '') + ' ' + (v.value || '') + ' ' + (v.code || '')).toLowerCase().indexOf(q) !== -1;
        });

        if (values.length === 0) {
            body.innerHTML = '<div class="mce-vguide-empty">' + (q ? 'Eslesme bulunamadi' : 'Deger yok') + '</div>';
            mceUpdateValuesGuideCount();
            return;
        }

        var sel = []; var unsel = [];
        values.forEach(function (v) {
            if (allowed.indexOf(v.id) !== -1) sel.push(v); else unsel.push(v);
        });

        function buildRow(v, isSel) {
            var isLocked = usedInCombo.indexOf(v.id) !== -1; // kombinasyonda kullanilan = kilitli
            var row = document.createElement('div');
            row.className = 'mce-vguide-row';
            if (isLocked) row.style.background = 'rgba(251,191,36,0.04)';

            var code = document.createElement('span');
            code.className = 'mce-vguide-row__code';
            code.textContent = v.code || '-';

            var name = document.createElement('span');
            name.className = 'mce-vguide-row__name';
            name.textContent = v.description || v.value || '';

            // Kilit badge'i (kombinasyonda kullanilan deger)
            if (isLocked) {
                var badge = document.createElement('span');
                badge.style.cssText = 'font-size:.62rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fbbf24;background:rgba(251,191,36,.10);border:1px solid rgba(251,191,36,.25);padding:2px 6px;border-radius:999px;flex-shrink:0;';
                badge.title = 'Bu deger aktif kombinasyon(lar)da kullaniliyor — kaldirilamaz';
                badge.textContent = '🔒 Kombinasyonda';
                row.appendChild(code);
                row.appendChild(name);
                row.appendChild(badge);
            } else {
                row.appendChild(code);
                row.appendChild(name);
            }

            // Tema-uyumlu yesil switchkey (.mce-switch standart class)
            var sw = document.createElement('label');
            sw.className = 'mce-switch' + (isLocked ? ' is-locked' : '');
            var cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.checked = isSel || isLocked; // kilitliyse her zaman acik gorunsun
            if (isLocked) cb.disabled = true;
            var track = document.createElement('span');
            track.className = 'mce-switch-track';
            sw.appendChild(cb); sw.appendChild(track);

            if (!isLocked) {
                cb.addEventListener('change', function () { mceToggleAllowedValue(v.id, cb.checked); });
                row.addEventListener('click', function (e) {
                    if (e.target === cb || e.target === track) return;
                    cb.checked = !cb.checked;
                    cb.dispatchEvent(new Event('change'));
                });
            } else {
                row.style.cursor = 'not-allowed';
            }

            row.appendChild(sw);
            return row;
        }

        if (sel.length > 0) {
            var sep1 = document.createElement('div');
            sep1.className = 'mce-vguide-sep';
            sep1.textContent = 'Secili degerler (' + sel.length + ')';
            body.appendChild(sep1);
            sel.forEach(function (v) { body.appendChild(buildRow(v, true)); });
        }
        if (unsel.length > 0) {
            var sep2 = document.createElement('div');
            sep2.className = 'mce-vguide-sep';
            sep2.textContent = 'Diger degerler (' + unsel.length + ')';
            body.appendChild(sep2);
            unsel.forEach(function (v) { body.appendChild(buildRow(v, false)); });
        }
        mceUpdateValuesGuideCount();
    }

    function mceToggleAllowedValue(valueId, checked) {
        if (!mceValuesGuideFeatureId) return;
        // Kombinasyonda kullanilan deger ise — kaldirilamaz
        var usedInCombo = (window.__mceFeatureUsedValueIds && window.__mceFeatureUsedValueIds[mceValuesGuideFeatureId]) || [];
        if (!checked && usedInCombo.indexOf(valueId) !== -1) {
            if (typeof showMsg === 'function') {
                showMsg('Bu deger aktif kombinasyon(lar)da kullaniliyor — kaldirilamaz.', false);
            }
            // UI'da geri al — render'i tetikle
            var sb = document.getElementById('mceValuesGuideSearch');
            mceRenderValuesGuide(sb ? sb.value : '');
            return;
        }
        if (!window.__mceFeatureAllowed) window.__mceFeatureAllowed = {};
        var arr = window.__mceFeatureAllowed[mceValuesGuideFeatureId] || [];
        var ix = arr.indexOf(valueId);
        if (checked && ix === -1) arr.push(valueId);
        else if (!checked && ix !== -1) arr.splice(ix, 1);
        window.__mceFeatureAllowed[mceValuesGuideFeatureId] = arr;
        // Feature satirindaki "Degerler (n)" badge guncelle
        var fid = mceValuesGuideFeatureId;
        var btn = document.querySelector('.mce-feat-values-btn[data-feature-id="' + fid + '"]');
        if (btn) {
            var cnt = arr.length;
            btn.innerHTML =
                '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>' +
                ' Degerler' + (cnt > 0 ? ' (' + cnt + ')' : '');
        }
        mceUpdateValuesGuideCount();
        // Otomatik kaydet
        if (typeof window.mceFeatureSave === 'function') {
            window.mceFeatureSave({ silent: true });
        }
    }

    function mceUpdateValuesGuideCount() {
        var el = document.getElementById('mceValuesGuideCount');
        if (!el) return;
        var cnt = 0;
        if (mceValuesGuideFeatureId && window.__mceFeatureAllowed) {
            var arr = window.__mceFeatureAllowed[mceValuesGuideFeatureId] || [];
            cnt = arr.length;
        }
        el.textContent = cnt + ' deger secili' + (cnt === 0 ? ' (kisitlama yok — tum degerler gecerli)' : '');
    }

    // Search input + ESC handler
    document.addEventListener('DOMContentLoaded', function () {
        var srch = document.getElementById('mceValuesGuideSearch');
        if (srch) {
            srch.addEventListener('input', function () {
                if (mceValuesGuideSearchTimer) clearTimeout(mceValuesGuideSearchTimer);
                mceValuesGuideSearchTimer = setTimeout(function () { mceRenderValuesGuide(srch.value); }, 180);
            });
        }
        document.addEventListener('keydown', function (e) {
            if (e.key !== 'Escape') return;
            var bd = document.getElementById('mceValuesGuideBackdrop');
            if (bd && bd.classList.contains('is-open')) {
                window.mceCloseValuesGuide();
            }
        });
    });

})();
</script>

<script>
    /* ═══════════════ Stok Hareketleri sekmesi ═══════════════
       Kaynak: /Logistics/ItemStockMovements (DocumentLine tabanlı hareket ekstresi).
       Koşan bakiye backend'de tüm geçmiş üzerinden hesaplanır; filtreler yalnız gösterimi
       daraltır. Tarih inputları global calibra-datepicker ile takvime döner (ISO değer).
       Excel export gösterilen satırlardan form-POST ile /api/export/smartboard-excel. */
    (function () {
        var _itemId = 0;
        var _loaded = false;      // ilk yükleme yapıldı mı (tekrar tab'a dönünce yeniden çekmemek için)
        var _locFilled = false;   // lokasyon dropdown'u dolduruldu mu
        var _rows = [];           // son çekilen (gösterilen) satırlar — export için

        function $(id) { return document.getElementById(id); }

        // tr-TR sayı biçimi — miktarlar 0-4 ondalık, maliyet 2 ondalık
        function fmt(n, maxDec) {
            if (n === null || n === undefined || isNaN(n)) return '';
            return Number(n).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: (maxDec == null ? 4 : maxDec) });
        }
        function fmtDate(iso) {
            if (!iso) return '';
            var p = String(iso).substring(0, 10).split('-');
            return p.length === 3 ? (p[2] + '.' + p[1] + '.' + p[0]) : iso;
        }
        function esc(s) {
            if (s === null || s === undefined) return '';
            return String(s).replace(/[&<>"]/g, function (c) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
            });
        }
        function badgeClass(mt) {
            return mt === 2 ? 'smv-badge--in' : mt === 1 ? 'smv-badge--out'
                : mt === 3 ? 'smv-badge--tr' : 'smv-badge--adj';
        }

        // ── İşaretli miktar hücreleri (girilen birim + ana birim) ──
        function qtyCell(m) {
            if (m.movementType === 3) return '<span class="smv-muted">' + fmt(m.quantity) + '</span>';
            if (m.signedQuantity >= 0) return '<span class="smv-qty--in">+' + fmt(m.quantity) + '</span>';
            return '<span class="smv-qty--out">-' + fmt(m.quantity) + '</span>';
        }
        function baseCell(m) {
            if (m.movementType === 3) return '<span class="smv-muted">' + fmt(m.baseQuantity) + '</span>';
            if (m.baseSignedQuantity >= 0) return '<span class="smv-qty--in">+' + fmt(m.baseQuantity) + '</span>';
            return '<span class="smv-qty--out">-' + fmt(m.baseQuantity) + '</span>';
        }

        // ── Kolon tanımları — görünürlük + sıralama, localStorage'da kalıcı ──
        //    cell(m): tablo hücresi HTML'i · xv(m): Excel için ham değer
        // Belge no → ilgili belge ekranı. { url, title, matchPath } döner (yoksa null).
        // matchPath = belge tipinin edit yolu → aynı tip için açık workspace tab varsa
        // onu yeniden kullanır (Shell.openWorkspaceTab başlığı da günceller). 4 depo tipi
        // linklenir; diğerleri (iş emri vb.) düz metin.
        function smvDocLink(m) {
            var id = m && m.documentId;
            if (!id || id <= 0) return null;
            switch (m.docTypeCode) {
                case 'depo_giris':    return { url: '/Warehouse/StockEntryEdit?id=' + id + '&type=in',  title: 'Ambar Giriş', matchPath: '/Warehouse/StockEntryEdit' };
                case 'depo_cikis':    return { url: '/Warehouse/StockEntryEdit?id=' + id + '&type=out', title: 'Ambar Çıkış', matchPath: '/Warehouse/StockEntryEdit' };
                case 'depo_transfer': return { url: '/Warehouse/TransferEdit?id=' + id,  title: 'Transfer', matchPath: '/Warehouse/TransferEdit' };
                case 'sayim':         return { url: '/Warehouse/InventoryEdit?id=' + id, title: 'Sayım',    matchPath: '/Warehouse/InventoryEdit' };
                default: return null;
            }
        }
        // Belgeyi workspace tab alanında aç — TAM EKRAN DEĞİL. Uygun açık tab varsa yeniden
        // kullanır; yoksa yeni tab açar. Shell API'sine iframe içinden window.top üzerinden erişilir.
        function smvOpenDoc(url, title, matchPath) {
            if (!url) return;
            try {
                var topWin = window.top || window;
                if (topWin && topWin.CalibraHub && typeof topWin.CalibraHub.openWorkspaceTab === 'function') {
                    topWin.CalibraHub.openWorkspaceTab({ url: url, title: title || 'Belge', matchPath: matchPath || null });
                    return;
                }
            } catch (e) { /* cross-origin — shell'e erişilemedi */ }
            // Shell yoksa iframe-içi navigasyon (yine de tam ekran patlatmaz).
            try { window.location.href = url; } catch (e2) { window.top.location.href = url; }
        }

        var COLS_DEFAULT = [
            { key: 'date',     label: 'Tarih',         cell: function (m) { return fmtDate(m.movementDate); }, xv: function (m) { return m.movementDate; } },
            { key: 'docNo',    label: 'Belge No',      cell: function (m) { var lnk = smvDocLink(m); var t = esc(m.documentNumber || ''); return lnk ? '<a class="smv-docno smv-doclink" data-url="' + esc(lnk.url) + '" data-title="' + esc(lnk.title) + '" data-match="' + esc(lnk.matchPath) + '" title="Belgeye git">' + t + '</a>' : '<span class="smv-docno">' + t + '</span>'; }, xv: function (m) { return m.documentNumber || ''; } },
            { key: 'docType',  label: 'Belge Tipi',    cell: function (m) { return esc(m.docTypeName || m.docTypeCode || ''); }, xv: function (m) { return m.docTypeName || m.docTypeCode || ''; } },
            { key: 'dir',      label: 'Hareket',       cell: function (m) { return '<span class="smv-badge ' + badgeClass(m.movementType) + '">' + esc(m.movementLabel) + '</span>'; }, xv: function (m) { return m.movementLabel || ''; } },
            { key: 'qty',      label: 'Miktar',        num: true, cell: qtyCell, xv: function (m) { return m.movementType === 3 ? m.quantity : m.signedQuantity; } },
            { key: 'unit',     label: 'Birim',         cell: function (m) { return esc(m.unitCode || ''); }, xv: function (m) { return m.unitCode || ''; } },
            { key: 'baseQty',  label: 'Baz Miktar',    num: true, cell: baseCell, xv: function (m) { return m.movementType === 3 ? m.baseQuantity : m.baseSignedQuantity; } },
            { key: 'fromLoc',  label: 'Kaynak Lok.',   cell: function (m) { var f = locText(m.fromLocationCode, m.fromLocationName); return f ? esc(f) : '<span class="smv-muted">—</span>'; }, xv: function (m) { return locText(m.fromLocationCode, m.fromLocationName); } },
            { key: 'toLoc',    label: 'Hedef Lok.',    cell: function (m) { var t = locText(m.toLocationCode, m.toLocationName); return t ? esc(t) : '<span class="smv-muted">—</span>'; }, xv: function (m) { return locText(m.toLocationCode, m.toLocationName); } },
            { key: 'unitCost', label: 'Birim Maliyet', num: true, cell: function (m) { return m.unitCost != null ? fmt(m.unitCost, 2) : '<span class="smv-muted">—</span>'; }, xv: function (m) { return m.unitCost == null ? '' : m.unitCost; } },
            { key: 'lot',      label: 'Lot / Parti',   cell: function (m) { return m.lotNo ? esc(m.lotNo) : '<span class="smv-muted">—</span>'; }, xv: function (m) { return m.lotNo || ''; } },
            { key: 'serial',   label: 'Seri',          cell: function (m) { return m.serialNos ? '<span title="' + esc(m.serialNos) + '">' + esc(m.serialNos.length > 28 ? m.serialNos.substring(0, 28) + '…' : m.serialNos) + '</span>' : '<span class="smv-muted">—</span>'; }, xv: function (m) { return m.serialNos || ''; } },
            { key: 'balance',  label: 'Bakiye',        num: true, title: 'Ana birim cinsinden koşan bakiye', xlabel: 'Bakiye (Ana Birim)', cell: function (m) { return fmt(m.runningBalance); }, xv: function (m) { return m.runningBalance; } },
            { key: 'user',     label: 'Kullanıcı',     cell: function (m) { return m.createdByName ? esc(m.createdByName) : '<span class="smv-muted">—</span>'; }, xv: function (m) { return m.createdByName || ''; } }
        ];
        var LS_COLS = 'mce-smv-cols-v1';
        var _cols = COLS_DEFAULT.slice();          // aktif sıra + görünürlük
        function isVis(c) { return c.visible !== false; }

        function loadColPrefs() {
            _cols = COLS_DEFAULT.slice();
            try {
                var raw = localStorage.getItem(LS_COLS);
                if (!raw) return;
                var saved = JSON.parse(raw);
                if (!Array.isArray(saved) || !saved.length) return;
                var map = {}; COLS_DEFAULT.forEach(function (c) { map[c.key] = c; });
                var ordered = [];
                saved.forEach(function (s) {
                    var c = map[s.key];
                    if (c && ordered.indexOf(c) < 0) { c.visible = (s.visible !== false); ordered.push(c); }
                });
                COLS_DEFAULT.forEach(function (c) { if (ordered.indexOf(c) < 0) ordered.push(c); });
                if (ordered.length) _cols = ordered;
            } catch (e) { }
        }
        function saveColPrefs() {
            try { localStorage.setItem(LS_COLS, JSON.stringify(_cols.map(function (c) { return { key: c.key, visible: isVis(c) }; }))); } catch (e) { }
        }

        function renderHead() {
            var head = $('smvHeadRow'); if (!head) return;
            var h = '';
            _cols.forEach(function (c) {
                if (!isVis(c)) return;
                h += '<th' + (c.num ? ' style="text-align:right;"' : '') + (c.title ? ' title="' + esc(c.title) + '"' : '') + '>' + esc(c.label) + '</th>';
            });
            head.innerHTML = h;
        }

        // ── Sütun Ayarları çekmecesi (body'e eklenir — clipping riski yok) ──
        var _panelEl = null, _backdropEl = null, _dragIdx = -1;
        var _GRIP = '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="6" r="1.5"/><circle cx="15" cy="6" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="9" cy="18" r="1.5"/><circle cx="15" cy="18" r="1.5"/></svg>';
        var _EYE = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>';
        var _EYEOFF = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-6.5 0-10-8-10-8a18.5 18.5 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c6.5 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="2" y1="2" x2="22" y2="22"/></svg>';

        function ensurePanel() {
            if (_panelEl) return;
            _backdropEl = document.createElement('div');
            _backdropEl.className = 'smv-col-backdrop';
            _backdropEl.addEventListener('click', closeColPanel);
            _panelEl = document.createElement('div');
            _panelEl.className = 'smv-col-panel';
            _panelEl.innerHTML =
                '<div class="smv-col-hd">' +
                    '<div class="smv-col-hd-ic"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="18" rx="1"/><rect x="14" y="3" width="7" height="18" rx="1"/></svg></div>' +
                    '<div class="smv-col-hd-tx"><strong>Sütun Ayarları</strong><small>Görünürlük ve sıralama</small></div>' +
                    '<button type="button" class="smv-col-reset" id="smvColReset">Sıfırla</button>' +
                    '<button type="button" class="smv-col-close" id="smvColClose"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>' +
                '</div>' +
                '<div class="smv-col-rows" id="smvColRows"></div>';
            document.body.appendChild(_backdropEl);
            document.body.appendChild(_panelEl);
            _panelEl.querySelector('#smvColClose').addEventListener('click', closeColPanel);
            _panelEl.querySelector('#smvColReset').addEventListener('click', function () {
                try { localStorage.removeItem(LS_COLS); } catch (e) { }
                COLS_DEFAULT.forEach(function (c) { c.visible = true; });
                _cols = COLS_DEFAULT.slice();
                renderColPanel(); renderHead(); renderRows(_rows);
            });
        }

        function renderColPanel() {
            var box = _panelEl && _panelEl.querySelector('#smvColRows');
            if (!box) return;
            var html = '';
            _cols.forEach(function (c, i) {
                html += '<div class="smv-cfg-row' + (isVis(c) ? '' : ' is-hidden') + '" data-idx="' + i + '" data-key="' + c.key + '" draggable="true">' +
                    '<span class="smv-cfg-grip">' + _GRIP + '</span>' +
                    '<button type="button" class="smv-cfg-eye' + (isVis(c) ? '' : ' is-off') + '" data-key="' + c.key + '" title="' + (isVis(c) ? 'Gizle' : 'Göster') + '">' + (isVis(c) ? _EYE : _EYEOFF) + '</button>' +
                    '<span class="smv-cfg-label">' + esc(c.label) + '</span>' +
                    '</div>';
            });
            box.innerHTML = html;
            box.querySelectorAll('.smv-cfg-eye').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var key = btn.getAttribute('data-key');
                    var def = _cols.find(function (d) { return d.key === key; });
                    if (!def) return;
                    if (isVis(def) && _cols.filter(isVis).length <= 1) return;   // en az bir kolon kalsın
                    def.visible = !isVis(def);
                    saveColPrefs(); renderColPanel(); renderHead(); renderRows(_rows);
                });
            });
            box.querySelectorAll('.smv-cfg-row').forEach(function (row) {
                row.addEventListener('dragstart', function () { _dragIdx = +row.getAttribute('data-idx'); row.classList.add('dragging'); });
                row.addEventListener('dragend', function () { _dragIdx = -1; row.classList.remove('dragging'); box.querySelectorAll('.drag-over').forEach(function (r) { r.classList.remove('drag-over'); }); });
                row.addEventListener('dragover', function (e) { e.preventDefault(); row.classList.add('drag-over'); });
                row.addEventListener('dragleave', function () { row.classList.remove('drag-over'); });
                row.addEventListener('drop', function (e) {
                    e.preventDefault(); row.classList.remove('drag-over');
                    var to = +row.getAttribute('data-idx');
                    if (_dragIdx < 0 || _dragIdx === to) return;
                    var moved = _cols.splice(_dragIdx, 1)[0];
                    _cols.splice(to, 0, moved);
                    saveColPrefs(); renderColPanel(); renderHead(); renderRows(_rows);
                });
            });
        }
        function openColPanel() { ensurePanel(); renderColPanel(); _backdropEl.classList.add('open'); _panelEl.classList.add('open'); }
        function closeColPanel() { if (_panelEl) _panelEl.classList.remove('open'); if (_backdropEl) _backdropEl.classList.remove('open'); }

        function setError(msg) {
            var e = $('smvError');
            if (!e) return;
            if (msg) { e.textContent = msg; e.style.display = ''; } else { e.style.display = 'none'; }
        }

        // Nav'dan çağrılır — sekme aktifleşince
        window.mceStockMovActivate = function (itemId) {
            _itemId = itemId || 0;
            var needsSave = $('smvNeedsSave');
            var main = $('smvMain');
            var tools = $('smvTools');
            if (_itemId <= 0) {
                if (needsSave) needsSave.style.display = '';
                if (main) main.style.display = 'none';
                if (tools) tools.style.display = 'none';
                return;
            }
            if (needsSave) needsSave.style.display = 'none';
            if (main) main.style.display = '';
            if (tools) tools.style.display = 'flex';
            if (!_loaded) load();
        };

        function buildQuery() {
            var p = ['itemId=' + encodeURIComponent(_itemId)];
            var from = $('smvFrom') && $('smvFrom').value;
            var to = $('smvTo') && $('smvTo').value;
            var type = $('smvType') && $('smvType').value;
            var loc = $('smvLoc') && $('smvLoc').value;
            if (from) p.push('fromDate=' + encodeURIComponent(from));
            if (to) p.push('toDate=' + encodeURIComponent(to));
            if (type) p.push('movementType=' + encodeURIComponent(type));
            if (loc) p.push('locationId=' + encodeURIComponent(loc));
            return p.join('&');
        }

        function load() {
            if (_itemId <= 0) return;
            setError('');
            renderHead();
            var body = $('smvBody');
            var empty = $('smvEmpty');
            var loading = $('smvLoading');
            if (empty) empty.style.display = 'none';
            if (loading) loading.style.display = '';
            if (body) body.innerHTML = '';

            fetch('/Logistics/ItemStockMovements?' + buildQuery(), { credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (loading) loading.style.display = 'none';
                    if (!data || !data.ok) { setError((data && data.error) || 'Stok hareketleri yüklenemedi.'); return; }
                    _loaded = true;
                    _rows = data.rows || [];
                    renderSummary(data.summary || {});
                    fillLocations(data.locations || []);
                    renderRows(_rows);
                    updateNavCount(data.summary ? data.summary.movementCount : _rows.length);
                })
                .catch(function (e) {
                    if (loading) loading.style.display = 'none';
                    setError('Stok hareketleri yüklenemedi: ' + (e && e.message ? e.message : e));
                });
        }

        function renderSummary(s) {
            if ($('smvTotalIn')) $('smvTotalIn').innerHTML = fmt(s.totalIn || 0);
            if ($('smvTotalOut')) $('smvTotalOut').innerHTML = fmt(s.totalOut || 0);
            if ($('smvBalance')) $('smvBalance').innerHTML = fmt(s.currentBalance || 0);
            if ($('smvCount')) $('smvCount').textContent = (s.movementCount || 0);
        }

        function updateNavCount(n) {
            var badge = $('mceStockMovCount');
            if (!badge) return;
            badge.textContent = n || 0;
            badge.classList.toggle('is-empty', !n);
        }

        // Lokasyon dropdown'u yalnız bir kez doldurulur (filtreden bağımsız tam liste)
        function fillLocations(locs) {
            if (_locFilled) return;
            var sel = $('smvLoc');
            if (!sel) return;
            var cur = sel.value;
            var html = '<option value="">Tümü</option>';
            for (var i = 0; i < locs.length; i++) {
                html += '<option value="' + locs[i].id + '">' + esc(locs[i].label) + '</option>';
            }
            sel.innerHTML = html;
            if (cur) sel.value = cur;
            _locFilled = true;
        }

        function locText(code, name) {
            var c = code ? String(code).trim() : '';
            var n = name ? String(name).trim() : '';
            if (c && n) return c + ' - ' + n;
            return n || c || '';
        }

        function renderRows(rows) {
            var body = $('smvBody');
            var empty = $('smvEmpty');
            if (!body) return;
            if (!rows.length) {
                body.innerHTML = '';
                if (empty) empty.style.display = '';
                return;
            }
            if (empty) empty.style.display = 'none';

            var vis = _cols.filter(isVis);
            var html = '';
            for (var i = 0; i < rows.length; i++) {
                var m = rows[i];
                html += '<tr>';
                for (var j = 0; j < vis.length; j++) {
                    html += '<td' + (vis[j].num ? ' class="smv-num"' : '') + '>' + vis[j].cell(m) + '</td>';
                }
                html += '</tr>';
            }
            body.innerHTML = html;
        }

        // Excel — gösterilen (görünür) sütunlardan server-side .xlsx (form-POST, iframe-safe)
        function exportExcel() {
            if (!_rows.length) return;
            var vis = _cols.filter(isVis);
            var headers = vis.map(function (c) { return { id: c.key, label: c.xlabel || c.label }; });
            var rows = _rows.map(function (m) {
                var o = {};
                vis.forEach(function (c) { o[c.key] = c.xv(m); });
                return o;
            });
            var code = (document.getElementById('mceMaterialCode') && document.getElementById('mceMaterialCode').value) || ('item' + _itemId);
            var stamp = new Date().toISOString().substring(0, 10).replace(/-/g, '');
            var payload = {
                fileName: 'stok-hareketleri_' + code + '_' + stamp + '.xlsx',
                sheetName: 'Stok Hareketleri',
                headers: headers,
                rows: rows
            };
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '/api/export/smartboard-excel';
            form.style.display = 'none';
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'payload';
            input.value = JSON.stringify(payload);
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
            setTimeout(function () { document.body.removeChild(form); }, 1200);
        }

        // Filtre + araç butonları
        document.addEventListener('DOMContentLoaded', function () {
            loadColPrefs();
            var apply = $('smvApply');
            if (apply) apply.addEventListener('click', function () { _loaded = false; load(); });
            var clear = $('smvClear');
            if (clear) clear.addEventListener('click', function () {
                if ($('smvFrom')) window.CalibraDate ? window.CalibraDate.setValue($('smvFrom'), '') : ($('smvFrom').value = '');
                if ($('smvTo')) window.CalibraDate ? window.CalibraDate.setValue($('smvTo'), '') : ($('smvTo').value = '');
                if ($('smvType')) $('smvType').value = '';
                if ($('smvLoc')) $('smvLoc').value = '';
                _loaded = false; load();
            });
            var exp = $('smvExport');
            if (exp) exp.addEventListener('click', exportExcel);
            // Belge no linkleri → workspace tab'da ilgili belgeyi aç (delege)
            var body = $('smvBody');
            if (body) body.addEventListener('click', function (e) {
                var a = e.target && e.target.closest ? e.target.closest('.smv-doclink') : null;
                if (a && a.getAttribute('data-url')) { e.preventDefault(); smvOpenDoc(a.getAttribute('data-url'), a.getAttribute('data-title'), a.getAttribute('data-match')); }
            });
            var refreshBtn = $('smvRefreshBtn');
            if (refreshBtn) refreshBtn.addEventListener('click', function () {
                refreshBtn.classList.remove('is-spin');
                void refreshBtn.offsetWidth;             // reflow → spin animasyonu tekrar tetiklensin
                refreshBtn.classList.add('is-spin');
                _loaded = false; load();
            });
            var colBtn = $('smvColBtn');
            if (colBtn) colBtn.addEventListener('click', openColPanel);
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && _panelEl && _panelEl.classList.contains('open')) closeColPanel();
            });
        });
    })();
</script>
}
