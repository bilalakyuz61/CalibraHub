    // ── Sidebar navigasyon — tab-panel modeli ─────────────────────────
    // Her nav butonu yalnizca kendi bolumunu gosterir, digerleri gizlenir.
    // Genel Bilgiler statik; widget gruplari React render'dan sonra eklenir.
    (function initSideNav() {
        var sidenav = document.getElementById('mceSideNav');
        var content = document.getElementById('mceContent');
        var dynCard = document.getElementById('mceDynamicWidgetsCard');
        if (!sidenav || !content) return;

        var _activeKey = 'general';

        // Nav buton vurgusu
        function setActive(btn) {
            sidenav.querySelectorAll('.mce-nav-btn').forEach(function(b) {
                b.classList.remove('is-active');
            });
            if (btn) btn.classList.add('is-active');
        }

        // Bolum gorunurlugu: sadece aktif key gorulur, diger her sey gizlenir
        function activateSection(key) {
            _activeKey = key;

            // Genel Bilgiler karti
            var generalCard = document.getElementById('mceGeneralCard');
            if (generalCard) generalCard.style.display = (key === 'general') ? '' : 'none';

            // Olcu Birimleri karti
            var unitsCard = document.getElementById('mceUnitsCard');
            if (unitsCard) unitsCard.style.display = (key === 'units') ? '' : 'none';

            // Lokasyonlar karti
            var locCard = document.getElementById('mceLocationsCard');
            if (locCard) locCard.style.display = (key === 'locations') ? '' : 'none';

            // Ozellikler karti
            var featuresCard = document.getElementById('mceFeaturesCard');
            if (featuresCard) featuresCard.style.display = (key === 'features') ? '' : 'none';

            // Kombinasyonlar karti
            var combCard = document.getElementById('mceCombinationsCard');
            if (combCard) combCard.style.display = (key === 'combinations') ? '' : 'none';

            // Her dinamik grup karti
            content.querySelectorAll('[data-dyn-group-id]').forEach(function(d) {
                d.style.display = (d.getAttribute('data-dyn-group-id') === key) ? 'block' : 'none';
            });
        }

        // Genel Bilgiler butonu
        var navGeneral = document.getElementById('mceNavGeneral');
        if (navGeneral) {
            navGeneral.addEventListener('click', function() {
                setActive(navGeneral);
                activateSection('general');
            });
        }

        // Olcu Birimleri butonu
        var navUnits = document.getElementById('mceNavUnits');
        if (navUnits) {
            navUnits.addEventListener('click', function() {
                setActive(navUnits);
                activateSection('units');
                // Ölçü birimi listesi (availableUnits) currentId'den bagimsiz — yeni
                // malzemede de dropdown dolu gelsin ki kullanici Master + Carpan
                // birimlerini onceden secip sonra Kaydet ile kalici hale getirebilsin.
                // stockCardId=0 sorgusu bile availableUnits'i doldurur.
                mceUnitLoad();
            });
        }

        // Lokasyonlar butonu
        var navLocations = document.getElementById('mceNavLocations');
        if (navLocations) {
            navLocations.addEventListener('click', function() {
                setActive(navLocations);
                activateSection('locations');
                if (currentId > 0) mceLocLoad();
            });
        }

        // Ozellikler butonu (sadece trackCombinations ac ikiyken nav'da gorunur)
        var navFeatures = document.getElementById('mceNavFeatures');
        if (navFeatures) {
            navFeatures.addEventListener('click', function() {
                setActive(navFeatures);
                activateSection('features');
                if (currentId > 0) mceFeatureLoad();
            });
        }

        // Kombinasyonlar butonu
        var navComb = document.getElementById('mceNavCombinations');
        if (navComb) {
            navComb.addEventListener('click', function() {
                setActive(navComb);
                activateSection('combinations');
            });
        }

        // Widget gruplarini tarayip nav butonlari olustur
        function buildGroupNav() {
            sidenav.querySelectorAll('[data-group-nav]').forEach(function(el) { el.remove(); });

            var groups = content.querySelectorAll('[data-dyn-group-id]');
            if (!groups.length) return;

            var lbl = document.createElement('span');
            lbl.className = 'mce-sidenav-label';
            lbl.setAttribute('data-group-nav', '__label');
            lbl.textContent = 'Ek Sahalar';
            sidenav.appendChild(lbl);

            groups.forEach(function(detail) {
                var gid   = detail.getAttribute('data-dyn-group-id') || '';
                var title = detail.getAttribute('data-dyn-group-label') || 'Grup';

                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'mce-nav-btn';
                btn.setAttribute('data-group-nav', gid);
                btn.title = title;
                btn.innerHTML =
                    '<span class="mce-nav-dot"></span>' +
                    '<span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0">' +
                    title + '</span>';

                btn.addEventListener('click', function() {
                    setActive(btn);
                    activateSection(gid);
                });

                sidenav.appendChild(btn);
            });

            // Mevcut aktif bolumu yeniden uygula (render sonrasi gruplar gizlenmeli)
            activateSection(_activeKey);
            // Aktif buton vurgusunu da yeniden uygula — buildGroupNav butonlari
            // silip yeniden olusturduğu icin is-active class'i kaybolur
            var activeBtn = null;
            if (_activeKey === 'general') activeBtn = navGeneral;
            else if (_activeKey === 'units') activeBtn = navUnits;
            else if (_activeKey === 'combinations') activeBtn = navComb;
            else activeBtn = sidenav.querySelector('[data-group-nav="' + _activeKey + '"]');
            if (activeBtn) setActive(activeBtn);
        }

        // DynamicWidgetsCard icinde data-dyn-group-id elementleri belirince nav'i yenile
        if (dynCard) {
            var _t = null;
            function scheduleScan() {
                clearTimeout(_t);
                _t = setTimeout(function() {
                    var groups = content.querySelectorAll('[data-dyn-group-id]');
                    if (groups.length > 0) {
                        buildGroupNav();
                    } else {
                        var tries = (scheduleScan._n = (scheduleScan._n || 0) + 1);
                        if (tries < 80) scheduleScan();
                        else scheduleScan._n = 0;
                    }
                }, 50);
            }

            var _obs = new MutationObserver(function() { scheduleScan(); });
            // Hem dynCard'in kendi style degisimini (React display toggle) hem ic elementleri izle
            _obs.observe(dynCard, { childList: true, subtree: true, attributes: true,
                                    attributeFilter: ['style', 'data-dyn-group-id'] });
            // dynCard'in parent'ini da izle: React container bazi durumlarda parent'i gunceller
            if (dynCard.parentElement) {
                _obs.observe(dynCard.parentElement, { childList: false, subtree: false,
                                                      attributes: true, attributeFilter: ['style'] });
            }
        }

        // Baslangic: Genel Bilgiler aktif
        setActive(navGeneral);

        // Dis erisim: mceSave() hata bolumune gidebilsin
        window.mceNavigateToSection = function(gid) {
            var navBtn;
            if (gid === 'general') navBtn = navGeneral;
            else if (gid === 'units') navBtn = navUnits;
            else if (gid === 'features') navBtn = navFeatures;
            else if (gid === 'combinations') navBtn = navComb;
            else navBtn = sidenav.querySelector('[data-group-nav="' + gid + '"]');
            setActive(navBtn || null);
            activateSection(gid);
        };
        activateSection('general');
    })();

