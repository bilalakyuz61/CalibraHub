    /* Özellik Tanımlama / Kombinasyon Üretici kısayolları — hedef ekranın VIEW
       yetkisine göre aktifleşir. Butonlar disabled başlar (default deny); yetki
       varsa enable + açıklayıcı tooltip, yoksa disabled + "yetkiniz yok" tooltip. */
    (function mceGateShortcutButtons() {
        function apply() {
            if (!window.CalibraHub || typeof window.CalibraHub.loadPermissions !== 'function') return;
            window.CalibraHub.loadPermissions().then(function() {
                document.querySelectorAll('[data-mce-shortcut-perm]').forEach(function(btn) {
                    var form = btn.getAttribute('data-mce-shortcut-perm');
                    var allowed = window.CalibraHub.hasPermission(form, 'VIEW');
                    if (allowed) {
                        btn.disabled = false;
                        btn.removeAttribute('data-perm-denied');
                        var tip = btn.getAttribute('data-tip-allowed');
                        if (tip) btn.setAttribute('title', tip);
                    } else {
                        btn.disabled = true;
                        btn.setAttribute('data-perm-denied', '1');
                        btn.setAttribute('title', 'Bu ekran için yetkiniz yok.');
                    }
                });
            });
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', apply);
        else apply();
    })();

    // ── Grup katlanma durumu persist (localStorage) ───────────────
    // Kullanici hangi gruplari acik/kapali birakmissa ekrani tekrar actiginda
    // ayni duruma donek. Anahtar: "mce-groups-open" (tum MaterialCardEdit icin ortak)
    (function initGroupPersistence() {
        var LS_KEY = 'mce-groups-open';
        var state = {};
        try { state = JSON.parse(localStorage.getItem(LS_KEY) || '{}') || {}; }
        catch (e) { state = {}; }

        document.querySelectorAll('details[data-group-key]').forEach(function(d) {
            var key = d.getAttribute('data-group-key');
            if (!key) return;
            // Kaydedilmis durum false ise kapat (varsayilan acik)
            if (state[key] === false) d.open = false;

            d.addEventListener('toggle', function() {
                state[key] = d.open;
                try { localStorage.setItem(LS_KEY, JSON.stringify(state)); }
                catch (e) { /* quota vs. sessiz gec */ }
            });
        });
    })();

