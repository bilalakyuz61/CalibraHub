    function updateCombNav(trackEnabled, count) {
        var btn = $('mceNavCombinations');
        var badge = $('mceCombCount');
        if (btn) {
            btn.style.display = trackEnabled ? '' : 'none';
            if (badge) {
                var n = count || 0;
                var newText = String(n);
                if (badge.textContent !== newText) badge.textContent = newText;
                badge.classList.toggle('is-empty', n <= 0);
            }
            if (!trackEnabled && btn.classList.contains('is-active')) {
                if (window.mceNavigateToSection) window.mceNavigateToSection('general');
