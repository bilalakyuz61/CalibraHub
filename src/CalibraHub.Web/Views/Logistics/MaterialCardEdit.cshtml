    function flashSuccess() {
        var bar = document.querySelector('.pte-action-bar');
        if (!bar) return;
        bar.classList.remove('is-save-flash');
        void bar.offsetWidth;
        bar.classList.add('is-save-flash');
        setTimeout(function() { bar.classList.remove('is-save-flash'); }, 1850);
    }

    window.mceSave = function() {
        var code = $('mceMaterialCode').value.trim();
        var name = $('mceMaterialName').value.trim();

        // Tum alanlari ES ZAMANLI validasyon — hata varsa devam etme
        var allValid = true;
        var invalid = [];
        if (!code) { invalid.push('mceMaterialCode'); allValid = false; }
        if (!name) { invalid.push('mceMaterialName'); allValid = false; }
        var unitIdRaw = $('mceUnitId') ? $('mceUnitId').value : '';
        if (!unitIdRaw) { invalid.push('mceUnitId'); allValid = false; }
        if (invalid.length > 0) markInvalid(invalid);

        // Ek alan (widget) zorunlu + kisitlama kontrolu — ANA FORM ILE AYNI ANDA
        if (window._mceDynRenderer && window._mceDynRenderer.validate) {
            var dynValidation = window._mceDynRenderer.validate();
            if (!dynValidation.valid) {
                allValid = false;
                // Ana form gecerliyse (kod+ad dolu), ilk hatalı alanin bulundugu bolume git
                if (invalid.length === 0) {
                    var firstErrId = (dynValidation.errorIds || [])[0];
                    if (firstErrId && window.mceNavigateToSection) {
                        var errEl = document.querySelector('[data-widget-code="' + firstErrId + '"]');
                        if (errEl) {
                            var grpEl = errEl.closest('[data-dyn-group-id]');
                            var gid   = grpEl ? grpEl.getAttribute('data-dyn-group-id') : null;
                            if (gid) window.mceNavigateToSection(gid);
                        }
                    }
                }
            }
        }

        // Ana form hatasi varsa Genel Bilgiler sayfasina git
        if (invalid.length > 0 && window.mceNavigateToSection) {
            window.mceNavigateToSection('general');
        }

        // Olcu birimleri validasyonu — secili birimin carpani bos/0 olmamali
        if (typeof mceUnitValidateAll === 'function' && !mceUnitValidateAll()) {
            allValid = false;
            if (window.mceNavigateToSection) window.mceNavigateToSection('units');
            showMsg('Olcu birimi secilen satirlarda carpan degeri sifirdan buyuk olmalidir.', false);
        }

        // Herhangi bir hata varsa kaydetme
        if (!allValid) return;

        var payload = {
            itemId: currentId > 0 ? currentId : null,
            code: code,
            name: name,
            typeId: $('mceMaterialTypeId').value ? parseInt($('mceMaterialTypeId').value) : null,
            unitId: unitIdRaw ? parseInt(unitIdRaw) : null,
            combinations: $('mceTrackCombinations').checked,
            taxRate: parseFloat($('mceTaxRate').value || '20'),
            minStock: parseFloat(($('mceGeneralMinStock') && $('mceGeneralMinStock').value) || '0') || 0,
            trackingType: (($('mceTraceability') && $('mceTraceability').checked) ? (($('mceTrackingMode') && $('mceTrackingMode').checked) ? 'Serial' : 'Lot') : 'None'),
            autoSerial: !!($('mceTraceability') && $('mceTraceability').checked &&
                           $('mceTrackingMode') && $('mceTrackingMode').checked &&
                           $('mceAutoSerial') && $('mceAutoSerial').checked)
        };

        $('mceSaveBtn').disabled = true;
        fetch('/Logistics/SaveMaterialCardJson', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success) {
                showMsg('Hata: ' + (data.message || 'Bilinmeyen'), false);
                return;
            }
            // Basari: yesil parlama animasyonu
            flashSuccess();

            if (data.id && data.id > 0) {
                currentId = data.id;
                // URL'i guncelle (yeni olusturulduysa edit'e cevir)
                if (editId <= 0) {
                    var newUrl = '/Logistics/MaterialCardEdit?id=' + data.id;
                    if (location.search.indexOf('workspace=1') !== -1) newUrl += '&workspace=1';
                    history.replaceState({}, '', newUrl);
                }
                _setDisp('mceDeleteBtn', 'inline-flex');
                mceFormatMeta(data.id, code, name);
            }

            // ── Ek alanlari (WidgetMas/WidgetTra) kaydet ──
            // Master kayit basarili oldu; React renderer'in kendi endpoint'ine
            // kayit etmesini tetikle. RecordId = Items.Id (integer PK).
            if (window._mceDynRenderer) {
                try {
                    window._mceDynRenderer.save({ recordId: String(currentId) })
                        .then(function(dynResult) {
                            if (dynResult && dynResult.success === false) {
                                console.warn('[MCE] widget save basarisiz:', dynResult.message);
                            }
                        })
                        .catch(function(err) { console.warn('[MCE] widget save hatasi:', err); });
                } catch (e) { console.warn('[MCE] dyn renderer cagrilamadi:', e); }
            }

            // ── Olcu birimlerini de ayni save akisinda kaydet ──
            if (typeof window.mceUnitSave === 'function' && currentId > 0) {
                window.mceUnitSave().then(function(res) {
                    if (res && res.success === false && !res.skipped) {
                        console.warn('[MCE] olcu birimi kaydi basarisiz:', res.message);
                    }
                }).catch(function(err) { console.warn('[MCE] unit save hatasi:', err); });
            }

            // ── Grup eslestirmelerini de kaydet (Gruplar tab acildiysa) ──
            if (typeof window.mceGroupsSave === 'function' && currentId > 0) {
                window.mceGroupsSave(currentId).then(function(res) {
                    if (res && res.success === false && !res.skipped) {
                        console.warn('[MCE] grup eslestirme kaydi basarisiz:', res.message);
                    }
                }).catch(function(err) { console.warn('[MCE] group save hatasi:', err); });
            }

            // ── Lokasyon eslestirmelerini de ayni save akisinda kaydet ──
            if (typeof window.mceLocSave === 'function' && currentId > 0) {
                window.mceLocSave().then(function(res) {
                    if (res && res.success === false && !res.skipped) {
                        console.warn('[MCE] lokasyon kaydi basarisiz:', res.message);
                    }
                }).catch(function(err) { console.warn('[MCE] location save hatasi:', err); });
            }

            // ── Belge kilitlerini (planlama) de ayni save akisinda kaydet ──
            if (typeof window.mceDocLockSave === 'function' && currentId > 0) {
                window.mceDocLockSave().then(function(res) {
                    if (res && res.success === false && !res.skipped) {
                        console.warn('[MCE] belge kilidi kaydi basarisiz:', res.message);
                    }
                }).catch(function(err) { console.warn('[MCE] doc-lock save hatasi:', err); });
            }

            // ── Ozellik eslestirmelerini de ayni save akisinda kaydet ──
            // (Sadece trackCombinations acikken + Ozellikler sekmesi bir kere yuklendiyse liste doludur)
            var tracking = $('mceTrackCombinations') && $('mceTrackCombinations').checked;
            var featList = document.getElementById('mceFeaturesList');
            if (tracking && featList && featList.querySelector('.mce-feature-chk') && currentId > 0) {
                if (typeof window.mceFeatureSave === 'function') {
                    try { window.mceFeatureSave({ silent: true }); }
                    catch (e) { console.warn('[MCE] feature save hatasi:', e); }
                }
            }
        })
        .catch(function(e) {
            showMsg('Kayit hatasi: ' + e.message, false);
        })
        .finally(function() {
            $('mceSaveBtn').disabled = false;
        });
    };

