    /**
     * Ana birim + birim 1..5 arasinda ayni olcu birimi iki kez secilemesin.
     * Her dropdown'in option'larini dolasip, baska bir satirda kullanilmis
     * option'lari (kendi secimi haric) disabled yapar.
     */
    function mceUnitRefreshSelects() {
        var usedCodes = new Set();
        var master = document.getElementById('mceUnitMaster');
        if (master && master.value) usedCodes.add(master.value);
        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!row) continue;
            var sel = row.querySelector('.mce-unit-code');
            if (sel && sel.value) usedCodes.add(sel.value);
        }

        function updateSelect(sel) {
            if (!sel) return;
            var own = sel.value;
            Array.prototype.forEach.call(sel.options, function(opt) {
                if (!opt.value) { opt.disabled = false; return; }
                opt.disabled = (opt.value !== own) && usedCodes.has(opt.value);
            });
        }

        updateSelect(master);
        for (var j = 1; j <= 5; j++) {
            var r2 = document.querySelector('[data-unit-line="' + j + '"]');
            if (!r2) continue;
            updateSelect(r2.querySelector('.mce-unit-code'));
        }

        // Satir aktifligi: ardisik kural
        mceUnitRefreshEnabledRows();
    }

    /**
     * Ardisik aktiflik: Birim N tanimlanmadan Birim N+1 pasif kalir.
     * "Tanimli" = kod dropdown'da secim yapilmis.
     */
    function mceUnitRefreshEnabledRows() {
        var prevFilled = true; // Birim 1 her zaman aktif
        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!row) continue;
            var codeEl = row.querySelector('.mce-unit-code');
            var multEl = row.querySelector('.mce-unit-mult');
            var shouldEnable = prevFilled;
            if (codeEl) codeEl.disabled = !shouldEnable;
            if (multEl) multEl.disabled = !shouldEnable;
            row.classList.toggle('mce-row-disabled', !shouldEnable);
            // Satir pasifse icerigini temizle (yanlis veri kalmasin)
            if (!shouldEnable) {
                if (codeEl) codeEl.value = '';
                if (multEl) { multEl.value = ''; multEl.classList.remove('is-invalid'); }
            }
            // Bir sonraki satir icin: bu satir hem aktif hem kod dolu olmali
            prevFilled = shouldEnable && !!(codeEl && codeEl.value);
        }
    }

    /**
     * Birim seçili ise carpan > 0 olmali.
     * Kod dolu ama carpan bos/0 ise input'a is-invalid class'i eklenir.
     */
    function mceUnitValidateRow(row) {
        if (!row) return true;
        var codeEl = row.querySelector('.mce-unit-code');
        var multEl = row.querySelector('.mce-unit-mult');
        if (!codeEl || !multEl) return true;
        var hasCode = !!codeEl.value;
        var mult = parseFloat(multEl.value) || 0;
        if (hasCode && mult <= 0) {
            multEl.classList.add('is-invalid');
            return false;
        }
        multEl.classList.remove('is-invalid');
        return true;
    }
    function mceUnitValidateAll() {
        var ok = true;
        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!mceUnitValidateRow(row)) ok = false;
        }
        return ok;
    }

    window.mceUnitLoad = function() {
        // Kaydedilmis kayit varsa conversions da gelir; yeni kartta sadece availableUnits cekilir
        var url = currentId && currentId > 0
            ? '/Logistics/GetStockUnitConversions?stockCardId=' + currentId
            : '/Logistics/GetStockUnitConversions?stockCardId=0';
        fetch(url, { credentials: 'same-origin' })
            .then(function(r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function(data) {
                _availableUnits = data.availableUnits || [];
                console.log('[MCE] unitLoad: availableUnits=' + _availableUnits.length + ', conversions=' + (data.conversions || []).length);
                mceUnitPopulateSelects();

                // Ölçü birimi tanimli degilse kullaniciyi uyar
                if (_availableUnits.length === 0) {
                    mceShowUnitWarning('Hic aktif olcu birimi tanimlanmamis. Lutfen once Lojistik > Sabit Tanimlamalar > Olcu Birimleri ekranindan tanimlama yapiniz.');
                } else {
                    mceShowUnitWarning('');
                }

                var conversions = data.conversions || [];
                // Satır 0 (line_no=0) → master birim
                var master = conversions.find(function(c) { return c.lineNo === 0; });
                if (master) document.getElementById('mceUnitMaster').value = master.unitCode;

                // Satır 1–5 — scope cakismasini onlemek icin yerel ad
                for (var i = 1; i <= 5; i++) {
                    var row = document.querySelector('[data-unit-line="' + i + '"]');
                    if (!row) continue;
                    var conv = conversions.find(function(c) { return c.lineNo === i; });
                    row.querySelector('.mce-unit-code').value = conv ? conv.unitCode : '';
                    row.querySelector('.mce-unit-mult').value = conv ? conv.multiplier : '';
                }
                _unitLoaded = true;

                // Dropdown'larda tekrari engelle + change listener'lari bagla (bir kez)
                mceUnitRefreshSelects();
                mceUnitBindListenersOnce();
            })
            .catch(function(e) { console.error('[MCE] unit load error:', e); });
    };

    var _unitListenersBound = false;
    function mceUnitBindListenersOnce() {
        if (_unitListenersBound) return;
        _unitListenersBound = true;

        // Ana birim degistiginde refresh
        var master = document.getElementById('mceUnitMaster');
        if (master) {
            master.addEventListener('change', function() { mceUnitRefreshSelects(); });
        }
        // Her satir: kod degistiginde dropdown'lari yenile + carpana odaklan.
        // Anlik kirmizi uyari / titresim YOK — dogrulama Kaydet'te yapilir.
        for (var i = 1; i <= 5; i++) {
            (function(i) {
                var row = document.querySelector('[data-unit-line="' + i + '"]');
                if (!row) return;
                var codeEl = row.querySelector('.mce-unit-code');
                var multEl = row.querySelector('.mce-unit-mult');
                if (codeEl) {
                    codeEl.addEventListener('change', function() {
                        mceUnitRefreshSelects();
                        // Onceden isaretlenmis is-invalid (kaydet sirasindan kalma) varsa temizle
                        if (multEl) multEl.classList.remove('is-invalid');
                        if (codeEl.value) {
                            // Kod secildiyse carpan 0 ise temizle ve odaklan
                            if (multEl && !parseFloat(multEl.value)) {
                                multEl.value = '';
                                multEl.focus();
                            }
                        } else {
                            // Kod temizlendiyse carpan da sifirlansin
                            if (multEl) multEl.value = '';
                        }
                    });
                }
                // Kullanici carpan yazarken onceki hata isaretini temizle
                if (multEl) {
                    multEl.addEventListener('input', function() {
                        if (parseFloat(multEl.value) > 0) multEl.classList.remove('is-invalid');
                    });
                }
            })(i);
        }
    }

    /**
     * Olcu birimlerini kaydeder. Promise (success: bool, message?: string) doner.
     * Genel Kaydet (mceSave) icinden cagrildigi icin buton referansi kullanilmaz.
     * stockCardId=0 ise (yeni kart, henuz kayit yok) atlar.
     */
    window.mceUnitSave = function() {
        var errDiv = document.getElementById('mceUnitError');
        if (errDiv) errDiv.style.display = 'none';

        if (!currentId || currentId <= 0) {
            return Promise.resolve({ success: true, skipped: true });
        }

        // Tum satirlari dogrula (carpan > 0 kurali)
        if (!mceUnitValidateAll()) {
            var msg0 = 'Olcu birimi secilen satirlarda carpan degeri sifirdan buyuk olmalidir.';
            if (errDiv) { errDiv.textContent = msg0; errDiv.style.display = 'block'; }
            return Promise.resolve({ success: false, message: msg0 });
        }

        // Birim satirlarindan data topla
        var items = [];
        var masterEl = document.getElementById('mceUnitMaster');
        var masterCode = masterEl ? masterEl.value : '';
        if (masterCode) items.push({ unitCode: masterCode, multiplier: 1 });

        var usedCodes = masterCode ? [masterCode.toUpperCase()] : [];

        for (var i = 1; i <= 5; i++) {
            var row = document.querySelector('[data-unit-line="' + i + '"]');
            if (!row) continue;
            var code = row.querySelector('.mce-unit-code').value;
            var mult = parseFloat(row.querySelector('.mce-unit-mult').value) || 0;
            if (!code) continue;
            var upper = code.toUpperCase();
            if (usedCodes.indexOf(upper) !== -1) {
                var msg1 = 'Ayni olcu birimi birden fazla tanimlanamaz: ' + code;
                if (errDiv) { errDiv.textContent = msg1; errDiv.style.display = 'block'; }
                return Promise.resolve({ success: false, message: msg1 });
            }
            usedCodes.push(upper);
            if (mult <= 0) {
                var msg2 = '"' + code + '" icin carpan degeri sifirdan buyuk olmalidir.';
                if (errDiv) { errDiv.textContent = msg2; errDiv.style.display = 'block'; }
                return Promise.resolve({ success: false, message: msg2 });
            }
            items.push({ unitCode: code, multiplier: mult });
        }

        // Hic birim tanimlanmamissa sunucuya gitme (mevcut kayit varsa temizle:
        // yine de sunucuya bos items gonderip temizlenmesini saglayalim)
        var payload = {
            itemId: currentId,
            items: items.map(function(it) { return { unitCode: it.unitCode, multiplier: it.multiplier }; })
        };

        return fetch('/Logistics/SaveStockUnitConversions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success && errDiv) {
                errDiv.textContent = data.message || 'Olcu birimi kaydi hatali.';
                errDiv.style.display = 'block';
            }
            return data;
        })
        .catch(function(e) {
            var msg = 'Baglanti hatasi: ' + e.message;
            if (errDiv) { errDiv.textContent = msg; errDiv.style.display = 'block'; }
            return { success: false, message: msg };
        });
    };

    // ── Lokasyonlar ────────────────────────────────────────────────
    var _mceLocState = { links: [], available: [] };

    function mceLocEsc(s) {
        var d = document.createElement('div');
        d.textContent = s == null ? '' : String(s);
        return d.innerHTML;
    }
    function mceLocTypeLabel(code) {
        var map = { FACTORY: 'Fabrika', SECTION: 'Bolum', SHELF: 'Raf', BIN: 'Hucre' };
        return map[code] || (code || '');
    }
    function mceLocSetError(msg) {
        var el = document.getElementById('mceLocError');
        if (!el) return;
        if (!msg) { el.style.display = 'none'; el.textContent = ''; return; }
        el.textContent = msg; el.style.display = 'block';
    }

    window.mceLocLoad = function() {
        if (!currentId || currentId <= 0) return Promise.resolve();
        mceLocSetError('');
        return fetch('/Logistics/GetItemLocations?itemId=' + currentId, { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                _mceLocState.links = (data && data.links) ? data.links.slice() : [];
                _mceLocState.available = (data && data.availableLocations) ? data.availableLocations.slice() : [];
                mceLocRenderPicker();
                mceLocRenderList();
            })
            .catch(function(e) { mceLocSetError('Lokasyon listesi yuklenemedi: ' + e.message); });
    };

    function mceLocRenderPicker() {
        var sel = document.getElementById('mceLocPick');
        if (!sel) return;
        var usedIds = {};
        _mceLocState.links.forEach(function(l) { usedIds[l.locationId] = true; });
        var options = ['<option value="">— Seçiniz —</option>'];
        _mceLocState.available.forEach(function(a) {
            if (usedIds[a.id]) return;
            var label = a.locationPath || (a.locationCode + (a.locationName ? ' — ' + a.locationName : ''));
            label += ' (' + mceLocTypeLabel(a.locationTypeCode) + ')';
            options.push('<option value="' + a.id + '">' + mceLocEsc(label) + '</option>');
        });
        sel.innerHTML = options.join('');
    }

    function mceLocRenderList() {
        var body = document.getElementById('mceLocListBody');
        var empty = document.getElementById('mceLocEmpty');
        var table = document.getElementById('mceLocListTable');
        var count = document.getElementById('mceLocCount');
        if (!body || !empty || !table) return;
        var links = _mceLocState.links;
        if (count) {
            if (links.length > 0) { count.textContent = String(links.length); count.style.display = ''; }
            else count.style.display = 'none';
        }
        if (links.length === 0) {
            body.innerHTML = '';
            empty.style.display = '';
            table.style.display = 'none';
            return;
        }
        empty.style.display = 'none';
        table.style.display = '';
        body.innerHTML = links.map(function(l, idx) {
            var radio = '<label style="display:inline-flex;align-items:center;gap:6px;cursor:pointer;">' +
                '<input type="radio" name="mceLocDefault" ' + (l.isDefault ? 'checked' : '') + ' onchange="mceLocSetDefault(' + idx + ')" />' +
                (l.isDefault ? '<span style="color:#34d399;font-weight:600;font-size:.74rem;">Varsayılan</span>' : '<span style="color:rgba(255,255,255,.45);font-size:.74rem;">Ayarla</span>') +
                '</label>';
            var delBtn = '<button type="button" class="mce-btn mce-btn--danger" onclick="mceLocRemove(' + idx + ')" style="font-size:.72rem;padding:4px 10px;">Sil</button>';
            var pathCell = l.locationPath
                ? '<div style="font-size:.7rem;color:rgba(255,255,255,.4);margin-top:2px;">' + mceLocEsc(l.locationPath) + '</div>'
                : '';
            return '<tr>' +
                '<td class="mce-comb-td">' + radio + '</td>' +
                '<td class="mce-comb-td mce-comb-code">' + mceLocEsc(l.locationCode) + '</td>' +
                '<td class="mce-comb-td mce-comb-name">' + mceLocEsc(l.locationName || '') + pathCell + '</td>' +
                '<td class="mce-comb-td">' + mceLocEsc(mceLocTypeLabel(l.locationTypeCode)) + '</td>' +
                '<td class="mce-comb-td" style="text-align:right;">' + delBtn + '</td>' +
                '</tr>';
        }).join('');
    }

    window.mceLocAdd = function() {
        var sel = document.getElementById('mceLocPick');
        if (!sel) return;
        var locId = parseInt(sel.value, 10);
        if (!locId) { mceLocSetError('Lutfen bir lokasyon secin.'); return; }
        // Once eklenmis mi?
        if (_mceLocState.links.some(function(l) { return l.locationId === locId; })) {
            mceLocSetError('Bu lokasyon zaten eklenmis.');
            return;
        }
        mceLocSetError('');
        var avail = _mceLocState.available.find(function(a) { return a.id === locId; });
        if (!avail) return;
        // Ilk satirsa otomatik varsayilan
        var isFirst = _mceLocState.links.length === 0;
        _mceLocState.links.push({
            locationId: avail.id,
            locationCode: avail.locationCode,
            locationName: avail.locationName,
            locationTypeCode: avail.locationTypeCode,
            isDefault: isFirst,
            sortOrder: _mceLocState.links.length
        });
        sel.value = '';
        mceLocRenderPicker();
        mceLocRenderList();
        // Otomatik kaydet
        mceLocSave();
    };

    window.mceLocRemove = function(idx) {
        if (idx < 0 || idx >= _mceLocState.links.length) return;
        var removed = _mceLocState.links.splice(idx, 1)[0];
        // Silinen varsayilansa kalan ilk satiri varsayilan yap
        if (removed && removed.isDefault && _mceLocState.links.length > 0) {
            _mceLocState.links[0].isDefault = true;
        }
        mceLocRenderPicker();
        mceLocRenderList();
        mceLocSave();
    };

    window.mceLocSetDefault = function(idx) {
        if (idx < 0 || idx >= _mceLocState.links.length) return;
        _mceLocState.links.forEach(function(l, i) { l.isDefault = (i === idx); });
        mceLocRenderList();
        mceLocSave();
    };

    window.mceLocSave = function() {
        if (!currentId || currentId <= 0) return Promise.resolve({ success: true });
        mceLocSetError('');
        var payload = {
            itemId: currentId,
            items: _mceLocState.links.map(function(l) {
                return { locationId: l.locationId, isDefault: !!l.isDefault };
            })
        };
        return fetch('/Logistics/SaveItemLocations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (!d || !d.success) mceLocSetError(d && d.message ? d.message : 'Kaydedilemedi.');
            return d;
        })
        .catch(function(e) {
            mceLocSetError('Baglanti hatasi: ' + e.message);
            return { success: false };
        });
    };

    // ── Malzeme - Lokasyon eslestirmeleri ──────────────────────────
    // state: o anki kart icin secili lokasyon listesi — [{locationId, locationCode, locationName, locationTypeCode, isDefault, sortOrder}]
    var _mceLocLinks = [];
    var _mceLocAvailable = [];

    window.mceLocLoad = function() {
        var tbody = document.getElementById('mceLocListBody');
        var empty = document.getElementById('mceLocEmpty');
        var pickSel = document.getElementById('mceLocPick');
        var errDiv = document.getElementById('mceLocError');
        if (errDiv) errDiv.style.display = 'none';

        if (!currentId || currentId <= 0) {
            if (tbody) tbody.innerHTML = '';
            if (empty) { empty.style.display = 'block'; empty.textContent = 'Once malzeme kartini kaydediniz, sonra lokasyon ekleyebilirsiniz.'; }
            if (pickSel) pickSel.innerHTML = '<option value="">— Seciniz —</option>';
            _mceLocLinks = [];
            _mceLocAvailable = [];
            return;
        }

        fetch('/Logistics/GetItemLocations?itemId=' + currentId, { credentials: 'same-origin' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                _mceLocLinks = (data && data.links) ? data.links.slice() : [];
                _mceLocAvailable = (data && data.availableLocations) ? data.availableLocations.slice() : [];
                mceLocRender();
            })
            .catch(function(e) {
                if (errDiv) {
                    errDiv.textContent = 'Lokasyonlar yuklenemedi: ' + e.message;
                    errDiv.style.display = 'block';
                }
            });
    };

    function mceLocTypeLabel(code) {
        if (!code) return '';
        var m = { WAREHOUSE: 'Depo', FLOOR: 'Kat', AISLE: 'Kor', SHELF: 'Raf', BIN: 'Goz' };
        return m[code.toUpperCase()] || code;
    }

    function mceLocRender() {
        var tbody = document.getElementById('mceLocListBody');
        var empty = document.getElementById('mceLocEmpty');
        var pickSel = document.getElementById('mceLocPick');
        var count = document.getElementById('mceLocCount');

        if (pickSel) {
            var taken = {};
            _mceLocLinks.forEach(function(l) { taken[l.locationId] = true; });
            var opts = ['<option value="">— Seciniz —</option>'];
            _mceLocAvailable.forEach(function(a) {
                if (taken[a.id]) return;
                var label = (a.locationCode || '') + (a.locationName ? ' — ' + a.locationName : '');
                opts.push('<option value="' + a.id + '">' + label + '</option>');
            });
            pickSel.innerHTML = opts.join('');
        }

        if (!tbody) return;
        if (_mceLocLinks.length === 0) {
            tbody.innerHTML = '';
            if (empty) { empty.style.display = 'block'; empty.textContent = 'Henuz atanmis lokasyon yok.'; }
            if (count) { count.style.display = 'none'; count.textContent = '0'; }
            return;
        }
        if (empty) empty.style.display = 'none';
        if (count) { count.style.display = 'inline-block'; count.textContent = String(_mceLocLinks.length); }

        tbody.innerHTML = _mceLocLinks.map(function(l, idx) {
            var def = l.isDefault ? 'checked' : '';
            return '<tr>' +
                '<td class="mce-comb-td" style="text-align:center;">' +
                    '<input type="radio" name="mceLocDefault" ' + def + ' onchange="mceLocSetDefault(' + idx + ')" title="Varsayilan yap" />' +
                '</td>' +
                '<td class="mce-comb-td" style="font-family:monospace;">' + (l.locationCode || '') + '</td>' +
                '<td class="mce-comb-td">' + (l.locationName || '') + '</td>' +
                '<td class="mce-comb-td">' + mceLocTypeLabel(l.locationTypeCode) + '</td>' +
                '<td class="mce-comb-td" style="text-align:center;">' +
                    '<button type="button" class="mce-btn mce-btn--danger" onclick="mceLocRemove(' + idx + ')" style="padding:3px 10px;font-size:.72rem;">Kaldir</button>' +
                '</td>' +
            '</tr>';
        }).join('');
    }

    window.mceLocAdd = function() {
        var pickSel = document.getElementById('mceLocPick');
        var errDiv = document.getElementById('mceLocError');
        if (errDiv) errDiv.style.display = 'none';
        var id = pickSel ? parseInt(pickSel.value, 10) : NaN;
        if (!id) {
            if (errDiv) { errDiv.textContent = 'Once bir lokasyon seciniz.'; errDiv.style.display = 'block'; }
            return;
        }
        if (_mceLocLinks.some(function(l) { return l.locationId === id; })) {
            if (errDiv) { errDiv.textContent = 'Bu lokasyon zaten eklenmis.'; errDiv.style.display = 'block'; }
            return;
        }
        var found = _mceLocAvailable.find(function(a) { return a.id === id; });
        if (!found) return;
        var isDefault = _mceLocLinks.length === 0;
        _mceLocLinks.push({
            locationId: found.id,
            locationCode: found.locationCode,
            locationName: found.locationName,
            locationTypeCode: found.locationTypeCode,
            isDefault: isDefault,
            sortOrder: _mceLocLinks.length
        });
        mceLocRender();
    };

    window.mceLocRemove = function(idx) {
        if (idx < 0 || idx >= _mceLocLinks.length) return;
        var removed = _mceLocLinks.splice(idx, 1)[0];
        if (removed && removed.isDefault && _mceLocLinks.length > 0) {
            _mceLocLinks[0].isDefault = true;
        }
        mceLocRender();
    };

    window.mceLocSetDefault = function(idx) {
        _mceLocLinks.forEach(function(l, i) { l.isDefault = (i === idx); });
        mceLocRender();
    };

    /**
     * Lokasyonlari kaydeder. Promise (success, message?) doner.
     * Ana mceSave icinden cagrildigi icin buton referansi kullanilmaz.
     */
    window.mceLocSave = function() {
        var errDiv = document.getElementById('mceLocError');
        if (errDiv) errDiv.style.display = 'none';

        if (!currentId || currentId <= 0) {
            return Promise.resolve({ success: true, skipped: true });
        }

        var payload = {
            itemId: currentId,
            items: _mceLocLinks.map(function(l, i) {
                return { locationId: l.locationId, isDefault: !!l.isDefault, sortOrder: i };
            })
        };

        return fetch('/Logistics/SaveItemLocations', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success && errDiv) {
                errDiv.textContent = data.message || 'Lokasyon kaydi hatali.';
                errDiv.style.display = 'block';
            }
            return data;
        })
        .catch(function(e) {
            var msg = 'Baglanti hatasi: ' + e.message;
            if (errDiv) { errDiv.textContent = msg; errDiv.style.display = 'block'; }
            return { success: false, message: msg };
        });
    };

    // ── Ozellik Eslestirme (Kombinasyon Takibi acik iken) ──────────
    function featureEsc(s) {
        var d = document.createElement('div');
        d.textContent = s == null ? '' : String(s);
        return d.innerHTML;
    }

    window.mceFeatureLoad = function() {
        if (!currentId || currentId <= 0) return;
        var listEl = document.getElementById('mceFeaturesList');
        var emptyEl = document.getElementById('mceFeaturesEmpty');
        var errEl = document.getElementById('mceFeaturesError');
        var okEl = document.getElementById('mceFeaturesOk');
        if (errEl) errEl.style.display = 'none';
        if (okEl) okEl.style.display = 'none';
        if (listEl) listEl.innerHTML = '<div style="padding:12px;color:rgba(255,255,255,.35);font-size:.8rem;">Yukleniyor...</div>';

        fetch('/Logistics/GetStockFeatures?stockCardId=' + currentId, { credentials: 'same-origin' })
            .then(function(r) {
                if (!r.ok) throw new Error('HTTP ' + r.status);
                return r.json();
            })
            .then(function(data) {
                var features = (data && data.features) || [];
                var headerEl = document.getElementById('mceFeaturesHeader');
                if (features.length === 0) {
                    listEl.innerHTML = '';
                    if (emptyEl) emptyEl.style.display = '';
                    if (headerEl) headerEl.style.display = 'none';
                    updateFeatureCount(0, 0);
                    return;
                }
                if (emptyEl) emptyEl.style.display = 'none';
                if (headerEl) headerEl.style.display = 'flex';

                // Veri tipi Turkcelestirme: server'dan gelen "TEXT/NUMBER/DATE" -> "Metin/Sayisal/Tarih"
                function mceDataTypeTr(dt) {
                    var v = (dt || '').toString().toUpperCase();
                    if (v === 'TEXT')   return 'Metin';
                    if (v === 'NUMBER' || v === 'NUMERIC') return 'Sayısal';
                    if (v === 'DATE')   return 'Tarih';
                    return dt || '';
                }
                listEl.innerHTML = features.map(function(f) {
                    var checked = f.linked ? 'checked' : '';
                    var chkId = 'mceFeatChk_' + f.id;
                    var printId = 'mceFeatPrint_' + f.id;
                    // printDescription: server'dan bagli olmayan ozellik icin true default gelir —
                    // ilk kez baglandiginda da "dizaynda aciklama bas" varsayilan olarak acik olsun.
                    var printChecked = (f.printDescription !== false) ? 'checked' : '';
                    // Baglanmamissa (linked=false) print switch pasif (disabled + soluk)
                    var printDisabled = f.linked ? '' : 'disabled';
                    var printWrapOpacity = f.linked ? '1' : '0.35';
                    return '' +
                        '<div class="mce-feature-row" style="display:flex;align-items:center;gap:14px;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);transition:background .12s;">' +
                            '<div style="flex:1;min-width:0;">' +
                                '<div style="font-size:.86rem;font-weight:600;color:rgba(255,255,255,.85);">' + featureEsc(f.name) + '</div>' +
                                '<div style="font-size:.7rem;color:rgba(255,255,255,.4);margin-top:2px;">' +
                                    featureEsc(f.code || '') +
                                    (f.dataType ? ' · <span style="color:#a5b4fc;">' + featureEsc(mceDataTypeTr(f.dataType)) + '</span>' : '') +
                                    (f.unitOfMeasure ? ' · ' + featureEsc(f.unitOfMeasure) : '') +
                                '</div>' +
                            '</div>' +
                            '<div style="width:80px;display:flex;align-items:center;justify-content:center;">' +
                                '<label class="mce-switch" for="' + chkId + '">' +
                                    '<input type="checkbox" id="' + chkId + '" class="mce-feature-chk" data-feature-id="' + f.id + '" ' + checked + ' />' +
                                    '<span class="mce-switch-track"></span>' +
                                '</label>' +
                            '</div>' +
                            '<div data-print-wrap="' + f.id + '" style="min-width:160px;display:flex;align-items:center;justify-content:center;opacity:' + printWrapOpacity + ';transition:opacity .15s;" title="Bu ozellik secimine ait aciklama dizaynda basilsin">' +
                                '<label class="mce-switch" for="' + printId + '">' +
                                    '<input type="checkbox" id="' + printId + '" class="mce-feature-print-chk" data-feature-id="' + f.id + '" ' + printChecked + ' ' + printDisabled + ' />' +
                                    '<span class="mce-switch-track"></span>' +
                                '</label>' +
                            '</div>' +
                        '</div>';
                }).join('');

                // "Bagli" toggle'u ile "Dizaynda Aciklama" switch'ini sync et:
                // bagli kapandiginda print pasif gorunsun + disabled olsun.
                document.querySelectorAll('#mceFeaturesList .mce-feature-chk').forEach(function(linkChk) {
                    linkChk.addEventListener('change', function() {
                        var id = linkChk.getAttribute('data-feature-id');
                        var printChk = document.getElementById('mceFeatPrint_' + id);
                        var wrap = document.querySelector('[data-print-wrap="' + id + '"]');
                        if (!printChk || !wrap) return;
                        printChk.disabled = !linkChk.checked;
                        wrap.style.opacity = linkChk.checked ? '1' : '0.35';
                    });
                });

                var linkedCount = features.filter(function(f) { return f.linked; }).length;
                updateFeatureCount(linkedCount, features.length);
            })
            .catch(function(e) {
                listEl.innerHTML = '';
                if (errEl) {
                    errEl.textContent = 'Yukleme hatasi: ' + e.message;
                    errEl.style.display = 'block';
                }
            });
    };

    function updateFeatureCount(linked, total) {
        var badge = document.getElementById('mceFeatCount');
        if (badge) badge.textContent = String(linked);
    }

    window.mceFeatureSave = function(opts) {
        opts = opts || {};
        if (!currentId || currentId <= 0) return Promise.resolve({ success: false, skipped: true });
        var errEl = document.getElementById('mceFeaturesError');
        if (errEl) errEl.style.display = 'none';

        // Her bagli (checked) feature icin {featureId, printDescriptionInDesign} topla.
        var items = [];
        document.querySelectorAll('#mceFeaturesList .mce-feature-chk:checked').forEach(function(cb) {
            var id = parseInt(cb.getAttribute('data-feature-id'), 10);
            if (id > 0) {
                var printChk = document.getElementById('mceFeatPrint_' + id);
                items.push({
                    featureId: id,
                    printDescriptionInDesign: printChk ? !!printChk.checked : true
                });
            }
        });

        return fetch('/Logistics/SaveStockFeatures', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ itemId: currentId, items: items }),
        })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data && data.success) {
                    var total = document.querySelectorAll('#mceFeaturesList .mce-feature-chk').length;
                    updateFeatureCount(items.length, total);
                } else {
                    if (errEl && !opts.silent) {
                        errEl.textContent = (data && data.message) || 'Ozellik kaydetme basarisiz.';
                        errEl.style.display = 'block';
                    }
                    console.warn('[MCE] feature save:', (data && data.message) || 'unknown');
                }
                return data;
            })
            .catch(function(e) {
                if (errEl && !opts.silent) {
                    errEl.textContent = 'Baglanti hatasi: ' + e.message;
                    errEl.style.display = 'block';
                }
                console.warn('[MCE] feature save error:', e);
                return { success: false, message: e.message };
            });
    };

})();
</script>
}
