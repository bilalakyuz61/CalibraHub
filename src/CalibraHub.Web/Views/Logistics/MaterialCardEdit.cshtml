    // ── Grup katlanma durumu persist (localStorage) ───────────────
    // Kullanici hangi gruplari acik/kapali birakmissa ekrani tekrar actiginda
    // ayni duruma donek. Anahtar: "mce-groups-open" (tum MaterialCardEdit icin ortak)
    (function initGroupPersistence() {
        var LS_KEY = 'mce-groups-open';
        var state = {};
        try { state = JSON.parse(localStorage.getItem(LS_KEY) || '{}') || {}; }
        catch (e) { state = {}; }

        document.querySelectorAll('details[data-group-key]').forEach(function(d) {
            var key = d.getAttribute('data-group-key');
            if (!key) return;
            // Kaydedilmis durum false ise kapat (varsayilan acik)
            if (state[key] === false) d.open = false;

            d.addEventListener('toggle', function() {
                state[key] = d.open;
                try { localStorage.setItem(LS_KEY, JSON.stringify(state)); }
                catch (e) { /* quota vs. sessiz gec */ }
            });
        });
    })();

