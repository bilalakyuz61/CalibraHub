    // Malzeme Kodu alaninda blur veya Enter: mevcut kart varsa in-place yukle, yoksa formu temizle
    (function initCodeLookup() {
        var codeInput = document.getElementById('mceMaterialCode');
        if (!codeInput) return;

        var _lastCheckedCode = '';

        function resetForm(keepCode) {
            currentId = 0;
            mceFormatMeta(null, keepCode || '', '');
            _setVal('mceMaterialCode', keepCode || '');
            _setVal('mceMaterialName', '');
            _setVal('mceMaterialTypeId', '');
            _setChk('mceTrackCombinations', false);
            _setVal('mceTaxRate', 20);
            (function () {
                if ($('mceTraceability')) $('mceTraceability').checked = false;
                if ($('mceTrackingMode')) $('mceTrackingMode').checked = false;
                var w = document.getElementById('mceTrackingModeWrap'); if (w) w.style.display = 'none';
            })();
            _setDisp('mceDeleteBtn', 'none');
            var pendingUnitId = '';
            window._mceApplyUnitId = function() {
                var el = $('mceUnitId');
                if (!el) return;
                el.value = pendingUnitId;
                if (typeof mceCbxRebuild === 'function') mceCbxRebuild(el);
                if (typeof mceUnitRefreshSelects === 'function') mceUnitRefreshSelects();
            };
            if (window._mceUnitsLoaded) window._mceApplyUnitId();
            renderCombinations([]);
            updateCombNav(false, 0);
            history.replaceState(null, '', '/Logistics/MaterialCardEdit');
        }

        function lookupByCode() {
            var code = (codeInput.value || '').trim();
            if (!code || code === _lastCheckedCode) return;
            _lastCheckedCode = code;

            fetch('/Logistics/GetMaterialCard?code=' + encodeURIComponent(code), { credentials: 'same-origin' })
                .then(function(r) { return r.ok ? r.json() : null; })
                .then(function(data) {
                    if (!data || !data.stockCardId) {
                        if (currentId > 0) resetForm(code);
                        return;
                    }
                    if (data.stockCardId === currentId) return;
                    currentId = data.stockCardId;
                    populate(data);
                    history.replaceState(null, '', '/Logistics/MaterialCardEdit?id=' + currentId);
                })
                .catch(function() { });
