@{
    ViewData["Title"] = "Makine Tanımlamaları";
    ViewData["FormCode"] = "MACHINES";
    ViewData["BodyClass"] = "page-machines";
}

@section Styles {
<style>
/* ── Tema değişkenleri (light default) ── */
.mch-page {
    --mch-bg:           #f8fafc;
    --mch-surface:      #ffffff;
    --mch-surface2:     #f1f5f9;
    --mch-border:       #e2e8f0;
    --mch-border-light: #f1f5f9;
    --mch-text:         #0f172a;
    --mch-text-muted:   #64748b;
    --mch-input-bg:     #ffffff;
    --mch-input-disabled:#f8fafc;
    --mch-accent:       var(--theme-accent, #2563eb);
    --mch-toast-ok-bg:  #d1fae5; --mch-toast-ok-tx: #065f46;
    --mch-toast-er-bg:  #fee2e2; --mch-toast-er-tx: #991b1b;
}
body.app-theme-dark .mch-page {
    --mch-bg:           #080c17;
    --mch-surface:      #0d1323;
    --mch-surface2:     #111827;
    --mch-border:       rgba(255,255,255,.09);
    --mch-border-light: rgba(255,255,255,.04);
    --mch-text:         #e2e8f0;
    --mch-text-muted:   #94a3b8;
    --mch-input-bg:     rgba(255,255,255,.06);
    --mch-input-disabled:rgba(255,255,255,.03);
    --mch-accent:       var(--theme-accent, #6366f1);
    --mch-toast-ok-bg:  rgba(34,197,94,.18); --mch-toast-ok-tx: #4ade80;
    --mch-toast-er-bg:  rgba(239,68,68,.18); --mch-toast-er-tx: #f87171;
}

/* ── Layout reset ── */
.page-machines .integrator-dashboard {
    height:100% !important; min-height:0 !important;
    padding:0 !important; max-width:none !important;
    background:transparent !important; box-shadow:none !important;
    border:none !important; border-radius:0 !important;
}
.page-machines .integrator-dashboard__content {
    display:flex !important; flex-direction:column !important;
    width:100% !important; max-width:none !important;
    min-height:0 !important; padding:0 !important; margin:0 !important;
    overflow:hidden !important; height:100% !important;
}

.mch-page {
    padding:14px 22px; height:100%; overflow:auto;
    display:flex; flex-direction:column; gap:12px;
    background: var(--mch-bg); color: var(--mch-text);
}

/* ── Toolbar (KITT animasyonlu) ── */
.mch-toolbar {
    display:flex; gap:8px; align-items:center;
    padding-bottom:10px;
    border-bottom: 1px solid var(--mch-border);
    position: relative; overflow: hidden;
}
.mch-toolbar h1 { margin:0; font-size:16px; }
.mch-toolbar .spacer { flex:1; }
.mch-btn {
    padding:6px 14px; border-radius:7px;
    border:1px solid var(--mch-border);
    background: var(--mch-surface); color: var(--mch-text);
    font-size:13px; font-weight:500; cursor:pointer;
    transition: background .12s, border-color .12s;
}
.mch-btn:hover:not(:disabled) { background: var(--mch-surface2); border-color: var(--mch-accent); }
.mch-btn:disabled { opacity:.4; cursor:not-allowed; }
.mch-btn--primary { background: linear-gradient(135deg, #6366f1, #4f46e5); color:#fff; border-color: #4f46e5; }
.mch-btn--danger  { background:#fef2f2; color:#991b1b; border-color:#fecaca; }
body.app-theme-dark .mch-btn--danger { background: rgba(239,68,68,.12); color:#fca5a5; border-color: rgba(239,68,68,.32); }


/* KITT (yesil tarayici) */
.mch-toolbar::before {
    content:''; position:absolute; left:0; right:0; bottom:0;
    height:2px; pointer-events:none; opacity:0;
    background: linear-gradient(90deg, rgba(0,60,20,0) 0%, rgba(10,120,40,.55) 50%, rgba(0,60,20,0) 100%);
}
.mch-toolbar::after {
    content:''; position:absolute; left:0; bottom:-1px;
    width:18%; height:4px; pointer-events:none; opacity:0;
    background: linear-gradient(90deg, transparent 0%, rgba(34,197,94,.35) 18%, rgba(74,255,140,1) 50%, rgba(34,197,94,.35) 82%, transparent 100%);
    box-shadow: 0 0 10px 2px rgba(34,197,94,.95), 0 0 22px 6px rgba(34,197,94,.55), 0 0 40px 12px rgba(34,197,94,.22);
    border-radius:50%;
}
.mch-toolbar.is-save-flash::before { animation: mchKittBg 1800ms ease-out forwards; }
.mch-toolbar.is-save-flash::after  { animation: mchKittScan 1800ms cubic-bezier(.45,.05,.55,.95) forwards; }
@@keyframes mchKittBg { 0%,100% { opacity:0; } 10%,90% { opacity:1; } }
@@keyframes mchKittScan {
    0% { opacity:0; left:0; } 8% { opacity:1; }
    48% { opacity:1; left:82%; } 52% { opacity:1; left:82%; }
    92% { opacity:1; left:0; } 100% { opacity:0; left:0; }
}

/* ── Body: form + grid 50/50 ── */
.mch-body { display:flex; flex-direction:column; gap:12px; flex:1 1 auto; min-height:0; }

/* Form */
.mch-form {
    background: var(--mch-surface); border:1px solid var(--mch-border);
    border-radius:10px; padding:14px 16px;
    display:grid; grid-template-columns: 140px 1fr 140px 1fr; gap:8px 12px; align-items:center;
}
.mch-form .full { grid-column: 1 / -1; }
.mch-form label { font-size:12px; color: var(--mch-text-muted); font-weight:500; }
.mch-form input, .mch-form select {
    padding:6px 9px; border-radius:6px;
    border:1px solid var(--mch-border);
    background: var(--mch-input-bg); color: var(--mch-text);
    font-size:13px; outline:none;
    transition: border-color .12s, box-shadow .12s;
}
.mch-form input:focus, .mch-form select:focus {
    border-color: var(--mch-accent); box-shadow: 0 0 0 2px rgba(99,102,241,.18);
}
.mch-form input[readonly], .mch-form input:disabled { background: var(--mch-input-disabled); color: var(--mch-text-muted); }
body.app-theme-dark .mch-form select,
html.dark .mch-form select { color-scheme: dark; }
/* select > * = option/optgroup (Razor parser "option" kelimesini OptionTagHelper olarak
   yorumladigi icin universal child selector kullaniliyor — WorkOrderEdit ile ayni desen). */
.mch-form select > * {
    background: var(--mch-surface);
    color: var(--mch-text);
}
body.app-theme-dark .mch-form select > *,
html.dark .mch-form select > * {
    background-color: #0d1323;
    color: #e2e8f0;
}
.mch-form .switch-row { display:flex; align-items:center; gap:8px; }

/* ── Switch (Aktif/Pasif) — Material Card pattern ── */
.mch-switch {
    display:inline-flex; align-items:center; gap:10px;
    cursor:pointer; user-select:none;
}
.mch-switch input { display:none; }
.mch-switch-track {
    width:38px; height:22px; border-radius:11px;
    background: var(--mch-border); position:relative;
    transition: background .15s; flex-shrink:0;
}
.mch-switch input:checked + .mch-switch-track { background: #10b981; }     /* Aktif → yeşil */
body.app-theme-dark .mch-switch input:checked + .mch-switch-track { background: #059669; }
.mch-switch-thumb {
    position:absolute; top:3px; left:3px;
    width:16px; height:16px; border-radius:50%;
    background:#fff; transition: transform .18s;
    box-shadow: 0 1px 3px rgba(0,0,0,.3);
}
.mch-switch input:checked + .mch-switch-track .mch-switch-thumb { transform: translateX(16px); }
.mch-switch-label {
    font-size:13px; font-weight:600;
    color: var(--mch-text-muted);
}
.mch-switch input:checked ~ .mch-switch-label { color:#10b981; }
body.app-theme-dark .mch-switch input:checked ~ .mch-switch-label { color:#86efac; }

/* Grid */
.mch-grid-wrap {
    background: var(--mch-surface); border:1px solid var(--mch-border);
    border-radius:10px; overflow:hidden; flex:1 1 auto; min-height:240px;
    display:flex; flex-direction:column;
}
.mch-grid-toolbar {
    display:flex; gap:8px; align-items:center;
    padding:8px 12px; border-bottom:1px solid var(--mch-border);
}
.mch-grid-toolbar input {
    padding:5px 9px; border-radius:6px;
    border:1px solid var(--mch-border);
    background: var(--mch-input-bg); color: var(--mch-text);
    font-size:13px; min-width:240px; outline:none;
}
.mch-grid-toolbar input:focus { border-color: var(--mch-accent); }
.mch-grid-scroll { flex:1 1 auto; overflow:auto; }

table.mch-grid { width:100%; border-collapse:collapse; font-size:13px; }
.mch-grid th, .mch-grid td {
    padding:7px 10px; border-bottom:1px solid var(--mch-border-light);
    text-align:left; vertical-align:middle;
}
.mch-grid th {
    position:sticky; top:0; z-index:1;
    background: var(--mch-surface2);
    font-size:11px; text-transform:uppercase; letter-spacing:.04em;
    color: var(--mch-text-muted); font-weight:700;
}
.mch-grid tbody tr { cursor:pointer; transition:background .1s; }
.mch-grid tbody tr:hover { background: var(--mch-surface2); }
.mch-grid tbody tr.is-selected { background: rgba(99,102,241,.14); }
.mch-pill {
    display:inline-block; padding:2px 9px; border-radius:9999px;
    font-size:11px; font-weight:600;
}
.mch-pill--green { background: rgba(34,197,94,.18); color:#15803d; }
.mch-pill--red   { background: rgba(239,68,68,.18); color:#b91c1c; }
body.app-theme-dark .mch-pill--green { color:#86efac; }
body.app-theme-dark .mch-pill--red   { color:#fca5a5; }

/* Toast */
#mch-toast-host {
    position:fixed; bottom:24px; right:24px; z-index:9999;
    display:flex; flex-direction:column-reverse; gap:10px;
    pointer-events:none; max-width:380px;
}
.mch-toast {
    pointer-events:auto;
    display:flex; align-items:flex-start; gap:10px;
    min-width:240px; max-width:380px;
    padding:11px 14px; border-radius:10px;
    box-shadow: 0 8px 28px rgba(0,0,0,.32);
    font-size:13px; line-height:1.4;
    animation: mch-toast-slide .22s ease-out;
}
.mch-toast--ok  { background: var(--mch-toast-ok-bg); color: var(--mch-toast-ok-tx); border:1px solid rgba(16,185,129,.32); }
.mch-toast--err { background: var(--mch-toast-er-bg); color: var(--mch-toast-er-tx); border:1px solid rgba(239,68,68,.32); }
.mch-toast.is-leaving { animation: mch-toast-fade .25s ease-in forwards; }
.mch-toast-msg { flex:1 1 auto; }
.mch-toast-close {
    flex-shrink:0; background:transparent; border:none; cursor:pointer;
    color:inherit; opacity:.7; width:22px; height:22px;
    display:inline-flex; align-items:center; justify-content:center;
    border-radius:4px; font-size:16px; line-height:1; padding:0;
}
.mch-toast-close:hover { opacity:1; background: rgba(0,0,0,.08); }
@@keyframes mch-toast-slide { from { transform: translateY(12px); opacity:0; } to { transform: translateY(0); opacity:1; } }
@@keyframes mch-toast-fade  { from { opacity:1; transform: translateY(0); } to { opacity:0; transform: translateY(8px); } }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">
<div class="mch-page">

    @* ── Aksiyon şeridi (KITT animasyonlu Kaydet) ───────────────────── *@
    <div class="mch-toolbar" id="mch-toolbar">
        <h1>Makine Tanımlamaları</h1>
        <span class="spacer"></span>
        <button type="button" class="mch-btn" id="btn-new" title="Yeni makine">+ Yeni</button>
        <button type="button" class="mch-btn mch-btn--primary" id="btn-save">Kaydet</button>
        <button type="button" class="mch-btn mch-btn--danger" id="btn-delete" disabled>Sil</button>
    </div>

    <div class="mch-body">
        @* ── Form ──────────────────────────────────────────── *@
        <div class="mch-form">
            @* MachineCode kullanici UI'da gorunmez — Service tarafinda MAC-{6hex} olarak
               otomatik uretilir, Id ile referans verilir. Hidden alan yine de form'da
               kaliyor cunku update'te selectId() ile dolacak (mevcut kodu korumak icin). *@
            <input type="hidden" id="f-id" />
            <input type="hidden" id="f-machineCode" />

            <label for="f-locationId">Lokasyon *</label>
            <select id="f-locationId" required>
                <option value="">— Lokasyon seçiniz —</option>
            </select>

            <label for="f-machineName">Makine Adı *</label>
            <input type="text" id="f-machineName" maxlength="150" placeholder="örn. CNC Torna 1" />

            <label for="f-machineType">Makine Tipi</label>
            <div style="display:flex; flex-direction:column; gap:4px; min-width:0; grid-column: 2 / -1;">
                <select id="f-machineType">
                    <option value="">— Tip seçiniz —</option>
                </select>
                <span id="f-machineTypeHint" style="font-size:11px; color:var(--mch-text-muted); line-height:1.35; min-height:0;"></span>
            </div>

            <label for="f-sortOrder">Sıralama</label>
            <input type="number" id="f-sortOrder" step="1" value="0" />

            <label for="f-isActive">Durum</label>
            <label class="mch-switch">
                <input type="checkbox" id="f-isActive" checked />
                <span class="mch-switch-track"><span class="mch-switch-thumb"></span></span>
                <span class="mch-switch-label" id="f-isActiveLabel">Aktif</span>
            </label>
        </div>

        @* ── Grid ──────────────────────────────────────────── *@
        <div class="mch-grid-wrap">
            <div class="mch-grid-toolbar">
                <input type="search" id="grid-search" placeholder="Kod, ad, tip, lokasyon ara..." />
                <span class="spacer" style="flex:1;"></span>
                <span style="font-size:12px;color:var(--mch-text-muted);" id="grid-info"></span>
            </div>
            <div class="mch-grid-scroll">
                <table class="mch-grid" id="mch-grid">
                    <thead>
                        <tr>
                            <th style="width:70px;">Sıra</th>
                            <th>Ad</th>
                            <th style="width:160px;">Tip</th>
                            <th style="width:220px;">Lokasyon</th>
                            <th style="width:80px;">Durum</th>
                        </tr>
                    </thead>
                    <tbody id="mch-tbody">
                        <tr><td colspan="5" style="text-align:center;padding:24px;color:var(--mch-text-muted);">Yükleniyor...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
</section>

<div id="mch-toast-host"></div>
@Html.AntiForgeryToken()

@section Scripts {
<script>
(function () {
    'use strict';
    const $ = id => document.getElementById(id);
    let allRows = [];

    // ── Toast (sag alt) ──────────────────────────────────────
    function flash(msg, ok) {
        const host = $('mch-toast-host'); if (!host) return;
        const el = document.createElement('div');
        el.className = 'mch-toast ' + (ok ? 'mch-toast--ok' : 'mch-toast--err');
        el.setAttribute('role', ok ? 'status' : 'alert');
        const m = document.createElement('div'); m.className = 'mch-toast-msg'; m.textContent = msg;
        const c = document.createElement('button'); c.type = 'button'; c.className = 'mch-toast-close';
        c.setAttribute('aria-label', 'Kapat'); c.textContent = '×';
        function dismiss() {
            if (el.classList.contains('is-leaving')) return;
            el.classList.add('is-leaving'); clearTimeout(tm);
            setTimeout(() => { if (el.parentNode) el.parentNode.removeChild(el); }, 260);
        }
        c.addEventListener('click', dismiss);
        el.appendChild(m); el.appendChild(c); host.appendChild(el);
        const tm = setTimeout(dismiss, 4000);
    }
    function flashSuccess() {
        const bar = $('mch-toolbar');
        if (!bar) return;
        bar.classList.remove('is-save-flash');
        void bar.offsetWidth;
        bar.classList.add('is-save-flash');
        setTimeout(() => bar.classList.remove('is-save-flash'), 1850);
    }

    // ── Helper ───────────────────────────────────────────────
    function token() {
        const el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }
    async function api(url, body) {
        const opts = { credentials:'same-origin' };
        if (body !== undefined) {
            opts.method = 'POST';
            opts.headers = { 'Content-Type':'application/json', 'RequestVerificationToken': token() };
            opts.body = JSON.stringify(body);
        }
        const r = await fetch(url, opts);
        return r.json().catch(() => ({ success:false, message:'Yanit JSON degil' }));
    }
    function escapeHtml(s) {
        return (s == null ? '' : String(s)).replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
    }

    // ── Lokasyon dropdown'unu doldur (hiyerarsik tree) ───────
    // Lokasyon tanimlamalari ekranindaki gibi indent + connector char'lari ile
    // (├─, └─) parent-child iliskisi gosterilir. Sadece aktif olanlar listelenir.
    async function loadLocations() {
        const r = await fetch('/Logistics/GetAllLocations', { credentials:'same-origin' });
        const all = r.ok ? await r.json() : [];
        const list = (all || []).filter(l => l.isActive);

        // ── Tree olustur ──
        const byParent = {};
        list.forEach(l => {
            const p = l.parentId || 0;
            if (!byParent[p]) byParent[p] = [];
            byParent[p].push(l);
        });
        Object.values(byParent).forEach(arr =>
            arr.sort((a, b) => (a.sortOrder || 0) - (b.sortOrder || 0)
                            || (a.locationCode || '').localeCompare(b.locationCode || ''))
        );

        // ── DFS dolas, indent prefix ile dolu satir uret ──
        const ordered = [];
        function walk(parentId, depth, ancestorsHasMoreSiblings) {
            const children = byParent[parentId] || [];
            children.forEach((node, idx) => {
                const isLast = idx === children.length - 1;
                let prefix = '';
                for (let i = 0; i < depth - 1; i++) {
                    prefix += ancestorsHasMoreSiblings[i] ? '│  ' : '   ';
                }
                if (depth > 0) prefix += isLast ? '└─ ' : '├─ ';
                ordered.push({ id: node.id, label: prefix + (node.locationCode || '') + (node.locationName ? ' — ' + node.locationName : '') });
                walk(node.id, depth + 1, ancestorsHasMoreSiblings.concat(!isLast));
            });
        }
        walk(0, 0, []);

        const sel = $('f-locationId');
        sel.innerHTML = '<option value="">— Lokasyon seçiniz —</option>' +
            ordered.map(x => `<option value="${x.id}">${escapeHtml(x.label)}</option>`).join('');
    }

    // ── Makine tipi dropdown'unu doldur (9 built-in + custom) ─
    let machineTypeMap = {};   // code → {name, description}
    async function loadMachineTypes() {
        const r = await fetch('/Logistics/GetAllMachineTypes', { credentials:'same-origin' });
        const list = r.ok ? await r.json() : [];
        const sel = $('f-machineType');
        machineTypeMap = {};
        (list || []).forEach(t => {
            machineTypeMap[t.code] = { name: t.name, description: t.description || '' };
        });
        sel.innerHTML = '<option value="">— Tip seçiniz —</option>' +
            (list || []).map(t =>
                `<option value="${escapeHtml(t.code)}">${escapeHtml(t.name)}</option>`
            ).join('');
        // Mevcut seçim varsa hint'i tazele
        updateMachineTypeHint();
    }
    function updateMachineTypeHint() {
        const code = $('f-machineType').value;
        const hint = $('f-machineTypeHint');
        if (!hint) return;
        if (!code || !machineTypeMap[code]) { hint.textContent = ''; return; }
        hint.textContent = machineTypeMap[code].description || '';
    }

    // ── Grid ──────────────────────────────────────────────────
    async function loadGrid() {
        const q = ($('grid-search').value || '').trim();
        const url = '/Logistics/GetAllMachines' + (q ? ('?search=' + encodeURIComponent(q)) : '');
        const r = await fetch(url, { credentials:'same-origin' });
        allRows = r.ok ? (await r.json()) : [];
        renderGrid();
    }
    function renderGrid() {
        const tbody = $('mch-tbody');
        if (!allRows.length) {
            tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:24px;color:var(--mch-text-muted);">Kayıt yok. Üstten yeni makine ekleyebilirsin.</td></tr>';
            $('grid-info').textContent = '0 kayıt';
            return;
        }
        // Tip kodunu UI'da tip adina cevir (machineTypeMap dropdown yuklerken doldu)
        function typeLabel(code) {
            if (!code) return '';
            const t = machineTypeMap[code];
            return t ? t.name : code;
        }
        tbody.innerHTML = allRows.map(m => `
            <tr data-id="${m.id}">
                <td>${m.sortOrder ?? 0}</td>
                <td>${escapeHtml(m.machineName || '')}</td>
                <td>${escapeHtml(typeLabel(m.machineType))}</td>
                <td>${escapeHtml((m.locationCode || '') + (m.locationName ? ' — ' + m.locationName : ''))}</td>
                <td><span class="mch-pill ${m.isActive ? 'mch-pill--green' : 'mch-pill--red'}">${m.isActive ? 'Aktif' : 'Pasif'}</span></td>
            </tr>`).join('');
        $('grid-info').textContent = allRows.length + ' kayıt';
        // Row click → form'a yükle
        tbody.querySelectorAll('tr').forEach(tr => {
            tr.addEventListener('click', () => {
                tbody.querySelectorAll('tr').forEach(x => x.classList.remove('is-selected'));
                tr.classList.add('is-selected');
                selectId(parseInt(tr.dataset.id));
            });
        });
    }
    function selectId(id) {
        const m = allRows.find(x => x.id === id);
        if (!m) return;
        $('f-id').value = m.id;
        $('f-locationId').value = m.locationId;
        $('f-machineCode').value = m.machineCode || '';   // hidden — backend'e mevcut kod gonderilir
        $('f-machineName').value = m.machineName || '';
        $('f-machineType').value = m.machineType || '';
        updateMachineTypeHint();
        $('f-sortOrder').value = m.sortOrder || 0;
        $('f-isActive').checked = !!m.isActive;
        updateActiveLabel();
        $('btn-delete').disabled = false;
    }

    function clearForm() {
        $('f-id').value = '';
        $('f-locationId').value = '';
        $('f-machineCode').value = '';   // bos = backend otomatik MAC-{6hex} uretir
        $('f-machineName').value = '';
        $('f-machineType').value = '';
        updateMachineTypeHint();
        $('f-sortOrder').value = '0';
        $('f-isActive').checked = true;
        updateActiveLabel();
        $('btn-delete').disabled = true;
        document.querySelectorAll('#mch-tbody tr').forEach(x => x.classList.remove('is-selected'));
        $('f-machineName').focus();
    }

    // Switch label senkronizasyonu (Aktif / Pasif)
    function updateActiveLabel() {
        const lbl = $('f-isActiveLabel');
        if (lbl) lbl.textContent = $('f-isActive').checked ? 'Aktif' : 'Pasif';
    }

    // Tip seçimi değişince hint güncelle
    document.addEventListener('change', e => {
        if (!e.target) return;
        if (e.target.id === 'f-machineType') updateMachineTypeHint();
        if (e.target.id === 'f-isActive') updateActiveLabel();
    });

    // ── Save / Delete / New ───────────────────────────────────
    $('btn-new').addEventListener('click', clearForm);

    $('btn-save').addEventListener('click', async () => {
        const idVal = $('f-id').value;
        const body = {
            id: idVal ? parseInt(idVal) : null,
            locationId: parseInt($('f-locationId').value || '0'),
            // machineCode bos gelirse backend otomatik uretir (MAC-{6hex});
            // dolu gelirse update'te mevcut kod korunur.
            machineCode: ($('f-machineCode').value || '').trim(),
            machineName: ($('f-machineName').value || '').trim() || null,
            machineType: $('f-machineType').value || null,
            hourlyCapacity: null,             // UI'dan kaldirildi — null gonderilir
            sortOrder: parseInt($('f-sortOrder').value || '0'),
            isActive: $('f-isActive').checked
        };
        if (!body.locationId) { flash('Lokasyon seçiniz.', false); $('f-locationId').focus(); return; }
        if (!body.machineName) { flash('Makine adı zorunlu.', false); $('f-machineName').focus(); return; }

        $('btn-save').disabled = true;
        try {
            const r = await api('/Logistics/SaveMachineJson', body);
            if (!r.success) { flash(r.message || 'Kayıt başarısız.', false); return; }
            flashSuccess();
            flash(idVal ? 'Güncellendi.' : 'Eklendi.', true);
            await loadGrid();
            if (!idVal && r.id) selectId(r.id);
        } finally { $('btn-save').disabled = false; }
    });

    $('btn-delete').addEventListener('click', async () => {
        const idVal = $('f-id').value;
        if (!idVal) return;
        if (!confirm('Bu makine silinsin mi?')) return;
        const r = await api('/Logistics/DeleteMachineJson?id=' + encodeURIComponent(idVal), {});
        if (!r.success) { flash(r.message || 'Silme başarısız.', false); return; }
        flash('Silindi.', true);
        clearForm(); await loadGrid();
    });

    $('grid-search').addEventListener('input', () => {
        clearTimeout(window.__mchSearchTm);
        window.__mchSearchTm = setTimeout(loadGrid, 200);
    });

    // ── Init ───────────────────────────────────────────────
    (async function init() {
        await Promise.all([loadLocations(), loadMachineTypes()]);
        await loadGrid();
    })();
})();
</script>
}
