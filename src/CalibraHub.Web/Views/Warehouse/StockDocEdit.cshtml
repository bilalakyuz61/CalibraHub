@model CalibraHub.Web.Models.Warehouse.StockDocEditViewModel
@{
    var isTransfer = Model.DocType == "TRANSFER";
    var isStockIn  = Model.DocType == "STOCK_IN";
    var isEdit     = Model.DocId.HasValue;

    var pageTitle = Model.DocType switch
    {
        "TRANSFER"  => isEdit ? "Transfer Düzenle"         : "Yeni Transfer",
        "STOCK_IN"  => isEdit ? "Giriş Belgesi Düzenle"    : "Yeni Giriş Belgesi",
        "STOCK_OUT" => isEdit ? "Çıkış Belgesi Düzenle"    : "Yeni Çıkış Belgesi",
        _ => "Depo Belgesi",
    };
    var listUrl    = isTransfer ? "/Warehouse/Transfer" : "/Warehouse/StockEntry";
    var bodyClass  = "page-wh-doc-edit";

    ViewData["Title"]     = pageTitle;
    ViewData["BodyClass"] = bodyClass;
}

@section Styles {
@* flatpickr css _Layout'tan global gelir (calibra-datepicker standardı) *@
<style>
    /* ── Viewport iskelet ─────────────────────────────────────────────── */
    .page-wh-doc-edit .integrator-dashboard { height: 100%; min-height: 0; }
    .page-wh-doc-edit .integrator-dashboard__content {
        display: flex !important; flex-direction: column;
        width: 100% !important; max-width: none !important;
        min-height: 0; padding: 0; margin: 0 !important; overflow: hidden;
    }
    .workspace-frame-body.page-wh-doc-edit .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column; overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-wh-doc-edit .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    /* ── Aksiyon seridi (DocumentEdit standart) ────────────────────── */
    .sqe-action-bar {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px; flex-shrink: 0;
        background: rgba(15,15,26,0.85); border-bottom: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
        position: relative; overflow: hidden;
    }
    body.app-theme-light .sqe-action-bar {
        background: rgba(248,250,252,0.92); border-bottom-color: #e2e8f0;
    }
    .sqe-action-bar::before {
        content: ''; position: absolute; left: 0; right: 0; bottom: 0;
        height: 2px; pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,rgba(0,60,20,0) 0%,rgba(10,120,40,.55) 50%,rgba(0,60,20,0) 100%);
    }
    .sqe-action-bar::after {
        content: ''; position: absolute; left: 0; bottom: -1px;
        width: 18%; height: 4px; pointer-events: none; opacity: 0;
        background: linear-gradient(90deg,transparent 0%,rgba(34,197,94,.35) 18%,rgba(74,255,140,1) 50%,rgba(34,197,94,.35) 82%,transparent 100%);
        box-shadow: 0 0 10px 2px rgba(34,197,94,.95),0 0 22px 6px rgba(34,197,94,.55),0 0 40px 12px rgba(34,197,94,.22);
        border-radius: 50%;
    }
    .sqe-action-bar.is-save-flash::before { animation: sqeKittBg   1800ms ease-out forwards; }
    .sqe-action-bar.is-save-flash::after  { animation: sqeKittScan 1800ms cubic-bezier(.45,.05,.55,.95) forwards; }
    @@keyframes sqeKittBg { 0%,100%{opacity:0;} 10%,90%{opacity:1;} }
    @@keyframes sqeKittScan {
        0%  {opacity:0;left:0;} 8%{opacity:1;} 48%{opacity:1;left:82%;} 52%{opacity:1;left:82%;} 92%{opacity:1;left:0;} 100%{opacity:0;left:0;}
    }

    /* Aksiyon butonları global .pte-btn--icon standardındadır (_CalibraActionBar +
       wwwroot/css/calibra-actionbar.css). Eski özel .sqe-btn CSS'i kaldırıldı. */

    /* ── İşlemler dropdown ────────────────────────────────────────────── */
    .sqe-actions-menu {
        position: relative; margin-left: auto;
        display: flex; align-items: center;
    }
    .sqe-actions-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 12px; font-size: 0.78rem; font-weight: 600;
        color: rgba(255,255,255,0.78);
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);
        border-radius: 8px; cursor: pointer;
        transition: background .12s, color .12s, border-color .12s;
    }
    .sqe-actions-btn:hover { background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.18); }
    .sqe-actions-menu.is-open .sqe-actions-btn { background: rgba(99,102,241,0.16); color: #c7d2fe; border-color: rgba(99,102,241,0.40); }
    body.app-theme-light .sqe-actions-btn { color: #334155; background: #fff; border-color: #e2e8f0; }
    body.app-theme-light .sqe-actions-btn:hover { background: #f8fafc; border-color: #cbd5e1; color: #0f172a; }
    body.app-theme-light .sqe-actions-menu.is-open .sqe-actions-btn { background: rgba(99,102,241,0.08); color: #4338ca; border-color: rgba(99,102,241,0.45); }
    .sqe-actions-caret { transition: transform .15s; opacity: 0.7; }
    .sqe-actions-menu.is-open .sqe-actions-caret { transform: rotate(180deg); opacity: 1; }

    .sqe-actions-dropdown {
        position: fixed; top: 0; left: 0;
        min-width: 180px; display: none; flex-direction: column;
        gap: 2px; padding: 6px; border-radius: 10px;
        background: rgba(15,19,30,0.98); border: 1px solid rgba(255,255,255,0.10);
        box-shadow: 0 16px 48px rgba(0,0,0,0.45),0 0 0 1px rgba(99,102,241,0.08);
        z-index: 10000;
        animation: sqeActionsDropIn 140ms cubic-bezier(.2,.8,.3,1);
    }
    .sqe-actions-dropdown.is-open { display: flex; }
    body.app-theme-light .sqe-actions-dropdown { background: #fff; border-color: #e2e8f0; box-shadow: 0 12px 40px rgba(15,23,42,0.16); }
    @@keyframes sqeActionsDropIn { from{opacity:0;transform:translateY(-4px) scale(0.98);} to{opacity:1;transform:translateY(0) scale(1);} }
    .sqe-actions-item {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 10px; font-size: 0.78rem; font-weight: 500;
        color: rgba(255,255,255,0.82); background: transparent;
        border: 1px solid transparent; border-radius: 7px;
        cursor: pointer; text-align: left; transition: background .1s,color .1s,border-color .1s;
    }
    .sqe-actions-item:hover { background: rgba(99,102,241,0.14); color: #c7d2fe; border-color: rgba(99,102,241,0.28); }
    body.app-theme-light .sqe-actions-item { color: #334155; }
    body.app-theme-light .sqe-actions-item:hover { background: rgba(99,102,241,0.08); color: #4338ca; border-color: rgba(99,102,241,0.25); }

    /* ── Belge bilgisi (meta) ────────────────────────────────────────── */
    .wde-docinfo {
        display: flex; align-items: center; gap: 10px;
        margin-right: auto;
    }
    .wde-docno {
        font-size: 0.88rem; font-weight: 700;
        color: rgba(255,255,255,0.85);
    }
    body.app-theme-light .wde-docno { color: #1e293b; }
    .wde-type-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 3px 10px; border-radius: 20px; font-size: 0.73rem; font-weight: 600;
    }
    .wde-type-badge--transfer  { background: rgba(99,102,241,.15); color: #818cf8; }
    .wde-type-badge--stock-in  { background: rgba(16,185,129,.15); color: #34d399; }
    .wde-type-badge--stock-out { background: rgba(239,68,68,.12);  color: #f87171; }
    body.app-theme-light .wde-type-badge--transfer  { color: #4f46e5; }
    body.app-theme-light .wde-type-badge--stock-in  { color: #059669; }
    body.app-theme-light .wde-type-badge--stock-out { color: #dc2626; }

    /* ── Sol tab + sağ içerik ────────────────────────────────────────── */
    .sqe-body { display: flex; flex: 1 1 auto; min-height: 0; overflow: hidden; }
    .sqe-tab-nav {
        width: 200px; flex-shrink: 0;
        border-right: 1px solid var(--app-border,#dde3ee);
        background: var(--app-surface,#fff);
        padding: 10px;
        display: flex; flex-direction: column;
        overflow-y: auto;
    }
    body.app-theme-dark .sqe-tab-nav { background: rgba(255,255,255,.02); border-right-color: rgba(255,255,255,.06); }
    .sqe-tab-btn {
        display: block; width: 100%; text-align: left;
        padding: 10px 16px; font-size: 0.9rem; font-weight: 600;
        color: var(--app-text-muted,#64748b); background: none;
        border: 1px solid transparent; border-radius: 8px;
        margin-bottom: 4px; border-left: 3px solid transparent;
        cursor: pointer; transition: color .12s, background .12s, border-color .12s;
    }
    .sqe-tab-btn:hover { background: var(--app-muted-surface,#f3f5f7); color: var(--app-text,#333); border-color: var(--app-border,#e2e8f0); }
    body.app-theme-dark .sqe-tab-btn:hover { background: rgba(255,255,255,.06); color: #e2e8f0; border-color: rgba(255,255,255,.1); }
    .sqe-tab-btn.is-active { color: #4f46e5; background: rgba(99,102,241,.10); border-color: rgba(99,102,241,.30); box-shadow: 0 1px 4px rgba(99,102,241,.15); }
    body.app-theme-dark .sqe-tab-btn.is-active { color: #a5b4fc; background: rgba(99,102,241,.14); border-color: rgba(99,102,241,.35); }
    .sqe-tab-content {
        flex: 1 1 auto; min-width: 0; overflow-y: auto; padding: 20px;
        scrollbar-gutter: stable;
    }
    .sqe-tab-pane { display: none; }
    .sqe-tab-pane.is-active { display: block; }

    /* Tab 2 (kalemler) tüm yüksekliği kaplasın */
    .sqe-tab-pane--lines {
        display: none; flex-direction: column;
        height: calc(100vh - 90px);
    }
    .sqe-tab-pane--lines.is-active { display: flex; }
    #reactDocLineGrid { flex: 1 1 auto; min-height: 0; }

    /* ── Üst bilgi formu ─────────────────────────────────────────────── */
    .sqe-hform {
        display: flex; flex-direction: column; gap: 10px;
        max-width: 680px;
    }
    .sqe-hrow { display: flex; align-items: center; gap: 12px; min-height: 38px; }
    .sqe-hlabel {
        flex: 0 0 140px; text-align: left;
        font-size: 0.85rem; font-weight: 600;
        color: var(--app-text-muted,#64748b);
        white-space: nowrap; user-select: none;
    }
    body.app-theme-dark .sqe-hlabel { color: rgba(255,255,255,.78); }
    .sqe-hinput { flex: 1; max-width: 320px; }
    .sqe-hform .form-control,
    .sqe-hform .form-select {
        background: var(--app-input-bg,#f8fafc);
        border: 1px solid var(--app-border,#d4dfeb);
        border-radius: 8px; font-size: .88rem;
        color: var(--app-text,#1e293b); outline: none;
        transition: border-color .15s, box-shadow .15s;
        padding: 7px 10px;
    }
    .sqe-hform .form-control:focus,
    .sqe-hform .form-select:focus {
        border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.12);
    }
    .sqe-hform .form-control[readonly] {
        background: var(--app-surface-2,#f1f5f9); color: var(--app-text-muted,#64748b); cursor: default;
    }
    body.app-theme-dark .sqe-hform .form-control,
    body.app-theme-dark .sqe-hform .form-select {
        background: rgba(255,255,255,.04); border-color: rgba(255,255,255,.10);
        color: rgba(255,255,255,.88);
    }
    body.app-theme-dark .sqe-hform .form-control[readonly] {
        background: rgba(255,255,255,.02); color: rgba(255,255,255,.45);
    }
    body.app-theme-dark .sqe-hform .form-select option { background: #0c0f1a; color: #fff; }

    /* ── Onay modal ──────────────────────────────────────────────────── */
    .wde-modal-backdrop {
        position: fixed; inset: 0; z-index: 9990;
        background: rgba(15,23,42,.6); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
    }
    .wde-modal {
        background: var(--app-surface,#fff); border: 1px solid var(--app-border,#d4dfeb);
        border-radius: 16px; padding: 28px 32px;
        min-width: 340px; max-width: 440px; width: 100%;
        box-shadow: 0 20px 60px rgba(0,0,0,.18);
        display: flex; flex-direction: column; gap: 16px;
    }
    .wde-modal__icon { width: 52px; height: 52px; border-radius: 14px; background: #fef2f2; display: flex; align-items: center; justify-content: center; font-size: 26px; margin: 0 auto; }
    .wde-modal__title { text-align: center; font-size: 1.05rem; font-weight: 700; color: var(--app-text,#1e293b); margin: 0; }
    .wde-modal__msg { text-align: center; font-size: .88rem; color: var(--app-text-muted,#64748b); margin: 0; }
    .wde-modal__actions { display: flex; gap: 10px; justify-content: center; margin-top: 4px; }
    .wde-modal__cancel { flex: 1; padding: 9px; border-radius: 8px; font-size: .88rem; font-weight: 600; border: 1px solid var(--app-border,#d4dfeb); background: transparent; cursor: pointer; color: var(--app-text-muted,#64748b); transition: all .15s; }
    .wde-modal__cancel:hover { background: var(--app-surface-2,#f1f5f9); }
    .wde-modal__ok { flex: 1; padding: 9px; border-radius: 8px; font-size: .88rem; font-weight: 600; border: none; background: #ef4444; color: #fff; cursor: pointer; transition: all .15s; }
    .wde-modal__ok:hover { background: #dc2626; }

    /* ── Loading mask ────────────────────────────────────────────────── */
    .sqe-loading-mask {
        position: absolute; inset: 0; z-index: 50;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 12px; background: rgba(255,255,255,.65);
        backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
        transition: opacity .2s;
    }
    body.app-theme-dark .sqe-loading-mask { background: rgba(10,13,23,.65); }
    .sqe-loading-mask.is-hidden { display: none; }
    .sqe-loading-mask__spinner {
        width: 32px; height: 32px; border-radius: 50%;
        border: 3px solid rgba(99,102,241,.2); border-top-color: #6366f1;
        animation: sqeSpinLoading .75s linear infinite;
    }
    @@keyframes sqeSpinLoading { to { transform: rotate(360deg); } }
    .sqe-loading-mask__text { font-size: .8rem; color: #64748b; }
    body.app-theme-dark .sqe-loading-mask__text { color: rgba(255,255,255,.55); }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">

  <!-- Aksiyon Şeridi — CalibraHub standart action bar -->
  @await Html.PartialAsync("_CalibraActionBar", new ViewDataDictionary(ViewData)
  {
      ["Title"]       = isTransfer ? "Transfer" : isStockIn ? "Ambar Giriş" : "Ambar Çıkış",
      ["ListUrl"]     = listUrl,
      ["ShowNew"]     = false,
      ["ShowDelete"]  = isEdit,
      ["ShowActions"] = true,
      ["SaveBtnId"]   = "wdeSaveBtn",
      ["DeleteBtnId"] = "wdeDeleteBtn",
  })

  <!-- İşlemler Dropdown (standart action bar'daki ptBtnActions butonu açar) -->
  <div class="sqe-actions-dropdown" id="wdeActionsDropdown">
    <button type="button" class="sqe-actions-item" onclick="wdePrint()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      <span>Yazdır</span>
    </button>
    @* Entegrasyonlar — bu belge tipi (TRANSFER/STOCK_IN/STOCK_OUT) icin Manual
       trigger'li aktif entegrasyonlar dropdown'a "ENTEGRASYONLAR" header'i altinda
       eklenir. Wizard'da bu form code'lariyla entegrasyon kaydedilmediyse hicbir
       sey gorunmez (placeholder gizli kalir).

       record-id: DocId yoksa "0" gonderilir; runtime'da kullanici "Once kaydi
       olusturun" toast'u alir. Save sonrasi JS code yeni id'yi
       wdeIntActionsHost.setAttribute('data-record-id', newId) ile gunceller. *@
    @await Html.PartialAsync("_IntegrationActionItems",
        new CalibraHub.Web.Models.IntegrationButtonsModel {
            FormCode = Model.DocType,
            RecordId = (Model.DocId ?? 0).ToString()
        })
  </div>

  <!-- Sol tab + sağ içerik -->
  <div class="sqe-body" style="position:relative;">

    <!-- Loading mask (edit modunda yükleme sırasında) -->
    <div id="sqLoadingMask" class="sqe-loading-mask@(isEdit ? "" : " is-hidden")" aria-hidden="true">
      <div class="sqe-loading-mask__spinner"></div>
      <span class="sqe-loading-mask__text">Yükleniyor…</span>
    </div>

    <nav class="sqe-tab-nav">
      <button type="button" class="sqe-tab-btn is-active" data-wde-tab-btn="general"
              onclick="wdeSwitchTab('general')">Üst Bilgi</button>
      <button type="button" class="sqe-tab-btn" data-wde-tab-btn="lines"
              onclick="wdeSwitchTab('lines')">Kalem Bilgileri</button>
      <button type="button" class="sqe-tab-btn" data-wde-tab-btn="widgets"
              onclick="wdeSwitchTab('widgets')">Ek Alanlar</button>
    </nav>

    <div class="sqe-tab-content" id="wdeTabContent">

      <!-- TAB 1: Üst Bilgi -->
      <div class="sqe-tab-pane is-active" data-wde-pane="general">
        <div class="sqe-hform">

          <div class="sqe-hrow">
            <label class="sqe-hlabel">Belge No</label>
            <input type="text" id="wdeDocNoInput" class="form-control form-control-sm sqe-hinput"
                   placeholder="Kaydedilince oluşturulur" readonly />
          </div>

          <div class="sqe-hrow">
            <label class="sqe-hlabel">Tarih</label>
            <input type="text" id="wdeDocDate" class="form-control form-control-sm sqe-hinput"
                   placeholder="gg.aa.yyyy" autocomplete="off" />
          </div>

          @if (!isTransfer)
          {
              <div class="sqe-hrow">
                <label class="sqe-hlabel">@(isStockIn ? "Giriş Deposu" : "Çıkış Deposu")</label>
                <select id="wdeLocation" class="form-select form-select-sm sqe-hinput">
                  <option value="">-- Seçiniz --</option>
                </select>
              </div>
          }

          <div class="sqe-hrow">
            <label class="sqe-hlabel">Referans No</label>
            <input type="text" id="wdeRefNo" class="form-control form-control-sm sqe-hinput"
                   placeholder="Opsiyonel" />
          </div>

          <div class="sqe-hrow" id="wdeArgeProjectRow" style="display:none;">
            <label class="sqe-hlabel">AR-GE / ÜR-GE Projesi</label>
            <select id="wdeArgeProject" class="form-select form-select-sm sqe-hinput">
              <option value="">— Proje yok —</option>
            </select>
          </div>

          <div class="sqe-hrow" style="align-items:flex-start;">
            <label class="sqe-hlabel" style="padding-top:8px;">Notlar</label>
            <textarea id="wdeNotes" class="form-control sqe-hinput"
                      placeholder="Açıklama…" style="max-width:400px;resize:vertical;min-height:72px;"></textarea>
          </div>

        </div>
      </div>

      <!-- TAB 2: Kalem Bilgileri -->
      <div class="sqe-tab-pane sqe-tab-pane--lines" data-wde-pane="lines">
        <div id="reactDocLineGrid" style="height:100%;"></div>
      </div>

      <!-- TAB 3: Ek Alanlar (Alan Yönetimi / dinamik widget'lar — üst bilgi form kodu) -->
      <div class="sqe-tab-pane" data-wde-pane="widgets" style="padding:18px 4px;">
        @await Html.PartialAsync("_DynamicWidgetHost", new CalibraHub.Web.Models.Shared.DynamicWidgetHostModel
        {
            FormCode = Model.DocType,
            HostId   = "wdeWidgets",
            RecordId = Model.DocId?.ToString(),
        })
      </div>

    </div><!-- /sqe-tab-content -->
  </div><!-- /sqe-body -->

  <!-- Silme onay modal -->
  <div id="wdeDeleteModal" class="wde-modal-backdrop" style="display:none;">
    <div class="wde-modal">
      <div class="wde-modal__icon">🗑️</div>
      <h3 class="wde-modal__title">Belgeyi Sil</h3>
      <p class="wde-modal__msg">Bu işlem geri alınamaz. Belgeyi silmek istiyor musunuz?</p>
      <div class="wde-modal__actions">
        <button type="button" class="wde-modal__cancel" id="wdeModalCancel">Vazgeç</button>
        <button type="button" class="wde-modal__ok"     id="wdeModalOk">Sil</button>
      </div>
    </div>
  </div>

</section>

@section Scripts {
<script>
(function() {
    var DOC_ID      = @Html.Raw(Model.DocId.HasValue ? Model.DocId.Value.ToString() : "null");
    var DOC_TYPE    = '@Model.DocType';
    var IS_TRANSFER = DOC_TYPE === 'TRANSFER';
    var LIST_URL    = '@listUrl';
    var LINE_GRID_CONFIG = @Html.Raw(Model.LineGridConfigJson);
    var BUNDLE_URL  = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js")';
    var CSS_URL     = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css")';
    var TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

    // ── State ─────────────────────────────────────────────────────────
    var _gridReady    = false;
    var _pendingRows  = null;
    window.__WH_LINES__ = [];

    // ── Tab geçişi ────────────────────────────────────────────────────
    window.wdeSwitchTab = function(tabKey) {
        document.querySelectorAll('[data-wde-tab-btn]').forEach(function(btn) {
            btn.classList.toggle('is-active', btn.getAttribute('data-wde-tab-btn') === tabKey);
        });
        document.querySelectorAll('[data-wde-pane]').forEach(function(pane) {
            pane.classList.toggle('is-active', pane.getAttribute('data-wde-pane') === tabKey);
        });
        // Grid mount: Kalem Bilgileri sekmesine ilk geçişte grid henüz mount edilmemiş olabilir
        if (tabKey === 'lines' && !_gridMounted) {
            mountLineGrid();
        }
    };

    // ── İşlemler dropdown (standart action bar ptBtnActions butonu açar) ──
    window.wdeToggleActionsMenu = function(e) {
        if (e) e.stopPropagation();
        var drop = document.getElementById('wdeActionsDropdown');
        var btn  = document.getElementById('ptBtnActions');
        if (!drop || !btn) return;
        var isOpen = drop.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        if (isOpen) {
            var rect = btn.getBoundingClientRect();
            drop.style.top  = (rect.bottom + 6) + 'px';
            // Sağa hizala — buton sağ kenarına yasla (taşma olursa min 8px)
            drop.style.left = Math.max(8, rect.right - (drop.offsetWidth || 240)) + 'px';
        }
    };
    document.addEventListener('click', function(e) {
        var drop = document.getElementById('wdeActionsDropdown');
        var btn  = document.getElementById('ptBtnActions');
        if (!drop) return;
        if ((btn && btn.contains(e.target)) || drop.contains(e.target)) return;
        drop.classList.remove('is-open');
        if (btn) btn.setAttribute('aria-expanded', 'false');
    });

    // Standart action bar .pte-meta alanına belge no + tür rozeti yazar.
    function wdeSetMeta(docNo) {
        var meta = document.querySelector('.pte-action-bar .pte-meta');
        if (!meta) return;
        var typeInfo = DOC_TYPE === 'TRANSFER'  ? { t: 'Transfer',    c: '#4f46e5', bg: 'rgba(99,102,241,.14)' }
                     : DOC_TYPE === 'STOCK_IN'  ? { t: 'Ambar Giriş', c: '#059669', bg: 'rgba(16,185,129,.14)' }
                     :                            { t: 'Ambar Çıkış', c: '#dc2626', bg: 'rgba(239,68,68,.12)' };
        var no = (docNo || '').trim();
        meta.innerHTML =
            (no ? '<span style="font-weight:700;color:var(--text-strong,#1e293b);margin-right:8px;">' + no + '</span>' : '') +
            '<span style="display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;' +
            'background:' + typeInfo.bg + ';color:' + typeInfo.c + ';">' + typeInfo.t + '</span>';
    }

    window.wdePrint = function() {
        window.print();
    };

    // ── Konum dropdown'larını doldur ──────────────────────────────────
    async function loadLocations() {
        if (IS_TRANSFER) return; // Transfer: lokasyon kalem seviyesinde
        try {
            var r = await fetch('/Warehouse/GetLocationsJson', { credentials: 'same-origin' });
            var locs = await r.json();
            var makeOption = function(loc) {
                var o = document.createElement('option');
                o.value = loc.id;
                o.textContent = (loc.locationName || loc.locationCode || '').trim();
                return o;
            };
            var el = document.getElementById('wdeLocation');
            if (el) locs.forEach(function(l) { el.appendChild(makeOption(l)); });
        } catch (e) {
            console.warn('[WDE] Lokasyon yüklenemedi:', e);
        }
    }

    // AR-GE/ÜR-GE proje dropdown — yalnizca STOCK_OUT (sarf) icin gosterilir + doldurulur.
    async function populateArgeProjects() {
        var row = document.getElementById('wdeArgeProjectRow');
        var sel = document.getElementById('wdeArgeProject');
        if (!row || !sel) return;
        if (DOC_TYPE !== 'STOCK_OUT') { row.style.display = 'none'; return; }
        row.style.display = '';
        try {
            var r = await fetch('/Warehouse/GetArgeProjectsJson', { credentials: 'same-origin' });
            var list = r.ok ? await r.json() : [];
            sel.innerHTML = '<option value="">— Proje yok —</option>' +
                list.map(function (p) { return '<option value="' + p.id + '">' + (p.label || p.name) + '</option>'; }).join('');
        } catch (e) { /* sessiz */ }
    }

    // ── Belgeyi yükle (edit mod) ──────────────────────────────────────
    async function loadDoc() {
        await populateArgeProjects();
        if (!DOC_ID) {
            hideMask();
            return;
        }
        try {
            var r = await fetch('/Warehouse/GetDocJson?id=' + DOC_ID, { credentials: 'same-origin' });
            if (!r.ok) { hideMask(); return; }
            var data = await r.json();
            var doc   = data.doc;
            var lines = data.lines || [];

            if (doc) {
                var noEl = document.getElementById('wdeDocNoInput');
                if (noEl) noEl.value = doc.docNo || '';
                wdeSetMeta(doc.docNo || '');

                var dateFp = document.getElementById('wdeDocDate')?._flatpickr;
                if (dateFp && doc.docDate) dateFp.setDate(doc.docDate.substring(0, 10));

                if (!IS_TRANSFER) {
                    var locId = doc.fromLocationId || doc.toLocationId;
                    var locEl = document.getElementById('wdeLocation');
                    if (locEl && locId) locEl.value = String(locId);
                }

                var refEl = document.getElementById('wdeRefNo');
                if (refEl) refEl.value = doc.refNo || '';
                var notesEl = document.getElementById('wdeNotes');
                if (notesEl) notesEl.value = doc.notes || '';
                var apEl = document.getElementById('wdeArgeProject');
                if (apEl && doc.argeProjectId) apEl.value = String(doc.argeProjectId);
            }

            var rows = lines.map(function(l) {
                return {
                    stockCardId:       l.itemId,
                    materialCode:      l.materialCode || '',
                    materialName:      l.materialName || '',
                    unitId:            l.unitId,
                    quantity:          l.qty,
                    combinationCode:   l.combinationCode || '',
                    trackCombinations: false,
                    notes:             l.notes || '',
                    fromLocationId:    l.fromLocationId || null,
                    toLocationId:      l.toLocationId || null,
                };
            });

            setGridRows(rows);
        } catch (e) {
            console.warn('[WDE] Belge yüklenemedi:', e);
        } finally {
            hideMask();
        }
    }

    function hideMask() {
        var m = document.getElementById('sqLoadingMask');
        if (m) m.classList.add('is-hidden');
    }

    // ── Grid satırları ────────────────────────────────────────────────
    function setGridRows(rows) {
        if (_gridReady && window.CalibraHub && window.CalibraHub.whLineGrid) {
            window.CalibraHub.whLineGrid.setRows(rows || []);
        } else {
            _pendingRows = rows || [];
        }
    }

    function getGridRows() {
        if (window.CalibraHub && window.CalibraHub.whLineGrid &&
            typeof window.CalibraHub.whLineGrid.getRows === 'function') {
            try { return window.CalibraHub.whLineGrid.getRows() || []; } catch(_) {}
        }
        return window.__WH_LINES__ || [];
    }

    // ── Kaydet ───────────────────────────────────────────────────────
    async function save() {
        // Standart .pte-btn--icon yapısını (ikon + .pte-btn__label) bozmadan
        // yalnızca disabled ile loading göster; içerik/etiket değiştirilmez.
        var btn = document.getElementById('wdeSaveBtn');
        if (btn) btn.disabled = true;

        try {
            var fromLocId = null, toLocId = null;
            if (!IS_TRANSFER) {
                var locEl = document.getElementById('wdeLocation');
                if (locEl && locEl.value) {
                    var locVal = parseInt(locEl.value, 10);
                    if (DOC_TYPE === 'STOCK_IN') toLocId = locVal;
                    else fromLocId = locVal;
                }
            }

            var docDateEl = document.getElementById('wdeDocDate');
            var docDate = docDateEl?._flatpickr?.selectedDates?.[0]
                ? docDateEl._flatpickr.selectedDates[0].toISOString()
                : new Date().toISOString();

            var rawLines = getGridRows();
            var lines = rawLines
                .filter(function(r) { return r && r.materialCode && String(r.materialCode).trim(); })
                .map(function(r) {
                    return {
                        id:             null,
                        itemId:         r.stockCardId || null,
                        materialCode:   r.materialCode,
                        materialName:   r.materialName,
                        unitId:         r.unitId || null,
                        qty:            parseFloat(r.quantity) || 0,
                        combinationId:  r.combinationId || null,
                        notes:          r.notes || null,
                        fromLocationId: r.fromLocationId || null,
                        toLocationId:   r.toLocationId || null,
                    };
                });

            var body = {
                id:             DOC_ID,
                docType:        DOC_TYPE,
                docDate:        docDate,
                fromLocationId: fromLocId,
                toLocationId:   toLocId,
                refNo:          (document.getElementById('wdeRefNo')?.value || '').trim() || null,
                notes:          (document.getElementById('wdeNotes')?.value || '').trim() || null,
                argeProjectId:  parseInt(document.getElementById('wdeArgeProject')?.value) || null,
                lines:          lines,
            };

            var resp = await fetch('/Warehouse/SaveDocJson', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
            });
            var json = await resp.json();

            if (json && json.success) {
                var noEl = document.getElementById('wdeDocNoInput');
                if (noEl) noEl.value = json.docNo || '';
                wdeSetMeta(json.docNo || '');
                if (!DOC_ID) {
                    DOC_ID = json.id;
                    history.replaceState(null, '', window.location.pathname + '?id=' + DOC_ID);
                    var delBtn = document.getElementById('wdeDeleteBtn');
                    if (delBtn) delBtn.style.display = '';
                }
                // Entegrasyon partial host'una yeni recordId yansit + items yeniden tara
                // (yeni kayit DOC_ID=0 -> gercek id, "Once kaydi olusturun" toast'i atilmaz).
                var intHost = document.querySelector('[data-integration-action-items]');
                if (intHost) {
                    intHost.setAttribute('data-record-id', String(DOC_ID || 0));
                    if (window.CalibraHub && window.CalibraHub.scanIntegrationActionItems) {
                        try { window.CalibraHub.scanIntegrationActionItems(); } catch (_) {}
                    }
                }
                // Ek Alanlar (dinamik widget) değerlerini yeni/mevcut belge Id'sine yaz.
                if (window.CalibraWidgetHost && DOC_ID) {
                    try { await window.CalibraWidgetHost.save('wdeWidgets', DOC_ID); }
                    catch (_) { /* widget save hatasi belge kaydini bloklamaz */ }
                }
                // K.I.T.T. flash
                var bar = document.querySelector('.pte-action-bar');
                if (bar) {
                    bar.classList.remove('is-save-flash');
                    void bar.offsetWidth;
                    bar.classList.add('is-save-flash');
                    setTimeout(function() { bar.classList.remove('is-save-flash'); }, 1900);
                }
                if (window.CalibraHub && window.CalibraHub.toast)
                    window.CalibraHub.toast('Belge kaydedildi.', 'ok');
            } else {
                var msg = (json && json.message) || 'Kayıt başarısız.';
                if (window.CalibraHub && window.CalibraHub.toast)
                    window.CalibraHub.toast(msg, 'err');
                else alert(msg);
            }
        } catch (ex) {
            if (window.CalibraHub && window.CalibraHub.toast)
                window.CalibraHub.toast('Hata: ' + (ex.message || ex), 'err');
            else alert('Hata: ' + ex.message);
        } finally {
            // Sadece disabled kaldırılır — buton içeriği (ikon + etiket) korunur.
            if (btn) btn.disabled = false;
        }
    }

    // ── Sil ──────────────────────────────────────────────────────────
    function showDeleteModal() { document.getElementById('wdeDeleteModal').style.display = 'flex'; document.getElementById('wdeModalOk').focus(); }
    function hideDeleteModal() { document.getElementById('wdeDeleteModal').style.display = 'none'; }
    async function doDelete() {
        hideDeleteModal();
        if (!DOC_ID) return;
        try {
            var resp = await fetch('/Warehouse/DeleteDocJson?id=' + DOC_ID, {
                method: 'POST', credentials: 'same-origin',
                headers: { 'RequestVerificationToken': TOKEN },
            });
            var json = await resp.json();
            if (json && json.ok) {
                window.location.href = LIST_URL;
            } else {
                var msg = (json && json.error) || 'Silme başarısız.';
                if (window.CalibraHub && window.CalibraHub.toast)
                    window.CalibraHub.toast(msg, 'err');
                else alert(msg);
            }
        } catch (ex) {
            if (window.CalibraHub && window.CalibraHub.toast)
                window.CalibraHub.toast('Hata: ' + (ex.message || ex), 'err');
        }
    }

    // ── Line Grid ────────────────────────────────────────────────────
    var _gridMounted = false;
    function patchGridKey() {
        Object.defineProperty(window.CalibraHub, 'salesLineGrid', {
            get: function() { return window.CalibraHub.__wh_grid; },
            set: function(v) {
                window.CalibraHub.__wh_grid  = v;
                window.CalibraHub.whLineGrid = v;
            },
            configurable: true,
        });
    }

    function mountLineGrid() {
        if (_gridMounted) return;
        var el = document.getElementById('reactDocLineGrid');
        if (!el) return;
        if (!window.CalibraHub || !window.CalibraHub.mountLineItemsGrid) {
            console.error('[WDE] mountLineItemsGrid yok');
            return;
        }
        _gridMounted = true;
        try {
            window.CalibraHub.mountLineItemsGrid(el, LINE_GRID_CONFIG, {
                onRowsChange: function(rows) { window.__WH_LINES__ = rows || []; }
            });
            var tries = 0;
            var timer = setInterval(function() {
                if (window.CalibraHub && window.CalibraHub.whLineGrid) {
                    clearInterval(timer);
                    _gridReady = true;
                    if (_pendingRows) {
                        window.CalibraHub.whLineGrid.setRows(_pendingRows);
                        _pendingRows = null;
                    }
                } else if (++tries > 80) {
                    clearInterval(timer);
                }
            }, 25);
        } catch (ex) {
            console.error('[WDE] grid mount exception:', ex);
            _gridMounted = false;
        }
    }

    // ── Bootstrap ────────────────────────────────────────────────────
    function bootstrap() {
        // Flatpickr tarih
        function initFlatpickr() {
            flatpickr('#wdeDocDate', {
                dateFormat: 'd.m.Y', locale: 'tr', defaultDate: new Date(),
            });
        }
        if (window.flatpickr) {
            initFlatpickr();
        } else {
            /* _Layout normalde global yükler — bu fallback lokal vendor'a bakar */
            var s = document.createElement('script');
            s.src = '/lib/flatpickr/flatpickr.min.js';
            s.onload = function() {
                var l = document.createElement('script');
                l.src = '/lib/flatpickr/l10n/tr.js';
                l.onload = initFlatpickr;
                document.head.appendChild(l);
            };
            document.head.appendChild(s);
        }

        // React bundle + grid (Kalem sekmesi ilk kez açıldığında mount edilir)
        if (!document.querySelector('link[data-wh-grid-css]')) {
            var link = document.createElement('link');
            link.rel = 'stylesheet'; link.href = CSS_URL;
            link.setAttribute('data-wh-grid-css', '1');
            document.head.appendChild(link);
        }

        function ensureBundle(cb) {
            if (window.CalibraHub && window.CalibraHub.mountLineItemsGrid) { cb(); return; }
            var sc = document.createElement('script');
            sc.src = BUNDLE_URL;
            sc.setAttribute('data-wh-grid', '1');
            sc.onload  = function() { setTimeout(cb, 0); };
            sc.onerror = function() { console.error('[WDE] Bundle yüklenemedi'); };
            document.head.appendChild(sc);
        }

        // Lokasyonları yükle, ardından belgeyi yükle
        loadLocations().then(function() {
            ensureBundle(function() {
                patchGridKey();
                // Grid'i hemen mount et (Kalem sekmesine gitmeden önce de hazır olsun)
                mountLineGrid();
                loadDoc();
            });
        });

        // Buton olayları
        document.getElementById('wdeSaveBtn')?.addEventListener('click', save);
        document.getElementById('ptBtnActions')?.addEventListener('click', wdeToggleActionsMenu);
        var delBtn = document.getElementById('wdeDeleteBtn');
        if (delBtn) delBtn.addEventListener('click', showDeleteModal);
        document.getElementById('wdeModalCancel')?.addEventListener('click', hideDeleteModal);
        document.getElementById('wdeModalOk')?.addEventListener('click', doDelete);
        document.getElementById('wdeDeleteModal')?.addEventListener('click', function(e) {
            if (e.target === this) hideDeleteModal();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') hideDeleteModal();
        });

        if (!DOC_ID) {
            if (delBtn) delBtn.style.display = 'none';
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bootstrap);
    } else {
        bootstrap();
    }

    window.addEventListener('pageshow', function(e) { if (e.persisted) location.reload(); });
})();
</script>
}
