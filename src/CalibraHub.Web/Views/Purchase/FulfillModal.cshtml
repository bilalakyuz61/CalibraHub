@*
    FulfillModal — İhtiyaç Kaydı karşılama durumu ve aksiyon paneli.
    SmartCard fetch-modal mekanizması ile yüklenir: GET /Purchase/FulfillModal?requestId={id}
    ViewData: RequestDoc (DocumentDto), Lines (IReadOnlyCollection<DocumentLineDto>),
              DerivedDocs (IReadOnlyCollection<DocumentDto>), RequestId (int)
*@
@using CalibraHub.Application.Contracts
@{
    var requestDoc  = ViewData["RequestDoc"]  as DocumentDto;
    var lines       = ViewData["Lines"]       as IReadOnlyCollection<DocumentLineDto> ?? [];
    var derivedDocs = ViewData["DerivedDocs"] as IReadOnlyCollection<DocumentDto>     ?? [];
    var requestId   = (int)(ViewData["RequestId"] ?? 0);
    var tr          = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");

    string FulfillStatusClass(int s) => s switch { 1 => "fm-fst--partial", 2 => "fm-fst--full", _ => "fm-fst--pending" };
    string FulfillStatusLabel(int s) => s switch { 1 => "Kısmen", 2 => "Tamamlandı", _ => "Bekliyor" };

    string TranslateStatus(string s) => s switch
    {
        "Draft"     => "Taslak",
        "Sent"      => "Onay Bekliyor",
        "Approved"  => "Onaylı",
        "Rejected"  => "Reddedildi",
        "Cancelled" => "Kapatıldı / İptal",
        "Converted" => "Dönüştürüldü",
        _           => s,
    };
    string StatusClass(string s) => s switch
    {
        "Draft"     => "fm-st--draft",
        "Sent"      => "fm-st--sent",
        "Approved"  => "fm-st--app",
        "Rejected"  => "fm-st--rej",
        "Cancelled" => "fm-st--canc",
        "Converted" => "fm-st--conv",
        _           => "fm-st--draft",
    };
}

<style>
    /* Dark default (mevcut tema) */
    .fm-root { color:#e2e8f0; font-size:0.84rem; padding:4px 0; }

    .fm-hdr {
        display:flex; flex-wrap:wrap; align-items:center; gap:10px;
        padding:10px 14px; border-radius:10px;
        background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.2);
        margin-bottom:14px;
    }
    .fm-hdr__no    { font-weight:700; color:#fbbf24; font-size:0.92rem; }
    .fm-hdr__date  { color:#94a3b8; font-size:0.78rem; }
    .fm-hdr__who   { color:#cbd5e1; font-size:0.78rem; }
    .fm-hdr__who strong { color:#e2e8f0; }
    .fm-hdr__cnt   { margin-left:auto; font-size:0.78rem; color:#94a3b8; }

    .fm-sec { margin-bottom:14px; }
    .fm-sec__lbl {
        font-size:0.7rem; font-weight:600; color:#94a3b8;
        text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px;
    }
    .fm-tbl { width:100%; border-collapse:collapse; }
    .fm-tbl thead tr   { border-bottom:1px solid rgba(255,255,255,0.07); }
    .fm-tbl th {
        text-align:left; padding:5px 8px;
        font-size:0.72rem; color:#64748b; font-weight:600;
    }
    .fm-tbl th.fm-num   { text-align:right; }
    .fm-tbl tbody tr    { border-bottom:1px solid rgba(255,255,255,0.04); }
    .fm-tbl td          { padding:6px 8px; color:#cbd5e1; }
    .fm-tbl td.fm-qty   { text-align:right; font-weight:600; color:#e2e8f0; font-variant-numeric:tabular-nums; }
    .fm-tbl td.fm-unit  { color:#94a3b8; }
    .fm-tbl td.fm-note  { color:#64748b; font-size:0.75rem; }
    .fm-tbl td.fm-mat-empty { color:#64748b; font-style:italic; }
    .fm-tbl td.fm-fulfill { text-align:right; font-variant-numeric:tabular-nums; font-size:0.8rem; }
    .fm-fst { display:inline-block; padding:1px 6px; border-radius:999px; font-size:0.68rem; font-weight:700; }
    .fm-fst--pending { background:rgba(100,116,139,0.15); color:#94a3b8; }
    .fm-fst--partial { background:rgba(245,158,11,0.15);  color:#fbbf24; }
    .fm-fst--full    { background:rgba(16,185,129,0.15);   color:#34d399; }
    body.app-theme-light .fm-fst--pending { background:rgba(100,116,139,0.12); color:#475569; }
    body.app-theme-light .fm-fst--partial { background:rgba(245,158,11,0.12);  color:#92400e; }
    body.app-theme-light .fm-fst--full    { background:rgba(16,185,129,0.12);   color:#047857; }

    .fm-derived {
        margin-bottom:14px; padding:10px 12px; border-radius:10px;
        background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.2);
    }
    .fm-derived__lbl {
        font-size:0.7rem; font-weight:600; color:#a5b4fc;
        text-transform:uppercase; letter-spacing:0.06em; margin-bottom:8px;
    }
    .fm-derived__row {
        display:flex; align-items:center; gap:10px; padding:6px 0;
        border-bottom:1px solid rgba(255,255,255,0.05);
    }
    .fm-derived__no    { font-weight:700; color:#c7d2fe; font-family:monospace; font-size:0.85rem; }
    .fm-derived__date  { color:#64748b; font-size:0.75rem; }
    .fm-derived__ctct  { color:#94a3b8; font-size:0.75rem; }

    .fm-st {
        padding:2px 7px; border-radius:999px;
        font-size:0.68rem; font-weight:700;
    }
    .fm-st--draft { background:rgba(100,116,139,0.15); color:#94a3b8; }
    .fm-st--sent  { background:rgba(59,130,246,0.15);  color:#60a5fa; }
    .fm-st--app   { background:rgba(16,185,129,0.15);  color:#34d399; }
    .fm-st--rej   { background:rgba(239,68,68,0.15);   color:#f87171; }
    .fm-st--canc  { background:rgba(100,116,139,0.1);  color:#64748b; }
    .fm-st--conv  { background:rgba(99,102,241,0.15);  color:#818cf8; }

    .fm-actions { padding-top:12px; border-top:1px solid rgba(255,255,255,0.07); }
    .fm-actions__lbl {
        font-size:0.7rem; font-weight:600; color:#94a3b8;
        text-transform:uppercase; letter-spacing:0.06em; margin-bottom:10px;
    }
    .fm-actions__row { display:flex; flex-wrap:wrap; gap:8px; }
    .fm-btn {
        display:inline-flex; align-items:center; gap:6px;
        padding:8px 14px; border-radius:8px;
        font-size:0.82rem; font-weight:600;
        text-decoration:none; transition:background 0.15s;
    }
    .fm-btn--q { background:rgba(59,130,246,0.15); border:1px solid rgba(59,130,246,0.3);  color:#93c5fd; }
    .fm-btn--q:hover { background:rgba(59,130,246,0.25); }
    .fm-btn--o { background:rgba(16,185,129,0.13); border:1px solid rgba(16,185,129,0.28); color:#6ee7b7; }
    .fm-btn--o:hover { background:rgba(16,185,129,0.22); }
    .fm-actions__hint { margin-top:8px; font-size:0.75rem; color:#64748b; }

    /* 2026-06-04: Acik tema override — FulfillModal (fm-*) */
    body.app-theme-light .fm-root { color:#0f172a; }
    body.app-theme-light .fm-hdr {
        background:rgba(245,158,11,0.08); border-color:rgba(245,158,11,0.3);
    }
    body.app-theme-light .fm-hdr__no    { color:#92400e; }
    body.app-theme-light .fm-hdr__date  { color:#64748b; }
    body.app-theme-light .fm-hdr__who   { color:#475569; }
    body.app-theme-light .fm-hdr__who strong { color:#0f172a; }
    body.app-theme-light .fm-hdr__cnt   { color:#64748b; }

    body.app-theme-light .fm-sec__lbl { color:#475569; }
    body.app-theme-light .fm-tbl thead tr { border-bottom-color:#e2e8f0; }
    body.app-theme-light .fm-tbl th { color:#64748b; }
    body.app-theme-light .fm-tbl tbody tr { border-bottom-color:#f1f5f9; }
    body.app-theme-light .fm-tbl td { color:#0f172a; }
    body.app-theme-light .fm-tbl td.fm-qty { color:#0f172a; }
    body.app-theme-light .fm-tbl td.fm-unit { color:#475569; }
    body.app-theme-light .fm-tbl td.fm-note { color:#64748b; }
    body.app-theme-light .fm-tbl td.fm-mat-empty { color:#94a3b8; }

    body.app-theme-light .fm-derived {
        background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.3);
    }
    body.app-theme-light .fm-derived__lbl  { color:#4338ca; }
    body.app-theme-light .fm-derived__row  { border-bottom-color:#e2e8f0; }
    body.app-theme-light .fm-derived__no   { color:#4338ca; }
    body.app-theme-light .fm-derived__date { color:#64748b; }
    body.app-theme-light .fm-derived__ctct { color:#475569; }

    body.app-theme-light .fm-st--draft { background:rgba(100,116,139,0.12); color:#475569; }
    body.app-theme-light .fm-st--sent  { background:rgba(59,130,246,0.12);  color:#1d4ed8; }
    body.app-theme-light .fm-st--app   { background:rgba(16,185,129,0.12);  color:#047857; }
    body.app-theme-light .fm-st--rej   { background:rgba(239,68,68,0.1);    color:#b91c1c; }
    body.app-theme-light .fm-st--canc  { background:rgba(100,116,139,0.1);  color:#64748b; }
    body.app-theme-light .fm-st--conv  { background:rgba(99,102,241,0.12);  color:#4338ca; }

    body.app-theme-light .fm-actions { border-top-color:#e2e8f0; }
    body.app-theme-light .fm-actions__lbl { color:#475569; }
    body.app-theme-light .fm-btn--q {
        background:rgba(59,130,246,0.1); border-color:rgba(59,130,246,0.35); color:#1d4ed8;
    }
    body.app-theme-light .fm-btn--q:hover { background:rgba(59,130,246,0.18); }
    body.app-theme-light .fm-btn--o {
        background:rgba(16,185,129,0.1); border-color:rgba(16,185,129,0.32); color:#047857;
    }
    body.app-theme-light .fm-btn--o:hover { background:rgba(16,185,129,0.18); }
    body.app-theme-light .fm-actions__hint { color:#64748b; }
</style>

<div class="fm-root">

    @* ── Belge Başlığı ── *@
    @if (requestDoc != null)
    {
        <div class="fm-hdr">
            <span class="fm-hdr__no">@requestDoc.DocumentNumber</span>
            <span class="fm-hdr__date">@requestDoc.DocumentDate.ToString("dd.MM.yyyy", tr)</span>
            @if (!string.IsNullOrWhiteSpace(requestDoc.RequesterPersonnelName))
            {
                <span class="fm-hdr__who">
                    Talep Eden: <strong>@requestDoc.RequesterPersonnelName</strong>
                </span>
            }
            <span class="fm-hdr__cnt">@lines.Count kalem</span>
        </div>
    }

    @* ── Kalemler ── *@
    @if (lines.Count > 0)
    {
        <div class="fm-sec">
            <div class="fm-sec__lbl">İhtiyaç Kalemleri</div>
            <table class="fm-tbl">
                <thead>
                    <tr>
                        <th>Malzeme</th>
                        <th class="fm-num">Talep</th>
                        <th class="fm-num">Depo</th>
                        <th class="fm-num">Satın Alma</th>
                        <th class="fm-num">Kalan</th>
                        <th>Durum</th>
                        <th>Birim</th>
                        <th>Notlar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ln in lines)
                    {
                        var remaining = ln.Quantity - ln.FulfilledFromStock - ln.FulfilledByPurchase;
                        <tr>
                            @if (!string.IsNullOrWhiteSpace(ln.MaterialName))
                            {
                                <td>@ln.MaterialName</td>
                            }
                            else
                            {
                                <td class="fm-mat-empty">[@ln.MaterialCode]</td>
                            }
                            <td class="fm-qty">@ln.Quantity.ToString("N2", tr)</td>
                            <td class="fm-fulfill" style="color:@(ln.FulfilledFromStock > 0 ? "#34d399" : "#64748b")">@ln.FulfilledFromStock.ToString("N2", tr)</td>
                            <td class="fm-fulfill" style="color:@(ln.FulfilledByPurchase > 0 ? "#60a5fa" : "#64748b")">@ln.FulfilledByPurchase.ToString("N2", tr)</td>
                            <td class="fm-fulfill" style="color:@(remaining > 0 ? "#fbbf24" : "#34d399")">@remaining.ToString("N2", tr)</td>
                            <td><span class="fm-fst @FulfillStatusClass(ln.FulfillmentStatus)">@FulfillStatusLabel(ln.FulfillmentStatus)</span></td>
                            <td class="fm-unit">@(ln.UnitCode ?? ln.UnitName ?? "")</td>
                            <td class="fm-note">@(ln.Notes ?? "")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* ── Mevcut Belgeler ── *@
    @if (derivedDocs.Count > 0)
    {
        <div class="fm-derived">
            <div class="fm-derived__lbl">Oluşturulan Belgeler (@derivedDocs.Count)</div>
            @foreach (var d in derivedDocs)
            {
                var status = d.Status ?? "Draft";
                <div class="fm-derived__row">
                    <span class="fm-derived__no">@d.DocumentNumber</span>
                    <span class="fm-st @StatusClass(status)">@TranslateStatus(status)</span>
                    <span class="fm-derived__date">@d.DocumentDate.ToString("dd.MM.yyyy", tr)</span>
                    @if (d.ContactName != null)
                    {
                        <span class="fm-derived__ctct">— @d.ContactName</span>
                    }
                </div>
            }
        </div>
    }

    @* ── Aksiyon Butonları ── *@
    <div class="fm-actions">
        <div class="fm-actions__lbl">Satın Alma Belgesi Oluştur</div>
        <div class="fm-actions__row">
            <a href="/Purchase/Edit?type=purchase_quote&fromRequest=@requestId" class="fm-btn fm-btn--q">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                Satın Alma Teklifi Oluştur
            </a>
            <a href="/Purchase/Edit?type=purchase_order&fromRequest=@requestId" class="fm-btn fm-btn--o">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                Satın Alma Siparişi Oluştur
            </a>
        </div>
        @if (derivedDocs.Count > 0)
        {
            <p class="fm-actions__hint">
                Bu ihtiyaç için @derivedDocs.Count belge daha önce oluşturulmuş. Gerekirse yeni belge ekleyebilirsiniz.
            </p>
        }
    </div>

</div>
