@*
    FulfillmentCenter v5 — Sol liste (tam genişlik) + sağdan slide-in drawer.
    Filtreler: Belge No, Talep Eden (çoklu), Durum (chip), Tarih (arasında), Karşılama Durumu (chip).
*@
@using CalibraHub.Application.Contracts
@using System.Text.Json
@{
    ViewData["Title"]     = "Karşılama Merkezi";
    ViewData["BodyClass"] = "page-fc3";
    ViewData["DbInfo"]    =
        "<table class='cb-dbinfo-table'>" +
        "<thead><tr><th colspan='3'>Document.Status — Durum Enum Değerleri</th></tr>" +
        "<tr><th>Değer</th><th>Tamsayı</th><th>Açıklama</th></tr></thead><tbody>" +
        "<tr><td><code>Draft</code></td><td>0</td><td>Taslak — hazırlanıyor, henüz gönderilmemiş</td></tr>" +
        "<tr><td><code>Sent</code></td><td>1</td><td>Onay Bekliyor — onay akışına düşürüldü</td></tr>" +
        "<tr><td><code>Approved</code></td><td>2</td><td>Onaylı — onaylandı veya onay akışı gerektirmiyor</td></tr>" +
        "<tr><td><code>Rejected</code></td><td>3</td><td>Reddedildi — onay akışı veya kullanıcı reddetti</td></tr>" +
        "<tr><td><code>Revised</code></td><td>4</td><td>Revize edildi — yeni versiyon oluşturuldu</td></tr>" +
        "<tr><td><code>Cancelled</code></td><td>5</td><td>Kapatıldı / İptal</td></tr>" +
        "<tr><td><code>Converted</code></td><td>6</td><td>Başka belgeye dönüştürüldü (sistem dahili)</td></tr>" +
        "</tbody></table>";

    var requests        = ViewData["Requests"]        as IReadOnlyCollection<DocumentListItemDto>    ?? [];
    var locations       = ViewData["Locations"]       as IReadOnlyCollection<LocationDto>             ?? [];
    var contactGroupMap = ViewData["ContactGroupMap"] as Dictionary<int, string>                      ?? new();
    var itemGroupMap    = ViewData["ItemGroupMap"]    as Dictionary<int, List<string>>                ?? new();

    var storageLocs = locations
        .Where(l => l.IsActive && l.IsStorageArea)
        .OrderBy(l => l.LocationName ?? l.LocationCode)
        .ToList();

    var jsonOpts = new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull,
    };
    var requestsJson = JsonSerializer.Serialize(
        requests.OrderByDescending(r => r.DocumentDate).ToList(), jsonOpts);
    var locsJson = JsonSerializer.Serialize(
        storageLocs.Select(l => new { id = l.Id, name = l.LocationName ?? l.LocationCode }).ToList(), jsonOpts);
    // Grup haritaları (JS merge için) — key string olarak gönderiliyor (JSON object key'leri string)
    var contactGroupMapJson = JsonSerializer.Serialize(
        contactGroupMap.ToDictionary(kv => kv.Key.ToString(), kv => kv.Value), jsonOpts);
    var itemGroupMapJson = JsonSerializer.Serialize(
        itemGroupMap.ToDictionary(kv => kv.Key.ToString(), kv => kv.Value), jsonOpts);
    var materialMapJson  = ViewData["MaterialMapJson"] as string ?? "{}";

    // Widget tanımları + değerleri (controller tarafında pre-serialize edildi)
    var widgetDefsJson      = ViewData["WidgetDefsJson"]      as string ?? "[]";
    var masterWidgetValJson = ViewData["MasterWidgetValJson"] as string ?? "{}";
    var lineWidgetValJson   = ViewData["LineWidgetValJson"]   as string ?? "{}";

    // Ek saha kolonları (cbv_FulfillmentLineExtras view)
    var extraColTuples = ViewData["ExtraColumnTuples"] as List<(string Key, string Label)> ?? [];
    var extraColsJson  = ViewData["ExtraColumnsJson"]  as string ?? "[]";

    // Onay akışında bekleyen belge ID'leri
    var pendingApprovalIdsJson = ViewData["PendingApprovalDocIdsJson"] as string ?? "[]";
}

@section Styles {
<style>
    /* ── Sayfa kap ── */
    .page-fc3 .integrator-dashboard {
        padding:0!important; background:transparent!important;
        box-shadow:none!important; border:none!important; max-width:none!important;
    }
    .page-fc3 .integrator-dashboard__content { width:100%!important; max-width:none!important; padding:0!important; }

    .fc3-outer {
        display:flex; flex-direction:column;
        height: calc(100vh - 56px);
        padding: 16px 20px 0;
        overflow:hidden;
    }

    /* ── Başlık ── */
    .fc3-hd {
        display:flex; align-items:center; gap:12px;
        margin-bottom:14px; flex-shrink:0;
    }
    .fc3-back {
        display:inline-flex; align-items:center; gap:5px;
        padding:5px 11px; border-radius:7px;
        background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.09);
        color:#94a3b8; font-size:.79rem; text-decoration:none; transition:all .13s;
    }
    .fc3-back:hover { background:rgba(255,255,255,.08); color:#e2e8f0; }
    .fc3-title-icon {
        width:34px; height:34px; border-radius:8px; flex-shrink:0;
        background:linear-gradient(135deg,#6366f1,#8b5cf6);
        display:flex; align-items:center; justify-content:center;
    }
    .fc3-title-tx  { font-size:1rem; font-weight:700; color:#e2e8f0; }
    .fc3-title-sub { font-size:.75rem; color:#475569; }

    /* Filtre ve Sütun ikon butonları (üst bar) */
    .fc3-hd-icon-btn {
        display:inline-flex; align-items:center; justify-content:center;
        width:32px; height:32px; border-radius:8px; padding:0; position:relative;
        background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.09);
        color:#94a3b8; cursor:pointer; transition:all .13s; flex-shrink:0;
    }
    .fc3-hd-icon-btn:hover { background:rgba(255,255,255,.08); color:#e2e8f0; }
    .fc3-filt-btn.has-filters { background:rgba(99,102,241,.1); border-color:rgba(99,102,241,.3); color:#a5b4fc; }
    .fc3-filt-badge {
        display:none; min-width:14px; height:14px; border-radius:999px;
        background:#6366f1; color:#fff; font-size:.6rem; font-weight:700;
        align-items:center; justify-content:center; padding:0 3px;
        position:absolute; top:-4px; right:-4px; pointer-events:none;
    }
    .fc3-filt-badge.show { display:inline-flex; }

    /* ── Liste (tam genişlik) ── */
    .fc3-body { flex:1; min-height:0; display:flex; flex-direction:column; }
    .fc3-left {
        flex:1; min-height:0; display:flex; flex-direction:column;
        background:rgba(255,255,255,.02); border:1px solid rgba(255,255,255,.07);
        border-radius:12px; overflow:hidden;
    }
    .fc3-list-bar {
        flex-shrink:0; display:flex; align-items:center; gap:10px;
        padding:9px 14px; border-bottom:1px solid rgba(255,255,255,.06);
    }
    .fc3-count-all { margin-left:auto; font-size:.75rem; color:#475569; }
    .fc3-count-sel { font-size:.79rem; font-weight:700; color:#a5b4fc; display:none; }
    .fc3-count-sel.show { display:inline; }

    /* ── Sütun ayarları drawer ── */
    .fc3-col-drw-backdrop {
        position:fixed; inset:0; z-index:9982;
        background:transparent; opacity:0; pointer-events:none;
        transition:opacity 60ms;
    }
    .fc3-col-drw-backdrop.open { opacity:1; pointer-events:auto; }
    .fc3-col-panel {
        position:fixed; top:0; right:0; bottom:0; z-index:9983;
        width:min(340px,100vw);
        background:rgba(13,18,34,.97); border-left:1px solid rgba(255,255,255,.09);
        transform:translateX(100%);
        transition:transform 280ms cubic-bezier(.23,1,.32,1), box-shadow 280ms;
        display:flex; flex-direction:column; overflow:hidden;
    }
    .fc3-col-panel.open { transform:translateX(0); box-shadow:-16px 0 48px rgba(0,0,0,.4); }
    body.app-theme-light .fc3-col-panel {
        background:rgba(255,255,255,.98); border-left-color:#e2e8f0;
    }
    body.app-theme-light .fc3-col-panel.open { box-shadow:-16px 0 48px rgba(15,23,42,.15); }
    .fc3-col-rows-inner { overflow-y:auto; flex:1; padding:4px 0; }
    .fc3-col-rows-inner::-webkit-scrollbar { width:4px; }
    .fc3-col-rows-inner::-webkit-scrollbar-thumb { background:rgba(255,255,255,.09); border-radius:2px; }
    body.app-theme-light .fc3-col-rows-inner::-webkit-scrollbar-thumb { background:#cbd5e1; }
    .fc3-cfg-row {
        display:flex; align-items:center; gap:6px;
        padding:5px 12px; cursor:grab; border-radius:7px; margin:1px 5px;
        transition:background .1s;
    }
    .fc3-cfg-row:hover { background:rgba(99,102,241,.08); }
    .fc3-cfg-row.is-fixed { cursor:default; }
    .fc3-cfg-row.is-hidden { opacity:.45; }
    .fc3-cfg-row.drag-over { outline:2px solid #6366f1; outline-offset:-2px; }
    .fc3-cfg-dragging { opacity:.4; }
    .fc3-cfg-grip { color:#475569; flex-shrink:0; display:flex; align-items:center; }
    .fc3-cfg-grip svg { width:10px; height:14px; }
    .fc3-cfg-eye {
        width:24px; height:24px; padding:0; border:none; background:transparent;
        cursor:pointer; display:flex; align-items:center; justify-content:center;
        color:#6366f1; border-radius:5px; flex-shrink:0; transition:background .1s;
    }
    .fc3-cfg-eye.fc3-eye-off { color:#475569; }
    .fc3-cfg-eye:hover { background:rgba(99,102,241,.1); }
    .fc3-cfg-eye svg { width:14px; height:14px; }
    .fc3-cfg-label { flex:1; font-size:.88rem; font-weight:500; color:#cbd5e1; }
    body.app-theme-light .fc3-cfg-label { color:#334155; }
    .fc3-cfg-chips { display:flex; gap:3px; flex-wrap:wrap; flex:1; }
    .fc3-cfg-chip {
        height:22px; padding:0 8px; border-radius:5px;
        border:1px solid rgba(148,163,184,.18); background:transparent;
        cursor:pointer; font-size:.72rem; color:#64748b; white-space:nowrap;
        transition:all .1s;
    }
    .fc3-cfg-chip:hover { background:rgba(99,102,241,.1); color:#818cf8; border-color:rgba(99,102,241,.3); }
    .fc3-cfg-chip.active { background:rgba(99,102,241,.15); color:#a5b4fc; border-color:rgba(99,102,241,.4); font-weight:600; }
    body.app-theme-light .fc3-cfg-chip { color:#64748b; border-color:rgba(100,116,139,.2); }
    body.app-theme-light .fc3-cfg-chip:hover { color:#6366f1; }
    body.app-theme-light .fc3-cfg-chip.active { color:#6366f1; background:rgba(99,102,241,.1); border-color:rgba(99,102,241,.35); }
    .fc3-cfg-exp {
        width:22px; height:22px; padding:0; border:none; background:transparent;
        cursor:pointer; display:flex; align-items:center; justify-content:center;
        color:#475569; border-radius:5px; flex-shrink:0; transition:background .1s;
    }
    .fc3-cfg-exp:hover { background:rgba(99,102,241,.1); color:#818cf8; }
    .fc3-cfg-exp svg { width:11px; height:11px; transition:transform .15s; }
    .fc3-cfg-exp.open svg { transform:rotate(180deg); }
    .fc3-cfg-detail {
        display:none; flex-direction:column; gap:6px;
        padding:6px 12px 10px 36px;
        border-bottom:1px solid rgba(255,255,255,.05);
        margin:0 5px 3px;
    }
    body.app-theme-light .fc3-cfg-detail { border-bottom-color:rgba(148,163,184,.12); }
    .fc3-cfg-detail.open { display:flex; }
    .fc3-cfg-field-row { display:flex; align-items:center; gap:8px; }
    .fc3-cfg-field-label { width:70px; font-size:.78rem; color:#64748b; flex-shrink:0; }
    body.app-theme-light .fc3-cfg-field-label { color:#64748b; }
    .fc3-cfg-field-input {
        flex:1; height:26px; padding:0 8px; border-radius:6px;
        border:1px solid rgba(255,255,255,.1);
        background:rgba(255,255,255,.05); font-size:.82rem;
        color:#e2e8f0; outline:none;
    }
    .fc3-cfg-field-input:focus { border-color:rgba(99,102,241,.5); }
    body.app-theme-light .fc3-cfg-field-input {
        background:#f8fafc; color:#0f172a; border-color:rgba(148,163,184,.25);
    }
    .fc3-cfg-align { display:flex; gap:2px; flex:1; }
    .fc3-cfg-align-btn {
        flex:1; height:26px; display:flex; align-items:center; justify-content:center;
        border-radius:5px; border:1px solid rgba(255,255,255,.08);
        cursor:pointer; color:#475569; background:transparent; padding:0; transition:all .1s;
    }
    body.app-theme-light .fc3-cfg-align-btn { border-color:rgba(148,163,184,.2); }
    .fc3-cfg-align-btn svg { width:14px; height:14px; }
    .fc3-cfg-align-btn:hover { background:rgba(99,102,241,.1); color:#818cf8; }
    .fc3-cfg-align-btn.fc3-align-active { background:rgba(99,102,241,.15); color:#818cf8; border-color:rgba(99,102,241,.3); }
    /* Grupla ikonu (ana satır) */
    .fc3-cfg-grp-btn {
        width:20px; height:20px; padding:0; border:none; background:transparent;
        cursor:pointer; display:flex; align-items:center; justify-content:center;
        color:#334155; border-radius:4px; flex-shrink:0; transition:background .1s, color .1s;
    }
    .fc3-cfg-grp-btn:hover { background:rgba(99,102,241,.1); color:#818cf8; }
    .fc3-cfg-grp-btn.active { color:#818cf8; }
    .fc3-cfg-grp-btn svg { width:12px; height:12px; }
    .fc3-cfg-grp-ord { font-size:10px; font-weight:700; color:#818cf8; min-width:12px; text-align:center; line-height:1; }
    /* Genişlik stepper (sütun paneli detay) */
    .fc3-cfg-stepper { display:flex; align-items:center; gap:5px; flex:1; }
    .fc3-cfg-step-btn {
        width:22px; height:22px; border-radius:5px; flex-shrink:0;
        border:1px solid rgba(148,163,184,.2); background:transparent;
        cursor:pointer; font-size:15px; font-weight:600; color:#64748b;
        display:flex; align-items:center; justify-content:center; line-height:1;
        transition:all .1s;
    }
    .fc3-cfg-step-btn:hover:not(:disabled) { background:rgba(99,102,241,.1); color:#6366f1; border-color:rgba(99,102,241,.3); }
    .fc3-cfg-step-btn:disabled { opacity:.28; cursor:not-allowed; }
    .fc3-step-dots { display:flex; gap:4px; flex:1; justify-content:center; align-items:center; }
    .fc3-step-dot { width:7px; height:7px; border-radius:50%; background:rgba(148,163,184,.25); transition:background .15s; }
    .fc3-step-dot.on { background:#6366f1; }
    /* Grup başlık satırı */
    .fc3-group-hdr {
        display:flex; align-items:center; gap:8px;
        padding:5px 12px; min-height:30px;
        background:rgba(99,102,241,.05);
        border-top:1px solid rgba(99,102,241,.1);
        border-bottom:1px solid rgba(99,102,241,.1);
        font-size:11.5px; user-select:none; position:sticky; left:0;
    }
    .fc3-grp-identity { display:flex; align-items:center; gap:5px; overflow:hidden; min-width:0; flex-shrink:1; }
    .fc3-group-hdr .fc3-sub-qty    { color:#818cf8; }
    .fc3-group-hdr .fc3-sub-remain { color:#818cf8; }
    body.app-theme-light .fc3-group-hdr .fc3-sub-qty    { color:#4f46e5; }
    body.app-theme-light .fc3-group-hdr .fc3-sub-remain { color:#4f46e5; }
    .fc3-group-hdr__dim { color:#64748b; font-weight:400; }
    .fc3-group-hdr__sep { color:#94a3b8; font-size:10px; }
    .fc3-group-hdr__val { color:#e2e8f0; font-weight:600; }
    body.app-theme-light .fc3-group-hdr { background:rgba(99,102,241,.04); border-color:rgba(99,102,241,.12); }
    body.app-theme-light .fc3-group-hdr__val { color:#1e293b; }
    body.app-theme-light .fc3-group-hdr__dim { color:#94a3b8; }
    /* Grup collapse toggle */
    .fc3-grp-tog { width:18px; height:18px; padding:0; border:none; background:transparent; cursor:pointer;
        display:flex; align-items:center; justify-content:center; flex-shrink:0;
        color:#64748b; border-radius:3px; transition:color .1s, background .1s; }
    .fc3-grp-tog:hover { color:#818cf8; background:rgba(99,102,241,.12); }
    .fc3-grp-tog svg { width:9px; height:9px; transition:transform .15s; }
    .fc3-group-hdr.collapsed .fc3-grp-tog svg { transform:rotate(-90deg); }
    /* Grup sayı + aggregate */
    .fc3-grp-cnt { margin-left:8px; font-size:.68rem; color:#475569; font-weight:400; white-space:nowrap; }
    .fc3-grp-agg { margin-left:6px; font-size:.68rem; color:#818cf8; font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    body.app-theme-light .fc3-grp-cnt { color:#94a3b8; }
    body.app-theme-light .fc3-grp-agg { color:#6366f1; }
    /* Grup özet satırı — aggregate değerleri sütun hizasında */
    .fc3-agg-row {
        display:flex; align-items:center; gap:8px; flex-wrap:nowrap;
        padding:2px 12px;
        background:rgba(99,102,241,.04);
        border-bottom:1px solid rgba(99,102,241,.08);
    }
    .fc3-agg-cb { width:15px; min-width:15px; flex-shrink:0; }
    .fc3-agg-row .fc3-sub-qty   { color:#818cf8; }
    .fc3-agg-row .fc3-sub-remain{ color:#818cf8; }
    body.app-theme-light .fc3-agg-row { background:rgba(99,102,241,.03); border-bottom-color:rgba(99,102,241,.1); }
    body.app-theme-light .fc3-agg-row .fc3-sub-qty    { color:#4f46e5; }
    body.app-theme-light .fc3-agg-row .fc3-sub-remain { color:#4f46e5; }
    /* Grup select-all checkbox */
    .fc3-grp-selall { padding:0 2px; cursor:pointer; flex-shrink:0; }
    .fc3-grp-selall input { cursor:pointer; accent-color:#6366f1; width:15px; height:15px; margin:0; }
    /* Tümünü aç/kapat butonları */
    .fc3-grp-ctrl { display:none; align-items:center; gap:2px; }
    .fc3-grp-ctrl-btn {
        width:26px; height:26px; padding:0; border-radius:5px;
        border:1px solid rgba(148,163,184,.18); background:transparent;
        cursor:pointer; display:flex; align-items:center; justify-content:center;
        color:#64748b; transition:all .1s; flex-shrink:0;
    }
    .fc3-grp-ctrl-btn svg { width:14px; height:14px; }
    .fc3-grp-ctrl-btn:hover { background:rgba(99,102,241,.1); color:#818cf8; border-color:rgba(99,102,241,.3); }
    body.app-theme-light .fc3-grp-ctrl-btn { color:#64748b; border-color:rgba(100,116,139,.2); }
    body.app-theme-light .fc3-grp-ctrl-btn:hover { color:#6366f1; border-color:rgba(99,102,241,.3); }
    /* İkon chip satırı (Boyut/Stil/Özet) */
    .fc3-cfg-icon-row { display:flex; gap:2px; flex:1; }
    .fc3-cfg-icon-row .fc3-cfg-chip {
        flex:1; height:28px; padding:0; line-height:1;
        display:flex; align-items:center; justify-content:center;
    }
    /* Line header */
    .fc3-sub-hdr {
        display:flex; align-items:center; gap:8px;
        padding:4px 14px 4px 36px;
        border-bottom:1px solid rgba(255,255,255,.06);
        background:rgba(99,102,241,.04);
        font-size:.69rem; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.05em;
    }
    .fc3-sub-hdr-mat  { flex:1; }
    .fc3-sub-hdr-qty  { min-width:54px; text-align:right; }
    .fc3-sub-hdr-unit { min-width:28px; }
    .fc3-sub-hdr-stk  { flex:1; }
    .fc3-sub-hdr-rem  { min-width:52px; text-align:right; }
    .fc3-sub-hdr-fst  { width:100px; min-width:100px; max-width:100px; text-align:center; }
    .fc3-sub-hdr-suf  { min-width:18px; text-align:center; }
    .fc3-list { flex:1; overflow-y:auto; }
    .fc3-list::-webkit-scrollbar { width:4px; }
    .fc3-list::-webkit-scrollbar-thumb { background:rgba(255,255,255,.09); border-radius:2px; }
    .fc3-row {
        display:flex; align-items:center; gap:8px; padding:9px 14px;
        border-bottom:1px solid rgba(255,255,255,.04);
        cursor:pointer; transition:background .11s; user-select:none;
    }
    .fc3-row:hover  { background:rgba(255,255,255,.025); }
    .fc3-row.sel    { background:rgba(99,102,241,.09); }
    .fc3-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
    .fc3-num  { font-family:monospace; font-size:.82rem; font-weight:700; color:#c7d2fe; min-width:130px; }
    .fc3-who  { flex:1; font-size:.8rem; color:#94a3b8; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .fc3-lc   { font-size:.72rem; color:#475569; white-space:nowrap; }
    .fc3-dt   { font-size:.72rem; color:#475569; white-space:nowrap; }
    .fc3-empty-list { padding:32px 14px; text-align:center; color:#475569; font-size:.82rem; }

    /* ── Expand toggle ── */
    .fc3-exp-btn {
        flex-shrink:0; width:20px; height:20px; border-radius:5px; padding:0;
        background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.09);
        color:#64748b; cursor:pointer; display:flex; align-items:center; justify-content:center;
        transition:all .12s; line-height:1;
    }
    .fc3-exp-btn:hover { background:rgba(99,102,241,.15); border-color:rgba(99,102,241,.3); color:#a5b4fc; }
    .fc3-exp-btn.active { background:rgba(99,102,241,.14); border-color:rgba(99,102,241,.28); color:#818cf8; }

    /* ── Satır detay bloğu ── */
    .fc3-sub { background:rgba(99,102,241,.025); border-bottom:2px solid rgba(99,102,241,.12); }
    .fc3-sub-row {
        display:flex; align-items:center; gap:8px; flex-wrap:nowrap;
        padding:5px 12px 5px 48px;
        border-bottom:1px solid rgba(255,255,255,.03);
        font-size:.76rem;
    }
    .fc3-sub-row:last-child { border-bottom:none; }
    .fc3-sub-mat { flex:1; color:#94a3b8; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; min-width:0; }
    .fc3-sub-qty { color:#e2e8f0; font-weight:600; min-width:54px; text-align:right;
                   font-family:ui-monospace,Menlo,Consolas,monospace; flex-shrink:0; }
    .fc3-sub-unit { color:#475569; min-width:28px; flex-shrink:0; }
    .fc3-sub-stk { display:flex; flex-wrap:wrap; gap:3px; min-width:0; flex:1; }
    .fc3-sk {
        padding:1px 5px; border-radius:999px; font-size:.67rem; font-weight:600;
        white-space:nowrap; flex-shrink:0; cursor:default;
    }
    .fc3-sk--ok   { background:rgba(16,185,129,.14);  color:#34d399; }
    .fc3-sk--warn { background:rgba(245,158,11,.13);  color:#fbbf24; }
    .fc3-sk--none { background:rgba(239,68,68,.13);   color:#f87171; }
    .fc3-sk--zero { background:rgba(100,116,139,.1);  color:#475569; }
    .fc3-sub-remain { color:#94a3b8; min-width:52px; text-align:right; flex-shrink:0;
                      font-family:ui-monospace,Menlo,Consolas,monospace; font-size:.74rem; }
    .fc3-sub-fst { padding:1px 5px; border-radius:999px; font-size:.63rem; font-weight:700; flex-shrink:0; width:100px; min-width:100px; max-width:100px; text-align:center; box-sizing:border-box; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .fm-fst--pending   { background:rgba(100,116,139,.15); color:#94a3b8; }
    .fm-fst--partial   { background:rgba(245,158,11,.15);  color:#fbbf24; }
    .fm-fst--full      { background:rgba(16,185,129,.15);  color:#34d399; }
    .fm-fst--approval  { background:rgba(99,102,241,.18);  color:#818cf8; }
    .fm-fst--draft     { background:rgba(100,116,139,.12); color:#94a3b8; }
    .fm-fst--rejected  { background:rgba(248,113,113,.15); color:#f87171; }
    .fm-fst--cancelled { background:rgba(71,85,105,.15);   color:#64748b; }
    body.app-theme-light .fm-fst--pending   { background:rgba(100,116,139,.12); color:#475569; }
    body.app-theme-light .fm-fst--partial   { background:rgba(245,158,11,.12);  color:#92400e; }
    body.app-theme-light .fm-fst--full      { background:rgba(16,185,129,.12);  color:#047857; }
    body.app-theme-light .fm-fst--approval  { background:rgba(99,102,241,.12);  color:#4f46e5; }
    body.app-theme-light .fm-fst--draft     { background:rgba(100,116,139,.1);  color:#64748b; }
    body.app-theme-light .fm-fst--rejected  { background:rgba(220,38,38,.1);    color:#dc2626; }
    body.app-theme-light .fm-fst--cancelled { background:rgba(71,85,105,.1);    color:#334155; }
    .fc3-sub-cb:disabled { opacity:.4; cursor:not-allowed; }
    .fc3-sub-suf { font-size:.8rem; flex-shrink:0; min-width:18px; text-align:center; }
    .fc3-sub-loading { padding:8px 48px; font-size:.76rem; color:#475569; font-style:italic; }
    /* Ek saha hücreleri (cbv_FulfillmentLineExtras) */
    .fc3-sub-ext { min-width:80px; max-width:140px; font-size:.74rem; color:#94a3b8; flex-shrink:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; padding-left:4px; }
    .fc3-sub-hdr-ext { min-width:80px; max-width:140px; flex-shrink:0; }
    .fc3-sub-err     { padding:8px 48px; font-size:.76rem; color:#f87171; }

    /* Light overrides */
    body.app-theme-light .fc3-exp-btn { background:#f1f5f9; border-color:#e2e8f0; color:#64748b; }
    body.app-theme-light .fc3-exp-btn:hover { background:#e0e7ff; border-color:#c7d2fe; color:#4338ca; }
    body.app-theme-light .fc3-exp-btn.active { background:#e0e7ff; border-color:#c7d2fe; color:#4338ca; }
    body.app-theme-light .fc3-sub { background:#f8fafc; border-bottom-color:#c7d2fe; }
    body.app-theme-light .fc3-sub-row { border-bottom-color:#f1f5f9; }
    body.app-theme-light .fc3-sub-mat { color:#475569; }
    body.app-theme-light .fc3-sub-qty { color:#0f172a; }
    body.app-theme-light .fc3-sub-unit { color:#94a3b8; }
    body.app-theme-light .fc3-sk--ok   { background:rgba(16,185,129,.1);  color:#047857; }
    body.app-theme-light .fc3-sk--warn { background:rgba(245,158,11,.1);  color:#92400e; }
    body.app-theme-light .fc3-sk--none { background:rgba(239,68,68,.08);  color:#b91c1c; }
    body.app-theme-light .fc3-sk--zero { background:#f1f5f9; color:#64748b; }
    body.app-theme-light .fc3-sub-remain { color:#64748b; }
    body.app-theme-light .fc3-sub-loading { color:#94a3b8; }

    /* ── DRAWER ── */
    .fc3-drawer-backdrop {
        position:fixed; inset:0; z-index:9980;
        background:transparent; opacity:0; pointer-events:none;
        transition:opacity 60ms;
    }
    .fc3-drawer-backdrop.open { opacity:1; pointer-events:auto; }
    .fc3-drawer {
        position:fixed; top:0; right:0; bottom:0; z-index:9981;
        width:min(340px,100vw);
        background:rgba(13,18,34,.97);
        backdrop-filter:blur(24px) saturate(140%);
        -webkit-backdrop-filter:blur(24px) saturate(140%);
        border-left:1px solid rgba(255,255,255,.08);
        transform:translateX(100%);
        transition:transform 280ms cubic-bezier(.23,1,.32,1), box-shadow 280ms;
        display:flex; flex-direction:column; overflow:hidden;
    }
    .fc3-drawer.open { transform:translateX(0); box-shadow:-24px 0 64px rgba(0,0,0,.4); }

    /* Drawer header */
    .fc3-drw-hd {
        display:flex; align-items:center; gap:10px;
        padding:13px 16px; border-bottom:1px solid rgba(255,255,255,.07); flex-shrink:0;
    }
    .fc3-drw-hd-icon {
        width:30px; height:30px; border-radius:9px; flex-shrink:0;
        display:flex; align-items:center; justify-content:center;
        background:rgba(99,102,241,.16); border:1px solid rgba(99,102,241,.28); color:#a5b4fc;
    }
    .fc3-drw-hd-tx { flex:1; min-width:0; }
    .fc3-drw-hd-tx strong { font-size:.85rem; font-weight:700; color:#e2e8f0; }
    .fc3-drw-hd-tx small  { display:block; font-size:.72rem; color:#475569; }
    .fc3-drw-close {
        padding:5px; border-radius:7px; background:none;
        border:1px solid rgba(255,255,255,.07); color:#475569;
        cursor:pointer; transition:all .12s; flex-shrink:0;
        display:flex; align-items:center;
    }
    .fc3-drw-close:hover { background:rgba(255,255,255,.07); color:#94a3b8; }

    /* Drawer body */
    .fc3-drw-body { flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:12px; padding:14px 16px; }
    .fc3-drw-body::-webkit-scrollbar { width:4px; }
    .fc3-drw-body::-webkit-scrollbar-thumb { background:rgba(255,255,255,.09); border-radius:2px; }

    /* ── Filtre kartı ── */
    .fc3-filter-card {
        flex-shrink:0; background:rgba(255,255,255,.025);
        border:1px solid rgba(255,255,255,.07); border-radius:10px; overflow:hidden;
    }
    .fc3-filter-hd {
        display:flex; align-items:center; justify-content:space-between;
        padding:8px 14px; border-bottom:1px solid rgba(255,255,255,.05);
    }
    .fc3-filter-hd span { font-size:.7rem; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.07em; }
    .fc3-filter-reset {
        display:inline-flex; align-items:center; gap:4px;
        padding:3px 9px; border-radius:5px; font-size:.72rem;
        background:none; border:1px solid rgba(255,255,255,.07); color:#475569; cursor:pointer; transition:all .12s;
    }
    .fc3-filter-reset:hover { color:#94a3b8; border-color:rgba(255,255,255,.14); }

    /* Filtre tablo satırları */
    .fc3-ftbl { width:100%; border-collapse:collapse; }
    .fc3-ftbl tr { border-bottom:1px solid rgba(255,255,255,.04); }
    .fc3-ftbl tr:last-child { border-bottom:none; }
    .fc3-ftbl td { vertical-align:middle; }
    .fc3-fl { padding:7px 8px 7px 14px; font-size:.78rem; color:#64748b; text-align:right; white-space:nowrap; width:90px; }
    .fc3-fop-c { padding:5px 4px; width:108px; }
    .fc3-fop {
        width:100%; padding:5px 6px;
        background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08);
        border-radius:5px; color:#94a3b8; font-size:.76rem; outline:none; cursor:pointer;
    }
    .fc3-fop option { background:#1e293b; }
    .fc3-fop:focus { border-color:rgba(99,102,241,.35); }
    .fc3-fop-static { padding:5px 6px; font-size:.75rem; color:#475569; font-style:italic; display:block; }
    .fc3-fv-c { padding:5px 10px 5px 3px; }
    .fc3-fv {
        width:100%; padding:5px 7px;
        background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08);
        border-radius:5px; color:#e2e8f0; font-size:.81rem; outline:none; color-scheme:dark;
    }
    .fc3-fv:focus { border-color:rgba(99,102,241,.4); }
    .fc3-fv::placeholder { color:#334155; }

    /* Tarih arasında — ikinci input */
    .fc3-date-wrap { display:flex; align-items:center; gap:4px; }
    .fc3-date-wrap .fc3-fv { flex:1; }
    .fc3-date-sep { color:#475569; font-size:.7rem; white-space:nowrap; flex-shrink:0; }

    /* ── Çoklu seçim bölümleri ── */
    .fc3-filt-sect { padding:10px 14px 11px; border-top:1px solid rgba(255,255,255,.04); }
    .fc3-filt-sect-lbl {
        font-size:.72rem; font-weight:700; color:#64748b;
        text-transform:uppercase; letter-spacing:.06em;
        margin-bottom:7px; display:flex; align-items:center; justify-content:space-between;
    }
    .fc3-filt-sect-lbl small { font-size:.7rem; font-weight:400; color:#334155; text-transform:none; letter-spacing:0; }

    /* ── Dropdown accordion seksiyon (Talep Eden / Durum) ── */
    .fc3-filt-dd { border-top:1px solid rgba(255,255,255,.04); }
    .fc3-dd-trigger {
        display:flex; align-items:center; gap:6px;
        padding:8px 14px; cursor:pointer; user-select:none;
        transition:background .1s;
    }
    .fc3-dd-trigger:hover { background:rgba(255,255,255,.03); }
    .fc3-filt-dd.open .fc3-dd-trigger { background:rgba(99,102,241,.06); }
    .fc3-dd-lbl {
        font-size:.72rem; font-weight:700; color:#64748b;
        text-transform:uppercase; letter-spacing:.06em; flex-shrink:0;
    }
    .fc3-dd-val {
        flex:1; font-size:.72rem; color:#475569;
        text-align:right; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; min-width:0;
    }
    .fc3-dd-val.has-sel { color:#818cf8; font-weight:600; }
    .fc3-dd-chev { width:12px; height:12px; color:#475569; flex-shrink:0; transition:transform .15s; }
    .fc3-filt-dd.open .fc3-dd-chev { transform:rotate(180deg); }
    .fc3-dd-body { display:none; padding:0 14px 10px; }
    .fc3-filt-dd.open .fc3-dd-body { display:block; }

    /* Arama kutusu (Talep Eden içi) */
    .fc3-ms-search {
        width:100%; padding:5px 8px; margin-bottom:5px;
        background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08);
        border-radius:5px; color:#e2e8f0; font-size:.79rem; outline:none;
    }
    .fc3-ms-search::placeholder { color:#334155; }
    .fc3-ms-search:focus { border-color:rgba(99,102,241,.4); }

    /* Checkbox listesi */
    .fc3-ms-list {
        max-height:118px; overflow-y:auto;
        border:1px solid rgba(255,255,255,.06); border-radius:6px;
    }
    .fc3-ms-list::-webkit-scrollbar { width:3px; }
    .fc3-ms-list::-webkit-scrollbar-thumb { background:rgba(255,255,255,.1); border-radius:2px; }
    .fc3-ms-opt {
        display:flex; align-items:center; gap:7px;
        padding:6px 10px; cursor:pointer; font-size:.79rem; color:#94a3b8;
        border-bottom:1px solid rgba(255,255,255,.03); transition:background .1s; user-select:none;
    }
    .fc3-ms-opt:last-child { border-bottom:none; }
    .fc3-ms-opt:hover { background:rgba(99,102,241,.07); color:#c7d2fe; }
    .fc3-ms-opt input { accent-color:#6366f1; flex-shrink:0; cursor:pointer; }
    .fc3-ms-empty { padding:12px 10px; font-size:.76rem; color:#334155; text-align:center; font-style:italic; }

    /* Durum chips */
    .fc3-ms-chips { display:flex; flex-wrap:wrap; gap:5px; }
    .fc3-ms-chip {
        display:inline-flex; align-items:center; gap:5px;
        padding:4px 10px; border-radius:999px; cursor:pointer; font-size:.75rem;
        background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08);
        color:#64748b; transition:all .12s; user-select:none;
    }
    .fc3-ms-chip:hover { background:rgba(255,255,255,.07); color:#94a3b8; }
    .fc3-ms-chip.active { background:rgba(99,102,241,.18); border-color:rgba(99,102,241,.4); color:#a5b4fc; }
    .fc3-ms-chip input { display:none; }

    /* ── Seçili özet bar ── */
    .fc3-sel-bar {
        flex-shrink:0; display:flex; align-items:center; gap:8px; flex-wrap:wrap;
        padding:9px 12px; background:rgba(99,102,241,.08); border:1px solid rgba(99,102,241,.2);
        border-radius:10px;
    }
    .fc3-sel-bar__n  { font-size:.83rem; font-weight:700; color:#a5b4fc; white-space:nowrap; }
    .fc3-sel-bar__tags { display:flex; gap:4px; flex-wrap:wrap; }
    .fc3-tag {
        padding:2px 9px; border-radius:999px; font-size:.71rem; font-weight:700;
        background:rgba(99,102,241,.2); border:1px solid rgba(99,102,241,.35);
        color:#c7d2fe; font-family:monospace;
    }

    /* ── Kalem section ── */
    .fc3-section { background:rgba(255,255,255,.02); border:1px solid rgba(255,255,255,.07); border-radius:10px; overflow:hidden; }
    .fc3-sec-hd {
        padding:7px 13px; border-bottom:1px solid rgba(255,255,255,.05);
        font-size:.7rem; font-weight:700; color:#64748b;
        text-transform:uppercase; letter-spacing:.06em;
        display:flex; align-items:center; gap:8px;
    }
    .fc3-spinner { width:10px; height:10px; border:1.5px solid rgba(99,102,241,.3); border-top-color:#6366f1; border-radius:50%; animation:fc3spin .6s linear infinite; flex-shrink:0; }
    @@keyframes fc3spin { to{transform:rotate(360deg);} }
    .fc3-load-badge { display:none; align-items:center; gap:4px; padding:2px 7px; border-radius:999px; background:rgba(99,102,241,.12); color:#818cf8; font-size:.7rem; }
    .fc3-load-badge.show { display:inline-flex; }
    .fc3-tbl { width:100%; border-collapse:collapse; font-size:.8rem; }
    .fc3-tbl th { text-align:left; padding:5px 8px; font-size:.68rem; font-weight:600; color:#475569; border-bottom:1px solid rgba(255,255,255,.06); white-space:nowrap; }
    .fc3-tbl td { padding:5px 8px; border-bottom:1px solid rgba(255,255,255,.03); vertical-align:top; }
    .fc3-tbl tr:last-child td { border-bottom:none; }
    .fc3-sb { display:inline-flex; align-items:center; gap:3px; padding:2px 6px; border-radius:999px; font-size:.67rem; font-weight:600; margin:1px 1px 1px 0; }
    .fc3-sb--ok   { background:rgba(16,185,129,.11); border:1px solid rgba(16,185,129,.28); color:#6ee7b7; }
    .fc3-sb--low  { background:rgba(245,158,11,.11);  border:1px solid rgba(245,158,11,.3);  color:#fbbf24; }
    .fc3-sb--load { background:rgba(100,116,139,.1);  border:1px solid rgba(100,116,139,.2); color:#475569; animation:fc3pulse 1.2s infinite; }
    @@keyframes fc3pulse { 0%,100%{opacity:.45} 50%{opacity:1} }

    /* Aksiyon butonları */
    .fc3-actions { display:flex; gap:6px; flex-wrap:wrap; padding:0 12px 12px; }
    .fc3-atab {
        display:inline-flex; align-items:center; gap:5px; padding:6px 12px; border-radius:7px;
        font-size:.79rem; font-weight:600; cursor:pointer; border:1.5px solid; transition:all .13s;
        text-decoration:none; background:none;
    }
    .fc3-atab--t { border-color:rgba(99,102,241,.3); color:#a5b4fc; }
    .fc3-atab--t:hover, .fc3-atab--t.on { background:rgba(99,102,241,.17); border-color:rgba(99,102,241,.5); color:#c7d2fe; }
    .fc3-atab--s { border-color:rgba(245,158,11,.28); color:#fcd34d; }
    .fc3-atab--s:hover, .fc3-atab--s.on { background:rgba(245,158,11,.15); border-color:rgba(245,158,11,.45); color:#fde68a; }
    .fc3-atab--p { border-color:rgba(16,185,129,.25); color:#6ee7b7; }
    .fc3-atab--p:hover, .fc3-atab--p.on { background:rgba(16,185,129,.14); border-color:rgba(16,185,129,.4); color:#a7f3d0; }
    .fc3-atab--close { border-color:rgba(239,68,68,.25); color:#fca5a5; }
    .fc3-atab--close:hover { background:rgba(239,68,68,.12); border-color:rgba(239,68,68,.4); color:#fecaca; }

    /* Transfer formu */
    .fc3-tf-panel { display:none; }
    .fc3-tf-panel.open { display:block; }
    .fc3-tf-tbl { width:100%; border-collapse:collapse; font-size:.79rem; }
    .fc3-tf-tbl th { text-align:left; padding:5px 8px; font-size:.68rem; font-weight:600; color:#475569; border-bottom:1px solid rgba(255,255,255,.07); }
    .fc3-tf-tbl td { padding:5px 7px; border-bottom:1px solid rgba(255,255,255,.03); vertical-align:middle; }
    .fc3-tf-tbl tr:last-child td { border-bottom:none; }
    .fc3-ti,.fc3-ts {
        width:100%; padding:5px 7px;
        background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.09);
        border-radius:6px; color:#e2e8f0; font-size:.79rem; outline:none;
    }
    .fc3-ti:focus,.fc3-ts:focus { border-color:rgba(99,102,241,.44); }
    .fc3-ti[type=number] { text-align:right; }
    .fc3-ts option { background:#1e293b; }
    .fc3-tf-foot { display:flex; align-items:center; gap:8px; flex-wrap:wrap; padding:9px 12px; border-top:1px solid rgba(255,255,255,.07); }
    .fc3-btn { display:inline-flex; align-items:center; gap:5px; padding:6px 13px; border-radius:7px; font-size:.79rem; font-weight:600; cursor:pointer; border:none; transition:all .13s; }
    .fc3-btn--p { background:linear-gradient(135deg,#6366f1,#8b5cf6); color:#fff; }
    .fc3-btn--p:hover { opacity:.88; }
    .fc3-btn--p:disabled { opacity:.4; cursor:not-allowed; }
    .fc3-btn--g { background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); color:#94a3b8; }
    .fc3-btn--g:hover { background:rgba(255,255,255,.09); color:#e2e8f0; }
    .fc3-res { display:none; padding:6px 10px; border-radius:6px; font-size:.78rem; font-weight:600; }
    .fc3-res--ok  { background:rgba(16,185,129,.12); border:1px solid rgba(16,185,129,.3); color:#6ee7b7; }
    .fc3-res--err { background:rgba(239,68,68,.1);   border:1px solid rgba(239,68,68,.3);  color:#fca5a5; }

    /* Belge linkleri */
    .fc3-doc-links { padding:9px 12px; display:flex; flex-direction:column; gap:5px; }
    .fc3-doc-row   { display:flex; align-items:center; gap:8px; font-size:.8rem; }
    .fc3-doc-lbl   { font-family:monospace; font-size:.78rem; color:#64748b; min-width:80px; }
    .fc3-doc-a { display:inline-flex; align-items:center; gap:5px; padding:4px 10px; border-radius:6px; font-size:.78rem; font-weight:600; text-decoration:none; transition:all .12s; }
    .fc3-doc-a--q { background:rgba(59,130,246,.12); border:1px solid rgba(59,130,246,.28); color:#93c5fd; }
    .fc3-doc-a--q:hover { background:rgba(59,130,246,.22); }
    .fc3-doc-a--o { background:rgba(16,185,129,.1);  border:1px solid rgba(16,185,129,.25); color:#6ee7b7; }
    .fc3-doc-a--o:hover { background:rgba(16,185,129,.2); }

    /* Boş durum */
    .fc3-right-empty {
        display:flex; flex-direction:column; align-items:center; justify-content:center;
        padding:28px 16px; color:#334155; text-align:center; gap:10px;
        background:rgba(255,255,255,.015); border:1px solid rgba(255,255,255,.06); border-radius:10px;
    }
    .fc3-right-empty svg { opacity:.2; }
    .fc3-right-empty p   { font-size:.83rem; }
    textarea.fc3-ti { resize:vertical; }

    /* 2026-06-04: Acik tema override — FulfillmentCenter (fc3-*) */
    body.app-theme-light .fc3-back {
        background:#f1f5f9; border-color:#e2e8f0; color:#475569;
    }
    body.app-theme-light .fc3-back:hover { background:#e2e8f0; color:#0f172a; }
    body.app-theme-light .fc3-title-tx  { color:#0f172a; }
    body.app-theme-light .fc3-title-sub { color:#64748b; }

    body.app-theme-light .fc3-filt-btn {
