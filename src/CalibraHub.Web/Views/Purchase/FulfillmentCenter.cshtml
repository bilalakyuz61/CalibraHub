    // ── Filtre okuma ─────────────────────────────────────────────────────────
    function readFilters() {
        var filters = [];
        document.querySelectorAll('.fc3-ftbl tr[data-field]').forEach(function(row) {
            var field = row.getAttribute('data-field');
            var opEl  = row.querySelector('.fc3-fop');
            var op    = opEl ? opEl.value : 'contains';

            if (field === 'date') {
                var d1El = row.querySelector('.fc3-date-1');
                var d2El = row.querySelector('.fc3-date-2');
                var v1   = d1El ? d1El.value.trim() : '';
                var v2   = d2El ? d2El.value.trim() : '';
                if (op === 'between') { if (v1 || v2) filters.push({ field:'date', op:'between', val:v1, val2:v2 }); }
                else                 { if (v1)        filters.push({ field:'date', op:op,        val:v1,  val2:'' }); }
                return;
            }

            var valEl = row.querySelector('.fc3-fv');
            var val   = valEl ? (valEl.value || '').trim() : '';
            if (val !== '') filters.push({ field:field, op:op, val:val, val2:'' });
        });
        return filters;
    }

    function fieldVal(r, field) {
        if (field === 'docNo')     return (r.documentNumber || '').toLowerCase();
        if (field === 'date')      return r.documentDate || '';

        return '';
    }

    function matchOp(rawVal, op, fv, fv2) {
        if (op === 'between') {
            var d  = new Date(rawVal);
            var d1 = fv  ? new Date(fv)              : null;
            var d2 = fv2 ? new Date(fv2 + 'T23:59:59') : null;
            if (isNaN(d.getTime())) return false;
            if (d1 && d < d1) return false;
            if (d2 && d > d2) return false;
            return d1 != null || d2 != null;
        }
        var v = rawVal.toLowerCase ? rawVal.toLowerCase() : String(rawVal);
        var f = fv ? (fv.toLowerCase ? fv.toLowerCase() : String(fv)) : '';
        if (op === 'contains')   return v.indexOf(f) >= 0;
        if (op === 'startsWith') return v.startsWith(f);
        if (op === 'eq')         return v === f;
        if (op === 'gte')        return new Date(rawVal) >= new Date(fv);
        if (op === 'lte')        return new Date(rawVal) <= new Date(fv + 'T23:59:59');
        return true;
    }

    // ── Filtre uygula ────────────────────────────────────────────────────────
    function fulfillCategory(r) {
        // pending=tüm satırlar bekliyor, full=tüm satırlar tamamlandı, partial=karışık
        if (!r.lineCount) return 'pending';
        if (r.fulfillFull === r.lineCount) return 'full';
        if ((r.fulfillFull || 0) > 0 || (r.fulfillPartial || 0) > 0) return 'partial';
        return 'pending';
    }

    function applyFilters() {
        var textFilters  = readFilters();
        var reqSel       = Array.from(document.querySelectorAll('.fc3-ms-cb-req:checked')).map(function(cb) { return cb.value.toLowerCase(); }).filter(function(v) { return v !== '__all__'; });
        var statSel      = Array.from(document.querySelectorAll('.fc3-ms-cb-stat:checked')).map(function(cb) { return cb.value; }).filter(function(v) { return v !== '__all__'; });
        var fulfillSel   = Array.from(document.querySelectorAll('.fc3-ms-cb-fulfill:checked')).map(function(cb) { return cb.value; });
        var cariGrpSel   = Array.from(document.querySelectorAll('.fc3-ms-cb-cg:checked')).map(function(cb) { return cb.value; });
        var kalemGrpSel  = Array.from(document.querySelectorAll('.fc3-ms-cb-kg:checked')).map(function(cb) { return cb.value; });
        var matSearchEl  = document.getElementById('fc3MatSearch');
        var matSearch    = matSearchEl ? (matSearchEl.value || '').trim().toLowerCase() : '';

        _vis = ALL.filter(function(r) {
            if (!textFilters.every(function(f) { return matchOp(fieldVal(r, f.field), f.op, f.val, f.val2); })) return false;
            if (reqSel.length > 0) {
                var who = (r.requesterPersonnelName || r.contactName || '').toLowerCase();
                if (!reqSel.some(function(s) { return who === s; })) return false;
            }
            if (statSel.length > 0) {
                if (statSel.indexOf(r.status || '') === -1) return false;
            }
            if (fulfillSel.length > 0) {
                if (fulfillSel.indexOf(fulfillCategory(r)) === -1) return false;
            }
            if (cariGrpSel.length > 0) {
                if (cariGrpSel.indexOf(r.contactGroupName || '') === -1) return false;
            }
            if (kalemGrpSel.length > 0) {
                var rGroups = r.itemGroupNames || [];
                if (!kalemGrpSel.some(function(g) { return rGroups.indexOf(g) >= 0; })) return false;
            }
            if (matSearch) {
                var mats = r.materialItems || [];
                if (!mats.some(function(m) {
                    return ((m.code || '').toLowerCase()).indexOf(matSearch) >= 0
                        || ((m.name || '').toLowerCase()).indexOf(matSearch) >= 0;
                })) return false;
            }
            // Widget filtreleri (her widget için OR, widgetlar arası AND)
            for (var _wi = 0; _wi < (WIDGET_DEFS || []).length; _wi++) {
                var _wd  = WIDGET_DEFS[_wi];
                var _sel = Array.from(document.querySelectorAll(
                    '.fc3-ms-cb-wdg[data-wdg="' + _wd.id + '"]:checked'
                )).map(function(cb) { return cb.value; });
                if (!_sel.length) continue;
                var _wvals = wdgValuesForRecord(r, _wd);
                if (!_sel.some(function(s) { return _wvals.indexOf(s) >= 0; })) return false;
            }
            return true;
        });

        var wdgActiveCount = (WIDGET_DEFS || []).filter(function(wd) {
            return document.querySelectorAll('.fc3-ms-cb-wdg[data-wdg="' + wd.id + '"]:checked').length > 0;
        }).length;

        var total = textFilters.length
            + (reqSel.length > 0 ? 1 : 0)
            + (statSel.length > 0 ? 1 : 0)
            + (fulfillSel.length > 0 ? 1 : 0)
            + (cariGrpSel.length > 0 ? 1 : 0)
            + (kalemGrpSel.length > 0 ? 1 : 0)
            + (matSearch ? 1 : 0)
            + wdgActiveCount;
        var btn   = document.getElementById('fc3FiltBtn');
        var badge = document.getElementById('fc3FiltBadge');
        var desc  = document.getElementById('fc3FiltDesc');
        if (btn)   btn.classList.toggle('has-filters', total > 0);
        if (badge) { badge.textContent = total || ''; badge.classList.toggle('show', total > 0); }
        if (desc)  desc.textContent = total
            ? total + ' filtre aktif · ' + _vis.length + ' kayıt'
            : 'Tüm kayıtlar görünüyor (' + ALL.length + ')';

        renderList();
    }

