    // ── Flat liste render ─────────────────────────────────────────────────────
    var FC3_EXTRA_COLS = @Html.Raw(extraColsJson);

    function renderFlatColHdr() {
        var el = document.getElementById('fc3FlatColHdr');
        if (!el) return;
        var visCols = _colDefs.filter(function(c) { return c.visible; });
        var h = '<span class="fc3-fhdr__cb"></span>';
        visCols.forEach(function(c) {
            var align = c.align || 'left';
            var hStyle = (c.flexWeight > 0 ? 'flex:' + c.flexWeight + ';' : '') + 'text-align:' + align;
            if (c.fontSize)   hStyle += ';font-size:'   + c.fontSize   + 'px';
            if (c.fontWeight) hStyle += ';font-weight:' + c.fontWeight;
            if (c.key === 'qty') {
                h += '<span class="fc3-fhdr__qty" style="' + hStyle + '">' + esc(c.label) + '</span>'
                   + '<span class="fc3-fhdr__unit"></span>';
            } else if (c.key === 'fst') {
                h += '<span class="fc3-fhdr__fst" style="' + hStyle + '">' + esc(c.label) + '</span>';
            } else if (c.key.indexOf('ext_') === 0) {
                h += '<span class="fc3-fhdr__ext" style="' + hStyle + '">' + esc(c.label) + '</span>';
            } else {
                h += '<span class="fc3-fhdr__' + c.key + '" style="' + hStyle + '">' + esc(c.label) + '</span>';
            }
        });
        el.innerHTML = h;
    }

    function loadAllLines() {
        var docIds = ALL.map(function(r) { return r.id; });
        if (!docIds.length) { renderList(); return; }
        var pending = docIds.filter(function(id) { return !_docLineCache[id]; });
        var promises = pending.map(function(id) {
            return fetch('/Purchase/RequestLines?requestIds=' + id)
                .then(function(res) { return res.json(); })
                .then(function(lines) { _docLineCache[id] = Array.isArray(lines) ? lines : []; })
                .catch(function() { _docLineCache[id] = []; });
        });
        Promise.all(promises).then(function() {
            var allItemIds = [];
            docIds.forEach(function(id) {
                (_docLineCache[id] || []).forEach(function(l) {
                    if (l.itemId && allItemIds.indexOf(l.itemId) < 0) allItemIds.push(l.itemId);
                });
            });
            if (!allItemIds.length) { _globalStockMap = {}; renderList(); return; }
            var qry = allItemIds.map(function(id) { return 'itemIds=' + id; }).join('&');
            fetch('/Purchase/StockBalances?' + qry)
                .then(function(r) { return r.json(); })
                .then(function(stockArr) {
                    _globalStockMap = {};
                    (stockArr || []).forEach(function(s) {
                        if (!_globalStockMap[s.itemId]) _globalStockMap[s.itemId] = [];
                        _globalStockMap[s.itemId].push(s);
                    });
                    renderList();
                })
                .catch(function() { _globalStockMap = {}; renderList(); });
        });
    }

    // ── Gruplama değeri (her kolon için) ─────────────────────────────────────
    function getGroupValue(r, l, key) {
        var FSL = { 0: 'Bekliyor', 1: 'Kısmen', 2: 'Tamam' };
        switch (key) {
            case 'num':    return r.documentNumber || '—';
            case 'who':    return r.requesterPersonnelName || r.contactName || '—';
            case 'dt':     return fmtDate(r.documentDate);
            case 'mat':    return l.materialName || l.materialCode || '—';
            case 'fst':    return PENDING_APPROVAL_IDS.has(r.id) ? 'Onay Sürecinde' : (FSL[l.fulfillmentStatus] || 'Bekliyor');
            case 'stk': {
                var stkArr = _globalStockMap[l.itemId] || [];
                var stkTot = stkArr.reduce(function(a, s) { return a + (s.balance || 0); }, 0);
                var sRem = l.remaining != null ? l.remaining : Math.max(0, (l.quantity||0) - (l.fulfilledFromStock||0) - (l.fulfilledByPurchase||0));
                if (sRem <= 0) return 'Karşılandı';
                if (!stkArr.length) return 'Stok Yok';
                return stkTot >= sRem ? 'Stok Yeterli' : 'Stok Yetersiz';
            }
            default:
                if (key.indexOf('ext_') === 0) {
                    var xKey   = key.slice(4);
                    var xLabel = (FC3_EXTRA_COLS.find(function(ec) { return ec.key === xKey; }) || {}).label || '';
                    return l.extras && l.extras[xLabel] != null ? String(l.extras[xLabel]) : '—';
                }
                return '';
        }
    }

    function renderList() {
        renderFlatColHdr();
        var el = document.getElementById('fc3List');
        if (!el) return;
        var cnt = document.getElementById('fc3AllCnt');

        var allLoaded = _vis.every(function(r) { return _docLineCache[r.id] !== undefined; });
        if (!allLoaded) {
            if (cnt) cnt.textContent = _vis.length + ' belge';
            el.innerHTML = '<div class="fc3-empty-list">Kalemler yükleniyor…</div>';
            return;
        }

        var totalLines = _vis.reduce(function(s, r) { return s + (_docLineCache[r.id] || []).length; }, 0);
        if (cnt) cnt.textContent = totalLines + ' kalem';

        if (totalLines === 0) {
            el.innerHTML = '<div class="fc3-empty-list">Filtre koşullarına uygun kayıt yok</div>';
            return;
        }

        var visCols = _colDefs.filter(function(c) { return c.visible; });
        var FS_CLASS = { 0: 'fm-fst--pending', 1: 'fm-fst--partial', 2: 'fm-fst--full' };
        var FS_LABEL = { 0: 'Bekliyor', 1: 'Kısmen', 2: 'Tamam' };

        function buildRowHtml(r, l) {
            var who = r.requesterPersonnelName || r.contactName || '—';
            var docHasApproval = PENDING_APPROVAL_IDS.has(r.id);
            var qty     = l.quantity || 0;
            var fromStk = l.fulfilledFromStock || 0;
            var fromPur = l.fulfilledByPurchase || 0;
            var remain  = l.remaining != null ? l.remaining : Math.max(0, qty - fromStk - fromPur);
            var stocks  = _globalStockMap[l.itemId] || [];
            var totalStk = stocks.reduce(function(a, s) { return a + (s.balance || 0); }, 0);

            var stkHtml;
            if (!stocks.length) {
                stkHtml = '<span class="fc3-sk fc3-sk--zero" title="Stok kaydı yok">Stok yok</span>';
            } else {
                var show = stocks.slice(0, 4);
                stkHtml = show.map(function(s) {
                    var bal = s.balance || 0;
                    var cls = bal >= remain && remain > 0 ? 'fc3-sk--ok'
                            : bal > 0 ? 'fc3-sk--warn'
                            : 'fc3-sk--none';
                    return '<span class="fc3-sk ' + cls + '" title="' + esc((s.locationName || '') + ': ' + fmtN(bal) + ' ' + (l.unitCode || '')) + '">'
                        + esc(s.locationName || 'Depo') + ':&thinsp;' + fmtN(bal) + '</span>';
                }).join('');
                if (stocks.length > 4) stkHtml += '<span class="fc3-sk fc3-sk--zero">+' + (stocks.length - 4) + '</span>';
            }

            var remainColor = remain <= 0 ? '#34d399' : (totalStk >= remain ? '#fbbf24' : '#f87171');
            var fstClass, fstLabel;
            if (docHasApproval) {
                fstClass = 'fm-fst--approval'; fstLabel = 'Onay Sürecinde';
            } else if (r.status === 'Approved') {
                fstClass = FS_CLASS[l.fulfillmentStatus] || FS_CLASS[0];
                fstLabel = FS_LABEL[l.fulfillmentStatus] || FS_LABEL[0];
            } else if (r.status === 'Rejected') {
                fstClass = 'fm-fst--rejected'; fstLabel = 'Reddedildi';
            } else if (r.status === 'Cancelled') {
                fstClass = 'fm-fst--cancelled'; fstLabel = 'Kapatıldı / İptal';
            } else {
                fstClass = 'fm-fst--draft'; fstLabel = 'Taslak';
            }

            var canSelect = !docHasApproval && r.status === 'Approved';
            var isLineSel = canSelect && !!_lineSel[l.lineId];
            var cbOnClick = 'event.stopPropagation();fc3LineCheck(' + l.lineId + ',' + r.id + ',' + (l.itemId||0) + ')';

            var cells = visCols.map(function(c) {
                var al = c.align || 'left';
                switch(c.key) {
                    case 'num':
                        return '<span class="fc3-flat-num" style="text-align:' + al + '">' + esc(r.documentNumber || '') + '</span>';
                    case 'who':
                        return '<span class="fc3-flat-who" style="flex:' + (c.flexWeight||1) + ';text-align:' + al + '" title="' + esc(who) + '">' + esc(who) + '</span>';
                    case 'dt':
                        return '<span class="fc3-flat-dt" style="text-align:' + al + '">' + fmtDate(r.documentDate) + '</span>';
                    case 'mat':
                        return '<span class="fc3-sub-mat" style="flex:' + (c.flexWeight||1) + ';text-align:' + al + '" title="' + esc(l.materialName || l.materialCode || '') + '">'
                            + esc(l.materialName || l.materialCode || '—') + '</span>';
                    case 'qty':
                        return '<span class="fc3-sub-qty" style="text-align:' + al + '">' + fmtN(qty) + '</span>'
                            + '<span class="fc3-sub-unit">' + esc(l.unitCode || '') + '</span>';
                    case 'stk':
                        return '<span class="fc3-sub-stk" style="flex:' + (c.flexWeight||1) + '">' + stkHtml + '</span>';
                    case 'remain':
                        return '<span class="fc3-sub-remain" style="color:' + remainColor + ';text-align:' + al + '" title="Kalan: ' + fmtN(remain) + '">'
                            + fmtN(Math.max(0, remain)) + '</span>';
                    case 'fst':
                        return '<span class="fc3-sub-fst ' + fstClass + '" style="text-align:' + al + '">' + fstLabel + '</span>';
                    default:
                        if (c.key.indexOf('ext_') === 0) {
                            var extKey   = c.key.slice(4);
                            var extLabel = (FC3_EXTRA_COLS.find(function(ec) { return ec.key === extKey; }) || {}).label || '';
                            var val = (l.extras && l.extras[extLabel] != null) ? l.extras[extLabel] : '';
                            return '<span class="fc3-sub-ext fc3-sub-ext-' + extKey + '" style="flex:' + (c.flexWeight||1) + '" title="' + esc(val) + '">' + esc(val) + '</span>';
                        }
                        return '';
                }
            }).join('');

            var cbDisableTitle = docHasApproval ? 'Onay sürecinde — seçilemez'
                               : r.status !== 'Approved' ? 'Yalnızca onaylı belgeler seçilebilir'
                               : '';
            return '<div class="fc3-flat-row" data-doc-id="' + r.id + '" data-line-id="' + l.lineId + '">'
                + '<input type="checkbox" class="fc3-sub-cb" data-line-id="' + l.lineId + '"'
                + (!canSelect ? ' disabled title="' + cbDisableTitle + '"' : '')
                + (isLineSel ? ' checked' : '')
                + (canSelect ? ' onclick="' + cbOnClick + '"' : '')
                + '>'
                + cells
                + '</div>';
        }

        // Aktif grup kolonları (sıraya göre)
        var groupCols = _colDefs.filter(function(c) { return c.groupBy && c.visible; })
                                .sort(function(a, b) { return a.groupOrder - b.groupOrder; });

        // Tümünü aç/kapat bar'ı
        var grpCtrl = document.getElementById('fc3GrpCtrl');
        if (grpCtrl) grpCtrl.style.display = groupCols.length > 0 ? 'flex' : 'none';

        if (groupCols.length > 0) {
            // Tüm (belge, kalem) çiftlerini düzleştir + sırala
            var allPairs = [];
            _vis.forEach(function(r) {
                (_docLineCache[r.id] || []).forEach(function(l) { allPairs.push({ r: r, l: l }); });
            });
            allPairs.sort(function(a, b) {
                for (var gi = 0; gi < groupCols.length; gi++) {
                    var ga = getGroupValue(a.r, a.l, groupCols[gi].key);
                    var gb = getGroupValue(b.r, b.l, groupCols[gi].key);
                    if (ga < gb) return -1; if (ga > gb) return 1;
                }
                return 0;
            });

            // Ön hesaplama: her gpath için pair listesi (aggregate + select-all için)
            var groupMeta = {}; // gpath → { pairs:[], lineIds:[] }
            allPairs.forEach(function(p) {
                var curVals = groupCols.map(function(gc) { return getGroupValue(p.r, p.l, gc.key); });
                for (var depth = 0; depth < groupCols.length; depth++) {
                    var gpath = groupCols.slice(0, depth + 1).map(function(gc2, di) { return gc2.key + ':' + curVals[di]; }).join('§§');
                    if (!groupMeta[gpath]) groupMeta[gpath] = { pairs: [], lineIds: [] };
                    groupMeta[gpath].pairs.push(p);
                    groupMeta[gpath].lineIds.push(p.l.lineId);
                }
            });

            // Aggregate hesaplama
            function getNumVal(r, l, key) {
                if (key === 'qty')    return l.quantity || 0;
                if (key === 'remain') return l.remaining != null ? l.remaining : Math.max(0, (l.quantity||0) - (l.fulfilledFromStock||0) - (l.fulfilledByPurchase||0));
                return null;
            }
            function calcAgg(pairs, colKey, func) {
                var vals = pairs.map(function(p) { return getNumVal(p.r, p.l, colKey); }).filter(function(v) { return v !== null; });
                if (!vals.length) return null;
                switch(func) {
                    case 'sum': return vals.reduce(function(a,b){return a+b;}, 0);
                    case 'avg': return Math.round((vals.reduce(function(a,b){return a+b;},0)/vals.length)*100)/100;
                    case 'min': return Math.min.apply(null, vals);
                    case 'max': return Math.max.apply(null, vals);
                    default:    return null;
                }
            }
            var aggCols = _colDefs.filter(function(c) { return c.aggregateFunc && c.aggregateFunc !== ''; });

            // Grup özet satırı — aggregate değerleri veri satırlarıyla aynı sütun hizasında
            function buildAggRowHtml(localVisCols, pairs, localAggCols, indent) {
                var aggMap = {};
                localAggCols.forEach(function(c) {
                    var v = calcAgg(pairs, c.key, c.aggregateFunc);
                    if (v !== null) aggMap[c.key] = v;
                });
                if (!Object.keys(aggMap).length) return '';

                var cells = localVisCols.map(function(c) {
                    var al = c.align || 'left';
                    var hasV = aggMap.hasOwnProperty(c.key);
                    switch(c.key) {
                        case 'num':
                            return '<span class="fc3-flat-num" style="text-align:' + al + '"></span>';
                        case 'who':
                            return '<span class="fc3-flat-who" style="flex:' + (c.flexWeight||1) + ';text-align:' + al + '"></span>';
                        case 'dt':
                            return '<span class="fc3-flat-dt"></span>';
                        case 'mat':
                            return '<span class="fc3-sub-mat" style="flex:' + (c.flexWeight||1) + '"></span>';
                        case 'qty':
                            return '<span class="fc3-sub-qty" style="text-align:right">'
                                + (hasV ? fmtN(aggMap[c.key]) : '') + '</span>'
                                + '<span class="fc3-sub-unit"></span>';
                        case 'stk':
                            return '<span class="fc3-sub-stk" style="flex:' + (c.flexWeight||1) + '"></span>';
                        case 'remain':
                            return '<span class="fc3-sub-remain" style="text-align:right">'
                                + (hasV ? fmtN(aggMap[c.key]) : '') + '</span>';
                        case 'fst':
                            return '<span class="fc3-sub-fst"></span>'
                                + '<span class="fc3-sub-suf"></span>';
                        default:
                            if (c.key.indexOf('ext_') === 0) {
                                return '<span class="fc3-sub-ext" style="flex:' + (c.flexWeight||1) + '"></span>';
                            }
                            return '';
                    }
                }).join('');

                return '<div class="fc3-agg-row" style="padding-left:' + (12 + indent) + 'px">'
                    + '<span class="fc3-agg-cb"></span>'
                    + cells
                    + '</div>';
            }

            // Render
            var chevDown = '<svg viewBox="0 0 10 8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><polyline points="1,2 5,6 9,2"/></svg>';
            var sentinelKeys = groupCols.map(function() { return '\x00'; });
            var gHtml = '';

            allPairs.forEach(function(p) {
                var curVals = groupCols.map(function(gc) { return getGroupValue(p.r, p.l, gc.key); });

                for (var gi = 0; gi < groupCols.length; gi++) {
                    var gv = curVals[gi];
                    if (gv !== sentinelKeys[gi]) {
                        for (var ri = gi; ri < groupCols.length; ri++) sentinelKeys[ri] = '\x00';
                        sentinelKeys[gi] = gv;

                        var gpath = groupCols.slice(0, gi + 1).map(function(gc2, di) { return gc2.key + ':' + curVals[di]; }).join('§§');

                        // Ebeveyn katlanmış mı?
                        var parentCollapsed = false;
                        for (var di = 0; di < gi; di++) {
                            var anc = groupCols.slice(0, di + 1).map(function(gc3, ddi) { return gc3.key + ':' + curVals[ddi]; }).join('§§');
                            if (_collapsedGroups[anc]) { parentCollapsed = true; break; }
                        }
                        if (parentCollapsed) continue;

                        var isCollapsed = !!_collapsedGroups[gpath];
                        var meta = groupMeta[gpath] || { pairs: [], lineIds: [] };
                        var rowCount = meta.pairs.length;

                        // Özet değerleri hesapla
                        var aggMapHdr = {};
                        aggCols.forEach(function(ac) {
                            var v = calcAgg(meta.pairs, ac.key, ac.aggregateFunc);
                            if (v !== null) aggMapHdr[ac.key] = v;
                        });
                        // Kimlik bölümünün flex/min-width hesabı: sütun hizalaması için
                        var hdrFixedW = 0, hdrFlex = 0;
                        visCols.forEach(function(vc) {
                            if (vc.key === 'num')                          hdrFixedW += 130;
                            else if (vc.key === 'dt')                      hdrFixedW += 55;
                            else if (vc.key === 'who' || vc.key === 'mat') hdrFlex += (vc.flexWeight || 1);
                        });
                        if (hdrFlex === 0) hdrFlex = 1;
                        // Sağ taraf (sayısal) sütun hücreleri
                        var hdrRightCells = visCols.map(function(vc) {
                            if (vc.key === 'num' || vc.key === 'who' || vc.key === 'dt' || vc.key === 'mat') return '';
                            var hasV = aggMapHdr.hasOwnProperty(vc.key);
                            switch(vc.key) {
                                case 'qty':    return '<span class="fc3-sub-qty" style="text-align:right">' + (hasV ? fmtN(aggMapHdr[vc.key]) : '') + '</span><span class="fc3-sub-unit"></span>';
                                case 'stk':    return '<span class="fc3-sub-stk" style="flex:' + (vc.flexWeight||1) + '"></span>';
                                case 'remain': return '<span class="fc3-sub-remain" style="text-align:right">' + (hasV ? fmtN(aggMapHdr[vc.key]) : '') + '</span>';
                                case 'fst':    return '<span class="fc3-sub-fst"></span><span class="fc3-sub-suf"></span>';
                                default:       return vc.key.indexOf('ext_') === 0 ? '<span class="fc3-sub-ext" style="flex:' + (vc.flexWeight||1) + '"></span>' : '';
                            }
                        }).join('');

                        var indent = gi * 16;
                        gHtml += '<div class="fc3-group-hdr' + (isCollapsed ? ' collapsed' : '') + '" style="padding-left:' + (12 + indent) + 'px">'
                            + '<span class="fc3-grp-identity" style="flex:' + hdrFlex + ';min-width:' + hdrFixedW + 'px">'
                            +   '<label class="fc3-grp-selall" title="Tümünü seç / kaldır"><input type="checkbox" class="fc3-grp-cb" data-gpath="' + esc(gpath) + '"></label>'
                            +   '<button type="button" class="fc3-grp-tog" data-gpath="' + esc(gpath) + '">' + chevDown + '</button>'
                            +   '<span class="fc3-group-hdr__dim">' + esc(groupCols[gi].label) + '</span>'
                            +   '<span class="fc3-group-hdr__sep"> › </span>'
                            +   '<span class="fc3-group-hdr__val">' + esc(gv || '—') + '</span>'
                            +   '<span class="fc3-grp-cnt">' + rowCount + ' kalem</span>'
                            + '</span>'
                            + hdrRightCells
                            + '</div>';
                    }
                }

                // Herhangi bir ata katlanmışsa satırı gizle
                var anyCollapsed = groupCols.some(function(gc2, depth) {
                    var cp = groupCols.slice(0, depth + 1).map(function(gc3, di) { return gc3.key + ':' + curVals[di]; }).join('§§');
                    return !!_collapsedGroups[cp];
                });
                if (!anyCollapsed) gHtml += buildRowHtml(p.r, p.l);
            });

            el.innerHTML = gHtml;

            // Grup katlama toggle
            el.querySelectorAll('.fc3-grp-tog').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var gpath = btn.getAttribute('data-gpath');
                    if (_collapsedGroups[gpath]) delete _collapsedGroups[gpath];
                    else _collapsedGroups[gpath] = true;
                    renderList();
                });
            });

            // Grup select-all / deselect-all
            el.querySelectorAll('.fc3-grp-cb').forEach(function(cb) {
                cb.addEventListener('change', function(e) {
                    e.stopPropagation();
                    var gpath = cb.getAttribute('data-gpath');
                    var meta = groupMeta[gpath] || { pairs: [] };
                    meta.pairs.forEach(function(p) {
                        if (PENDING_APPROVAL_IDS.has(p.r.id)) return;
                        if (cb.checked) _lineSel[p.l.lineId] = { docId: p.r.id, itemId: p.l.itemId };
                        else delete _lineSel[p.l.lineId];
                        var domCb = el.querySelector('.fc3-sub-cb[data-line-id="' + p.l.lineId + '"]');
                        if (domCb) domCb.checked = cb.checked;
                    });
                    fc3UpdateFulfillBar(); onLineSel();
                });
            });
        } else {
            // Düz liste (mevcut davranış)
            el.innerHTML = _vis.map(function(r) {
                return (_docLineCache[r.id] || []).map(function(l) { return buildRowHtml(r, l); }).join('');
            }).join('');
        }
    }

    // ── Satır seçimi (Depodan Karşıla) ────────────────────────────────────────
    window.fc3LineCheck = function(lineId, docId, itemId) {
        var cb = document.querySelector('.fc3-sub-cb[data-line-id="' + lineId + '"]');
        if (!cb) return;
        if (cb.checked) {
            _lineSel[lineId] = { docId: docId, itemId: itemId };
        } else {
            delete _lineSel[lineId];
        }
        fc3UpdateFulfillBar(); onLineSel();
    };

    window.fc3LineSelClear = function() {
        _lineSel = {};
        document.querySelectorAll('.fc3-sub-cb').forEach(function(cb) { cb.checked = false; });
        fc3UpdateFulfillBar(); onLineSel();
    };

    window.fc3CollapseAll = function() {
        document.querySelectorAll('#fc3List .fc3-grp-tog').forEach(function(btn) {
            var gp = btn.getAttribute('data-gpath');
            if (gp) _collapsedGroups[gp] = true;
        });
        renderList();
    };
    window.fc3ExpandAll = function() { _collapsedGroups = {}; renderList(); };

    function fc3UpdateFulfillBar() {
        var bar = document.getElementById('fc3FulfillBar');
        if (!bar) return;
        var vals = Object.values(_lineSel);
        bar.classList.toggle('show', vals.length > 0);
        var cnt = document.getElementById('fc3FbCnt');
        if (cnt) cnt.textContent = vals.length + ' kalem seçili';
        var res = document.getElementById('fc3FbRes');
        if (res) { res.textContent = ''; res.className = 'fc3-fb-res'; }
        var chips = document.getElementById('fc3FbChips');
        if (chips) {
            var uniqueItems = new Set(vals.map(function(v) { return v.itemId; })).size;
            var uniqueDocs  = new Set(vals.map(function(v) { return v.docId;  })).size;
            var html = '';
            if (uniqueItems > 0) html += '<span class="fc3-fb-chip">' + uniqueItems + ' malzeme</span>';
            if (uniqueDocs  > 0) html += '<span class="fc3-fb-chip">' + uniqueDocs  + ' ihtiyaç</span>';
            chips.innerHTML = html;
        }
        if (!vals.length) fc3CloseActionSheet();
    }

    window.fc3FulfillFromStock = function() {
        var ids = Object.keys(_lineSel).map(Number);
        if (!ids.length) return;
        var btn = document.getElementById('fc3FbBtn');
        var res = document.getElementById('fc3FbRes');
        if (btn) { btn.disabled = true; }
        if (res) { res.textContent = ''; res.className = 'fc3-fb-res'; }
        fetch('/Purchase/FulfillFromStock', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ lineIds: ids, notes: null })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (btn) btn.disabled = false;
            if (data.ok) {
                var fulfilled = (data.results || []).filter(function(r) { return r.fulfilled > 0; }).length;
                var msg = (data.docNo ? data.docNo + ' fişi oluşturuldu · ' : '') + fulfilled + ' kalem karşılandı';
                if (res) { res.textContent = '✓ ' + msg; res.className = 'fc3-fb-res ok'; }
                // Cache'i temizle ve yenile
                _lineSel = {};
                _docLineCache  = {};
                _globalStockMap = {};
                document.querySelectorAll('.fc3-sub-cb').forEach(function(cb) { cb.checked = false; });
                fc3UpdateFulfillBar();
                loadAllLines();
                // Bar 3 sn sonra kapansın
                setTimeout(function() {
                    var b2 = document.getElementById('fc3FulfillBar');
                    if (b2 && !Object.keys(_lineSel).length) b2.classList.remove('show');
                    if (res) { res.textContent = ''; res.className = 'fc3-fb-res'; }
                }, 3000);
            } else {
                if (res) { res.textContent = '✕ ' + (data.error || 'Hata'); res.className = 'fc3-fb-res err'; }
            }
        })
        .catch(function(err) {
            if (btn) btn.disabled = false;
            if (res) { res.textContent = '✕ Bağlantı hatası'; res.className = 'fc3-fb-res err'; }
        });
    };

    // ── Kalem seçimi → drawer beslemesi ──────────────────────────────────────
    function buildSelectedLines() {
        var result = [];
        Object.keys(_lineSel).forEach(function(lineId) {
            var info = _lineSel[lineId];
            var docLines = _docLineCache[info.docId] || [];
            var line = docLines.find(function(l) { return l.lineId === parseInt(lineId, 10); });
            if (line) result.push(line);
        });
        return result;
    }

    function onLineSel() {
        var lineIds = Object.keys(_lineSel);
        var sc = document.getElementById('fc3SelCnt');
        if (sc) { sc.textContent = lineIds.length ? lineIds.length + ' kalem seçili' : ''; sc.classList.toggle('show', lineIds.length > 0); }
        if (!lineIds.length) return;
        _lines = buildSelectedLines();
        renderLines(); renderTf(); renderSf(); renderPr();
    }

    // ── Sütun yapılandırması ──────────────────────────────────────────────────
    var DEFAULT_DEFS = [
        { key: 'num',    label: 'Belge No',    visible: true, align: 'left',   fixed: false, fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 0, aggregateFunc: '' },
        { key: 'who',    label: 'Talep Eden',  visible: true, align: 'left',   fixed: false, fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 2, aggregateFunc: '' },
        { key: 'dt',     label: 'Tarih',       visible: true, align: 'right',  fixed: false, fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 0, aggregateFunc: '' },
        { key: 'mat',    label: 'Malzeme',     visible: true, align: 'left',   fixed: true,  fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 2, aggregateFunc: '' },
        { key: 'qty',    label: 'Miktar',      visible: true, align: 'right',  fixed: false, fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 0, aggregateFunc: 'sum' },
        { key: 'stk',    label: 'Stok',        visible: true, align: 'left',   fixed: false, fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 2, aggregateFunc: '' },
        { key: 'remain', label: 'Kalan',       visible: true, align: 'right',  fixed: false, fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 0, aggregateFunc: 'sum' },
        { key: 'fst',    label: 'Durum',       visible: true, align: 'center', fixed: false, fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 0, aggregateFunc: '' },
    ];

    function _makeDefaultDefs() {
        var d = DEFAULT_DEFS.map(function(x) { return Object.assign({}, x); });
        FC3_EXTRA_COLS.forEach(function(c) {
            d.push({ key: 'ext_' + c.key, label: c.label, visible: true, align: 'left', fixed: false, fontSize: 0, fontWeight: 0, groupBy: false, groupOrder: 0, flexWeight: 2, aggregateFunc: '' });
        });
        return d;
    }

    var _colDefs = _makeDefaultDefs();

    function _applyColSaved(saved) {
        if (!Array.isArray(saved)) return;
        saved.forEach(function(s) {
            var def = _colDefs.find(function(d) { return d.key === s.key; });
            if (!def) return;
            if (s.label      !== undefined) def.label      = s.label;
            if (s.align      !== undefined) def.align      = s.align;
            if (s.fontSize   !== undefined) def.fontSize   = s.fontSize   || 0;
            if (s.fontWeight !== undefined) def.fontWeight = s.fontWeight || 0;
            if (s.visible    !== undefined && !def.fixed) def.visible = s.visible;
            if (s.groupBy       !== undefined) def.groupBy       = !!s.groupBy;
            if (s.groupOrder    !== undefined) def.groupOrder    = s.groupOrder || 0;
            if (s.flexWeight    !== undefined && def.flexWeight > 0) def.flexWeight = Math.max(1, Math.min(4, s.flexWeight || 2));
            if (s.aggregateFunc !== undefined) def.aggregateFunc = s.aggregateFunc || '';
        });
        var order = saved.map(function(s) { return s.key; });
        _colDefs.sort(function(a, b) {
            var ia = order.indexOf(a.key), ib = order.indexOf(b.key);
            if (ia < 0) return 1; if (ib < 0) return -1;
            return ia - ib;
        });
    }

    (function loadFromStorage() {
        try {
            var json = localStorage.getItem('fc3-col-flat-v3');
            if (json) _applyColSaved(JSON.parse(json));
        } catch(e) {}
    })();

    function _serializeDefs() {
        return JSON.stringify(_colDefs.map(function(c) {
            return { key: c.key, visible: c.visible, align: c.align, label: c.label, fontSize: c.fontSize || 0, fontWeight: c.fontWeight || 0, groupBy: c.groupBy || false, groupOrder: c.groupOrder || 0, flexWeight: c.flexWeight || 0, aggregateFunc: c.aggregateFunc || '' };
        }));
    }
    function _saveColDefs() {
        var json = _serializeDefs();
        try { localStorage.setItem('fc3-col-flat-v3', json); } catch(e) {}
        fetch('/Purchase/SaveFlatColConfig', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ config: json })
        }).catch(function() {});
    }

    // ── Panel SVG sabitler ────────────────────────────────────────────────────
    var _GRIP   = '<svg viewBox="0 0 16 16" fill="currentColor"><circle cx="5" cy="4" r="1.2"/><circle cx="5" cy="8" r="1.2"/><circle cx="5" cy="12" r="1.2"/><circle cx="11" cy="4" r="1.2"/><circle cx="11" cy="8" r="1.2"/><circle cx="11" cy="12" r="1.2"/></svg>';
    var _EYE    = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    var _EYEOFF = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
    var _CHEV   = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>';
    var _GRP    = '<svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="1" y1="3" x2="13" y2="3"/><line x1="3" y1="7" x2="13" y2="7"/><line x1="5" y1="11" x2="13" y2="11"/></svg>';
    var _ALIGN_ICONS = {
        left:   '<svg viewBox="0 0 16 14" fill="currentColor"><rect x="0" y="0" width="16" height="2" rx="1"/><rect x="0" y="4" width="10" height="2" rx="1"/><rect x="0" y="8" width="13" height="2" rx="1"/><rect x="0" y="12" width="8" height="2" rx="1"/></svg>',
        center: '<svg viewBox="0 0 16 14" fill="currentColor"><rect x="0" y="0" width="16" height="2" rx="1"/><rect x="3" y="4" width="10" height="2" rx="1"/><rect x="1.5" y="8" width="13" height="2" rx="1"/><rect x="4" y="12" width="8" height="2" rx="1"/></svg>',
        right:  '<svg viewBox="0 0 16 14" fill="currentColor"><rect x="0" y="0" width="16" height="2" rx="1"/><rect x="6" y="4" width="10" height="2" rx="1"/><rect x="2.5" y="8" width="13" height="2" rx="1"/><rect x="8" y="12" width="8" height="2" rx="1"/></svg>',
    };
    // Boyut (font-size): standart=büyük, iki küçük seçenek
    var _F = 'font-family:Georgia,serif;line-height:1';
    var _BOYUT_ICONS = {
        10: '<span style="font-size:9px;'  + _F + '">A</span>',
        12: '<span style="font-size:13px;' + _F + '">A</span>',
        15: '<span style="font-size:16px;' + _F + '">A</span>',
    };
    // Stil (font-weight): "B" gerçek kalınlık değerlerinde
    var _STIL_ICONS = {
        0:   '<span style="font-size:14px;font-weight:400;' + _F + '">B</span>',
        500: '<span style="font-size:14px;font-weight:500;' + _F + '">B</span>',
        700: '<span style="font-size:14px;font-weight:700;' + _F + '">B</span>',
        900: '<span style="font-size:14px;font-weight:900;' + _F + '">B</span>',
    };
    // Özet (aggregateFunc): matematiksel semboller
    var _AGG_ICONS = {
        '':    '<span style="font-size:16px;font-weight:300;line-height:1">—</span>',
        'sum': '<span style="font-size:14px;font-style:italic;' + _F + '">Σ</span>',
        'avg': '<span style="font-size:12px;' + _F + '">x&#773;</span>',
        'min': '<span style="font-size:15px;line-height:1">↓</span>',
        'max': '<span style="font-size:15px;line-height:1">↑</span>',
    };
    var _expandedKeys = new Set();

    function _renderColPanel() {
        var rowsEl = document.getElementById('fc3ColRows');
        if (!rowsEl) return;
        var html = '';
        _colDefs.forEach(function(c, i) {
            var fc = c.fixed   ? ' is-fixed'  : '';
            var hc = !c.visible ? ' is-hidden' : '';
            var isOpen = _expandedKeys.has(c.key);
            var oc = isOpen ? ' open' : '';
            html +=
                '<div class="fc3-cfg-row' + fc + hc + '" data-idx="' + i + '" data-key="' + c.key + '" draggable="' + (c.fixed ? 'false' : 'true') + '">' +
                    '<span class="fc3-cfg-grip">' + _GRIP + '</span>' +
                    '<button type="button" class="fc3-cfg-eye' + (!c.visible ? ' fc3-eye-off' : '') + '" data-key="' + c.key + '">' + (c.visible ? _EYE : _EYEOFF) + '</button>' +
                    '<span class="fc3-cfg-label">' + esc(c.label) + '</span>' +
                    '<button type="button" class="fc3-cfg-grp-btn' + (c.groupBy ? ' active' : '') + '" data-key="' + c.key + '" title="' + (c.groupBy ? '#' + c.groupOrder + ' — Gruplamayı kaldır' : 'Grupla') + '">' +
                        (c.groupBy ? '<span class="fc3-cfg-grp-ord">' + c.groupOrder + '</span>' : _GRP) +
                    '</button>' +
                    '<button type="button" class="fc3-cfg-exp' + oc + '" data-key="' + c.key + '" title="Detay ayarları">' + _CHEV + '</button>' +
                '</div>' +
                '<div class="fc3-cfg-detail' + oc + '" data-key="' + c.key + '">' +
                    '<div class="fc3-cfg-field-row">' +
                        '<span class="fc3-cfg-field-label">Başlık</span>' +
                        '<input type="text" class="fc3-cfg-field-input" data-key="' + c.key + '" data-field="label" value="' + esc(c.label) + '">' +
                    '</div>' +
                    '<div class="fc3-cfg-field-row">' +
                        '<span class="fc3-cfg-field-label">Hizalama</span>' +
                        '<span class="fc3-cfg-align">' +
                            '<button type="button" class="fc3-cfg-align-btn' + (c.align === 'left'   ? ' fc3-align-active' : '') + '" data-key="' + c.key + '" data-align="left"   title="Sola">'   + _ALIGN_ICONS.left   + '</button>' +
                            '<button type="button" class="fc3-cfg-align-btn' + (c.align === 'center' ? ' fc3-align-active' : '') + '" data-key="' + c.key + '" data-align="center" title="Orta">'   + _ALIGN_ICONS.center + '</button>' +
                            '<button type="button" class="fc3-cfg-align-btn' + (c.align === 'right'  ? ' fc3-align-active' : '') + '" data-key="' + c.key + '" data-align="right"  title="Sağa">'  + _ALIGN_ICONS.right  + '</button>' +
                        '</span>' +
                    '</div>' +
                    '<div class="fc3-cfg-field-row">' +
                        '<span class="fc3-cfg-field-label">Boyut</span>' +
                        '<span class="fc3-cfg-icon-row">' +
                            '<button type="button" class="fc3-cfg-chip' + (c.fontSize === 10    ? ' active' : '') + '" data-key="' + c.key + '" data-field="fontSize" data-val="10"  title="Küçük">'    + _BOYUT_ICONS[10] + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (c.fontSize === 12    ? ' active' : '') + '" data-key="' + c.key + '" data-field="fontSize" data-val="12"  title="Orta">'     + _BOYUT_ICONS[12] + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (!c.fontSize || c.fontSize === 15 ? ' active' : '') + '" data-key="' + c.key + '" data-field="fontSize" data-val="15"  title="Standart (Büyük)">' + _BOYUT_ICONS[15] + '</button>' +
                        '</span>' +
                    '</div>' +
                    '<div class="fc3-cfg-field-row">' +
                        '<span class="fc3-cfg-field-label">Stil</span>' +
                        '<span class="fc3-cfg-icon-row">' +
                            '<button type="button" class="fc3-cfg-chip' + (!c.fontWeight         ? ' active' : '') + '" data-key="' + c.key + '" data-field="fontWeight" data-val="0"   title="Normal (400)">'     + _STIL_ICONS[0]   + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (c.fontWeight === 500  ? ' active' : '') + '" data-key="' + c.key + '" data-field="fontWeight" data-val="500" title="Orta (500)">'       + _STIL_ICONS[500] + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (c.fontWeight === 700  ? ' active' : '') + '" data-key="' + c.key + '" data-field="fontWeight" data-val="700" title="Kalın (700)">'      + _STIL_ICONS[700] + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (c.fontWeight === 900  ? ' active' : '') + '" data-key="' + c.key + '" data-field="fontWeight" data-val="900" title="Çok Kalın (900)">'  + _STIL_ICONS[900] + '</button>' +
                        '</span>' +
                    '</div>' +
                    '<div class="fc3-cfg-field-row">' +
                        '<span class="fc3-cfg-field-label">Özet</span>' +
                        '<span class="fc3-cfg-icon-row">' +
                            '<button type="button" class="fc3-cfg-chip' + (!c.aggregateFunc       ? ' active' : '') + '" data-key="' + c.key + '" data-field="aggregateFunc" data-val=""    title="Yok">'          + _AGG_ICONS['']    + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (c.aggregateFunc==='sum'  ? ' active' : '') + '" data-key="' + c.key + '" data-field="aggregateFunc" data-val="sum" title="Toplam (Σ)">'  + _AGG_ICONS['sum'] + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (c.aggregateFunc==='avg'  ? ' active' : '') + '" data-key="' + c.key + '" data-field="aggregateFunc" data-val="avg" title="Ortalama">'   + _AGG_ICONS['avg'] + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (c.aggregateFunc==='min'  ? ' active' : '') + '" data-key="' + c.key + '" data-field="aggregateFunc" data-val="min" title="Minimum">'    + _AGG_ICONS['min'] + '</button>' +
                            '<button type="button" class="fc3-cfg-chip' + (c.aggregateFunc==='max'  ? ' active' : '') + '" data-key="' + c.key + '" data-field="aggregateFunc" data-val="max" title="Maksimum">'   + _AGG_ICONS['max'] + '</button>' +
                        '</span>' +
                    '</div>' +
                    (c.flexWeight > 0 ?
                    '<div class="fc3-cfg-field-row">' +
                        '<span class="fc3-cfg-field-label">Genişlik</span>' +
                        '<span class="fc3-cfg-stepper">' +
                            '<button type="button" class="fc3-cfg-step-btn" data-key="' + c.key + '" data-dir="-1"' + (c.flexWeight <= 1 ? ' disabled' : '') + '>−</button>' +
                            '<span class="fc3-step-dots">' +
                                [1,2,3,4].map(function(i) { return '<span class="fc3-step-dot' + (i <= c.flexWeight ? ' on' : '') + '"></span>'; }).join('') +
                            '</span>' +
                            '<button type="button" class="fc3-cfg-step-btn" data-key="' + c.key + '" data-dir="1"' + (c.flexWeight >= 4 ? ' disabled' : '') + '>+</button>' +
                        '</span>' +
                    '</div>'
                    : '') +
                '</div>';
        });
        rowsEl.innerHTML = html;

        // Göz toggle
        rowsEl.querySelectorAll('.fc3-cfg-eye').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key = btn.getAttribute('data-key');
                var def = _colDefs.find(function(d) { return d.key === key; });
                if (!def || def.fixed) return;
                def.visible = !def.visible;
                _saveColDefs();
                _renderColPanel();
                renderList();
            });
        });

        // Hizalama
        rowsEl.querySelectorAll('.fc3-cfg-align-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key   = btn.getAttribute('data-key');
                var align = btn.getAttribute('data-align');
                var def   = _colDefs.find(function(d) { return d.key === key; });
                if (!def) return;
                def.align = align;
                _saveColDefs();
                _renderColPanel();
                renderList();
            });
        });

        // Başlık düzenleme
        rowsEl.querySelectorAll('input[data-field="label"]').forEach(function(inp) {
            inp.addEventListener('input', function(e) {
                e.stopPropagation();
                var key = inp.getAttribute('data-key');
                var def = _colDefs.find(function(d) { return d.key === key; });
                if (!def) return;
                def.label = inp.value;
                _saveColDefs();
                var span = rowsEl.querySelector('.fc3-cfg-row[data-key="' + key + '"] .fc3-cfg-label');
                if (span) span.textContent = def.label;
                renderList();
            });
        });

        // Boyut + Stil + Özet chip seçimleri
        rowsEl.querySelectorAll('.fc3-cfg-chip').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key   = btn.getAttribute('data-key');
                var field = btn.getAttribute('data-field');
                var rawVal = btn.getAttribute('data-val');
                var def   = _colDefs.find(function(d) { return d.key === key; });
                if (!def) return;
                // aggregateFunc string, diğerleri int
                def[field] = (field === 'aggregateFunc') ? (rawVal || '') : (parseInt(rawVal, 10) || 0);
                _saveColDefs();
                if (field === 'aggregateFunc') { renderList(); } else { renderFlatColHdr(); }
                _renderColPanel();
            });
        });

        // Genişlik stepper
        rowsEl.querySelectorAll('.fc3-cfg-step-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key = btn.getAttribute('data-key');
                var dir = parseInt(btn.getAttribute('data-dir'), 10);
                var def = _colDefs.find(function(d) { return d.key === key; });
                if (!def || def.flexWeight <= 0) return;
                def.flexWeight = Math.max(1, Math.min(4, def.flexWeight + dir));
                _saveColDefs();
                _renderColPanel();
                renderList();
            });
        });

        // Grupla toggle (ana satır)
        rowsEl.querySelectorAll('.fc3-cfg-grp-btn').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key = btn.getAttribute('data-key');
                var def = _colDefs.find(function(d) { return d.key === key; });
                if (!def) return;
                if (def.groupBy) {
                    def.groupBy = false;
                    def.groupOrder = 0;
                    // Kalan grupları yeniden numaralandır
                    _colDefs.filter(function(d) { return d.groupBy; })
                            .sort(function(a, b) { return a.groupOrder - b.groupOrder; })
                            .forEach(function(d, i) { d.groupOrder = i + 1; });
                } else {
                    var maxOrd = _colDefs.reduce(function(m, d) { return d.groupBy ? Math.max(m, d.groupOrder) : m; }, 0);
                    def.groupBy = true;
                    def.groupOrder = maxOrd + 1;
                }
                _saveColDefs();
                _renderColPanel();
                renderList();
            });
        });

        // Expand/collapse
        rowsEl.querySelectorAll('.fc3-cfg-exp').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                var key = btn.getAttribute('data-key');
                if (_expandedKeys.has(key)) _expandedKeys.delete(key); else _expandedKeys.add(key);
                _renderColPanel();
            });
        });

        // Drag-and-drop sıralama
        var dragSrcIdx = null;
        rowsEl.querySelectorAll('.fc3-cfg-row:not(.is-fixed)').forEach(function(row) {
            row.addEventListener('dragstart', function(e) {
                dragSrcIdx = parseInt(row.getAttribute('data-idx'), 10);
                e.dataTransfer.effectAllowed = 'copyMove';
                setTimeout(function() { row.classList.add('fc3-cfg-dragging'); }, 0);
            });
            row.addEventListener('dragend', function() {
                dragSrcIdx = null;
                rowsEl.querySelectorAll('.fc3-cfg-row').forEach(function(r) { r.classList.remove('fc3-cfg-dragging', 'drag-over'); });
            });
            row.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                rowsEl.querySelectorAll('.fc3-cfg-row').forEach(function(r) { r.classList.remove('drag-over'); });
                row.classList.add('drag-over');
            });
            row.addEventListener('drop', function(e) {
                e.preventDefault();
                if (dragSrcIdx === null) return;
                var tgtIdx = parseInt(row.getAttribute('data-idx'), 10);
                if (isNaN(tgtIdx) || dragSrcIdx === tgtIdx) return;
                if (_colDefs[tgtIdx] && _colDefs[tgtIdx].fixed) return;
                var moved = _colDefs.splice(dragSrcIdx, 1)[0];
                _colDefs.splice(tgtIdx, 0, moved);
                _saveColDefs();
                _renderColPanel();
                renderList();
            });
        });

        var panelEl = document.getElementById('fc3ColPanel');
        if (panelEl) panelEl.ondragover = function(e2) { e2.preventDefault(); };
    }

    window.fc3ToggleColPanel = function(e) {
        if (e) e.stopPropagation();
        var panel    = document.getElementById('fc3ColPanel');
        var backdrop = document.getElementById('fc3ColBackdrop');
        if (!panel) return;
        if (panel.classList.contains('open')) {
            panel.classList.remove('open');
            if (backdrop) backdrop.classList.remove('open');
        } else {
            panel.classList.add('open');
            if (backdrop) backdrop.classList.add('open');
            _renderColPanel();
        }
    };
    window.fc3CloseColPanel = function() {
        var panel    = document.getElementById('fc3ColPanel');
        var backdrop = document.getElementById('fc3ColBackdrop');
        if (panel)    panel.classList.remove('open');
        if (backdrop) backdrop.classList.remove('open');
    };

    // Async: server'dan yükle, farklıysa yeniden render
    fetch('/Purchase/GetFlatColConfig')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data || !data.config) return;
            var localJson = localStorage.getItem('fc3-col-flat-v3');
            if (data.config === localJson) return;
            _colDefs = _makeDefaultDefs();
            try { _applyColSaved(JSON.parse(data.config)); } catch(e) {}
            renderList();
        }).catch(function() {});

    // ── Drawer: seçili kalemler tablosu ─────────────────────────────────────
    function renderLines() {
        var tb = document.getElementById('fc3LinesTbody');
        if (!tb) return;
        if (!_lines.length) { tb.innerHTML = '<tr><td colspan="7" style="padding:12px;text-align:center;color:#475569;font-size:.8rem;">Kalem bulunamadı</td></tr>'; return; }
        tb.innerHTML = _lines.map(function(l, i) {
            return '<tr data-item-id="' + l.itemId + '">'
                + '<td style="color:#475569;font-size:.74rem;">' + (i + 1) + '</td>'
                + '<td style="font-family:monospace;font-size:.74rem;color:#818cf8;">' + esc(l.requestNumber || '') + '</td>'
                + '<td style="color:#cbd5e1;">' + esc(l.materialName || l.materialCode || '—') + '</td>'
                + '<td style="text-align:right;font-weight:600;color:#e2e8f0;">' + fmtN(l.quantity) + '</td>'
                + '<td style="color:#94a3b8;font-size:.76rem;">' + esc(l.unitCode || '') + '</td>'
                + '<td style="color:#94a3b8;font-size:.76rem;">' + esc(l.locationName || '') + '</td>'
                + '<td id="stk' + i + '"><span class="fc3-sb fc3-sb--load">yükleniyor…</span></td>'
                + '</tr>';
        }).join('');
    }



    function updTfLoc(itemId, stockRows) {
        var byLoc = {};
        stockRows.forEach(function(r) { if (r.locationId) byLoc[r.locationId] = r; });
        document.querySelectorAll('.fc3-tf-row[data-item-id="' + itemId + '"] .fc3-tf-loc').forEach(function(sel) {
            Array.from(sel.options).forEach(function(opt) {
                if (!opt.value) return;
                var s = byLoc[parseInt(opt.value)];
                if (s) opt.text = opt.text.replace(/ \(.*adet\)$/, '') + ' (' + fmtN(s.balance) + ' adet)';
            });
        });
    }

    function renderTf() {
        var tb = document.getElementById('fc3TfBody');
        if (!tb) return;
        var locOpts = LOCS.map(function(l) { return '<option value="' + l.id + '">' + esc(l.name) + '</option>'; }).join('');
        tb.innerHTML = _lines.map(function(l) {
            return '<tr class="fc3-tf-row" data-item-id="' + l.itemId + '"'
                + ' data-unit-id="'  + (l.unitId || '')     + '"'
                + ' data-to-loc="'   + (l.locationId || '') + '"'
                + ' data-comb-id="'  + (l.combinationId||'') + '">'
                + '<td><input type="checkbox" class="fc3-cb fc3-tf-cb" checked></td>'
                + '<td style="color:#cbd5e1;font-size:.79rem;">' + esc(l.materialName || l.materialCode || '—')
                + '<br><span style="font-family:monospace;font-size:.7rem;color:#6366f1;">' + esc(l.requestNumber) + '</span></td>'
                + '<td style="text-align:right;font-weight:600;color:#e2e8f0;">' + fmtN(l.quantity) + '</td>'
                + '<td><select class="fc3-ts fc3-tf-loc" style="min-width:130px;"><option value="">— Depo Seçin —</option>' + locOpts + '</select></td>'
                + '<td><input type="number" class="fc3-ti fc3-tf-qty" value="' + l.quantity.toFixed(2) + '" min="0.01" step="0.01" style="min-width:65px;text-align:right;"></td>'
                + '<td style="color:#64748b;font-size:.76rem;">' + esc(l.unitCode || '') + '</td>'
                + '</tr>';
        }).join('');
    }

    // ── Panel aç/kapat — action sheet üzerinden (T=Transfer, S=StockIssue, P=PurchaseOrder) ──
    var _PANELS = {
        T: { panelId:'fc3TfPanel', btnId:'fc3BtnT', title:'Depo Transferi',      msgIds:['fc3TfOk','fc3TfErr'] },
        S: { panelId:'fc3SfPanel', btnId:'fc3BtnS', title:'Ambar Çıkış Fişi',    msgIds:['fc3SfOk','fc3SfErr'] },
        P: { panelId:'fc3PrPanel', btnId:'fc3BtnP', title:'Satın Alma Talebi',   msgIds:['fc3PrOk','fc3PrErr'] },
    };
    window.fc3CloseActionSheet = function() {
        var sheet = document.getElementById('fc3ActionSheet');
        if (sheet) sheet.classList.remove('open');
        Object.keys(_PANELS).forEach(function(k) {
            var pb = document.getElementById(_PANELS[k].btnId);
            if (pb) pb.classList.remove('on');
        });
    };
    window.fc3TogglePanel = function(key) {
        var cfg = _PANELS[key]; if (!cfg) return;
        var sheet = document.getElementById('fc3ActionSheet');
        var p = document.getElementById(cfg.panelId);
        var b = document.getElementById(cfg.btnId);
        // Aynı panel açıksa sheet'i kapat (toggle)
        var sheetOpen = sheet && sheet.classList.contains('open');
        var samePanel = sheetOpen && p && p.style.display !== 'none';
        if (samePanel) { fc3CloseActionSheet(); return; }
        // Tüm diğer panelleri gizle
        Object.keys(_PANELS).forEach(function(k) {
            var c = _PANELS[k];
            var pp = document.getElementById(c.panelId);
            var pb = document.getElementById(c.btnId);
            if (pp) pp.style.display = 'none';
            if (pb) pb.classList.remove('on');
        });
        // Bu paneli göster
        if (p) p.style.display = '';
        if (b) b.classList.add('on');
        // Sheet başlığını güncelle ve aç
        var titleEl = document.getElementById('fc3AsTitle');
        if (titleEl) titleEl.textContent = cfg.title;
        if (sheet) sheet.classList.add('open');
        // Mesajları temizle
        cfg.msgIds.forEach(function(id) {
            var el = document.getElementById(id);
            if (el) { el.style.display='none'; el.textContent=''; }
        });
    };
    window.fc3ToggleTf = function() { fc3TogglePanel('T'); };

    // Ambar Çıkış Fişi formu — Transfer ile aynı yapı, Hedef Depo yok
    function renderSf() {
        var tb = document.getElementById('fc3SfBody');
        if (!tb) return;
        var locOpts = LOCS.map(function(l) { return '<option value="' + l.id + '">' + esc(l.name) + '</option>'; }).join('');
        tb.innerHTML = _lines.map(function(l) {
            return '<tr class="fc3-sf-row" data-item-id="' + l.itemId + '"'
                + ' data-unit-id="' + (l.unitId || '') + '"'
                + ' data-comb-id="' + (l.combinationId||'') + '">'
                + '<td><input type="checkbox" class="fc3-cb fc3-sf-cb" checked></td>'
                + '<td style="color:#cbd5e1;font-size:.79rem;">' + esc(l.materialName || l.materialCode || '—')
                + '<br><span style="font-family:monospace;font-size:.7rem;color:#fbbf24;">' + esc(l.requestNumber) + '</span></td>'
                + '<td style="text-align:right;font-weight:600;color:#e2e8f0;">' + fmtN(l.quantity) + '</td>'
                + '<td><select class="fc3-ts fc3-sf-loc" style="min-width:130px;"><option value="">— Depo Seçin —</option>' + locOpts + '</select></td>'
                + '<td><input type="number" class="fc3-ti fc3-sf-qty" value="' + l.quantity.toFixed(2) + '" min="0.01" step="0.01" style="min-width:65px;text-align:right;"></td>'
                + '<td style="color:#64748b;font-size:.76rem;">' + esc(l.unitCode || '') + '</td>'
                + '</tr>';
        }).join('');
    }

    // Satın Alma Talebi formu
    function renderPr() {
        var tb = document.getElementById('fc3PrBody');
        if (!tb) return;
        tb.innerHTML = _lines.map(function(l) {
            var remain = Math.max(0, l.quantity - (l.fulfilledFromStock||0) - (l.fulfilledByPurchase||0));
            return '<tr class="fc3-pr-row" data-item-id="' + l.itemId + '"'
                + ' data-unit-id="' + (l.unitId || '') + '"'
                + ' data-comb-id="' + (l.combinationId||'') + '"'
                + ' data-line-id="' + (l.lineId||'') + '">'
                + '<td><input type="checkbox" class="fc3-cb fc3-pr-cb" checked></td>'
                + '<td style="color:#cbd5e1;font-size:.79rem;">' + esc(l.materialName || l.materialCode || '—')
                + '<br><span style="font-family:monospace;font-size:.7rem;color:#6ee7b7;">' + esc(l.requestNumber) + '</span></td>'
                + '<td style="text-align:right;font-weight:600;color:#e2e8f0;">' + fmtN(l.quantity) + '</td>'
                + '<td style="text-align:right;color:' + (remain > 0 ? '#fbbf24' : '#34d399') + ';font-weight:600;">' + fmtN(remain) + '</td>'
                + '<td><input type="number" class="fc3-ti fc3-pr-qty" value="' + remain.toFixed(2) + '" min="0.01" step="0.01" style="min-width:65px;text-align:right;"></td>'
                + '<td style="color:#64748b;font-size:.76rem;">' + esc(l.unitCode || '') + '</td>'
                + '<td><input type="text" class="fc3-ti fc3-pr-note" placeholder="Not…" style="min-width:100px;"></td>'
                + '</tr>';
        }).join('');
    }

    window.fc3CreateTransfer = function() {
        var btn = document.getElementById('fc3TfSubmit');
        var ok  = document.getElementById('fc3TfOk');
        var err = document.getElementById('fc3TfErr');
        ok.style.display = err.style.display = 'none';
        var lines = [];
        document.querySelectorAll('.fc3-tf-row').forEach(function(tr, idx) {
            var cb  = tr.querySelector('.fc3-tf-cb');
            if (!cb || !cb.checked) return;
            var sel = tr.querySelector('.fc3-tf-loc');
            var qty = tr.querySelector('.fc3-tf-qty');
            var loc = sel ? parseInt(sel.value) : 0;
            var q   = qty ? parseFloat(qty.value.replace(',', '.')) : 0;
            if (!loc || q <= 0) return;
            var l = _lines[idx];
            if (!l) return;
            lines.push({ itemId:l.itemId, unitId:l.unitId||null, qty:q,
                         fromLocationId:loc, toLocationId:l.locationId||null,
                         combinationId:l.combinationId||null, notes:null,
                         requestLineId:l.lineId||null });
        });
        if (!lines.length) { err.textContent='Lütfen en az bir kalem seçin ve kaynak depoyu belirtin.'; err.style.display='block'; return; }
        if (btn) btn.disabled = true;
        fetch('/Purchase/CreateTransfer', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ requestIds:Array.from(new Set(Object.values(_lineSel).map(function(v){return v.docId;}))), notes:(document.getElementById('fc3TfNotes')||{}).value||null, lines:lines }),
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (btn) btn.disabled = false;
            if (d.ok) { ok.textContent='✔ Transfer oluşturuldu: ' + d.docNo; ok.style.display='block'; }
            else       { err.textContent='✖ ' + (d.error||'Hata'); err.style.display='block'; }
        })
        .catch(function() { if (btn) btn.disabled=false; err.textContent='✖ Bağlantı hatası'; err.style.display='block'; });
    };

