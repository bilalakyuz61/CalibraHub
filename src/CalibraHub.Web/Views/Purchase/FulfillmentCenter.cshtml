            if (d.ok) { ok.textContent='✔ Ambar çıkış fişi oluşturuldu: ' + d.docNo; ok.style.display='block'; invalidateDocCache(); }
            else       { err.textContent='✖ ' + (d.error||'Hata'); err.style.display='block'; }
