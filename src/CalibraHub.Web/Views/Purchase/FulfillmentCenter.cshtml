</div>

@section Scripts {
<script>
(function() {
    var ALL  = @Html.Raw(requestsJson);
    var LOCS = @Html.Raw(locsJson);
    var PENDING_APPROVAL_IDS = new Set(@Html.Raw(pendingApprovalIdsJson));

    // ── Grup haritaları: contactId/docId → grup adı(ları) ───────────────────
    var CONTACT_GROUP_MAP = @Html.Raw(contactGroupMapJson);  // { "123": "Toptan" }
    var ITEM_GROUP_MAP    = @Html.Raw(itemGroupMapJson);     // { "5": ["Elektronik","A Grubu"] }

    // ── Widget tanımları + değerleri ─────────────────────────────────────────
    var WIDGET_DEFS  = @Html.Raw(widgetDefsJson);       // [{id,label,dataType,level}]
    var MASTER_WVAL  = @Html.Raw(masterWidgetValJson);  // {"42":{"w_dept":"Üretim",...}}
    var LINE_WVAL    = @Html.Raw(lineWidgetValJson);     // {"42":{"w_cat":["Elm","Mek"]}}
    var MATERIAL_MAP = @Html.Raw(materialMapJson);       // {"42":[{code,name,hasStock}]}

    // ALL kayıtlarına grup + widget bilgisini merge et
    ALL.forEach(function(r) {
        var k = String(r.id);
        if (r.contactId && CONTACT_GROUP_MAP) {
            var cg = CONTACT_GROUP_MAP[String(r.contactId)];
            if (cg) r.contactGroupName = cg;
        }
        if (ITEM_GROUP_MAP) {
            var ig = ITEM_GROUP_MAP[k];
            if (ig && ig.length) r.itemGroupNames = ig;
        }
        if (MASTER_WVAL && MASTER_WVAL[k]) r.mw = MASTER_WVAL[k];
        if (LINE_WVAL   && LINE_WVAL[k])   r.lw = LINE_WVAL[k];
        if (MATERIAL_MAP) {
            var mm = MATERIAL_MAP[k];
            if (mm && mm.length) r.materialItems = mm;
        }
    });

    // ── Widget değer çıkarma yardımcıları ────────────────────────────────────
    function wdgStrings(val) {
        // object? → string[] (WidgetRenderDto.Value çeşitleri: string, bool, number, string[])
        if (val == null) return [];
        if (Array.isArray(val)) return val.map(String).filter(Boolean);
        if (typeof val === 'boolean') return [val ? 'Evet' : 'Hayır'];
        var s = String(val).trim();
        return s ? [s] : [];
    }
    function wdgValuesForRecord(r, wd) {
        if (wd.level === 'master') return wdgStrings((r.mw || {})[wd.id]);
        return ((r.lw || {})[wd.id]) || [];
    }

    var S_DOT = { Draft:'#64748b', Sent:'#60a5fa', Approved:'#34d399',
                  Rejected:'#f87171', Cancelled:'#475569', Closed:'#818cf8' };

    var _vis = [], _lines = [], _stock = {}, _tmr = null;
    var _docLineCache   = {};  // { docId: [...] }   — kalemler
    var _globalStockMap = {};  // { itemId: [...] }  — stok
    var _lineSel        = {};  // { lineId: { docId, itemId } }
    var _collapsedGroups = {}; // { gpath: true }     — katlanmış grup yolları

    // ── Filtre Drawer aç/kapat ──────────────────────────────────────────────
    window.fc3OpenDrawer = function() {
        document.getElementById('fc3Backdrop').classList.add('open');
        document.getElementById('fc3Drawer').classList.add('open');
    };
    window.fc3CloseDrawer = function() {
        document.getElementById('fc3Drawer').classList.remove('open');
        document.getElementById('fc3Backdrop').classList.remove('open');
    };
    window.fc3BackdropClick = function() {
        document.getElementById('fc3Drawer').classList.remove('open');
        document.getElementById('fc3Backdrop').classList.remove('open');
    };
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') fc3CloseDrawer(); });

    // ── Dropdown accordion (Talep Eden / Durum) ───────────────────────────────
    window.fc3ToggleDd = function(id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.classList.toggle('open');
    };

    // ── Tarih operatör değişimi ───────────────────────────────────────────────
    window.fc3DateOpChange = function(sel) {
        var row = sel.closest('tr');
        var sep = row.querySelector('.fc3-date-sep');
        var d2  = row.querySelector('.fc3-date-2');
        var between = sel.value === 'between';
        if (sep) sep.style.visibility = between ? 'visible' : 'hidden';
        if (d2)  d2.style.visibility  = between ? 'visible' : 'hidden';
        if (!between && d2) d2.value = '';
        applyFilters();
    };

    // ── Durum checkbox listesi ────────────────────────────────────────────────
    var STAT_ITEMS = [
        { val: 'Draft',     label: 'Taslak',          dot: '#64748b' },
        { val: 'Sent',      label: 'Onay Bekliyor',   dot: '#60a5fa' },
        { val: 'Approved',  label: 'Onaylı',           dot: '#34d399' },
