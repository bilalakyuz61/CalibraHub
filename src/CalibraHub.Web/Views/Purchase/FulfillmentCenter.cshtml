        var html = '<label class="fc3-ms-opt"><input type="checkbox" class="fc3-cb fc3-ms-cb-stat" value="__all__"'
            + (!hasSpecific ? ' checked' : '') + ' onchange="fc3StatChange(this)"> Tümü</label>';
