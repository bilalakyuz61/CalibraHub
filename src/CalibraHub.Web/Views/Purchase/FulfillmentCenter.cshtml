    window.fc3CreatePurchaseOrder = function() {
        var btn = document.getElementById('fc3PrSubmit');
        var ok  = document.getElementById('fc3PrOk');
        var err = document.getElementById('fc3PrErr');
        ok.style.display = err.style.display = 'none';
        var lines = [];
        document.querySelectorAll('.fc3-pr-row').forEach(function(tr, idx) {
            var cb  = tr.querySelector('.fc3-pr-cb');
            if (!cb || !cb.checked) return;
            var qty  = tr.querySelector('.fc3-pr-qty');
            var note = tr.querySelector('.fc3-pr-note');
            var q    = qty ? parseFloat(qty.value.replace(',','.')) : 0;
            if (q <= 0) return;
            var l = _lines[idx]; if (!l) return;
            lines.push({ itemId:l.itemId, unitId:l.unitId||null, qty:q,
                         combinationId:l.combinationId||null,
                         notes:(note ? note.value : null) || null,
                         requestLineId:l.lineId||null });
        });
        if (!lines.length) { err.textContent='Lütfen en az bir kalem seçin.'; err.style.display='block'; return; }
        if (btn) btn.disabled = true;
        fetch('/Purchase/CreatePurchaseOrderFromIhtiyac', {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ requestIds:Array.from(new Set(Object.values(_lineSel).map(function(v){return v.docId;}))), notes:(document.getElementById('fc3PrNotes')||{}).value||null, contactId:null, lines:lines }),
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (btn) btn.disabled = false;
            if (d.ok) {
                ok.innerHTML = '✔ Satın alma talebi oluşturuldu: <a href="/Purchase/Edit?id=' + d.docId + '" target="_blank" style="color:#6ee7b7;">' + esc(d.docNo) + '</a>';
                ok.style.display = 'block';
                invalidateDocCache();
            } else {
                err.textContent = '✖ ' + (d.error||'Hata');
                err.style.display = 'block';
            }
        })
        .catch(function() { if (btn) btn.disabled=false; err.textContent='✖ Bağlantı hatası'; err.style.display='block'; });
    };

    window.fc3CloseRequests = function() {
        var ids = Array.from(new Set(Object.values(_lineSel).map(function(v) { return v.docId; })));
        if (!ids.length) return;
        var names = ids.map(function(id) {
            var r = ALL.find(function(x) { return x.id === id; });
            return r ? r.documentNumber : '#' + id;
        }).join(', ');
        showConfirm({
            title:   'İhtiyaç Kaydı Kapatılacak',
            message: 'Seçili ' + ids.length + ' ihtiyaç kaydı kapatılacak:\n' + names + '\n\nBu işlem geri alınamaz. Devam edilsin mi?',
            okLabel: 'Kapat',
        }).then(function(ok) {
            if (!ok) return;
            fetch('/Purchase/CloseRequests', {
                method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ requestIds:ids }),
            })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.ok || (d.closed && d.closed.length > 0)) {
                    var msg = (d.closed||[]).length + ' kayıt kapatıldı.' + (d.errors&&d.errors.length ? ' Hatalar: '+d.errors.join(', ') : '');
                    CalibraAlert.show(msg, { type: 'success', autoDismissMs: 2500 });
                    setTimeout(function() { window.location.reload(); }, 1800);
                } else {
                    CalibraAlert.show('Kapatma başarısız: ' + (d.errors||[]).join(', '), { type: 'error' });
                }
            })
            .catch(function() { CalibraAlert.show('Bağlantı hatası.', { type: 'error' }); });
        });
    };

    function invalidateDocCache() {
        _docLineCache   = {};
        _globalStockMap = {};
        loadAllLines();
    }

    // ── Yardımcılar ──────────────────────────────────────────────────────────
    function fmtN(n) { return parseFloat(n||0).toLocaleString('tr-TR',{minimumFractionDigits:2,maximumFractionDigits:2}); }
    function fmtDate(iso) {
        if (!iso) return '';
        var d = new Date(iso);
        return d.getDate().toString().padStart(2,'0')+'.'+(d.getMonth()+1).toString().padStart(2,'0')+'.'+d.getFullYear();
    }
    function esc(s) {
        return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Widget labelId haritası (reset için) ─────────────────────────────────
    var _wdgLblIds = {};  // { widgetId → lblElementId }

    // ── Grup chip yardımcı: dinamik chip oluştur + click handler bağla ───────
    function renderGrpChips(containerId, values, cbClass, lblId) {
        var cont = document.getElementById(containerId);
        if (!cont || !values.length) return;
        cont.innerHTML = values.map(function(name) {
            var safe = esc(name);
            return '<label class="fc3-ms-chip" data-val="' + safe + '">'
                + '<input type="checkbox" class="fc3-ms-cb ' + cbClass + '" value="' + safe + '" style="display:none;">'
                + safe + '</label>';
        }).join('');
        cont.querySelectorAll('.fc3-ms-chip').forEach(function(chip) {
            chip.addEventListener('click', function() {
                var cb = chip.querySelector('input');
                if (!cb) return;
                cb.checked = !cb.checked;
                chip.classList.toggle('active', cb.checked);
                var sel = document.querySelectorAll('.' + cbClass + ':checked');
                var lbl = document.getElementById(lblId);
                if (lbl) lbl.textContent = sel.length ? sel.length + ' seçili' : 'herhangi biri';
                applyFilters();
            });
        });
    }

    // ── Init ─────────────────────────────────────────────────────────────────
    // Metin/sayı/tarih filtrelerinde event
    document.querySelectorAll('.fc3-ftbl .fc3-fv,.fc3-ftbl .fc3-fop').forEach(function(el) {
        el.addEventListener('input',  applyFilters);
        el.addEventListener('change', applyFilters);
    });

    renderReqList('');             // Talep eden listesi ilk yükleme
    renderStatList(['Approved']);  // Durum: Onaylı varsayılan seçili
    _updateStatLbl();

    // Cari grubu chip'leri — veri varsa section'ı göster
    var _cariGrpAll = (function() {
        var set = new Set();
        ALL.forEach(function(r) { if (r.contactGroupName) set.add(r.contactGroupName); });
        return Array.from(set).sort(function(a, b) { return a.localeCompare(b, 'tr'); });
    })();
    if (_cariGrpAll.length) {
        var cgSect = document.getElementById('fc3CariGrpSect');
        if (cgSect) cgSect.style.display = '';
        renderGrpChips('fc3MsCgChips', _cariGrpAll, 'fc3-ms-cb-cg', 'fc3CgLbl');
    }

    // Kalem grubu chip'leri — veri varsa section'ı göster
    var _kalemGrpAll = (function() {
        var set = new Set();
        ALL.forEach(function(r) { (r.itemGroupNames || []).forEach(function(g) { set.add(g); }); });
        return Array.from(set).sort(function(a, b) { return a.localeCompare(b, 'tr'); });
    })();
    if (_kalemGrpAll.length) {
        var kgSect = document.getElementById('fc3KalemGrpSect');
        if (kgSect) kgSect.style.display = '';
        renderGrpChips('fc3MsKgChips', _kalemGrpAll, 'fc3-ms-cb-kg', 'fc3KgLbl');
    }

    // ── Stok durumu chip click ────────────────────────────────────────────────
    document.querySelectorAll('#fc3StockChips .fc3-ms-chip').forEach(function(chip) {
        chip.addEventListener('click', function() {
            var cb = chip.querySelector('.fc3-ms-cb-stock');
            if (!cb) return;
            cb.checked = !cb.checked;
            chip.classList.toggle('active', cb.checked);
            var sel = Array.from(document.querySelectorAll('.fc3-ms-cb-stock:checked'));
            var lbl = document.getElementById('fc3StockLbl');
            if (lbl) lbl.textContent = sel.length ? sel.length + ' seçili' : 'herhangi biri';
            applyFilters();
        });
    });

    // ── Widget filtre section'ları (dinamik) ─────────────────────────────────
    var _wdgContainer = document.getElementById('fc3WdgSects');
    if (_wdgContainer) {
        (WIDGET_DEFS || []).forEach(function(wd) {
            // Bu widget için tüm kayıtlardan benzersiz değerleri topla
            var valueSet = new Set();
            ALL.forEach(function(r) {
                wdgValuesForRecord(r, wd).forEach(function(v) { if (v) valueSet.add(v); });
            });
            var values = Array.from(valueSet).sort(function(a, b) { return a.localeCompare(b, 'tr'); });
            if (!values.length) return;  // Bu widget için veri yok, section ekleme

            // Benzersiz element id'leri
            var safeId  = wd.id.replace(/[^a-zA-Z0-9_-]/g, '_');
            var secId   = 'fc3WdgSect_'  + safeId;
            var lblId   = 'fc3WdgLbl_'   + safeId;
            var chpId   = 'fc3WdgChp_'   + safeId;
            var levelTx = wd.level === 'line' ? ' <span style="font-size:.65rem;padding:1px 5px;border-radius:999px;background:rgba(99,102,241,.15);color:#818cf8;font-weight:400;letter-spacing:0;text-transform:none;">kalem</span>' : '';

            _wdgLblIds[wd.id] = lblId;  // reset için kaydet

            var sect = document.createElement('div');
            sect.className = 'fc3-filt-sect';
            sect.id = secId;
            sect.innerHTML =
                '<div class="fc3-filt-sect-lbl">'
                    + '<span>' + esc(wd.label) + levelTx + '</span>'
                    + '<small id="' + lblId + '">herhangi biri</small>'
                + '</div>'
                + '<div class="fc3-ms-chips" id="' + chpId + '"></div>';
            _wdgContainer.appendChild(sect);

            // Chip'leri doldur + click handler
            var chipCont = document.getElementById(chpId);
            if (!chipCont) return;
            chipCont.innerHTML = values.map(function(name) {
                var safe = esc(name);
                return '<label class="fc3-ms-chip">'
                    + '<input type="checkbox" class="fc3-ms-cb fc3-ms-cb-wdg" data-wdg="' + esc(wd.id) + '" value="' + safe + '" style="display:none;">'
                    + safe + '</label>';
            }).join('');
            chipCont.querySelectorAll('.fc3-ms-chip').forEach(function(chip) {
                chip.addEventListener('click', function() {
                    var cb = chip.querySelector('input');
                    if (!cb) return;
                    cb.checked = !cb.checked;
                    chip.classList.toggle('active', cb.checked);
                    var sel = chipCont.querySelectorAll('.fc3-ms-cb-wdg:checked');
                    var lbl = document.getElementById(lblId);
                    if (lbl) lbl.textContent = sel.length ? sel.length + ' seçili' : 'herhangi biri';
                    applyFilters();
                });
            });
        });
    }

    applyFilters();    // İlk render (filtre state'ini _vis'e yaz)
    loadAllLines();    // Tüm kalemleri paralel fetch et, sonra renderList()
})();
</script>
}
