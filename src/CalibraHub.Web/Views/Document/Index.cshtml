        var iconHtml;
        if (state === 'loading') {
            iconHtml = '<div class="dt-toast-icon"><div class="dt-toast-spinner"></div></div>';
        } else if (state === 'ok') {
            iconHtml = '<div class="dt-toast-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>';
        } else {
            iconHtml = '<div class="dt-toast-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div>';
        }
        card.innerHTML = iconHtml +
            '<div class="dt-toast-body">' +
                '<div class="dt-toast-title">' + esc(title) + '</div>' +
                (sub ? '<div class="dt-toast-sub">' + esc(sub) + '</div>' : '') +
            '</div>';
        bd.appendChild(card);
        document.body.appendChild(bd);
        // Esc ile kapat
        bd.addEventListener('click', function (e) {
