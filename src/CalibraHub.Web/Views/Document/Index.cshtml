                  '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' +
                '</div>' +
                '<div style="flex:1;min-width:0;">' +
                  '<div style="font-size:1rem;font-weight:600;color:#e2e8f0;">Onizleme</div>' +
                  '<div style="font-size:.78rem;color:#94a3b8;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(templateName || '') + '</div>' +
                '</div>' +
                '<label style="display:flex;align-items:center;gap:6px;font-size:.78rem;color:#cbd5e1;">' +
                  'Test ID:' +
                  '<input type="number" min="1" value="1" data-role="rid" style="width:80px;padding:6px 10px;background:#0a0d17;border:1px solid #3a3f5a;border-radius:6px;color:#e2e8f0;font-size:.85rem;" />' +
                  '<button type="button" data-role="load" style="padding:6px 12px;background:rgba(6,182,212,.15);border:1px solid rgba(6,182,212,.3);border-radius:6px;color:#67e8f9;cursor:pointer;font-size:.8rem;">Yukle</button>' +
                '</label>' +
                '<button type="button" data-role="close" title="Kapat" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);border-radius:6px;color:#fca5a5;cursor:pointer;width:36px;height:36px;display:flex;align-items:center;justify-content:center;">' +
                  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                '</button>' +
              '</div>' +
              '<iframe data-role="frame" style="flex:1;min-height:0;width:100%;border:1px solid #3a3f5a;border-radius:10px;background:#0a0d17;" sandbox="allow-same-origin allow-scripts allow-forms"></iframe>' +
            '</div>';
        // Light tema uyumu
        if (document.body.classList.contains('app-theme-light')) {
            var card = bd.firstElementChild;
            card.style.background = '#ffffff';
            card.style.borderColor = '#e2e8f0';
            var title = card.querySelector('div > div > div:first-child');
            if (title) title.style.color = '#1f2937';
        }
        document.body.appendChild(bd);

        var ridInp = bd.querySelector('[data-role=rid]');
        var loadBtn = bd.querySelector('[data-role=load]');
        var closeBtn = bd.querySelector('[data-role=close]');
        var frame = bd.querySelector('[data-role=frame]');

        function load() {
            var rid = parseInt(ridInp.value, 10);
            if (!rid || rid < 1) { ridInp.focus(); return; }
            // Iframe URL'si adresi — ana sayfa URL'i degismez, sadece iframe degisir
            frame.src = '/Document/Preview/' + templateId + '/' + rid;
        }
        function close() { try { bd.remove(); } catch (e) {} document.removeEventListener('keydown', onKey); }
        var onKey = function (e) { if (e.key === 'Escape') close(); };

        loadBtn.onclick = load;
        closeBtn.onclick = close;
        ridInp.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); load(); } });
        document.addEventListener('keydown', onKey);
        // Ilk yuklemede default 1 ile dene
        load();
        setTimeout(function () { ridInp.focus(); ridInp.select(); }, 50);
    };

    // ── Data Source yonetim modali ─────────────────────────────────
    window.dtManageSources = async function (templateId, templateName, docTypeId) {
        var existing = document.getElementById('dtSourcesModal');
        if (existing) existing.remove();

        // Mevcut source'lari + kullanilabilir view listesini + belge tipinin required key'ini fetch et
        var sources = [];
        var availableViews = [];
        var requiredKey = '';
        try {
            var [srcResp, viewResp, dtResp] = await Promise.all([
                fetch('/Document/Sources/' + templateId,                 { credentials: 'same-origin' }),
                fetch('/Document/AvailableViews',                        { credentials: 'same-origin' }),
                fetch('/Document/DocumentTypeView/' + (docTypeId || selectedTypeId), { credentials: 'same-origin' })
            ]);
            sources        = await srcResp.json()  || [];
            var vjson      = await viewResp.json();
            var djson      = await dtResp.json();
            availableViews = (vjson && vjson.success) ? (vjson.views || []) : [];
            requiredKey    = (djson && djson.success) ? (djson.requiredKey || '') : '';
        } catch (e) { /* sessiz */ }

        var bd = document.createElement('div');
        bd.id = 'dtSourcesModal';
        bd.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(6px);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;';

        var isLight = document.body.classList.contains('app-theme-light');
        var cardBg  = isLight ? '#ffffff' : 'linear-gradient(135deg,#15182b 0%,#1a1e35 100%)';
        var borderC = isLight ? '#e2e8f0' : '#3a3f5a';
        var textC   = isLight ? '#1f2937' : '#e2e8f0';
        var softC   = isLight ? '#64748b' : '#94a3b8';
        var inputBg = isLight ? '#f8fafc' : '#0a0d17';

        bd.innerHTML =
            '<div style="background:' + cardBg + ';border:1px solid ' + borderC + ';border-radius:14px;padding:18px;max-width:520px;width:100%;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.5);">' +
              '<div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;padding-bottom:10px;border-bottom:1px solid ' + borderC + ';">' +
                '<div style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:8px;background:rgba(6,182,212,.15);color:#67e8f9;">' +
                  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 11v6c0 1.66 4 3 9 3s9-1.34 9-3v-6"/></svg>' +
                '</div>' +
                '<div style="flex:1;min-width:0;">' +
                  '<div style="font-size:.95rem;font-weight:600;color:' + textC + ';">Data Source\'lar</div>' +
                  '<div style="font-size:.72rem;color:' + softC + ';white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(templateName || '') + '</div>' +
                '</div>' +
                '<button type="button" data-role="close" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);border-radius:6px;color:#fca5a5;cursor:pointer;width:30px;height:30px;display:flex;align-items:center;justify-content:center;">' +
                  '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                '</button>' +
              '</div>' +
              (requiredKey
                ? '<div style="padding:8px 12px;margin-bottom:10px;border-radius:6px;font-size:.74rem;' +
                  'background:rgba(6,182,212,.08);border:1px solid rgba(6,182,212,.25);color:' + (isLight?'#0e7490':'#67e8f9') + ';">' +
                  'Beklenen anahtar kolon: <code style="background:rgba(6,182,212,.15);padding:1px 7px;border-radius:4px;">' + esc(requiredKey) + '</code>' +
                  '</div>'
                : '') +
              '<div data-role="rows" style="flex:1;min-height:0;overflow:auto;display:flex;flex-direction:column;gap:8px;"></div>' +
              '<div style="display:flex;gap:8px;margin-top:10px;padding-top:10px;border-top:1px solid ' + borderC + ';">' +
                '<button type="button" data-role="add" style="padding:7px 12px;background:rgba(6,182,212,.1);border:1px solid rgba(6,182,212,.3);border-radius:6px;color:#67e8f9;cursor:pointer;font-size:.8rem;">+ Ekle</button>' +
                '<div style="flex:1;"></div>' +
                '<button type="button" data-role="cancel" style="padding:7px 14px;background:transparent;border:1px solid ' + borderC + ';border-radius:6px;color:' + softC + ';cursor:pointer;font-size:.8rem;">Iptal</button>' +
                '<button type="button" data-role="save" style="padding:7px 18px;background:linear-gradient(135deg,#06b6d4,#0891b2);border:none;border-radius:6px;color:#fff;cursor:pointer;font-size:.8rem;font-weight:600;">Kaydet</button>' +
              '</div>' +
            '</div>';

        document.body.appendChild(bd);

        var rowsEl = bd.querySelector('[data-role=rows]');
        var state  = []; // each: {sourceName, viewName, compatible}

        // View kolonlarini cache'le
        var viewColumnsCache = {};
        function fetchViewColumns(view) {
            if (!view) return Promise.resolve([]);
            if (viewColumnsCache[view]) return Promise.resolve(viewColumnsCache[view]);
            return fetch('/Document/ViewColumns/' + encodeURIComponent(view), { credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    var cols = (d && d.success && Array.isArray(d.columns)) ? d.columns : [];
                    viewColumnsCache[view] = cols;
                    return cols;
                })
                .catch(function () { return []; });
        }

        function renderRows() {
            rowsEl.innerHTML = '';
            state.forEach(function (s, i) { rowsEl.appendChild(buildRow(s, i)); });
            if (state.length === 0) {
                rowsEl.innerHTML = '<div style="padding:30px;text-align:center;color:' + softC + ';font-style:italic;border:1px dashed ' + borderC + ';border-radius:10px;">Henuz data source yok. Yukaridaki <strong>+ Data Source Ekle</strong> butonu ile ekleyin.</div>';
            }
            updateAddButtonState();
        }

        // "+ Data Source Ekle" butonunun aktifligini guncelle
        function updateAddButtonState() {
            var addBtn = bd.querySelector('[data-role=add]');
            if (!addBtn) return;
            // Son satirdaki view secilmis ve uyumlu olmali (veya hic satir yoksa aktif)
            var canAdd = state.length === 0 ||
                (state[state.length - 1].viewName && state[state.length - 1].compatible);
            addBtn.disabled = !canAdd;
            addBtn.style.opacity = canAdd ? '1' : '.45';
            addBtn.style.cursor  = canAdd ? 'pointer' : 'not-allowed';
            addBtn.title = canAdd
                ? 'Yeni data source satiri ekle'
                : 'Once mevcut satirda uyumlu bir view secmelisiniz';
        }

        // Diger satirlardaki secili view adlari (duplicate engelleme icin)
        function otherChosenViews(exceptIdx) {
            var s = new Set();
            state.forEach(function (x, i) { if (i !== exceptIdx && x.viewName) s.add(x.viewName.toLowerCase()); });
            return s;
        }

        // Source adi = view adi (kullanicinin istegi dogrultusunda). Frx'te [vw_X.Y] olarak kullanilir.
        function autoSourceName(viewName, isPrimary) {
            return viewName || '';
        }

        function buildRow(s, idx) {
            var row = document.createElement('div');
            row.style.cssText = 'border:1px solid ' + borderC + ';border-radius:8px;padding:10px;background:' + inputBg + ';display:flex;flex-direction:column;gap:8px;';
            // Duplicate engelleme: diger satirlardaki secili view'lari dropdown'dan gizle
            var usedByOthers = otherChosenViews(idx);
            var viewOpts = '<option value="">— View Secin —</option>' +
                availableViews
                    .filter(function (v) { return v === s.viewName || !usedByOthers.has(v.toLowerCase()); })
                    .map(function (v) { return '<option value="' + esc(v) + '"' + (v === s.viewName ? ' selected' : '') + '>' + esc(v) + '</option>'; })
                    .join('');

            var selStyle = 'width:100%;padding:7px 10px;background:' + (isLight?'#fff':'#15182b') + ';border:1px solid ' + borderC + ';border-radius:6px;color:' + textC + ';font-size:.82rem;transition:border-color .15s,box-shadow .15s;';
            var labelStyle = 'font-size:.7rem;font-weight:600;color:' + softC + ';margin-bottom:3px;display:block;';

            row.innerHTML =
                '<div style="display:grid;grid-template-columns:28px 1fr auto;gap:10px;align-items:center;">' +
                    '<div style="display:flex;align-items:center;justify-content:center;font-size:.78rem;font-weight:600;color:' + softC + ';">' + (idx + 1) + '</div>' +
                    '<select data-f="view" class="dt-src-view" style="' + selStyle + '">' + viewOpts + '</select>' +
                    '<button type="button" data-f="remove" title="Sil" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);border-radius:6px;color:#fca5a5;cursor:pointer;width:30px;height:30px;display:flex;align-items:center;justify-content:center;">' +
                      '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                    '</button>' +
                '</div>' +
                '<div data-f="sort-wrap" style="display:none;grid-template-columns:28px 1fr 130px;gap:10px;align-items:end;padding-top:2px;">' +
                    '<div></div>' +
                    '<div>' +
                        '<label style="' + labelStyle + '">Siralama kolonu</label>' +
                        '<select data-f="sortcol" style="' + selStyle + '"><option value="">— Siralama yok —</option></select>' +
                    '</div>' +
                    '<div>' +
                        '<label style="' + labelStyle + '">Yon</label>' +
                        '<select data-f="sortdir" style="' + selStyle + '">' +
                            '<option value="ASC">Artan (ASC)</option>' +
                            '<option value="DESC">Azalan (DESC)</option>' +
                        '</select>' +
                    '</div>' +
                '</div>';

            var selView    = row.querySelector('[data-f=view]');
            var btnRem     = row.querySelector('[data-f=remove]');
            var sortWrap   = row.querySelector('[data-f=sort-wrap]');
            var sortColSel = row.querySelector('[data-f=sortcol]');
            var sortDirSel = row.querySelector('[data-f=sortdir]');

            // Source adi = view adi (backend'e boyle gonderilir)
            function refreshIdent(viewName) {
                s.sourceName = viewName || '';
            }

            function triggerShake() {
                selView.classList.remove('dt-shake-red');
                void selView.offsetWidth;
                selView.classList.add('dt-shake-red');
                setTimeout(function () { selView.classList.remove('dt-shake-red'); }, 450);
            }

            // View kolonlarini sort dropdown'a doldur ve siralama bolumunu goster
            function loadSortColumns(view) {
                if (!view) {
                    sortWrap.style.display = 'none';
                    return;
                }
                fetchViewColumns(view).then(function (cols) {
                    var optsHtml = '<option value="">— Siralama yok —</option>';
                    cols.forEach(function (c) {
                        optsHtml += '<option value="' + esc(c) + '"' + (c === s.sortColumn ? ' selected' : '') + '>' + esc(c) + '</option>';
                    });
                    sortColSel.innerHTML = optsHtml;
                    sortDirSel.value = (s.sortDirection || 'ASC').toUpperCase() === 'DESC' ? 'DESC' : 'ASC';
                    sortWrap.style.display = 'grid';
                });
            }

            function updateCompat(view) {
                if (!view) {
                    s.compatible = false;
                    sortWrap.style.display = 'none';
                    updateAddButtonState();
                    return;
                }
                if (!requiredKey) {
                    s.compatible = true;
                    loadSortColumns(view);
                    updateAddButtonState();
                    return;
                }
                fetchViewColumns(view).then(function (cols) {
                    var has = cols.some(function (c) { return c.toLowerCase() === requiredKey.toLowerCase(); });
                    if (has) {
                        s.compatible = true;
                        loadSortColumns(view);
                    } else {
                        s.compatible = false;
                        sortWrap.style.display = 'none';
                        triggerShake();
                        s.viewName = '';
                        s.sortColumn = '';
                        s.sortDirection = 'ASC';
                        refreshIdent('');
                        selView.value = '';
                    }
                    updateAddButtonState();
                });
            }

            if (s.viewName) updateCompat(s.viewName);

            selView.onchange = function () {
                s.viewName = selView.value;
                // View degistiginde eski sort secimi gecersiz; resetle
                s.sortColumn = '';
                s.sortDirection = 'ASC';
                refreshIdent(s.viewName);
                updateCompat(s.viewName);
            };
            sortColSel.onchange = function () { s.sortColumn    = sortColSel.value; };
            sortDirSel.onchange = function () { s.sortDirection = sortDirSel.value; };
            btnRem.onclick = function () {
                state.splice(idx, 1);
                renderRows();
            };

            refreshIdent(s.viewName);

            return row;
        }

        // Mevcut source'lari state'e yukle (ordered)
        if (Array.isArray(sources) && sources.length > 0) {
            // Primary'yi en basa al (DisplayOrder genelde zaten dogru; ekstra koruma)
            var ordered = sources.slice().sort(function (a, b) {
                if (a.isPrimary !== b.isPrimary) return a.isPrimary ? -1 : 1;
                return (a.displayOrder || 0) - (b.displayOrder || 0);
            });
            ordered.forEach(function (s) {
                state.push({
                    sourceName:    s.sourceName || '',
                    viewName:      s.viewName || '',
                    sortColumn:    s.sortColumn || '',
                    sortDirection: s.sortDirection || 'ASC',
                    compatible:    true,
                });
            });
        } else {
            // Default: tek source (Belge primary)
            state.push({ sourceName: 'Belge', viewName: '', sortColumn: '', sortDirection: 'ASC', compatible: false });
        }
        renderRows();

        bd.querySelector('[data-role=add]').onclick = function () {
            // Disabled kontrolu (updateAddButtonState bunu ayarliyor)
            if (this.disabled) return;
            state.push({ sourceName: '', viewName: '', sortColumn: '', sortDirection: 'ASC', compatible: false });
            renderRows();
        };

        function close() { try { bd.remove(); } catch (e) {} document.removeEventListener('keydown', onKey); }
        var onKey = function (e) { if (e.key === 'Escape') close(); };
        document.addEventListener('keydown', onKey);

        bd.querySelector('[data-role=close]').onclick  = close;
        bd.querySelector('[data-role=cancel]').onclick = close;
        bd.querySelector('[data-role=save]').onclick   = function () {
            if (state.length === 0) {
                dtShowToast('err', 'En az bir source', 'Lutfen en az bir data source ekleyin.'); setTimeout(dtHideToast, 3500); return;
            }
            for (var i = 0; i < state.length; i++) {
                var x = state[i];
                if (!x.sourceName || !x.viewName) {
                    dtShowToast('err', 'Eksik alan', 'Source ' + (i+1) + ': isim ve view dolu olmali.'); setTimeout(dtHideToast, 3500); return;
                }
                if (!x.compatible) {
                    dtShowToast('err', 'Uyumsuz view', 'Source ' + (i+1) + ': secilen view beklenen key kolonunu icermiyor.'); setTimeout(dtHideToast, 4000); return;
                }
            }

            // Backend: key_column = docType.RequiredKeyColumn her source icin aynidir.
            // Primary = ilk source (displayOrder = 0).
            var payload = {
                sources: state.map(function (x, i) {
                    return {
                        sourceName:       x.sourceName,
                        viewName:         x.viewName,
                        keyColumn:        requiredKey || 'id',
                        parentSourceName: null,
                        parentKeyColumn:  null,
                        isPrimary:        i === 0,
                        sortColumn:       x.sortColumn || null,
                        sortDirection:    x.sortColumn ? (x.sortDirection || 'ASC') : null,
                    };
                })
            };
            fetch('/Document/Sources/' + templateId, {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d && d.success) {
                    close();
                    dtLoad();
                } else {
                    dtShowToast('err', 'Kaydedilemedi', (d && d.message) || 'Bilinmeyen hata.');
                    setTimeout(dtHideToast, 4000);
                }
            })
            .catch(function (e) {
                dtShowToast('err', 'Hata', e && e.message ? e.message : 'Bilinmeyen.');
                setTimeout(dtHideToast, 4000);
            });
        };
    };

    window.dtOpenInDesigner = function (id) {
        if (!designerOnline) {
            dtShowToast('err', 'Designer calismiyor', 'CalibraHub.Designer.exe baslatin.');
            setTimeout(dtHideToast, 3500);
            return;
        }
        // Sessiz ac — loading/success toast'lari gosterme. Sadece hatalari bildir.
        fetch(DESIGNER_URL + '/open?id=' + id + '&url=' + encodeURIComponent(location.origin), { mode: 'cors' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d || !d.ok) {
                    dtShowToast('err', 'Designer acilamadi', 'Lutfen tekrar deneyin.');
                    setTimeout(dtHideToast, 3500);
                }
            })
            .catch(function () {
                dtShowToast('err', 'Designer iletisim hatasi', 'Baglanti kurulamadi.');
                setTimeout(dtHideToast, 3500);
            });
    };

    // ── Siralama Ayarlari modal — KALDIRILDI ───────────────────
    // Siralama artik per-source: Data Source'lari Yonet ekraninda her
    // source view'i icin ayri kolon + yon secimi yapilir. Bu fonksiyon
    // geriye donuk uyumluluk icin no-op olarak birakildi.
    window.dtOpenSortOptions = function () { /* no-op */ };

    // Eski tek-kolonluk modal (referans icin korundu, hicbir yerden cagrilmiyor)
    window._legacy_dtOpenSortOptions = async function (id, name) {
        var existing = document.getElementById('dtSortModal');
        if (existing) existing.remove();

        // Mevcut ayar + view kolonlari
        var cols = [], cur = null, dir = 'ASC', viewName = '';
        try {
            var resp = await fetch('/Document/SortOptions/' + id, { credentials: 'same-origin' });
            var data = await resp.json();
            if (data && data.success) {
                cols     = data.columns || [];
                cur      = data.column  || '';
                dir      = data.direction || 'ASC';
                viewName = data.view    || '';
            }
        } catch (_) { /* sessiz */ }

        if (!document.getElementById('dtSortStyles')) {
            var st = document.createElement('style');
            st.id = 'dtSortStyles';
            st.textContent = [
                '#dtSortModal .so-row { display:flex; gap:8px; align-items:flex-end; }',
                '#dtSortModal .so-row > .so-col-field { flex:1; }',
                '#dtSortModal .so-row > .so-col-dir { flex:0 0 130px; }',
                '#dtSortModal .so-field { display:flex; flex-direction:column; gap:5px; }',
                '#dtSortModal .so-field label { font-size:11.5px; font-weight:600; color:rgba(255,255,255,.6); }',
                'body.app-theme-light #dtSortModal .so-field label { color:#64748b; }',
                '#dtSortModal select { padding:8px 10px; border-radius:7px; font-size:12.5px; font-family:inherit; width:100%; background:rgba(255,255,255,.05); color:rgba(255,255,255,.9); border:1px solid rgba(255,255,255,.12); }',
                'body.app-theme-light #dtSortModal select { background:#fff; color:#0f172a; border-color:#cbd5e1; }',
                '#dtSortModal .so-empty { padding:14px; font-size:12px; color:rgba(255,255,255,.55); background:rgba(255,255,255,.04); border:1px dashed rgba(255,255,255,.14); border-radius:8px; }',
                'body.app-theme-light #dtSortModal .so-empty { color:#64748b; background:#f8fafc; border-color:#cbd5e1; }'
            ].join('\n');
            document.head.appendChild(st);
        }

        var modal = document.createElement('div');
        modal.id = 'dtSortModal';

        var optsHtml = '<option value="">— Siralama yok —</option>';
        cols.forEach(function (c) {
            optsHtml += '<option value="' + c + '"' + (c === cur ? ' selected' : '') + '>' + c + '</option>';
        });

        modal.innerHTML =
            '<div class="dt-modal-backdrop">' +
                '<div class="dt-modal" onclick="event.stopPropagation()" style="max-width:560px;">' +
                    '<div class="dt-modal-header">' +
                        '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M7 12h10"/><path d="M11 18h2"/></svg>' +
                        '<div style="flex:1">' +
                            '<div class="dt-modal-title">Siralama Ayari</div>' +
                            '<div class="dt-modal-sub">Sablon: ' + (name || '-') + (viewName ? ' • View: ' + viewName : '') + '</div>' +
                        '</div>' +
                        '<button type="button" class="dt-modal-close" id="dtSortClose" title="Kapat">' +
                            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                        '</button>' +
                    '</div>' +
                    '<div class="dt-modal-body">' +
                        (cols.length === 0 ?
                            '<div class="so-empty">View kolonlari okunamadi. Sablonun bagli view\'i tanimli oldugundan emin olun.</div>'
                            :
                            '<div class="so-row">' +
                                '<div class="so-col-field so-field">' +
                                    '<label for="dtSortCol">Siralama kolonu</label>' +
                                    '<select id="dtSortCol">' + optsHtml + '</select>' +
                                '</div>' +
                                '<div class="so-col-dir so-field">' +
                                    '<label for="dtSortDir">Yon</label>' +
                                    '<select id="dtSortDir">' +
                                        '<option value="ASC"' + (dir === 'ASC' ? ' selected' : '') + '>Artan (ASC)</option>' +
                                        '<option value="DESC"' + (dir === 'DESC' ? ' selected' : '') + '>Azalan (DESC)</option>' +
                                    '</select>' +
                                '</div>' +
                            '</div>'
                        ) +
                        '<div class="dt-modal-hint">Generation sirasinda SQL sorgusuna ORDER BY [kolon] yon eklenir. "Siralama yok" secilirse view\'in dogal sirasi korunur.</div>' +
                    '</div>' +
                    '<div class="dt-modal-footer">' +
                        '<button type="button" class="dt-btn dt-btn--secondary" id="dtSortCancel">Vazgec</button>' +
                        '<button type="button" class="dt-btn dt-btn--primary" id="dtSortSave"' + (cols.length === 0 ? ' disabled' : '') + '>Kaydet</button>' +
                    '</div>' +
                '</div>' +
            '</div>';
        document.body.appendChild(modal);

        function close() {
            modal.remove();
            document.removeEventListener('keydown', esc);
        }
        function esc(e) { if (e.key === 'Escape') close(); }
        document.addEventListener('keydown', esc);
        modal.querySelector('#dtSortClose').onclick  = close;
        modal.querySelector('#dtSortCancel').onclick = close;
        modal.querySelector('.dt-modal-backdrop').addEventListener('click', function (e) {
            if (e.target.classList.contains('dt-modal-backdrop')) close();
        });

        var saveBtn = modal.querySelector('#dtSortSave');
        if (saveBtn) {
            saveBtn.onclick = async function () {
                var col = modal.querySelector('#dtSortCol').value || '';
                var dr  = modal.querySelector('#dtSortDir').value || 'ASC';
                saveBtn.disabled = true;
                saveBtn.textContent = 'Kaydediliyor...';
                try {
                    var resp = await fetch('/Document/SortOptions/' + id, {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ column: col, direction: dr })
                    });
                    var json = await resp.json();
                    if (json && json.success) {
                        dtShowToast('ok', 'Siralama ayari kaydedildi', name || '');
                        setTimeout(dtHideToast, 2200);
                        close();
                    } else {
                        dtShowToast('err', 'Kayit basarisiz', (json && json.message) || '');
                        setTimeout(dtHideToast, 3000);
                    }
                } catch (err) {
                    dtShowToast('err', 'Sunucu hatasi', err && err.message ? err.message : '');
                    setTimeout(dtHideToast, 3000);
                } finally {
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'Kaydet';
                }
            };
        }
    };

    // ── Cikti Ayarlari modal ─────────────────────────────────────
    // Sablon icin Baski/PDF/Mail varsayilanlarini DB'ye yazar.
    // Sales/DocumentEdit > Yazdir bu kayitli ayarlari okuyup direkt uygular.
    window.dtOpenOutputOptions = async function (id, name) {
        var existing = document.getElementById('dtOutputModal');
        if (existing) existing.remove();

        if (!document.getElementById('dtOutputStyles')) {
            var st = document.createElement('style');
            st.id = 'dtOutputStyles';
            st.textContent = [
                '#dtOutputModal .opt-row { display:flex; align-items:flex-start; gap:10px; padding:10px 12px; border:1px solid rgba(255,255,255,.12); border-radius:8px; cursor:pointer; transition:.15s; }',
                '#dtOutputModal .opt-row:hover { border-color:rgba(255,255,255,.28); }',
                '#dtOutputModal .opt-row.is-checked { border-color:#3b82f6; background:rgba(59,130,246,.10); }',
                '#dtOutputModal .opt-row.is-disabled { opacity:.45; pointer-events:none; }',
                '#dtOutputModal .opt-row input { margin-top:3px; cursor:pointer; }',
                '#dtOutputModal .opt-text { display:flex; flex-direction:column; gap:2px; }',
                '#dtOutputModal .opt-title { font-weight:600; font-size:13px; }',
                '#dtOutputModal .opt-desc { font-size:11.5px; opacity:.65; }',
                '#dtOutputModal .opt-mail { display:none; flex-direction:column; gap:8px; padding:12px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.10); border-radius:8px; margin-top:2px; }',
                '#dtOutputModal .opt-mail.is-open { display:flex; }',
                '#dtOutputModal .opt-mail label { font-size:11.5px; font-weight:600; opacity:.75; }',
                '#dtOutputModal .opt-mail input, #dtOutputModal .opt-mail textarea { width:100%; padding:7px 10px; border:1px solid rgba(255,255,255,.18); background:rgba(0,0,0,.18); color:inherit; border-radius:6px; font-size:12.5px; font-family:inherit; box-sizing:border-box; }',
                '#dtOutputModal .opt-mail textarea { resize:vertical; min-height:70px; }',
                'body.app-theme-light #dtOutputModal .opt-row { border-color:#e2e8f0; }',
                'body.app-theme-light #dtOutputModal .opt-row:hover { border-color:#94a3b8; }',
                'body.app-theme-light #dtOutputModal .opt-row.is-checked { background:#eff6ff; border-color:#2563eb; }',
                'body.app-theme-light #dtOutputModal .opt-mail { background:#f8fafc; border-color:#e2e8f0; }',
                'body.app-theme-light #dtOutputModal .opt-mail input, body.app-theme-light #dtOutputModal .opt-mail textarea { background:#fff; border-color:#cbd5e1; color:#0f172a; }'
            ].join('\n');
            document.head.appendChild(st);
        }

        // Mevcut ayari yukle
        var current = { preview: true, pdf: false, mail: false, mailTo: '', mailSubject: '', mailBody: '' };
        try {
            var resp = await fetch('/Document/OutputOptions/' + id, { credentials: 'same-origin' });
            var data = await resp.json();
            if (data && data.options) {
                try { current = Object.assign(current, JSON.parse(data.options)); } catch (_) {}
            }
        } catch (_) { /* sessiz */ }

        var modal = document.createElement('div');
        modal.id = 'dtOutputModal';
        modal.innerHTML =
            '<div class="dt-modal-backdrop">' +
                '<div class="dt-modal" onclick="event.stopPropagation()" style="max-width:560px;">' +
                    '<div class="dt-modal-header">' +
                        '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>' +
                        '<div style="flex:1">' +
                            '<div class="dt-modal-title">Cikti Ayarlari</div>' +
                            '<div class="dt-modal-sub">Sablon: ' + (name || '-') + '</div>' +
                        '</div>' +
                        '<button type="button" class="dt-modal-close" id="dtOutClose" title="Kapat">' +
                            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                        '</button>' +
                    '</div>' +
                    '<div class="dt-modal-body">' +
                        '<label class="opt-row" data-opt="preview">' +
                            '<input type="checkbox" id="dtOutPreview" />' +
                            '<span class="opt-text">' +
                                '<span class="opt-title">Baski onizle</span>' +
                                '<span class="opt-desc">Yazdir basildiginda PDF onizleme modali acilsin.</span>' +
                            '</span>' +
                        '</label>' +
                        '<label class="opt-row" data-opt="pdf">' +
                            '<input type="checkbox" id="dtOutPdf" />' +
                            '<span class="opt-text">' +
                                '<span class="opt-title">PDF olarak kaydet</span>' +
                                '<span class="opt-desc">Yazdir basildiginda PDF dosyasi indirilsin. Secilirse baski onizleme pasiflesir.</span>' +
                            '</span>' +
                        '</label>' +
                        '<label class="opt-row" data-opt="mail">' +
                            '<input type="checkbox" id="dtOutMail" />' +
                            '<span class="opt-text">' +
                                '<span class="opt-title">Mail gonderim</span>' +
                                '<span class="opt-desc">Yazdir basildiginda PDF eki ile mail gonderilsin.</span>' +
                            '</span>' +
                        '</label>' +
                        '<div class="opt-mail" id="dtOutMailFields">' +
                            '<div style="font-size:11.5px; opacity:.75; padding:6px 10px; background:rgba(59,130,246,.10); border-left:3px solid #3b82f6; border-radius:4px;">' +
                                'Alici e-postasi gonderim aninda belgeye ait <strong>cari kart</strong>tan otomatik alinir.' +
                            '</div>' +
                            '<div><label for="dtOutMailSubject">Varsayilan konu</label>' +
                            '<input type="text" id="dtOutMailSubject" placeholder="Belge adi" /></div>' +
                            '<div><label for="dtOutMailBody">Varsayilan mesaj</label>' +
                            '<textarea id="dtOutMailBody" placeholder="Ekte belgeyi bulabilirsiniz..."></textarea></div>' +
                        '</div>' +
                        '<div class="dt-modal-hint">Bos birakirsaniz Yazdir basildiginda kullaniciya secim modali acilir. Doldurursaniz Yazdir direkt secili aksiyonu calistirir.</div>' +
                    '</div>' +
                    '<div class="dt-modal-footer">' +
                        '<button type="button" class="dt-btn dt-btn--secondary" id="dtOutCancel">Vazgec</button>' +
                        '<button type="button" class="dt-btn dt-btn--primary" id="dtOutSave">Kaydet</button>' +
                    '</div>' +
                '</div>' +
            '</div>';
        document.body.appendChild(modal);

        var optPreview  = modal.querySelector('#dtOutPreview');
        var optPdf      = modal.querySelector('#dtOutPdf');
        var optMail     = modal.querySelector('#dtOutMail');
        var rowPreview  = modal.querySelector('[data-opt="preview"]');
        var rowPdf      = modal.querySelector('[data-opt="pdf"]');
        var rowMail     = modal.querySelector('[data-opt="mail"]');
        var mailFields  = modal.querySelector('#dtOutMailFields');
        var mailSubjEl  = modal.querySelector('#dtOutMailSubject');
        var mailBodyEl  = modal.querySelector('#dtOutMailBody');
        var saveBtn     = modal.querySelector('#dtOutSave');

        // Mevcut degerleri yerlestir
        optPreview.checked = !!current.preview;
        optPdf.checked     = !!current.pdf;
        optMail.checked    = !!current.mail;
        mailSubjEl.value   = current.mailSubject|| '';
        mailBodyEl.value   = current.mailBody   || '';

        function refresh() {
            if (optPdf.checked) {
                optPreview.checked = false;
                rowPreview.classList.add('is-disabled');
            } else {
                rowPreview.classList.remove('is-disabled');
            }
            rowPreview.classList.toggle('is-checked', optPreview.checked);
            rowPdf.classList.toggle('is-checked',     optPdf.checked);
            rowMail.classList.toggle('is-checked',    optMail.checked);
            mailFields.classList.toggle('is-open',    optMail.checked);
        }
        [optPreview, optPdf, optMail].forEach(function (cb) { cb.addEventListener('change', refresh); });
        refresh();

        function close() {
            modal.remove();
            document.removeEventListener('keydown', esc);
        }
        function esc(e) { if (e.key === 'Escape') close(); }
        document.addEventListener('keydown', esc);
        modal.querySelector('#dtOutClose').onclick  = close;
        modal.querySelector('#dtOutCancel').onclick = close;
        modal.querySelector('.dt-modal-backdrop').addEventListener('click', function (e) {
            if (e.target.classList.contains('dt-modal-backdrop')) close();
        });

        saveBtn.onclick = async function () {
            var payload = {
                preview:     optPreview.checked,
                pdf:         optPdf.checked,
                mail:        optMail.checked,
                mailSubject: mailSubjEl.value.trim(),
                mailBody:    mailBodyEl.value.trim()
            };
            // Hicbiri secili degilse → ayar temizlenir (modal'a geri donulur)
            var hasAny = payload.preview || payload.pdf || payload.mail;
            saveBtn.disabled = true;
            saveBtn.textContent = 'Kaydediliyor...';
            try {
                var resp = await fetch('/Document/OutputOptions/' + id, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ optionsJson: hasAny ? JSON.stringify(payload) : null })
                });
                var json = await resp.json();
                if (json && json.success) {
                    dtShowToast('ok', 'Cikti ayarlari kaydedildi', name || '');
                    setTimeout(dtHideToast, 2200);
                    close();
                } else {
                    dtShowToast('err', 'Kayit basarisiz', (json && json.message) || '');
                    setTimeout(dtHideToast, 3000);
                }
            } catch (err) {
                dtShowToast('err', 'Sunucu hatasi', err && err.message ? err.message : '');
                setTimeout(dtHideToast, 3000);
            } finally {
                saveBtn.disabled = false;
                saveBtn.textContent = 'Kaydet';
            }
        };
    };

    // ── Mail modal ────────────────────────────────────────────────
    window.dtOpenMail = function (id, name) {
        currentMailTemplateId = id;
        document.getElementById('dtMailTemplateName').textContent = 'Sablon: ' + (name || '-');
        document.getElementById('dtMailSubject').value = name || 'Belge';
        document.getElementById('dtMailTo').value = '';
        document.getElementById('dtMailBody').value = '';
        document.getElementById('dtMailRecordId').value = '';
        var res = document.getElementById('dtMailResult');
        res.className = 'dt-result'; res.textContent = ''; res.style.display = 'none';
        document.getElementById('dtMailModal').style.display = 'block';
        setTimeout(function () { document.getElementById('dtMailTo').focus(); }, 50);
    };
    window.dtCloseMail = function () {
        document.getElementById('dtMailModal').style.display = 'none';
        currentMailTemplateId = null;
    };
    window.dtSendMail = function () {
        if (!currentMailTemplateId) return;
        var to = document.getElementById('dtMailTo').value.trim();
        var subject = document.getElementById('dtMailSubject').value.trim();
        var body = document.getElementById('dtMailBody').value;
        var recordId = document.getElementById('dtMailRecordId').value.trim();

        if (!to || !subject) {
            showMailResult('Alici ve konu zorunludur.', false);
            return;
        }

        var payload = {
            templateId: currentMailTemplateId,
            recordId:   recordId || null,
            toEmail:    to,
            subject:    subject,
            bodyText:   body || null,
            bodyHtml:   null,
        };

        var btn = document.getElementById('dtMailSendBtn');
        btn.disabled = true;
        btn.textContent = 'Gonderiliyor...';

        fetch('/Document/SendEmail', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload),
        })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d.success) {
                    showMailResult('Mail basariyla gonderildi.', true);
                    setTimeout(dtCloseMail, 1200);
                } else {
                    showMailResult(d.message || 'Gonderim basarisiz.', false);
                }
            })
            .catch(function (e) { showMailResult('Baglanti hatasi: ' + e.message, false); })
            .finally(function () {
                btn.disabled = false;
                btn.textContent = 'Gonder';
            });
    };

    function showMailResult(text, ok) {
        var res = document.getElementById('dtMailResult');
        res.textContent = text;
        res.className = 'dt-result ' + (ok ? 'dt-result--ok' : 'dt-result--err');
        res.style.display = 'block';
    }
})();
</script>
}
