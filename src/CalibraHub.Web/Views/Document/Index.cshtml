    window.dtDelete = async function (id) {
        var ok = await dtConfirm({
            title:      'Sablonu Sil',
            message:    'Bu sablonu silmek istediginize emin misiniz? Islem geri alinamaz.',
            okText:     'Evet, Sil',
            cancelText: 'Iptal',
            danger:     true
        });
        if (!ok) return;
        try {
            var resp = await fetch('/Document/Delete/' + id, { method: 'POST', credentials: 'same-origin' });
            var d    = await resp.json();
            if (d.success) {
                // Sessiz silme — success toast gosterme, sadece listeyi yenile.
                dtLoad();
            } else {
                dtShowToast('err', 'Silinemedi', d.message || 'Bilinmeyen hata.');
                setTimeout(dtHideToast, 3500);
            }
        } catch (e) {
            dtShowToast('err', 'Silme hatasi', e && e.message ? e.message : 'Bilinmeyen.');
            setTimeout(dtHideToast, 3500);
        }
    };

