    // ── Ekran ortasi Confirm ve Prompt dialog'lari — browser confirm()/prompt() yerine
    // tema uyumlu glassmorphism kart. Promise doner.

    function dtConfirm(opts) {
        opts = opts || {};
        var title      = opts.title      || 'Onay';
        var message    = opts.message    || 'Bu islemi onayliyor musunuz?';
        var okText     = opts.okText     || 'Onayla';
        var cancelText = opts.cancelText || 'Iptal';
        var danger     = opts.danger === true;

        return new Promise(function (resolve) {
            var bd = document.createElement('div');
            bd.className = 'dt-dialog-backdrop';
            var iconSvg = danger
                ? '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>'
                : '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>';
            bd.innerHTML =
                '<div class="dt-dialog-card' + (danger ? ' dt-dialog-card--danger' : '') + '">' +
                  '<div class="dt-dialog-head">' +
                    '<div class="dt-dialog-icon">' + iconSvg + '</div>' +
                    '<div style="flex:1;min-width:0;">' +
                      '<div class="dt-dialog-title">' + esc(title) + '</div>' +
                      '<div class="dt-dialog-msg">' + esc(message) + '</div>' +
                    '</div>' +
                  '</div>' +
                  '<div class="dt-dialog-actions">' +
                    '<button type="button" class="dt-dialog-btn dt-dialog-btn--cancel" data-role="cancel">' + esc(cancelText) + '</button>' +
                    '<button type="button" class="dt-dialog-btn ' + (danger ? 'dt-dialog-btn--danger' : 'dt-dialog-btn--ok') + '" data-role="ok">' + esc(okText) + '</button>' +
                  '</div>' +
                '</div>';
            document.body.appendChild(bd);
            function cleanup(val) { try { bd.parentNode.removeChild(bd); } catch (e) {} resolve(val); }
            bd.querySelector('[data-role=cancel]').onclick = function () { cleanup(false); };
            bd.querySelector('[data-role=ok]').onclick     = function () { cleanup(true);  };
            bd.addEventListener('click', function (e) { if (e.target === bd) cleanup(false); });
            var onKey = function (e) {
                if (e.key === 'Escape') { document.removeEventListener('keydown', onKey); cleanup(false); }
                else if (e.key === 'Enter') { document.removeEventListener('keydown', onKey); cleanup(true); }
            };
            document.addEventListener('keydown', onKey);
            setTimeout(function () { bd.querySelector('[data-role=ok]').focus(); }, 10);
        });
    }

    // ── Multi-field prompt: sablon adi + SQL view + read-only required key info ─
    function dtPromptCreate(opts) {
        opts = opts || {};
        var title       = opts.title       || 'Yeni Sablon';
        var message     = opts.message     || '';
        var nameLabel   = opts.nameLabel   || 'Sablon Adi';
        var nameHolder  = opts.nameHolder  || '';
        var viewLabel   = opts.viewLabel   || 'SQL View';
        var viewDefault = opts.viewDefault || '';
        var views       = Array.isArray(opts.views) ? opts.views : [];
        var requiredKey = opts.requiredKey || '';
        var okText      = opts.okText      || 'Olustur';
        var cancelText  = opts.cancelText  || 'Iptal';

        if (viewDefault && views.indexOf(viewDefault) < 0) {
            views = [viewDefault].concat(views);
        }

        return new Promise(function (resolve) {
            var bd = document.createElement('div');
            bd.className = 'dt-dialog-backdrop';
            var iconSvg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>';

            var defaultOption = '<option value="">' +
                (viewDefault ? '— Default (' + esc(viewDefault) + ') —' : '— Default —') +
                '</option>';
            var viewOptions = defaultOption + views.map(function (v) {
                return '<option value="' + esc(v) + '">' + esc(v) + '</option>';
            }).join('');

            bd.innerHTML =
                '<div class="dt-dialog-card" style="max-width:560px;">' +
                  '<div class="dt-dialog-head">' +
                    '<div class="dt-dialog-icon">' + iconSvg + '</div>' +
                    '<div style="flex:1;min-width:0;">' +
                      '<div class="dt-dialog-title">' + esc(title) + '</div>' +
                      (message ? '<div class="dt-dialog-msg">' + esc(message) + '</div>' : '') +
                    '</div>' +
                  '</div>' +
                  '<div style="display:flex;flex-direction:column;gap:10px;margin-top:6px;">' +
                    '<label style="font-size:.78rem;font-weight:600;color:var(--dt-text-soft,#94a3b8);display:flex;flex-direction:column;gap:4px;">' +
                      esc(nameLabel) +
                      '<input type="text" class="dt-dialog-input" data-role="name" placeholder="' + esc(nameHolder) + '" />' +
                    '</label>' +
                    '<label style="font-size:.78rem;font-weight:600;color:var(--dt-text-soft,#94a3b8);display:flex;flex-direction:column;gap:4px;">' +
                      esc(viewLabel) +
                      '<select class="dt-dialog-input" data-role="view">' + viewOptions + '</select>' +
                    '</label>' +
                    '<div data-role="compat-info" style="padding:10px 12px;border-radius:8px;font-size:.76rem;line-height:1.5;' +
                      'background:rgba(148,163,184,.08);border:1px solid rgba(148,163,184,.18);color:#94a3b8;">' +
                      (requiredKey
                        ? 'Beklenen anahtar kolon: <code style="background:rgba(6,182,212,.15);padding:2px 6px;border-radius:4px;color:#67e8f9;">' + esc(requiredKey) + '</code><br/>' +
                          '<span data-role="compat-status">View kontrol ediliyor...</span>'
                        : 'Bu belge tipi icin zorunlu anahtar kolon tanimli degil — kullanicinin view\'i kendi filtrelemesi gerekir.') +
                    '</div>' +
                  '</div>' +
                  '<div class="dt-dialog-actions">' +
                    '<button type="button" class="dt-dialog-btn dt-dialog-btn--cancel" data-role="cancel">' + esc(cancelText) + '</button>' +
                    '<button type="button" class="dt-dialog-btn dt-dialog-btn--ok"     data-role="ok" disabled style="opacity:.5;cursor:not-allowed;">' + esc(okText) + '</button>' +
                  '</div>' +
                '</div>';
            document.body.appendChild(bd);
            var nameInp = bd.querySelector('[data-role=name]');
            var viewSel = bd.querySelector('[data-role=view]');
            var okBtn   = bd.querySelector('[data-role=ok]');
            var compatInfo = bd.querySelector('[data-role=compat-info]');
            var compatStatus = bd.querySelector('[data-role=compat-status]');

            var isCompatible = false;

            function setOkEnabled(enabled) {
                okBtn.disabled = !enabled;
                okBtn.style.opacity = enabled ? '1' : '.5';
                okBtn.style.cursor = enabled ? 'pointer' : 'not-allowed';
            }

            function setCompatResult(ok, text, cls) {
                if (!compatInfo) return;
                compatInfo.style.background     = cls === 'ok'   ? 'rgba(34,197,94,.08)'  : cls === 'err' ? 'rgba(239,68,68,.08)'  : 'rgba(148,163,184,.08)';
                compatInfo.style.borderColor    = cls === 'ok'   ? 'rgba(34,197,94,.28)'  : cls === 'err' ? 'rgba(239,68,68,.3)'   : 'rgba(148,163,184,.18)';
                compatInfo.style.color          = cls === 'ok'   ? '#86efac'              : cls === 'err' ? '#fca5a5'              : '#94a3b8';
                if (compatStatus) compatStatus.innerHTML = text;
                isCompatible = ok;
                setOkEnabled(ok && (nameInp.value.trim().length > 0));
            }

            // View secilince uyumluluk kontrolu (required key kolon mevcut mu?)
            function checkCompat(viewName) {
                if (!requiredKey) {
                    // Zorunlu key yoksa her view uyumlu sayilir
                    isCompatible = true;
                    setOkEnabled(nameInp.value.trim().length > 0);
                    return;
                }
                // "Default" secili ise defaultView'i kontrol et
                var vn = viewName || viewDefault;
                if (!vn) {
                    setCompatResult(false, '<strong>Bir view secin.</strong>', 'err');
                    return;
                }
                setCompatResult(false, 'Kontrol ediliyor: ' + esc(vn) + '...', 'neutral');
                fetch('/Document/ViewColumns/' + encodeURIComponent(vn), { credentials: 'same-origin' })
                    .then(function (r) { return r.json(); })
                    .then(function (d) {
                        if (!d || !d.success || !Array.isArray(d.columns)) {
                            setCompatResult(false, '<strong>View kolonlari okunamadi.</strong>', 'err');
                            return;
                        }
                        var hasKey = d.columns.some(function (c) { return c.toLowerCase() === requiredKey.toLowerCase(); });
                        if (hasKey) {
                            setCompatResult(true,
                                '<strong>&#10003; Uyumlu.</strong> <code>' + esc(vn) + '</code> view\'inda <code>' + esc(requiredKey) + '</code> kolonu mevcut.',
                                'ok');
                        } else {
                            setCompatResult(false,
                                '<strong>&#10007; Uyumsuz.</strong> <code>' + esc(vn) + '</code> view\'inda <code>' + esc(requiredKey) + '</code> kolonu bulunamadi. ' +
                                'Bu view kullanilamaz — farkli bir view secin.',
                                'err');
                        }
                    })
                    .catch(function () { setCompatResult(false, '<strong>Kontrol basarisiz.</strong>', 'err'); });
            }

            // Ilk kontrol
            if (requiredKey) checkCompat(viewSel.value);
            else { isCompatible = true; setOkEnabled(false); }

            viewSel.addEventListener('change', function () { checkCompat(viewSel.value); });
            nameInp.addEventListener('input', function () {
                setOkEnabled(isCompatible && nameInp.value.trim().length > 0);
            });

            function cleanup(val) { try { bd.parentNode.removeChild(bd); } catch (e) {} resolve(val); }
            function submit() {
                if (okBtn.disabled) return;
                var nm = (nameInp.value || '').trim();
                var vw = (viewSel.value || '').trim();
                if (!nm) { nameInp.focus(); return; }
                cleanup({ name: nm, view: vw });
            }
            bd.querySelector('[data-role=cancel]').onclick = function () { cleanup(null); };
            okBtn.onclick = submit;
            bd.addEventListener('click', function (e) { if (e.target === bd) cleanup(null); });
            var onKey = function (e) {
                if (e.key === 'Escape') { document.removeEventListener('keydown', onKey); cleanup(null); }
                else if (e.key === 'Enter' && document.activeElement === nameInp) {
                    document.removeEventListener('keydown', onKey);
                    submit();
                }
            };
            document.addEventListener('keydown', onKey);
            setTimeout(function () { nameInp.focus(); nameInp.select(); }, 10);
        });
    }

    function dtPrompt(opts) {
        opts = opts || {};
        var title        = opts.title        || 'Ad giriniz';
        var message      = opts.message      || '';
        var placeholder  = opts.placeholder  || '';
        var defaultValue = opts.defaultValue || '';
        var okText       = opts.okText       || 'Tamam';
        var cancelText   = opts.cancelText   || 'Iptal';

        return new Promise(function (resolve) {
            var bd = document.createElement('div');
            bd.className = 'dt-dialog-backdrop';
            var iconSvg = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>';
            bd.innerHTML =
                '<div class="dt-dialog-card">' +
                  '<div class="dt-dialog-head">' +
                    '<div class="dt-dialog-icon">' + iconSvg + '</div>' +
                    '<div style="flex:1;min-width:0;">' +
                      '<div class="dt-dialog-title">' + esc(title) + '</div>' +
                      (message ? '<div class="dt-dialog-msg">' + esc(message) + '</div>' : '') +
                    '</div>' +
                  '</div>' +
                  '<input type="text" class="dt-dialog-input" data-role="input" placeholder="' + esc(placeholder) + '" />' +
                  '<div class="dt-dialog-actions">' +
                    '<button type="button" class="dt-dialog-btn dt-dialog-btn--cancel" data-role="cancel">' + esc(cancelText) + '</button>' +
                    '<button type="button" class="dt-dialog-btn dt-dialog-btn--ok"     data-role="ok">' + esc(okText) + '</button>' +
                  '</div>' +
                '</div>';
            document.body.appendChild(bd);
            var inp = bd.querySelector('[data-role=input]');
            inp.value = defaultValue;
            function cleanup(val) { try { bd.parentNode.removeChild(bd); } catch (e) {} resolve(val); }
            bd.querySelector('[data-role=cancel]').onclick = function () { cleanup(null); };
            bd.querySelector('[data-role=ok]').onclick     = function () {
                var v = (inp.value || '').trim();
                cleanup(v || null);
            };
            bd.addEventListener('click', function (e) { if (e.target === bd) cleanup(null); });
            var onKey = function (e) {
                if (e.key === 'Escape') { document.removeEventListener('keydown', onKey); cleanup(null); }
                else if (e.key === 'Enter' && document.activeElement === inp) {
                    document.removeEventListener('keydown', onKey);
                    var v = (inp.value || '').trim();
                    cleanup(v || null);
                }
            };
            document.addEventListener('keydown', onKey);
            setTimeout(function () { inp.focus(); inp.select(); }, 10);
        });
    }

    // ── Inline preview modal — URL'de id gorunmez ─────────────────
    window.dtOpenPreview = function (templateId, templateName) {
