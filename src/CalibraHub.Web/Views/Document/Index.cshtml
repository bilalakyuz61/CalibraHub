@{
    ViewBag.Title        = "Belge Sablonlari";
    ViewData["Title"]    = "Belge Sablonlari";
    ViewData["FormCode"] = "DOC_TEMPLATES";
    ViewData["BodyClass"] = "page-doc-templates";
    ViewBag.PageTitle    = "Belge Sablonlari";

    var docTypes     = (IReadOnlyCollection<CalibraHub.Domain.Entities.DocumentType>)(ViewBag.DocumentTypes ?? Array.Empty<CalibraHub.Domain.Entities.DocumentType>());
    var selectedType = (CalibraHub.Domain.Entities.DocumentType?)ViewBag.SelectedType;
    var templates    = (IReadOnlyCollection<CalibraHub.Domain.Entities.ReportTemplate>)(ViewBag.Templates ?? Array.Empty<CalibraHub.Domain.Entities.ReportTemplate>());
}

@section Styles {
<style>
    /* ── Page shell ──────────────────────────────────────────────── */
    .page-doc-templates .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-doc-templates .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important;
        margin: 0 !important; overflow: hidden !important;
    }
    .workspace-frame-body.page-doc-templates .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-doc-templates .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    .dt-shell {
        flex: 1 1 auto; min-height: 0; display: flex; flex-direction: column; overflow: hidden;
        background: #0c0f1a;
        background-image:
            radial-gradient(at 20% 30%, rgba(99,102,241,.12) 0, transparent 50%),
            radial-gradient(at 80% 20%, rgba(14,165,233,.08) 0, transparent 50%);
    }
    body.app-theme-light .dt-shell { background: #f8fafc; background-image: none; }

    /* Action bar */
    .dt-action-bar {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px; flex-shrink: 0;
        background: rgba(15,15,26,.85); border-bottom: 1px solid rgba(255,255,255,.06);
        backdrop-filter: blur(16px);
    }
    body.app-theme-light .dt-action-bar { background: rgba(248,250,252,.92); border-bottom-color: #e2e8f0; }

    .dt-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 14px; border-radius: 8px; border: 1px solid;
        font-size: .78rem; font-weight: 600; cursor: pointer;
        transition: all .12s; background: transparent;
    }
    .dt-btn--primary { background: #6366f1; border-color: #4f46e5; color: #fff; }
    .dt-btn--primary:hover:not(:disabled) { background: #4f46e5; }
    .dt-btn--secondary { background: rgba(255,255,255,.05); border-color: rgba(255,255,255,.1); color: rgba(255,255,255,.65); }
    body.app-theme-light .dt-btn--secondary { background: #fff; border-color: #e2e8f0; color: #475569; }
    .dt-btn--secondary:hover:not(:disabled) { background: rgba(255,255,255,.1); color: #fff; }
    body.app-theme-light .dt-btn--secondary:hover:not(:disabled) { background: #f1f5f9; color: #1e293b; }
    .dt-btn:disabled { opacity: .5; cursor: not-allowed; }

    /* Selector bar */
    .dt-selector-bar {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 16px; flex-shrink: 0;
        border-bottom: 1px solid rgba(255,255,255,.04);
    }
    body.app-theme-light .dt-selector-bar { border-bottom-color: rgba(15,23,42,.06); }
    .dt-selector-bar label {
        font-size: .78rem; font-weight: 600;
        color: rgba(255,255,255,.55);
    }
    body.app-theme-light .dt-selector-bar label { color: #64748b; }
    .dt-select {
        padding: 7px 10px; border-radius: 8px;
        background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1);
        color: rgba(255,255,255,.85); font-size: .84rem;
        min-width: 220px; outline: none;
    }
    body.app-theme-light .dt-select { background: #fff; border-color: #e2e8f0; color: #1e293b; }
    .dt-select option { background: #0d1117; color: rgba(255,255,255,.9); }
    body.app-theme-light .dt-select option { background: #fff; color: #1e293b; }

    .dt-designer-indicator {
        display: inline-flex; align-items: center; gap: 6px;
        margin-left: auto;
        font-size: .72rem; color: rgba(255,255,255,.45);
    }
    body.app-theme-light .dt-designer-indicator { color: #94a3b8; }
    .dt-dot { width: 8px; height: 8px; border-radius: 50%; background: #dc2626; }
    .dt-dot.online { background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,.5); }

    /* Designer Opening Toast — ekran ortasi glassmorphism kart */
    .dt-toast-backdrop {
        position: fixed; inset: 0; z-index: 2100;
        background: radial-gradient(at 20% 10%, rgba(99,102,241,0.12) 0%, transparent 45%), radial-gradient(at 85% 85%, rgba(168,85,247,0.10) 0%, transparent 45%), rgba(3,6,15,0.55);
        backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
        display: flex; align-items: center; justify-content: center;
        animation: dtToastFade 160ms ease-out;
        pointer-events: auto;
    }
    @@keyframes dtToastFade { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes dtToastPop { from { opacity: 0; transform: translateY(6px) scale(.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    .dt-toast-card {
        width: 360px; max-width: 92%;
        border-radius: 16px;
        background: linear-gradient(180deg, rgba(23,28,42,0.98) 0%, rgba(15,19,30,0.98) 100%);
        border: 1px solid rgba(255,255,255,0.10);
        box-shadow: 0 24px 64px rgba(0,0,0,0.55), 0 0 0 1px rgba(99,102,241,0.08);
        color: rgba(255,255,255,0.92);
        padding: 20px 22px;
        display: flex; align-items: center; gap: 14px;
        animation: dtToastPop 220ms cubic-bezier(.2,.8,.3,1);
    }
    body.app-theme-light .dt-toast-card {
        background: #ffffff;
        border-color: #e2e8f0;
        box-shadow: 0 20px 56px rgba(15,23,42,0.18), 0 0 0 1px rgba(99,102,241,0.08);
        color: #1e293b;
    }
    .dt-toast-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        background: linear-gradient(135deg, rgba(99,102,241,0.28), rgba(168,85,247,0.20));
        border: 1px solid rgba(99,102,241,0.35);
        box-shadow: 0 4px 16px rgba(99,102,241,0.22);
        color: #a5b4fc;
    }
    body.app-theme-light .dt-toast-icon {
        background: linear-gradient(135deg, rgba(99,102,241,0.14), rgba(168,85,247,0.10));
        color: #4f46e5;
    }
    .dt-toast-spinner {
        width: 18px; height: 18px; border-radius: 50%;
        border: 2.5px solid rgba(165,180,252,0.22);
        border-top-color: #a5b4fc;
        animation: dtToastSpin 0.7s linear infinite;
    }
    body.app-theme-light .dt-toast-spinner { border-color: rgba(99,102,241,0.20); border-top-color: #4f46e5; }
    @@keyframes dtToastSpin { to { transform: rotate(360deg); } }
    .dt-toast-body { flex: 1; min-width: 0; }
    .dt-toast-title {
        font-size: 0.92rem; font-weight: 700; letter-spacing: -.005em;
        margin-bottom: 3px; color: inherit;
    }
    .dt-toast-sub {
        font-size: 0.77rem; color: rgba(255,255,255,0.55);
    }
    body.app-theme-light .dt-toast-sub { color: #64748b; }
    /* Ust serit — shimmer, "calistiriyorum" hissi */
    .dt-toast-card::before {
        content: ''; display: block; position: absolute;
        top: 0; left: 0; right: 0; height: 3px;
        background: linear-gradient(90deg, #6366f1 0%, #a855f7 50%, #6366f1 100%);
        background-size: 200% 100%;
        animation: dtToastShimmer 2.4s linear infinite;
    }
    .dt-toast-card { position: relative; overflow: hidden; }
    @@keyframes dtToastShimmer { 0% { background-position: 0% 0%; } 100% { background-position: 200% 0%; } }

    /* Basari / hata varyantlari */
    .dt-toast-card--ok  .dt-toast-icon { background: rgba(34,197,94,0.18); border-color: rgba(34,197,94,0.45); color: #86efac; box-shadow: 0 4px 16px rgba(34,197,94,0.25); }
    .dt-toast-card--ok::before { background: linear-gradient(90deg, #22c55e 0%, #10b981 50%, #22c55e 100%); background-size: 200% 100%; }
    .dt-toast-card--err .dt-toast-icon { background: rgba(239,68,68,0.18); border-color: rgba(239,68,68,0.45); color: #fca5a5; box-shadow: 0 4px 16px rgba(239,68,68,0.25); }
    .dt-toast-card--err::before { background: linear-gradient(90deg, #ef4444 0%, #f59e0b 50%, #ef4444 100%); background-size: 200% 100%; }
    body.app-theme-light .dt-toast-card--ok  .dt-toast-icon { background: rgba(34,197,94,0.12); color: #15803d; }
    body.app-theme-light .dt-toast-card--err .dt-toast-icon { background: rgba(239,68,68,0.10); color: #b91c1c; }

    /* Confirm / Prompt dialog — ekran ortasi glassmorphism */
    .dt-dialog-backdrop {
        position: fixed; inset: 0; z-index: 2200;
        background: radial-gradient(at 20% 10%, rgba(99,102,241,0.12) 0%, transparent 45%), radial-gradient(at 85% 85%, rgba(168,85,247,0.10) 0%, transparent 45%), rgba(3,6,15,0.60);
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        display: flex; align-items: center; justify-content: center;
        padding: 16px; animation: dtToastFade 160ms ease-out;
    }
    .dt-dialog-card {
        width: 420px; max-width: 94%;
        border-radius: 16px;
        background: linear-gradient(180deg, rgba(23,28,42,0.98) 0%, rgba(15,19,30,0.98) 100%);
        border: 1px solid rgba(255,255,255,0.10);
        box-shadow: 0 28px 72px rgba(0,0,0,0.60), 0 0 0 1px rgba(99,102,241,0.08);
        color: rgba(255,255,255,0.92);
        padding: 22px 24px 18px;
        animation: dtToastPop 220ms cubic-bezier(.2,.8,.3,1);
        position: relative; overflow: hidden;
    }
    body.app-theme-light .dt-dialog-card {
        background: #ffffff; border-color: #e2e8f0; color: #1e293b;
        box-shadow: 0 24px 60px rgba(15,23,42,0.18);
    }
    .dt-dialog-card::before {
        content: ''; display: block; position: absolute; top: 0; left: 0; right: 0; height: 3px;
        background: linear-gradient(90deg, #6366f1 0%, #a855f7 50%, #6366f1 100%);
        background-size: 200% 100%;
        animation: dtToastShimmer 2.4s linear infinite;
    }
    .dt-dialog-card--danger::before {
        background: linear-gradient(90deg, #ef4444 0%, #f59e0b 50%, #ef4444 100%);
        background-size: 200% 100%;
    }
    .dt-dialog-head { display: flex; gap: 14px; align-items: flex-start; margin-bottom: 14px; }
    .dt-dialog-icon {
        width: 44px; height: 44px; border-radius: 12px; flex-shrink: 0;
        display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, rgba(99,102,241,0.28), rgba(168,85,247,0.20));
        border: 1px solid rgba(99,102,241,0.35);
        color: #a5b4fc;
    }
    .dt-dialog-card--danger .dt-dialog-icon {
        background: rgba(239,68,68,0.18); border-color: rgba(239,68,68,0.45); color: #fca5a5;
        box-shadow: 0 4px 16px rgba(239,68,68,0.25);
    }
    body.app-theme-light .dt-dialog-icon { color: #4f46e5; background: linear-gradient(135deg, rgba(99,102,241,0.14), rgba(168,85,247,0.10)); }
    body.app-theme-light .dt-dialog-card--danger .dt-dialog-icon { background: rgba(239,68,68,0.10); color: #b91c1c; }
    .dt-dialog-title { font-size: .98rem; font-weight: 700; margin: 2px 0 3px; color: inherit; letter-spacing: -.005em; }
    .dt-dialog-msg { font-size: .82rem; color: rgba(255,255,255,0.62); line-height: 1.45; }
    body.app-theme-light .dt-dialog-msg { color: #64748b; }
    .dt-dialog-input {
        width: 100%; padding: 10px 12px; border-radius: 10px;
        border: 1px solid rgba(255,255,255,0.14);
        background: rgba(10,14,24,0.55); color: rgba(255,255,255,0.92);
        font-size: .86rem; outline: none; transition: border-color .12s, box-shadow .12s;
        margin: 4px 0 0;
    }
    .dt-dialog-input:focus {
        border-color: rgba(99,102,241,0.55);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    body.app-theme-light .dt-dialog-input {
        background: #ffffff; border-color: #cbd5e1; color: #1e293b;
    }
    .dt-dialog-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 18px; }
    .dt-dialog-btn {
        padding: 8px 16px; border-radius: 10px; border: 1px solid;
        font-size: .82rem; font-weight: 700; cursor: pointer;
        transition: all .12s; user-select: none;
    }
    .dt-dialog-btn--cancel {
        background: rgba(255,255,255,0.04);
        border-color: rgba(255,255,255,0.10);
        color: rgba(255,255,255,0.8);
    }
    .dt-dialog-btn--cancel:hover { background: rgba(255,255,255,0.08); }
    body.app-theme-light .dt-dialog-btn--cancel {
        background: #f1f5f9; border-color: #e2e8f0; color: #334155;
    }
    body.app-theme-light .dt-dialog-btn--cancel:hover { background: #e2e8f0; }
    .dt-dialog-btn--ok {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        border-color: rgba(99,102,241,0.55);
        color: #ffffff;
        box-shadow: 0 4px 16px rgba(99,102,241,0.35);
    }
    .dt-dialog-btn--ok:hover { transform: translateY(-1px); }
    .dt-dialog-btn--danger {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border-color: rgba(239,68,68,0.55);
        color: #ffffff;
        box-shadow: 0 4px 16px rgba(239,68,68,0.35);
    }
    .dt-dialog-btn--danger:hover { transform: translateY(-1px); }

    /* Content area */
    .dt-content {
        flex: 1 1 auto; min-height: 0; overflow-y: auto;
        padding: 16px;
    }

    /* Grid card */
    .dt-grid-card {
        background: rgba(255,255,255,.02);
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 14px;
        padding: 0; margin-bottom: 14px;
        overflow: hidden;
        backdrop-filter: blur(10px);
    }
    body.app-theme-light .dt-grid-card { background: #fff; border-color: #e2e8f0; box-shadow: 0 1px 3px rgba(15,23,42,.04); }

    .dt-grid { width: 100%; border-collapse: collapse; font-size: .82rem; }
    .dt-grid thead th {
        text-align: left; padding: 10px 14px;
        font-weight: 700; font-size: .7rem; text-transform: uppercase;
        letter-spacing: .05em; color: rgba(255,255,255,.4);
        background: rgba(15,15,26,.6);
        border-bottom: 1px solid rgba(255,255,255,.06);
    }
    body.app-theme-light .dt-grid thead th {
        background: #f8fafc; color: #64748b; border-bottom-color: #e2e8f0;
    }
    .dt-grid tbody tr {
        border-bottom: 1px solid rgba(255,255,255,.04);
        transition: background .1s;
    }
    body.app-theme-light .dt-grid tbody tr { border-bottom-color: rgba(15,23,42,.05); }
    .dt-grid tbody tr:hover { background: rgba(99,102,241,.05); }
    body.app-theme-light .dt-grid tbody tr:hover { background: rgba(99,102,241,.04); }
    .dt-grid td { padding: 10px 14px; color: rgba(255,255,255,.85); vertical-align: middle; }
    body.app-theme-light .dt-grid td { color: #334155; }

    .dt-col-no { width: 40px; color: rgba(255,255,255,.3); text-align: center; }
    body.app-theme-light .dt-col-no { color: #94a3b8; }
    .dt-name {
        font-weight: 600; cursor: pointer;
        border-bottom: 1px dashed transparent;
        transition: border-color .15s, color .15s;
    }
    .dt-name:hover { border-bottom-color: #818cf8; color: #a5b4fc; }
    body.app-theme-light .dt-name:hover { color: #4f46e5; }
    .dt-col-default { width: 80px; text-align: center; }
    .dt-col-date { width: 130px; font-size: .74rem; color: rgba(255,255,255,.45); white-space: nowrap; }
    body.app-theme-light .dt-col-date { color: #64748b; }
    .dt-col-actions { white-space: nowrap; width: 220px; text-align: right; }

    .dt-default-dot {
        display: inline-block; width: 8px; height: 8px; border-radius: 50%;
        background: #22c55e; box-shadow: 0 0 6px rgba(34,197,94,.5);
    }

    /* View badge — sablonun kullandigi SQL view'i gosterir */
    .dt-view-badge {
        display: inline-block; padding: 2px 8px;
        font-size: .72rem; font-family: ui-monospace, 'Cascadia Mono', Consolas, monospace;
        border-radius: 5px; line-height: 1.4;
        background: rgba(148, 163, 184, .12);
        color: rgba(226, 232, 240, .8);
        border: 1px solid rgba(148, 163, 184, .18);
        white-space: nowrap;
    }
    body.app-theme-light .dt-view-badge {
        background: rgba(100, 116, 139, .08);
        color: #475569;
        border-color: rgba(100, 116, 139, .18);
    }
    /* Override badge: template'in kendi view'i varsa cyan vurgu */
    .dt-view-badge--override {
        background: rgba(6, 182, 212, .12);
        color: #67e8f9;
        border-color: rgba(6, 182, 212, .3);
    }
    body.app-theme-light .dt-view-badge--override {
        background: rgba(6, 182, 212, .08);
        color: #0e7490;
        border-color: rgba(6, 182, 212, .28);
    }

    .dt-row-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px; margin-left: 4px;
        border-radius: 7px; border: none; cursor: pointer;
        transition: background .12s;
    }
    .dt-row-btn--preview { background: rgba(245,158,11,.12); color: #fcd34d; }
    .dt-row-btn--preview:hover { background: rgba(245,158,11,.22); }
    .dt-row-btn--sources { background: rgba(6,182,212,.12); color: #67e8f9; }
    .dt-row-btn--sources:hover { background: rgba(6,182,212,.22); }
    .dt-row-btn--mail { background: rgba(16,185,129,.1); color: #34d399; }
    .dt-row-btn--mail:hover { background: rgba(16,185,129,.2); }
    .dt-row-btn--designer { background: rgba(139,92,246,.12); color: #c4b5fd; }
    .dt-row-btn--designer:hover { background: rgba(139,92,246,.22); }
    .dt-row-btn--default { background: rgba(59,130,246,.12); color: #93c5fd; }
    .dt-row-btn--default:hover { background: rgba(59,130,246,.22); }
    .dt-row-btn--del { background: rgba(239,68,68,.1); color: #fca5a5; }
    .dt-row-btn--del:hover { background: rgba(239,68,68,.2); }
    .dt-row-btn--output { background: rgba(244,114,182,.12); color: #f9a8d4; }
    .dt-row-btn--output:hover { background: rgba(244,114,182,.22); }
    body.app-theme-light .dt-row-btn--output { background: rgba(244,114,182,.10); color: #be185d; }
    body.app-theme-light .dt-row-btn--preview  { background: rgba(245,158,11,.1);  color: #b45309; }
    body.app-theme-light .dt-row-btn--sources  { background: rgba(6,182,212,.08);  color: #0e7490; }

    /* Uyumsuz view icin titresim — kirmizi SADECE animasyon suresince gorunur */
    @@keyframes dt-shake-red-kf {
        0%, 100% { transform: translateX(0); }
        20%, 60% { transform: translateX(-6px); }
        40%, 80% { transform: translateX(6px); }
    }
    .dt-shake-red {
        animation: dt-shake-red-kf 0.4s ease-in-out;
        border-color: #ef4444 !important;
        box-shadow: 0 0 0 2px rgba(239,68,68,.25) !important;
    }
    body.app-theme-light .dt-row-btn--mail     { background: rgba(16,185,129,.08); color: #059669; }
    body.app-theme-light .dt-row-btn--designer { background: rgba(139,92,246,.08); color: #6d28d9; }
    body.app-theme-light .dt-row-btn--default  { background: rgba(59,130,246,.08); color: #1d4ed8; }
    body.app-theme-light .dt-row-btn--del      { background: rgba(239,68,68,.08); color: #dc2626; }

    .dt-empty { padding: 40px 20px; text-align: center; color: rgba(255,255,255,.35); font-style: italic; }
    body.app-theme-light .dt-empty { color: #94a3b8; }

    /* Upload area */
    .dt-upload {
        border: 1.5px dashed rgba(255,255,255,.15);
        border-radius: 12px;
        padding: 22px;
        text-align: center;
        color: rgba(255,255,255,.4);
        font-size: .84rem;
        transition: border-color .15s, background .15s;
        background: rgba(255,255,255,.02);
    }
    body.app-theme-light .dt-upload { border-color: #cbd5e1; background: #f8fafc; color: #64748b; }
    .dt-upload.dragover { border-color: #6366f1; background: rgba(99,102,241,.06); color: rgba(255,255,255,.7); }
    body.app-theme-light .dt-upload.dragover { background: #eff6ff; }
    .dt-upload input[type="file"] { display: none; }
    .dt-upload label { cursor: pointer; color: #818cf8; font-weight: 600; text-decoration: underline; margin: 0 4px; }
    body.app-theme-light .dt-upload label { color: #6366f1; }

    /* ── Mail modal ──────────────────────────────────────────────── */
    .dt-modal-backdrop {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,.55); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        animation: dtFadeIn .15s ease-out;
    }
    body.app-theme-light .dt-modal-backdrop { background: rgba(15,23,42,.35); }
    @@keyframes dtFadeIn { from { opacity: 0; } to { opacity: 1; } }

    .dt-modal {
        width: min(620px, 95vw); max-height: 90vh;
        display: flex; flex-direction: column;
        background: #1a1f2e;
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 14px; box-shadow: 0 24px 72px rgba(0,0,0,.5);
        overflow: hidden;
        animation: dtSlide .22s cubic-bezier(.23,1,.32,1);
    }
    body.app-theme-light .dt-modal { background: #fff; border-color: #e2e8f0; }
    @@keyframes dtSlide {
        from { transform: translateY(12px) scale(.97); opacity: 0; }
        to   { transform: translateY(0) scale(1); opacity: 1; }
    }

    .dt-modal-header {
        padding: 14px 18px; display: flex; align-items: center; gap: 10px;
        border-bottom: 1px solid rgba(255,255,255,.08);
        color: rgba(255,255,255,.9);
    }
    body.app-theme-light .dt-modal-header { color: #1e293b; border-bottom-color: #e2e8f0; }
    .dt-modal-header svg { color: #34d399; }
    .dt-modal-title { font-size: .95rem; font-weight: 700; flex: 1; }
    .dt-modal-sub   { font-size: .72rem; color: rgba(255,255,255,.45); margin-top: 2px; }
    body.app-theme-light .dt-modal-sub { color: #94a3b8; }
    .dt-modal-close {
        background: transparent; border: none; cursor: pointer;
        color: inherit; padding: 4px; border-radius: 6px;
        display: inline-flex; align-items: center; justify-content: center;
    }
    .dt-modal-close:hover { background: rgba(255,255,255,.08); }
    body.app-theme-light .dt-modal-close:hover { background: #f1f5f9; }

    .dt-modal-body { flex: 1; overflow-y: auto; padding: 16px 18px; display: flex; flex-direction: column; gap: 10px; }

    .dt-field { display: flex; flex-direction: column; gap: 4px; }
    .dt-field label {
        font-size: .72rem; font-weight: 600; color: rgba(255,255,255,.55);
    }
    body.app-theme-light .dt-field label { color: #64748b; }
    .dt-input, .dt-textarea {
        padding: 8px 12px; border-radius: 8px;
        background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1);
        color: rgba(255,255,255,.85); font-size: .84rem;
        outline: none; font-family: inherit;
        transition: border-color .15s, box-shadow .15s;
    }
    .dt-input:focus, .dt-textarea:focus {
        border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.15);
    }
    body.app-theme-light .dt-input, body.app-theme-light .dt-textarea {
        background: #fff; border-color: #e2e8f0; color: #1e293b;
    }
    .dt-input::placeholder, .dt-textarea::placeholder { color: rgba(255,255,255,.25); }
    body.app-theme-light .dt-input::placeholder, body.app-theme-light .dt-textarea::placeholder { color: #94a3b8; }
    .dt-textarea { resize: vertical; min-height: 100px; }

    .dt-modal-footer {
        padding: 12px 18px; display: flex; justify-content: flex-end; gap: 8px;
        border-top: 1px solid rgba(255,255,255,.08);
    }
    body.app-theme-light .dt-modal-footer { border-top-color: #e2e8f0; }

    .dt-modal-hint {
        font-size: .7rem; color: rgba(255,255,255,.35);
        padding: 6px 10px; background: rgba(255,255,255,.02);
        border-radius: 6px; border-left: 3px solid rgba(59,130,246,.4);
    }
    body.app-theme-light .dt-modal-hint { color: #64748b; background: #f8fafc; border-left-color: #3b82f6; }

    .dt-result { padding: 8px 12px; border-radius: 8px; font-size: .78rem; font-weight: 500; display: none; }
    .dt-result--ok  { background: rgba(16,185,129,.1); color: #6ee7b7; border: 1px solid rgba(16,185,129,.3); display: block; }
    .dt-result--err { background: rgba(239,68,68,.1); color: #fca5a5; border: 1px solid rgba(239,68,68,.3); display: block; }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">
    <div class="dt-shell">
        <!-- Action bar -->
        <div class="dt-action-bar" data-no-proxy>
            @if (selectedType is not null)
            {
                <button type="button" class="dt-btn dt-btn--primary" onclick="dtCreateBlank()" title="Yeni bos sablon olustur ve Designer'da ac">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Yeni Sablon
                </button>
                <label for="dtFrxFileInput" class="dt-btn dt-btn--secondary" style="cursor:pointer">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    .frx Yukle
                </label>
                <input type="file" id="dtFrxFileInput" accept=".frx" style="display:none" />
            }
        </div>

        <!-- Selector bar -->
        <div class="dt-selector-bar">
            <label for="dtTypeSelect">Belge Tipi:</label>
            <select id="dtTypeSelect" class="dt-select">
                @foreach (var dt in docTypes)
                {
                    if (selectedType?.Id == dt.Id)
                    {
                        <option value="@dt.Code" data-id="@dt.Id" selected="selected">@dt.Name</option>
                    }
                    else
                    {
                        <option value="@dt.Code" data-id="@dt.Id">@dt.Name</option>
                    }
                }
            </select>

            <div class="dt-designer-indicator" id="dtDesignerIndicator" title="Designer: Bagli degil">
                <span class="dt-dot"></span>
                <span id="dtDesignerLabel">Designer baglanti bekleniyor</span>
            </div>
        </div>

        <!-- Content: grid + upload -->
        <div class="dt-content">
            @if (selectedType is not null)
            {
                <div class="dt-grid-card">
                    <table class="dt-grid">
                        <thead>
                            <tr>
                                <th style="width:40px">#</th>
                                <th>Sablon Adi</th>
                                <th style="width:170px">View</th>
                                <th style="width:110px">Key Kolon</th>
                                <th style="width:90px">Boyut</th>
                                <th class="dt-col-default">Varsayilan</th>
                                <th class="dt-col-date">Olusturulma</th>
                                <th class="dt-col-actions">Islemler</th>
                            </tr>
                        </thead>
                        <tbody id="dtBody">
                            @if (templates.Any())
                            {
                                var idx = 0;
                                var defaultViewName = selectedType?.SqlViewName ?? string.Empty;
                                @foreach (var tpl in templates)
                                {
                                    idx++;
                                    var size = tpl.FrxContent?.Length ?? 0;
                                    var tplView = string.IsNullOrWhiteSpace(tpl.SqlViewName) ? defaultViewName : tpl.SqlViewName;
                                    var tplViewOverride = !string.IsNullOrWhiteSpace(tpl.SqlViewName);
                                    <tr data-id="@tpl.Id">
                                        <td class="dt-col-no">@idx</td>
                                        <td><span class="dt-name" data-id="@tpl.Id" title="Ismi duzenlemek icin tiklayin">@tpl.Name</span></td>
                                        <td style="font-size:.74rem;">
                                            <span class="dt-view-badge @(tplViewOverride ? "dt-view-badge--override" : "")"
                                                  title="@(tplViewOverride ? "Bu sablonun kendi view override'i" : "Belge tipinin default view'i")">
                                                @(string.IsNullOrWhiteSpace(tplView) ? "—" : tplView)
                                            </span>
                                        </td>
                                        <td style="font-size:.74rem;">
                                            <span class="dt-view-badge" title="Bu sablondan basim yaparken WHERE [kolon] = recordId kullanilir">
                                                @(string.IsNullOrWhiteSpace(tpl.KeyColumn) ? "auto" : tpl.KeyColumn)
                                            </span>
                                        </td>
                                        <td style="font-size:.74rem;opacity:.6">@(size > 0 ? $"{size / 1024.0:F1} KB" : "—")</td>
                                        <td class="dt-col-default">@if (tpl.IsDefault) { <span class="dt-default-dot" title="Varsayilan"></span> }</td>
                                        <td class="dt-col-date">@tpl.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td class="dt-col-actions">
                                            <button type="button" class="dt-row-btn dt-row-btn--preview" onclick="dtOpenPreview('@tpl.Id', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(tpl.Name)))" title="Onizle">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                            </button>
                                            <button type="button" class="dt-row-btn dt-row-btn--sources" onclick="dtManageSources('@tpl.Id', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(tpl.Name)), @tpl.DocumentTypeId)" title="Data Source'lari Yonet">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 11v6c0 1.66 4 3 9 3s9-1.34 9-3v-6"/></svg>
                                            </button>
                                            <button type="button" class="dt-row-btn dt-row-btn--designer" onclick="dtOpenInDesigner('@tpl.Id')" title="Designer'da Ac">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                                            </button>
                                            <button type="button" class="dt-row-btn dt-row-btn--output" onclick="dtOpenOutputOptions('@tpl.Id', @Html.Raw(System.Text.Json.JsonSerializer.Serialize(tpl.Name)))" title="Cikti Ayarlari">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                                            </button>
                                            @if (!tpl.IsDefault)
                                            {
                                                <button type="button" class="dt-row-btn dt-row-btn--default" onclick="dtSetDefault('@tpl.Id')" title="Varsayilan Yap">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                                </button>
                                            }
                                            <button type="button" class="dt-row-btn dt-row-btn--del" onclick="dtDelete('@tpl.Id')" title="Sil">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="8" class="dt-empty">Henuz sablon yok. Yukaridan yeni sablon olusturun veya .frx yukleyin.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Upload drop zone -->
                <div class="dt-upload" id="dtUploadArea">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="vertical-align:middle;margin-right:6px;opacity:.5;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <label for="dtFrxFileInput">.frx dosya sec</label>
                    veya surukle birak
                    <div style="font-size:.7rem;opacity:.6;margin-top:4px;">(Maks. 1 MB — DB'ye binary olarak saklanir)</div>
                </div>
            }
            else
            {
                <div class="dt-empty">Belge tipi bulunamadi.</div>
            }
        </div>
    </div>

    <!-- Mail modal -->
    <div id="dtMailModal" style="display:none;">
        <div class="dt-modal-backdrop" onclick="dtCloseMail()">
            <div class="dt-modal" onclick="event.stopPropagation()">
                <div class="dt-modal-header">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <div style="flex:1">
                        <div class="dt-modal-title">Sablon ile Mail Gonder</div>
                        <div class="dt-modal-sub" id="dtMailTemplateName"></div>
                    </div>
                    <button type="button" class="dt-modal-close" onclick="dtCloseMail()" title="Kapat">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                <div class="dt-modal-body">
                    <div class="dt-field">
                        <label for="dtMailTo">Alici (virgul ile ayirabilirsiniz) *</label>
                        <input type="text" id="dtMailTo" class="dt-input" placeholder="ornek@firma.com, digeri@firma.com" />
                    </div>
                    <div class="dt-field">
                        <label for="dtMailSubject">Konu *</label>
                        <input type="text" id="dtMailSubject" class="dt-input" />
                    </div>
                    <div class="dt-field">
                        <label for="dtMailRecordId">Kayit ID (opsiyonel — PDF olarak ekleyecegi kaynak kayit)</label>
                        <input type="text" id="dtMailRecordId" class="dt-input" placeholder="Guid bicimi — bos birakilirsa sadece mesaj gonderilir" />
                    </div>
                    <div class="dt-field">
                        <label for="dtMailBody">Mesaj</label>
                        <textarea id="dtMailBody" class="dt-textarea" placeholder="Mail govdesi..."></textarea>
                    </div>
                    <div class="dt-modal-hint">
                        Aktif SMTP profili mail ayarlarindan ayarlanir. Kayit ID doldurulduysa ilgili belge PDF olarak ek yapilir.
                    </div>
                    <div id="dtMailResult" class="dt-result"></div>
                </div>
                <div class="dt-modal-footer">
                    <button type="button" class="dt-btn dt-btn--secondary" onclick="dtCloseMail()">Iptal</button>
                    <button type="button" class="dt-btn dt-btn--primary" id="dtMailSendBtn" onclick="dtSendMail()">Gonder</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
(function () {
    var selectedTypeId = '@(selectedType?.Id.ToString() ?? "")';
    var currentMailTemplateId = null;

    function esc(s) { var d = document.createElement('div'); d.textContent = s == null ? '' : String(s); return d.innerHTML; }
    // JSON.stringify cift tirnakli string uretir; cift tirnakli HTML attribute
    // icinde (onclick="...") bu durum attribute'u erkenden kapatir ve
    // "Unexpected end of input" parse hatasina neden olur. &quot; ile escape
    // ederek HTML-guvenli JS literal ureten bir helper kullaniyoruz.
    function jsonEscape(s) { return JSON.stringify(s == null ? '' : String(s)).replace(/"/g, '&quot;'); }

    // ── Belge tipi degistir ───────────────────────────────────────
    var typeSelect = document.getElementById('dtTypeSelect');
    if (typeSelect) {
        typeSelect.addEventListener('change', function () {
            var opt = this.options[this.selectedIndex];
            selectedTypeId = opt.dataset.id;
            dtLoad();
        });
    }

    function dtLoad() {
        if (!selectedTypeId) return;
        fetch('/Document/Templates?documentTypeId=' + selectedTypeId, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) { renderGrid(data || []); })
            .catch(function () { renderGrid([]); });
    }

    function renderGrid(list) {
        var body = document.getElementById('dtBody');
        if (!body) return;
        if (list.length === 0) {
            body.innerHTML = '<tr><td colspan="8" class="dt-empty">Henuz sablon yok. Yukaridan yeni sablon olusturun veya .frx yukleyin.</td></tr>';
            return;
        }
        body.innerHTML = list.map(function (t, i) {
            var size = t.contentSize > 0 ? (t.contentSize / 1024).toFixed(1) + ' KB' : '—';
            var viewName = t.viewName || '';
            var viewBadgeCls = t.isViewOverride ? 'dt-view-badge dt-view-badge--override' : 'dt-view-badge';
            var viewTitle = t.isViewOverride ? 'Bu sablonun kendi view override\'i' : 'Belge tipinin default view\'i';
            var keyCol = t.keyColumn || '';
            return '<tr data-id="' + t.id + '">' +
                '<td class="dt-col-no">' + (i + 1) + '</td>' +
                '<td><span class="dt-name" data-id="' + t.id + '" title="Ismi duzenlemek icin tiklayin">' + esc(t.name) + '</span></td>' +
                '<td style="font-size:.74rem;"><span class="' + viewBadgeCls + '" title="' + esc(viewTitle) + '">' + esc(viewName || '—') + '</span></td>' +
                '<td style="font-size:.74rem;"><span class="dt-view-badge" title="WHERE [kolon] = recordId filtresi">' + esc(keyCol || 'auto') + '</span></td>' +
                '<td style="font-size:.74rem;opacity:.6">' + esc(size) + '</td>' +
                '<td class="dt-col-default">' + (t.isDefault ? '<span class="dt-default-dot" title="Varsayilan"></span>' : '') + '</td>' +
                '<td class="dt-col-date">' + esc(t.createdAt) + '</td>' +
                '<td class="dt-col-actions">' +
                    '<button type="button" class="dt-row-btn dt-row-btn--preview" onclick="dtOpenPreview(' + jsonEscape(t.id) + ',' + jsonEscape(t.name) + ')" title="Onizle">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>' +
                    '</button>' +
                    '<button type="button" class="dt-row-btn dt-row-btn--sources" onclick="dtManageSources(' + jsonEscape(t.id) + ',' + jsonEscape(t.name) + ',' + selectedTypeId + ')" title="Data Source\'lari Yonet">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v6c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 11v6c0 1.66 4 3 9 3s9-1.34 9-3v-6"/></svg>' +
                    '</button>' +
                    '<button type="button" class="dt-row-btn dt-row-btn--designer" onclick="dtOpenInDesigner(' + jsonEscape(t.id) + ')" title="Designer\'da Ac">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>' +
                    '</button>' +
                    '<button type="button" class="dt-row-btn dt-row-btn--output" onclick="dtOpenOutputOptions(' + jsonEscape(t.id) + ',' + jsonEscape(t.name) + ')" title="Cikti Ayarlari">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>' +
                    '</button>' +
                    (!t.isDefault ? '<button type="button" class="dt-row-btn dt-row-btn--default" onclick="dtSetDefault(' + jsonEscape(t.id) + ')" title="Varsayilan Yap">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
                    '</button>' : '') +
                    '<button type="button" class="dt-row-btn dt-row-btn--del" onclick="dtDelete(' + jsonEscape(t.id) + ')" title="Sil">' +
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>' +
                    '</button>' +
                '</td>' +
            '</tr>';
        }).join('');
    }

    // ── Upload ────────────────────────────────────────────────────
    var fileInput = document.getElementById('dtFrxFileInput');
    var uploadArea = document.getElementById('dtUploadArea');
    if (fileInput) {
        fileInput.addEventListener('change', function () {
            if (this.files.length > 0) uploadFile(this.files[0]);
            this.value = '';
        });
    }
    if (uploadArea) {
        uploadArea.addEventListener('dragover', function (e) { e.preventDefault(); this.classList.add('dragover'); });
        uploadArea.addEventListener('dragleave', function () { this.classList.remove('dragover'); });
        uploadArea.addEventListener('drop', function (e) {
            e.preventDefault(); this.classList.remove('dragover');
            if (e.dataTransfer.files.length > 0) uploadFile(e.dataTransfer.files[0]);
        });
    }

    async function uploadFile(file) {
        if (!file.name.toLowerCase().endsWith('.frx')) {
            dtShowToast('err', 'Gecersiz dosya', 'Sadece .frx dosyalari yuklenebilir.');
            setTimeout(dtHideToast, 3000);
            return;
        }
        if (file.size > 1_048_576) {
            dtShowToast('err', 'Dosya cok buyuk', 'Maks 1 MB olabilir.');
            setTimeout(dtHideToast, 3000);
            return;
        }
        var name = await dtPrompt({
            title:        'Yuklenecek Sablon',
            message:      'DB\'ye kaydedilecek sablona bir ad verin.',
            placeholder:  'Sablon adi',
            defaultValue: file.name.replace(/\.frx$/i, ''),
            okText:       'Yukle',
            cancelText:   'Iptal'
        });
        if (!name) return;
        dtShowToast('loading', 'Yukleniyor', 'Sablon DB\u0027ye kaydediliyor...');
        var fd = new FormData();
        fd.append('file', file);
        fd.append('documentTypeId', selectedTypeId);
        fd.append('name', name);
        fetch('/Document/Upload', { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d.success) {
                    dtShowToast('ok', 'Yuklendi', 'Yeni sablon eklendi.');
                    setTimeout(dtHideToast, 1400);
                    dtLoad();
                } else {
                    dtShowToast('err', 'Yukleme basarisiz', d.message || 'Bilinmeyen hata.');
                    setTimeout(dtHideToast, 3500);
                }
            })
            .catch(function (e) {
                dtShowToast('err', 'Yukleme hatasi', e && e.message ? e.message : 'Bilinmeyen hata.');
                setTimeout(dtHideToast, 3500);
            });
    }

