@model CalibraHub.Web.Models.Assets.AssetsSmartBoardViewModel
@{
    ViewData["Title"] = "Varlık Yönetimi";
    ViewData["FormCode"] = "ASSETS";
    ViewData["BodyClass"] = "page-assets";
    ViewData["DbInfo"] =
        "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>Asset</td><td style='padding:6px 8px;'>Varlık kartı (lokasyon/departman FK, durum, bakım & kalibrasyon takvimi, MachineId ile makine birleşimi)</td></tr>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>AssetEvent</td><td style='padding:6px 8px;'>Varlık geçmişi (bakım/kalibrasyon/onarım/zimmet hareketi/durum)</td></tr>"
        + "</table>";
}

@section Styles {
<style>
    .av-root { display:flex; flex-direction:column; height:100dvh; overflow:hidden; background:var(--app-bg, #f1f5f9); }
    body.page-assets, html { overflow:hidden; height:100%; }

    .av-tabs { display:flex; gap:2px; flex-shrink:0; padding:0 14px; border-bottom:1px solid var(--app-border, #e2e8f0); background:var(--app-surface, #fff); }
    body.app-theme-dark .av-tabs { background:#0d1323; border-bottom-color:rgba(255,255,255,.09); }
    .av-tab { display:flex; align-items:center; gap:8px; padding:13px 18px; font-size:13.5px; font-weight:600; cursor:pointer; border:none; background:none; color:var(--app-muted, #64748b); border-bottom:2.5px solid transparent; transition:all .12s; white-space:nowrap; }
    .av-tab svg { opacity:.8; }
    .av-tab:hover { color:var(--app-text, #0f172a); }
    body.app-theme-dark .av-tab:hover { color:#e2e8f0; }
    .av-tab.active { color:#6366f1; border-bottom-color:#6366f1; }
    body.app-theme-dark .av-tab.active { color:#a5b4fc; border-bottom-color:#a5b4fc; }

    .av-content { flex:1; min-height:0; position:relative; }
    .av-boards { position:absolute; inset:0; }
    .av-board { position:absolute; inset:0; display:none; overflow:hidden; }
    .av-board.active { display:block; }
    .av-loading { display:flex; align-items:center; justify-content:center; height:100%; color:var(--app-muted,#64748b); font-size:13px; }

    /* Edit/Zimmet formu — sekme şeridinin altında, iframe içinde */
    .av-editor { position:absolute; inset:0; display:none; background:var(--app-bg,#f1f5f9); }
    .av-editor.active { display:block; }
    .av-editor iframe { width:100%; height:100%; border:0; display:block; }
    .av-content.editing .av-boards { display:none; }

    /* Zimmet Raporu — sade tablo */
    .av-report { position:absolute; inset:0; display:flex; flex-direction:column; }
    .av-report-bar { flex-shrink:0; display:flex; align-items:center; gap:8px; padding:12px 18px; border-bottom:1px solid var(--app-border,#e2e8f0); background:var(--app-surface,#fff); }
    body.app-theme-dark .av-report-bar { background:#0d1323; border-bottom-color:rgba(255,255,255,.09); }
    .av-report-bar input { padding:8px 12px; border-radius:8px; border:1px solid var(--app-border,#e2e8f0); font-size:13px; min-width:240px; background:#fff; color:#0f172a; outline:none; }
    body.app-theme-dark .av-report-bar input { background:#0b1120; color:#e2e8f0; border-color:rgba(255,255,255,.12); }
    .av-rbtn { padding:7px 14px; border-radius:8px; border:1px solid var(--app-border,#e2e8f0); background:none; color:#64748b; font-size:12.5px; font-weight:600; cursor:pointer; }
    body.app-theme-dark .av-rbtn { border-color:rgba(255,255,255,.12); color:#94a3b8; }
    .av-rbtn.active { background:rgba(99,102,241,.1); color:#6366f1; border-color:rgba(99,102,241,.35); }
    .av-report-count { margin-left:auto; font-size:12px; color:#64748b; }
    .av-report-scroll { flex:1; overflow:auto; padding:0 18px 18px; }
    table.av-rtable { width:100%; border-collapse:collapse; font-size:12.5px; }
    table.av-rtable th { position:sticky; top:0; z-index:1; background:#fff; text-align:left; padding:10px 8px; color:#64748b; font-weight:700; border-bottom:2px solid var(--app-border,#e2e8f0); white-space:nowrap; }
    body.app-theme-dark table.av-rtable th { background:#0d1323; color:#94a3b8; border-bottom-color:rgba(255,255,255,.12); }
    table.av-rtable td { padding:9px 8px; border-bottom:1px solid var(--app-border,#eef2f7); color:#0f172a; vertical-align:top; }
    body.app-theme-dark table.av-rtable td { color:#e2e8f0; border-bottom-color:rgba(255,255,255,.06); }
    table.av-rtable tr:hover td { background:rgba(99,102,241,.05); }
    .av-rtable .muted { color:#94a3b8; }
    .av-rchip { display:inline-block; padding:1px 9px; border-radius:999px; font-size:10.5px; font-weight:700; }
    .av-rchip--on { background:rgba(59,130,246,.14); color:#2563eb; }
    .av-rchip--off { background:rgba(16,185,129,.14); color:#059669; }
    body.app-theme-dark .av-rchip--on  { color:#60a5fa; background:rgba(59,130,246,.18); }
    body.app-theme-dark .av-rchip--off { color:#34d399; background:rgba(16,185,129,.18); }
    .av-report-empty { padding:28px; text-align:center; color:#64748b; font-size:13px; }
    body.app-theme-dark .av-root { background: #080c17; }
    body.app-theme-dark .av-report { background: #080c17; }
    body.app-theme-dark .av-report-scroll { background: #080c17; }
    body.app-theme-dark .av-rbtn.active { background:rgba(165,180,252,.12); color:#a5b4fc; border-color:rgba(165,180,252,.35); }
</style>
}

<div class="av-root">
  <div class="av-tabs" role="tablist">
    <button class="av-tab active" data-board="def" type="button">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.27 6.96 12 12.01l8.73-5.05"/><path d="M12 22.08V12"/></svg>
      Varlık Tanımlama
    </button>
    <button class="av-tab" data-board="assign" type="button">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>
      Zimmetleme
    </button>
    <button class="av-tab" data-board="calib" type="button">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>
      Kalibrasyon Takibi
    </button>
    <button class="av-tab" data-board="maint" type="button">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      Bakım Takibi
    </button>
    <button class="av-tab" data-board="report" type="button">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/><line x1="8" y1="9" x2="10" y2="9"/></svg>
      Zimmet Raporu
    </button>
  </div>

  <div class="av-content">
    <div class="av-boards">
      <div class="av-board active" id="board-def"    data-url="/Assets/AssetsBoardConfig"></div>
      <div class="av-board"        id="board-assign" data-url="/Assets/AssignmentBoardConfig"></div>
      <div class="av-board"        id="board-calib"  data-url="/Assets/CalibrationBoardConfig"></div>
      <div class="av-board"        id="board-maint"  data-url="/Assets/MaintenanceBoardConfig"></div>
      <div class="av-board"        id="board-report"></div>
    </div>
    <div class="av-editor" id="av-editor">
      <iframe id="av-editor-frame" title="Varlık Formu"></iframe>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function () {
    var BUNDLE_URL = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js")';
    var CSS_URL    = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css")';
    var content = document.querySelector('.av-content');
    var editor  = document.getElementById('av-editor');
    var frame   = document.getElementById('av-editor-frame');

    function loadCss() {
        if (document.querySelector('link[data-assets-sb]')) return;
        var link = document.createElement('link'); link.rel = 'stylesheet'; link.href = CSS_URL;
        link.setAttribute('data-assets-sb', '1'); document.head.appendChild(link);
    }
    function ensureBundle(cb) {
        if (window.CalibraHub && window.CalibraHub.mountSmartBoard) { cb(); return; }
        var prev = document.querySelector('script[data-assets-sb]');
        if (prev) { prev.addEventListener('load', cb); return; }
        var s = document.createElement('script'); s.src = BUNDLE_URL; s.setAttribute('data-assets-sb', '1');
        s.onload = function () { setTimeout(cb, 0); };
        s.onerror = function () { console.error('[Assets] bundle yüklenemedi'); };
        document.head.appendChild(s);
    }

    var _boardHandles = {};
    function mountBoard(key) {
        var el = document.getElementById('board-' + key);
        if (!el || el.dataset.mounted === '1') return;
        el.dataset.mounted = '1';
        el.innerHTML = '<div class="av-loading">Yükleniyor…</div>';
        fetch(el.dataset.url, { credentials: 'same-origin', cache: 'no-store' })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (cfg) {
                el.innerHTML = '';
                if (!cfg) { el.innerHTML = '<div class="av-loading">Yüklenemedi.</div>'; return; }
                try { _boardHandles[key] = window.CalibraHub.mountSmartBoard(el, cfg); }
                catch (e) { console.error('[Assets] mount hata:', e); el.innerHTML = '<div class="av-loading">Hata: ' + (e.message || e) + '</div>'; }
            })
            .catch(function () { el.dataset.mounted = '0'; el.innerHTML = '<div class="av-loading">Bağlantı hatası.</div>'; });
    }

    // ── Zimmet Raporu (sade tablo, SmartBoard değil) ──
    var _reportRows = null, _reportFilter = 'all', _reportSearch = '';
    function mountReport() {
        var el = document.getElementById('board-report');
        if (!el || el.dataset.mounted === '1') return;
        el.dataset.mounted = '1';
        el.innerHTML = '<div class="av-loading">Yükleniyor…</div>';
        fetch('/Assets/AssignmentReportJson', { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (rows) { _reportRows = rows || []; renderReport(); })
            .catch(function () { el.dataset.mounted = '0'; el.innerHTML = '<div class="av-loading">Bağlantı hatası.</div>'; });
    }
    function renderReport() {
        var el = document.getElementById('board-report');
        if (!el || !_reportRows) return;
        function fmt(s) { if (!s) return ''; var d = new Date(s); return isNaN(d) ? '' : ('0'+d.getDate()).slice(-2)+'.'+('0'+(d.getMonth()+1)).slice(-2)+'.'+d.getFullYear(); }
        function esc(s) { return (s == null ? '' : String(s)).replace(/[&<>"]/g, function (c) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'})[c]; }); }
        var q = _reportSearch.trim().toLowerCase();
        var rows = _reportRows.filter(function (x) {
            if (_reportFilter === 'active' && x.returnDate) return false;
            if (!q) return true;
            return ((x.assetCode || '') + ' ' + (x.assetName || '') + ' ' + (x.personnelName || '')).toLowerCase().indexOf(q) !== -1;
        });
        var body = rows.map(function (x) {
            var on = !x.returnDate;
            return '<tr>'
                + '<td><b>' + esc(x.assetName) + '</b><div class="muted">' + esc(x.assetCode) + '</div></td>'
                + '<td>' + esc(x.personnelName || '—') + '</td>'
                + '<td>' + esc(x.departmentName || '—') + '</td>'
                + '<td>' + esc(x.locationName || '—') + '</td>'
                + '<td>' + fmt(x.assignDate) + '</td>'
                + '<td>' + (x.returnDate ? fmt(x.returnDate) : '<span class="muted">—</span>') + '</td>'
                + '<td><span class="av-rchip ' + (on ? 'av-rchip--on' : 'av-rchip--off') + '">' + (on ? 'Zimmette' : 'İade edildi') + '</span></td>'
                + '<td>' + esc(x.documentNo || '') + '</td>'
                + '<td>' + esc(x.assignNote || '') + (x.returnNote ? ' · ' + esc(x.returnNote) : '') + '</td>'
                + '</tr>';
        }).join('');
        el.innerHTML =
            '<div class="av-report">'
          + '  <div class="av-report-bar">'
          + '    <input id="av-rsearch" placeholder="Ara… (varlık / personel)" value="' + esc(_reportSearch) + '" />'
          + '    <button class="av-rbtn ' + (_reportFilter === 'all' ? 'active' : '') + '" data-f="all">Tümü</button>'
          + '    <button class="av-rbtn ' + (_reportFilter === 'active' ? 'active' : '') + '" data-f="active">Aktif (zimmette)</button>'
          + '    <span class="av-report-count">' + rows.length + ' kayıt</span>'
          + '  </div>'
          + '  <div class="av-report-scroll">'
          + (rows.length
              ? '<table class="av-rtable"><thead><tr><th>Varlık</th><th>Zimmetli Personel</th><th>Departman</th><th>Lokasyon</th><th>Zimmet Tarihi</th><th>İade Tarihi</th><th>Durum</th><th>Belge No</th><th>Not</th></tr></thead><tbody>' + body + '</tbody></table>'
              : '<div class="av-report-empty">Kayıt yok.</div>')
          + '  </div>'
          + '</div>';
        var si = document.getElementById('av-rsearch');
        if (si) si.addEventListener('input', function () { var pos = si.selectionStart; _reportSearch = si.value; renderReport(); var ns = document.getElementById('av-rsearch'); if (ns) { ns.focus(); try { ns.setSelectionRange(pos, pos); } catch (e) {} } });
        Array.prototype.forEach.call(el.querySelectorAll('.av-rbtn'), function (b) { b.addEventListener('click', function () { _reportFilter = b.getAttribute('data-f'); renderReport(); }); });
    }
    function mountTab(key) {
        if (key === 'report') { mountReport(); return; }
        mountBoard(key);
    }

    function remountBoard(key) {
        if (key === 'report') {
            // Zimmet Raporu — DOM tabanlı, direkt yeniden fetch
            var rep = document.getElementById('board-report');
            if (rep) { rep.dataset.mounted = '0'; _reportRows = null; }
            mountReport();
            return;
        }
        // SmartBoard — handle varsa refresh() kullan (React root korunur, DOM temizlenmez)
        var el = document.getElementById('board-' + key);
        if (_boardHandles[key] && typeof _boardHandles[key].refresh === 'function' && el) {
            fetch(el.dataset.url, { credentials: 'same-origin', cache: 'no-store' })
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (cfg) { if (cfg) _boardHandles[key].refresh(cfg); })
                .catch(function () {});
            return;
        }
        // Fallback: tam yeniden mount
        if (el) { el.dataset.mounted = '0'; el.innerHTML = ''; }
        mountTab(key);
    }
    function activeKey() {
        var b = document.querySelector('.av-tab.active');
        return b ? b.dataset.board : 'def';
    }

    function showBoard(key) {
        document.querySelectorAll('.av-tab').forEach(function (b) { b.classList.toggle('active', b.dataset.board === key); });
        document.querySelectorAll('.av-board').forEach(function (p) { p.classList.toggle('active', p.id === 'board-' + key); });
        mountTab(key);
    }

    // ── Edit/Zimmet iframe (sekme şeridi korunur) ──
    function openEditor(url) {
        frame.src = url;
        editor.classList.add('active');
        content.classList.add('editing');
    }
    function hideEditor() {
        editor.classList.remove('active');
        content.classList.remove('editing');
        frame.src = 'about:blank';
    }
    function clearHash() {
        if (location.hash) { try { history.replaceState(null, '', location.pathname + location.search); } catch (e) { location.hash = ''; } }
    }
    // Formlar (iframe) buradan çağırır: kapat + (gerekirse) aktif board'u yenile
    window.AssetContainer = {
        closeEditor: function (refresh) {
            hideEditor(); clearHash();
            if (refresh) remountBoard(activeKey());
        }
    };

    function handleHash() {
        // SmartBoard başlık aksiyonu navigateInWorkspace ile hash'e ?workspace=1 ekleyebilir
        // (örn. #asset-new?workspace=1) → query kısmını ayıkla.
        var h = (location.hash || '').replace(/\?.*$/, ''), m;
        if (h === '#asset-new') { openEditor('/Assets/AssetEdit?workspace=1'); return; }
        if (h === '#asset-bulk-assign') { openEditor('/Assets/BulkAssign?workspace=1'); return; }
        if ((m = h.match(/^#asset-edit-a(\d+)$/)))  { openEditor('/Assets/AssetEdit?id=' + m[1] + '&workspace=1'); return; }
        if ((m = h.match(/^#asset-edit-m(\d+)$/)))  { openEditor('/Assets/AssetEdit?machineId=' + m[1] + '&workspace=1'); return; }
        if ((m = h.match(/^#asset-assign-(\d+)$/))) { openEditor('/Assets/AssetAssign?id=' + m[1] + '&workspace=1'); return; }
        if ((m = h.match(/^#asset-maint-(\d+)$/)))  { openEditor('/Assets/AssetMaintenance?id=' + m[1] + '&mode=maint&workspace=1'); return; }
        if ((m = h.match(/^#asset-calib-(\d+)$/)))  { openEditor('/Assets/AssetMaintenance?id=' + m[1] + '&mode=calib&workspace=1'); return; }
        hideEditor(); // bilinmeyen/boş hash → board'a dön
    }
    window.addEventListener('hashchange', handleHash);

    // Tab tıklaması: edit açıksa kapat, board'a geç
    document.querySelectorAll('.av-tab').forEach(function (btn) {
        btn.addEventListener('click', function () {
            if (content.classList.contains('editing')) { hideEditor(); clearHash(); remountBoard(btn.dataset.board); }
            showBoard(btn.dataset.board);
        });
    });

    loadCss();
    ensureBundle(function () {
        mountBoard('def');
        if (location.hash) handleHash(); // derin link ile gelindiyse formu aç
    });

    window.addEventListener('pageshow', function (e) { if (e.persisted) location.reload(); });
})();
</script>
}
