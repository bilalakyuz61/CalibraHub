            </header>
            <div style="padding:16px 20px;display:flex;flex-direction:column;gap:12px;overflow:auto;">
                <input type="hidden" id="cpFldId" value="" />
                <div class="ca-row">
                    <label class="ca-label" for="cpFldTitleId">Ünvan <span class="required">*</span></label>
                    <div style="display:flex;gap:6px;align-items:stretch;">
                        <select id="cpFldTitleId" class="ca-input" style="flex:1 1 auto;min-width:0;">
                            <option value="">Seçiniz…</option>
                        </select>
                        <button type="button" id="cpFldTitleAddBtn" class="ca-btn"
                                style="flex:0 0 auto;padding:0 12px;white-space:nowrap;"
