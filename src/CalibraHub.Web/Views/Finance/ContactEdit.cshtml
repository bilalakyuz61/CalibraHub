    </div>

    <input type="hidden" id="caId" value="@(existing?.Id.ToString() ?? "")" />

    <!-- İletişim Kişisi modalı (ekle/düzenle) -->
    <div id="cpModalBackdrop" class="ca-grid-modal-backdrop" style="display:none;">
        <div class="ca-grid-modal" role="dialog" aria-modal="true" aria-labelledby="cpModalTitle">
            <header>
                <span id="cpModalTitle" class="ca-grid-modal__title">İletişim Kişisi</span>
