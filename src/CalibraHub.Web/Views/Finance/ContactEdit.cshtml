                        <button type="button" id="cpFldTitleManageBtn" class="ca-btn"
                                style="flex:0 0 auto;padding:0 12px;white-space:nowrap;"
                                title="Mevcut ünvanları yönet (sil/pasifleştir)">Yönet</button>
                    </div>
                </div>
                <div class="ca-row">
                    <label class="ca-label" for="cpFldFullName">Ad Soyad <span class="required">*</span></label>
                    <input id="cpFldFullName" type="text" class="ca-input" maxlength="150" placeholder="Ad Soyad" />
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="ca-row">
                        <label class="ca-label" for="cpFldPhone">Telefon</label>
                        <input id="cpFldPhone" type="text" class="ca-input" maxlength="40" placeholder="+90 5XX XXX XXXX" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="cpFldEmail">E-posta</label>
                        <input id="cpFldEmail" type="email" class="ca-input" maxlength="200" placeholder="ornek@firma.com" />
                    </div>
                </div>
                <div class="ca-row">
                    <label class="ca-label" for="cpFldNotes">Not</label>
                    <textarea id="cpFldNotes" class="ca-input" rows="2" maxlength="1000" placeholder="(opsiyonel) eklemek istediğiniz not"></textarea>
                </div>
                <div style="display:flex;gap:18px;align-items:center;padding:2px 0;">
                    <label class="cp-switch">
                        <input type="checkbox" id="cpFldIsPrimary" />
                        <span class="cp-switch__track"><span class="cp-switch__thumb"></span></span>
                        <span class="cp-switch__label">Birincil iletişim</span>
                    </label>
                    <label class="cp-switch">
                        <input type="checkbox" id="cpFldIsActive" checked />
                        <span class="cp-switch__track"><span class="cp-switch__thumb"></span></span>
                        <span class="cp-switch__label">Aktif</span>
                    </label>
                </div>
                <div id="cpModalErr" style="display:none;padding:8px 12px;border-radius:8px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#f87171;font-size:.78rem;"></div>
            </div>
            <footer style="padding:12px 20px;border-top:1px solid rgba(255,255,255,0.08);display:flex;justify-content:flex-end;gap:8px;">
                <button type="button" id="cpModalCancel" class="ca-btn">Vazgeç</button>
                <button type="button" id="cpModalSave" class="ca-btn ca-btn--primary">Kaydet</button>
            </footer>
        </div>
    </div>

    <!-- Yeni ünvan ekle modalı (ortalı) — prompt() yerine -->
    <div id="cpTitleAddBackdrop" class="ca-grid-modal-backdrop" style="display:none;">
        <div class="ca-grid-modal" role="dialog" aria-modal="true" style="width:min(420px,92vw);">
            <header>
                <span class="ca-grid-modal__title">Yeni Ünvan Ekle</span>
            </header>
            <div style="padding:18px 20px;display:flex;flex-direction:column;gap:10px;">
                <label class="ca-label" for="cpTitleAddName">Ünvan Adı <span class="required">*</span></label>
                <input id="cpTitleAddName" type="text" class="ca-input" maxlength="100" placeholder="Örn: Pazarlama Direktörü" autocomplete="off" />
                <div id="cpTitleAddErr" style="display:none;padding:8px 12px;border-radius:8px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);color:#f87171;font-size:.78rem;"></div>
            </div>
            <footer style="padding:12px 20px;border-top:1px solid rgba(255,255,255,0.08);display:flex;justify-content:flex-end;gap:8px;">
                <button type="button" id="cpTitleAddCancel" class="ca-btn">Vazgeç</button>
                <button type="button" id="cpTitleAddOk" class="ca-btn ca-btn--primary">Ekle</button>
            </footer>
        </div>
    </div>

    <!-- Ünvanları yönet modalı (liste + sil) -->
    <div id="cpTitleManageBackdrop" class="ca-grid-modal-backdrop" style="display:none;">
        <div class="ca-grid-modal" role="dialog" aria-modal="true" style="width:min(540px,95vw);max-height:80vh;">
            <header>
                <span class="ca-grid-modal__title">Ünvanları Yönet</span>
                <button type="button" id="cpTitleManageClose" class="ca-btn" style="font-size:.74rem;padding:4px 10px;">Kapat</button>
            </header>
            <div style="padding:14px 20px;overflow:auto;flex:1 1 auto;">
                <div style="font-size:.78rem;color:rgba(255,255,255,0.55);margin-bottom:10px;">
                    Kullanılmayan ünvanlar silinebilir. Sistem ünvanları (★) silinemez ama pasif yapılabilir.
                </div>
                <table style="width:100%;border-collapse:separate;border-spacing:0;font-size:.84rem;">
                    <thead>
                        <tr>
                            <th class="cp-grid__th">Ünvan</th>
                            <th class="cp-grid__th" style="width:90px;text-align:center;">Sistem</th>
                            <th class="cp-grid__th" style="width:80px;text-align:right;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="cpTitleManageList">
                        <tr><td colspan="3" style="padding:14px;color:rgba(255,255,255,0.55);text-align:center;">Yükleniyor…</td></tr>
                    </tbody>
                </table>
            </div>
