    </div>

    <!-- Silme onay modalı (ortalı, danger) -->
    <div id="cpConfirmBackdrop" class="ca-grid-modal-backdrop" style="display:none;">
        <div class="ca-grid-modal" role="dialog" aria-modal="true" style="width:min(440px,92vw);">
            <header style="color:#f87171;">
                <span class="ca-grid-modal__title">İletişim Kişisini Sil</span>
            </header>
            <div style="padding:18px 20px;">
                <div id="cpConfirmMsg" style="font-size:.86rem;color:rgba(255,255,255,0.88);line-height:1.5;">
                    Bu iletişim kişisini silmek istediğinize emin misiniz?
                </div>
            </div>
            <footer style="padding:12px 20px;border-top:1px solid rgba(255,255,255,0.08);display:flex;justify-content:flex-end;gap:8px;">
                <button type="button" id="cpConfirmCancel" class="ca-btn">Vazgeç</button>
                <button type="button" id="cpConfirmOk" class="ca-btn" style="background:#dc2626;color:#fff;border-color:#dc2626;">Sil</button>
            </footer>
        </div>
    </div>

</section>

@section Scripts {
<script>
(function () {
    var UPSERT_URL  = '@Html.Raw(upsertUrl)';
    var LIST_URL    = '@Html.Raw(listUrl)';
    var existingId  = document.getElementById('caId').value;

    var saveBtn = document.getElementById('caSaveBtn');

    // Ana kayıt silme
    var deleteBtn = document.getElementById('ptBtnDelete');
    if (deleteBtn) {
        deleteBtn.addEventListener('click', async function () {
            var id = parseInt(document.getElementById('caId').value || '0', 10);
            if (!id) return;
            if (window.CalibraAlert && CalibraAlert.confirm) {
                var ok = await CalibraAlert.confirm('Bu cari hesap silinsin mi?', { title: 'Cari Sil', okText: 'Evet, Sil', cancelText: 'İptal', danger: true });
                if (!ok) return;
            }
            try {
                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                var r = await fetch('/Finance/DeleteContactJson?id=' + id, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token ? token.value : '' },
                    credentials: 'same-origin',
                });
                var data = await r.json();
                if (!data.success) { if (window.CalibraAlert) CalibraAlert.error(data.message || 'Silinemedi'); return; }
                location.replace('/Finance/Contacts');
            } catch (e) {
                if (window.CalibraAlert) CalibraAlert.error('Silme hatası: ' + e.message);
            }
        });
    }

    // Bilgilendirme: ekranda yer kaplamayan, ortalanmis modal kullan.
    // Basari durumunda zaten KITT yesil tarayici var, ek mesaj cikmasin.
    function showMsg(text, ok) {
        if (ok) return; // basari mesajini bastir
        if (window.CalibraAlert && CalibraAlert.error) {
            CalibraAlert.error(text);
            return;
        }
        // Fallback (CalibraAlert yuklenmemisse) — eski davranis
        return showMsgLegacy(text, ok);
    }
    function showMsgLegacy(text, ok) {
        var m = document.getElementById('caMsg');
        m.textContent = text;
        m.className = 'ca-message ' + (ok ? 'ok' : 'err');
        setTimeout(function () { m.className = 'ca-message'; m.textContent = ''; }, 4000);
    }

    // K.I.T.T. yesil tarayici (aksiyon seridi alti) — basariyla kayit edilince
    function flashSuccess() {
        var bar = document.getElementById('caActionBar');
        if (!bar) return;
        bar.classList.remove('is-save-flash');
        void bar.offsetWidth;
        bar.classList.add('is-save-flash');
        setTimeout(function () { bar.classList.remove('is-save-flash'); }, 1850);
        try { if (window.CalibraDirty) window.CalibraDirty.clear(); } catch (e) {}
    }

    function markInvalid(ids) {
        ids.forEach(function (id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.classList.remove('is-invalid');
            void el.offsetWidth;
            el.classList.add('is-invalid');
            var clear = function () {
                el.classList.remove('is-invalid');
                el.removeEventListener('input', clear);
                el.removeEventListener('change', clear);
            };
            el.addEventListener('input', clear);
            el.addEventListener('change', clear);
        });
        var first = document.getElementById(ids[0]);
        if (first) first.focus({ preventScroll: false });
    }

    window.caBackToList = function () {
        var url = LIST_URL;
        if (location.search.indexOf('workspace=1') !== -1 && url.indexOf('workspace=1') === -1) {
            url += (url.indexOf('?') !== -1 ? '&' : '?') + 'workspace=1';
        }
        location.replace(url);
    };

    function getVal(id) {
        var el = document.getElementById(id);
        return el ? el.value.trim() : '';
    }

    /**
     * Cari Kod ekran-seviyesi primary key handler — IN-PLACE AJAX FILL (sayfa reload yok).
     *
     * Davranis:
     *   - Kod yazip blur/Enter/Tab ile ayrildiginda DB'de lookup yapilir
     *   - VAR ise: tum form alanlari AJAX ile yerinde doldurulur (parlama/grid shift yok),
     *     URL history.pushState ile ?id=X olur, baslik guncellenir, yan paneller refresh edilir
     *   - YOK ise:
     *     * Yeni mod ise (existing yok): sessizce kalir
     *     * Edit mod ise: "Yeni cari?" sor → in-place clear + URL ?new=1&code=X
     *   - Bos veya degismemis (data-original ile ayni) kod: hicbir sey yapilmaz
     */
    (function attachAccountCodePrimaryKeyLookup() {
        var codeInput = document.getElementById('accountCode');
        if (!codeInput) return;
        var lookupInFlight = false;
        var lastChecked = '';

        // Form'daki tum alanlari id'leri ile data'dan doldur (in-place fill).
        // Yan paneller (Adresler/Stok/Hareket) icin event dispatch et — kendileri refresh eder.
        function fillFormFields(c) {
            function setVal(id, v) {
                var el = document.getElementById(id);
                if (!el) return;
                if (el.tagName === 'SELECT') {
                    el.value = v == null ? '' : String(v);
                    try { el.dispatchEvent(new Event('change', { bubbles: true })); } catch (_) {}
                } else if (el.type === 'checkbox') {
                    el.checked = !!v;
                } else {
                    el.value = v == null ? '' : String(v);
                }
            }
            // Temel
            setVal('accountCode',    c.accountCode);
            setVal('accountTitle',   c.accountTitle);
            setVal('accountType',    c.accountType);
            setVal('taxOffice',      c.taxOffice);
            setVal('taxNumber',      c.taxNumber);
            setVal('identityNumber', c.identityNumber);
            setVal('contactPerson',  c.contactPerson);
            // Iletisim
            setVal('phone',          c.phone);
            setVal('mobile',         c.mobile);
            setVal('waPhone',        c.waPhone);
            setVal('waName',         c.waName);
            setVal('email',          c.email);
            setVal('website',        c.website);
            // Adres
            setVal('countryCode',    c.countryCode);
            setVal('city',           c.city);
            setVal('district',       c.district);
            setVal('neighborhood',   c.neighborhood);
            setVal('postalCode',     c.postalCode);
            setVal('address',        c.address);
            // Selects (DOM mevcutsa otomatik)
            if (c.salesRepId != null)     setVal('salesRepId',     c.salesRepId);
            if (c.contactGroupId != null) setVal('contactGroupId', c.contactGroupId);
            // Hidden Id + data-original guncelle (sonraki lookup'lar dogru cevirsin)
            var caId = document.getElementById('caId');
            if (caId) caId.value = c.id;
            codeInput.setAttribute('data-original', c.accountCode);
            lastChecked = c.accountCode;
            // Sayfa basligi + uygulama tab basligi
            document.title = 'Cari Düzenle — ' + c.accountCode;
            var titleHost = document.querySelector('.workspace-title, h1.page-title');
            if (titleHost) titleHost.textContent = c.accountCode + ' — ' + (c.accountTitle || '');
            // Yan paneller event ile haberdar olsun (Adresler/Stok/Hareket vb. kendi kendine refresh)
            try {
                window.dispatchEvent(new CustomEvent('ca:contactSwitched', {
                    detail: { id: c.id, code: c.accountCode, title: c.accountTitle }
                }));
            } catch (_) {}
        }

        function clearFormFieldsForNew(code) {
            // Yeni cari modu — kullanicinin yazdigi kod kalir, gerisi temizlenir
            var keepCode = code || '';
            ['accountTitle','taxOffice','taxNumber','identityNumber','contactPerson',
             'phone','mobile','waPhone','waName','email','website',
             'city','district','neighborhood','postalCode','address']
            .forEach(function (id) {
                var el = document.getElementById(id);
                if (el) el.value = '';
            });
            var caId = document.getElementById('caId');
            if (caId) caId.value = '';
            codeInput.value = keepCode;
            codeInput.setAttribute('data-original', '');
            lastChecked = keepCode;
            document.title = 'Yeni Cari Hesap';
            try {
                window.dispatchEvent(new CustomEvent('ca:contactReset', {
                    detail: { code: keepCode }
                }));
            } catch (_) {}
        }

        async function doLookup() {
            if (lookupInFlight) return;
            var code = (codeInput.value || '').trim();
            var original = codeInput.getAttribute('data-original') || '';
            if (!code || code === original || code === lastChecked) return;
            lastChecked = code;
            lookupInFlight = true;

            try {
                var r = await fetch('/Finance/GetContact?code=' + encodeURIComponent(code),
                    { credentials: 'same-origin' });

                if (r.ok) {
                    // ── BULDU ── In-place fill + URL pushState (NO reload, NO flash)
                    var c = await r.json();
                    if (!c || !c.id) return;
                    fillFormFields(c);
                    // URL'i guncelle: workspace=1 query'i koru
                    var newUrl = '/Finance/ContactEdit?id=' + c.id;
                    if (location.search.indexOf('workspace=1') !== -1) newUrl += '&workspace=1';
                    try { history.pushState({ contactId: c.id }, '', newUrl); } catch (_) {}
                    if (window.CalibraHub && CalibraHub.toast)
                        CalibraHub.toast('Cari yuklendi: ' + c.accountCode, 'ok');
                    return;
                }

                if (r.status === 404) {
                    // Bulunamadi — formu yeni cari icin temizle (kodu koru)
                    clearFormFieldsForNew(code);
                }
            } catch (e) {
                if (window.CalibraHub && CalibraHub.toast)
                    CalibraHub.toast('Cari lookup hatasi: ' + e.message, 'err');
            } finally {
                lookupInFlight = false;
            }
        }

        codeInput.addEventListener('blur', doLookup);
        codeInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' || e.key === 'Tab') {
                if (e.key === 'Enter') e.preventDefault();
                doLookup();
            }
        });
    })();

    // WhatsApp "Sohbeti Aç" butonu — waPhone alanını WhatsApp sayfasına query string olarak gönderir
    // Rapor §6.6 — native alert → CalibraAlert.warn (toast fallback)
    function _waChatNotify(msg) {
        if (window.CalibraAlert && CalibraAlert.warn) CalibraAlert.warn(msg);
        else if (window.CalibraHub && CalibraHub.toast) CalibraHub.toast(msg, 'warn');
        else alert(msg);
    }
    var waOpenBtn = document.getElementById('waOpenChat');
    if (waOpenBtn) {
        waOpenBtn.addEventListener('click', function () {
            var raw = getVal('waPhone');
            if (!raw) {
                _waChatNotify('Önce WhatsApp Numarası alanını doldur ve kaydet.');
                var waInp = document.getElementById('waPhone');
                if (waInp) waInp.focus();
                return;
            }
            var digits = raw.replace(/[^\d]/g, '');
            if (digits.length < 10) {
                _waChatNotify('WhatsApp numarası en az 10 rakam içermeli (ülke kodu dahil).');
                return;
            }
            // Yeni sekmede aç ki müşteri kartı kaybolmasın
            window.open('/Whatsapp?phone=' + encodeURIComponent(digits), '_blank', 'noopener');
        });
    }

    saveBtn.addEventListener('click', function () {
        var accountCode  = getVal('accountCode');
        var accountTitle = getVal('accountTitle');
        var accountType  = parseInt(getVal('accountType'), 10);

        var invalidIds = [];
        if (!accountCode)  invalidIds.push('accountCode');
        if (!accountTitle) invalidIds.push('accountTitle');

        // Hata varsa ilgili bolume git
        if (invalidIds.length > 0) {
            if (window.caNavigateToSection) window.caNavigateToSection('basic');
            markInvalid(invalidIds);
            return;
        }

        // Ek alan (widget) zorunlu kontrolu
        var allValid = true;
        if (window._caDynRenderer && window._caDynRenderer.validate) {
            var dynValidation = window._caDynRenderer.validate();
            if (!dynValidation.valid) {
                allValid = false;
                var firstErrId = (dynValidation.errorIds || [])[0];
                if (firstErrId && window.caNavigateToSection) {
                    var errEl = document.querySelector('[data-widget-code="' + firstErrId + '"]');
                    if (errEl) {
                        var grpEl = errEl.closest('[data-dyn-group-id]');
                        var gid   = grpEl ? grpEl.getAttribute('data-dyn-group-id') : null;
                        if (gid) window.caNavigateToSection(gid);
                    }
                }
            }
        }
        if (!allValid) return;

        var payload = {
            id:             existingId ? parseInt(existingId, 10) : null,
            accountType:    accountType || 1,
            accountCode:    accountCode,
            accountTitle:   accountTitle,
            taxNumber:      getVal('taxNumber')      || null,
            identityNumber: getVal('identityNumber') || null,
            taxOffice:      getVal('taxOffice')      || null,
            contactPerson:  getVal('contactPerson')  || null,
            phone:          getVal('phone')          || null,
            mobile:         getVal('mobile')         || null,
            waPhone:        getVal('waPhone')        || null,
            waName:         getVal('waName')         || null,
            email:          getVal('email')          || null,
            website:        getVal('website')        || null,
            address:        getVal('address')        || null,
            postalCode:     getVal('postalCode')     || null,
            city:           getVal('city')           || null,
            district:       getVal('district')       || null,
            neighborhood:   getVal('neighborhood')   || null,
            countryCode:    (getVal('countryCode') || '').toUpperCase() || null,
            isActive:       document.getElementById('isActive').checked,
            priceGroupId:   null,
            salesRepresentativeId: (function() {
                var v = document.getElementById('salesRepresentativeId');
                var n = v ? parseInt(v.value, 10) : 0;
                return n > 0 ? n : null;
            })(),
            contactGroupId: (function() {
                var v = document.getElementById('contactGroupId');
                var n = v ? parseInt(v.value, 10) : 0;
                return n > 0 ? n : null;
            })()
        };

        saveBtn.classList.add('loading');
        saveBtn.disabled = true;

        fetch(UPSERT_URL, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body:    JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (!(data && data.success)) {
                saveBtn.classList.remove('loading');
                saveBtn.disabled = false;
                showMsg('Hata: ' + (data && data.message ? data.message : 'Bilinmeyen hata.'), false);
                return;
            }

            var newRecordId = String((data.account && data.account.id) || document.getElementById('caId').value || '');
            var dynPromise = (window._caDynRenderer && newRecordId)
                ? window._caDynRenderer.save({ recordId: newRecordId })
                    .catch(function (err) {
                        console.warn('[CA] widget save hatasi:', err);
                        return { success: false, message: err.message };
                    })
                : Promise.resolve({ success: true });

            // Hiyerarsik grup mapping'lerini de kaydet (Gruplar tab acildiysa)
            var groupsPromise = (typeof window.caGroupsSave === 'function' && newRecordId)
                ? window.caGroupsSave(newRecordId)
                    .catch(function (err) {
                        console.warn('[CA] groups save hatasi:', err);
                        return { success: false, message: err.message };
                    })
                : Promise.resolve({ success: true });

            Promise.all([dynPromise, groupsPromise]).then(function (results) {
                saveBtn.classList.remove('loading');
                saveBtn.disabled = false;
                var dynRes = results[0], grpRes = results[1];
                if (dynRes && dynRes.success === false) {
                    console.warn('[CA] widget save basarisiz:', dynRes.message);
                }
                if (grpRes && grpRes.success === false) {
                    console.warn('[CA] groups save basarisiz:', grpRes.message);
                }
                // Sadece KITT yesil tarayici — text bildirim yok, otomatik redirect yok.
                flashSuccess();
            });
        })
        .catch(function (err) {
            saveBtn.classList.remove('loading');
            saveBtn.disabled = false;
            showMsg('Bağlantı hatası: ' + err.message, false);
        });
    });

    // ── Sidebar navigasyon — tab-panel modeli ─────────────────────────
    (function initSideNav() {
        var sidenav = document.getElementById('caSideNav');
        var content = document.getElementById('caContent');
        var dynCard = document.getElementById('caDynamicWidgetsCard');
        if (!sidenav || !content) return;

        var _activeKey = 'basic';

        function setActive(btn) {
            sidenav.querySelectorAll('.ca-nav-btn').forEach(function (b) {
                b.classList.remove('is-active');
            });
            if (btn) btn.classList.add('is-active');
        }

        function activateSection(key) {
            _activeKey = key;

            // Statik kartlar
            content.querySelectorAll('[data-section]').forEach(function (card) {
                card.style.display = (card.getAttribute('data-section') === key) ? '' : 'none';
            });

            // Dinamik widget gruplari
            content.querySelectorAll('[data-dyn-group-id]').forEach(function (d) {
                d.style.display = (d.getAttribute('data-dyn-group-id') === key) ? 'block' : 'none';
            });
        }

        // Statik nav butonlari — data-nav-key ile eslestir
        sidenav.querySelectorAll('.ca-nav-btn[data-nav-key]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                setActive(btn);
                activateSection(btn.getAttribute('data-nav-key'));
            });
        });

        // Widget gruplarini tarayip nav butonlari olustur
        function buildGroupNav() {
            sidenav.querySelectorAll('[data-group-nav]').forEach(function (el) { el.remove(); });

            var groups = content.querySelectorAll('[data-dyn-group-id]');
            if (!groups.length) return;

            var lbl = document.createElement('span');
            lbl.className = 'ca-sidenav-label';
            lbl.setAttribute('data-group-nav', '__label');
            lbl.textContent = 'Ek Sahalar';
            sidenav.appendChild(lbl);

            groups.forEach(function (detail) {
                var gid   = detail.getAttribute('data-dyn-group-id') || '';
                var title = detail.getAttribute('data-dyn-group-label') || 'Grup';

                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'ca-nav-btn';
                btn.setAttribute('data-group-nav', gid);
                btn.title = title;
                btn.innerHTML =
                    '<span class="ca-nav-dot"></span>' +
                    '<span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0">' +
                    title + '</span>';

                btn.addEventListener('click', function () {
                    setActive(btn);
                    activateSection(gid);
                });

                sidenav.appendChild(btn);
            });

            activateSection(_activeKey);
        }

        // DynamicWidgetsCard icinde data-dyn-group-id elementleri belirince nav'i yenile
        if (dynCard) {
            var _t = null;
            function scheduleScan() {
                clearTimeout(_t);
                _t = setTimeout(function () {
                    var groups = content.querySelectorAll('[data-dyn-group-id]');
                    if (groups.length > 0) {
                        buildGroupNav();
                    } else {
                        var tries = (scheduleScan._n = (scheduleScan._n || 0) + 1);
                        if (tries < 80) scheduleScan();
                        else scheduleScan._n = 0;
                    }
                }, 50);
            }

            var _obs = new MutationObserver(function () { scheduleScan(); });
            _obs.observe(dynCard, { childList: true, subtree: true, attributes: true,
                                    attributeFilter: ['style', 'data-dyn-group-id'] });
            if (dynCard.parentElement) {
                _obs.observe(dynCard.parentElement, { childList: false, subtree: false,
                                                      attributes: true, attributeFilter: ['style'] });
            }
        }

        // Baslangic: Temel Bilgiler aktif
        activateSection('basic');

        // Dis erisim: save validasyonu hata bolumune gidebilsin
        window.caNavigateToSection = function (key) {
            var navBtn = sidenav.querySelector('[data-nav-key="' + key + '"]') ||
                         sidenav.querySelector('[data-group-nav="' + key + '"]');
            setActive(navBtn || null);
            activateSection(key);
        };
    })();

    // ── Ek alanlar renderer'ini mount et (WidgetMas/WidgetTra) ──
    (function initDynRenderer() {
        var el = document.getElementById('caDynamicWidgets');
        if (!el) return;

        function doMount() {
            if (!window.CalibraHub || !window.CalibraHub.mountDynamicWidgetRenderer) {
                console.warn('[CA] mountDynamicWidgetRenderer bulunamadi');
                return;
            }
            try {
                window._caDynRenderer = window.CalibraHub.mountDynamicWidgetRenderer(el, {
                    formCode: el.getAttribute('data-form-code') || 'CONTACTS',
                    recordId: el.getAttribute('data-record-id') || '',
                    classPrefix: 'ca',
                    containerId: 'caDynamicWidgetsCard'
                });
            } catch (e) { console.warn('[CA] mountDynamicWidgetRenderer hatasi:', e); }
        }

        if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
            doMount();
        } else {
            var cssUrl = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.css")';
            var jsUrl  = '@FileVersioner.AddFileVersionToPath(Context.Request.PathBase, "/react/calibrahub-widgets.js")';

            if (!document.querySelector('link[data-ca-bundle]')) {
                var link = document.createElement('link');
                link.rel = 'stylesheet'; link.href = cssUrl;
                link.setAttribute('data-ca-bundle', '1');
                document.head.appendChild(link);
            }

            if (!document.querySelector('script[data-ca-bundle]')) {
                var script = document.createElement('script');
                script.src = jsUrl;
                script.setAttribute('data-ca-bundle', '1');
                script.onload = function () { setTimeout(doMount, 0); };
                script.onerror = function () { console.error('[CA] Bundle yuklenemedi'); };
                document.head.appendChild(script);
            }
        }
    })();

    // ══════════════════════════════════════════════════════════════
    // İletişim sekmesi — ana adres alanlarinda PTT cascade dropdown
    // 2026-07-06 — DEVRE DIŞI: Adres kataloğu yapısı kaldırıldı; şehir/ilçe
    // için ileride ayrı tanımlama ekranı yapılacak. Alanlar serbest metin.
    // ══════════════════════════════════════════════════════════════
    (function () {
        return; // PTT katalog beslemesi kapalı
        function gid(id) { return document.getElementById(id); }
        var ctyEl  = gid('city');
        var distEl = gid('district');
        var ngEl   = gid('neighborhood');
        var pkEl   = gid('postalCode');
        var ccEl   = gid('countryCode');
        if (!ctyEl) return;

        var ngPostalCache = {};

        async function loadCities() {
            var country = ((ccEl && ccEl.value) || 'TR').toUpperCase();
            try {
                var r = await fetch('/Address/Cities?countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
                var data = await r.json();
                var dl = gid('cityList');
                if (dl) dl.innerHTML = (data || []).map(function (c) { return '<option value="' + c + '">'; }).join('');
            } catch (e) { /* sessizce gec */ }
        }

        async function loadDistricts() {
            var city = (ctyEl.value || '').trim();
            if (!city) { gid('districtList').innerHTML = ''; return; }
            var country = ((ccEl && ccEl.value) || 'TR').toUpperCase();
            try {
                var r = await fetch('/Address/Districts?city=' + encodeURIComponent(city) + '&countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
                var data = await r.json();
                gid('districtList').innerHTML = (data || []).map(function (d) { return '<option value="' + d + '">'; }).join('');
            } catch (e) { /* sessizce gec */ }
        }

        async function loadNeighborhoods() {
            var city = (ctyEl.value || '').trim();
            var dist = (distEl.value || '').trim();
            if (!city || !dist) { gid('neighborhoodList').innerHTML = ''; return; }
            var country = ((ccEl && ccEl.value) || 'TR').toUpperCase();
            try {
                var r = await fetch('/Address/Neighborhoods?city=' + encodeURIComponent(city) + '&district=' + encodeURIComponent(dist) + '&countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
                var data = await r.json();
                ngPostalCache = (data || []).reduce(function (acc, x) { acc[x.name] = x.postalCode; return acc; }, {});
                gid('neighborhoodList').innerHTML = (data || []).map(function (n) {
                    return '<option value="' + n.name + '">' + (n.postalCode ? '(' + n.postalCode + ')' : '') + '</option>';
                }).join('');
            } catch (e) { /* sessizce gec */ }
        }

        function autofillPostal() {
            var ng = (ngEl.value || '').trim();
            if (ng && ngPostalCache[ng] && !pkEl.value) pkEl.value = ngPostalCache[ng];
        }

        // Event'ler
        if (ccEl) ccEl.addEventListener('change', function () {
            ctyEl.value = ''; distEl.value = ''; ngEl.value = ''; pkEl.value = '';
            loadCities();
        });
        ctyEl.addEventListener('change', function () {
            distEl.value = ''; ngEl.value = ''; pkEl.value = '';
            loadDistricts();
        });
        distEl.addEventListener('change', function () {
            ngEl.value = ''; pkEl.value = '';
            loadNeighborhoods();
        });
        ngEl.addEventListener('change', autofillPostal);

        // Ilk yukleme — sehir listesi (ulke kodu varsa)
        loadCities();
        if (ctyEl.value) loadDistricts();
        if (distEl.value) loadNeighborhoods();
    })();

    // ══════════════════════════════════════════════════════════════
    // Cari Hareket — cariye ait tum belgeler (filtreli)
    // ══════════════════════════════════════════════════════════════
    (function () {
        function gid(id) { return document.getElementById(id); }
        var contactIdStr = gid('caId') ? gid('caId').value : '';
        var contactId = parseInt(contactIdStr, 10) || 0;

        var statusLabels = {
            Draft: 'Taslak', Sent: 'Onay Bekliyor', Approved: 'Onaylı',
            Rejected: 'Reddedildi', Revised: 'Revize', Cancelled: 'Kapatıldı / İptal', Converted: 'Dönüştürüldü'
        };

        function fmtMoney(n) {
            return (n || 0).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        function fmtDate(s) {
            if (!s) return '';
            try { return new Date(s).toLocaleDateString('tr-TR'); } catch (e) { return s; }
        }
        function escH(s) {
            return String(s == null ? '' : s).replace(/[&<>"']/g, function (ch) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
            });
        }

        async function loadDocTypes() {
            try {
                var r = await fetch('/Finance/GetDocumentTypes', { credentials: 'same-origin' });
                var data = await r.json();
                var sel = gid('caMovDocType');
                if (!sel) return;
                (data || []).forEach(function (t) {
                    var opt = document.createElement('option');
                    opt.value = String(t.id);
                    opt.textContent = t.name;
                    sel.appendChild(opt);
                });
            } catch (e) { console.warn('[CA] Belge tipleri yuklenemedi:', e); }
        }

        window.caMovClearFilters = function() {
            var dt = gid('caMovDocType'); if (dt) dt.value = '';
            var f = gid('caMovFrom'); if (f) f.value = '';
            var t = gid('caMovTo'); if (t) t.value = '';
            caMovLoad();
        };

        window.caMovLoad = async function () {
            if (contactId <= 0) return;
            try {
                var docType = gid('caMovDocType') ? gid('caMovDocType').value : '';
                var from = gid('caMovFrom') ? gid('caMovFrom').value : '';
                var to   = gid('caMovTo') ? gid('caMovTo').value : '';
                var url = '/Finance/GetContactMovements?contactId=' + contactId;
                if (docType) url += '&documentTypeId=' + encodeURIComponent(docType);
                if (from)    url += '&fromDate='       + encodeURIComponent(from);
                if (to)      url += '&toDate='         + encodeURIComponent(to);
                var r = await fetch(url, { credentials: 'same-origin' });
                var rows = await r.json();
                var host = gid('caMovList');
                var empty = gid('caMovEmpty');
                var cnt = gid('caMovementsCount');
                host.innerHTML = '';
                if (!rows || rows.length === 0) {
                    empty.style.display = '';
                    if (cnt) cnt.style.display = 'none';
                    return;
                }
                empty.style.display = 'none';
                if (cnt) { cnt.textContent = String(rows.length); cnt.style.display = ''; }
                rows.forEach(function (q) {
                    var a = document.createElement('a');
                    a.href = '/Sales/DocumentEdit?id=' + q.id + (location.search.indexOf('workspace=1') !== -1 ? '&workspace=1' : '');
                    a.className = 'ca-quote-row';
                    var typeLbl = q.documentTypeName ? '<span class="ca-quote-date" style="color:#a5b4fc;font-weight:600;">' + escH(q.documentTypeName) + '</span>' : '';
                    a.innerHTML =
                        typeLbl
                        + '<span class="ca-quote-no">' + escH(q.documentNumber) + '</span>'
                        + '<span class="ca-quote-date">' + escH(fmtDate(q.documentDate)) + '</span>'
                        + '<span class="ca-quote-date">' + (q.lineCount || 0) + ' kalem</span>'
                        + '<span class="ca-quote-total">' + fmtMoney(q.grandTotal) + ' ' + escH(q.currency || 'TRY') + '</span>'
                        + '<span class="ca-quote-status ca-quote-status--' + escH(q.status) + '">' + escH(statusLabels[q.status] || q.status) + '</span>';
                    host.appendChild(a);
                });
            } catch (e) { console.warn('[CA] Cari hareket listesi yuklenemedi:', e); }
        };

        document.addEventListener('DOMContentLoaded', function() {
            loadDocTypes();
            if (contactId > 0) caMovLoad();
        });
    })();

    // ══════════════════════════════════════════════════════════════
    // Satis Temsilcisi dropdown — Temel Bilgiler kartinda
    // ══════════════════════════════════════════════════════════════
    (function () {
        var sel = document.getElementById('salesRepresentativeId');
        if (!sel) return;
        var preselect = sel.getAttribute('data-selected') || '';
        fetch('/Finance/GetSalesRepsList', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                (data || []).forEach(function (rep) {
                    var opt = document.createElement('option');
                    opt.value = String(rep.id);
                    opt.textContent = (rep.code ? rep.code + ' — ' : '') + rep.name;
                    if (preselect && String(rep.id) === preselect) opt.selected = true;
                    sel.appendChild(opt);
                });
            })
            .catch(function (e) { console.warn('[CA] Satis temsilcisi listesi yuklenemedi:', e); });
    })();

    // ══════════════════════════════════════════════════════════════
    // Cari Grubu dropdown — Temel Bilgiler kartinda
    // ══════════════════════════════════════════════════════════════
    (function () {
        var sel = document.getElementById('contactGroupId');
        if (!sel) return;
        var preselect = sel.getAttribute('data-selected') || '';
        fetch('/GeneralDefinitions/GetCariGroups', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                (data || []).forEach(function (g) {
                    var opt = document.createElement('option');
                    opt.value = String(g.id);
                    opt.textContent = g.name;
                    if (preselect && String(g.id) === preselect) opt.selected = true;
                    sel.appendChild(opt);
                });
            })
            .catch(function (e) { console.warn('[CA] Cari grup listesi yuklenemedi:', e); });
    })();

    // ══════════════════════════════════════════════════════════════
    // Teslim Adresleri — cascade dropdown + CRUD
    // ══════════════════════════════════════════════════════════════
    var caAddrContactId = parseInt(document.getElementById('caId').value || '0', 10) || 0;
    var caAddrCatalogEmpty = false;

    function qs(id) { return document.getElementById(id); }

    // 2026-07-06 — PTT katalog beslemesi devre dışı: şehir/ilçe ileride ayrı
    // tanımlama ekranından gelecek. İl/İlçe/Mahalle alanları serbest metin;
    // datalist'ler boş kalır, katalog uyarısı hiç gösterilmez.
    async function caAddrLoadCities() { /* katalog kapalı */ }

    async function caAddrLoadDistricts() { /* katalog kapalı */ }

    async function caAddrLoadNeighborhoods() { /* katalog kapalı */ }

    function caAddrAutofillPostal() {
        var ng = (qs('caAddrNeighborhood').value || '').trim();
        if (ng && window.__caNgCache && window.__caNgCache[ng] && !qs('caAddrPostal').value) {
            qs('caAddrPostal').value = window.__caNgCache[ng];
        }
    }

    async function caAddrLoadList() {
        if (caAddrContactId <= 0) { qs('caAddrList').innerHTML = ''; qs('caAddrEmpty').style.display = ''; return; }
        try {
            var r = await fetch('/Address/ByContact?contactId=' + caAddrContactId, { credentials: 'same-origin' });
            var rows = await r.json();
            var host = qs('caAddrList');
            host.innerHTML = '';
            if (!rows || rows.length === 0) {
                qs('caAddrEmpty').style.display = '';
                qs('caAddressCount').style.display = 'none';
                return;
            }
            qs('caAddrEmpty').style.display = 'none';
            qs('caAddressCount').textContent = String(rows.length);
            qs('caAddressCount').style.display = '';
            rows.forEach(function (a) {
                var loc = [a.countryCode, a.cityName, a.districtName, a.neighborhoodName].filter(Boolean).join(' / ');
                var card = document.createElement('div');
                card.className = 'ca-addr-card';
                card.innerHTML =
                    '<div class="ca-addr-card__main">'
                    + '<div class="ca-addr-card__name">' + escapeHtml(a.name) + (a.isDefault ? ' <span class="ca-addr-default-tag">★ Varsayılan</span>' : '') + '</div>'
                    + '<div class="ca-addr-card__loc">' + escapeHtml(loc) + (a.postalCode ? ' · ' + escapeHtml(a.postalCode) : '') + '</div>'
                    + (a.addressLine ? '<div class="ca-addr-card__line">' + escapeHtml(a.addressLine) + '</div>' : '')
                    + '</div>'
                    + '<button type="button" class="ca-btn ca-btn--secondary" data-edit="' + a.id + '" style="padding:6px 12px;font-size:.76rem;">Düzenle</button>'
                    + '<button type="button" class="ca-btn ca-btn--danger" data-del="' + a.id + '" style="padding:6px 12px;font-size:.76rem;">Sil</button>';
                host.appendChild(card);
                card.querySelector('[data-edit]').addEventListener('click', function () { caAddrEdit(a); });
                card.querySelector('[data-del]').addEventListener('click', function () { caAddrDelete(a.id); });
            });
        } catch (e) { console.warn('[CA] Adres listesi yuklenemedi:', e); }
    }

    function caAddrEdit(a) {
        qs('caAddrEditId').value = a.id || '';
        qs('caAddrName').value = a.name || '';
        qs('caAddrCountry').value = a.countryCode || 'TR';
        qs('caAddrCity').value = a.cityName || '';
        qs('caAddrDistrict').value = a.districtName || '';
        qs('caAddrNeighborhood').value = a.neighborhoodName || '';
        qs('caAddrPostal').value = a.postalCode || '';
        qs('caAddrLine').value = a.addressLine || '';
        qs('caAddrDefault').checked = !!a.isDefault;
        qs('caAddrForm').style.display = '';
        caAddrLoadCities();
        caAddrLoadDistricts();
        caAddrLoadNeighborhoods();
    }

    function caAddrResetForm() {
        qs('caAddrEditId').value = '';
        qs('caAddrName').value = '';
        qs('caAddrCountry').value = 'TR';
        qs('caAddrCity').value = '';
        qs('caAddrDistrict').value = '';
        qs('caAddrNeighborhood').value = '';
        qs('caAddrPostal').value = '';
        qs('caAddrLine').value = '';
        qs('caAddrDefault').checked = false;
    }

    async function caAddrSave() {
        var name = (qs('caAddrName').value || '').trim();
        if (!name) { if (window.CalibraAlert) CalibraAlert.warning('Adres ismi zorunludur.'); return; }
        if (caAddrContactId <= 0) { if (window.CalibraAlert) CalibraAlert.warning('Önce cari kartı kaydediniz.'); return; }
        var id = parseInt(qs('caAddrEditId').value || '0', 10) || 0;
        var payload = {
            id: id > 0 ? id : null,
            contactId: caAddrContactId,
            name: name,
            countryCode: (qs('caAddrCountry').value || 'TR').toUpperCase(),
            cityName: qs('caAddrCity').value || null,
            districtName: qs('caAddrDistrict').value || null,
            neighborhoodName: qs('caAddrNeighborhood').value || null,
            postalCode: qs('caAddrPostal').value || null,
            addressLine: qs('caAddrLine').value || null,
            isDefault: qs('caAddrDefault').checked
        };
        try {
            var r = await fetch('/Address/SaveAddress', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify(payload)
            });
            var data = await r.json();
            if (!data.success) { if (window.CalibraAlert) CalibraAlert.error(data.message || 'Kaydedilemedi'); return; }
            qs('caAddrForm').style.display = 'none';
            caAddrResetForm();
            await caAddrLoadList();
        } catch (e) { if (window.CalibraAlert) CalibraAlert.error('Kaydetme hatası: ' + e.message); }
    }

    async function caAddrDelete(id) {
        if (window.CalibraAlert && CalibraAlert.confirm) {
            var ok = await CalibraAlert.confirm('Bu adres silinsin mi?', { title: 'Adres Sil', okText: 'Evet, Sil', cancelText: 'İptal', danger: true });
            if (!ok) return;
        }
        try {
            var r = await fetch('/Address/DeleteAddress', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ id: id })
            });
            var data = await r.json();
            if (!data.success) { if (window.CalibraAlert) CalibraAlert.error(data.message || 'Silinemedi'); return; }
            await caAddrLoadList();
        } catch (e) { if (window.CalibraAlert) CalibraAlert.error('Silme hatası: ' + e.message); }
    }

    function escapeHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (ch) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
        });
    }

    // Baglama — DOM hazir oldugunda
    document.addEventListener('DOMContentLoaded', function () {
        var addBtn = qs('caAddrAddBtn');
        var cancelBtn = qs('caAddrCancelBtn');
        var saveBtn = qs('caAddrSaveBtn');
        if (addBtn) addBtn.addEventListener('click', function () {
            caAddrResetForm();
            qs('caAddrForm').style.display = '';
            caAddrLoadCities();
        });
        if (cancelBtn) cancelBtn.addEventListener('click', function () {
            qs('caAddrForm').style.display = 'none';
            caAddrResetForm();
        });
        if (saveBtn) saveBtn.addEventListener('click', caAddrSave);

        // Cascade event'leri
        var cityEl = qs('caAddrCity');
        var distEl = qs('caAddrDistrict');
        var ngEl   = qs('caAddrNeighborhood');
        if (cityEl) cityEl.addEventListener('change', function () {
            distEl.value = ''; ngEl.value = ''; qs('caAddrPostal').value = '';
            caAddrLoadDistricts();
        });
        if (distEl) distEl.addEventListener('change', function () {
            ngEl.value = ''; qs('caAddrPostal').value = '';
            caAddrLoadNeighborhoods();
        });
        if (ngEl) ngEl.addEventListener('change', caAddrAutofillPostal);

        // Ilk yuklemede (contact varsa) listeyi getir
        if (caAddrContactId > 0) caAddrLoadList();
    });

    // ══════════════════════════════════════════════════════════════
    // Stok Eslestirmeleri — inline editable grid (satis teklif gibi)
    // Her satir bagimsiz: stok secimi + cari kod/ad/not duzenleme + blur'da
    // otomatik save (Save endpoint, contactId+itemId UNIQUE oldugundan upsert).
    // (qs/escapeHtml helper'lari adresler bolumunde tanimli — paylasilir.)
    // ══════════════════════════════════════════════════════════════
    var caItemContactId = parseInt(document.getElementById('caId').value || '0', 10) || 0;
    var CA_ITEM_GUIDE_CODE = 'ITEMS_FINISHED'; // TypeId=1 mamul rehberi (kullanici karari: tip 1 rehber)

    function caItemEmptyToggle() {
        var rows = qs('caItemRows').children.length;
        qs('caItemEmpty').style.display = (rows === 0) ? '' : 'none';
        qs('caItemCount').textContent = String(rows);
        qs('caItemCount').style.display = (rows === 0) ? 'none' : '';
        // Index'leri yenile
        Array.prototype.forEach.call(qs('caItemRows').children, function (tr, i) {
            var cell = tr.querySelector('.ca-item-grid__index');
            if (cell) cell.textContent = String(i + 1);
        });
    }

    /**
     * Yeni bir <tr> uretir. row null ise bos (yeni eklenen, henuz save'siz) satir.
     */
    function caItemBuildRow(row) {
        var tr = document.createElement('tr');
        tr.setAttribute('data-id', row && row.id ? String(row.id) : '0');
        tr.setAttribute('data-item-id', row && row.itemId ? String(row.itemId) : '0');

        var html = ''
            + '<td class="ca-item-grid__index"></td>'
            + '<td class="ca-item-grid__cell-code' + ((row && row.itemId) ? '' : ' ca-item-grid__needs-pick') + '">'
            +   '<input type="text" data-field="itemCode" autocomplete="off" placeholder="Stok kodu ile ara..." maxlength="60" value="' + escapeHtml(row && row.itemCode ? row.itemCode : '') + '" />'
            + '</td>'
            + '<td><input type="text" data-field="itemName" readonly value="' + escapeHtml(row && row.itemName ? row.itemName : '') + '" placeholder="(otomatik dolar)" /></td>'
            + '<td><input type="text" data-field="vendorCode" maxlength="60" value="' + escapeHtml(row && row.vendorCode ? row.vendorCode : '') + '" placeholder="—" /></td>'
            + '<td><input type="text" data-field="vendorName" maxlength="200" value="' + escapeHtml(row && row.vendorName ? row.vendorName : '') + '" placeholder="—" /></td>'
            + '<td><input type="text" data-field="notes" maxlength="500" value="' + escapeHtml(row && row.notes ? row.notes : '') + '" placeholder="—" /></td>'
            + '<td style="text-align:center;">'
            +   '<label class="ca-toggle" title="Aktif" style="vertical-align:middle;">'
            +     '<input type="checkbox" data-field="isActive"' + ((!row || row.isActive !== false) ? ' checked' : '') + ' />'
            +     '<span class="ca-toggle-track"></span>'
            +   '</label>'
            +   '<span class="ca-item-grid__status" data-status style="margin-left:6px;"></span>'
            + '</td>'
            + '<td style="text-align:center;">'
            +   '<button type="button" class="ca-item-grid__row-del" title="Sil">Sil</button>'
            + '</td>';
        tr.innerHTML = html;
        caItemBindRow(tr);
        return tr;
    }

    function caItemMarkStatus(tr, kind) {
        tr.classList.remove('is-dirty', 'is-saving', 'is-error');
        var s = tr.querySelector('[data-status]');
        if (s) {
            s.classList.remove('is-dirty', 'is-saving', 'is-saved', 'is-error');
        }
        if (kind === 'dirty')  { tr.classList.add('is-dirty');  if (s) s.classList.add('is-dirty');  }
        if (kind === 'saving') { tr.classList.add('is-saving'); if (s) s.classList.add('is-saving'); }
        if (kind === 'saved')  { if (s) s.classList.add('is-saved'); }
        if (kind === 'error')  { tr.classList.add('is-error');  if (s) s.classList.add('is-error');  }
    }

    function caItemRowReadable(tr) {
        return {
            id:         parseInt(tr.getAttribute('data-id') || '0', 10) || 0,
            itemId:     parseInt(tr.getAttribute('data-item-id') || '0', 10) || 0,
            itemCode:   tr.querySelector('[data-field="itemCode"]').value.trim(),
            itemName:   tr.querySelector('[data-field="itemName"]').value.trim(),
            vendorCode: tr.querySelector('[data-field="vendorCode"]').value.trim(),
            vendorName: tr.querySelector('[data-field="vendorName"]').value.trim(),
            notes:      tr.querySelector('[data-field="notes"]').value.trim(),
            isActive:   tr.querySelector('[data-field="isActive"]').checked,
        };
    }

    async function caItemSaveRow(tr) {
        if (caItemContactId <= 0) return;
        var data = caItemRowReadable(tr);
        if (data.itemId <= 0) {
            // Stok secilmemis — kaydetme; "needs-pick" gosterimi zaten var.
            caItemMarkStatus(tr, 'dirty');
            return;
        }
        caItemMarkStatus(tr, 'saving');
        try {
            var r = await fetch('/ContactItem/Save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({
                    id: data.id > 0 ? data.id : null,
                    contactId: caItemContactId,
                    itemId: data.itemId,
                    vendorCode: data.vendorCode || null,
                    vendorName: data.vendorName || null,
                    notes:      data.notes      || null,
                    isActive:   data.isActive,
                })
            });
            var resp = await r.json();
            if (!resp.success) {
                caItemMarkStatus(tr, 'error');
                if (window.CalibraAlert) CalibraAlert.error(resp.message || 'Kaydedilemedi');
                return;
            }
            if (resp.id && data.id <= 0) {
                tr.setAttribute('data-id', String(resp.id));
            }
            caItemMarkStatus(tr, 'saved');
            // Kisa sure sonra status nokta'sini sondur
            setTimeout(function () {
                var s = tr.querySelector('[data-status]');
                if (s) s.classList.remove('is-saved');
            }, 1400);
        } catch (e) {
            caItemMarkStatus(tr, 'error');
            if (window.CalibraAlert) CalibraAlert.error('Kaydetme hatası: ' + e.message);
        }
    }

    async function caItemDeleteRow(tr) {
        var id = parseInt(tr.getAttribute('data-id') || '0', 10) || 0;
        if (id <= 0) {
            // Sadece DOM'dan kaldir (henuz kaydedilmemis)
            tr.remove();
            caItemEmptyToggle();
            return;
        }
        if (window.CalibraAlert && CalibraAlert.confirm) {
            var ok = await CalibraAlert.confirm('Bu stok eşleştirmesi silinsin mi?', { title: 'Eşleştirme Sil', okText: 'Evet, Sil', cancelText: 'İptal', danger: true });
            if (!ok) return;
        }
        try {
            var r = await fetch('/ContactItem/Delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ id: id })
            });
            var data = await r.json();
            if (!data.success) {
                if (window.CalibraAlert) CalibraAlert.error(data.message || 'Silinemedi');
                return;
            }
            tr.remove();
            caItemEmptyToggle();
        } catch (e) {
            if (window.CalibraAlert) CalibraAlert.error('Silme hatası: ' + e.message);
        }
    }

    function caItemBindRow(tr) {
        var codeInput  = tr.querySelector('[data-field="itemCode"]');
        var nameInput  = tr.querySelector('[data-field="itemName"]');
        var vCodeInput = tr.querySelector('[data-field="vendorCode"]');
        var vNameInput = tr.querySelector('[data-field="vendorName"]');
        var notesInput = tr.querySelector('[data-field="notes"]');
        var activeChk  = tr.querySelector('[data-field="isActive"]');
        var delBtn     = tr.querySelector('.ca-item-grid__row-del');

        // Stok kodu hucresine ITEMS_FINISHED rehberi (LookupCard modal) mount et.
        // Mevcut input value'su varsa LookupCard initial display'i icin data-display
        // attribute'unu set ediyoruz (server'dan ItemName geldi zaten).
        if (nameInput.value && !codeInput.getAttribute('data-display')) {
            codeInput.setAttribute('data-display', nameInput.value);
        }

        caItemMountLookup(codeInput);

        // LookupCard secim yapinca input.value (Code) ve data-display (Name) set eder
        // ve change/input event dispatch eder. Code geldiyse Items.Id'yi resolve et.
        codeInput.addEventListener('change', async function () {
            var code = (codeInput.value || '').trim();
            var disp = codeInput.getAttribute('data-display') || '';
            if (!code) {
                // Kod silindi — stok secimi sifirlandi
                tr.setAttribute('data-item-id', '0');
                nameInput.value = '';
                tr.querySelector('.ca-item-grid__cell-code').classList.add('ca-item-grid__needs-pick');
                caItemMarkStatus(tr, 'dirty');
                return;
            }
            // Display'i hemen yansit (LookupCard zaten data-display set etti)
            if (disp) nameInput.value = disp;

            // Items.Id'yi resolve et — /api/guides/{guide}/resolve?value={code}
            try {
                var url = '/api/guides/' + encodeURIComponent(CA_ITEM_GUIDE_CODE)
                        + '/resolve?value=' + encodeURIComponent(code);
                var r = await fetch(url, { credentials: 'same-origin' });
                if (!r.ok) throw new Error('HTTP ' + r.status);
                var data = await r.json();
                var cells = (data && data.cells) || {};
                var id = cells.Id != null ? cells.Id : cells.id;
                if (id == null) {
                    // Code rehberde yok — kullanici manuel yazmis
                    tr.setAttribute('data-item-id', '0');
                    tr.querySelector('.ca-item-grid__cell-code').classList.add('ca-item-grid__needs-pick');
                    caItemMarkStatus(tr, 'dirty');
                    return;
                }
                tr.setAttribute('data-item-id', String(id));
                tr.querySelector('.ca-item-grid__cell-code').classList.remove('ca-item-grid__needs-pick');
                // Display gecmediyse resolve'dan al
                if (!nameInput.value && data && data.display) nameInput.value = data.display;
                caItemMarkStatus(tr, 'dirty');
                // Otomatik save tetikle — yeni stok secildi
                caItemSaveRow(tr);
                // Bir sonraki alana focus
                vCodeInput.focus();
            } catch (e) {
                console.warn('[CA] Stok ID resolve hatasi:', e);
                caItemMarkStatus(tr, 'error');
            }
        });

        // Diger alanlar — change/blur'da save
        function bindBlurSave(input) {
            var lastSnapshot = input.value;
            input.addEventListener('input', function () {
                if (input.value !== lastSnapshot) {
                    caItemMarkStatus(tr, 'dirty');
                }
            });
            input.addEventListener('blur', function () {
                if (input.value !== lastSnapshot) {
                    lastSnapshot = input.value;
                    caItemSaveRow(tr);
                }
            });
        }
        bindBlurSave(vCodeInput);
        bindBlurSave(vNameInput);
        bindBlurSave(notesInput);

        // Aktif checkbox — anlik save
        activeChk.addEventListener('change', function () {
            caItemMarkStatus(tr, 'dirty');
            caItemSaveRow(tr);
        });

        // Sil butonu
        delBtn.addEventListener('click', function () {
            // LookupCard wrapper'ini DOM'dan kaldirmadan once unmount et
            try {
                var lookupRef = tr._caLookupRef;
                if (lookupRef && lookupRef.unmount) lookupRef.unmount();
            } catch (e) { /* ignore */ }
            caItemDeleteRow(tr);
        });
    }

    /**
     * Stok kodu input'una ITEMS_FINISHED rehberini (modal lookup) mount eder.
     * Bundle (calibrahub-widgets.js) henuz yuklenmemisse 100ms interval ile bekler.
     * Aktif rehber kodu = CA_ITEM_GUIDE_CODE — kullanici karari "tip 1 rehber" (mamul).
     */
    function caItemMountLookup(input) {
        if (!input || input.dataset.lookupMounted === '1') return;
        function tryMount() {
            if (!window.CalibraHub || !window.CalibraHub.mountLookupForInput) return false;
            try {
                var ref = window.CalibraHub.mountLookupForInput({
                    inputElement: input,
                    formCode: 'CONTACTS',
                    fieldKey: 'contactItem.itemCode',
                    guideCode: CA_ITEM_GUIDE_CODE,
                    isRequired: true,
                });
                input.dataset.lookupMounted = '1';
                // Sil butonunda unmount edilmek icin tr'ye iliskilendir
                var tr = input.closest('tr');
                if (tr) tr._caLookupRef = ref;
                return true;
            } catch (e) {
                console.warn('[CA] Stok lookup mount hatasi:', e);
                return true; // bir daha denememek icin
            }
        }
        if (tryMount()) return;
        var tries = 0;
        var t = setInterval(function () {
            tries++;
            if (tryMount() || tries >= 50) clearInterval(t);
        }, 100);
    }

    async function caItemLoadList() {
        var tbody = qs('caItemRows');
        tbody.innerHTML = '';
        if (caItemContactId <= 0) {
            caItemEmptyToggle();
            return;
        }
        try {
            var r = await fetch('/ContactItem/ByContact?contactId=' + caItemContactId, { credentials: 'same-origin' });
            var rows = await r.json();
            if (!Array.isArray(rows)) rows = [];
            rows.forEach(function (it) {
                tbody.appendChild(caItemBuildRow(it));
            });
        } catch (e) {
            console.warn('[CA] Stok eslestirme listesi yuklenemedi:', e);
        }
        caItemEmptyToggle();
    }

    function caItemAddRow() {
        if (caItemContactId <= 0) {
            qs('caItemNoContact').style.display = '';
            if (window.CalibraAlert) CalibraAlert.warning('Önce cari kartı kaydediniz.');
            return;
        }
        qs('caItemNoContact').style.display = 'none';
        var tr = caItemBuildRow(null);
        qs('caItemRows').appendChild(tr);
        caItemEmptyToggle();
        var input = tr.querySelector('[data-field="itemCode"]');
        if (input) input.focus();
    }

    document.addEventListener('DOMContentLoaded', function () {
        var addBtn = qs('caItemAddRowBtn');
        if (addBtn) addBtn.addEventListener('click', caItemAddRow);

        if (caItemContactId > 0) {
            caItemLoadList();
        } else {
            qs('caItemNoContact').style.display = '';
            caItemEmptyToggle();
        }
    });
})();

// ══════════════════════════════════════════════════════════════════════
// Gruplar — 5 seviyeli hiyerarsik gruplama (entityType=2 cari)
// Malzeme karttaki mceGroups* pattern'inin cari versiyonu.
// Endpoint'ler:
//   GET  /Definitions/GetCardGroups?cardType=2&level=N&parentId=P
//   GET  /Definitions/GetCardGroupMappings?entityType=2&entityId={contactId}
//   POST /Definitions/SaveCardGroupMappings { entityType:2, entityId, levels:[{level,cardGroupId}] }
// ══════════════════════════════════════════════════════════════════════
(function () {
    var caGroupsLoaded = false;

    function selByLevel(level) {
        return document.querySelector('.ca-group-sel[data-level="' + level + '"]');
    }

    function buildOptions(level, items) {
        var sel = selByLevel(level);
        if (!sel) return;
        var prevValue = sel.value;
        var opts = '<option value="">Seciniz</option>';
        (items || []).forEach(function (g) {
            opts += '<option value="' + g.id + '">' + (g.code || '') +
                    (g.description ? ' — ' + g.description : '') + '</option>';
        });
        sel.innerHTML = opts;
        if (prevValue && Array.prototype.some.call(sel.options, function (o) { return o.value === prevValue; })) {
            sel.value = prevValue;
        }
    }

    function clearLevels(fromLevel) {
        for (var lv = fromLevel; lv <= 5; lv++) {
            var sel = selByLevel(lv);
            if (!sel) continue;
            sel.innerHTML = '<option value="">Seciniz</option>';
            sel.value = '';
        }
    }

    function fetchLevel(level, parentId) {
        var url = '/Definitions/GetCardGroups?cardType=2&level=' + level;
        if (parentId) url += '&parentId=' + parentId;
        return fetch(url, { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (data) {
                var items = Array.isArray(data) ? data : (data.items || []);
                buildOptions(level, items);
                return items;
            })
            .catch(function (e) { console.error('[CA] group fetch level=' + level + ':', e); return []; });
    }

    function loadExistingMappings(contactId) {
        if (!contactId || contactId <= 0) return;
        var url = '/Definitions/GetCardGroupMappings?entityType=2&entityId=' + contactId;
        fetch(url, { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (data) {
                var mappings = Array.isArray(data) ? data : (data.items || data.mappings || []);
                var byLevel = {};
                mappings.forEach(function (m) { byLevel[m.level] = m.cardGroupId; });

                function applyLevel(lv) {
                    if (lv > 5) return Promise.resolve();
                    var sel = selByLevel(lv);
                    if (!sel) return Promise.resolve();
                    var val = byLevel[lv];
                    if (val) {
                        sel.value = String(val);
                        return fetchLevel(lv + 1, val).then(function () { return applyLevel(lv + 1); });
                    }
                    return Promise.resolve();
                }
                applyLevel(1);
            })
            .catch(function (e) { console.error('[CA] group mappings load:', e); });
    }

    function bindCascadeOnce() {
        if (window._caGroupCascadeBound) return;
        window._caGroupCascadeBound = true;
        for (var lv = 1; lv <= 5; lv++) {
            (function (level) {
                var sel = selByLevel(level);
                if (!sel) return;
                sel.addEventListener('change', function () {
                    var val = sel.value;
                    clearLevels(level + 1);
                    if (val && level < 5) {
                        fetchLevel(level + 1, val);
                    }
                });
            })(lv);
        }
    }

    // Tab acilinca yukle (lazy): sidenav data-nav-key="groups" tiklaninca tetiklenir
    window.caGroupsEnsureLoaded = function () {
        if (caGroupsLoaded) return;
        caGroupsLoaded = true;
        bindCascadeOnce();
        fetchLevel(1, null).then(function () {
            var caId = document.getElementById('caId');
            var contactId = caId ? parseInt(caId.value || '0', 10) : 0;
            if (contactId > 0) loadExistingMappings(contactId);
        });
    };

    // Save flow icindeki cagri noktasi — caGroupsSave(contactId)
    window.caGroupsSave = function (contactIdOverride) {
        var caId = document.getElementById('caId');
        var entityId = contactIdOverride || (caId ? caId.value : '');
        if (!entityId) return Promise.resolve({ success: true, skipped: true });
        if (!caGroupsLoaded) return Promise.resolve({ success: true, skipped: true });

        var levels = [];
        for (var lv = 1; lv <= 5; lv++) {
            var sel = selByLevel(lv);
            if (!sel) continue;
            var v = sel.value;
            levels.push({ level: lv, cardGroupId: v ? parseInt(v) : null });
        }

        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        var token = tokenEl ? tokenEl.value : '';
        var payload = { entityType: 2, entityId: String(entityId), levels: levels };
        return fetch('/Definitions/SaveCardGroupMappings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            credentials: 'same-origin',
            body: JSON.stringify(payload)
        })
        .then(function (r) { return r.json().catch(function () { return { success: r.ok }; }); })
        .catch(function (e) {
            console.error('[CA] group save error:', e);
            return { success: false, message: e.message };
        });
    };

    // Sidenav "Gruplar" butonuna tiklayinca lazy yukle
    document.addEventListener('click', function (e) {
        var btn = e.target.closest && e.target.closest('[data-nav-key="groups"]');
        if (btn) window.caGroupsEnsureLoaded();
    });
})();

// ── İletişim Kişileri (ContactPerson) ────────────────────────────
(function () {
    var loaded = false;
    var listEl    = document.getElementById('cpRows');
    var emptyEl   = document.getElementById('cpEmpty');
    var noContact = document.getElementById('cpNoContact');
    var listWrap  = document.getElementById('cpListWrap');
    var addBtn    = document.getElementById('cpAddBtn');
    var navCount  = document.getElementById('cpPersonCount');

    var modal     = document.getElementById('cpModalBackdrop');
    var modalTitle= document.getElementById('cpModalTitle');
    var fldId     = document.getElementById('cpFldId');
    var fldTitleSel = document.getElementById('cpFldTitleId');
    var fldTitleAdd = document.getElementById('cpFldTitleAddBtn');
    var fldName   = document.getElementById('cpFldFullName');

    // Lookup cache — modal her acildiginda ag istegi yapilmasin diye module-level.
    var _titlesLoaded = false;
    var _titlesPromise = null;
    function ensureTitlesLoaded() {
        if (_titlesLoaded) return Promise.resolve();
        if (_titlesPromise) return _titlesPromise;
        _titlesPromise = fetch('/Finance/ContactPersonTitles', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res && res.ok && Array.isArray(res.data)) {
                    populateTitleOptions(res.data);
                    _titlesLoaded = true;
                }
            })
            .catch(function (e) { console.error('[cp] titles load err', e); })
            .finally(function () { _titlesPromise = null; });
        return _titlesPromise;
    }
    function populateTitleOptions(titles) {
        if (!fldTitleSel) return;
        // Mevcut secimi koru
        var current = fldTitleSel.value;
        // Placeholder + secenekleri yeniden cizelim
        fldTitleSel.innerHTML = '<option value="">Seçiniz…</option>';
        titles.forEach(function (t) {
            var opt = document.createElement('option');
            opt.value = String(t.id);
            opt.textContent = t.name;
            fldTitleSel.appendChild(opt);
        });
        // Eski deger hala mevcutsa geri koy
        if (current) fldTitleSel.value = current;
    }
    function selectTitleByName(name) {
        if (!fldTitleSel || !name) return false;
        var trg = String(name).trim().toLowerCase();
        for (var i = 0; i < fldTitleSel.options.length; i++) {
            var o = fldTitleSel.options[i];
            if ((o.textContent || '').trim().toLowerCase() === trg) {
                fldTitleSel.value = o.value;
                return true;
            }
        }
        return false;
    }
    // ── Yeni ünvan ekle modali (prompt() yerine center modal) ────────────────
    var titleAddBackdrop = document.getElementById('cpTitleAddBackdrop');
    var titleAddNameInp  = document.getElementById('cpTitleAddName');
    var titleAddErr      = document.getElementById('cpTitleAddErr');
    var titleAddOk       = document.getElementById('cpTitleAddOk');
    var titleAddCancel   = document.getElementById('cpTitleAddCancel');

    function openAddTitleModal() {
        if (!titleAddBackdrop) return;
        titleAddNameInp.value = '';
        titleAddErr.style.display = 'none';
        titleAddBackdrop.style.display = 'flex';
        setTimeout(function(){ try { titleAddNameInp.focus(); } catch(_){} }, 30);
    }
    function closeAddTitleModal() {
        if (titleAddBackdrop) titleAddBackdrop.style.display = 'none';
    }
    function addInlineTitle() { openAddTitleModal(); }

    function submitAddTitle() {
        var name = (titleAddNameInp.value || '').trim();
        if (!name) {
            titleAddErr.textContent = 'Ünvan adı zorunlu.';
            titleAddErr.style.display = 'block';
            return;
        }
        titleAddOk.disabled = true;
        fetch('/Finance/AddContactPersonTitle', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify({ name: name })
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            titleAddOk.disabled = false;
            if (!res || !res.ok) {
                titleAddErr.textContent = (res && res.message) || 'Ünvan eklenemedi.';
                titleAddErr.style.display = 'block';
                return;
            }
            // Dropdown'a ekle + secili yap
            var existingOpt = null;
            for (var i = 0; i < fldTitleSel.options.length; i++) {
                if (parseInt(fldTitleSel.options[i].value || '0', 10) === res.id) { existingOpt = fldTitleSel.options[i]; break; }
            }
            if (!existingOpt) {
                var opt = document.createElement('option');
                opt.value = String(res.id);
                opt.textContent = res.name;
                if (fldTitleSel.firstChild && fldTitleSel.firstChild.nextSibling) {
                    fldTitleSel.insertBefore(opt, fldTitleSel.firstChild.nextSibling);
                } else {
                    fldTitleSel.appendChild(opt);
                }
                existingOpt = opt;
            }
            fldTitleSel.value = existingOpt.value;
            closeAddTitleModal();
        })
        .catch(function (e) {
            titleAddOk.disabled = false;
            titleAddErr.textContent = 'Bağlantı hatası: ' + e.message;
            titleAddErr.style.display = 'block';
        });
    }
    if (titleAddOk)     titleAddOk.addEventListener('click', submitAddTitle);
    if (titleAddCancel) titleAddCancel.addEventListener('click', closeAddTitleModal);
    if (titleAddBackdrop) {
        titleAddBackdrop.addEventListener('click', function (ev) {
            if (ev.target === titleAddBackdrop) closeAddTitleModal();
        });
    }
    if (titleAddNameInp) {
        titleAddNameInp.addEventListener('keydown', function (ev) {
            if (ev.key === 'Enter')     { ev.preventDefault(); submitAddTitle(); }
            if (ev.key === 'Escape')    { ev.preventDefault(); closeAddTitleModal(); }
        });
    }

    // ── Ünvanları yönet modali (sil/pasif) ─────────────────────────────────
    var titleMgrBackdrop = document.getElementById('cpTitleManageBackdrop');
    var titleMgrList     = document.getElementById('cpTitleManageList');
    var titleMgrClose    = document.getElementById('cpTitleManageClose');
    var fldTitleManage   = document.getElementById('cpFldTitleManageBtn');

    function openManageTitlesModal() {
        if (!titleMgrBackdrop) return;
        titleMgrBackdrop.style.display = 'flex';
        loadManageList();
    }
    function closeManageTitlesModal() {
        if (titleMgrBackdrop) titleMgrBackdrop.style.display = 'none';
    }
    function loadManageList() {
        if (!titleMgrList) return;
        // Tema-aware muted color (.cp-grid td zaten dark+light override icerir).
        titleMgrList.innerHTML = '<tr class="cp-mgr-row"><td colspan="3" class="cp-mgr-muted">Yükleniyor…</td></tr>';
        fetch('/Finance/ContactPersonTitles', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (!res || !res.ok || !res.data || res.data.length === 0) {
                    titleMgrList.innerHTML = '<tr class="cp-mgr-row"><td colspan="3" class="cp-mgr-muted">Aktif ünvan yok.</td></tr>';
                    return;
                }
                var html = '';
                res.data.forEach(function (t) {
                    var sys = t.isSystem ? '★' : '';
                    html += '<tr class="cp-mgr-row" data-tid="' + t.id + '">'
                        +  '<td class="cp-mgr-cell">' + escapeHtml(t.name) + '</td>'
                        +  '<td class="cp-mgr-cell" style="text-align:center;color:#fbbf24;font-weight:700;">' + sys + '</td>'
                        +  '<td class="cp-mgr-cell" style="text-align:right;">'
                        +    '<button type="button" class="ca-btn cp-title-del-btn" data-tid="' + t.id + '" data-tname="' + escapeHtml(t.name) + '" style="padding:4px 10px;font-size:.74rem;background:rgba(220,38,38,0.18);border:1px solid rgba(220,38,38,0.4);color:#dc2626;">Sil</button>'
                        +  '</td>'
                        + '</tr>';
                });
                titleMgrList.innerHTML = html;
                // Sil click handler
                titleMgrList.querySelectorAll('.cp-title-del-btn').forEach(function (btn) {
                    btn.addEventListener('click', async function () {
                        var tid = parseInt(btn.getAttribute('data-tid') || '0', 10);
                        var tname = btn.getAttribute('data-tname') || '';
                        if (!tid) return;
                        // Sayfa ortasinda ozel modal (CLAUDE.md silme onay standardi).
                        // CalibraAlert.confirm Promise tabanli, danger:true ile kirmizi buton.
                        if (window.CalibraAlert && window.CalibraAlert.confirm) {
                            var ok = await window.CalibraAlert.confirm(
                                "'" + tname + "' ünvanını silmek istediğinize emin misiniz?",
                                { title: 'Ünvan Sil', okText: 'Evet, Sil', cancelText: 'Vazgeç', danger: true });
                            if (!ok) return;
                        } else if (!window.confirm("'" + tname + "' ünvanını silmek istediğinize emin misiniz?")) {
                            return; // fallback (CalibraAlert yuklenmemisse)
                        }
                        btn.disabled = true;
                        var fd = new FormData();
                        fd.append('id', tid);
                        fetch('/Finance/DeleteContactPersonTitle?id=' + tid, {
                            method: 'POST',
                            credentials: 'same-origin',
                            headers: { 'RequestVerificationToken': getToken() }
                        })
                        .then(function (r) { return r.json(); })
                        .then(function (dres) {
                            btn.disabled = false;
                            if (!dres || !dres.ok) {
                                if (window.CalibraAlert && window.CalibraAlert.error) {
                                    window.CalibraAlert.error((dres && dres.message) || 'Silme başarısız.');
                                } else {
                                    alert((dres && dres.message) || 'Silme başarısız.');
                                }
                                return;
                            }
                            // Listeyi yenile + dropdown'dan kaldir
                            loadManageList();
                            for (var i = fldTitleSel.options.length - 1; i >= 0; i--) {
                                if (parseInt(fldTitleSel.options[i].value || '0', 10) === tid) {
                                    fldTitleSel.removeChild(fldTitleSel.options[i]);
                                    break;
                                }
                            }
                        })
                        .catch(function (e) {
                            btn.disabled = false;
                            alert('Bağlantı hatası: ' + e.message);
                        });
                    });
                });
            })
            .catch(function () {
                titleMgrList.innerHTML = '<tr><td colspan="3" style="padding:14px;color:#f87171;text-align:center;">Yüklenemedi.</td></tr>';
            });
    }
    function escapeHtml(s) {
        return String(s || '').replace(/[&<>"']/g, function (c) {
            return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
        });
    }
    if (titleMgrClose) titleMgrClose.addEventListener('click', closeManageTitlesModal);
    if (titleMgrBackdrop) {
        titleMgrBackdrop.addEventListener('click', function (ev) {
            if (ev.target === titleMgrBackdrop) closeManageTitlesModal();
        });
    }
    if (fldTitleManage) fldTitleManage.addEventListener('click', openManageTitlesModal);
    var fldPhone  = document.getElementById('cpFldPhone');
    var fldEmail  = document.getElementById('cpFldEmail');
    var fldNotes  = document.getElementById('cpFldNotes');
    var fldPrim   = document.getElementById('cpFldIsPrimary');
    var fldActive = document.getElementById('cpFldIsActive');
    var errBox    = document.getElementById('cpModalErr');

    var confirmModal = document.getElementById('cpConfirmBackdrop');
    var confirmMsg   = document.getElementById('cpConfirmMsg');
    var _pendingDelete = null;

    function getContactId() {
        var el = document.getElementById('caId');
        return el ? parseInt(el.value || '0', 10) : 0;
    }
    function getToken() {
        var t = document.querySelector('input[name="__RequestVerificationToken"]');
        return t ? t.value : '';
    }
    function htmlEscape(s) {
        return (s == null ? '' : String(s))
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function setNavCount(n) {
        if (!navCount) return;
        if (n > 0) { navCount.style.display = ''; navCount.textContent = String(n); }
        else       { navCount.style.display = 'none'; }
    }
    function renderRows(items) {
        listEl.innerHTML = '';
        if (!items || items.length === 0) {
            emptyEl.style.display = '';
            listWrap.style.display = 'none';
            setNavCount(0);
            return;
        }
        emptyEl.style.display = 'none';
        listWrap.style.display = '';
        setNavCount(items.length);
        items.forEach(function (p, i) {
            var tr = document.createElement('tr');
            tr.innerHTML =
                '<td>' + (i + 1) + '</td>' +
                '<td>' + htmlEscape(p.title) + '</td>' +
                '<td>' + htmlEscape(p.fullName) + '</td>' +
                '<td>' + htmlEscape(p.phone || '') + '</td>' +
                '<td>' + htmlEscape(p.email || '') + '</td>' +
                '<td style="text-align:center;">' +
                    (p.isPrimary
                        ? '<span class="cp-primary-badge">✓</span>'
                        : '<span style="color:rgba(148,163,184,.4);">—</span>') +
                '</td>' +
                '<td>' +
                    '<div class="cp-row-actions">' +
                        '<button type="button" class="cp-action-btn cp-action-btn--edit" data-act="edit" data-id="' + p.id + '" title="Düzenle">✎</button>' +
                        '<button type="button" class="cp-action-btn cp-action-btn--del"  data-act="del"  data-id="' + p.id + '" data-name="' + htmlEscape(p.fullName) + '" title="Sil">🗑</button>' +
                    '</div>' +
                '</td>';
            tr._data = p;
            listEl.appendChild(tr);
        });
    }

    function load() {
        var cid = getContactId();
        if (cid <= 0) {
            noContact.style.display = '';
            listWrap.style.display = 'none';
            emptyEl.style.display = 'none';
            if (addBtn) addBtn.disabled = true;
            setNavCount(0);
            return Promise.resolve();
        }
        noContact.style.display = 'none';
        if (addBtn) addBtn.disabled = false;
        return fetch('/Finance/ContactPersons?contactId=' + cid, { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res && res.ok) renderRows(res.data || []);
                else renderRows([]);
            })
            .catch(function (e) { console.error('[cp] load err', e); renderRows([]); });
    }

    function openModal(person) {
        errBox.style.display = 'none'; errBox.textContent = '';
        // Once dropdown'i doldur (modal hemen acilir, options async gelir; placeholder gosterilir)
        ensureTitlesLoaded().then(function () {
            if (person) {
                // TitleId varsa onu sec; yoksa eski string Title'a gore ad eslesmesi dene.
                if (person.titleId) {
                    fldTitleSel.value = String(person.titleId);
                } else if (person.title) {
                    if (!selectTitleByName(person.title)) {
                        // Eski string Title hicbir lookup'a uymadiysa "Seçiniz…" kalir.
                        fldTitleSel.value = '';
                    }
                }
            }
        });

        if (person) {
            modalTitle.textContent = 'İletişim Kişisini Düzenle';
            fldId.value     = person.id || '';
            // Dropdown ensureTitlesLoaded() sonrasi set ediliyor — burada onceden "" koy
            fldTitleSel.value = person.titleId ? String(person.titleId) : '';
            fldName.value   = person.fullName || '';
            fldPhone.value  = person.phone || '';
            fldEmail.value  = person.email || '';
            fldNotes.value  = person.notes || '';
            fldPrim.checked   = !!person.isPrimary;
            fldActive.checked = person.isActive !== false;
        } else {
            modalTitle.textContent = 'Yeni İletişim Kişisi';
            fldId.value = '';
            fldTitleSel.value = '';
            fldName.value = '';
            fldPhone.value = ''; fldEmail.value = ''; fldNotes.value = '';
            fldPrim.checked = false; fldActive.checked = true;
        }
        modal.style.display = 'flex';
        setTimeout(function () { fldTitleSel.focus(); }, 50);
    }
    function closeModal() { modal.style.display = 'none'; }

    function save() {
        var cid = getContactId();
        if (cid <= 0) { errBox.textContent = 'Önce cari kart bilgilerini kaydedin.'; errBox.style.display = ''; return; }
        var titleId = parseInt(fldTitleSel.value || '0', 10);
        var n = (fldName.value  || '').trim();
        if (!titleId) { errBox.textContent = 'Ünvan zorunlu.'; errBox.style.display = ''; fldTitleSel.focus(); return; }
        if (!n) { errBox.textContent = 'Ad Soyad zorunlu.'; errBox.style.display = ''; fldName.focus(); return; }

        // Display amacli secili option metnini de yolla — backend TitleId'yi kullanir,
        // title alani sadece legacy fallback kolonu icin senkron tutulur.
        var titleText = '';
        if (fldTitleSel.selectedIndex >= 0) {
            titleText = (fldTitleSel.options[fldTitleSel.selectedIndex].textContent || '').trim();
        }

        var payload = {
            id: parseInt(fldId.value || '0', 10),
            contactId: cid,
            titleId: titleId,
            title: titleText,
            fullName: n,
            phone: (fldPhone.value || '').trim() || null,
            email: (fldEmail.value || '').trim() || null,
            notes: (fldNotes.value || '').trim() || null,
            isPrimary: !!fldPrim.checked,
            isActive: !!fldActive.checked,
        };

        fetch('/Finance/SaveContactPerson', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
            body: JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            if (!res || !res.ok) {
                errBox.textContent = (res && res.message) || 'Kayıt başarısız.';
                errBox.style.display = '';
                return;
            }
            closeModal();
            load();
            if (window.CalibraAlert && window.CalibraAlert.toast) {
                window.CalibraAlert.toast('İletişim kişisi kaydedildi.', 'success');
            }
        })
        .catch(function (e) {
            errBox.textContent = 'Bağlantı hatası: ' + e.message;
            errBox.style.display = '';
        });
    }

    function openConfirm(id, name) {
        _pendingDelete = id;
        confirmMsg.innerHTML = 'Bu iletişim kişisini silmek istediğinize emin misiniz?'
            + (name ? '<br><b style="color:#a5b4fc;">' + htmlEscape(name) + '</b>' : '');
        confirmModal.style.display = 'flex';
    }
    function closeConfirm() { confirmModal.style.display = 'none'; _pendingDelete = null; }
    function doDelete() {
        var id = _pendingDelete; if (!id) return;
        fetch('/Finance/DeleteContactPerson?id=' + encodeURIComponent(id), {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'RequestVerificationToken': getToken() }
        })
        .then(function (r) { return r.json(); })
        .then(function (res) {
            closeConfirm();
            if (res && res.ok) { load(); }
            else if (window.CalibraAlert && window.CalibraAlert.error) {
                window.CalibraAlert.error((res && res.message) || 'Silme başarısız.');
            }
        })
        .catch(function (e) { closeConfirm(); console.error('[cp] delete err', e); });
    }

    // Event bindings
    if (addBtn) addBtn.addEventListener('click', function () { openModal(null); });
    if (fldTitleAdd) fldTitleAdd.addEventListener('click', addInlineTitle);
    document.getElementById('cpModalClose')?.addEventListener('click', closeModal);
    document.getElementById('cpModalCancel')?.addEventListener('click', closeModal);
    document.getElementById('cpModalSave')?.addEventListener('click', save);
    modal?.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });

    document.getElementById('cpConfirmCancel')?.addEventListener('click', closeConfirm);
    document.getElementById('cpConfirmOk')?.addEventListener('click', doDelete);
    confirmModal?.addEventListener('click', function (e) { if (e.target === confirmModal) closeConfirm(); });

    // Esc / Enter klavye kisayollari
    document.addEventListener('keydown', function (e) {
        if (modal && modal.style.display === 'flex') {
            if (e.key === 'Escape') { e.preventDefault(); closeModal(); }
            else if (e.key === 'Enter' && e.target && e.target.tagName !== 'TEXTAREA') {
                e.preventDefault(); save();
            }
        } else if (confirmModal && confirmModal.style.display === 'flex') {
            if (e.key === 'Escape') { e.preventDefault(); closeConfirm(); }
            else if (e.key === 'Enter') { e.preventDefault(); doDelete(); }
        }
    });

    if (listEl) listEl.addEventListener('click', function (e) {
        var btn = e.target.closest && e.target.closest('button[data-act]');
        if (!btn) return;
        var act = btn.getAttribute('data-act');
        var id  = parseInt(btn.getAttribute('data-id') || '0', 10);
        if (act === 'edit') {
            var tr = btn.closest('tr');
            openModal(tr && tr._data ? tr._data : { id: id });
        } else if (act === 'del') {
            openConfirm(id, btn.getAttribute('data-name') || '');
        }
    });

    // Lazy load: sidenav "İletişim Bilgileri" tabina ilk tiklamada yukle.
    // (Eski "persons" sekmesi "contact" altina birlestirildi)
    document.addEventListener('click', function (e) {
        var btn = e.target.closest && e.target.closest('[data-nav-key="contact"]');
        if (!btn) return;
        if (loaded) return;
        loaded = true;
        load();
    });
})();
</script>
}
