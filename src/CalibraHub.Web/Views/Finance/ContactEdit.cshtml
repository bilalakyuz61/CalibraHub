@{
    var existing   = ViewData["Contact"] as CalibraHub.Application.Contracts.ContactDto;
    var isEdit     = existing is not null;
    var pageTitle  = isEdit ? $"Cari Düzenle — {existing!.AccountCode}" : "Yeni Cari Hesap";
    ViewData["Title"]     = pageTitle;
    ViewData["BodyClass"] = "page-contact-account-edit";

    var upsertUrl = Url.Action("UpsertContact", "Finance")!;
    var listUrl   = Url.Action("Contacts",      "Finance")!;
}

@section Styles {
<style>
/* ── Page shell ──────────────────────────────────────────────── */
.page-contact-account-edit .integrator-dashboard {
    height: 100% !important; min-height: 0 !important;
    padding: 0 !important; max-width: none !important;
    background: transparent !important; box-shadow: none !important;
    border: none !important; border-radius: 0 !important;
}
.page-contact-account-edit .integrator-dashboard__content {
    display: flex !important; flex-direction: column !important;
    width: 100% !important; max-width: none !important;
    min-height: 0 !important; padding: 0 !important;
    margin: 0 !important; overflow: hidden !important;
}
.workspace-frame-body.page-contact-account-edit .app-content-area--workspace-frame {
    height: 100dvh; display: flex; flex-direction: column;
    overflow: hidden; padding: 0;
}
.workspace-frame-body.page-contact-account-edit .integrator-dashboard {
    flex: 1 1 auto; min-height: 0; height: 100%;
}

/* ── Action bar ─────────────────────────────────────────────── */
.ca-action-bar {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 16px; flex-shrink: 0;
    background: rgba(15,15,26,0.85); border-bottom: 1px solid rgba(255,255,255,0.06);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    position: relative; overflow: hidden;
}
body.app-theme-light .ca-action-bar {
    background: rgba(248,250,252,0.92); border-bottom-color: #e2e8f0;
}
.ca-action-bar .ca-meta {
    margin-right: auto; font-size: 0.72rem; color: rgba(255,255,255,0.55);
    font-weight: 500;
}
body.app-theme-light .ca-action-bar .ca-meta { color: #94a3b8; }
.ca-action-bar .ca-meta strong { color: rgba(255,255,255,0.7); font-weight: 700; }
body.app-theme-light .ca-action-bar .ca-meta strong { color: #334155; }

/* Success flash — K.I.T.T. yesil tarayici (aksiyon seridi alti) */
.ca-action-bar::before {
    content: ''; position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 2px;
    pointer-events: none; opacity: 0;
    background: linear-gradient(90deg,
        rgba(0, 60, 20, 0) 0%,
        rgba(10, 120, 40, .55) 50%,
        rgba(0, 60, 20, 0) 100%);
}
.ca-action-bar::after {
    content: ''; position: absolute;
    left: 0; bottom: -1px;
    width: 18%; height: 4px;
    pointer-events: none; opacity: 0;
    background: linear-gradient(90deg,
        transparent 0%,
        rgba(34, 197, 94, .35) 18%,
        rgba(74, 255, 140, 1) 50%,
        rgba(34, 197, 94, .35) 82%,
        transparent 100%);
    box-shadow:
        0 0 10px 2px rgba(34, 197, 94, .95),
        0 0 22px 6px rgba(34, 197, 94, .55),
        0 0 40px 12px rgba(34, 197, 94, .22);
    border-radius: 50%;
}
.ca-action-bar.is-save-flash::before { animation: caKittBg   1800ms ease-out forwards; }
.ca-action-bar.is-save-flash::after  { animation: caKittScan 1800ms cubic-bezier(.45,.05,.55,.95) forwards; }
@@keyframes caKittBg {
    0%, 100% { opacity: 0; }
    10%, 90% { opacity: 1; }
}
@@keyframes caKittScan {
    0%   { opacity: 0; left: 0; }
    8%   { opacity: 1; }
    48%  { opacity: 1; left: 82%; }
    52%  { opacity: 1; left: 82%; }
    92%  { opacity: 1; left: 0; }
    100% { opacity: 0; left: 0; }
}

/* ── Buttons ─────────────────────────────────────────────────── */
.ca-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px; border-radius: 8px; border: 1px solid;
    font-size: 0.78rem; font-weight: 600; cursor: pointer;
    transition: all 0.12s ease; background: transparent;
}
.ca-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.ca-btn--primary { background: #6366f1; border-color: #4f46e5; color: #fff; }
.ca-btn--primary:hover:not(:disabled) { background: #4f46e5; }
.ca-btn--primary.loading { opacity: .7; pointer-events: none; }
.ca-btn--secondary {
    background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.65);
}
body.app-theme-light .ca-btn--secondary {
    background: #fff; border-color: #e2e8f0; color: #475569;
}
.ca-btn--secondary:hover:not(:disabled) { background: rgba(255,255,255,0.1); color: #fff; }
body.app-theme-light .ca-btn--secondary:hover:not(:disabled) { background: #f1f5f9; color: #1e293b; }

/* ── Danger button (Sil/Delete) ─────────────────────────────── */
.ca-btn--danger {
    background: rgba(239,68,68,0.12); border-color: rgba(239,68,68,0.3); color: #fca5a5;
}
.ca-btn--danger:hover:not(:disabled) { background: #ef4444; color: #fff; border-color: #dc2626; }
body.app-theme-light .ca-btn--danger { background: #fef2f2; border-color: #fecaca; color: #b91c1c; }
body.app-theme-light .ca-btn--danger:hover:not(:disabled) { background: #ef4444; color: #fff; border-color: #dc2626; }

/* ── Teslim adres kartlari (tema uyumlu) ────────────────────── */
.ca-addr-card {
    padding: 12px 14px;
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 10px;
    background: rgba(255,255,255,0.04);
    display: flex; align-items: center; gap: 12px;
    transition: background .12s, border-color .12s;
}
.ca-addr-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.15); }
body.app-theme-light .ca-addr-card { background: #fff; border-color: #e2e8f0; }
body.app-theme-light .ca-addr-card:hover { background: #f8fafc; border-color: #cbd5e1; }
.ca-addr-card__main { flex: 1 1 auto; min-width: 0; }
.ca-addr-card__name { font-weight: 700; font-size: .92rem; color: rgba(255,255,255,.92); display: flex; align-items: center; gap: 8px; }
body.app-theme-light .ca-addr-card__name { color: #1e293b; }
.ca-addr-card__name .ca-addr-default-tag {
    font-size: .68rem; font-weight: 600; padding: 2px 8px; border-radius: 999px;
    background: rgba(16,185,129,0.18); color: #34d399; border: 1px solid rgba(16,185,129,0.35);
}
body.app-theme-light .ca-addr-card__name .ca-addr-default-tag { background: #d1fae5; color: #047857; border-color: #6ee7b7; }
.ca-addr-card__loc {
    font-size: .78rem; color: rgba(255,255,255,.55); margin-top: 4px;
    font-variant-numeric: tabular-nums;
}
body.app-theme-light .ca-addr-card__loc { color: #64748b; }
.ca-addr-card__line { font-size: .82rem; color: rgba(255,255,255,.78); margin-top: 4px; }
body.app-theme-light .ca-addr-card__line { color: #334155; }

/* ── Verilen teklifler liste satirlari ───────────────────────── */
.ca-quote-row {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.2fr auto;
    gap: 12px; align-items: center;
    padding: 10px 14px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    background: rgba(255,255,255,0.03);
    transition: background .12s, border-color .12s;
    text-decoration: none;
    color: inherit;
}
.ca-quote-row:hover { background: rgba(255,255,255,0.06); border-color: rgba(99,102,241,0.4); }
body.app-theme-light .ca-quote-row { background: #fff; border-color: #e2e8f0; }
body.app-theme-light .ca-quote-row:hover { background: #f8fafc; border-color: #818cf8; }
.ca-quote-no   { font-family: 'JetBrains Mono','Fira Code',monospace; font-size: .82rem; font-weight: 700; color: rgba(255,255,255,.92); }
body.app-theme-light .ca-quote-no { color: #1e293b; }
.ca-quote-date { font-size: .78rem; color: rgba(255,255,255,.6); font-variant-numeric: tabular-nums; }
body.app-theme-light .ca-quote-date { color: #64748b; }
.ca-quote-total { font-size: .86rem; font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; color: #fbbf24; }
body.app-theme-light .ca-quote-total { color: #b45309; }
.ca-quote-status {
    font-size: .72rem; font-weight: 600; padding: 3px 10px; border-radius: 999px;
    border: 1px solid; text-align: center; white-space: nowrap;
}
.ca-quote-status--Draft     { background: rgba(148,163,184,.18); color: #cbd5e1; border-color: rgba(148,163,184,.35); }
.ca-quote-status--Sent      { background: rgba(59,130,246,.18); color: #93c5fd; border-color: rgba(59,130,246,.35); }
.ca-quote-status--Approved  { background: rgba(16,185,129,.20); color: #34d399; border-color: rgba(16,185,129,.40); }
.ca-quote-status--Rejected  { background: rgba(239,68,68,.20); color: #fca5a5; border-color: rgba(239,68,68,.40); }
.ca-quote-status--Revised   { background: rgba(245,158,11,.20); color: #fcd34d; border-color: rgba(245,158,11,.40); }
.ca-quote-status--Cancelled { background: rgba(120,113,108,.20); color: #d6d3d1; border-color: rgba(120,113,108,.40); }
.ca-quote-arrow { color: rgba(255,255,255,.35); font-size: 16px; }
body.app-theme-light .ca-quote-arrow { color: #94a3b8; }

/* ── Two-column body ─────────────────────────────────────────── */
.ca-body {
    display: flex; flex: 1 1 auto; min-height: 0; overflow: hidden;
}

/* ── Sidebar ─────────────────────────────────────────────────── */
.ca-sidenav {
    width: 192px; flex-shrink: 0;
    border-right: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.02);
    display: flex; flex-direction: column;
    padding: 10px 0; overflow-y: auto;
}
body.app-theme-light .ca-sidenav {
    background: #f8fafc; border-right-color: #e2e8f0;
}
.ca-sidenav-label {
    font-size: 0.7rem; font-weight: 700;
    color: rgba(255,255,255,0.55);
    padding: 10px 16px 5px; margin-top: 4px;
}
.ca-sidenav-label:first-child { margin-top: 0; }
body.app-theme-light .ca-sidenav-label { color: #94a3b8; }
.ca-nav-btn {
    display: flex; align-items: center; gap: 8px;
    width: 100%; padding: 8px 16px;
    background: transparent; border: none;
    border-left: 3px solid transparent;
    color: rgba(255,255,255,0.65);
    font-size: 0.78rem; font-weight: 500; text-align: left;
    cursor: pointer; transition: all 0.15s; line-height: 1.35;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
body.app-theme-light .ca-nav-btn { color: #64748b; }
.ca-nav-btn:hover {
    background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.85);
}
body.app-theme-light .ca-nav-btn:hover {
    background: rgba(15,23,42,0.04); color: #1e293b;
}
.ca-nav-btn.is-active {
    border-left-color: #6366f1;
    background: rgba(99,102,241,0.09);
    color: #a5b4fc; font-weight: 600;
}
body.app-theme-light .ca-nav-btn.is-active {
    background: rgba(99,102,241,0.07); color: #4f46e5;
}
.ca-nav-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: currentColor; flex-shrink: 0; opacity: 0.5;
}
.ca-nav-btn.is-active .ca-nav-dot { opacity: 1; }

/* ── Content area ────────────────────────────────────────────── */
.ca-content {
    flex: 1 1 auto; min-width: 0; overflow-y: auto;
    padding: 20px 24px;
    background: transparent;
}
body.app-theme-dark .ca-content,
html.dark .ca-content {
    background: #0c0f1a;
    background-image:
        radial-gradient(at 20% 30%, rgba(99,102,241,0.12) 0px, transparent 50%),
        radial-gradient(at 80% 20%, rgba(14,165,233,0.08) 0px, transparent 50%),
        radial-gradient(at 50% 80%, rgba(168,85,247,0.08) 0px, transparent 50%);
}
body.app-theme-light .ca-content { background: #f8fafc; }

/* Widget gruplari varsayilan gizli */
.ca-content [data-dyn-group-id] { display: none; }

/* ── Glass card ─────────────────────────────────────────────── */
.ca-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px; padding: 22px;
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    margin-bottom: 16px;
}
body.app-theme-light .ca-card {
    background: rgba(255,255,255,0.8); border-color: rgba(15,23,42,0.08);
    box-shadow: 0 2px 6px rgba(15,23,42,0.04);
}
.ca-card__title {
    font-size: 0.85rem; font-weight: 700;
    color: rgba(255,255,255,0.85);
    margin: 0 0 14px 0; display: flex; align-items: center; gap: 8px;
}
body.app-theme-light .ca-card__title { color: #64748b; }
.ca-card__title::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%; background: #6366f1;
}

/* ── Horizontal field rows — etiket solda, alan sagda ────────── */
.ca-rows { display: flex; flex-direction: column; gap: 0; }
.ca-row {
    display: flex; align-items: center; gap: 16px;
    padding: 9px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
}
.ca-row:last-child { border-bottom: none; }
body.app-theme-light .ca-row { border-bottom-color: rgba(15,23,42,0.06); }
.ca-row .ca-label {
    width: 140px; min-width: 140px; flex-shrink: 0;
    font-size: .75rem; font-weight: 600; color: rgba(255,255,255,0.55);
    letter-spacing: .02em; text-align: right; padding-right: 4px;
}
body.app-theme-light .ca-row .ca-label { color: #64748b; }
.ca-row .ca-label span.required { color: #f87171; margin-left: 2px; }
.ca-row .ca-input,
.ca-row .ca-select { flex: 1 1 auto; min-width: 0; }

/* Eski grid uyumluluğu (widget'lar kullanabilir) */
.ca-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.ca-grid-1 { display: grid; grid-template-columns: 1fr; gap: 14px; }
@@media (max-width: 580px) { .ca-grid-2 { grid-template-columns: 1fr; } }

/* ── Field (fallback) ────────────────────────────────────────── */
.ca-field { display: flex; flex-direction: column; gap: 5px; }
.ca-field--full { grid-column: 1 / -1; }
.ca-label {
    font-size: .72rem; font-weight: 600; color: rgba(255,255,255,0.65);
    letter-spacing: .02em;
}
body.app-theme-light .ca-label { color: #64748b; }
.ca-label span.required { color: #f87171; margin-left: 2px; }
.ca-input, .ca-select {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 9px; padding: 9px 12px;
    font-size: .85rem; color: rgba(255,255,255,.85);
    width: 100%; outline: none; transition: border-color .15s, background .15s;
}
body.app-theme-light .ca-input,
body.app-theme-light .ca-select {
    background: #fff; border-color: #e2e8f0; color: #1e293b;
}
.ca-input::placeholder { color: rgba(255,255,255,.2); }
body.app-theme-light .ca-input::placeholder { color: #94a3b8; }
.ca-input:focus, .ca-select:focus {
    border-color: #6366f1;
    background: rgba(255,255,255,.06);
    box-shadow: 0 0 0 3px rgba(99,102,241,.12);
}
body.app-theme-light .ca-input:focus,
body.app-theme-light .ca-select:focus { background: #fff; }
.ca-select option { background: #0d1117; color: rgba(255,255,255,.85); }
body.app-theme-light .ca-select option { background: #ffffff; color: #1e293b; }

/* Toggle (IsActive) */
.ca-toggle-row {
    display: flex; align-items: center; gap: 12px; padding: 4px 0;
}
.ca-toggle-label { font-size: .84rem; color: rgba(255,255,255,.7); }
body.app-theme-light .ca-toggle-label { color: #475569; }
.ca-toggle {
    position: relative; width: 40px; height: 22px;
    display: inline-block; flex-shrink: 0;
}
.ca-toggle input { opacity: 0; width: 0; height: 0; }
.ca-toggle-track {
    position: absolute; inset: 0; border-radius: 22px; cursor: pointer;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.15); transition: .25s;
}
.ca-toggle input:checked + .ca-toggle-track { background: #6366f1; border-color: #818cf8; }
.ca-toggle-track::before {
    content: ''; position: absolute; height: 16px; width: 16px;
    left: 2px; top: 2px; border-radius: 50%;
    background: rgba(255,255,255,.6); transition: .25s;
}
.ca-toggle input:checked + .ca-toggle-track::before {
    transform: translateX(18px); background: #fff;
}

/* Link widget */
.ca-link-group { display: flex; align-items: stretch; gap: 8px; }
.ca-link-group > .ca-input { flex: 1 1 auto; min-width: 0; }
.ca-link-btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 6px; padding: 0 14px; min-height: 34px;
    border-radius: 10px; font-size: .78rem; font-weight: 600;
    color: #c4b5fd; text-decoration: none;
    background: rgba(139,92,246,.14);
    border: 1px solid rgba(139,92,246,.45);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    transition: all .18s ease; cursor: pointer; flex-shrink: 0;
}
.ca-link-btn:hover:not(.is-disabled) {
    background: rgba(139,92,246,.25); border-color: rgba(139,92,246,.65);
    color: #e9d5ff; transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(139,92,246,.2);
}
.ca-link-btn.is-disabled { opacity: .35; cursor: not-allowed; pointer-events: none; }
body.app-theme-light .ca-link-btn { color: #6d28d9; background: rgba(139,92,246,.12); border-color: rgba(139,92,246,.4); }
body.app-theme-light .ca-link-btn:hover:not(.is-disabled) { background: rgba(139,92,246,.22); color: #5b21b6; }

/* Lookup widget */
.ca-lookup-group { display: flex; align-items: stretch; gap: 8px; position: relative; }
.ca-lookup-group > .ca-input { flex: 1 1 auto; min-width: 0; }
.ca-lookup-btn, .ca-lookup-clear {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 34px; min-height: 34px; padding: 0 10px;
    border-radius: 10px; cursor: pointer; flex-shrink: 0;
    border: 1px solid rgba(245,158,11,.45);
    background: rgba(245,158,11,.14); color: #fcd34d;
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    transition: all .18s ease;
}
.ca-lookup-btn:hover:not(:disabled) {
    background: rgba(245,158,11,.25); border-color: rgba(245,158,11,.65);
    transform: translateY(-1px); box-shadow: 0 4px 12px rgba(245,158,11,.2);
}
.ca-lookup-btn:disabled { opacity: .35; cursor: not-allowed; }
.ca-lookup-clear {
    background: rgba(244,63,94,.1); border-color: rgba(244,63,94,.4); color: #fda4af;
}
.ca-lookup-clear:hover { background: rgba(244,63,94,.2); border-color: rgba(244,63,94,.6); }
body.app-theme-light .ca-lookup-btn { color: #b45309; }
body.app-theme-light .ca-lookup-clear { color: #be123c; }

.ca-lookup-modal-backdrop {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.55); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    animation: caLookupFadeIn .15s ease-out;
}
@@keyframes caLookupFadeIn { from { opacity: 0; } to { opacity: 1; } }
.ca-lookup-modal {
    width: min(900px,95vw); max-height: 80vh;
    display: flex; flex-direction: column;
    background: var(--app-surface, #1a1f2e);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 16px; box-shadow: 0 24px 72px rgba(0,0,0,.5);
    overflow: hidden;
    animation: caLookupSlideIn .2s cubic-bezier(0.23, 1, 0.32, 1);
}
@@keyframes caLookupSlideIn {
    from { transform: translateY(12px) scale(0.98); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
}
body.app-theme-light .ca-lookup-modal { background: #fff; border-color: #e2e8f0; }
.ca-lookup-modal header {
    padding: 14px 18px; display: flex; align-items: center; gap: 10px;
    border-bottom: 1px solid rgba(255,255,255,.08); color: #fbbf24;
}
body.app-theme-light .ca-lookup-modal header { border-bottom-color: #e2e8f0; color: #d97706; }
.ca-lookup-modal header input {
    flex: 1; min-width: 0;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
    border-radius: 8px; padding: 8px 12px; color: inherit;
    font-size: .85rem; outline: none;
}
.ca-lookup-modal header input:focus {
    border-color: rgba(245,158,11,.5);
    box-shadow: 0 0 0 3px rgba(245,158,11,.12);
}
body.app-theme-light .ca-lookup-modal header input {
    background: #f8fafc; border-color: #e2e8f0; color: #1e293b;
}
.ca-lookup-close {
    background: transparent; border: none; color: inherit; cursor: pointer;
    padding: 6px; border-radius: 6px; transition: background .15s;
    display: inline-flex; align-items: center; justify-content: center;
}
.ca-lookup-close:hover { background: rgba(255,255,255,.08); }
.ca-lookup-error {
    padding: 10px 18px; background: rgba(239,68,68,.1); color: #f87171;
    font-size: .75rem; border-bottom: 1px solid rgba(239,68,68,.2);
}
.ca-lookup-scroll { flex: 1; overflow-y: auto; min-height: 0; }
.ca-lookup-table { width: 100%; border-collapse: collapse; font-size: .78rem; }
.ca-lookup-table thead th {
    position: sticky; top: 0; z-index: 1;
    background: var(--app-surface, #1a1f2e);
    text-align: left; padding: 10px 14px;
    font-weight: 700;
    font-size: .78rem; color: #fbbf24;
    border-bottom: 1px solid rgba(255,255,255,.08);
}
body.app-theme-light .ca-lookup-table thead th {
    background: #f8fafc; color: #b45309; border-bottom-color: #e2e8f0;
}
.ca-lookup-table tbody tr {
    cursor: pointer; border-bottom: 1px solid rgba(255,255,255,.04);
    transition: background .12s;
}
.ca-lookup-table tbody tr:hover { background: rgba(245,158,11,.1); }
body.app-theme-light .ca-lookup-table tbody tr { border-bottom-color: #f1f5f9; }
body.app-theme-light .ca-lookup-table tbody tr:hover { background: rgba(245,158,11,.08); }
.ca-lookup-table td { padding: 9px 14px; color: var(--app-text, #e2e8f0); }
body.app-theme-light .ca-lookup-table td { color: #334155; }
.ca-lookup-empty, .ca-lookup-sentinel {
    text-align: center; padding: 20px;
    color: rgba(255,255,255,.35); font-size: .75rem;
}
.ca-lookup-sentinel span { display: inline-flex; align-items: center; gap: 6px; }
.ca-lookup-sentinel .spin { animation: caLookupSpin .9s linear infinite; }
@@keyframes caLookupSpin { from { transform: rotate(0); } to { transform: rotate(360deg); } }
.ca-lookup-footer {
    padding: 10px 18px; font-size: .7rem; opacity: .6;
    border-top: 1px solid rgba(255,255,255,.06);
}
body.app-theme-light .ca-lookup-footer { border-top-color: #e2e8f0; }

/* ── Grid (Alt Tablo / Master-Detail) widget ────────────────── */
.ca-field--grid { grid-column: 1 / -1; }
.ca-grid-wrap {
    border-radius: 14px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 14px 16px 16px;
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
body.app-theme-light .ca-grid-wrap { background: #ffffff; border-color: #e2e8f0; }
.ca-grid-header {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; margin-bottom: 12px;
}
.ca-grid-header__title {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.85rem; font-weight: 700;
    color: #60a5fa;
}
body.app-theme-light .ca-grid-header__title { color: #2563eb; }
.ca-grid-add-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; min-height: 34px;
    border-radius: 10px; font-size: 0.78rem; font-weight: 600;
    color: #93c5fd;
    background: rgba(59,130,246,0.14);
    border: 1px solid rgba(59,130,246,0.45);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    transition: all 0.18s ease; cursor: pointer;
}
.ca-grid-add-btn:hover:not(:disabled) {
    background: rgba(59,130,246,0.25); border-color: rgba(59,130,246,0.65);
    transform: translateY(-1px); box-shadow: 0 4px 14px rgba(59,130,246,0.22);
}
.ca-grid-add-btn:disabled { opacity: 0.4; cursor: not-allowed; }
body.app-theme-light .ca-grid-add-btn { color: #1d4ed8; }
.ca-grid-error {
    padding: 10px 14px; margin-bottom: 10px;
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25);
    border-radius: 10px; color: #f87171; font-size: 0.75rem;
}
.ca-grid-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 6px; padding: 32px 16px;
    border-radius: 12px;
    border: 1.5px dashed rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.35); font-size: 0.82rem;
}
.ca-grid-empty small { font-size: 0.7rem; opacity: 0.7; }
body.app-theme-light .ca-grid-empty { border-color: #e2e8f0; color: #94a3b8; }
.ca-grid-rows { display: flex; flex-direction: column; gap: 10px; }
.ca-grid-row {
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: center; gap: 14px; padding: 12px 14px;
    border-radius: 12px;
    background: rgba(255,255,255,0.035);
    border: 1px solid rgba(255,255,255,0.06);
    backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
    transition: all 0.18s ease;
}
.ca-grid-row:hover {
    background: rgba(59,130,246,0.08); border-color: rgba(59,130,246,0.25);
    transform: translateY(-1px); box-shadow: 0 6px 18px rgba(59,130,246,0.08);
}
body.app-theme-light .ca-grid-row { background: #f8fafc; border-color: #e2e8f0; }
body.app-theme-light .ca-grid-row:hover { background: #eff6ff; border-color: #bfdbfe; }
.ca-grid-row__index {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 28px; height: 28px; border-radius: 999px;
    background: rgba(59,130,246,0.16); border: 1px solid rgba(59,130,246,0.35);
    color: #93c5fd; font-size: 0.7rem; font-weight: 700;
}
body.app-theme-light .ca-grid-row__index { color: #1d4ed8; }
.ca-grid-row__cells {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 10px 18px; min-width: 0;
}
.ca-grid-row__cell { display: flex; flex-direction: column; min-width: 0; }
.ca-grid-row__label {
    font-size: 0.72rem; font-weight: 600;
    color: rgba(255,255,255,0.55); margin-bottom: 2px;
}
body.app-theme-light .ca-grid-row__label { color: #94a3b8; }
.ca-grid-row__value {
    font-size: 0.82rem; color: rgba(255,255,255,0.88);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
body.app-theme-light .ca-grid-row__value { color: #1e293b; }
.ca-grid-row__actions { display: flex; gap: 6px; flex-shrink: 0; }
.ca-grid-row__edit, .ca-grid-row__delete {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 8px; cursor: pointer;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.55); transition: all 0.15s;
}
.ca-grid-row__edit:hover {
    background: rgba(59,130,246,0.2); border-color: rgba(59,130,246,0.5); color: #93c5fd;
}
.ca-grid-row__delete:hover {
    background: rgba(239,68,68,0.18); border-color: rgba(239,68,68,0.5); color: #fca5a5;
}
body.app-theme-light .ca-grid-row__edit,
body.app-theme-light .ca-grid-row__delete { background: #fff; border-color: #e2e8f0; color: #64748b; }
body.app-theme-light .ca-grid-row__edit:hover { color: #1d4ed8; }
body.app-theme-light .ca-grid-row__delete:hover { color: #be123c; }

.ca-grid-modal-backdrop {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    animation: caGridFadeIn 0.15s ease-out;
}
@@keyframes caGridFadeIn { from { opacity: 0; } to { opacity: 1; } }
.ca-grid-modal {
    width: min(780px,95vw); max-height: 85vh;
    display: flex; flex-direction: column;
    background: var(--app-surface, #1a1f2e);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px; box-shadow: 0 24px 72px rgba(0,0,0,0.55);
    overflow: hidden;
    animation: caGridSlide 0.22s cubic-bezier(0.23,1,0.32,1);
}
@@keyframes caGridSlide {
    from { transform: translateY(16px) scale(0.97); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
}
body.app-theme-light .ca-grid-modal { background: #fff; border-color: #e2e8f0; }
.ca-grid-modal header {
    padding: 16px 20px; display: flex; align-items: center; gap: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.08); color: #60a5fa;
}
body.app-theme-light .ca-grid-modal header { border-bottom-color: #e2e8f0; color: #2563eb; }
.ca-grid-modal__title {
    flex: 1; font-size: 0.88rem; font-weight: 700; color: rgba(255,255,255,0.9);
}
body.app-theme-light .ca-grid-modal__title { color: #1e293b; }
.ca-grid-modal__close {
    background: transparent; border: none; color: inherit; cursor: pointer;
    padding: 6px; border-radius: 6px;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.15s;
}
.ca-grid-modal__close:hover { background: rgba(255,255,255,0.08); }
.ca-grid-modal__body { flex: 1; overflow-y: auto; padding: 18px 20px; }
.ca-grid-modal__footer {
    padding: 14px 20px; display: flex; justify-content: flex-end; gap: 10px;
    border-top: 1px solid rgba(255,255,255,0.08);
}
body.app-theme-light .ca-grid-modal__footer { border-top-color: #e2e8f0; }
.ca-grid-modal__cancel, .ca-grid-modal__confirm {
    padding: 8px 18px; min-height: 36px; border-radius: 10px; cursor: pointer;
    font-size: 0.78rem; font-weight: 600; transition: all 0.15s;
}
.ca-grid-modal__cancel {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.65);
}
.ca-grid-modal__cancel:hover { background: rgba(255,255,255,0.08); }
body.app-theme-light .ca-grid-modal__cancel { background: #fff; border-color: #e2e8f0; color: #64748b; }
body.app-theme-light .ca-grid-modal__cancel:hover { background: #f1f5f9; }
.ca-grid-modal__confirm {
    background: rgba(59,130,246,0.18); border: 1px solid rgba(59,130,246,0.55); color: #93c5fd;
}
.ca-grid-modal__confirm:hover {
    background: rgba(59,130,246,0.3); border-color: rgba(59,130,246,0.75);
    transform: translateY(-1px); box-shadow: 0 4px 14px rgba(59,130,246,0.25);
}
body.app-theme-light .ca-grid-modal__confirm { color: #1d4ed8; }

/* ── Rule Engine — visibility / disabled / formula / error ───── */
.ca-field--readonly .ca-field__readonly-wrap {
    opacity: 0.62; cursor: not-allowed; position: relative;
}
.ca-field--readonly .ca-field__readonly-wrap::after {
    content: ''; position: absolute; inset: 0; border-radius: 8px;
    background: repeating-linear-gradient(45deg, rgba(255,255,255,0.02), rgba(255,255,255,0.02) 8px, rgba(255,255,255,0.05) 8px, rgba(255,255,255,0.05) 16px);
    pointer-events: none;
}
body.app-theme-light .ca-field--readonly .ca-field__readonly-wrap::after {
    background: repeating-linear-gradient(45deg, rgba(15,23,42,0.015), rgba(15,23,42,0.015) 8px, rgba(15,23,42,0.04) 8px, rgba(15,23,42,0.04) 16px);
}
.ca-field--formula .ca-label::after {
    content: ' f'; display: inline-block; margin-left: 4px;
    padding: 1px 6px; border-radius: 6px;
    font-size: 0.62rem; font-weight: 700; font-family: 'Courier New', monospace;
    color: #a78bfa; background: rgba(139,92,246,0.14); border: 1px solid rgba(139,92,246,0.32);
}
body.app-theme-light .ca-field--formula .ca-label::after { color: #7c3aed; background: rgba(139,92,246,0.1); }
.ca-rule-error {
    display: flex; align-items: flex-start; gap: 5px;
    margin-top: 4px; padding: 5px 9px;
    font-size: 0.7rem; line-height: 1.35; color: #fca5a5;
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.22); border-radius: 8px;
}
.ca-rule-error::before { content: '\26A0'; flex-shrink: 0; color: #f87171; font-size: 0.78rem; }
body.app-theme-light .ca-rule-error { color: #b91c1c; background: rgba(239,68,68,0.06); border-color: rgba(239,68,68,0.28); }
body.app-theme-light .ca-rule-error::before { color: #dc2626; }
.ca-rule-cycle {
    padding: 18px 22px; background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.35); border-radius: 12px; color: #fca5a5;
}
.ca-rule-cycle strong { color: #f87171; }
.ca-rule-cycle code {
    display: inline-block; margin-top: 4px; padding: 3px 9px;
    background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px; font-family: 'Courier New', monospace;
}
body.app-theme-light .ca-rule-cycle { background: rgba(239,68,68,0.07); border-color: rgba(239,68,68,0.3); color: #991b1b; }
body.app-theme-light .ca-rule-cycle strong { color: #dc2626; }
body.app-theme-light .ca-rule-cycle code { background: #fef2f2; border-color: #fecaca; color: #7f1d1d; }

/* ── Validation — red border + shake ────────────────────────── */
.ca-input.is-invalid, .ca-select.is-invalid {
    border-color: #ef4444 !important;
    background: rgba(239,68,68,.06) !important;
    box-shadow: 0 0 0 3px rgba(239,68,68,.20) !important;
    animation: caShake 0.45s cubic-bezier(.36,.07,.19,.97) both;
}
@@keyframes caShake {
    10%, 90% { transform: translateX(-2px); }
    20%, 80% { transform: translateX(3px); }
    30%, 50%, 70% { transform: translateX(-4px); }
    40%, 60% { transform: translateX(4px); }
}

/* ── Message ─────────────────────────────────────────────────── */
.ca-message {
    padding: 10px 14px; border-radius: 10px; margin-bottom: 16px;
    font-size: 0.8rem; font-weight: 500; display: none;
}
.ca-message.ok { background: rgba(16,185,129,0.1); color: #6ee7b7; border: 1px solid rgba(16,185,129,0.3); display: block; }
.ca-message.err { background: rgba(239,68,68,0.1); color: #fca5a5; border: 1px solid rgba(239,68,68,0.3); display: block; }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content">

    <!-- Aksiyon Seridi -->
    <div class="ca-action-bar" id="caActionBar" data-no-proxy>
        <button type="button" class="ca-btn ca-btn--primary" id="caSaveBtn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            @(isEdit ? "Güncelle" : "Kaydet")
        </button>
        <button type="button" class="ca-btn ca-btn--secondary" onclick="caBackToList()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Liste
        </button>
        <span class="ca-meta" id="caMeta">
            @if (isEdit) {
                <strong>@existing!.AccountCode</strong> @:— @existing.AccountTitle
            }
        </span>
    </div>

    <div class="ca-body">

        <!-- Sol navigasyon -->
        <nav class="ca-sidenav" id="caSideNav" aria-label="Bolumler">
            <span class="ca-sidenav-label">Genel</span>
            <button type="button" class="ca-nav-btn is-active" data-nav-key="basic">
                <span class="ca-nav-dot"></span>
                Temel Bilgiler
            </button>
            <button type="button" class="ca-nav-btn" data-nav-key="contact">
                <span class="ca-nav-dot"></span>
                İletişim
            </button>
            <button type="button" class="ca-nav-btn" data-nav-key="addresses" id="caNavAddresses">
                <span class="ca-nav-dot"></span>
                Teslim Adresleri
                <span class="ca-nav-count" id="caAddressCount" style="display:none;">0</span>
            </button>
            <button type="button" class="ca-nav-btn" data-nav-key="movements" id="caNavMovements">
                <span class="ca-nav-dot"></span>
                Cari Hareket
                <span class="ca-nav-count" id="caMovementsCount" style="display:none;">0</span>
            </button>
            <!-- Widget grup butonlari JS tarafindan dinamik olarak eklenir -->
        </nav>

        <!-- Sag icerik alani -->
        <div class="ca-content" id="caContent">
            <div class="ca-message" id="caMsg"></div>

            <!-- Temel Bilgiler -->
            <div class="ca-card" id="caCardBasic" data-section="basic">
                <div class="ca-card__title">Temel Bilgiler</div>
                @{
                    var t = existing?.AccountType ?? 1;
                    var selectHtml =
                        "<select id=\"accountType\" name=\"accountType\" class=\"ca-select\" required>" +
                        "<option value=\"1\"" + (t == 1 ? " selected" : "") + ">Müşteri</option>" +
                        "<option value=\"2\"" + (t == 2 ? " selected" : "") + ">Satıcı</option>" +
                        "<option value=\"3\"" + (t == 3 ? " selected" : "") + ">Her İkisi</option>" +
                        "</select>";
                }
                <div class="ca-rows">
                    <div class="ca-row">
                        <label class="ca-label" for="accountType">Cari Tipi <span class="required">*</span></label>
                        @Html.Raw(selectHtml)
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="accountCode">Cari Kod <span class="required">*</span></label>
                        <input id="accountCode" name="accountCode" type="text" class="ca-input"
                               placeholder="Örn: CH001" maxlength="50"
                               value="@(existing?.AccountCode ?? "")" required />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="accountTitle">Ünvan <span class="required">*</span></label>
                        <input id="accountTitle" name="accountTitle" type="text" class="ca-input"
                               placeholder="Firma veya kişi ünvanı" maxlength="200"
                               value="@(existing?.AccountTitle ?? "")" required />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="taxOffice">Vergi Dairesi</label>
                        <input id="taxOffice" name="taxOffice" type="text" class="ca-input"
                               placeholder="Vergi dairesi adı" maxlength="100"
                               value="@(existing?.TaxOffice ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="taxNumber">Vergi Numarası</label>
                        <input id="taxNumber" name="taxNumber" type="text" class="ca-input"
                               placeholder="10 haneli VKN" maxlength="20"
                               value="@(existing?.TaxNumber ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="identityNumber">TC Kimlik No</label>
                        <input id="identityNumber" name="identityNumber" type="text" class="ca-input"
                               placeholder="11 haneli TCKN" maxlength="11"
                               value="@(existing?.IdentityNumber ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="salesRepresentativeId">Satış Temsilcisi</label>
                        <select id="salesRepresentativeId" name="salesRepresentativeId" class="ca-select"
                                data-selected="@(existing?.SalesRepresentativeId?.ToString() ?? "")">
                            <option value="">— Seçiniz —</option>
                        </select>
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="isActive">Durum</label>
                        <label class="ca-toggle" for="isActive" style="margin:0;">
                            <input type="checkbox" id="isActive" name="isActive"
                                   @(existing is null || existing.IsActive ? "checked" : "") />
                            <span class="ca-toggle-track"></span>
                        </label>
                        <span class="ca-toggle-label" style="margin-left:10px;">Cari hesap aktif</span>
                    </div>
                </div>
            </div>

            <!-- İletişim -->
            <div class="ca-card" id="caCardContact" data-section="contact" style="display:none;">
                <div class="ca-card__title">İletişim</div>
                <div class="ca-rows">
                    <div class="ca-row">
                        <label class="ca-label" for="contactPerson">İlgili Kişi</label>
                        <input id="contactPerson" name="contactPerson" type="text" class="ca-input"
                               placeholder="Ahmet Yılmaz" maxlength="150"
                               value="@(existing?.ContactPerson ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="phone">Telefon</label>
                        <input id="phone" name="phone" type="tel" class="ca-input"
                               placeholder="0212 000 00 00" maxlength="30"
                               value="@(existing?.Phone ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="mobile">Cep Telefonu</label>
                        <input id="mobile" name="mobile" type="tel" class="ca-input"
                               placeholder="0532 000 00 00" maxlength="30"
                               value="@(existing?.Mobile ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="email">E-Posta</label>
                        <input id="email" name="email" type="email" class="ca-input"
                               placeholder="info@@firma.com" maxlength="200"
                               value="@(existing?.Email ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="website">Web Sitesi</label>
                        <input id="website" name="website" type="url" class="ca-input"
                               placeholder="https://www.firma.com" maxlength="200"
                               value="@(existing?.Website ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="countryCode">Ülke Kodu</label>
                        <input id="countryCode" name="countryCode" type="text" class="ca-input"
                               placeholder="TR" maxlength="2"
                               style="text-transform:uppercase;max-width:120px;"
                               list="countryCodeOptions"
                               value="@(existing?.CountryCode ?? "")" />
                        <datalist id="countryCodeOptions">
                            <option value="TR">Türkiye</option>
                            <option value="US">Amerika</option>
                            <option value="DE">Almanya</option>
                            <option value="GB">İngiltere</option>
                            <option value="FR">Fransa</option>
                            <option value="IT">İtalya</option>
                            <option value="NL">Hollanda</option>
                            <option value="RU">Rusya</option>
                            <option value="CN">Çin</option>
                            <option value="JP">Japonya</option>
                            <option value="SA">Suudi Arabistan</option>
                            <option value="AE">Birleşik Arap Emirlikleri</option>
                            <option value="AZ">Azerbaycan</option>
                            <option value="IR">İran</option>
                            <option value="IQ">Irak</option>
                            <option value="SY">Suriye</option>
                            <option value="GR">Yunanistan</option>
                            <option value="BG">Bulgaristan</option>
                        </datalist>
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="city">İl</label>
                        <input id="city" name="city" type="text" class="ca-input"
                               list="cityList"
                               placeholder="İstanbul" maxlength="80"
                               value="@(existing?.City ?? "")" />
                        <datalist id="cityList"></datalist>
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="district">İlçe</label>
                        <input id="district" name="district" type="text" class="ca-input"
                               list="districtList"
                               placeholder="Kadıköy" maxlength="100"
                               value="@(existing?.District ?? "")" />
                        <datalist id="districtList"></datalist>
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="neighborhood">Mahalle</label>
                        <input id="neighborhood" name="neighborhood" type="text" class="ca-input"
                               list="neighborhoodList"
                               placeholder="Caferağa" maxlength="150"
                               value="@(existing?.Neighborhood ?? "")" />
                        <datalist id="neighborhoodList"></datalist>
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="address">Adres</label>
                        <input id="address" name="address" type="text" class="ca-input"
                               placeholder="Sokak, bina no, daire" maxlength="300"
                               value="@(existing?.Address ?? "")" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="postalCode">Posta Kodu</label>
                        <input id="postalCode" name="postalCode" type="text" class="ca-input"
                               placeholder="34000" maxlength="20" style="max-width:140px;"
                               value="@(existing?.PostalCode ?? "")" />
                    </div>
                </div>
            </div>

            <!-- Teslim Adresleri -->
            <div class="ca-card" id="caCardAddresses" data-section="addresses" style="display:none;">
                <div class="ca-card__title" style="display:flex;align-items:center;justify-content:space-between;gap:10px;">
                    <span>Teslim Adresleri</span>
                    <button type="button" class="ca-btn ca-btn--primary" id="caAddrAddBtn" style="font-size:.75rem;padding:6px 12px;">+ Yeni Adres</button>
                </div>
                <div id="caAddrEmpty" style="padding:20px;text-align:center;color:rgba(148,163,184,.7);font-size:.86rem;font-style:italic;">
                    Henuz adres tanimlanmamis. "+ Yeni Adres" ile ekleyebilirsiniz.
                </div>
                <div id="caAddrList" style="display:flex;flex-direction:column;gap:8px;"></div>

                <!-- Ekleme/duzenleme form'u (gizli) -->
                <div id="caAddrForm" style="display:none;margin-top:14px;padding:14px;border:1px solid rgba(148,163,184,.25);border-radius:10px;background:rgba(99,102,241,.04);">
                    <input type="hidden" id="caAddrEditId" value="" />
                    <div class="ca-row">
                        <label class="ca-label" for="caAddrName">Adres İsmi <span style="color:#f87171">*</span></label>
                        <input id="caAddrName" type="text" class="ca-input" placeholder="Merkez / Şube / Depo" maxlength="100" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="caAddrCountry">Ülke Kodu</label>
                        <input id="caAddrCountry" type="text" class="ca-input" value="TR" maxlength="2" style="max-width:100px;text-transform:uppercase;" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="caAddrCity">İl</label>
                        <input id="caAddrCity" type="text" class="ca-input" list="caAddrCityList" placeholder="İstanbul" maxlength="100" style="max-width:260px;" />
                        <datalist id="caAddrCityList"></datalist>
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="caAddrDistrict">İlçe</label>
                        <input id="caAddrDistrict" type="text" class="ca-input" list="caAddrDistrictList" placeholder="Kadıköy" maxlength="100" style="max-width:260px;" />
                        <datalist id="caAddrDistrictList"></datalist>
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="caAddrNeighborhood">Mahalle</label>
                        <input id="caAddrNeighborhood" type="text" class="ca-input" list="caAddrNgList" placeholder="Caferağa" maxlength="150" style="max-width:320px;" />
                        <datalist id="caAddrNgList"></datalist>
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="caAddrPostal">Posta Kodu</label>
                        <input id="caAddrPostal" type="text" class="ca-input" placeholder="34000" maxlength="10" style="max-width:140px;" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-label" for="caAddrLine">Açık Adres</label>
                        <input id="caAddrLine" type="text" class="ca-input" placeholder="Sokak, bina no, daire, vs." maxlength="500" />
                    </div>
                    <div class="ca-row">
                        <label class="ca-toggle" for="caAddrDefault">
                            <input type="checkbox" id="caAddrDefault" />
                            <span class="ca-toggle-track"></span>
                        </label>
                        <span class="ca-toggle-label">Varsayılan adres</span>
                    </div>
                    <div style="display:flex;gap:8px;margin-top:10px;">
                        <button type="button" class="ca-btn ca-btn--primary" id="caAddrSaveBtn">Kaydet</button>
                        <button type="button" class="ca-btn" id="caAddrCancelBtn">İptal</button>
                    </div>
                </div>
                <div id="caAddrNoData" style="display:none;margin-top:12px;padding:10px 12px;border-radius:8px;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);color:#f59e0b;font-size:.78rem;">
                    PTT posta kodu katalogu henuz yuklu degil — Ülke/İl/İlçe/Mahalle listeleri bos. Admin "Şirket Ayarları → Adres Kataloğu" bolumunden yukleyebilir.
                </div>
            </div>

            <!-- Cari Hareket -->
            <div class="ca-card" id="caCardMovements" data-section="movements" style="display:none;">
                <div class="ca-card__title">Cari Hareket</div>

                <!-- Filtre serisi -->
                <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);margin-bottom:14px;">
                    <label style="font-size:.75rem;color:rgba(148,163,184,.85);">Belge Tipi</label>
                    <select id="caMovDocType" class="ca-select" style="min-width:160px;max-width:220px;" onchange="caMovLoad()">
                        <option value="">Tümü</option>
                    </select>
                    <label style="font-size:.75rem;color:rgba(148,163,184,.85);">Başlangıç</label>
                    <input id="caMovFrom" type="date" class="ca-input" style="max-width:160px;" onchange="caMovLoad()" />
                    <label style="font-size:.75rem;color:rgba(148,163,184,.85);">Bitiş</label>
                    <input id="caMovTo" type="date" class="ca-input" style="max-width:160px;" onchange="caMovLoad()" />
                    <button type="button" class="ca-btn" onclick="caMovClearFilters()" style="font-size:.74rem;padding:6px 12px;">Temizle</button>
                </div>

                <div id="caMovEmpty" style="padding:20px;text-align:center;color:rgba(148,163,184,.7);font-size:.86rem;font-style:italic;">
                    Seçili kriterlere uygun hareket yok.
                </div>
                <div id="caMovList" style="display:flex;flex-direction:column;gap:8px;"></div>
            </div>

            @* Ek Alanlar — DynamicWidgetRenderer gruplari buraya render edilir. *@
            <div id="caDynamicWidgetsCard" style="display:none">
                <div id="caDynamicWidgets"
                     data-form-code="CONTACTS"
                     data-record-id="@(existing?.Id.ToString() ?? string.Empty)">
                </div>
            </div>

        </div>

    </div>

    <input type="hidden" id="caId" value="@(existing?.Id.ToString() ?? "")" />

</section>

@section Scripts {
<script>
(function () {
    var UPSERT_URL  = '@Html.Raw(upsertUrl)';
    var LIST_URL    = '@Html.Raw(listUrl)';
    var existingId  = document.getElementById('caId').value;

    var saveBtn = document.getElementById('caSaveBtn');

    // Bilgilendirme: ekranda yer kaplamayan, ortalanmis modal kullan.
    // Basari durumunda zaten KITT yesil tarayici var, ek mesaj cikmasin.
    function showMsg(text, ok) {
        if (ok) return; // basari mesajini bastir
        if (window.CalibraAlert && CalibraAlert.error) {
            CalibraAlert.error(text);
            return;
        }
        // Fallback (CalibraAlert yuklenmemisse) — eski davranis
        return showMsgLegacy(text, ok);
    }
    function showMsgLegacy(text, ok) {
        var m = document.getElementById('caMsg');
        m.textContent = text;
        m.className = 'ca-message ' + (ok ? 'ok' : 'err');
        setTimeout(function () { m.className = 'ca-message'; m.textContent = ''; }, 4000);
    }

    // K.I.T.T. yesil tarayici (aksiyon seridi alti) — basariyla kayit edilince
    function flashSuccess() {
        var bar = document.getElementById('caActionBar');
        if (!bar) return;
        bar.classList.remove('is-save-flash');
        void bar.offsetWidth;
        bar.classList.add('is-save-flash');
        setTimeout(function () { bar.classList.remove('is-save-flash'); }, 1850);
        try { if (window.CalibraDirty) window.CalibraDirty.clear(); } catch (e) {}
    }

    function markInvalid(ids) {
        ids.forEach(function (id) {
            var el = document.getElementById(id);
            if (!el) return;
            el.classList.remove('is-invalid');
            void el.offsetWidth;
            el.classList.add('is-invalid');
            var clear = function () {
                el.classList.remove('is-invalid');
                el.removeEventListener('input', clear);
                el.removeEventListener('change', clear);
            };
            el.addEventListener('input', clear);
            el.addEventListener('change', clear);
        });
        var first = document.getElementById(ids[0]);
        if (first) first.focus({ preventScroll: false });
    }

    window.caBackToList = function () {
        var url = LIST_URL;
        if (location.search.indexOf('workspace=1') !== -1 && url.indexOf('workspace=1') === -1) {
            url += (url.indexOf('?') !== -1 ? '&' : '?') + 'workspace=1';
        }
        location.replace(url);
    };

    function getVal(id) {
        var el = document.getElementById(id);
        return el ? el.value.trim() : '';
    }

    saveBtn.addEventListener('click', function () {
        var accountCode  = getVal('accountCode');
        var accountTitle = getVal('accountTitle');
        var accountType  = parseInt(getVal('accountType'), 10);

        var invalidIds = [];
        if (!accountCode)  invalidIds.push('accountCode');
        if (!accountTitle) invalidIds.push('accountTitle');

        // Hata varsa ilgili bolume git
        if (invalidIds.length > 0) {
            if (window.caNavigateToSection) window.caNavigateToSection('basic');
            markInvalid(invalidIds);
            return;
        }

        // Ek alan (widget) zorunlu kontrolu
        var allValid = true;
        if (window._caDynRenderer && window._caDynRenderer.validate) {
            var dynValidation = window._caDynRenderer.validate();
            if (!dynValidation.valid) {
                allValid = false;
                var firstErrId = (dynValidation.errorIds || [])[0];
                if (firstErrId && window.caNavigateToSection) {
                    var errEl = document.querySelector('[data-widget-code="' + firstErrId + '"]');
                    if (errEl) {
                        var grpEl = errEl.closest('[data-dyn-group-id]');
                        var gid   = grpEl ? grpEl.getAttribute('data-dyn-group-id') : null;
                        if (gid) window.caNavigateToSection(gid);
                    }
                }
            }
        }
        if (!allValid) return;

        var payload = {
            id:             existingId ? parseInt(existingId, 10) : null,
            accountType:    accountType || 1,
            accountCode:    accountCode,
            accountTitle:   accountTitle,
            taxNumber:      getVal('taxNumber')      || null,
            identityNumber: getVal('identityNumber') || null,
            taxOffice:      getVal('taxOffice')      || null,
            contactPerson:  getVal('contactPerson')  || null,
            phone:          getVal('phone')          || null,
            mobile:         getVal('mobile')         || null,
            email:          getVal('email')          || null,
            website:        getVal('website')        || null,
            address:        getVal('address')        || null,
            postalCode:     getVal('postalCode')     || null,
            city:           getVal('city')           || null,
            district:       getVal('district')       || null,
            neighborhood:   getVal('neighborhood')   || null,
            countryCode:    (getVal('countryCode') || '').toUpperCase() || null,
            isActive:       document.getElementById('isActive').checked,
            priceGroupId:   null,
            salesRepresentativeId: (function() {
                var v = document.getElementById('salesRepresentativeId');
                var n = v ? parseInt(v.value, 10) : 0;
                return n > 0 ? n : null;
            })()
        };

        saveBtn.classList.add('loading');
        saveBtn.disabled = true;

        fetch(UPSERT_URL, {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body:    JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (!(data && data.success)) {
                saveBtn.classList.remove('loading');
                saveBtn.disabled = false;
                showMsg('Hata: ' + (data && data.message ? data.message : 'Bilinmeyen hata.'), false);
                return;
            }

            var newRecordId = String((data.account && data.account.id) || document.getElementById('caId').value || '');
            var dynPromise = (window._caDynRenderer && newRecordId)
                ? window._caDynRenderer.save({ recordId: newRecordId })
                    .catch(function (err) {
                        console.warn('[CA] widget save hatasi:', err);
                        return { success: false, message: err.message };
                    })
                : Promise.resolve({ success: true });

            dynPromise.then(function (dynRes) {
                saveBtn.classList.remove('loading');
                saveBtn.disabled = false;
                if (dynRes && dynRes.success === false) {
                    console.warn('[CA] widget save basarisiz:', dynRes.message);
                }
                // Sadece KITT yesil tarayici — text bildirim yok, otomatik redirect yok.
                flashSuccess();
            });
        })
        .catch(function (err) {
            saveBtn.classList.remove('loading');
            saveBtn.disabled = false;
            showMsg('Bağlantı hatası: ' + err.message, false);
        });
    });

    // ── Sidebar navigasyon — tab-panel modeli ─────────────────────────
    (function initSideNav() {
        var sidenav = document.getElementById('caSideNav');
        var content = document.getElementById('caContent');
        var dynCard = document.getElementById('caDynamicWidgetsCard');
        if (!sidenav || !content) return;

        var _activeKey = 'basic';

        function setActive(btn) {
            sidenav.querySelectorAll('.ca-nav-btn').forEach(function (b) {
                b.classList.remove('is-active');
            });
            if (btn) btn.classList.add('is-active');
        }

        function activateSection(key) {
            _activeKey = key;

            // Statik kartlar
            content.querySelectorAll('[data-section]').forEach(function (card) {
                card.style.display = (card.getAttribute('data-section') === key) ? '' : 'none';
            });

            // Dinamik widget gruplari
            content.querySelectorAll('[data-dyn-group-id]').forEach(function (d) {
                d.style.display = (d.getAttribute('data-dyn-group-id') === key) ? 'block' : 'none';
            });
        }

        // Statik nav butonlari — data-nav-key ile eslestir
        sidenav.querySelectorAll('.ca-nav-btn[data-nav-key]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                setActive(btn);
                activateSection(btn.getAttribute('data-nav-key'));
            });
        });

        // Widget gruplarini tarayip nav butonlari olustur
        function buildGroupNav() {
            sidenav.querySelectorAll('[data-group-nav]').forEach(function (el) { el.remove(); });

            var groups = content.querySelectorAll('[data-dyn-group-id]');
            if (!groups.length) return;

            var lbl = document.createElement('span');
            lbl.className = 'ca-sidenav-label';
            lbl.setAttribute('data-group-nav', '__label');
            lbl.textContent = 'Ek Sahalar';
            sidenav.appendChild(lbl);

            groups.forEach(function (detail) {
                var gid   = detail.getAttribute('data-dyn-group-id') || '';
                var title = detail.getAttribute('data-dyn-group-label') || 'Grup';

                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'ca-nav-btn';
                btn.setAttribute('data-group-nav', gid);
                btn.title = title;
                btn.innerHTML =
                    '<span class="ca-nav-dot"></span>' +
                    '<span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0">' +
                    title + '</span>';

                btn.addEventListener('click', function () {
                    setActive(btn);
                    activateSection(gid);
                });

                sidenav.appendChild(btn);
            });

            activateSection(_activeKey);
        }

        // DynamicWidgetsCard icinde data-dyn-group-id elementleri belirince nav'i yenile
        if (dynCard) {
            var _t = null;
            function scheduleScan() {
                clearTimeout(_t);
                _t = setTimeout(function () {
                    var groups = content.querySelectorAll('[data-dyn-group-id]');
                    if (groups.length > 0) {
                        buildGroupNav();
                    } else {
                        var tries = (scheduleScan._n = (scheduleScan._n || 0) + 1);
                        if (tries < 80) scheduleScan();
                        else scheduleScan._n = 0;
                    }
                }, 50);
            }

            var _obs = new MutationObserver(function () { scheduleScan(); });
            _obs.observe(dynCard, { childList: true, subtree: true, attributes: true,
                                    attributeFilter: ['style', 'data-dyn-group-id'] });
            if (dynCard.parentElement) {
                _obs.observe(dynCard.parentElement, { childList: false, subtree: false,
                                                      attributes: true, attributeFilter: ['style'] });
            }
        }

        // Baslangic: Temel Bilgiler aktif
        activateSection('basic');

        // Dis erisim: save validasyonu hata bolumune gidebilsin
        window.caNavigateToSection = function (key) {
            var navBtn = sidenav.querySelector('[data-nav-key="' + key + '"]') ||
                         sidenav.querySelector('[data-group-nav="' + key + '"]');
            setActive(navBtn || null);
            activateSection(key);
        };
    })();

    // ── Ek alanlar renderer'ini mount et (WidgetMas/WidgetTra) ──
    (function initDynRenderer() {
        var el = document.getElementById('caDynamicWidgets');
        if (!el) return;

        function doMount() {
            if (!window.CalibraHub || !window.CalibraHub.mountDynamicWidgetRenderer) {
                console.warn('[CA] mountDynamicWidgetRenderer bulunamadi');
                return;
            }
            try {
                window._caDynRenderer = window.CalibraHub.mountDynamicWidgetRenderer(el, {
                    formCode: el.getAttribute('data-form-code') || 'CONTACTS',
                    recordId: el.getAttribute('data-record-id') || '',
                    classPrefix: 'ca',
                    containerId: 'caDynamicWidgetsCard'
                });
            } catch (e) { console.warn('[CA] mountDynamicWidgetRenderer hatasi:', e); }
        }

        if (window.CalibraHub && window.CalibraHub.mountDynamicWidgetRenderer) {
            doMount();
        } else {
            var cssUrl = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
            var jsUrl  = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';

            if (!document.querySelector('link[data-ca-bundle]')) {
                var link = document.createElement('link');
                link.rel = 'stylesheet'; link.href = cssUrl;
                link.setAttribute('data-ca-bundle', '1');
                document.head.appendChild(link);
            }

            if (!document.querySelector('script[data-ca-bundle]')) {
                var script = document.createElement('script');
                script.src = jsUrl;
                script.setAttribute('data-ca-bundle', '1');
                script.onload = function () { setTimeout(doMount, 0); };
                script.onerror = function () { console.error('[CA] Bundle yuklenemedi'); };
                document.head.appendChild(script);
            }
        }
    })();

    // ══════════════════════════════════════════════════════════════
    // İletişim sekmesi — ana adres alanlarinda PTT cascade dropdown
    // ══════════════════════════════════════════════════════════════
    (function () {
        function gid(id) { return document.getElementById(id); }
        var ctyEl  = gid('city');
        var distEl = gid('district');
        var ngEl   = gid('neighborhood');
        var pkEl   = gid('postalCode');
        var ccEl   = gid('countryCode');
        if (!ctyEl) return;

        var ngPostalCache = {};

        async function loadCities() {
            var country = ((ccEl && ccEl.value) || 'TR').toUpperCase();
            try {
                var r = await fetch('/Address/Cities?countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
                var data = await r.json();
                var dl = gid('cityList');
                if (dl) dl.innerHTML = (data || []).map(function (c) { return '<option value="' + c + '">'; }).join('');
            } catch (e) { /* sessizce gec */ }
        }

        async function loadDistricts() {
            var city = (ctyEl.value || '').trim();
            if (!city) { gid('districtList').innerHTML = ''; return; }
            var country = ((ccEl && ccEl.value) || 'TR').toUpperCase();
            try {
                var r = await fetch('/Address/Districts?city=' + encodeURIComponent(city) + '&countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
                var data = await r.json();
                gid('districtList').innerHTML = (data || []).map(function (d) { return '<option value="' + d + '">'; }).join('');
            } catch (e) { /* sessizce gec */ }
        }

        async function loadNeighborhoods() {
            var city = (ctyEl.value || '').trim();
            var dist = (distEl.value || '').trim();
            if (!city || !dist) { gid('neighborhoodList').innerHTML = ''; return; }
            var country = ((ccEl && ccEl.value) || 'TR').toUpperCase();
            try {
                var r = await fetch('/Address/Neighborhoods?city=' + encodeURIComponent(city) + '&district=' + encodeURIComponent(dist) + '&countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
                var data = await r.json();
                ngPostalCache = (data || []).reduce(function (acc, x) { acc[x.name] = x.postalCode; return acc; }, {});
                gid('neighborhoodList').innerHTML = (data || []).map(function (n) {
                    return '<option value="' + n.name + '">' + (n.postalCode ? '(' + n.postalCode + ')' : '') + '</option>';
                }).join('');
            } catch (e) { /* sessizce gec */ }
        }

        function autofillPostal() {
            var ng = (ngEl.value || '').trim();
            if (ng && ngPostalCache[ng] && !pkEl.value) pkEl.value = ngPostalCache[ng];
        }

        // Event'ler
        if (ccEl) ccEl.addEventListener('change', function () {
            ctyEl.value = ''; distEl.value = ''; ngEl.value = ''; pkEl.value = '';
            loadCities();
        });
        ctyEl.addEventListener('change', function () {
            distEl.value = ''; ngEl.value = ''; pkEl.value = '';
            loadDistricts();
        });
        distEl.addEventListener('change', function () {
            ngEl.value = ''; pkEl.value = '';
            loadNeighborhoods();
        });
        ngEl.addEventListener('change', autofillPostal);

        // Ilk yukleme — sehir listesi (ulke kodu varsa)
        loadCities();
        if (ctyEl.value) loadDistricts();
        if (distEl.value) loadNeighborhoods();
    })();

    // ══════════════════════════════════════════════════════════════
    // Cari Hareket — cariye ait tum belgeler (filtreli)
    // ══════════════════════════════════════════════════════════════
    (function () {
        function gid(id) { return document.getElementById(id); }
        var contactIdStr = gid('caId') ? gid('caId').value : '';
        var contactId = parseInt(contactIdStr, 10) || 0;

        var statusLabels = {
            Draft: 'Taslak', Sent: 'Gönderildi', Approved: 'Onaylandı',
            Rejected: 'Reddedildi', Revised: 'Revize', Cancelled: 'İptal'
        };

        function fmtMoney(n) {
            return (n || 0).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        function fmtDate(s) {
            if (!s) return '';
            try { return new Date(s).toLocaleDateString('tr-TR'); } catch (e) { return s; }
        }
        function escH(s) {
            return String(s == null ? '' : s).replace(/[&<>"']/g, function (ch) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
            });
        }

        async function loadDocTypes() {
            try {
                var r = await fetch('/Finance/GetDocumentTypes', { credentials: 'same-origin' });
                var data = await r.json();
                var sel = gid('caMovDocType');
                if (!sel) return;
                (data || []).forEach(function (t) {
                    var opt = document.createElement('option');
                    opt.value = String(t.id);
                    opt.textContent = t.name;
                    sel.appendChild(opt);
                });
            } catch (e) { console.warn('[CA] Belge tipleri yuklenemedi:', e); }
        }

        window.caMovClearFilters = function() {
            var dt = gid('caMovDocType'); if (dt) dt.value = '';
            var f = gid('caMovFrom'); if (f) f.value = '';
            var t = gid('caMovTo'); if (t) t.value = '';
            caMovLoad();
        };

        window.caMovLoad = async function () {
            if (contactId <= 0) return;
            try {
                var docType = gid('caMovDocType') ? gid('caMovDocType').value : '';
                var from = gid('caMovFrom') ? gid('caMovFrom').value : '';
                var to   = gid('caMovTo') ? gid('caMovTo').value : '';
                var url = '/Finance/GetContactMovements?contactId=' + contactId;
                if (docType) url += '&documentTypeId=' + encodeURIComponent(docType);
                if (from)    url += '&fromDate='       + encodeURIComponent(from);
                if (to)      url += '&toDate='         + encodeURIComponent(to);
                var r = await fetch(url, { credentials: 'same-origin' });
                var rows = await r.json();
                var host = gid('caMovList');
                var empty = gid('caMovEmpty');
                var cnt = gid('caMovementsCount');
                host.innerHTML = '';
                if (!rows || rows.length === 0) {
                    empty.style.display = '';
                    if (cnt) cnt.style.display = 'none';
                    return;
                }
                empty.style.display = 'none';
                if (cnt) { cnt.textContent = String(rows.length); cnt.style.display = ''; }
                rows.forEach(function (q) {
                    var a = document.createElement('a');
                    a.href = '/Sales/DocumentEdit?id=' + q.id + (location.search.indexOf('workspace=1') !== -1 ? '&workspace=1' : '');
                    a.className = 'ca-quote-row';
                    var typeLbl = q.documentTypeName ? '<span class="ca-quote-date" style="color:#a5b4fc;font-weight:600;">' + escH(q.documentTypeName) + '</span>' : '';
                    a.innerHTML =
                        typeLbl
                        + '<span class="ca-quote-no">' + escH(q.documentNumber) + '</span>'
                        + '<span class="ca-quote-date">' + escH(fmtDate(q.documentDate)) + '</span>'
                        + '<span class="ca-quote-date">' + (q.lineCount || 0) + ' kalem</span>'
                        + '<span class="ca-quote-total">' + fmtMoney(q.grandTotal) + ' ' + escH(q.currency || 'TRY') + '</span>'
                        + '<span class="ca-quote-status ca-quote-status--' + escH(q.status) + '">' + escH(statusLabels[q.status] || q.status) + '</span>';
                    host.appendChild(a);
                });
            } catch (e) { console.warn('[CA] Cari hareket listesi yuklenemedi:', e); }
        };

        document.addEventListener('DOMContentLoaded', function() {
            loadDocTypes();
            if (contactId > 0) caMovLoad();
        });
    })();

    // ══════════════════════════════════════════════════════════════
    // Satis Temsilcisi dropdown — Temel Bilgiler kartinda
    // ══════════════════════════════════════════════════════════════
    (function () {
        var sel = document.getElementById('salesRepresentativeId');
        if (!sel) return;
        var preselect = sel.getAttribute('data-selected') || '';
        fetch('/Finance/GetSalesRepsList', { credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                (data || []).forEach(function (rep) {
                    var opt = document.createElement('option');
                    opt.value = String(rep.id);
                    opt.textContent = (rep.code ? rep.code + ' — ' : '') + rep.name;
                    if (preselect && String(rep.id) === preselect) opt.selected = true;
                    sel.appendChild(opt);
                });
            })
            .catch(function (e) { console.warn('[CA] Satis temsilcisi listesi yuklenemedi:', e); });
    })();

    // ══════════════════════════════════════════════════════════════
    // Teslim Adresleri — cascade dropdown + CRUD
    // ══════════════════════════════════════════════════════════════
    var caAddrContactId = parseInt(document.getElementById('caId').value || '0', 10) || 0;
    var caAddrCatalogEmpty = false;

    function qs(id) { return document.getElementById(id); }

    async function caAddrLoadCities() {
        try {
            var country = (qs('caAddrCountry').value || 'TR').toUpperCase();
            var r = await fetch('/Address/Cities?countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
            var data = await r.json();
            var dl = qs('caAddrCityList');
            dl.innerHTML = (data || []).map(function (c) { return '<option value="' + c + '">'; }).join('');
            if (!data || data.length === 0) {
                caAddrCatalogEmpty = true;
                qs('caAddrNoData').style.display = '';
            }
        } catch (e) { console.warn('[CA] Sehir yuklenemedi:', e); }
    }

    async function caAddrLoadDistricts() {
        var city = (qs('caAddrCity').value || '').trim();
        if (!city) { qs('caAddrDistrictList').innerHTML = ''; return; }
        var country = (qs('caAddrCountry').value || 'TR').toUpperCase();
        try {
            var r = await fetch('/Address/Districts?city=' + encodeURIComponent(city) + '&countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
            var data = await r.json();
            qs('caAddrDistrictList').innerHTML = (data || []).map(function (d) { return '<option value="' + d + '">'; }).join('');
        } catch (e) { console.warn('[CA] Ilce yuklenemedi:', e); }
    }

    async function caAddrLoadNeighborhoods() {
        var city = (qs('caAddrCity').value || '').trim();
        var district = (qs('caAddrDistrict').value || '').trim();
        if (!city || !district) { qs('caAddrNgList').innerHTML = ''; return; }
        var country = (qs('caAddrCountry').value || 'TR').toUpperCase();
        try {
            var r = await fetch('/Address/Neighborhoods?city=' + encodeURIComponent(city) + '&district=' + encodeURIComponent(district) + '&countryCode=' + encodeURIComponent(country), { credentials: 'same-origin' });
            var data = await r.json();
            // Mahalle seciminde posta kodu otomatik dolsun diye cache'le
            window.__caNgCache = (data || []).reduce(function (acc, x) { acc[x.name] = x.postalCode; return acc; }, {});
            qs('caAddrNgList').innerHTML = (data || []).map(function (n) {
                return '<option value="' + n.name + '">' + (n.postalCode ? '(' + n.postalCode + ')' : '') + '</option>';
            }).join('');
        } catch (e) { console.warn('[CA] Mahalle yuklenemedi:', e); }
    }

    function caAddrAutofillPostal() {
        var ng = (qs('caAddrNeighborhood').value || '').trim();
        if (ng && window.__caNgCache && window.__caNgCache[ng] && !qs('caAddrPostal').value) {
            qs('caAddrPostal').value = window.__caNgCache[ng];
        }
    }

    async function caAddrLoadList() {
        if (caAddrContactId <= 0) { qs('caAddrList').innerHTML = ''; qs('caAddrEmpty').style.display = ''; return; }
        try {
            var r = await fetch('/Address/ByContact?contactId=' + caAddrContactId, { credentials: 'same-origin' });
            var rows = await r.json();
            var host = qs('caAddrList');
            host.innerHTML = '';
            if (!rows || rows.length === 0) {
                qs('caAddrEmpty').style.display = '';
                qs('caAddressCount').style.display = 'none';
                return;
            }
            qs('caAddrEmpty').style.display = 'none';
            qs('caAddressCount').textContent = String(rows.length);
            qs('caAddressCount').style.display = '';
            rows.forEach(function (a) {
                var loc = [a.countryCode, a.cityName, a.districtName, a.neighborhoodName].filter(Boolean).join(' / ');
                var card = document.createElement('div');
                card.className = 'ca-addr-card';
                card.innerHTML =
                    '<div class="ca-addr-card__main">'
                    + '<div class="ca-addr-card__name">' + escapeHtml(a.name) + (a.isDefault ? ' <span class="ca-addr-default-tag">★ Varsayılan</span>' : '') + '</div>'
                    + '<div class="ca-addr-card__loc">' + escapeHtml(loc) + (a.postalCode ? ' · ' + escapeHtml(a.postalCode) : '') + '</div>'
                    + (a.addressLine ? '<div class="ca-addr-card__line">' + escapeHtml(a.addressLine) + '</div>' : '')
                    + '</div>'
                    + '<button type="button" class="ca-btn ca-btn--secondary" data-edit="' + a.id + '" style="padding:6px 12px;font-size:.76rem;">Düzenle</button>'
                    + '<button type="button" class="ca-btn ca-btn--danger" data-del="' + a.id + '" style="padding:6px 12px;font-size:.76rem;">Sil</button>';
                host.appendChild(card);
                card.querySelector('[data-edit]').addEventListener('click', function () { caAddrEdit(a); });
                card.querySelector('[data-del]').addEventListener('click', function () { caAddrDelete(a.id); });
            });
        } catch (e) { console.warn('[CA] Adres listesi yuklenemedi:', e); }
    }

    function caAddrEdit(a) {
        qs('caAddrEditId').value = a.id || '';
        qs('caAddrName').value = a.name || '';
        qs('caAddrCountry').value = a.countryCode || 'TR';
        qs('caAddrCity').value = a.cityName || '';
        qs('caAddrDistrict').value = a.districtName || '';
        qs('caAddrNeighborhood').value = a.neighborhoodName || '';
        qs('caAddrPostal').value = a.postalCode || '';
        qs('caAddrLine').value = a.addressLine || '';
        qs('caAddrDefault').checked = !!a.isDefault;
        qs('caAddrForm').style.display = '';
        caAddrLoadCities();
        caAddrLoadDistricts();
        caAddrLoadNeighborhoods();
    }

    function caAddrResetForm() {
        qs('caAddrEditId').value = '';
        qs('caAddrName').value = '';
        qs('caAddrCountry').value = 'TR';
        qs('caAddrCity').value = '';
        qs('caAddrDistrict').value = '';
        qs('caAddrNeighborhood').value = '';
        qs('caAddrPostal').value = '';
        qs('caAddrLine').value = '';
        qs('caAddrDefault').checked = false;
    }

    async function caAddrSave() {
        var name = (qs('caAddrName').value || '').trim();
        if (!name) { if (window.CalibraAlert) CalibraAlert.warning('Adres ismi zorunludur.'); return; }
        if (caAddrContactId <= 0) { if (window.CalibraAlert) CalibraAlert.warning('Önce cari kartı kaydediniz.'); return; }
        var id = parseInt(qs('caAddrEditId').value || '0', 10) || 0;
        var payload = {
            id: id > 0 ? id : null,
            contactId: caAddrContactId,
            name: name,
            countryCode: (qs('caAddrCountry').value || 'TR').toUpperCase(),
            cityName: qs('caAddrCity').value || null,
            districtName: qs('caAddrDistrict').value || null,
            neighborhoodName: qs('caAddrNeighborhood').value || null,
            postalCode: qs('caAddrPostal').value || null,
            addressLine: qs('caAddrLine').value || null,
            isDefault: qs('caAddrDefault').checked
        };
        try {
            var r = await fetch('/Address/SaveAddress', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify(payload)
            });
            var data = await r.json();
            if (!data.success) { if (window.CalibraAlert) CalibraAlert.error(data.message || 'Kaydedilemedi'); return; }
            qs('caAddrForm').style.display = 'none';
            caAddrResetForm();
            await caAddrLoadList();
        } catch (e) { if (window.CalibraAlert) CalibraAlert.error('Kaydetme hatası: ' + e.message); }
    }

    async function caAddrDelete(id) {
        if (window.CalibraAlert && CalibraAlert.confirm) {
            var ok = await CalibraAlert.confirm('Bu adres silinsin mi?', { title: 'Adres Sil', okText: 'Evet, Sil', cancelText: 'İptal', danger: true });
            if (!ok) return;
        }
        try {
            var r = await fetch('/Address/DeleteAddress', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ id: id })
            });
            var data = await r.json();
            if (!data.success) { if (window.CalibraAlert) CalibraAlert.error(data.message || 'Silinemedi'); return; }
            await caAddrLoadList();
        } catch (e) { if (window.CalibraAlert) CalibraAlert.error('Silme hatası: ' + e.message); }
    }

    function escapeHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (ch) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
        });
    }

    // Baglama — DOM hazir oldugunda
    document.addEventListener('DOMContentLoaded', function () {
        var addBtn = qs('caAddrAddBtn');
        var cancelBtn = qs('caAddrCancelBtn');
        var saveBtn = qs('caAddrSaveBtn');
        if (addBtn) addBtn.addEventListener('click', function () {
            caAddrResetForm();
            qs('caAddrForm').style.display = '';
            caAddrLoadCities();
        });
        if (cancelBtn) cancelBtn.addEventListener('click', function () {
            qs('caAddrForm').style.display = 'none';
            caAddrResetForm();
        });
        if (saveBtn) saveBtn.addEventListener('click', caAddrSave);

        // Cascade event'leri
        var cityEl = qs('caAddrCity');
        var distEl = qs('caAddrDistrict');
        var ngEl   = qs('caAddrNeighborhood');
        if (cityEl) cityEl.addEventListener('change', function () {
            distEl.value = ''; ngEl.value = ''; qs('caAddrPostal').value = '';
            caAddrLoadDistricts();
        });
        if (distEl) distEl.addEventListener('change', function () {
            ngEl.value = ''; qs('caAddrPostal').value = '';
            caAddrLoadNeighborhoods();
        });
        if (ngEl) ngEl.addEventListener('change', caAddrAutofillPostal);

        // Ilk yuklemede (contact varsa) listeyi getir
        if (caAddrContactId > 0) caAddrLoadList();
    });
})();
</script>
}
