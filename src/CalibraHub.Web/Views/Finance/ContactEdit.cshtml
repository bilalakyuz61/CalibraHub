            </div>

            <!-- Cari Hareket -->
            <div class="ca-card" id="caCardMovements" data-section="movements" style="display:none;">
                <div class="ca-card__title">Cari Hareket</div>

                <!-- Filtre serisi -->
                <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);margin-bottom:14px;">
                    <label style="font-size:.75rem;color:rgba(148,163,184,.85);">Belge Tipi</label>
                    <select id="caMovDocType" class="ca-select" style="min-width:160px;max-width:220px;" onchange="caMovLoad()">
