                        <tbody id="caItemRows"></tbody>
                    </table>
                </div>

                <div id="caItemEmpty" style="padding:18px;text-align:center;color:rgba(148,163,184,.7);font-size:.84rem;font-style:italic;">
                    Henüz stok eşleştirmesi yok. "+ Yeni Satır" ile ekleyebilirsiniz.
                </div>

                <div id="caItemNoContact" style="display:none;margin:12px 14px;padding:10px 12px;border-radius:8px;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);color:#f59e0b;font-size:.78rem;">
                    Önce cari kart bilgilerini kaydediniz — eşleştirme satırları cari kayıt edildikten sonra eklenebilir.
                </div>
            </div>

            <!-- İletişim Kişileri — Iletisim Bilgileri sekmesinin altinda; ayri nav butonu yok artik -->
            <div class="ca-card" id="caCardPersons" data-section="contact" style="display:none;">
                <div class="ca-card__title" style="display:flex;align-items:center;justify-content:space-between;gap:10px;">
                    <span>İletişim Kişileri</span>
                    <button type="button" class="ca-btn ca-btn--primary" id="cpAddBtn" style="font-size:.75rem;padding:6px 12px;">+ Kişi Ekle</button>
                </div>
                <div style="padding:6px 14px 4px 14px;font-size:.78rem;color:rgba(148,163,184,.85);">
                    Bu carideki yetkili kişiler (Satış Müdürü, Üretim Sorumlusu, CFO, CTO vb.). Telefon ve e-postaları belge gönderim akışlarında kullanılır.
                </div>

                <div id="cpNoContact" style="display:none;margin:12px 14px;padding:10px 12px;border-radius:8px;background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.25);color:#f59e0b;font-size:.78rem;">
                    Önce cari kart bilgilerini kaydediniz — iletişim kişileri cari kayıt edildikten sonra eklenebilir.
                </div>

                <div id="cpListWrap" style="padding:8px 14px 0 14px;overflow:auto;">
                    <table class="cp-grid" style="width:100%;border-collapse:separate;border-spacing:0;font-size:.82rem;">
                        <thead>
                            <tr>
                                <th class="cp-grid__th" style="width:36px;">#</th>
                                <th class="cp-grid__th" style="width:180px;">Ünvan</th>
                                <th class="cp-grid__th">Ad Soyad</th>
