@model CalibraHub.Web.Models.Finance.ContactsViewModel
@{
    ViewData["Title"] = "Cari Hesaplar";
    ViewData["FormCode"] = "CONTACTS";
    ViewData["BodyClass"] = "page-contact-accounts";
    ViewData["DbInfo"] = "<table style='width:100%;border-collapse:collapse;font-size:0.78rem;'>"
        + "<tr><td style='padding:6px 8px;font-weight:600;color:#2563eb;white-space:nowrap;'>contact_accounts</td><td style='padding:6px 8px;'>Cari hesap tanimlari (kod, unvan, vergi no, adres, telefon, e-posta, tip, durum)</td></tr>"
        + "</table>";
}

@section Styles {
<style>
    .page-contact-accounts .integrator-dashboard {
        height: 100% !important; min-height: 0 !important;
        padding: 0 !important; max-width: none !important;
        background: transparent !important; box-shadow: none !important;
        border: none !important; border-radius: 0 !important;
    }
    .page-contact-accounts .integrator-dashboard__content {
        display: flex !important; flex-direction: column !important;
        width: 100% !important; max-width: none !important;
        min-height: 0 !important; padding: 0 !important;
        margin: 0 !important; overflow: hidden !important;
    }
    .workspace-frame-body.page-contact-accounts .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column;
        overflow: hidden; padding: 0;
    }
    .workspace-frame-body.page-contact-accounts .integrator-dashboard {
        flex: 1 1 auto; min-height: 0; height: 100%;
    }

    /* ── Single page-level loader ── HTML render edilir edilmez gorunur,
       SmartBoard ilk fetch tamamlayincaya kadar kalir. SmartBoard'un kendi
       inline spinner'i bu sayfada GIZLI (cift gosterge olmasin). */
    .ca-loading-overlay {
        position: absolute; inset: 0; z-index: 50;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center; gap: 16px;
        background: rgba(12,15,26,.92);
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
        transition: opacity .35s ease;
    }
    body.app-theme-light .ca-loading-overlay { background: rgba(248,250,252,.92); }
    .ca-loading-overlay.is-hidden { opacity: 0; pointer-events: none; }

    .ca-loading-ring {
        width: 44px; height: 44px;
        border-radius: 50%;
        border: 3px solid rgba(99,102,241,.18);
        border-top-color: #6366f1;
        animation: caRingSpin 0.9s linear infinite;
    }
    @@keyframes caRingSpin { to { transform: rotate(360deg); } }
    .ca-loading-text {
        font-size: 12px; font-weight: 600;
        color: rgba(255,255,255,.55);
        letter-spacing: .04em;
    }
    body.app-theme-light .ca-loading-text { color: #64748b; }

    /* SmartBoard'un kendi inline loading spinner'ini gizle — sadece overlay */
    #reactSmartBoard .flex.items-center.justify-center.py-20 { display: none !important; }
</style>
}

<section class="integrator-dashboard integrator-dashboard--wide integrator-dashboard--compact integrator-dashboard__content" style="position:relative;">
    <div id="reactSmartBoard" style="flex:1 1 auto;min-height:0;overflow:hidden;"></div>

    <!-- Tek loading overlay — Razor render olur olmaz gorunur, SmartBoard
         ilk fetch tamamladiginda (onReady) kapatilir. -->
    <div class="ca-loading-overlay" id="caLoadingOverlay">
        <div class="ca-loading-ring"></div>
        <span class="ca-loading-text">Cariler yükleniyor…</span>
    </div>
</section>

@section Scripts {
<script>
(function () {
    var BUNDLE_URL = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
    var CSS_URL    = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
    // Combined payload endpoint — config + ilk sayfa verisi tek istek.
    // HTML response anlik (DB cagirisi yok), spinner hemen gorunur, bundle ve
    // veri PARALEL yuklenir (eskiden HTML render 3 sn DB bekliyordu).
    var PAYLOAD_URL = '/Finance/GetContactsInitialPayload';
    var el          = document.getElementById('reactSmartBoard');

    if (!el) { console.error('[CA] Mount element yok'); return; }

    function hideOverlay() {
        var overlay = document.getElementById('caLoadingOverlay');
        if (overlay) {
            overlay.classList.add('is-hidden');
            setTimeout(function () { if (overlay.parentNode) overlay.remove(); }, 400);
        }
    }

    function showError(msg) {
        hideOverlay();
        el.innerHTML =
            '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;' +
            'height:100%;min-height:400px;background:#0c0f1a;color:#f87171;font-size:14px;gap:12px;">' +
            '<div>' + msg + '</div>' +
            '<button onclick="location.reload()" style="padding:8px 20px;border-radius:8px;' +
            'border:1px solid #4f46e5;background:#6366f1;color:#fff;cursor:pointer;font-size:13px;">' +
            'Sayfayi Yenile</button></div>';
    }

    function doMount(config) {
        if (!config) { showError('Board config bulunamadi'); return; }
        if (!window.CalibraHub || !window.CalibraHub.mountSmartBoard) {
            showError('SmartBoard mount fonksiyonu bulunamadi');
            return;
        }
        try {
            // SmartBoard ilk fetch tamamlayinca hideOverlay'i tetikle
            var configWithReady = Object.assign({}, config, {
                onReady: hideOverlay
            });
            window.CalibraHub.mountSmartBoard(el, configWithReady);
            // Guvenlik: 8 saniye sonra hala overlay varsa kapat (donmasin)
            setTimeout(hideOverlay, 8000);
        } catch (ex) {
            console.error('[CA] Mount exception:', ex);
            showError('Mount hatasi: ' + (ex.message || ex));
        }
    }

    function loadCss() {
        if (document.querySelector('link[data-ca-smartboard]')) return;
        var link = document.createElement('link');
        link.rel  = 'stylesheet';
        link.href = CSS_URL;
        link.setAttribute('data-ca-smartboard', '1');
        document.head.appendChild(link);
    }

    function ensureBundle(cb) {
        if (window.CalibraHub && window.CalibraHub.mountSmartBoard) { cb(); return; }
        if (document.querySelector('script[data-ca-smartboard]')) {
            // Bundle yukleniyor, bekle
            var t = setInterval(function () {
                if (window.CalibraHub && window.CalibraHub.mountSmartBoard) { clearInterval(t); cb(); }
            }, 50);
            return;
        }
        var script = document.createElement('script');
        script.src = BUNDLE_URL;
        script.setAttribute('data-ca-smartboard', '1');
        script.onload  = function () { setTimeout(cb, 0); };
        script.onerror = function () { showError('Bundle yuklenemedi'); };
        document.head.appendChild(script);
    }

    // Bundle ve combined payload PARALEL yuklenir, ikisi de hazir olunca mount.
    // Bu sayede toplam bekleme = max(bundle, payload) yerine bundle+payload degil.
    loadCss();

    var bundleReady = false;
    var payloadData = null;
    var payloadError = null;

    function tryMount() {
        if (!bundleReady) return;
        if (payloadError) { showError(payloadError); return; }
        if (payloadData)  { doMount(payloadData); }
    }

    // Payload fetch — bundle ile paralel
    fetch(PAYLOAD_URL, { credentials: 'same-origin' })
        .then(function (r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function (data) { payloadData = data; tryMount(); })
        .catch(function (e) {
            payloadError = 'Veri yuklenemedi: ' + (e.message || e);
            console.error('[CA] Payload fetch error:', e);
            tryMount();
        });

    ensureBundle(function () {
        bundleReady = true;
        tryMount();
    });

    window.addEventListener('pageshow', function (e) {
        if (e.persisted) location.reload();
    });
})();
</script>
}
