@{
    ViewData["Title"] = "İçe Aktarım Sihirbazı";
    ViewData["FormCode"] = "DATA_IMPORT";
    ViewData["BodyClass"] = "page-data-import";
}

@section Styles {
<style>
    .workspace-frame-body.page-data-import .app-content-area--workspace-frame {
        height: 100dvh; display: flex; flex-direction: column; overflow: hidden; padding: 0;
    }
    #dataImportRoot { flex: 1 1 auto; min-height: 0; display: flex; flex-direction: column; height: 100%; }
</style>
}

<div id="dataImportRoot"></div>

@section Scripts {
<script>
(function () {
    var BUNDLE_URL = '/react/calibrahub-widgets.js?v=@(DateTime.UtcNow.Ticks)';
    var CSS_URL    = '/react/calibrahub-widgets.css?v=@(DateTime.UtcNow.Ticks)';
    var el = document.getElementById('dataImportRoot');

    function showError(msg) { if (el) el.innerHTML = '<div style="padding:24px;color:#dc2626;font-size:13px;">' + msg + '</div>'; }
    function loadCss() {
        if (document.querySelector('link[data-data-import]')) return;
        var link = document.createElement('link');
        link.rel = 'stylesheet'; link.href = CSS_URL; link.setAttribute('data-data-import', '1');
        document.head.appendChild(link);
    }
    function loadScript(cb) {
        var prev = document.querySelector('script[data-data-import]');
        if (prev) { prev.addEventListener('load', cb); return; }
        var s = document.createElement('script');
        s.src = BUNDLE_URL; s.setAttribute('data-data-import', '1');
        s.onload = function () { setTimeout(cb, 0); };
        s.onerror = function () { showError('React bundle yüklenemedi.'); };
        document.head.appendChild(s);
    }
    function doMount() {
        if (!window.CalibraHub || !window.CalibraHub.mountDataImport) { showError('mountDataImport bulunamadı.'); return; }
        window.CalibraHub.mountDataImport(el);
    }

    loadCss();
    if (window.CalibraHub && window.CalibraHub.mountDataImport) doMount();
    else loadScript(doMount);
})();
</script>
}
